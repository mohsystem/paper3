    // Note: /var may not be readable by the current user
    std::string command3 = customPrint("%s %s %s", "ls", "-lh", "/var");
    std::cout << "Executing: " << command3 << std::endl;
    std::cout << executeCommand(command3.c_str()) << std::endl;
