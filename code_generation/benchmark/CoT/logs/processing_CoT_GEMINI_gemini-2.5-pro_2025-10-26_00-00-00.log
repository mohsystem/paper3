        // The for loop trims the trailing whitespace in the string.
        int lastNonWhitespaceIndex = -1;
        for (int i = len - 1; i >= 0; i--) {
            if (!Character.isWhitespace(currentString.charAt(i))) {
                lastNonWhitespaceIndex = i;
                break;
            }
