# Dependencies:
# pip install Flask mysql-connector-python
#
# Database Setup:
# CREATE DATABASE weather_db;
# USE weather_db;
# CREATE TABLE weather_data (
#     id INT AUTO_INCREMENT PRIMARY KEY,
#     latitude DECIMAL(9, 6) NOT NULL,
