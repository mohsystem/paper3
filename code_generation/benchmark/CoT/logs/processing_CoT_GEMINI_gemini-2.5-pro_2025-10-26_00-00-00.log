        buy_order(conn, "MSFT", 15)
        buy_order(conn, "AMZN", 2)
        # Test case with a potentially malicious name to show safety
        buy_order(conn, "TSLA'); DROP TABLE orders; --", 1)
        print("--- Test Cases Finished ---\n")
        
