    // Test Case 1: Valid input
    std::cout << "Test 1: ";
    char* test1[] = {(char*)"program", (char*)"3", (char*)"zero", (char*)"one", (char*)"two", (char*)"three"};
    printArgumentAtIndex(6, test1); // Expected: one

    // Test Case 2: Index out of bounds (too high)
