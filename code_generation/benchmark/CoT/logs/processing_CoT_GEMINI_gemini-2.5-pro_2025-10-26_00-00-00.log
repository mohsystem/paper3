        // --- Test Case Cleanup ---
        try {
            Files.deleteIfExists(Paths.get("test1.txt"));
            Files.deleteIfExists(Paths.get("test2.jpg"));
            Files.deleteIfExists(Paths.get("test3.txt"));
        } catch (IOException e) {
            System.err.println("Failed to clean up test files: " + e.getMessage());
        }
    }
}
