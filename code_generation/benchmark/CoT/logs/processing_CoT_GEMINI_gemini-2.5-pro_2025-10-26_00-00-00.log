        std::cout << "Failed." << std::endl;
    }
    std::cout << "--------------------" << std::endl;

    // Test Case 4: Writing an empty string to a file
    std::cout << "Test Case 4: Writing to 'empty_file.txt'" << std::endl;
    if (writeToFile("empty_file.txt", "")) {
        std::cout << "Success." << std::endl;
