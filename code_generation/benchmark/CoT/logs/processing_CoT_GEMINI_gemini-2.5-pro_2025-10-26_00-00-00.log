            os.close();
        }

        /**
         * A simple HTML escaping function to mitigate XSS.
         * In a real application, use a library like Apache Commons Text.
         */
        private String escapeHtml(String data) {
            if (data == null) {
                return "";
            }
            return data.replace("&", "&amp;")
                       .replace("<", "&lt;")
                       .replace(">", "&gt;")
                       .replace("\"", "&quot;")
                       .replace("'", "&#x27;");
        }
    }
}
