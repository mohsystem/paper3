        }

        byte[] bytes1 = s1.getBytes();
        byte[] bytes2 = s2.getBytes();

        if (bytes1.length != bytes2.length) {
            return false;
        }

        int diff = 0;
        for (int i = 0; i < bytes1.length; i++) {
            diff |= bytes1[i] ^ bytes2[i];
        }
        return diff == 0;
