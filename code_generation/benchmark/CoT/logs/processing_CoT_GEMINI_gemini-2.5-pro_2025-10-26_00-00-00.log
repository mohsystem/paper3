    printf("3. unknownuser / password123 -> %s\n", login("unknownuser", "password123"));

    // Test Case 4: Another successful login
    printf("4. jdoe / securePass!@# -> %s\n", login("jdoe", "securePass!@#"));

    // Test Case 5: Empty credentials
    printf("5. \"\" / \"\" -> %s\n", login("", ""));

    return 0;
