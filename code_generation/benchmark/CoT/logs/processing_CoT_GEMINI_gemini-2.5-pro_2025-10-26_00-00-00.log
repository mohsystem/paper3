    @staticmethod
    def trim_trailing_whitespace(s: str) -> str:
        """
        Trims trailing whitespace (spaces, tabs, newlines) from a string.

        Args:
            s: The input string.

        Returns:
            The string with trailing whitespace removed.
        """
