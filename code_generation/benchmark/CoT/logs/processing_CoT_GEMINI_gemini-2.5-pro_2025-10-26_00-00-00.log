            std::cout << "Unzip successful. Verify directory '" << unpack5 << "' is empty." << std::endl;
        }
        
        std::cout << "\nC++ tests complete. Please manually clean up " << baseTestDir << std::endl;
    }
};

int main() {
    Lse49::runTests();
    return 0;
}
