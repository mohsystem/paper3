    printf("\n--- Running Test Cases ---\n");

    // Test Case 1: Valid file
    printf("Test 1: Requesting a valid file 'test1.jpg'\n");
    FileData r1 = img("test1.jpg");
    if (r1.success && r1.size == 10 && strncmp(r1.data, "ImageData1", 10) == 0) {
