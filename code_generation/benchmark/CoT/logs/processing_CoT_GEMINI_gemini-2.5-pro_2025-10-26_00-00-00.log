        if os.path.exists("test1.txt"):
            os.remove("test1.txt")
        if os.path.exists("test2.jpg"):
            os.remove("test2.jpg")
        if os.path.exists("test3.txt"):
            os.remove("test3.txt")
    except OSError as e:
        print(f"Failed to clean up test files: {e}")


if __name__ == "__main__":
    main()
