    try:
        # 1. Parse the string to an integer
        size = int(size_str)

        # 2. Validate the input size
        if size < 0:
            print("Error: Buffer size cannot be negative.")
            return

        print(f"Allocating buffer of size: {size}")

        # 3. Allocate the buffer
        # In Python, bytearray is zero-initialized.
