    std::cout << "\n--- Running 5 Test Cases ---" << std::endl;
    buyOrder(db, "AAPL", 10);
    buyOrder(db, "GOOGL", 5);
    buyOrder(db, "MSFT", 15);
    buyOrder(db, "AMZN", 2);
    // Test case with a potentially malicious name to show safety
    buyOrder(db, "TSLA'); DROP TABLE orders; --", 1);
