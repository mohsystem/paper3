std::string decideRedirect(bool isLoggedIn, bool isAdmin) {
    const std::string LOGIN = "/login";
    const std::string USER = "/user";
    const std::string ADMIN = "/admin";

    if (!isLoggedIn) return LOGIN;
    if (isAdmin) return ADMIN;
    return USER;
}

