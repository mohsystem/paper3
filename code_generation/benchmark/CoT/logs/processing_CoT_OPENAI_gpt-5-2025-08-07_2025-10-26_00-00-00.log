#include <stdio.h>
#include <stdint.h>
#include <string.h>
#include <stdlib.h>
#include <stdbool.h>

// Minimal SHA-256 implementation (public domain style)
typedef struct {
    uint8_t data[64];
    uint32_t datalen;
    uint64_t bitlen;
    uint32_t state[8];
} SHA256_CTX;

static inline uint32_t ROTRIGHT32(uint32_t a, uint32_t b){ return ((a >> b) | (a << (32 - b))); }
static inline uint32_t CH32(uint32_t x, uint32_t y, uint32_t z){ return ((x & y) ^ (~x & z)); }
static inline uint32_t MAJ32(uint32_t x, uint32_t y, uint32_t z){ return ((x & y) ^ (x & z) ^ (y & z)); }
static inline uint32_t EP0_32(uint32_t x){ return ROTRIGHT32(x,2) ^ ROTRIGHT32(x,13) ^ ROTRIGHT32(x,22); }
static inline uint32_t EP1_32(uint32_t x){ return ROTRIGHT32(x,6) ^ ROTRIGHT32(x,11) ^ ROTRIGHT32(x,25); }
static inline uint32_t SIG0_32(uint32_t x){ return ROTRIGHT32(x,7) ^ ROTRIGHT32(x,18) ^ (x >> 3); }
static inline uint32_t SIG1_32(uint32_t x){ return ROTRIGHT32(x,17) ^ ROTRIGHT32(x,19) ^ (x >> 10); }

static const uint32_t k256_c[64] = {
  0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,
  0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,
  0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,
  0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,
  0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,
  0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,
  0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,
  0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2
};

static void sha256_transform_c(SHA256_CTX *ctx, const uint8_t data[]) {
    uint32_t a,b,c,d,e,f,g,h,i,j,t1,t2,m[64];

    for (i=0,j=0; i<16; ++i, j+=4)
        m[i] = (data[j] << 24) | (data[j+1] << 16) | (data[j+2] << 8) | (data[j+3]);
    for (; i<64; ++i)
        m[i] = SIG1_32(m[i-2]) + m[i-7] + SIG0_32(m[i-15]) + m[i-16];

    a=ctx->state[0]; b=ctx->state[1]; c=ctx->state[2]; d=ctx->state[3];
    e=ctx->state[4]; f=ctx->state[5]; g=ctx->state[6]; h=ctx->state[7];

    for (i=0; i<64; ++i) {
        t1 = h + EP1_32(e) + CH32(e,f,g) + k256_c[i] + m[i];
        t2 = EP0_32(a) + MAJ32(a,b,c);
        h=g; g=f; f=e; e=d + t1;
        d=c; c=b; b=a; a=t1 + t2;
    }

    ctx->state[0] += a; ctx->state[1] += b; ctx->state[2] += c; ctx->state[3] += d;
    ctx->state[4] += e; ctx->state[5] += f; ctx->state[6] += g; ctx->state[7] += h;
}

static void sha256_init_c(SHA256_CTX *ctx) {
    ctx->datalen = 0;
    ctx->bitlen = 0;
    ctx->state[0]=0x6a09e667;
    ctx->state[1]=0xbb67ae85;
    ctx->state[2]=0x3c6ef372;
    ctx->state[3]=0xa54ff53a;
    ctx->state[4]=0x510e527f;
    ctx->state[5]=0x9b05688c;
    ctx->state[6]=0x1f83d9ab;
    ctx->state[7]=0x5be0cd19;
}

static void sha256_update_c(SHA256_CTX *ctx, const uint8_t data[], size_t len) {
    for (size_t i=0; i<len; ++i) {
        ctx->data[ctx->datalen] = data[i];
        ctx->datalen++;
        if (ctx->datalen == 64) {
            sha256_transform_c(ctx, ctx->data);
            ctx->bitlen += 512;
            ctx->datalen = 0;
        }
    }
}

static void sha256_final_c(SHA256_CTX *ctx, uint8_t hash[32]) {
    uint32_t i = ctx->datalen;

    // Pad
    if (ctx->datalen < 56) {
        ctx->data[i++] = 0x80;
        while (i < 56) ctx->data[i++] = 0x00;
    } else {
        ctx->data[i++] = 0x80;
        while (i < 64) ctx->data[i++] = 0x00;
        sha256_transform_c(ctx, ctx->data);
        memset(ctx->data, 0, 56);
    }

    ctx->bitlen += ctx->datalen * 8ULL;
    ctx->data[63] = ctx->bitlen;
    ctx->data[62] = ctx->bitlen >> 8;
    ctx->data[61] = ctx->bitlen >> 16;
    ctx->data[60] = ctx->bitlen >> 24;
    ctx->data[59] = ctx->bitlen >> 32;
    ctx->data[58] = ctx->bitlen >> 40;
    ctx->data[57] = ctx->bitlen >> 48;
    ctx->data[56] = ctx->bitlen >> 56;
    sha256_transform_c(ctx, ctx->data);

    for (i=0; i<4; ++i) {
        hash[i]      = (ctx->state[0] >> (24 - i * 8)) & 0xff;
        hash[i + 4]  = (ctx->state[1] >> (24 - i * 8)) & 0xff;
        hash[i + 8]  = (ctx->state[2] >> (24 - i * 8)) & 0xff;
        hash[i + 12] = (ctx->state[3] >> (24 - i * 8)) & 0xff;
        hash[i + 16] = (ctx->state[4] >> (24 - i * 8)) & 0xff;
        hash[i + 20] = (ctx->state[5] >> (24 - i * 8)) & 0xff;
        hash[i + 24] = (ctx->state[6] >> (24 - i * 8)) & 0xff;
        hash[i + 28] = (ctx->state[7] >> (24 - i * 8)) & 0xff;
    }
}

static void sha256_bytes_c(const uint8_t* data, size_t len, uint8_t out[32]) {
    SHA256_CTX ctx;
    sha256_init_c(&ctx);
    sha256_update_c(&ctx, data, len);
    sha256_final_c(&ctx, out);
}

static bool ct_equal_c(const uint8_t* a, const uint8_t* b, size_t len) {
    uint8_t diff = 0;
    for (size_t i = 0; i < len; ++i) {
        diff |= (uint8_t)(a[i] ^ b[i]);
    }
    return diff == 0;
}

const char* login(const char* username, const char* password) {
    const char* USER_SALT = "usr_salt_v1|";
    const char* PASS_SALT = "pwd_salt_v1|";
    const char* EXPECTED_USERNAME = "admin";
    const char* EXPECTED_PASSWORD = "Password!234";
    const size_t MAX_LEN = 64;

    if (username == NULL || password == NULL) {
        return "Incorrect username or password.";
    }
    size_t ulen = strlen(username);
    size_t plen = strlen(password);
    if (ulen == 0 || plen == 0 || ulen > MAX_LEN || plen > MAX_LEN) {
        return "Incorrect username or password.";
    }

    uint8_t providedUserHash[32], expectedUserHash[32];
    uint8_t providedPassHash[32], expectedPassHash[32];

    size_t us_len = strlen(USER_SALT) + ulen;
    char* us = (char*)malloc(us_len + 1);
    memcpy(us, USER_SALT, strlen(USER_SALT));
    memcpy(us + strlen(USER_SALT), username, ulen);
    us[us_len] = '\0';
    sha256_bytes_c((const uint8_t*)us, us_len, providedUserHash);
    free(us);

    size_t ue_len = strlen(USER_SALT) + strlen(EXPECTED_USERNAME);
    char* ue = (char*)malloc(ue_len + 1);
    memcpy(ue, USER_SALT, strlen(USER_SALT));
    memcpy(ue + strlen(USER_SALT), EXPECTED_USERNAME, strlen(EXPECTED_USERNAME));
    ue[ue_len] = '\0';
    sha256_bytes_c((const uint8_t*)ue, ue_len, expectedUserHash);
    free(ue);

    size_t ps_len = strlen(PASS_SALT) + plen;
    char* ps = (char*)malloc(ps_len + 1);
    memcpy(ps, PASS_SALT, strlen(PASS_SALT));
    memcpy(ps + strlen(PASS_SALT), password, plen);
    ps[ps_len] = '\0';
    sha256_bytes_c((const uint8_t*)ps, ps_len, providedPassHash);
    free(ps);

    size_t pe_len = strlen(PASS_SALT) + strlen(EXPECTED_PASSWORD);
    char* pe = (char*)malloc(pe_len + 1);
    memcpy(pe, PASS_SALT, strlen(PASS_SALT));
    memcpy(pe + strlen(PASS_SALT), EXPECTED_PASSWORD, strlen(EXPECTED_PASSWORD));
    pe[pe_len] = '\0';
    sha256_bytes_c((const uint8_t*)pe, pe_len, expectedPassHash);
    free(pe);

    bool userOk = ct_equal_c(providedUserHash, expectedUserHash, 32);
    bool passOk = ct_equal_c(providedPassHash, expectedPassHash, 32);

    if (userOk && passOk) {
        return "Login successful. Redirecting to /session";
    } else {
        return "Incorrect username or password.";
    }
}

int main(void) {
    const char* tests[5][2] = {
        {"admin", "Password!234"},
        {"admin", "Password!2345"},
        {"Admin", "Password!234"},
        {"user", "123"},
        {"admin", "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"} // 65 'a'
    };

    for (int i = 0; i < 5; ++i) {
        const char* u = tests[i][0];
        const char* p = tests[i][1];
        const char* res = login(u, p);
        printf("Test %d: %s / <hidden> -> %s\n", i + 1, u, res);
    }
    return 0;
}
