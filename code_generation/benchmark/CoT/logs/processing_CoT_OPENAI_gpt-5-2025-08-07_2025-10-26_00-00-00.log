            new String[]{"cat", "3", "a", "b", "c", "d"},      // prints "d"
            new String[]{"oops", "notnum", "foo"},             // ERROR
            new String[]{"few", "9", "only", "two"}            // ERROR
        };
        for (String[] t : tests) {
            String indexStr = t.length > 1 ? t[1] : null;
            printAtIndex(t, indexStr);
        }
    }
}
