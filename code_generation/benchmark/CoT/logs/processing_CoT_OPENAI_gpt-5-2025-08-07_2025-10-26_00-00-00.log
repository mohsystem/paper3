#include <bits/stdc++.h>
using namespace std;

// Step 1-2: Purpose and security considerations (comments only)
// Step 3-5: Implement secure code; includes constant-time compare and SHA-256

// Minimal SHA-256 implementation (public-domain style)
struct SHA256_CTX {
    uint8_t data[64];
    uint32_t datalen;
    uint64_t bitlen;
    uint32_t state[8];
};

static const uint32_t k256[64] = {
    0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,
    0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,
    0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,
    0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,
    0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,
    0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,
    0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,
    0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2
};

#define ROTRIGHT(a,b) (((a) >> (b)) | ((a) << (32-(b))))
#define CH(x,y,z)     (((x) & (y)) ^ (~(x) & (z)))
#define MAJ(x,y,z)    (((x) & (y)) ^ ((x) & (z)) ^ ((y) & (z)))
#define EP0(x)        (ROTRIGHT(x,2) ^ ROTRIGHT(x,13) ^ ROTRIGHT(x,22))
#define EP1(x)        (ROTRIGHT(x,6) ^ ROTRIGHT(x,11) ^ ROTRIGHT(x,25))
#define SIG0(x)       (ROTRIGHT(x,7) ^ ROTRIGHT(x,18) ^ ((x) >> 3))
#define SIG1(x)       (ROTRIGHT(x,17) ^ ROTRIGHT(x,19) ^ ((x) >> 10))

static void sha256_transform(SHA256_CTX *ctx, const uint8_t data[]) {
    uint32_t a,b,c,d,e,f,g,h,i,j,t1,t2,m[64];
    for (i = 0, j = 0; i < 16; ++i, j += 4)
        m[i] = (data[j] << 24) | (data[j+1] << 16) | (data[j+2] << 8) | (data[j+3]);
    for ( ; i < 64; ++i)
        m[i] = SIG1(m[i-2]) + m[i-7] + SIG0(m[i-15]) + m[i-16];

    a = ctx->state[0];
    b = ctx->state[1];
    c = ctx->state[2];
    d = ctx->state[3];
    e = ctx->state[4];
    f = ctx->state[5];
    g = ctx->state[6];
    h = ctx->state[7];

    for (i = 0; i < 64; ++i) {
        t1 = h + EP1(e) + CH(e,f,g) + k256[i] + m[i];
        t2 = EP0(a) + MAJ(a,b,c);
        h = g; g = f; f = e; e = d + t1; d = c; c = b; b = a; a = t1 + t2;
    }

    ctx->state[0] += a;
    ctx->state[1] += b;
    ctx->state[2] += c;
    ctx->state[3] += d;
    ctx->state[4] += e;
    ctx->state[5] += f;
    ctx->state[6] += g;
    ctx->state[7] += h;
}

static void sha256_init(SHA256_CTX *ctx) {
    ctx->datalen = 0;
    ctx->bitlen = 0;
    ctx->state[0] = 0x6a09e667;
    ctx->state[1] = 0xbb67ae85;
    ctx->state[2] = 0x3c6ef372;
    ctx->state[3] = 0xa54ff53a;
    ctx->state[4] = 0x510e527f;
    ctx->state[5] = 0x9b05688c;
    ctx->state[6] = 0x1f83d9ab;
    ctx->state[7] = 0x5be0cd19;
}

static void sha256_update(SHA256_CTX *ctx, const uint8_t data[], size_t len) {
    for (size_t i = 0; i < len; ++i) {
        ctx->data[ctx->datalen] = data[i];
        ctx->datalen++;
        if (ctx->datalen == 64) {
            sha256_transform(ctx, ctx->data);
            ctx->bitlen += 512;
            ctx->datalen = 0;
        }
    }
}

static void sha256_final(SHA256_CTX *ctx, uint8_t hash[]) {
    uint32_t i = ctx->datalen;

    // Pad whatever data is left in the buffer.
    if (ctx->datalen < 56) {
        ctx->data[i++] = 0x80;
        while (i < 56) ctx->data[i++] = 0x00;
    } else {
        ctx->data[i++] = 0x80;
        while (i < 64) ctx->data[i++] = 0x00;
        sha256_transform(ctx, ctx->data);
        memset(ctx->data, 0, 56);
    }

    // Append to the padding the total message's length in bits and transform.
    ctx->bitlen += ctx->datalen * 8ULL;
    ctx->data[63] = ctx->bitlen;
    ctx->data[62] = ctx->bitlen >> 8;
    ctx->data[61] = ctx->bitlen >> 16;
    ctx->data[60] = ctx->bitlen >> 24;
    ctx->data[59] = ctx->bitlen >> 32;
    ctx->data[58] = ctx->bitlen >> 40;
    ctx->data[57] = ctx->bitlen >> 48;
    ctx->data[56] = ctx->bitlen >> 56;
    sha256_transform(ctx, ctx->data);

    // Since this implementation uses little endian byte ordering and SHA uses big endian,
    // reverse all the bytes when copying the final state to the output hash.
    for (i = 0; i < 4; ++i) {
        hash[i]      = (ctx->state[0] >> (24 - i * 8)) & 0x000000ff;
        hash[i + 4]  = (ctx->state[1] >> (24 - i * 8)) & 0x000000ff;
        hash[i + 8]  = (ctx->state[2] >> (24 - i * 8)) & 0x000000ff;
        hash[i + 12] = (ctx->state[3] >> (24 - i * 8)) & 0x000000ff;
        hash[i + 16] = (ctx->state[4] >> (24 - i * 8)) & 0x000000ff;
        hash[i + 20] = (ctx->state[5] >> (24 - i * 8)) & 0x000000ff;
        hash[i + 24] = (ctx->state[6] >> (24 - i * 8)) & 0x000000ff;
        hash[i + 28] = (ctx->state[7] >> (24 - i * 8)) & 0x000000ff;
    }
}

static string sha256_hex(const string &input) {
    uint8_t hash[32];
    SHA256_CTX ctx;
    sha256_init(&ctx);
    sha256_update(&ctx, reinterpret_cast<const uint8_t*>(input.data()), input.size());
    sha256_final(&ctx, hash);
    static const char* hex = "0123456789abcdef";
    string out(64, '0');
    for (int i = 0; i < 32; ++i) {
        out[2*i] = hex[(hash[i] >> 4) & 0x0F];
        out[2*i+1] = hex[hash[i] & 0x0F];
    }
    return out;
}

static bool ct_equals(const string &a, const string &b) {
    if (a.size() != b.size()) return false;
    unsigned char diff = 0;
    for (size_t i = 0; i < a.size(); ++i) {
        diff |= static_cast<unsigned char>(a[i]) ^ static_cast<unsigned char>(b[i]);
    }
    return diff == 0;
}

class Lse58 {
public:
    struct User {
        string username;
        string email;
        string saltHex;
        string passwordHashHex;
        bool loggedIn;
    };

private:
    User user;

    static string randomSaltHex(size_t n = 16) {
        std::random_device rd;
        std::mt19937_64 gen(rd());
        std::uniform_int_distribution<int> dist(0, 255);
        string s; s.reserve(n);
        for (size_t i = 0; i < n; ++i) s.push_back(static_cast<char>(dist(gen)));
        // convert to hex
        static const char* hex = "0123456789abcdef";
        string out; out.reserve(n*2);
        for (unsigned char c : s) {
            out.push_back(hex[(c >> 4) & 0xF]);
            out.push_back(hex[c & 0xF]);
        }
        return out;
    }

    static string hashPasswordHex(const string &password, const string &saltHex) {
        // simple combine saltHex + password then sha256
        return sha256_hex(saltHex + password);
    }

    static bool secureStrEq(const string &a, const string &b) {
        return ct_equals(string(a.begin(), a.end()), string(b.begin(), b.end()));
    }

public:
    Lse58(const string &username, const string &email, const string &password) {
        user.username = username;
        user.email = email;
        user.saltHex = randomSaltHex(16);
        user.passwordHashHex = hashPasswordHex(password, user.saltHex);
        user.loggedIn = false;
    }

    bool login(const string &username, const string &password) {
        if (!secureStrEq(username, user.username)) return false;
        string candidate = hashPasswordHex(password, user.saltHex);
        bool ok = ct_equals(candidate, user.passwordHashHex);
        user.loggedIn = ok;
        return ok;
    }

    void logout() {
        user.loggedIn = false;
    }

    bool changeEmail(const string &oldEmail, const string &newEmail, const string &confirmPassword) {
        if (!user.loggedIn) return false;
        if (!secureStrEq(oldEmail, user.email)) return false;
        string candidate = hashPasswordHex(confirmPassword, user.saltHex);
        if (!ct_equals(candidate, user.passwordHashHex)) return false;
        user.email = newEmail;
        return true;
    }

    string getEmail() const {
        return user.email;
    }
};

int main() {
    Lse58 sys("alice", "alice@example.com", "S3cret!42");

    // Test 1: change while not logged in -> false
    bool t1 = sys.changeEmail("alice@example.com", "new1@example.com", "S3cret!42");
    cout << "Test1 (change while not logged in): " << (t1 ? "true" : "false") << " | email=" << sys.getEmail() << "\n";

    // Test 2: login wrong password -> false
    bool t2 = sys.login("alice", "WrongPass!");
    cout << "Test2 (login wrong password): " << (t2 ? "true" : "false") << " | email=" << sys.getEmail() << "\n";

    // Test 3: login correct password -> true
    bool t3 = sys.login("alice", "S3cret!42");
    cout << "Test3 (login correct password): " << (t3 ? "true" : "false") << " | email=" << sys.getEmail() << "\n";

    // Test 4: change with wrong old email -> false
    bool t4 = sys.changeEmail("wrong@example.com", "new2@example.com", "S3cret!42");
    cout << "Test4 (wrong old email): " << (t4 ? "true" : "false") << " | email=" << sys.getEmail() << "\n";

    // Test 5: successful change -> true
    bool t5 = sys.changeEmail("alice@example.com", "alice.new@example.com", "S3cret!42");
    cout << "Test5 (successful change): " << (t5 ? "true" : "false") << " | email=" << sys.getEmail() << "\n";
    return 0;
}
