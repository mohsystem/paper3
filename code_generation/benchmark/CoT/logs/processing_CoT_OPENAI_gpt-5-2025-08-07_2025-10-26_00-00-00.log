            testData[i] = arr;
        }

        String[] names = {"img1.png", "photo-02.jpg", "scan_03.tif", "icon-4.bmp", "graph5.svg"};
        List<Path> paths = new ArrayList<>();
        for (int i = 0; i < 5; i++) {
