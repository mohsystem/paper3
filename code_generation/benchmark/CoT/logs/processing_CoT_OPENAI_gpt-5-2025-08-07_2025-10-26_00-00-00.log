    MAX_BYTES = 5 * 1024 * 1024  # 5 MiB
    data = _read_file_capped(os.path.abspath(file_path), MAX_BYTES)
    if data is None:
        return False
    b64 = base64.b64encode(data).decode('ascii')
    return db.insert(image_name, b64)

