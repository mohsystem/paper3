            while ((r = in.read(buf)) != -1) {
                total += r;
                if (total > MAX_BYTES) {
                    throw new IOException("File exceeded maximum allowed size while reading");
                }
                bos.write(buf, 0, r);
            }
            return bos.toString(StandardCharsets.UTF_8);
