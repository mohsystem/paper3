        "latitude=35.6895&longitude=139.6917&year=2019&month=3&day=10&grib_file=sample5.grb"
    };
    for (int i = 0; i < 5; ++i) {
        char out[1024];
        build_response_for_request(tests[i], out, sizeof(out));
        printf("%s\n", out);
    }
    return 0;
}
