import java.io.*;
import java.util.*;

public class Lse11 {

    // Returns the value at the given index if valid; otherwise returns 0.
    public static int getValueFromArray(int[] arr, int size, int index) {
        if (arr == null || size < 0) {
            return 0;
        }
        if (index < 0 || index >= size) {
            return 0;
        }
        return arr[index];
    }

