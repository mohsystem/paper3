import secrets

def generate_random_above(min_exclusive: int) -> int:
    lower = max(1000, int(min_exclusive)) + 1
    upper = min((2**31 - 1), lower + 1_000_000)
    if upper < lower:
        upper = lower
    bound = max(1, upper - lower + 1)
