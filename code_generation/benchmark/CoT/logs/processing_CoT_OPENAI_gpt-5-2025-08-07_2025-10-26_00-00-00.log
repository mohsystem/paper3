        print("  Extracted:", p)
    if not out2:
        print("  No files extracted.")

    # Test 3: Path traversal attempts
    _safe_delete_tmp_unpack(dest)
    _create_zip(zpath, {
        "../evil.txt": b"skip",
        "safe/d.txt": b"ok",
        "x/../../evil2.txt": b"skip",
    })
    out3 = unzip_secure(zpath, dest)
    print("Test: Path traversal prevention")
    for p in out3:
        print("  Extracted:", p)
    if not out3:
        print("  No files extracted.")

    # Test 4: Absolute path entry handling
    _safe_delete_tmp_unpack(dest)
