import secrets

def generate_and_diff(min_v: int, max_v: int):
    if min_v > max_v:
        raise ValueError("min_v must be <= max_v")
    span = (max_v - min_v) + 1
    a = min_v + secrets.randbelow(span)
    b = min_v + secrets.randbelow(span)
    diff = abs(a - b)
    return (a, b, diff)

