            int[] testIndices = {0, 2, 4, -1, 10};
            for (int i = 0; i < testIndices.length; i++) {
                String result = getVehicleAt(vehicles, testIndices[i]);
                System.out.println("Test " + (i + 1) + " - index " + testIndices[i] + ": " + (result != null ? result : "Invalid index"));
            }
        } finally {
            sc.close();
        }
    }
}
