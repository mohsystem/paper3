def get_value_at_index(index: int) -> int:
    if not isinstance(index, int):
        raise TypeError("Index must be an integer.")
    if index < 0 or index >= len(ID_SEQUENCE):
        raise IndexError("Index out of range.")
    return ID_SEQUENCE[index]

def main():
