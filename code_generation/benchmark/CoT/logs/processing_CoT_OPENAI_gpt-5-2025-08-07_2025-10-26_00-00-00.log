    if (fd == -1) {
        (void)saved_errno;
        return 0;
    }
    if (close(fd) != 0) {
        return 0;
    }
    return 1;
#endif
}

static void cleanup(const char* filename) {
#ifdef _WIN32
    _unlink(filename);
#else
    unlink(filename);
#endif
}

int main(void) {
    const char* fname = "important_config";
    for (int i = 1; i <= 5; ++i) {
        cleanup(fname);
        int ok = create_secure_config(fname);
