 and validates domain structure\n    private static final Pattern SAFE_URL_PATTERN = \n        Pattern.compile("^https://([a-zA-Z0-9-]+\\\\.)*example\\\\.com(/.*)?$");\n    \n    /**\n     * Security: Validates redirect target against whitelist\n     * Prevents open redirect vulnerability (CWE-601)\n     */\n    private static boolean validateRedirectTarget(String target) {\n        if (target == null || target.isEmpty()) {\n            return false;\n        }\n        \n        // Security: Length validation to prevent DoS\n        if (target.length() > MAX_URL_LENGTH) {\n            return false;\n        }\n        \n        // Security: Check against whitelist pattern\n        Matcher matcher = SAFE_URL_PATTERN.matcher(target);\n        return matcher.matches();\n    }\n    \n    static class RedirectHandler implements HttpHandler {\n        @Override\n        public void handle(HttpExchange exchange) throws IOException {\n            String redirectUrl = "/";\n            \n            try {\n                // Security: Only accept GET requests\n                if (!"GET".equals(exchange.getRequestMethod())) {\n                    exchange.sendResponseHeaders(405, -1);\n                    return;\n                }\n                \n                // Security: Parse query string safely\n                URI requestURI = exchange.getRequestURI();\n                String query = requestURI.getQuery();\n                String target = null;\n                \n                if (query != null) {\n                    String[] pairs = query.split("&");\n                    for (String pair : pairs) {\n                        String[] keyValue = pair.split("=", 2);\n                        if (keyValue.length == 2 && "target".equals(keyValue[0])) {\n                            // Security: URL decode with UTF-8\n                            target = URLDecoder.decode(keyValue[1], StandardCharsets.UTF_8);\n                            break;\n                        }\n                    }\n                }\n                \n                // Security: Validate target before redirect\n                if (target != null && validateRedirectTarget(target)) {\n                    redirectUrl = target;\n                }\n                \n                // Security: Add security headers\n                exchange.getResponseHeaders().set("Location", redirectUrl);\n                exchange.getResponseHeaders().set("X-Content-Type-Options", "nosniff");\n                exchange.getResponseHeaders().set("X-Frame-Options", "DENY");\n                exchange.getResponseHeaders().set("Content-Security-Policy", "default-src 'none'");\n                \n                // Security: Send redirect response\n                exchange.sendResponseHeaders(302, -1);\n                \n            } catch (Exception e) {\n                // Security: Generic error message, log detailed error separately\n                System.err.println("Error processing request: " + e.getMessage());\n                exchange.sendResponseHeaders(500, -1);\n            } finally {\n                exchange.close();\n            }\n        }\n    }\n    \n    public static void main(String[] args) {\n        // Test cases\n        System.out.println("Running test cases:");\n        \n        // Test 1: Valid example.com URL\n        String test1 = "https://example.com/path";\n        System.out.println("Test 1 - Valid URL: " + test1 + " -> " + \n                         (validateRedirectTarget(test1) ? "PASS" : "FAIL"));\n        \n        // Test 2: Valid subdomain\n        String test2 = "https://subdomain.example.com/page";\n        System.out.println("Test 2 - Valid subdomain: " + test2 + " -> " + \n                         (validateRedirectTarget(test2) ? "PASS" : "FAIL"));\n        \n        // Test 3: Invalid - different domain\n        String test3 = "https://evil.com";\n        System.out.println("Test 3 - Invalid domain: " + test3 + " -> " + \n                         (!validateRedirectTarget(test3) ? "PASS" : "FAIL"));\n        \n        // Test 4: Invalid - no scheme\n        String test4 = "example.com";\n        System.out.println("Test 4 - No scheme: " + test4 + " -> " + \n                         (!validateRedirectTarget(test4) ? "PASS" : "FAIL"));\n        \n        // Test 5: Invalid - XSS attempt\n        String test5 = "javascript:alert('XSS')";\n        System.out.println("Test 5 - XSS attempt: " + test5 + " -> " + \n                         (!validateRedirectTarget(test5) ? "PASS" : "FAIL"));\n        \n        try {\n            // Security: Start server with minimal configuration\n            HttpServer server = HttpServer.create(new InetSocketAddress(PORT), 0);\n            server.createContext("/", new RedirectHandler());\n            server.setExecutor(null);\n            server.start();\n            \n            System.out.println("\\nServer started on port " + PORT);\n            System.out.println("Press Enter to stop...");\n            System.in.read();\n            \n            server.stop(0);\n            System.out.println("Server stopped");\n            \n        } catch (IOException e) {\n            System.err.println("Failed to start server: " + e.getMessage());\n        }\n    }\n}\n```\n\n```python\nimport re\nfrom http.server import HTTPServer, BaseHTTPRequestHandler\nfrom urllib.parse import urlparse, parse_qs, unquote\nimport sys\n\nPORT = 8888\nMAX_URL_LENGTH = 2048\n\n# Security: Strict regex pattern to whitelist only example.com URLs\n# Requires https:// scheme for security and validates domain structure\nSAFE_URL_PATTERN = re.compile(r'^https://([a-zA-Z0-9-]+\\.)*example\\.com(/.*)?$')\n\ndef validate_redirect_target(target):\n    """\n    Security: Validates redirect target against whitelist\n    Prevents open redirect vulnerability (CWE-601)\n    """\n    if not target:\n        return False\n    \n    # Security: Length validation to prevent DoS\n    if len(target) > MAX_URL_LENGTH:\n        return False\n    \n    # Security: Check against whitelist pattern\n    return bool(SAFE_URL_PATTERN.match(target))\n\nclass RedirectHandler(BaseHTTPRequestHandler):\n    """\n    Security: Safe redirect handler with input validation\n    """\n    \n    def do_GET(self):\n        """\n        Handle GET requests with secure redirect validation\n        """\n        redirect_url = '/'\n        \n        try:\n            # Security: Parse URL safely\n            parsed_url = urlparse(self.path)\n            query_params = parse_qs(parsed_url.query)\n            \n            # Security: Get target parameter safely\n            target = None\n            if 'target' in query_params:\n                # Security: URL decode with UTF-8\n                target = unquote(query_params['target'][0])\n            \n            # Security: Validate target before redirect\n            if target and validate_redirect_target(target):\n                redirect_url = target\n            \n            # Security: Send redirect response with security headers\n            self.send_response(302)\n            self.send_header('Location', redirect_url)\n            self.send_header('X-Content-Type-Options', 'nosniff')\n            self.send_header('X-Frame-Options', 'DENY')\n            self.send_header('Content-Security-Policy', "default-src 'none'")\n            self.end_headers()\n            \n        except Exception as e:\n            # Security: Generic error response, detailed log separate\n            print(f"Error processing request: {e}", file=sys.stderr)\n            self.send_error(500)\n    \n    def log_message(self, format, *args):\n        """Security: Override to control logging"""\n        sys.stderr.write("%s - - [%s] %s\\n" %\n                        (self.address_string(),\n                         self.log_date_time_string(),\n                         format % args))\n\ndef main():\n    # Test cases\n    print("Running test cases:")\n    \n    # Test 1: Valid example.com URL\n    test1 = "https://example.com/path"\n    print(f"Test 1 - Valid URL: {test1} -> {'PASS' if validate_redirect_target(test1) else 'FAIL'}")\n    \n    # Test 2: Valid subdomain\n    test2 = "https://subdomain.example.com/page"\n    print(f"Test 2 - Valid subdomain: {test2} -> {'PASS' if validate_redirect_target(test2) else 'FAIL'}")\n    \n    # Test 3: Invalid - different domain\n    test3 = "https://evil.com"\n    print(f"Test 3 - Invalid domain: {test3} -> {'PASS' if not validate_redirect_target(test3) else 'FAIL'}")\n    \n    # Test 4: Invalid - no scheme\n    test4 = "example.com"\n    print(f"Test 4 - No scheme: {test4} -> {'PASS' if not validate_redirect_target(test4) else 'FAIL'}")\n    \n    # Test 5: Invalid - XSS attempt\n    test5 = "javascript:alert('XSS')"\n    print(f"Test 5 - XSS attempt: {test5} -> {'PASS' if not validate_redirect_target(test5) else 'FAIL'}")\n    \n    # Security: Start server with minimal configuration\n    print(f"\\nStarting server on port {PORT}...")\n    server = HTTPServer(('localhost', PORT), RedirectHandler)\n    \n    try:\n        print(f"Server running on http://localhost:{PORT}")\n        print("Press Ctrl+C to stop")\n        server.serve_forever()\n    except KeyboardInterrupt:\n        print("\\nServer stopped")\n        server.shutdown()\n\nif __name__ == '__main__':\n    main()\n```\n\n```javascript\n// Security: Use strict mode for safer JavaScript\n'use strict';\n\nconst http = require('http');\nconst url = require('url');\nconst querystring = require('querystring');\n\nconst PORT = 8888;\nconst MAX_URL_LENGTH = 2048;\n\n// Security: Strict regex pattern to whitelist only example.com URLs\n// Requires https:// scheme and validates domain structure\nconst SAFE_URL_PATTERN = /^https:\\/\\/([a-zA-Z0-9-]+\\.)*example\\.com(\\/.*)?$/;\n\n/**\n * Security: Validates redirect target against whitelist\n * Prevents open redirect vulnerability (CWE-601)\n */\nfunction validateRedirectTarget(target) {\n    if (!target || typeof target !== 'string') {\n        return false;\n    }\n    \n    // Security: Length validation to prevent DoS\n    if (target.length > MAX_URL_LENGTH) {\n        return false;\n    }\n    \n    // Security: Check against whitelist pattern\n    return SAFE_URL_PATTERN.test(target);\n}\n\n/**\n * Security: Safe request handler with input validation\n */\nfunction handleRequest(req, res) {\n    let redirectUrl = '/';\n    \n    try {\n        // Security: Only accept GET requests\n        if (req.method !== 'GET') {\n            res.writeHead(405, { 'Content-Type': 'text/plain' });\n            res.end('Method Not Allowed');\n            return;\n        }\n        \n        // Security: Parse URL safely\n        const parsedUrl = url.parse(req.url, true);\n        const target = parsedUrl.query.target;\n        \n        // Security: Validate target before redirect\n        if (target && validateRedirectTarget(target)) {\n            redirectUrl = target;\n        }\n        \n        // Security: Set redirect with security headers\n        res.writeHead(302, {\n            'Location': redirectUrl,\n            'X-Content-Type-Options': 'nosniff',\n            'X-Frame-Options': 'DENY',\n            'Content-Security-Policy': "default-src 'none'"\n        });\n        res.end();\n        \n    } catch (error) {\n        // Security: Generic error response, log detailed error separately\n        console.error('Error processing request:', error.message);\n        res.writeHead(500, { 'Content-Type': 'text/plain' });\n        res.end('Internal Server Error');\n    }\n}\n\nfunction main() {\n    // Test cases\n    console.log('Running test cases:');\n    \n    // Test 1: Valid example.com URL\n    const test1 = 'https://example.com/path';\n    console.log(`Test 1 - Valid URL: ${test1} -> ${validateRedirectTarget(test1) ? 'PASS' : 'FAIL'}`);\n    \n    // Test 2: Valid subdomain\n    const test2 = 'https://subdomain.example.com/page';\n    console.log(`Test 2 - Valid subdomain: ${test2} -> ${validateRedirectTarget(test2) ? 'PASS' : 'FAIL'}`);\n    \n    // Test 3: Invalid - different domain\n    const test3 = 'https://evil.com';\n    console.log(`Test 3 - Invalid domain: ${test3} -> ${!validateRedirectTarget(test3) ? 'PASS' : 'FAIL'}`);\n    \n    // Test 4: Invalid - no scheme\n    const test4 = 'example.com';\n    console.log(`Test 4 - No scheme: ${test4} -> ${!validateRedirectTarget(test4) ? 'PASS' : 'FAIL'}`);\n    \n    // Test 5: Invalid - XSS attempt\n    const test5 = "javascript:alert('XSS')";\n    console.log(`Test 5 - XSS attempt: ${test5} -> ${!validateRedirectTarget(test5) ? 'PASS' : 'FAIL'}`);\n    \n    // Security: Create server with minimal configuration\n    const server = http.createServer(handleRequest);\n    \n    server.listen(PORT, 'localhost', () => {\n        console.log(`\\nServer running on http://localhost:${PORT}`);\n        console.log('Press Ctrl+C to stop');\n    });\n    \n    // Security: Handle errors\n    server.on('error', (error) => {\n        console.error('Server error:', error.message);\n        process.exit(1);\n    });\n}\n\n// Run main if this is the entry point\nif (require.main === module) {\n    main();\n}\n\nmodule.exports = { validateRedirectTarget };\n```', type='text')
