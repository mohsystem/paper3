tf(stderr, "ERROR: NULL target URL\\n");\n        /* Fail closed: return default URL */\n        snprintf(output_buffer, buffer_size, "%s", DEFAULT_REDIRECT_URL);\n        return output_buffer;\n    }\n    \n    /* Input validation: check length bounds to prevent buffer issues */\n    size_t url_len = strnlen(target_url, MAX_URL_LENGTH + 1);\n    if (url_len == 0 || url_len > MAX_URL_LENGTH) {\n        fprintf(stderr, "ERROR: Invalid URL length\\n");\n        snprintf(output_buffer, buffer_size, "%s", DEFAULT_REDIRECT_URL);\n        return output_buffer;\n    }\n    \n    /* Ensure regex is initialized */\n    if (!regex_initialized) {\n        fprintf(stderr, "ERROR: Regex not initialized\\n");\n        snprintf(output_buffer, buffer_size, "%s", DEFAULT_REDIRECT_URL);\n        return output_buffer;\n    }\n    \n    /* Validate target URL against the compiled regex pattern */\n    /* The regex only validates - does NOT construct or modify the URL */\n    int match_result = regexec(&url_regex, target_url, 0, NULL, 0);\n    \n    if (match_result == 0) {\n        /* URL matches the safe pattern - use it directly */\n        /* Copy safely with bounds checking */\n        snprintf(output_buffer, buffer_size, "%.*s", (int)url_len, target_url);\n        return output_buffer;\n    } else {\n        /* URL does not match - use default URL */\n        /* Do not log the invalid URL to avoid log injection */\n        fprintf(stderr, "INFO: URL validation failed, using default\\n");\n        snprintf(output_buffer, buffer_size, "%s", DEFAULT_REDIRECT_URL);\n        return output_buffer;\n    }\n}\n\n/**\n * Main function with test cases\n */\nint main(void) {\n    char redirect_buffer[MAX_URL_LENGTH];\n    const char *result = NULL;\n    \n    /* Initialize regex once at module load */\n    if (init_url_regex() != 0) {\n        fprintf(stderr, "FATAL: Cannot initialize regex\\n");\n        return EXIT_FAILURE;\n    }\n    \n    printf("=== URL Redirect Validation Tests ===\\n\\n");\n    \n    /* Test case 1: Valid HTTPS URL */\n    printf("Test 1: Valid HTTPS URL\\n");\n    result = get_redirect_url("https://secure.example.com/path", redirect_buffer, sizeof(redirect_buffer));\n    printf("Input:  https://secure.example.com/path\\n");\n    printf("Result: %s\\n\\n", result);\n    \n    /* Test case 2: Invalid HTTP URL (not HTTPS) */\n    printf("Test 2: Invalid HTTP URL\\n");\n    result = get_redirect_url("http://example.com/path", redirect_buffer, sizeof(redirect_buffer));\n    printf("Input:  http://example.com/path\\n");\n    printf("Result: %s\\n\\n", result);\n    \n    /* Test case 3: NULL pointer */\n    printf("Test 3: NULL pointer\\n");\n    result = get_redirect_url(NULL, redirect_buffer, sizeof(redirect_buffer));\n    printf("Input:  NULL\\n");\n    printf("Result: %s\\n\\n", result);\n    \n    /* Test case 4: Empty string */\n    printf("Test 4: Empty string\\n");\n    result = get_redirect_url("", redirect_buffer, sizeof(redirect_buffer));\n    printf("Input:  (empty)\\n");\n    printf("Result: %s\\n\\n", result);\n    \n    /* Test case 5: Valid HTTPS URL with query parameters */\n    printf("Test 5: Valid HTTPS URL with query\\n");\n    result = get_redirect_url("https://api.example.com/endpoint?param=value&id=123", redirect_buffer, sizeof(redirect_buffer));\n    printf("Input:  https://api.example.com/endpoint?param=value&id=123\\n");\n    printf("Result: %s\\n\\n", result);\n    \n    /* Cleanup resources */\n    cleanup_url_regex();\n    \n    return EXIT_SUCCESS;\n}\n```\n\n```Python\nimport re\nfrom typing import Optional\n\n# Global compiled regex - initialized once at module load\n# Pattern validates safe HTTPS URLs only (alphanumeric domains)\n# The regex is NOT used to construct URLs - only to validate them\nURL_REGEX: re.Pattern = re.compile(\n    r'^https://[a-zA-Z0-9][a-zA-Z0-9.-]*[a-zA-Z0-9]\\.[a-zA-Z]{2,}(/[a-zA-Z0-9._~:/?#\\[\\]@!$&\\'()*+,;=-]*)?$'\n)\n\n# Default redirect URL - module constant\nDEFAULT_REDIRECT_URL: str = "https://example.com/default"\nMAX_URL_LENGTH: int = 2048\n\n\ndef get_redirect_url(target_url: Optional[str]) -> str:\n    """\n    Validates and returns the redirect URL.\n    \n    If target_url matches the compiled regex pattern, it is used directly.\n    If not, the default URL is returned.\n    The regex is NOT used to construct the URL - only to validate it.\n    \n    Security measures:\n    - Input validation: checks for None, empty string, and length bounds\n    - Type validation: ensures input is string type\n    - Pattern matching: only allows safe HTTPS URLs\n    - Fail closed: returns default on any validation failure\n    - No logging of invalid URLs to prevent log injection\n    \n    Args:\n        target_url: The URL to validate (may be None)\n    \n    Returns:\n        str: Either the validated target_url or DEFAULT_REDIRECT_URL\n    """\n    # Input validation: check for None\n    if target_url is None:\n        print("ERROR: None target URL", file=__import__('sys').stderr)\n        return DEFAULT_REDIRECT_URL\n    \n    # Input validation: check type\n    if not isinstance(target_url, str):\n        print("ERROR: Invalid URL type", file=__import__('sys').stderr)\n        return DEFAULT_REDIRECT_URL\n    \n    # Input validation: check length bounds\n    if len(target_url) == 0 or len(target_url) > MAX_URL_LENGTH:\n        print("ERROR: Invalid URL length", file=__import__('sys').stderr)\n        return DEFAULT_REDIRECT_URL\n    \n    # Validate target URL against the compiled regex pattern\n    # The regex only validates - does NOT construct or modify the URL\n    if URL_REGEX.match(target_url):\n        # URL matches the safe pattern - return it directly\n        return target_url\n    else:\n        # URL does not match - return default\n        # Do not log the invalid URL to avoid information disclosure\n        print("INFO: URL validation failed, using default", file=__import__('sys').stderr)\n        return DEFAULT_REDIRECT_URL\n\n\ndef main() -> None:\n    """Main function with test cases."""\n    print("=== URL Redirect Validation Tests ===\\n")\n    \n    # Test case 1: Valid HTTPS URL\n    print("Test 1: Valid HTTPS URL")\n    result = get_redirect_url("https://secure.example.com/path")\n    print(f"Input:  https://secure.example.com/path")\n    print(f"Result: {result}\\n")\n    \n    # Test case 2: Invalid HTTP URL (not HTTPS)\n    print("Test 2: Invalid HTTP URL")\n    result = get_redirect_url("http://example.com/path")\n    print(f"Input:  http://example.com/path")\n    print(f"Result: {result}\\n")\n    \n    # Test case 3: None value\n    print("Test 3: None value")\n    result = get_redirect_url(None)\n    print(f"Input:  None")\n    print(f"Result: {result}\\n")\n    \n    # Test case 4: Empty string\n    print("Test 4: Empty string")\n    result = get_redirect_url("")\n    print(f"Input:  (empty)")\n    print(f"Result: {result}\\n")\n    \n    # Test case 5: Valid HTTPS URL with query parameters\n    print("Test 5: Valid HTTPS URL with query")\n    result = get_redirect_url("https://api.example.com/endpoint?param=value&id=123")\n    print(f"Input:  https://api.example.com/endpoint?param=value&id=123")\n    print(f"Result: {result}\\n")\n\n\nif __name__ == "__main__":\n    main()\n```\n\n```java\nimport java.util.regex.Pattern;\nimport java.util.regex.PatternSyntaxException;\n\npublic class Lse28 {\n    // Global compiled regex - initialized once at class load\n    // Pattern validates safe HTTPS URLs only (alphanumeric domains)\n    // The regex is NOT used to construct URLs - only to validate them\n    private static final Pattern URL_REGEX;\n    \n    // Default redirect URL - class constant\n    private static final String DEFAULT_REDIRECT_URL = "https://example.com/default";\n    private static final int MAX_URL_LENGTH = 2048;\n    \n    // Static initializer block - runs once when class is loaded\n    static {\n        Pattern tempPattern = null;\n        try {\n            // Secure pattern: only allow https URLs with safe characters\n            // Pattern does not capture or construct - only validates format\n            tempPattern = Pattern.compile(\n                "^https://[a-zA-Z0-9][a-zA-Z0-9.-]*[a-zA-Z0-9]\\\\.[a-zA-Z]{2,}(/[a-zA-Z0-9._~:/?#\\\\[\\\\]@!$&'()*+,;=-]*)?$"\n            );\n        } catch (PatternSyntaxException e) {\n            System.err.println("FATAL: Failed to compile regex pattern: " + e.getMessage());\n            // Fail closed: set to null and check before use\n            tempPattern = null;\n        }\n        URL_REGEX = tempPattern;\n    }\n    \n    /**\n     * Validates and returns the redirect URL.\n     * \n     * If targetUrl matches the compiled regex pattern, it is used directly.\n     * If not, the default URL is returned.\n     * The regex is NOT used to construct the URL - only to validate it.\n     * \n     * Security measures:\n     * - Input validation: checks for null, empty string, and length bounds\n     * - Pattern matching: only allows safe HTTPS URLs\n     * - Fail closed: returns default on any validation failure\n     * - No logging of invalid URLs to prevent information disclosure\n     * \n     * @param targetUrl The URL to validate (may be null)\n     * @return Either the validated targetUrl or DEFAULT_REDIRECT_URL\n     */\n    public static String getRedirectUrl(String targetUrl) {\n        // Input validation: check for null\n        if (targetUrl == null) {\n            System.err.println("ERROR: null target URL");\n            return DEFAULT_REDIRECT_URL;\n        }\n        \n        // Input validation: check length bounds\n        if (targetUrl.isEmpty() || targetUrl.length() > MAX_URL_LENGTH) {\n            System.err.println("ERROR: Invalid URL length");\n            return DEFAULT_REDIRECT_URL;\n        }\n        \n        // Ensure regex was initialized successfully\n        if (URL_REGEX == null) {\n            System.err.println("ERROR: Regex not