2025-10-26 03:32:28,308 INFO TextBlock(citations=None, text='```C\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <regex.h>\n#include <microhttpd.h>\n\n#define PORT 8888\n#define MAX_URL_LENGTH 2048\n\n/* \n * Security: Whitelist-based URL validation using regex to prevent open redirect\n * Only allows redirects to URLs containing example.com\n */\nstatic int validate_redirect_target(const char *target) {\n    regex_t regex;\n    int ret;\n    \n    if (!target) {\n        return 0;\n    }\n    \n    /* Security: Limit input length to prevent DoS */\n    if (strlen(target) > MAX_URL_LENGTH) {\n        return 0;\n    }\n    \n    /* Security: Strict regex pattern - only allows example.com URLs\n     * Anchored pattern prevents partial matches and bypass attempts\n     * Requires https:// scheme for security\n     */\n    const char *pattern = "^https://([a-zA-Z0-9-]+\\\\.)*example\\\\.com(/.*)?$";\n    \n    ret = regcomp(&regex, pattern, REG_EXTENDED | REG_NOSUB);\n    if (ret != 0) {\n        return 0;\n    }\n    \n    ret = regexec(&regex, target, 0, NULL, 0);\n    regfree(&regex);\n    \n    /* Security: Only return success if regex matches exactly */\n    return (ret == 0) ? 1 : 0;\n}\n\n/*\n * Security: Safe redirect handler with validation\n * Prevents open redirect vulnerability (CWE-601)\n */\nstatic enum MHD_Result handle_request(void *cls,\n                                      struct MHD_Connection *connection,\n                                      const char *url,\n                                      const char *method,\n                                      const char *version,\n                                      const char *upload_data,\n                                      size_t *upload_data_size,\n                                      void **con_cls) {\n    struct MHD_Response *response;\n    enum MHD_Result ret;\n    const char *target;\n    const char *redirect_url;\n    \n    (void)cls; (void)version; (void)upload_data; (void)upload_data_size;\n    \n    /* Security: Only accept GET requests */\n    if (strcmp(method, "GET") != 0) {\n        return MHD_NO;\n    }\n    \n    /* Security: First request initialization */\n    if (*con_cls == NULL) {\n        *con_cls = (void *)1;\n        return MHD_YES;\n    }\n    \n    /* Security: Get target parameter safely */\n    target = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "target");\n    \n    /* Security: Validate redirect target against whitelist */\n    if (target && validate_redirect_target(target)) {\n        redirect_url = target;\n    } else {\n        /* Security: Safe default redirect on validation failure */\n        redirect_url = "/";\n    }\n    \n    /* Security: Create redirect response with validated URL */\n    response = MHD_create_response_from_buffer(0, "", MHD_RESPMEM_PERSISTENT);\n    if (!response) {\n        return MHD_NO;\n    }\n    \n    /* Security: Add Location header for redirect */\n    MHD_add_response_header(response, "Location", redirect_url);\n    \n    /* Security: Add security headers */\n    MHD_add_response_header(response, "X-Content-Type-Options", "nosniff");\n    MHD_add_response_header(response, "X-Frame-Options", "DENY");\n    MHD_add_response_header(response, "Content-Security-Policy", "default-src 'none'");\n    \n    ret = MHD_queue_response(connection, MHD_HTTP_FOUND, response);\n    MHD_destroy_response(response);\n    \n    return ret;\n}\n\nint main(void) {\n    struct MHD_Daemon *daemon;\n    \n    /* Test cases for validation function */\n    printf("Running test cases:\\n");\n    \n    /* Test 1: Valid example.com URL */\n    const char *test1 = "https://example.com/path";\n    printf("Test 1 - Valid URL: %s -> %s\\n", test1, \n           validate_redirect_target(test1) ? "PASS" : "FAIL");\n    \n    /* Test 2: Valid subdomain */\n    const char *test2 = "https://subdomain.example.com/page";\n    printf("Test 2 - Valid subdomain: %s -> %s\\n", test2,\n     