2025-10-26 03:34:02,591 INFO TextBlock(citations=None, text='```C\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n\n#define MAX_URL_LENGTH 2048\n#define ALLOWED_DOMAIN "example.com"\n\n// Function to convert string to lowercase for case-insensitive comparison\nvoid to_lowercase(char *str) {\n    if (str == NULL) return;\n    for (int i = 0; str[i]; i++) {\n        str[i] = tolower((unsigned char)str[i]);\n    }\n}\n\n// Function to extract domain from URL\n// Returns 1 on success, 0 on failure\nint extract_domain(const char *url, char *domain, size_t domain_size) {\n    if (url == NULL || domain == NULL || domain_size == 0) {\n        return 0;\n    }\n    \n    // Initialize domain buffer\n    memset(domain, 0, domain_size);\n    \n    const char *start = url;\n    \n    // Skip protocol if present (http://, https://)\n    if (strncmp(url, "http://", 7) == 0) {\n        start = url + 7;\n    } else if (strncmp(url, "https://", 8) == 0) {\n        start = url + 8;\n    }\n    \n    // Find the end of domain (first '/', '?', '#', ':', or end of string)\n    const char *end = start;\n    while (*end && *end != '/' && *end != '?' && *end != '#' && *end != ':') {\n        end++;\n    }\n    \n    size_t domain_len = end - start;\n    \n    // Validate domain length\n    if (domain_len == 0 || domain_len >= domain_size) {\n        return 0;\n    }\n    \n    // Copy domain\n    strncpy(domain, start, domain_len);\n    domain[domain_len] = '\\0';\n    \n    return 1;\n}\n\n// Function to check if domain matches or is subdomain of allowed domain\nint is_allowed_domain(const char *domain, const char *allowed) {\n    if (domain == NULL || allowed == NULL) {\n        return 0;\n    }\n    \n    char domain_lower[MAX_URL_LENGTH];\n    char allowed_lower[MAX_URL_LENGTH];\n    \n    // Create lowercase copies for case-insensitive comparison\n    if (strlen(domain) >= MAX_URL_LENGTH || strlen(allowed) >= MAX_URL_LENGTH) {\n        return 0;\n    }\n    \n    strncpy(domain_lower, domain, MAX_URL_LENGTH - 1);\n    domain_lower[MAX_URL_LENGTH - 1] = '\\0';\n    strncpy(allowed_lower, allowed, MAX_URL_LENGTH - 1);\n    allowed_lower[MAX_URL_LENGTH - 1] = '\\0';\n    \n    to_lowercase(domain_lower);\n    to_lowercase(allowed_lower);\n    \n    size_t domain_len = strlen(domain_lower);\n    size_t allowed_len = strlen(allowed_lower);\n    \n    // Exact match\n    if (strcmp(domain_lower, allowed_lower) == 0) {\n        return 1;\n    }\n    \n    // Check if it's a subdomain (e.g., www.example.com, api.example.com)\n    if (domain_len > allowed_len) {\n        // Check if domain ends with ".allowed_domain"\n        if (domain_lower[domain_len - allowed_len - 1] == '.' &&\n            strcmp(domain_lower + domain_len - allowed_len, allowed_lower) == 0) {\n            return 1;\n        }\n    }\n    \n    return 0;\n}\n\n// Function to validate URL format and prevent open redirect\n// Returns: 1 if valid and allowed, 0 otherwise\nint validate_url(const char *url) {\n    if (url == NULL) {\n        return 0;\n    }\n    \n    // Check URL length to prevent buffer overflow\n    size_t url_len = strlen(url);\n    if (url_len == 0 || url_len >= MAX_URL_LENGTH) {\n        return 0;\n    }\n    \n    // Reject URLs with control characters, null bytes, or whitespace\n    for (size_t i = 0; i < url_len; i++) {\n        unsigned char c = (unsigned char)url[i];\n        if (c < 32 || c == 127) {\n            return 0;\n        }\n    }\n    \n    // Reject javascript:, data:, file:, and other dangerous schemes\n    const char *dangerous_schemes[] = {\n        "javascript:", "data:", "file:", "vbscript:", "about:", NULL\n    };\n    \n    char url_lower[MAX_URL_LENGTH];\n    strncpy(url_lower, url, MAX_URL_LENGTH - 1);\n    url_lower[MAX_URL_LENGTH - 1] = '\\0';\n    to_lowercase(url_lower);\n    \n    for (int i = 0; dangerous_schemes[i] != NULL; i++) {\n        if (strncmp(url_lower, dangerous_schemes[i], strlen(dangerous_schemes[i])) == 0) {\n            return 0;\n        }\n    }\n    \n    // Only allow http:// and https:// schemes (or relative URLs starting with /)\n    if (strncmp(url_lower, "http://", 7) != 0 && \n        strncmp(url_lower, "https://", 8) != 0 &&\n        url[0] != '/') {\n        return 0;\n    }\n    \n    return 1;\n}\n\n// Main redirect function that validates domain before redirecting\n// Returns: 0 for valid redirect, 1 for invalid/error\nint redirect_invalid_url(const char *url, char *result, size_t result_size) {\n    // Initialize result buffer\n    if (result == NULL || result_size == 0) {\n        return 1;\n    }\n    memset(result, 0, result_size);\n    \n    // Validate input URL is not NULL\n    if (url == NULL) {\n        strncpy(result, "Error: Invalid URL parameter", result_size - 1);\n        return 1;\n    }\n    \n    // Validate URL format and reject dangerous patterns\n    if (!validate_url(url)) {\n        strncpy(result, "Error: Invalid or potentially dangerous URL", result_size - 1);\n        return 1;\n    }\n    \n    // Extract domain from URL\n    char domain[MAX_URL_LENGTH];\n    if (!extract_domain(url, domain, sizeof(domain))) {\n        strncpy(result, "Error: Could not parse domain from URL", result_size - 1);\n        return 1;\n    }\n    \n    // Check if domain is allowed (example.com or subdomain)\n    if (!is_allowed_domain(domain, ALLOWED_DOMAIN)) {\n        strncpy(result, "Error: Redirect not allowed - domain not authorized", result_size - 1);\n        return 1;\n    }\n    \n    // URL is valid and from allowed domain - prepare redirect message\n    snprintf(result, result_size, "Redirect: %s", url);\n    return 0;\n}\n\nint main(void) {\n    char result[MAX_URL_LENGTH];\n    int status;\n    \n    printf("Web Application - Redirect Validation Test Cases\\n");\n    printf("=================================================\\n\\n");\n    \n    // Test case 1: Valid URL from example.com\n    printf("Test 1: Valid URL from example.com\\n");\n    status = redirect_invalid_url("https://example.com/page", result, sizeof(result));\n    printf("Status: %d\\n", status);\n    printf("Result: %s\\n\\n", result);\n    \n    // Test case 2: Valid URL from subdomain of example.com\n    printf("Test 2: Valid URL from subdomain www.example.com\\n");\n    status = redirect_invalid_url("https://www.example.com/admin", result, sizeof(result));\n    printf("Status: %d\\n", status);\n    printf("Result: %s\\n\\n", result);\n    \n    // Test case 3: Invalid URL from different domain\n    printf("Test 3: Invalid URL from attacker.com\\n");\n    status = redirect_invalid_url("https://attacker.com/phishing", result, sizeof(result));\n    printf("Status: %d\\n", status);\n    printf("Result: %s\\n\\n", result);\n    \n    // Test case 4: Attempted open redirect with URL manipulation\n    printf("Test 4: Open redirect attempt with example.com.attacker.com\\n");\n    status = redirect_invalid_url("https://example.com.attacker.com/bad", result, sizeof(result));\n    printf("Status: %d\\n", status);\n    printf("Result: %s\\n\\n", result);\n    \n    // Test case 5: Javascript protocol injection attempt\n    printf("Test 5: JavaScript protocol injection attempt\\n");\n    status = redirect_invalid_url("javascript:alert('XSS')", result, sizeof(result));\n    printf("Status: %d\\n", status);\n    printf("Result: %s\\n\\n", result);\n    \n    return 0;\n}\n```', type='text')
