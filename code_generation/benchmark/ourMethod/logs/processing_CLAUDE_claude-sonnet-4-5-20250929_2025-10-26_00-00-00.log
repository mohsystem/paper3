2025-10-26 03:33:00,805 INFO TextBlock(citations=None, text='```C\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <regex.h>\n#include <ctype.h>\n\n/* Security: Maximum allowed length for target parameter to prevent excessive memory usage */\n#define MAX_TARGET_LENGTH 256\n/* Security: Maximum allowed length for query string */\n#define MAX_QUERY_LENGTH 2048\n\n/**\n * Extract query parameter value from query string\n * Security: Validates buffer boundaries and null-terminates output\n * \n * @param query_string The full query string (e.g., "target=value&other=data")\n * @param param_name The parameter name to extract\n * @param output Buffer to store the extracted value\n * @param output_size Maximum size of output buffer\n * @return 1 on success, 0 on failure\n */\nint get_query_parameter(const char* query_string, const char* param_name, \n                        char* output, size_t output_size) {\n    /* Security: Validate all input pointers */\n    if (query_string == NULL || param_name == NULL || output == NULL || output_size == 0) {\n        return 0;\n    }\n    \n    /* Security: Initialize output buffer */\n    memset(output, 0, output_size);\n    \n    size_t param_len = strlen(param_name);\n    const char* pos = query_string;\n    \n    /* Search for parameter in query string */\n    while (pos != NULL) {\n        /* Find parameter name */\n        pos = strstr(pos, param_name);\n        if (pos == NULL) {\n            return 0;\n        }\n        \n        /* Security: Verify parameter is at start or after & and followed by = */\n        int is_start = (pos == query_string || *(pos - 1) == '&');\n        int has_equals = (*(pos + param_len) == '=');\n        \n        if (is_start && has_equals) {\n            /* Found the parameter, extract value */\n            const char* value_start = pos + param_len + 1;\n            const char* value_end = strchr(value_start, '&');\n            size_t value_len;\n            \n            if (value_end == NULL) {\n                value_len = strlen(value_start);\n            } else {\n                value_len = value_end - value_start;\n            }\n            \n            /* Security: Prevent buffer overflow - ensure value fits in output buffer */\n            if (value_len >= output_size) {\n                return 0;\n            }\n            \n            /* Security: Copy with boundary check and null-terminate */\n            memcpy(output, value_start, value_len);\n            output[value_len] = '\\0';\n            return 1;\n        }\n        \n        pos++;\n    }\n    \n    return 0;\n}\n\n/**\n * Validates and redirects based on target parameter\n * Security: Uses strict regex validation to prevent open redirect vulnerabilities\n * Only allows relative paths matching the pattern: alphanumeric/hyphen followed by period\n * \n * @param query_string The HTTP query string\n * @return Redirect location (caller must not free - returns static strings)\n */\nconst char* validate_and_redirect(const char* query_string) {\n    regex_t regex;\n    int reti;\n    char target[MAX_TARGET_LENGTH];\n    \n    /* Security: Validate input pointer */\n    if (query_string == NULL) {\n        return "/";\n    }\n    \n    /* Security: Validate query string length to prevent excessive processing */\n    if (strlen(query_string) > MAX_QUERY_LENGTH) {\n        return "/";\n    }\n    \n    /* \n     * Security: Strict regex pattern to prevent open redirect attacks\n     * Pattern: ^[a-zA-Z0-9-]+\\.\n     * - ^ anchors to start of string\n     * - [a-zA-Z0-9-]+ requires one or more alphanumeric or hyphen characters\n     * - \\. requires a literal period\n     * This prevents absolute URLs, protocol handlers, and directory traversal\n     */\n    const char* pattern = "^[a-zA-Z0-9-]+\\\\.";\n    \n    /* Compile regular expression */\n    reti = regcomp(&regex, pattern, REG_EXTENDED | REG_NOSUB);\n    if (reti != 0) {\n        /* Security: Fail closed - regex compilation failed */\n        return "/";\n    }\n    \n    /* Extract target parameter from query string */\n    if (!get_query_parameter(query_string, "target", target, sizeof(target))) {\n        /* Security: Target parameter not found or invalid, redirect to root */\n        regfree(&regex);\n        return "/";\n    }\n    \n    /* Security: Additional length validation after extraction */\n    size_t target_len = strlen(target);\n    if (target_len == 0 || target_len >= MAX_TARGET_LENGTH) {\n        regfree(&regex);\n        return "/";\n    }\n    \n    /* \n     * Security: Validate target does not contain dangerous patterns\n     * Block directory traversal, absolute URLs, and special characters\n     */\n    if (strstr(target, "..") != NULL || \n        strstr(target, "://") != NULL ||\n        target[0] == '/' ||\n        strstr(target, "\\\\") != NULL) {\n        regfree(&regex);\n        return "/";\n    }\n    \n    /* Execute regular expression match */\n    reti = regexec(&regex, target, 0, NULL, 0);\n    regfree(&regex);\n    \n    if (reti == 0) {\n        /* \n         * Security: Match successful, but return generic success indicator\n         * In real implementation, sanitize target further before actual redirect\n         * For this example, we return a safe indicator that validation passed\n         * Actual redirect would need additional context-specific validation\n         */\n        return "valid-match";\n    } else {\n        /* Security: Match failed, redirect to root */\n        return "/";\n    }\n}\n\n/* Test cases */\nint main(void) {\n    const char* result;\n    \n    printf("Test Case 1: Valid target 'page.html'\\n");\n    result = validate_and_redirect("target=page.html");\n    printf("Result: %s\\n\\n", result);\n    \n    printf("Test Case 2: Valid target 'my-page.php'\\n");\n    result = validate_and_redirect("target=my-page.php");\n    printf("Result: %s\\n\\n", result);\n    \n    printf("Test Case 3: Invalid target wi