2025-10-26 03:33:27,317 INFO TextBlock(citations=None, text='```C\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n\n// Maximum URL length to prevent excessive memory usage\n#define MAX_URL_LENGTH 2048\n// Maximum domain length\n#define MAX_DOMAIN_LENGTH 253\n\n// Structure to hold parsed URL components\ntypedef struct {\n    char scheme[16];\n    char domain[MAX_DOMAIN_LENGTH + 1];\n    char path[MAX_URL_LENGTH];\n    int port;\n} ParsedURL;\n\n// Safe string copy with bounds checking\nstatic void safe_strncpy(char *dest, const char *src, size_t dest_size) {\n    if (dest == NULL || src == NULL || dest_size == 0) {\n        return;\n    }\n    size_t i;\n    for (i = 0; i < dest_size - 1 && src[i] != '\\0'; i++) {\n        dest[i] = src[i];\n    }\n    dest[i] = '\\0';  // Ensure null termination\n}\n\n// Convert string to lowercase for case-insensitive comparison\nstatic void to_lowercase(char *str) {\n    if (str == NULL) return;\n    for (size_t i = 0; str[i] != '\\0'; i++) {\n        str[i] = tolower((unsigned char)str[i]);\n    }\n}\n\n// Parse URL into components\n// Returns 0 on success, -1 on failure\nstatic int parse_url(const char *url, ParsedURL *parsed) {\n    if (url == NULL || parsed == NULL) {\n        return -1;\n    }\n    \n    // Input validation: check URL length\n    size_t url_len = strlen(url);\n    if (url_len == 0 || url_len > MAX_URL_LENGTH) {\n        return -1;\n    }\n    \n    // Initialize parsed structure\n    memset(parsed, 0, sizeof(ParsedURL));\n    \n    // Create a working copy for parsing\n    char url_copy[MAX_URL_LENGTH + 1];\n    safe_strncpy(url_copy, url, sizeof(url_copy));\n    \n    char *ptr = url_copy;\n    char *scheme_end = strstr(ptr, "://");\n    \n    // Extract scheme\n    if (scheme_end != NULL) {\n        size_t scheme_len = scheme_end - ptr;\n        if (scheme_len >= sizeof(parsed->scheme)) {\n            return -1;  // Scheme too long\n        }\n        safe_strncpy(parsed->scheme, ptr, scheme_len + 1);\n        to_lowercase(parsed->scheme);\n        ptr = scheme_end + 3;  // Skip "://"\n    } else {\n        // No scheme found, invalid URL\n        return -1;\n    }\n    \n    // Extract domain (network location)\n    char *path_start = strchr(ptr, '/');\n    char *query_start = strchr(ptr, '?');\n    char *fragment_start = strchr(ptr, '#');\n    \n    // Find the earliest delimiter\n    char *domain_end = path_start;\n    if (query_start != NULL && (domain_end == NULL || query_start < domain_end)) {\n        domain_end = query_start;\n    }\n    if (fragment_start != NULL && (domain_end == NULL || fragment_start < domain_end)) {\n        domain_end = fragment_start;\n    }\n    \n    size_t domain_len;\n    if (domain_end != NULL) {\n        domain_len = domain_end - ptr;\n    } else {\n        domain_len = strlen(ptr);\n    }\n    \n    // Validate domain length\n    if (domain_len == 0 || domain_len > MAX_DOMAIN_LENGTH) {\n        return -1;\n    }\n    \n    // Copy and normalize domain\n    safe_strncpy(parsed->domain, ptr, domain_len + 1);\n    to_lowercase(parsed->domain);\n    \n    // Extract path if present\n    if (path_start != NULL) {\n        safe_strncpy(parsed->path, path_start, sizeof(parsed->path));\n    } else {\n        parsed->path[0] = '\\0';\n    }\n    \n    return 0;\n}\n\n// Redirect URL function\n// Returns 1 if redirected to example.com, 0 if 404 (invalid domain), -1 on error\nint redirect_url(const char *url) {\n    // Input validation: ensure url is not NULL\n    if (url == NULL) {\n        fprintf(stderr, "Error: Invalid input\\n");\n        return -1;\n    }\n    \n    // Validate URL length to prevent buffer issues\n    size_t url_len = strlen(url);\n    if (url_len == 0 || url_len > MAX_URL_LENGTH) {\n        fprintf(stderr, "Error: Invalid URL length\\n");\n        return -1;\n    }\n    \n    ParsedURL parsed;\n    \n    // Parse the URL\n    if (parse_url(url, &parsed) != 0) {\n        fprintf(stderr, "Error: Failed to parse URL\\n");\n        return -1;\n    }\n    \n    // Check if domain matches example.com (case-insensitive, already lowercased)\n    if (strcmp(parsed.domain, "example.com") == 0) {\n        // Redirect accepted\n        printf("Redirect: %s\\n", url);\n        return 1;\n    } else {\n        // Domain does not match, return 404\n        printf("404 Not Found\\n");\n        return 0;\n    }\n}\n\nint main(void) {\n    // Test case 1: Valid example.com URL\n    printf("Test 1: ");\n    redirect_url("http://example.com/path");\n    \n    // Test case 2: Valid example.com URL with HTTPS\n    printf("\\nTest 2: ");\n    redirect_url("https://example.com/");\n    \n    // Test case 3: Different domain (should return 404)\n    printf("\\nTest 3: ");\n    redirect_url("http://notexample.com/path");\n    \n    // Test case 4: Case insensitive example.com\n    printf("\\nTest 4: ");\n    redirect_url("http://EXAMPLE.COM/test");\n    \n    // Test case 5: Invalid domain (should return 404)\n    printf("\\nTest 5: ");\n    redirect_url("https://test.example.org/page");\n    \n    return 0;\n}\n```', type='text')
