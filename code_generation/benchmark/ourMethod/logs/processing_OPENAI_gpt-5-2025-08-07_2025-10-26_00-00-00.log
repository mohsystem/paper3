#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <regex.h>
#include <stdbool.h>

/*
 Simple CGI-capable web application in C:
 - Single route: this CGI/script endpoint
 - Takes a 'target' parameter from QUERY_STRING
 - If 'target' matches a regex that checks the URL contains "example.com" (case-insensitive), redirects to it
 - Otherwise redirects to "/"
 - Security: bounds checking, input length limits, CR/LF stripping for header safety, fail closed on errors
 - If not running as CGI (no GATEWAY_INTERFACE), runs 5 test cases as a console program.

 Build:
   cc -std=c99 -Wall -Wextra -Werror -O2 app.c -o app
 Run as CGI by placing it behind a web server or simulate by setting QUERY_STRING and GATEWAY_INTERFACE.
*/

#define MAX_QUERY_LEN   4096
#define MAX_URL_LEN     2048
#define MAX_RESPONSE    4096

static int hexval(char c) {
    if (c >= '0' && c <= '9') return c - '0';
    if (c >= 'a' && c <= 'f') return 10 + (c - 'a');
    if (c >= 'A' && c <= 'F') return 10 + (c - 'A');
    return -1;
}

// URL decode (application/x-www-form-urlencoded). Returns 0 on success, -1 on error.
static int url_decode(const char *src, char *dst, size_t dst_size) {
    if (!src || !dst || dst_size == 0) return -1;
    size_t si = 0, di = 0;
    while (src[si] != '\0') {
        if (di + 1 >= dst_size) { // keep space for null terminator
            return -1;
        }
        char ch = src[si];
        if (ch == '+') {
            dst[di++] = ' ';
            si++;
        } else if (ch == '%') {
            int h1 = hexval(src[si + 1]);
            int h2 = hexval(src[si + 2]);
            if (h1 < 0 || h2 < 0) {
                return -1;
            }
            dst[di++] = (char)((h1 << 4) | h2);
            si += 3;
        } else {
            dst[di++] = ch;
            si++;
        }
    }
    dst[di] = '\0';
    return 0;
}

// Extract a named parameter from a query string. Returns 1 if found and decoded successfully, 0 if not found, -1 on error.
static int get_param_value(const char *query, const char *name, char *out, size_t out_size) {
    if (!query || !name || !out || out_size == 0) return -1;

    size_t qlen = strnlen(query, MAX_QUERY_LEN + 1);
    if (qlen == 0 || qlen > MAX_QUERY_LEN) {
        return -1; // treat overlong query as error
    }

    const char *p = query;
    char keybuf[64]; // reasonable size for parameter name
    char valbuf[MAX_URL_LEN + 1];

    while (*p != '\0') {
        // Locate end of this pair
        const char *amp = strchr(p, '&');
        size_t pair_len = amp ? (size_t)(amp - p) : strlen(p);
        if (pair_len == 0) {
            if (!amp) break;
            p = amp + 1;
            continue;
        }

        // Find '=' within this pair
        const char *eq = memchr(p, '=', pair_len);
        size_t klen = eq ? (size_t)(eq - p) : pair_len;
        size_t vlen = eq ? (pair_len - klen - 1) : 0;

        if (klen < sizeof(keybuf)) {
            // Copy raw key
            char rawkey[64];
            memcpy(rawkey, p, klen);
            rawkey[klen] = '\0';

            // Decode key to compare
            if (url_decode(rawkey, keybuf, sizeof(keybuf)) == 0) {
                if (strcmp(keybuf, name) == 0) {
                    // Got the key we want
                    if (!eq) return -1; // key present without value -> error
                    if (vlen > MAX_URL_LEN) return -1; // too long
                    char rawval[MAX_URL_LEN + 1];
                    memcpy(rawval, eq + 1, vlen);
                    rawval[vlen] = '\0';
                    if (url_decode(rawval, valbuf, sizeof(valbuf)) != 0) {
                        return -1;
                    }
                    // Copy to out
                    size_t outlen = strnlen(valbuf, sizeof(valbuf));
                    if (outlen >= out_size) {
                        return -1;
                    }
                    memcpy(out, valbuf, outlen + 1);
                    return 1;
                }
            } else {
                return -1; // malformed key encoding
            }
        }
        if (!amp) break;
        p = amp + 1;
    }
    return 0;
}

static bool contains_crlf(const char *s) {
    if (!s) return true;
    for (const char *p = s; *p; ++p) {
        if (*p == '\r' || *p == '\n') return true;
    }
    return false;
}

// Check if URL contains "example.com" (case-insensitive) using POSIX regex.
static int matches_example_com(const char *url) {
    if (!url) return 0;

    regex_t re;
    // Simple pattern that matches any occurrence of "example.com"
    const char *pattern = "example\\.com";
    int rc = regcomp(&re, pattern, REG_ICASE | REG_NOSUB | REG_EXTENDED);
    if (rc != 0) {
        return 0; // fail closed
    }
    rc = regexec(&re, url, 0, NULL, 0);
    regfree(&re);
    return rc == 0 ? 1 : 0;
}

// Build an HTTP 302 response with appropriate Location based on query.
// Returns 0 on success, -1 on error.
static int build_redirect_response(const char *query, char *out, size_t out_size) {
    if (!out || out_size == 0) return -1;

    // Default location
    const char *fallback = "/";

    char target[MAX_URL_LEN + 1];
    target[0] = '\0';

    int got = get_param_value(query, "target", target, sizeof(target));
    const char *loc = fallback;

    if (got == 1) {
        // Basic validation
        size_t tlen = strnlen(target, sizeof(target));
        if (tlen > 0 && tlen < sizeof(target) && !contains_crlf(target) && matches_example_com(target)) {
            loc = target;
        }
    } else if (got == -1) {
        // Malformed query: fail closed to fallback
        loc = fallback;
    }

    // Build response
    // Keep it minimal: Status + Location + headers with zero-length body
    int n = snprintf(out, out_size,
                     "Status: 302 Found\r\n"
                     "Location: %s\r\n"
                     "Cache-Control: no-store\r\n"
                     "Content-Type: text/plain; charset=utf-8\r\n"
                     "Content-Length: 0\r\n"
                     "\r\n",
                     loc);
    if (n < 0 || (size_t)n >= out_size) {
        return -1;
    }
    return 0;
}

static void print_response_or_error(const char *query) {
    char resp[MAX_RESPONSE];
    if (build_redirect_response(query, resp, sizeof(resp)) == 0) {
        fputs(resp, stdout);
    } else {
        // Minimal error fallback: redirect to "/" safely
        fputs("Status: 302 Found\r\n"
              "Location: /\r\n"
              "Cache-Control: no-store\r\n"
              "Content-Type: text/plain; charset=utf-8\r\n"
              "Content-Length: 0\r\n"
              "\r\n", stdout);
    }
}

int main(void) {
    const char *cgi = getenv("GATEWAY_INTERFACE");
    if (cgi && *cgi) {
        // CGI mode
        const char *qs = getenv("QUERY_STRING");
        char safe_qs[MAX_QUERY_LEN + 1];
        if (!qs) {
            safe_qs[0] = '\0';
        } else {
            size_t qlen = strnlen(qs, MAX_QUERY_LEN + 1);
            if (qlen > MAX_QUERY_LEN) {
                safe_qs[0] = '\0'; // fail closed
            } else {
                memcpy(safe_qs, qs, qlen);
                safe_qs[qlen] = '\0';
            }
        }
        print_response_or_error(safe_qs);
        return 0;
    }

    // Test mode (not CGI): run 5 test cases
    const char *tests[5] = {
        "target=http%3A%2F%2Fexample.com%2Ffoo",
        "target=https://sub.example.com/path?x=1",
        "target=http://evil.com/?ref=example.com",
        "foo=bar",
        "target=https://good.com/%0D%0ASet-Cookie:%20x=1"
    };

    for (int i = 0; i < 5; ++i) {
        printf("---- Test %d ----\n", i + 1);
        print_response_or_error(tests[i]);
    }

    return 0;
}
