#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <regex.h>
#include <errno.h>

#define MAX_URL_LEN 2048
#define MAX_PATTERN_LEN 256

static regex_t g_url_re;
static int g_url_re_compiled = 0;

static size_t bounded_strlen(const char *s, size_t max) {
    if (s == NULL) return 0;
    size_t i = 0;
    for (; i < max; i++) {
        if (s[i] == '\0') break;
    }
    return i;
}

int module_load_init(const char *pattern) {
    if (pattern == NULL) {
        return -1;
    }
    size_t plen = bounded_strlen(pattern, MAX_PATTERN_LEN + 1);
    if (plen == 0 || plen > MAX_PATTERN_LEN) {
        return -1;
    }
    if (g_url_re_compiled) {
        return 0;
    }
    int rc = regcomp(&g_url_re, pattern, REG_EXTENDED | REG_NOSUB);
    if (rc != 0) {
        return -1;
    }
    g_url_re_compiled = 1;
    return 0;
}

int module_release(int perform_free) {
    if (perform_free && g_url_re_compiled) {
        regfree(&g_url_re);
        g_url_re_compiled = 0;
    }
    return 0;
}

/*
compute_redirect:
- Decides redirect target using a precompiled regex.
- If target_url fully matches the regex and fits limits, it is used.
- Otherwise, default_url is used.
- The regex is not used to construct the URL; it only gates selection.
Returns:
  0 on success and writes the chosen URL to out.
 -1 on failure (invalid inputs or insufficient buffer).
*/
int compute_redirect(const char *target_url, const char *default_url, char *out, size_t out_size) {
    if (!out || out_size == 0 || !default_url) {
        return -1;
    }
    if (!g_url_re_compiled) {
        return -1;
    }

    size_t def_len = bounded_strlen(default_url, MAX_URL_LEN + 1);
    if (def_len == 0 || def_len > MAX_URL_LEN) {
        return -1;
    }

    const char *chosen = default_url;
    if (target_url != NULL) {
        size_t tlen = bounded_strlen(target_url, MAX_URL_LEN + 1);
        if (tlen > 0 && tlen <= MAX_URL_LEN) {
            int match = regexec(&g_url_re, target_url, 0, NULL, 0);
            if (match == 0) {
                chosen = target_url;
            }
        }
    }

    size_t clen = bounded_strlen(chosen, MAX_URL_LEN + 1);
    if (clen == 0 || clen > MAX_URL_LEN) {
        return -1;
    }
    if (clen >= out_size) {
        return -1;
    }

    memcpy(out, chosen, clen);
    out[clen] = '\0';
    return 0;
}

int main(void) {
    const char *pattern = "^(https://(www\\.)?example\\.com(/[A-Za-z0-9._~:/?#\\[\\]@!$&'()*+,;=%-]*)?)$";
    const char *default_url = "https://www.example.com/home";
    if (module_load_init(pattern) != 0) {
        fprintf(stderr, "Failed to compile regex.\n");
        return 1;
    }

    char out[4096];

    // Test case 1: Match (https, example.com)
    const char *t1 = "https://example.com/welcome";
    if (compute_redirect(t1, default_url, out, sizeof(out)) == 0) {
        printf("Test1 Target: %s -> Redirect: %s\n", t1, out);
    } else {
        printf("Test1 failed\n");
    }

    // Test case 2: No match (http, not https)
    const char *t2 = "http://example.com/not-ssl";
    if (compute_redirect(t2, default_url, out, sizeof(out)) == 0) {
        printf("Test2 Target: %s -> Redirect: %s\n", t2, out);
    } else {
        printf("Test2 failed\n");
    }

    // Test case 3: No match (different domain)
    const char *t3 = "https://evil.com/uh-oh";
    if (compute_redirect(t3, default_url, out, sizeof(out)) == 0) {
        printf("Test3 Target: %s -> Redirect: %s\n", t3, out);
    } else {
        printf("Test3 failed\n");
    }

    // Test case 4: Match (https, www.example.com, query+fragment)
    const char *t4 = "https://www.example.com/ok?x=1#frag";
    if (compute_redirect(t4, default_url, out, sizeof(out)) == 0) {
        printf("Test4 Target: %s -> Redirect: %s\n", t4, out);
    } else {
        printf("Test4 failed\n");
    }

    // Test case 5: Overly long URL (should fail match due to length guard and use default)
    size_t base_len = strlen("https://www.example.com/");
    size_t extra_len = 3000;
    char *t5 = (char *)malloc(base_len + extra_len + 1);
    if (t5 == NULL) {
        fprintf(stderr, "Allocation failed\n");
        module_release(1);
        return 1;
    }
    strcpy(t5, "https://www.example.com/");
    memset(t5 + base_len, 'a', extra_len);
    t5[base_len + extra_len] = '\0';

    if (compute_redirect(t5, default_url, out, sizeof(out)) == 0) {
        printf("Test5 Target: %s...(%zu chars) -> Redirect: %s\n", "https://www.example.com/a", strlen(t5), out);
    } else {
        printf("Test5 failed\n");
    }

    free(t5);

    module_release(1);
    return 0;
}
