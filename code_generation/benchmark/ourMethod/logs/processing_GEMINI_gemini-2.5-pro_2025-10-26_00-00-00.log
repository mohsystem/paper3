#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <regex.h>

// Global static variable for the compiled regex, simulating module-level loading.
static regex_t compiled_regex;
static int is_regex_compiled = 0; // Flag to check if compilation was successful

/**
 * @brief Compiles the regular expression pattern.
 * This function should be called once when the application or module starts.
 * It exits the program on failure, as the redirector cannot function without a valid regex.
 *
 * @param pattern The regular expression string to compile.
 */
void init_redirector(const char* pattern) {
    if (pattern == NULL) {
        fprintf(stderr, "Error: Regex pattern cannot be NULL.\n");
        exit(EXIT_FAILURE);
    }

    // REG_EXTENDED for modern regex syntax.
    // REG_NOSUB is an optimization as we don't need capture groups.
    int reti = regcomp(&compiled_regex, pattern, REG_EXTENDED | REG_NOSUB);
    if (reti) {
        char errbuf[100];
        regerror(reti, &compiled_regex, errbuf, sizeof(errbuf));
        fprintf(stderr, "Could not compile regex: %s\n", errbuf);
        exit(EXIT_FAILURE);
    }
    is_regex_compiled = 1;
}

/**
 * @brief Frees the memory used by the compiled regular expression.
 * This function should be called once when the application or module shuts down.
 */
void cleanup_redirector() {
    if (is_regex_compiled) {
        regfree(&compiled_regex);
        is_regex_compiled = 0;
    }
}

/**
 * @brief Determines the redirect URL based on a regex match.
 * If the target URL matches the pre-compiled regex, the target URL is returned.
 * Otherwise, the default URL is returned.
 *
 * @param target_url The URL to check against the regex.
 * @param default_url The URL to use if the target_url does not match.
 * @return The appropriate redirect URL (either target_url or default_url).
 */
const char* get_redirect_url(const char* target_url, const char* default_url) {
    // Rule #1: Ensure all input is validated.
    if (target_url == NULL || default_url == NULL) {
        return default_url;
    }

    if (!is_regex_compiled) {
        fprintf(stderr, "Error: Redirector not initialized. Falling back to default URL.\n");
        return default_url; // Fail safe
    }

    // Rule #2: Use potentially dangerous functions with caution by validating inputs and checking returns.
    int reti = regexec(&compiled_regex, target_url, 0, NULL, 0);

    if (reti == 0) {
        // Match found
        return target_url;
    } else if (reti == REG_NOMATCH) {
        // No match found
        return default_url;
    } else {
        // An error occurred during matching.
        char errbuf[100];
        regerror(reti, &compiled_regex, errbuf, sizeof(errbuf));
        fprintf(stderr, "Regex match failed for URL '%s': %s. Falling back to default URL.\n", target_url, errbuf);
        return default_url; // Fail safe to default URL
    }
}

int main() {
    // The regular expression is compiled once when the module is loaded.
    // This pattern matches secure URLs for product pages with numeric IDs.
    const char* pattern = "^https://example\\.com/products/[0-9]+$";
    const char* default_url = "https://example.com/home";

    init_redirector(pattern);

    // Array of test cases.
    const char* test_urls[] = {
        // Test Case 1: A valid URL that should match.
        "https://example.com/products/12345",
        // Test Case 2: An invalid URL (non-numeric ID) that should not match.
        "https://example.com/products/abc-def",
        // Test Case 3: An invalid URL (insecure protocol) that should not match.
        "http://example.com/products/67890",
        // Test Case 4: An invalid URL (wrong domain) that should not match.
        "https://anotherexample.com/products/54321",
        // Test Case 5: An invalid URL (wrong path) that should not match.
        "https://example.com/items/13579"
    };
    int num_tests = sizeof(test_urls) / sizeof(test_urls[0]);

    printf("Regex Pattern: %s\n", pattern);
    printf("Default URL:   %s\n\n", default_url);

    for (int i = 0; i < num_tests; ++i) {
        const char* target = test_urls[i];
        const char* redirect = get_redirect_url(target, default_url);
        printf("Test Case %d:\n", i + 1);
        printf("  Target URL:    %s\n", target);
        printf("  Redirect URL:  %s\n", redirect);
        if (redirect == target) {
            printf("  Result:        Matched, using target URL.\n");
        } else {
            printf("  Result:        No match, using default URL.\n");
        }
        printf("\n");
    }

    // The compiled regex is freed when the module unloads.
    cleanup_redirector();

    return 0;
}
