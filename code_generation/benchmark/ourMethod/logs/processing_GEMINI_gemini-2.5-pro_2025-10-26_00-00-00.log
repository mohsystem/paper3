/**
 * @file simple_redirect_server.c
 * @brief A simple C web server using libmicrohttpd that redirects based on a URL parameter.
 *
 * This server listens on a specified port for GET requests. It expects a 'target'
 * query parameter. If the 'target' URL contains 'example.com' as its domain,
 * it redirects the client to that URL. Otherwise, it redirects to '/'.
 *
 * This code prioritizes security by using a strict regular expression to validate
 * the 'target' URL, preventing open redirect vulnerabilities.
 *
 * To compile:
 *   gcc -o server simple_redirect_server.c -lmicrohttpd
 *
 * To run:
 *   ./server
 *
 * Example Usage (from another terminal):
 *   # This should redirect to https://www.example.com
 *   curl -v "http://localhost:8888/?target=https://www.example.com"
 *
 *   # This should redirect to /
 *   curl -v "http://localhost:8888/?target=http://www.google.com"
 *
 *   # This is an attempt to exploit an open redirect, which should be blocked and redirect to /
 *   curl -v "http://localhost:8888/?target=http://evil.com?q=example.com"
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <regex.h>
#include <microhttpd.h>

#define PORT 8888
#define MAX_URL_LENGTH 2048
// A secure regex to ensure the domain is example.com or a subdomain thereof.
// This prevents open redirect vulnerabilities where "example.com" might appear
// in the path or query string of a malicious URL.
// Breakdown:
// ^https?://          - Starts with http:// or https://
// ([a-zA-Z0-9\\-]+\\.)* - Zero or more subdomains (e.g., www., sub.)
// example\\.com       - The literal domain name
// ([:/].*)?$          - Optionally followed by a port or path, to the end of the string
#define URL_REGEX "^https?://([a-zA-Z0-9\\-]+\\.)*example\\.com([:/].*)?$"

/**
 * @brief Validates a URL string against a predefined regular expression.
 *
 * @param target The URL string to validate.
 * @return 1 if the URL is valid and matches the regex, 0 otherwise.
 */
static int is_valid_target(const char *target) {
    if (target == NULL) {
        return 0;
    }

    // Rule #1: Ensure all input is validated. Check length before processing.
    if (strlen(target) > MAX_URL_LENGTH) {
        fprintf(stderr, "Error: Target URL exceeds maximum length of %d\n", MAX_URL_LENGTH);
        return 0;
    }

    regex_t regex;
    int reti;
    int result = 0;

    // Compile the regular expression
    reti = regcomp(&regex, URL_REGEX, REG_EXTENDED | REG_NOSUB);
    if (reti) {
        fprintf(stderr, "Error: Could not compile regex\n");
        return 0; // Fail closed if regex compilation fails
    }

    // Execute the regex against the target string
    reti = regexec(&regex, target, 0, NULL, 0);
    if (reti == 0) {
        // Match found
        result = 1;
    } else if (reti != REG_NOMATCH) {
        // An error occurred during regex execution
        char msgbuf[100];
        regerror(reti, &regex, msgbuf, sizeof(msgbuf));
        fprintf(stderr, "Regex match failed: %s\n", msgbuf);
        result = 0;
    }
    // If reti == REG_NOMATCH, result remains 0 (no match).

    // Free the compiled regular expression to prevent memory leaks
    regfree(&regex);

    return result;
}

/**
 * @brief The main request handler for libmicrohttpd.
 *
 * This function is called for each incoming HTTP request. It parses the 'target'
 * parameter, validates it, and issues a 302 redirect accordingly.
 */
static enum MHD_Result answer_to_connection(void *cls, struct MHD_Connection *connection,
                                           const char *url, const char *method,
                                           const char *version, const char *upload_data,
                                           size_t *upload_data_size, void **con_cls) {
    (void)cls;            // Unused
    (void)url;            // Unused
    (void)version;        // Unused
    (void)upload_data;    // Unused
    (void)upload_data_size; // Unused
    (void)con_cls;        // Unused

    // We only handle GET requests
    if (0 != strcmp(method, "GET")) {
        return MHD_NO; // Let libmicrohttpd handle the error response
    }

    const char *target_url = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "target");
    const char *redirect_location = "/"; // Default redirect location (fail-safe)

    if (is_valid_target(target_url)) {
        redirect_location = target_url;
    }

    // Create a response object
    struct MHD_Response *response = MHD_create_response_from_buffer(0, NULL, MHD_RESPMEM_PERSISTENT);
    if (response == NULL) {
        fprintf(stderr, "Error: Failed to create MHD response\n");
        return MHD_NO;
    }

    // Add the 'Location' header to perform the redirect.
    // MHD_add_response_header checks for NULL header/value internally.
    enum MHD_Result ret = MHD_add_response_header(response, "Location", redirect_location);
    if (ret != MHD_YES) {
        MHD_destroy_response(response);
        fprintf(stderr, "Error: Failed to add Location header to response\n");
        return MHD_NO;
    }

    // Queue the response with an HTTP 302 "Found" status code.
    ret = MHD_queue_response(connection, MHD_HTTP_FOUND, response);
    MHD_destroy_response(response); // Clean up the response object

    return ret;
}

/**
 * @brief Runs a series of test cases against the URL validation logic.
 */
static void run_test_cases() {
    printf("--- Running Validation Test Cases ---\n");

    const char *test_urls[] = {
        "https://www.example.com/some/path", // Test Case 1: Valid URL
        "http://sub.example.com",           // Test Case 2: Valid subdomain URL
        "http://www.google.com",            // Test Case 3: Invalid domain
        "http://www.evil.com/?q=example.com",// Test Case 4: Invalid URL with example.com in query
        NULL,                               // Test Case 5: NULL input
        "http://example.com.evil.com",      // Test Case 6: Invalid domain with example.com as subdomain
        "ftp://example.com/file",           // Test Case 7: Invalid protocol
        "http://example.com",               // Test Case 8: Valid base domain
        "https://sub-domain.with-dashes.example.com/path" // Test Case 9: Valid complex subdomain
    };
    int expected_results[] = {1, 1, 0, 0, 0, 0, 0, 1, 1};
    int num_tests = sizeof(test_urls) / sizeof(test_urls[0]);
    int passed = 0;

    for (int i = 0; i < num_tests; ++i) {
        int result = is_valid_target(test_urls[i]);
        const char *status = (result == expected_results[i]) ? "PASSED" : "FAILED";
        if (result == expected_results[i]) {
            passed++;
        }
        printf("Test %d: '%s' -> %s (Expected: %s)\n",
               i + 1, test_urls[i] ? test_urls[i] : "NULL",
               result ? "Valid" : "Invalid",
               expected_results[i] ? "Valid" : "Invalid");
    }
    printf("--- Test Summary: %d/%d passed ---\n\n", passed, num_tests);
}


int main(void) {
    // Run unit tests for the validation logic before starting the server
    run_test_cases();

    struct MHD_Daemon *daemon;

    daemon = MHD_start_daemon(MHD_USE_SELECT_INTERNALLY, PORT, NULL, NULL,
                              &answer_to_connection, NULL, MHD_OPTION_END);

    if (NULL == daemon) {
        fprintf(stderr, "Error: Failed to start daemon on port %d\n", PORT);
        return 1;
    }

    printf("Server running on http://localhost:%d\n", PORT);
    printf("Press Enter to stop the server...\n");
    (void)getchar();

    MHD_stop_daemon(daemon);
    printf("Server stopped.\n");

    return 0;
}
