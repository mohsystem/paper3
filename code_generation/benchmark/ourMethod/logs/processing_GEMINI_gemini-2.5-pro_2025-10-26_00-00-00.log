#include <stdio.h>
#include <string.h>
#include <regex.h>
#include <stdlib.h>

// A reasonable maximum length for a URL parameter to prevent abuse.
#define MAX_TARGET_LEN 2048

/**
 * @brief Processes a redirect request based on a target string.
 *
 * This function checks if the target string matches the regular expression
 * "^[a-zA-Z0-9-]+\.". If it matches, it prints a message indicating a
 * redirect to the target. Otherwise, it prints a message indicating a
 * redirect to the root ("/"). It includes validation for NULL input and
 * input length.
 *
 * @param target The target string from the query parameter.
 */
void process_redirect_request(const char* target) {
    // Rule #1: Ensure all input is validated.
    // Check for NULL input first.
    if (target == NULL) {
        printf("Invalid target (NULL). Redirecting to: /\n");
        return;
    }

    // Rule #1 & #3: Validate input length to prevent excessive memory usage or long processing.
    if (strlen(target) > MAX_TARGET_LEN) {
        printf("Invalid target (too long). Redirecting to: /\n");
        return;
    }

    regex_t regex;
    int reti;
    // The pattern matches a string that starts with one or more alphanumeric
    // characters or hyphens, followed by a literal period.
    // The backslash for the period must be escaped in the C string.
    const char* pattern = "^[a-zA-Z0-9-]+\\.";

    // Compile the regular expression.
    // REG_EXTENDED allows for modern regex syntax.
    // REG_NOSUB is a performance optimization as we only need to know if it matches,
    // not what the matched substrings are.
    reti = regcomp(&regex, pattern, REG_EXTENDED | REG_NOSUB);
    if (reti) {
        // This indicates a programming error (bad regex pattern).
        fprintf(stderr, "Could not compile regex\n");
        // Fail safely by redirecting to a known-good location.
        printf("Internal error. Redirecting to: /\n");
        return;
    }

    // Execute the regular expression against the target string.
    reti = regexec(&regex, target, 0, NULL, 0);

    // Process the result.
    if (reti == 0) {
        // A match was found.
        printf("Target matches. Redirecting to: %s\n", target);
    } else if (reti == REG_NOMATCH) {
        // No match was found.
        printf("Target does not match pattern. Redirecting to: /\n");
    } else {
        // An error occurred during regex execution.
        char msgbuf[128];
        regerror(reti, &regex, msgbuf, sizeof(msgbuf));
        fprintf(stderr, "Regex match failed: %s\n", msgbuf);
        // Fail safely.
        printf("Internal error. Redirecting to: /\n");
    }

    // Free the memory allocated for the compiled regular expression.
    regfree(&regex);
}

int main() {
    printf("--- Redirect Logic Test Cases ---\n\n");

    // Test Case 1: A valid target that should be redirected to.
    printf("Test Case 1: \"valid-domain.com/path\"\n");
    process_redirect_request("valid-domain.com/path");
    printf("----------------------------------------\n");

    // Test Case 2: An invalid target that starts with a forbidden character.
    printf("Test Case 2: \".invalid-start.com\"\n");
    process_redirect_request(".invalid-start.com");
    printf("----------------------------------------\n");

    // Test Case 3: An invalid target that is missing the required period.
    printf("Test Case 3: \"domain-without-period\"\n");
    process_redirect_request("domain-without-period");
    printf("----------------------------------------\n");

    // Test Case 4: An invalid empty string target.
    printf("Test Case 4: \"\" (empty string)\n");
    process_redirect_request("");
    printf("----------------------------------------\n");

    // Test Case 5: A NULL target, representing a missing parameter.
    printf("Test Case 5: NULL\n");
    process_redirect_request(NULL);
    printf("----------------------------------------\n");

    return 0;
}
