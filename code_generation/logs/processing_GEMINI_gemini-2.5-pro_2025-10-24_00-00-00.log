            printf("Response body (first 400 chars):\n%.400s\n\n", response->memory);
            free_memory_struct(response);
        } else {
            printf("Request failed.\n\n");
        }
    }

    // curl_global_cleanup() should be called once per program
    curl_global_cleanup();

    return 0;
}
