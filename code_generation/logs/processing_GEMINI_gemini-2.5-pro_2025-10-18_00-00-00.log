```c
#define _DEFAULT_SOURCE // For DT_REG on some systems
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <pthread.h>
#include <dirent.h>
#include <unistd.h>
#include <sys/stat.h>
#include <errno.h>
#include <time.h>

// Basic platform compatibility
#if defined(_WIN32) || defined(_WIN64)
#include <windows.h>
#include <direct.h>
#define MKDIR(path, mode) _mkdir(path)
#define RMDIR(path) _rmdir(path)
#define PATH_SEPARATOR "\\"
#ifndef PATH_MAX
#define PATH_MAX MAX_PATH
#endif
#define strdup _strdup
#else
#include <limits.h>
#define MKDIR(path, mode) mkdir(path, mode)
#define RMDIR(path) rmdir(path)
#define PATH_SEPARATOR "/"
#endif

// A structure to hold the shared work queue and synchronization primitive
typedef struct {
    char** file_paths;
    int file_count;
    int next_index;
    pthread_mutex_t mtx;
} WorkQueue;

typedef struct {
    WorkQueue* queue;
    int thread_id;
} ThreadArgs;

void process_file(const char* file_path, int thread_id) {
    printf("Thread %d started processing: %s\n", thread_id, file_path);
    // Simulate work with random duration
#if defined(_WIN32) || defined(_WIN64)
    Sleep(100 + (rand() % 150));
#else
    struct timespec ts = {0, (100 + (rand() % 150)) * 1000000L}; // ms to ns
    nanosleep(&ts, NULL);
#endif
    printf("Thread %d finished processing: %s\n", thread_id, file_path);
}

void* worker_thread(void* arg) {
    ThreadArgs* thread_args = (ThreadArgs*)arg;
    WorkQueue* queue = thread_args->queue;
    int thread_id = thread_args->thread_id;
    free(thread_args); // Args are heap-allocated per thread, free immediately

    while (1) {
        char* file_to_process = NULL;

        pthread_mutex_lock(&queue->mtx);
        if (queue->next_index < queue->file_count) {
            file_to_process = queue->file_paths[queue->next_index];
            queue->next_index++;
        }
        pthread_mutex_unlock(&queue->mtx);

        if (file_to_process == NULL) {
            break; // No more work
        }
        process_file(file_to_process, thread_id);
    }
    return NULL;
}

void free_file_list(char** file_paths, int count) {
    if (!file_paths) return;
    for (int i = 0; i < count; ++i) {
        free(file_paths[i]);
        file_paths[i] = NULL;
    }
    free(file_paths);
}

int populate_file_list(WorkQueue* queue, const char* dir_path) {
    DIR *d = opendir(dir_path);
    if (!d) {
        perror("opendir failed");
        return -1;
    }

    struct dirent *dir;
    int count = 0;
    while ((dir = readdir(d)) != NULL) {
        // Skip "." and ".." directories
        if (strcmp(dir->d_name, ".") == 0 || strcmp(dir->d_name, "..") == 0) continue;
        
        char path_buffer[PATH_MAX];
        snprintf(path_buffer, sizeof(path_buffer), "%s%s%s", dir_path, PATH_SEPARATOR, dir->d_name);
        struct stat path_stat;
        if(stat(path_buffer, &path_stat) == 0 && S_ISREG(path_stat.st_mode)){
            count++;
        }
    }
    rewinddir(d);

    if (count == 0) {
        closedir(d);
        return 0; // No files to process
    }

    queue->file_paths = (char**)calloc(count, sizeof(char*));
    if (!queue->file_paths) {
        perror("calloc for file_paths failed");
        closedir(d);
        return -1;
    }
    
    int current_index = 0;
    while ((dir = readdir(d)) != NULL && current_index < count) {
        if (strcmp(dir->d_name, ".") == 0 || strcmp(dir->d_name, "..") == 0) continue;

        char path_buffer[PATH_MAX];
        int len = snprintf(path_buffer, sizeof(path_buffer), "%s%s%s", dir_path, PATH_SEPARATOR, dir->d_name);
        if (len < 0 || (size_t)len >= sizeof(path_buffer)) {
            fprintf(stderr, "Path construction failed for %s\n", dir->d_name);
            continue;
        }

        struct stat path_stat;
        if(stat(path_buffer, &path_stat) == 0 && S_ISREG(path_stat.st_mode)) {
            queue->file_paths[current_index] = strdup(path_buffer);
            if (!queue->file_paths[current_index]) {
                perror("strdup failed");
                free_file_list(queue->file_paths, current_index);
                queue->file_paths = NULL;
                closedir(d);
                return -1;
            }
            current_index++;
        }
    }
    queue->file_count = current_index;
    closedir(d);
    return 0;
}

void cleanup_directory(const char* dir_path, char** file_paths, int file_count) {
    for (int i = 0; i < file_count; ++i) {
        if (remove(file_paths[i]) != 0) {
            perror("Failed to remove file");
        }
    }
    if (RMDIR(dir_path) != 0) {
        perror("Failed to remove directory");
    }
}

void run_simulation(const char* test_name, int num_files, int num_threads) {
    printf("====================================================\n");
    printf("Running Test: %s\n", test_name);
    printf("====================================================\n");

    char dir_path[256];
    snprintf(dir_path, sizeof(dir_path), "test_dir_c_%d", rand());

    if (MKDIR(dir_path, 0755) != 0 && errno != EEXIST) {
        perror("mkdir failed");
        return;
    }

    for (int i = 0; i < num_files; ++i) {
        char file_path[PATH_MAX];
        snprintf(file_path, sizeof(file_path), "%s%sfile_%d.txt", dir_path, PATH_SEPARATOR, i);
        FILE *fp = fopen(file_path, "w");
        if (fp) {
            fprintf(fp, "This is test file %d.\n", i);
            fclose(fp);
        } else {
            perror("fopen failed");
        }
    }

    WorkQueue queue = { .file_paths = NULL, .file_count = 0, .next_index = 0 };
    if (populate_file_list(&queue, dir_path) != 0) {
        cleanup_directory(dir_path, queue.file_paths, queue.file_count);
        free_file_list(queue.file_paths, queue.file_count);
        return;
    }
    
    if (pthread_mutex_init(&queue.mtx, NULL) != 0) {
        perror("pthread_mutex_init failed");
        cleanup_directory(dir_path, queue.file_paths, queue.file_count);
        free_file_list(queue.file_paths, queue.file_count);
        return;
    }

    if (num_threads <= 0) {
        fprintf(stderr, "Number of threads must be positive.\n");
    }
    pthread_t* threads = (pthread_t*)malloc(num_threads * sizeof(pthread_t));
    if (!threads) {
        perror("malloc for threads failed");
        pthread_mutex_destroy(&queue.mtx);
        cleanup_directory(dir_path, queue.file_paths, queue.file_count);
        free_file_list(queue.file_paths, queue.file_count);
        return;
    }

    for (int i = 0; i < num_threads; ++i) {
        ThreadArgs* args = (ThreadArgs*)malloc(sizeof(ThreadArgs));
        if (!args) {
            perror("malloc for thread args failed");
            num_threads = i; // Stop creating threads
            break;
        }
        args->queue = &queue;
        args->thread_id = i + 1;
        if (pthread_create(&threads[i], NULL, worker_thread, args) != 0) {
            perror("pthread_create failed");
            free(args);
            num_threads = i;
            break;
        }
    }

    for (int i = 0; i < num_threads; ++i) {
        pthread_join(threads[i], NULL);
    }

    pthread_mutex_destroy(&queue.mtx);
    cleanup_directory(dir_path, queue.file_paths, queue.file_count);
    free_file_list(queue.file_paths, queue.file_count);
    free(threads);

    printf("\nTest '%s' finished.\n\n", test_name);
}

