#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/types.h>

#define CURL_STATICLIB
#include <curl/curl.h>

#ifdef _WIN32
#include <direct.h>
#include <io.h>
#define fileno _fileno
#define fstat _fstat
#define stat _stat
#define S_ISREG(m) (((m) & S_IFMT) == S_IFREG)
#else
#include <unistd.h>
#endif

// Struct to hold server response data
struct MemoryStruct {
    char *memory;
    size_t size;
};

// Callback for writing response data from server into MemoryStruct
static size_t WriteMemoryCallback(void *contents, size_t size, size_t nmemb, void *userp) {
    size_t realsize = size * nmemb;
    struct MemoryStruct *mem = (struct MemoryStruct *)userp;

    // Check for potential overflow before allocation
    if (mem->size + realsize < mem->size) {
        fprintf(stderr, "Error: size_t overflow detected in callback\n");
        return 0; // Signal error
    }

    char *ptr = realloc(mem->memory, mem->size + realsize + 1);
    if(ptr == NULL) {
        fprintf(stderr, "Error: not enough memory (realloc returned NULL)\n");
        return 0; // Signal error
    }

    mem->memory = ptr;
    memcpy(&(mem->memory[mem->size]), contents, realsize);
    mem->size += realsize;
    mem->memory[mem->size] = 0;

    return realsize;
}

// The function returns a dynamically allocated string that the caller must free.
char* uploadFile(const char* url, const char* filePath) {
    if (url == NULL || filePath == NULL || url[0] == '\0' || filePath[0] == '\0') {
        char* error_msg = malloc(64);
        if (error_msg) snprintf(error_msg, 64, "Error: URL or file path is empty.");
        return error_msg;
    }

    struct stat file_info;
    if (stat(filePath, &file_info) != 0) {
        char* error_msg = malloc(256);
        if (error_msg) snprintf(error_msg, 256, "Error: Cannot stat file: %s", filePath);
        return error_msg;
    }

    if (!S_ISREG(file_info.st_mode)) {
        char* error_msg = malloc(256);
        if (error_msg) snprintf(error_msg, 256, "Error: Path is not a regular file: %s", filePath);
        return error_msg;
    }
    
    FILE *fp = fopen(filePath, "rb");
    if (!fp) {
        char* error_msg = malloc(256);
        if (error_msg) snprintf(error_msg, 256, "Error: Could not open file for reading: %s", filePath);
        return error_msg;
    }

    if(fstat(fileno(fp), &file_info) != 0) {
        fclose(fp);
        char* error_msg = malloc(256);
        if (error_msg) snprintf(error_msg, 256, "Error: fstat failed on open file: %s", filePath);
        return error_msg;
    }
    curl_off_t fileSize = file_info.st_size;

    CURL *curl_handle = curl_easy_init();
    if (!curl_handle) {
        fclose(fp);
        char* error_msg = malloc(64);
        if (error_msg) snprintf(error_msg, 64, "Error: curl_easy_init() failed.");
        return error_msg;
    }
    
    struct MemoryStruct chunk;
    chunk.memory = malloc(1); 
    chunk.size = 0;
    if (chunk.memory == NULL) {
        fclose(fp);
        curl_easy_cleanup(curl_handle);
        char* error_msg = malloc(64);
        if(error_msg) snprintf(error_msg, 64, "Error: initial malloc failed.");
        return error_msg;
    }

    curl_easy_setopt(curl_handle, CURLOPT_UPLOAD, 1L);
    curl_easy_setopt(curl_handle, CURLOPT_URL, url);
    curl_easy_setopt(curl_handle, CURLOPT_READDATA, fp);
    curl_easy_setopt(curl_handle, CURLOPT_INFILESIZE_LARGE, fileSize);
    curl_easy_setopt(curl_handle, CURLOPT_WRITEFUNCTION, WriteMemoryCallback);
    curl_easy_setopt(curl_handle, CURLOPT_WRITEDATA, (void *)&chunk);

    curl_easy_setopt(curl_handle, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl_handle, CURLOPT_SSL_VERIFYHOST, 2L);

    CURLcode res = curl_easy_perform(curl_handle);
    fclose(fp);

    char* result_string = NULL;
    if (res != CURLE_OK) {
        const size_t buffer_size = 256 + strlen(curl_easy_strerror(res));
        result_string = malloc(buffer_size);
        if (result_string) snprintf(result_string, buffer_size, "Error: curl_easy_perform() failed: %s", curl_easy_strerror(res));
    } else {
        long http_code = 0;
        curl_easy_getinfo(curl_handle, CURLINFO_RESPONSE_CODE, &http_code);
        if (http_code >= 200 && http_code < 300) {
            const size_t buffer_size = 40 + chunk.size;
            result_string = malloc(buffer_size);
            if (result_string) snprintf(result_string, buffer_size, "Success (%ld). Server response: %s", http_code, chunk.memory);
        } else {
            const size_t buffer_size = 60 + chunk.size;
            result_string = malloc(buffer_size);
            if(result_string) snprintf(result_string, buffer_size, "Error: Server returned HTTP status %ld. Response: %s", http_code, chunk.memory);
        }
    }
    
    free(chunk.memory);
    curl_easy_cleanup(curl_handle);

    if (result_string == NULL) {
        result_string = malloc(32);
        if (result_string) snprintf(result_string, 32, "Error: memory allocation failed.");
    }
    return result_string;
}

void run_c_test_cases() {
    const char* test_file_name = "test_upload_c.txt";
    const char* test_dir_name = "test_dir_c";
    FILE* test_file = fopen(test_file_name, "w");
    if (test_file) {
        fprintf(test_file, "This is a C test file for upload.\n");
        fclose(test_file);
    }
    #ifdef _WIN32
        _mkdir(test_dir_name);
    #else
        mkdir(test_dir_name, 0700);
    #endif

    const char* url = "http://localhost:8080/upload-c.txt";
    char* response = NULL;

    printf("--- C Test Case 1: Valid file upload ---\n");
    response = uploadFile(url, test_file_name);
    if(response) { printf("%s\n\n", response); free(response); }

    printf("--- C Test Case 2: Non-existent file ---\n");
    response = uploadFile(url, "nonexistent_c.txt");
    if(response) { printf("%s\n\n", response); free(response); }

    printf("--- C Test Case 3: Uploading a directory ---\n");
    response = uploadFile(url, test_dir_name);
    if(response) { printf("%s\n\n", response); free(response); }

    printf("--- C Test Case 4: Empty file path ---\n");
    response = uploadFile(url, "");
    if(response) { printf("%s\n\n", response); free(response); }
    
    printf("--- C Test Case 5: Empty URL ---\n");
    response = uploadFile("", test_file_name);
    if(response) { printf("%s\n\n", response); free(response); }

    remove(test_file_name);
    #ifdef _WIN32
        _rmdir(test_dir_name);
    #else
        rmdir(test_dir_name);
    #endif
}

int main(void) {
    // Note: To run this code, you need a server listening on http://localhost:8080
    // that accepts PUT requests. A simple Python server is provided in the thought process.
    if (curl_global_init(CURL_GLOBAL_ALL) != 0) {
        fprintf(stderr, "Error: curl_global_init() failed.\n");
        return 1;
    }

    run_c_test_cases();

    curl_global_cleanup();

    return 0;
}
