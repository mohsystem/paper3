    printf("Is %d narcissistic? %s\n", test4, narcissistic(test4) ? "true" : "false");
    
    // Test case 5: 9474 (true)
    int test5 = 9474;
    printf("Is %d narcissistic? %s\n", test5, narcissistic(test5) ? "true" : "false");
    
    return 0;
}
