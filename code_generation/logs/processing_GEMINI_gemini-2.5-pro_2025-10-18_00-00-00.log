```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <arpa/inet.h>
#include <sys/socket.h>
#include <pthread.h>
#include <errno.h>

#define BUFFER_SIZE 4096
#define MAX_CLIENTS 100

// Globals for server
int client_sockets[MAX_CLIENTS];
pthread_mutex_t clients_mutex = PTHREAD_MUTEX_INITIALIZER;

void* handle_client(void* socket_desc);
void server_main(int port);
void* send_messages(void* socket_desc);
void* receive_messages(void* socket_desc);
void client_main(const char* ip, int port);

// Broadcasts a message to all clients except the sender
void broadcast_message(const char* message, int sender_sock) {
    pthread_mutex_lock(&clients_mutex);
    for (int i = 0; i < MAX_CLIENTS; i++) {
        if (client_sockets[i] != 0 && client_sockets[i] != sender_sock) {
            if (send(client_sockets[i], message, strlen(message), 0) < 0) {
                perror("send failed");
            }
        }
    }
    pthread_mutex_unlock(&clients_mutex);
}

// Adds a client socket to the global array
void add_client(int sock) {
    pthread_mutex_lock(&clients_mutex);
    for (int i = 0; i < MAX_CLIENTS; i++) {
        if (client_sockets[i] == 0) {
            client_sockets[i] = sock;
            break;
        }
    }
    pthread_mutex_unlock(&clients_mutex);
}

// Removes a client socket from the global array
void remove_client(int sock) {
    pthread_mutex_lock(&clients_mutex);
    for (int i = 0; i < MAX_CLIENTS; i++) {
        if (client_sockets[i] == sock) {
            client_sockets[i] = 0;
            break;
        }
    }
    pthread_mutex_unlock(&clients_mutex);
}

// Handles a single client connection in a separate thread
void* handle_client(void* socket_desc) {
    int sock = *(int*)socket_desc;
    free(socket_desc);
    
    char buffer[BUFFER_SIZE];
    char message[BUFFER_SIZE + 30]; 
    ssize_t read_size;

    snprintf(message, sizeof(message), "Client %d has joined the chat.\n", sock);
    printf("%s", message);
    broadcast_message(message, -1);

    while ((read_size = recv(sock, buffer, BUFFER_SIZE - 1, 0)) > 0) {
        buffer[read_size] = '\0';
        snprintf(message, sizeof(message), "Client %d: %s\n", sock, buffer);
        printf("%s", message); 
        broadcast_message(message, sock);
        memset(buffer, 0, BUFFER_SIZE);
    }

    if (read_size == 0) {
        snprintf(message, sizeof(message), "Client %d disconnected.\n", sock);
        printf("%s", message);
        broadcast_message(message, sock);
    } else if (read_size == -1) {
        perror("recv failed");
    }

    remove_client(sock);
    close(sock);
    return NULL;
}


// Server entry point
void server_main(int port) {
    int server_fd, new_socket;
    struct sockaddr_in server, client;
    int opt = 1;
    
    memset(client_sockets, 0, sizeof(client_sockets));

    if ((server_fd = socket(AF_INET, SOCK_STREAM, 0)) < 0) {
        perror("socket failed");
        exit(EXIT_FAILURE);
    }

    if (setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt))) {
        perror("setsockopt");
        close(server_fd);
        exit(EXIT_FAILURE);
    }

    server.sin_family = AF_INET;
    server.sin_addr.s_addr = INADDR_ANY;
    server.sin_port = htons(port);

    if (bind(server_fd, (struct sockaddr *)&server, sizeof(server)) < 0) {
        perror("bind failed");
        close(server_fd);
        exit(EXIT_FAILURE);
    }

    if (listen(server_fd, 3) < 0) {
        perror("listen");
        close(server_fd);
        exit(EXIT_FAILURE);
    }

    printf("Server listening on port %d\n", port);
    
    socklen_t c = sizeof(struct sockaddr_in);
    while ((new_socket = accept(server_fd, (struct sockaddr *)&client, &c))) {
        if (new_socket < 0) {
            perror("accept failed");
            continue;
        }

        int current_clients = 0;
        pthread_mutex_lock(&clients_mutex);
        for(int i=0; i<MAX_CLIENTS; i++) if(client_sockets[i] != 0) current_clients++;
        pthread_mutex_unlock(&clients_mutex);

        if (current_clients >= MAX_CLIENTS) {
            fprintf(stderr, "Max clients reached. Connection rejected.\n");
            const char* msg = "Server is full.\n";
            send(new_socket, msg, strlen(msg), 0);
            close(new_socket);
            continue;
        }

        char client_ip[INET_ADDRSTRLEN];
        inet_ntop(AF_INET, &client.sin_addr, client_ip, INET_ADDRSTRLEN);
        printf("Connection accepted from %s:%d\n", client_ip, ntohs(client.sin_port));

        add_client(new_socket);

        pthread_t client_thread;
        int* new_sock_ptr = malloc(sizeof(int));
        if (new_sock_ptr == NULL) {
            perror("malloc for new socket ptr failed");
            close(new_socket);
            remove_client(new_socket);
            continue;
        }
        *new_sock_ptr = new_socket;
        
        if (pthread_create(&client_thread, NULL, handle_client, (void*)new_sock_ptr) < 0) {
            perror("could not create thread");
            free(new_sock_ptr);
            close(new_socket);
            remove_client(new_socket);
        }
        pthread_detach(client_thread);
    }
    
    close(server_fd);
}

// Client thread for sending messages
void* send_messages(void* socket_desc) {
    int sock = *(int*)socket_desc;
    char message[BUFFER_SIZE];

    while (fgets(message, BUFFER_SIZE, stdin) != NULL) {
        message[strcspn(message, "\n")] = 0;
        if (strlen(message) > 0) {
            if (send(sock, message, strlen(message), 0) < 0) {
                perror("send failed");
                break;
            }
        }
    }
    shutdown(sock, SHUT_WR);
    return NULL;
}

// Client thread for receiving messages
void* receive_messages(void* socket_desc) {
    int sock = *(int*)socket_desc;
    char server_reply[BUFFER_SIZE];
    ssize_t read_size;

    while ((read_size = recv(sock, server_reply, BUFFER_SIZE - 1, 0)) > 0) {
        server_reply[read_size] = '\0';
        printf("%s", server_reply);
        fflush(stdout);
    }

    if (read_size == 0) {
        printf("\nServer disconnected.\n");
    } else {
        perror("recv failed");
    }
    exit(0);
}

// Client entry point
void client_main(const char* ip, int port) {
    int sock;
    struct sockaddr_in server;
    
    sock = socket(AF_INET, SOCK_STREAM, 0);
    if (sock == -1) {
        perror("Could not create socket");
        exit(EXIT_FAILURE);
    }

    server.sin_family = AF_INET;
    server.sin_port = htons(port);
    if (inet_pton(AF_INET, ip, &server.sin_addr) <= 0) {
        fprintf(stderr, "Invalid address/ Address not supported\n");
        close(sock);
        exit(EXIT_FAILURE);
    }

    if (connect(sock, (struct sockaddr *)&server, sizeof(server)) < 0) {
        perror("connect failed");
        close(sock);
        exit(EXIT_FAILURE);
    }
    
    printf("Connected to server. You can start typing.\n");
    
    pthread_t send_thread, recv_thread;
    
    if (pthread_create(&send_thread, NULL, send_messages, (void*)&sock) < 0) {
        perror("could not create send thread");
        close(sock);
        exit(EXIT_FAILURE);
    }
    
    if (pthread_create(&recv_thread, NULL, receive_messages, (void*)&sock) < 0) {
        perror("could not create receive thread");
        close(sock);
        exit(EXIT_FAILURE);
    }
    
    pthread_join(send_thread, NULL);
    pthread_join(recv_thread, NULL);
    close(sock); 
}

int main(int argc, char *argv[]) {
    if (argc < 2) {
        fprintf(stderr, "Usage:\n"
                  "  %s server <port>\n"
                  "  %s client <ip> <port>\n\n"
                  "Test Cases (run in separate terminals):\n"
                  "1. Run as server: %s server 8080\n"
                  "2. Run as client: %s client 127.0.0.1 8080\n"
                  "3. Run another client: %s client 127.0.0.1 8080\n"
                  "4. Test client disconnect: Close a client terminal with Ctrl+C.\n"
                  "5. Test invalid arguments: %s client 127.0.0.1 99999\n",
                  argv[0], argv[0], argv[0], argv[0], argv[0], argv[0]);
        return 1;
    }

    char *endptr;
    long port;

    if (strcmp(argv[1], "server") == 0 && argc == 3) {
        errno = 0;
        port = strtol(argv[2], &endptr, 10);
        if (*endptr != '\0' || port <= 0 || port > 65535 || (errno == ERANGE && (port == LONG_MAX || port == LONG_MIN))) {
            fprintf(stderr, "Invalid port number: %s\n", argv[2]);
            return 1;
        }
        server_main((int)port);
    } else if (strcmp(argv[1], "client") == 0 && argc == 4) {
        errno = 0;
        port = strtol(argv[3], &endptr, 10);
        if (*endptr != '\0' || port <= 0 || port > 65535 || (errno == ERANGE && (port == LONG_MAX || port == LONG_MIN))) {
            fprintf(stderr, "Invalid port number: %s\n", argv[3]);
            return 1;
        }
        client_main(argv[2], (int)port);
    } else {
        fprintf(stderr, "Invalid arguments. See usage printed below.\n");
        main(1, argv);
        return 1;
    }

    return 0;
}
