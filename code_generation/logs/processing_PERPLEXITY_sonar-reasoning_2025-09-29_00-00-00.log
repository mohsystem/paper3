```java
public class Task178 {
    public static int shortestSubarray(int[] nums, int k) {
        if (nums == null || nums.length == 0) {
            return -1;
        }
        
        int n = nums.length;
        int minLen = Integer.MAX_VALUE;
        int left = 0;
        long sum = 0;
        
        for (int right = 0; right < n; right++) {
            sum += nums[right];
            
            while (left <= right && sum >= k) {
                minLen = Math.min(minLen, right - left + 1);
                sum -= nums[left];
                left++;
            }
        }
        
        return minLen == Integer.MAX_VALUE ? -1 : minLen;
    }
    
    public static void main(String[] args) {
        System.out.println(shortestSubarray(new int[]{1}, 1));
        System.out.println(shortestSubarray(new int[]{1, 2}, 4));
        System.out.println(shortestSubarray(new int[]{2, -1, 2}, 3));
        System.out.println(shortestSubarray(new int[]{1, 2, 3, 4}, 6));
        System.out.println(shortestSubarray(new int[]{-1, -2, -3}, 1));
    }
}
