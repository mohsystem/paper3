```c
#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

typedef struct {
    int* data;
    int front;
    int rear;
    int size;
    int capacity;
} Deque;

Deque* createDeque(int capacity) {
    Deque* dq = (Deque*)malloc(sizeof(Deque));
    if (!dq) return NULL;
    
    dq->data = (int*)malloc(capacity * sizeof(int));
    if (!dq->data) {
        free(dq);
        return NULL;
    }
    
    dq->front = 0;
    dq->rear = -1;
    dq->size = 0;
    dq->capacity = capacity;
    return dq;
}

void destroyDeque(Deque* dq) {
    if (dq) {
        free(dq->data);
        free(dq);
    }
}

int isEmpty(Deque* dq) {
    return dq->size == 0;
}

void pushBack(Deque* dq, int val) {
    if (dq->size >= dq->capacity) return;
    dq->rear = (dq->rear + 1) % dq->capacity;
    dq->data[dq->rear] = val;
    dq->size++;
}

void popBack(Deque* dq) {
    if (isEmpty(dq)) return;
    dq->rear = (dq->rear - 1 + dq->capacity) % dq->capacity;
    dq->size--;
}

void popFront(Deque* dq) {
    if (isEmpty(dq)) return;
    dq->front = (dq->front + 1) % dq->capacity;
    dq->size--;
}

int peekFront(Deque* dq) {
    if (isEmpty(dq)) return -1;
    return dq->data[dq->front];
}

int peekBack(Deque* dq) {
    if (isEmpty(dq)) return -1;
    return dq->data[dq->rear];
}

int constrainedSubsetSum(int* nums, int numsSize, int k) {
    if (!nums || numsSize <= 0 || k < 1 || k > numsSize) {
        return INT_MIN;
    }
    
    int* dp = (int*)malloc(numsSize * sizeof(int));
    if (!dp) return INT_MIN;
    
    Deque* dq = createDeque(numsSize);
    if (!dq) {
        free(dp);
        return INT_MIN;
    }
    
    int result = INT_MIN;
    
    for (int i = 0; i < numsSize; i++) {
        while (!isEmpty(dq) && peekFront(dq) < i - k) {
            popFront(dq);
        }
        
        dp[i] = nums[i];
        if (!isEmpty(dq)) {
            int maxPrev = dp[peekFront(dq)];
            if (nums[i] + maxPrev > dp[i]) {
                dp[i] = nums[i] + maxPrev;
            }
        }
        
        if (dp[i] > result) {
            result = dp[i];
        }
        
        while (!isEmpty(dq) && dp[peekBack(dq)] <= dp[i]) {
            popBack(dq);
        }
        pushBack(dq, i);
    }
    
    destroyDeque(dq);
    free(dp);
    return result;
}

int main() {
    int nums1[] = {10, 2, -10, 5, 20};
    printf("%d\n", constrainedSubsetSum(nums1, 5, 2));
    
    int nums2[] = {-1, -2, -3};
    printf("%d\n", constrainedSubsetSum(nums2, 3, 1));
    
    int nums3[] = {10, -2, -10, -5, 20};
    printf("%d\n", constrainedSubsetSum(nums3, 5, 2));
    
    int nums4[] = {1};
    printf("%d\n", constrainedSubsetSum(nums4, 1, 1));
    
    int nums5[] = {1, 2, 3, 4, 5};
    printf("%d\n", constrainedSubsetSum(nums5, 5, 3));
    
    return 0;
}
