```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_SIZE 50000

typedef struct {
    int data[MAX_SIZE];
    int size;
} MedianFinder;

MedianFinder* medianFinderCreate() {
    MedianFinder* obj = (MedianFinder*)malloc(sizeof(MedianFinder));
    if (!obj) return NULL;
    obj->size = 0;
    memset(obj->data, 0, sizeof(obj->data));
    return obj;
}

void medianFinderAddNum(MedianFinder* obj, int num) {
    if (!obj || obj->size >= MAX_SIZE) return;
    if (num < -100000 || num > 100000) return;
    
    // Insert in sorted order
    int pos = obj->size;
    while (pos > 0 && obj->data[pos - 1] > num) {
        obj->data[pos] = obj->data[pos - 1];
        pos--;
    }
    obj->data[pos] = num;
    obj->size++;
}

double medianFinderFindMedian(MedianFinder* obj) {
    if (!obj || obj->size == 0) return 0.0;
    
    if (obj->size % 2 == 1) {
        return (double)obj->data[obj->size / 2];
    } else {
        int mid1 = obj->data[obj->size / 2 - 1];
        int mid2 = obj->data[obj->size / 2];
        return (mid1 + mid2) / 2.0;
    }
}

void medianFinderFree(MedianFinder* obj) {
    if (obj) {
        free(obj);
    }
}

int main() {
    // Test case 1
    MedianFinder* mf1 = medianFinderCreate();
    medianFinderAddNum(mf1, 1);
    medianFinderAddNum(mf1, 2);
    printf("%.1f\n", medianFinderFindMedian(mf1)); // 1.5
    medianFinderAddNum(mf1, 3);
    printf("%.1f\n", medianFinderFindMedian(mf1)); // 2.0
    medianFinderFree(mf1);
    
    // Test case 2
    MedianFinder* mf2 = medianFinderCreate();
    medianFinderAddNum(mf2, 6);
    printf("%.1f\n", medianFinderFindMedian(mf2)); // 6.0
    medianFinderAddNum(mf2, 10);
    printf("%.1f\n", medianFinderFindMedian(mf2)); // 8.0
    medianFinderFree(mf2);
    
    // Test case 3
    MedianFinder* mf3 = medianFinderCreate();
    medianFinderAddNum(mf3, 2);
    medianFinderAddNum(mf3, 3);
    medianFinderAddNum(mf3, 4);
    printf("%.1f\n", medianFinderFindMedian(mf3)); // 3.0
    medianFinderFree(mf3);
    
    // Test case 4
    MedianFinder* mf4 = medianFinderCreate();
    medianFinderAddNum(mf4, -1);
    medianFinderAddNum(mf4, -2);
    printf("%.1f\n", medianFinderFindMedian(mf4)); // -1.5
    medianFinderFree(mf4);
    
    // Test case 5
    MedianFinder* mf5 = medianFinderCreate();
    medianFinderAddNum(mf5, 1);
    medianFinderAddNum(mf5, 2);
    medianFinderAddNum(mf5, 3);
    medianFinderAddNum(mf5, 4);
    medianFinderAddNum(mf5, 5);
    printf("%.1f\n", medianFinderFindMedian(mf5)); // 3.0
    medianFinderFree(mf5);
    
    return 0;
}
