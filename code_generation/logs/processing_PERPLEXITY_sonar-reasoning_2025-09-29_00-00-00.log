```python
from typing import Dict, List, Set

def reparent_tree(tree: Dict[int, List[int]], new_root: int) -> Dict[int, List[int]]:
    if not tree:
        return {}
    
    if new_root not in tree:
        raise ValueError("New root not found in tree")
    
    result = {node: [] for node in tree}
    visited: Set[int] = set()
    
    def dfs(current: int, parent: int) -> None:
        visited.add(current)
        
        for neighbor in tree[current]:
            if neighbor not in visited:
                result[current].append(neighbor)
                dfs(neighbor, current)
    
    dfs(new_root, -1)
    return result

def main():
    # Test case 1: Simple tree
    tree1 = {
        0: [1, 2, 3],
        1: [0, 4, 5],
        2: [0, 6, 7],
        3: [0, 8, 9],
        4: [1],
        5: [1],
        6: [2],
        7: [2],
        8: [3],
        9: [3]
    }
    
    result1 = reparent_tree(tree1, 6)
    print(f"Test 1 - Reparent from 6: {result1}")
    
    # Test case 2: Linear tree
    tree2 = {
        1: [2],
        2: [1, 3],
        3: [2, 4],
        4: [3]
    }
    
    result2 = reparent_tree(tree2, 3)
    print(f"Test 2 - Reparent from 3: {result2}")
    
    # Test case 3: Single node
    tree3 = {1: []}
    
    result3 = reparent_tree(tree3, 1)
    print(f"Test 3 - Single node: {result3}")
    
    # Test case 4: Two nodes
    tree4 = {
        1: [2],
        2: [1]
    }
    
    result4 = reparent_tree(tree4, 2)
    print(f"Test 4 - Two nodes from 2: {result4}")
    
    # Test case 5: Triangle-like tree
    tree5 = {
        1: [2, 3],
        2: [1, 4],
        3: [1, 5],
        4: [2],
        5: [3]
    }
    
    result5 = reparent_tree(tree5, 4)
    print(f"Test 5 - Reparent from 4: {result5}")

if __name__ == "__main__":
    main()
