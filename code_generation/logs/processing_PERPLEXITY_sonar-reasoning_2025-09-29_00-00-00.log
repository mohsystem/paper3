```java
import javax.crypto.SecretKeyFactory;
import javax.crypto.spec.PBEKeySpec;
import java.security.NoSuchAlgorithmException;
import java.security.SecureRandom;
import java.security.spec.InvalidKeySpecException;
import java.time.LocalDateTime;
import java.time.temporal.ChronoUnit;
import java.util.*;
import java.util.concurrent.ConcurrentHashMap;
import java.nio.charset.StandardCharsets;

public class Task133 {
    private static final int SALT_LENGTH = 16;
    private static final int HASH_LENGTH = 32;
    private static final int ITERATIONS = 210000;
    private static final int TOKEN_LENGTH = 32;
    private static final int TOKEN_EXPIRY_MINUTES = 60;
    
    private static class User {
        String email;
        byte[] passwordHash;
        byte[] salt;
        
        User(String email, byte[] passwordHash, byte[] salt) {
            this.email = email;
            this.passwordHash = passwordHash.clone();
            this.salt = salt.clone();
        }
    }
    
    private static class ResetToken {
        byte[] tokenHash;
        String userEmail;
        LocalDateTime expiry;
        
        ResetToken(byte[] tokenHash, String userEmail, LocalDateTime expiry) {
            this.tokenHash = tokenHash.clone();
            this.userEmail = userEmail;
            this.expiry = expiry;
        }
    }
    
    private final Map<String, User> users = new ConcurrentHashMap<>();
    private final Map<String, ResetToken> resetTokens = new ConcurrentHashMap<>();
    private final SecureRandom secureRandom = new SecureRandom();
    
    private byte[] generateSalt() {
        byte[] salt = new byte[SALT_LENGTH];
        secureRandom.nextBytes(salt);
        return salt;
    }
    
    private byte[] hashPassword(String password, byte[] salt) throws NoSuchAlgorithmException, InvalidKeySpecException {
        if (password == null || password.length() < 8) {
            throw new IllegalArgumentException("Password must be at least 8 characters");
        }
        
        PBEKeySpec spec = new PBEKeySpec(password.toCharArray(), salt, ITERATIONS, HASH_LENGTH * 8);
        try {
            SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            return factory.generateSecret(spec).getEncoded();
        } finally {
            spec.clearPassword();
        }
    }
    
    private boolean constantTimeEquals(byte[] a, byte[] b) {
        if (a.length != b.length) return false;
        int result = 0;
        for (int i = 0; i < a.length; i++) {
            result |= a[i] ^ b[i];
        }
        return result == 0;
    }
    
    public boolean registerUser(String email, String password) {
        if (email == null || !email.contains("@") || email.length() > 254) {
            return false;
        }
        if (password == null || password.length() < 8 || password.length() > 128) {
            return false;
        }
        
        try {
            byte[] salt = generateSalt();
            byte[] hash = hashPassword(password, salt);
            users.put(email, new User(email, hash, salt));
            return true;
        } catch (Exception e) {
            return false;
        }
    }
    
    public String requestPasswordReset(String email) {
        if (email == null || !users.containsKey(email)) {
            return null;
        }
        
        byte[] tokenBytes = new byte[TOKEN_LENGTH];
        secureRandom.nextBytes(tokenBytes);
        String token = Base64.getUrlEncoder().withoutPadding().encodeToString(tokenBytes);
        
        try {
            byte[] tokenSalt = generateSalt();
            byte[] tokenHash = hashPassword(token, tokenSalt);
            
            ResetToken resetToken = new ResetToken(tokenHash, email, 
                LocalDateTime.now().plus(TOKEN_EXPIRY_MINUTES, ChronoUnit.MINUTES));
            resetTokens.put(token, resetToken);
            
            return token;
        } catch (Exception e) {
            return null;
        }
    }
    
    public boolean resetPassword(String token, String newPassword) {
        if (token == null || newPassword == null || newPassword.length() < 8 || newPassword.length() > 128) {
            return false;
        }
        
        ResetToken resetToken = resetTokens.get(token);
        if (resetToken == null) {
            return false;
        }
        
        if (LocalDateTime.now().isAfter(resetToken.expiry)) {
            resetTokens.remove(token);
            return false;
        }
        
        User user = users.get(resetToken.userEmail);
        if (user == null) {
            resetTokens.remove(token);
            return false;
        }
        
        try {
            byte[] newSalt = generateSalt();
            byte[] newHash = hashPassword(newPassword, newSalt);
            
            users.put(user.email, new User(user.email, newHash, newSalt));
            resetTokens.remove(token);
            return true;
        } catch (Exception e) {
            return false;
        }
    }
    
    public boolean verifyPassword(String email, String password) {
        if (email == null || password == null) return false;
        
        User user = users.get(email);
        if (user == null) return false;
        
        try {
            byte[] hash = hashPassword(password, user.salt);
            return constantTimeEquals(user.passwordHash, hash);
        } catch (Exception e) {
            return false;
        }
    }
    
    public static void main(String[] args) {
        Task133 system = new Task133();
        
        // Test case 1: Register user and verify password
        boolean test1 = system.registerUser("user1@example.com", "password123") &&
                       system.verifyPassword("user1@example.com", "password123");
        System.out.println("Test 1: " + test1);
        
        // Test case 2: Request password reset
        String token = system.requestPasswordReset("user1@example.com");
        boolean test2 = token != null;
        System.out.println("Test 2: " + test2);
        
        // Test case 3: Reset password with valid token
        boolean test3 = system.resetPassword(token, "newpassword456") &&
                       system.verifyPassword("user1@example.com", "newpassword456");
        System.out.println("Test 3: " + test3);
        
        // Test case 4: Try to use expired token by creating new user
        system.registerUser("user2@example.com", "password789");
        String token2 = system.requestPasswordReset("user2@example.com");
        boolean test4 = !system.resetPassword("invalid_token", "newpassword") &&
                       system.verifyPassword("user2@example.com", "password789");
