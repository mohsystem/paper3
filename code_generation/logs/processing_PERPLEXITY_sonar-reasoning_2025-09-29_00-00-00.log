```cpp
#include <iostream>
#include <cmath>
#include <string>

bool narcissistic(int value) {
    if (value < 0) return false;
    
    std::string str = std::to_string(value);
    int numDigits = static_cast<int>(str.length());
    long long sum = 0;
    
    for (char c : str) {
        int digit = c - '0';
        sum += static_cast<long long>(std::pow(digit, numDigits));
    }
    
    return sum == value;
}

int main() {
    std::cout << (narcissistic(153) ? "true" : "false") << std::endl;   // true
    std::cout << (narcissistic(1652) ? "true" : "false") << std::endl;  // false
    std::cout << (narcissistic(9) ? "true" : "false") << std::endl;     // true
    std::cout << (narcissistic(371) ? "true" : "false") << std::endl;   // true
    std::cout << (narcissistic(123) ? "true" : "false") << std::endl;   // false
    
    return 0;
}
```

```c
#include <stdio.h>
#include <math.h>
#include <stdbool.h>

int countDigits(int n) {
    if (n == 0) return 1;
    int count = 0;
    while (n > 0) {
        count++;
        n /= 10;
    }
    return count;
}

bool narcissistic(int value) {
    if (value < 0) return false;
    
    int numDigits = countDigits(value);
    long long sum = 0;
    int temp = value;
    
    while (temp > 0) {
        int digit = temp % 10;
        sum += (long long)pow(digit, numDigits);
        temp /= 10;
    }
    
    return sum == value;
}

int main() {
    printf("%s\n", narcissistic(153) ? "true" : "false");   // true
    printf("%s\n", narcissistic(1652) ? "true" : "false");  // false
    printf("%s\n", narcissistic(9) ? "true" : "false");     // true
    printf("%s\n", narcissistic(371) ? "true" : "false");   // true
    printf("%s\n", narcissistic(123) ? "true" : "false");   // false
    
    return 0;
}
```
