import java.math.BigDecimal;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.locks.ReentrantReadWriteLock;
import java.util.concurrent.atomic.AtomicLong;

public class Task181 {
    private static class BankAccount {
        private final String accountNumber;
        private BigDecimal balance;
        private boolean isOpen;
        private final ReentrantReadWriteLock lock;
        
        public BankAccount(String accountNumber, BigDecimal initialBalance) {
            if (accountNumber == null || accountNumber.trim().isEmpty()) {
                throw new IllegalArgumentException("Account number cannot be null or empty");
            }
            if (initialBalance == null || initialBalance.compareTo(BigDecimal.ZERO) < 0) {
                throw new IllegalArgumentException("Initial balance cannot be null or negative");
            }
            this.accountNumber = accountNumber;
            this.balance = initialBalance;
            this.isOpen = true;
            this.lock = new ReentrantReadWriteLock();
        }
        
        public boolean deposit(BigDecimal amount) {
            if (amount == null || amount.compareTo(BigDecimal.ZERO) <= 0) {
                return false;
            }
            
            lock.writeLock().lock();
            try {
                if (!isOpen) {
                    return false;
                }
                balance = balance.add(amount);
                return true;
            } finally {
                lock.writeLock().unlock();
            }
        }
        
        public boolean withdraw(BigDecimal amount) {
            if (amount == null || amount.compareTo(BigDecimal.ZERO) <= 0) {
                return false;
            }
            
            lock.writeLock().lock();
            try {
                if (!isOpen || balance.compareTo(amount) < 0) {
                    return false;
                }
                balance = balance.subtract(amount);
                return true;
            } finally {
                lock.writeLock().unlock();
            }
        }
        
        public BigDecimal getBalance() {
            lock.readLock().lock();
            try {
                return isOpen ? balance : null;
            } finally {
                lock.readLock().unlock();
            }
        }
        
        public boolean close() {
            lock.writeLock().lock();
            try {
                if (!isOpen) {
                    return false;
                }
                isOpen = false;
                return true;
            } finally {
                lock.writeLock().unlock();
            }
        }
        
        public boolean isOpen() {
            lock.readLock().lock();
            try {
                return isOpen;
            } finally {
                lock.readLock().unlock();
            }
        }
    }
    
    private static class BankSystem {
        private final ConcurrentHashMap<String, BankAccount> accounts;
        private final AtomicLong accountCounter;
        
        public BankSystem() {
            this.accounts = new ConcurrentHashMap<>();
            this.accountCounter = new AtomicLong(1000);
        }
        
        public String openAccount(BigDecimal initialBalance) {
            if (initialBalance == null || initialBalance.compareTo(BigDecimal.ZERO) < 0) {
                return null;
            }
            
            String accountNumber = String.valueOf(accountCounter.getAndIncrement());
            BankAccount account = new BankAccount(accountNumber, initialBalance);
            accounts.put(accountNumber, account);
            return accountNumber;
        }
        
        public boolean closeAccount(String accountNumber) {
            if (accountNumber == null || accountNumber.trim().isEmpty()) {
                return false;
            }
            
            BankAccount account = accounts.get(accountNumber);
            if (account == null) {
                return false;
            }
            
            return account.close();
        }
        
        public boolean deposit(String accountNumber, BigDecimal amount) {
            if (accountNumber == null || accountNumber.trim().isEmpty()) {
                return false;
            }
            
            BankAccount account = accounts.get(accountNumber);
            if (account == null) {
                return false;
            }
            
            return account.deposit(amount);
        }
        
        public boolean withdraw(String accountNumber, BigDecimal amount) {
            if (accountNumber == null || accountNumber.trim().isEmpty()) {
                return false;
            }
            
            BankAccount account = accounts.get(accountNumber);
            if (account == null) {
                return false;
            }
            
            return account.withdraw(amount);
        }
        
        public BigDecimal getBalance(String accountNumber) {
            if (accountNumber == null || accountNumber.trim().isEmpty()) {
                return null;
            }
            
            BankAccount account = accounts.get(accountNumber);
            if (account == null) {
                return null;
            }
            
            return account.getBalance();
        }
    }
    
    public static void main(String[] args) {
        BankSystem bank = new BankSystem();
        
        // Test case 1: Open account and deposit
        String account1 = bank.openAccount(new BigDecimal("1000.00"));
        System.out.println("Test 1 - Account opened: " + (account1 != null));
        boolean depositResult = bank.deposit(account1, new BigDecimal("500.00"));
        System.out.println("Test 1 - Deposit successful: " + depositResult);
        System.out.println("Test 1 - Balance: " + bank.getBalance(account1));
        
        // Test case 2: Withdraw money
        boolean withdrawResult = bank.withdraw(account1, new BigDecimal("200.00"));
        System.out.println("Test 2 - Withdraw successful: " + withdrawResult);
        System.out.println("Test 2 - Balance: " + bank.getBalance(account1));
        
        // Test case 3: Insufficient funds
        boolean insufficientWithdraw = bank.withdraw(account1, new BigDecimal("2000.00"));
        System.out.println("Test 3 - Insufficient funds withdraw: " + insufficientWithdraw);
        
        // Test case 4: Close account and try operations
        boolean closeResult = bank.closeAccount(account1);
        System.out.println("Test 4 - Account closed: " + closeResult);
        boolean depositClosed = bank.deposit(account1, new BigDecimal("100.00"));
        System.out.println("Test 4 - Deposit to closed account: " + depositClosed);
        
        // Test case 5: Invalid operations
        boolean invalidAccount = bank.deposit("invalid", new BigDecimal("100.00"));
        System.out.println("Test 5 - Invalid account operation: " + invalidAccount);
        BigDecimal nullBalance = bank.getBalance("nonexistent");
        System.out.println("Test 5 - Nonexistent account balance: " + nullBalance);
    }
