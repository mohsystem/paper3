```python
import threading
from typing import Callable

class FooBar:
    def __init__(self, n: int):
        if not isinstance(n, int) or n < 1 or n > 1000:
            raise ValueError("n must be an integer between 1 and 1000")
        self.n = n
        self.foo_turn = True
        self.condition = threading.Condition()
    
    def foo(self, printFoo: Callable[[], None]) -> None:
        for i in range(self.n):
            with self.condition:
                while not self.foo_turn:
                    self.condition.wait()
                printFoo()
                self.foo_turn = False
                self.condition.notify_all()
    
    def bar(self, printBar: Callable[[], None]) -> None:
        for i in range(self.n):
            with self.condition:
                while self.foo_turn:
                    self.condition.wait()
                printBar()
                self.foo_turn = True
                self.condition.notify_all()

def main():
    test_cases = [1, 2, 3, 4, 5]
    
    for n in test_cases:
        print(f"Test case n={n}:")
        foobar = FooBar(n)
        
        def print_foo():
            print("foo", end="")
        
        def print_bar():
            print("bar", end="")
        
        t1 = threading.Thread(target=foobar.foo, args=(print_foo,))
        t2 = threading.Thread(target=foobar.bar, args=(print_bar,))
        
        t1.start()
        t2.start()
        
        t1.join()
        t2.join()
        
        print()

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <thread>
#include <mutex>
#include <condition_variable>
#include <functional>
#include <stdexcept>

class FooBar {
private:
    int n;
    bool fooTurn;
    std::mutex mtx;
    std::condition_variable cv;

public:
    FooBar(int n) : n(n), fooTurn(true) {
        if (n < 1 || n > 1000) {
            throw std::invalid_argument("n must be between 1 and 1000");
        }
    }

    void foo(std::function<void()> printFoo) {
        for (int i = 0; i < n; i++) {
            std::unique_lock<std::mutex> lock(mtx);
            cv.wait(lock, [this]() { return fooTurn; });
            printFoo();
            fooTurn = false;
            cv.notify_all();
        }
    }

    void bar(std::function<void()> printBar) {
        for (int i = 0; i < n; i++) {
            std::unique_lock<std::mutex> lock(mtx);
            cv.wait(lock, [this]() { return !fooTurn; });
            printBar();
            fooTurn = true;
            cv.notify_all();
        }
    }
};

int main() {
    int testCases[] = {1, 2, 3, 4, 5};
    
    for (int n : testCases) {
        std::cout << "Test case n=" << n << ":" << std::endl;
        FooBar fooBar(n);
        
        std::thread t1([&fooBar]() {
            fooBar.foo([]() { std::cout << "foo"; });
        });
        
        std::thread t2([&fooBar]() {
            fooBar.bar([]() { std::cout << "bar"; });
        });
        
        t1.join();
        t2.join();
        
        std::cout << std::endl;
    }
    
    return 0;
}
```

```c
#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>

typedef struct {
    int n;
    int fooTurn;
    pthread_mutex_t mutex;
    pthread_cond_t cond;
} FooBar;

typedef struct {
    FooBar* foobar;
    void (*printFunc)(void);
} ThreadData;

FooBar* foobar_init(int n) {
    if (n < 1 || n > 1000) {
        return NULL;
    }
    
    FooBar* fb = malloc(sizeof(FooBar));
    if (!fb) return NULL;
    
    fb->n = n;
    fb->fooTurn = 1;
    if (pthread_mutex_init(&fb->mutex, NULL) != 0) {
        free(fb);
        return NULL;
    }
    if (pthread_cond_init(&fb->cond, NULL) != 0) {
        pthread_mutex_destroy(&fb->mutex);
        free(fb);
        return NULL;
    }
    return fb;
}

void foobar_destroy(FooBar* fb) {
    if (fb) {
        pthread_mutex_destroy(&fb->mutex);
        pthread_cond_destroy(&fb->cond);
        free(fb);
    }
}

void* foo_thread(void* arg) {
    ThreadData* data = (ThreadData*)arg;
    FooBar* fb = data->foobar;
    
    for (int i = 0; i < fb->n; i++) {
        pthread_mutex_lock(&fb->mutex);
        while (!fb->fooTurn) {
            pthread_cond_wait(&fb->cond, &fb->mutex);
        }
        data->printFunc();
        fb->fooTurn = 0;
        pthread_cond_broadcast(&fb->cond);
        pthread_mutex_unlock(&fb->mutex);
    }
    return NULL;
}

void* bar_thread(void* arg) {
    ThreadData* data = (ThreadData*)arg;
    FooBar* fb = data->foobar;
    
    for (int i = 0; i < fb->n; i++) {
        pthread_mutex_lock(&fb->mutex);
        while (fb->fooTurn) {
            pthread_cond_wait(&fb->cond, &fb->mutex);
        }
        data->printFunc();
        fb->fooTurn = 1;
        pthread_cond_broadcast(&fb->cond);
        pthread_mutex_unlock(&fb->mutex);
    }
    return NULL;
}

void print_foo(void) {
    printf("foo");
}

void print_bar(void) {
    printf("bar");
}

int main() {
    int testCases[] = {1, 2, 3, 4, 5};
    int numTests = sizeof(testCases) / sizeof(testCases);
    
    for (int t = 0; t < numTests; t++) {
        int n = testCases[t];
        printf("Test case n=%d:\n", n);
        
        FooBar* foobar = foobar_init(n);
        if (!foobar) {
            printf("Initialization failed\n");
            continue;
        }
        
        ThreadData fooData = {foobar, print_foo};
        ThreadData barData = {foobar, print_bar};
        
        pthread_t t1, t2;
        
        if (pthread_create(&t1, NULL, foo_thread, &fooData) != 0 ||
            pthread_create(&t2, NULL, bar_thread, &barData) != 0) {
            printf("Thread creation failed\n");
            foobar_destroy(foobar);
            continue;
        }
        
        pthread_join(t1, NULL);
        pthread_join(t2, NULL);
        
        printf("\n");
        
        foobar_destroy(foobar);
    }
    
    return 0;
}
```
