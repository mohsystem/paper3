```c
#include <stdio.h>
#include <stdlib.h>

int peopleOnBus(int busStops[][2], int numStops) {
    if (busStops == NULL || numStops <= 0) {
        fprintf(stderr, "Invalid input: bus stops array is null or empty\n");
        exit(1);
    }
    
    int peopleCount = 0;
    
    for (int i = 0; i < numStops; i++) {
        int on = busStops[i][0];
        int off = busStops[i][1];
        
        if (on < 0 || off < 0) {
            fprintf(stderr, "Invalid input: people counts cannot be negative\n");
            exit(1);
        }
        
        peopleCount += on - off;
        
        if (peopleCount < 0) {
            fprintf(stderr, "Invalid state: bus cannot have negative people count\n");
            exit(1);
        }
    }
    
    return peopleCount;
}

int main() {
    // Test case 1
    int test1[][2] = {{10, 0}, {3, 5}, {5, 8}};
    printf("Test 1: %d\n", peopleOnBus(test1, 3)); // Expected: 5
    
    // Test case 2
    int test2[][2] = {{3, 0}, {9, 1}, {4, 10}, {12, 2}, {6, 1}, {7, 10}};
    printf("Test 2: %d\n", peopleOnBus(test2, 6)); // Expected: 17
    
    // Test case 3
    int test3[][2] = {{3, 0}, {9, 1}, {4, 8}, {12, 2}, {6, 1}, {7, 8}};
    printf("Test 3: %d\n", peopleOnBus(test3, 6)); // Expected: 21
    
    // Test case 4
    int test4[][2] = {{0, 0}};
    printf("Test 4: %d\n", peopleOnBus(test4, 1)); // Expected: 0
    
    // Test case 5
    int test5[][2] = {{5, 0}, {2, 3}, {4, 1}};
    printf("Test 5: %d\n", peopleOnBus(test5, 3)); // Expected: 7
    
    return 0;
}
