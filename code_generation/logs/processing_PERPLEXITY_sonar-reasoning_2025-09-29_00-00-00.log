import javax.crypto.*;
import javax.crypto.spec.*;
import java.io.*;
import java.net.*;
import java.security.*;
import java.security.spec.*;
import java.nio.charset.StandardCharsets;
import java.util.*;

public class Task7 {
    private static final String MAGIC = "ENC1";
    private static final int VERSION = 1;
    private static final int SALT_LENGTH = 16;
    private static final int IV_LENGTH = 12;
    private static final int TAG_LENGTH = 16;
    private static final int ITERATIONS = 210000;
    
    public static class ChatServer {
        private static final String USERS_FILE = "users.enc";
        private static final int PORT = 8080;
        private Map<String, byte[]> users = new HashMap<>();
        
        public void startServer() {
            loadUsers();
            try (ServerSocket serverSocket = new ServerSocket(PORT)) {
                while (true) {
                    try (Socket clientSocket = serverSocket.accept()) {
                        handleClient(clientSocket);
                    } catch (Exception e) {
                        System.err.println("Client error: " + e.getMessage());
                    }
                }
            } catch (IOException e) {
                System.err.println("Server error: " + e.getMessage());
            }
        }
        
        private void handleClient(Socket clientSocket) throws IOException {
            try (BufferedReader in = new BufferedReader(new InputStreamReader(clientSocket.getInputStream(), StandardCharsets.UTF_8));
                 PrintWriter out = new PrintWriter(new OutputStreamWriter(clientSocket.getOutputStream(), StandardCharsets.UTF_8), true)) {
                
                String request = in.readLine();
                if (request != null && request.length() <= 1000) {
                    String[] parts = request.split(":", 3);
                    if (parts.length == 3 && "LOGIN".equals(parts[0])) {
                        String username = parts[1];
                        String password = parts[2];
                        if (validateInput(username) && validateInput(password)) {
                            boolean authenticated = authenticate(username, password);
                            out.println(authenticated ? "SUCCESS" : "FAILURE");
                        } else {
                            out.println("INVALID_INPUT");
                        }
                    } else {
                        out.println("INVALID_REQUEST");
                    }
                }
            }
        }
        
        private boolean validateInput(String input) {
            return input != null && input.length() >= 1 && input.length() <= 50 && input.matches("[a-zA-Z0-9_]+");
        }
        
        private boolean authenticate(String username, String password) {
            byte[] storedHash = users.get(username);
            if (storedHash == null) return false;
            
            try {
                byte[] salt = Arrays.copyOfRange(storedHash, 0, SALT_LENGTH);
                byte[] expectedHash = Arrays.copyOfRange(storedHash, SALT_LENGTH, storedHash.length);
                byte[] actualHash = hashPassword(password, salt);
                return MessageDigest.isEqual(expectedHash, actualHash);
            } catch (Exception e) {
                return false;
            }
        }
        
        private byte[] hashPassword(String password, byte[] salt) throws Exception {
            KeySpec spec = new PBEKeySpec(password.toCharArray(), salt, ITERATIONS, 256);
            SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            return factory.generateSecret(spec).getEncoded();
        }
        
        public void addUser(String username, String password) {
            try {
                SecureRandom random = new SecureRandom();
                byte[] salt = new byte[SALT_LENGTH];
                random.nextBytes(salt);
                byte[] hash = hashPassword(password, salt);
                byte[] combined = new byte[salt.length + hash.length];
                System.arraycopy(salt, 0, combined, 0, salt.length);
                System.arraycopy(hash, 0, combined, salt.length, hash.length);
                users.put(username, combined);
                saveUsers();
            } catch (Exception e) {
                System.err.println("Error adding user: " + e.getMessage());
            }
        }
        
        private void loadUsers() {
            File file = new File(USERS_FILE);
            if (!file.exists()) return;
            
            try {
                byte[] data = decryptFile(USERS_FILE, "defaultpass");
                String content = new String(data, StandardCharsets.UTF_8);
                for (String line : content.split("\n")) {
                    if (line.length() > 0) {
                        String[] parts = line.split(":", 2);
                        if (parts.length == 2) {
                            users.put(parts[0], Base64.getDecoder().decode(parts[1]));
                        }
                    }
                }
            } catch (Exception e) {
                System.err.println("Error loading users: " + e.getMessage());
            }
        }
        
        private void saveUsers() {
            try {
                StringBuilder sb = new StringBuilder();
                for (Map.Entry<String, byte[]> entry : users.entrySet()) {
                    sb.append(entry.getKey()).append(":").append(Base64.getEncoder().encodeToString(entry.getValue())).append("\n");
                }
                encryptFile(USERS_FILE, sb.toString().getBytes(StandardCharsets.UTF_8), "defaultpass");
            } catch (Exception e) {
                System.err.println("Error saving users: " + e.getMessage());
            }
        }
        
        private void encryptFile(String filename, byte[] data, String passphrase) throws Exception {
            SecureRandom random = new SecureRandom();
            byte[] salt = new byte[SALT_LENGTH];
            byte[] iv = new byte[IV_LENGTH];
            random.nextBytes(salt);
            random.nextBytes(iv);
            
            KeySpec spec = new PBEKeySpec(passphrase.toCharArray(), salt, ITERATIONS, 256);
            SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            SecretKey key = new SecretKeySpec(factory.generateSecret(spec).getEncoded(), "AES");
            
            Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding");
            GCMParameterSpec gcmSpec = new GCMParameterSpec(128, iv);
            cipher.init(Cipher.ENCRYPT_MODE, key, gcmSpec);
            
            byte[] ciphertext = cipher.doFinal(data);
            
            try (FileOutputStream fos = new FileOutputStream(filename + ".tmp")) {
                fos.write(MAGIC.getBytes(StandardCharsets.UTF_8));
                fos.write(VERSION);
                fos.write(salt);
                fos.write(iv);
                fos.write(ciphertext);
                fos.flush();
                fos.getFD().sync();
            }
            
            new File(filename + ".tmp").renameTo(new File(filename));
        }
        
        private byte[] decryptFile(String filename, String passphrase) throws Exception {
            try (FileInputStream fis = new FileInputStream(filename)) {
                byte[] magic = new byte[4];
                if (fis.read(magic) != 4 || !Arrays.equals(magic, MAGIC.getBytes(StandardCharsets.UTF_8))) {
                    throw new IllegalArgumentException("Invalid file format");
                }
                
                int version = fis.read();
                if (version != VERSION) {
                    throw new IllegalArgumentException("Unsupported version");
                }
                
                byte[] salt = new byte[SALT_LENGTH];
                byte[] iv = new byte[IV_LENGTH];
                if (fis.read(salt) != SALT_LENGTH || fis.read(iv) != IV_LENGTH) {
                    throw new IllegalArgumentException("Incomplete file");
                }
                
                byte[] ciphertext = fis.readAllBytes();
                
                KeySpec spec = new PBEKeySpec(passphrase.toCharArray(), salt, ITERATIONS, 256);
                SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
                SecretKey key = new SecretKeySpec(factory.generateSecret(spec).getEncoded(), "AES");
                
                Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding");
                GCMParameterSpec gcmSpec = new GCMParameterSpec(128, iv);
                cipher.init(Cipher.DECRYPT_MODE, key, gcmSpec);
                
                return cipher.doFinal(ciphertext);
            }
        }
    }
    
    public static class ChatClient {
        public String login(String username, String password, String serverHost, int port) {
            if (!validateInput(username) || !validateInput(password)) {
                return "INVALID_INPUT";
            }
            
            try (Socket socket = new Socket(serverHost, port);
                 PrintWriter out = new PrintWriter(new OutputStreamWriter(socket.getOutputStream(), StandardCharsets.UTF_8), true);
                 BufferedReader in = new BufferedReader(new InputStreamReader(socket.getInputStream(), StandardCharsets.UTF_8))) {
                
                out.println("LOGIN:" + username + ":" + password);
                return in.readLine();
            } catch (IOException e) {
                return "CONNECTION_ERROR";
            }
        }
        
        private boolean validateInput(String input) {
            return input != null && input.length() >= 1 && input.length() <= 50 && input.matches("[a-zA-Z0-9_]+");
        }
    }
    
    public static void main(String[] args) {
        ChatServer server = new ChatServer();
        ChatClient client = new ChatClient();
        
        // Test case 1: Add valid user
        server.addUser("user1", "password123");
        System.out.println("Test 1: User added");
        
        // Test case 2: Valid login
        new Thread(() -> {
            try {
                Thread.sleep(100);
                String result = client.login("user1", "password123", "localhost", 8080);
                System.out.println("Test 2 result: " + result);
            } catch (Exception e) {
                System.err.println("Test 2 error: " + e.getMessage());
            }
        }).start();
        
        // Test case 3: Invalid login
        new Thread(() -> {
            try {
                Thread.sleep(200);
                String result = client.login("user1", "wrongpass", "localhost", 8080);
                System.out.println("Test 3 result: " + result);
            } catch (Exception e) {
                System.err.println("Test 3 error: " + e.getMessage());
            }
        }).start();
        
        // Test case 4: Invalid username
        new Thread(() -> {
            try {
                Thread.sleep(300);
                String result = client.login("invalid@user", "password", "localhost", 8080);
                System.out.println("Test 4 result: " + result);
            } catch (Exception e) {
                System.err.println("Test 4 error: " + e.getMessage());
            }
        }).start();
        
        // Test case 5: Non-existent user
        new Thread(() -> {
            try {
                Thread.sleep(400);
                String result = client.login("nonexistent", "password", "localhost", 8080);
                System.out.println("Test 5 result: " + result);
                System.exit(0);
            } catch (Exception e) {
                System.err.println("Test 5 error: " + e.getMessage());
            }
        }).start();
        
        server.startServer();
    }
}
