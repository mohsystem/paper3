int peopleOnBus(const std::vector<std::vector<int>>& busStops) {
    if (busStops.empty()) {
        throw std::invalid_argument("Bus stops vector cannot be empty");
    }
    
    int peopleCount = 0;
    
    for (size_t i = 0; i < busStops.size(); ++i) {
        if (busStops[i].size() != 2) {
            throw std::invalid_argument("Each bus stop must have exactly 2 values");
        }
        
        int on = busStops[i][0];
        int off = busStops[i][1];
        
        if (on < 0 || off < 0) {
            throw std::invalid_argument("People counts cannot be negative");
        }
        
        peopleCount += on - off;
        
        if (peopleCount < 0) {
            throw std::invalid_argument("Bus cannot have negative people count");
        }
    }
    
    return peopleCount;
}

int main() {
    // Test case 1
    std::vector<std::vector<int>> test1 = {{10, 0}, {3, 5}, {5, 8}};
