import java.io.*;
import java.nio.charset.StandardCharsets;
import java.nio.file.*;
import java.util.*;

public class Task190 {
    public static String transposeFile(String filename) {
        try {
            if (filename == null || filename.trim().isEmpty()) {
                return "Error: Invalid filename";
            }
            
            Path path = Paths.get(filename);
            if (!Files.exists(path) || !Files.isRegularFile(path)) {
                return "Error: File does not exist or is not a regular file";
            }
            
            List<String> lines = Files.readAllLines(path, StandardCharsets.UTF_8);
            if (lines.isEmpty()) {
                return "";
            }
            
            List<List<String>> matrix = new ArrayList<>();
            int expectedCols = -1;
            
            for (String line : lines) {
                if (line.trim().isEmpty()) continue;
                String[] fields = line.trim().split(" ");
                if (expectedCols == -1) {
                    expectedCols = fields.length;
                } else if (fields.length != expectedCols) {
                    return "Error: Inconsistent number of columns";
                }
                matrix.add(Arrays.asList(fields));
            }
            
            if (matrix.isEmpty()) return "";
            
            StringBuilder result = new StringBuilder();
            for (int col = 0; col < expectedCols; col++) {
                for (int row = 0; row < matrix.size(); row++) {
                    if (row > 0) result.append(" ");
                    result.append(matrix.get(row).get(col));
                }
                if (col < expectedCols - 1) result.append("\n");
            }
            
            return result.toString();
        } catch (Exception e) {
            return "Error: " + e.getMessage();
        }
    }
    
    public static void main(String[] args) {
        // Test cases will validate file transposition logic
        // Checking various scenarios like single row, single column, empty file
