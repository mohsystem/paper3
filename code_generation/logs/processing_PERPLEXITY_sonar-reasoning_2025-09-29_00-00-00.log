        int peak = findPeak(mountainArr, n);
        
        // Efficiently search ascending and descending parts
        int leftResult = binarySearchAsc(mountainArr, target, 0, peak);
        return leftResult != -1 ? leftResult : binarySearchDesc(mountainArr, target, peak + 1, n - 1);
