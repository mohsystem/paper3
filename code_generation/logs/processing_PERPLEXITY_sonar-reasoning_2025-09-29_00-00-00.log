#include <iostream>
#include <string>
#include <vector>
#include <algorithm>
#include <stdexcept>

std::vector<int> computeLPS(const std::string& pattern) {
    std::vector<int> lps(pattern.length(), 0);
    int length = 0;
    size_t i = 1;
    
    while (i < pattern.length()) {
        if (pattern[i] == pattern[length]) {
            length++;
            lps[i] = length;
            i++;
        } else {
            if (length != 0) {
                length = lps[length - 1];
            } else {
                lps[i] = 0;
                i++;
            }
        }
    }
    return lps;
}

std::string shortestPalindrome(const std::string& s) {
    if (s.empty()) {
        return "";
    }
    
    // Input validation
    if (s.length() > 50000) {
        throw std::invalid_argument("String length exceeds maximum allowed");
    }
    
    for (char c : s) {
        if (c < 'a' || c > 'z') {
            throw std::invalid_argument("String must contain only lowercase English letters");
        }
    }
    
    std::string revS = s;
    std::reverse(revS.begin(), revS.end());
    std::string combined = s + "#" + revS;
    
    std::vector<int> lps = computeLPS(combined);
    int overlap = lps.back();
    
    return revS.substr(0, s.length() - overlap) + s;
}

int main() {
    std::cout << shortestPalindrome("aacecaaa") << std::endl;
    std::cout << shortestPalindrome("abcd") << std::endl;
    std::cout << shortestPalindrome("") << std::endl;
    std::cout << shortestPalindrome("a") << std::endl;
    std::cout << shortestPalindrome("race") << std::endl;
    return 0;
}
