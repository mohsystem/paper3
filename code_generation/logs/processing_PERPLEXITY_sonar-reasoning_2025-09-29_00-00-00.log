#include <iostream>
#include <vector>

bool xorGame(std::vector<int>& nums) {
    if (nums.empty()) {
        return true;
    }
    
    int xorResult = 0;
    for (int num : nums) {
        xorResult ^= num;
    }
    
    return xorResult == 0 || nums.size() % 2 == 0;
}

int main() {
    // Test case 1
    std::vector<int> nums1 = {1, 1, 2};
    std::cout << std::boolalpha << xorGame(nums1) << std::endl; // false
    
    // Test case 2
    std::vector<int> nums2 = {0, 1};
    std::cout << std::boolalpha << xorGame(nums2) << std::endl; // true
    
    // Test case 3
    std::vector<int> nums3 = {1, 2, 3};
    std::cout << std::boolalpha << xorGame(nums3) << std::endl; // true
    
    // Test case 4
    std::vector<int> nums4 = {1};
    std::cout << std::boolalpha << xorGame(nums4) << std::endl; // false
    
    // Test case 5
    std::vector<int> nums5 = {2, 3, 1, 0};
    std::cout << std::boolalpha << xorGame(nums5) << std::endl; // true
    
    return 0;
}
