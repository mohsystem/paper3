```cpp
#include <iostream>
#include <string>
#include <regex>
#include <stdexcept>
#include <limits>
#include <sstream>
#include <vector>

class XMLRPCServer {
private:
    static bool wouldOverflowAdd(int a, int b) {
        if (a > 0 && b > std::numeric_limits<int>::max() - a) return true;
        if (a < 0 && b < std::numeric_limits<int>::min() - a) return true;
        return false;
    }
    
    static bool wouldOverflowMultiply(int a, int b) {
        if (a == 0 || b == 0) return false;
        if (a > std::numeric_limits<int>::max() / b) return true;
        if (a < std::numeric_limits<int>::min() / b) return true;
        return false;
    }
    
    static std::string createSuccessResponse(int value) {
        std::ostringstream oss;
        oss << "<?xml version=\"1.0\"?>\n"
            << "<methodResponse>\n"
            << "<params>\n"
            << "<param><value><int>" << value << "</int></value></param>\n"
            << "</params>\n"
            << "</methodResponse>";
        return oss.str();
    }
    
    static std::string createErrorResponse(const std::string& message) {
        std::ostringstream oss;
        oss << "<?xml version=\"1.0\"?>\n"
            << "<methodResponse>\n"
            << "<fault>\n"
            << "<value><struct>\n"
            << "<member><name>faultCode</name><value><int>1</int></value></member>\n"
            << "<member><name>faultString</name><value><string>" << message << "</string></value></member>\n"
            << "</struct></value>\n"
            << "</fault>\n"
            << "</methodResponse>";
        return oss.str();
    }

public:
    static int add(int a, int b) {
        if (wouldOverflowAdd(a, b)) {
            throw std::overflow_error("Integer overflow in addition");
        }
        return a + b;
    }
    
  
