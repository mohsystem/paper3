```java
public class Task171 {
    public static int reversePairs(int[] nums) {
        if (nums == null || nums.length < 1 || nums.length > 50000) {
            return 0;
        }
        
        int count = 0;
        for (int i = 0; i < nums.length; i++) {
            for (int j = i + 1; j < nums.length; j++) {
                if ((long)nums[i] > 2L * (long)nums[j]) {
                    count++;
                }
            }
        }
        return count;
    }
    
    public static void main(String[] args) {
        System.out.println(reversePairs(new int[]{1,3,2,3,1})); // 2
        System.out.println(reversePairs(new int[]{2,4,3,5,1})); // 3
        System.out.println(reversePairs(new int[]{1})); // 0
        System.out.println(reversePairs(new int[]{1,2})); // 0
        System.out.println(reversePairs(new int[]{5,4,3,2,1})); // 4
    }
}
```

```python
from typing import List

def reverse_pairs(nums: List[int]) -> int:
    if not nums or len(nums) < 1 or len(nums) > 50000:
        return 0
    
    count = 0
    for i in range(len(nums)):
        for j in range(i + 1, len(nums)):
            if nums[i] > 2 * nums[j]:
                count += 1
    
    return count

def main():
    print(reverse_pairs([1,3,2,3,1]))  # 2
    print(reverse_pairs([2,4,3,5,1]))  # 3
    print(reverse_pairs([1]))  # 0
    print(reverse_pairs([1,2]))  # 0
    print(reverse_pairs([5,4,3,2,1]))  # 4

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <vector>
#include <climits>

int reversePairs(std::vector<int>& nums) {
    if (nums.empty() || nums.size() > 50000) {
        return 0;
    }
    
    int count = 0;
    for (size_t i = 0; i < nums.size(); ++i) {
        for (size_t j = i + 1; j < nums.size(); ++j) {
            if (static_cast<long long>(nums[i]) > 2LL * static_cast<long long>(nums[j])) {
                count++;
            }
        }
    }
    return count;
}

int main() {
    std::vector<int> test1 = {1,3,2,3,1};
    std::cout << reversePairs(test1) << std::endl; // 2
    
    std::vector<int> test2 = {2,4,3,5,1};
    std::cout << reversePairs(test2) << std::endl; // 3
    
    std::vector<int> test3 = {1};
    std::cout << reversePairs(test3) << std::endl; // 0
    
    std::vector<int> test4 = {1,2};
    std::cout << reversePairs(test4) << std::endl; // 0
    
    std::vector<int> test5 = {5,4,3,2,1};
    std::cout << reversePairs(test5) << std::endl; // 4
    
    return 0;
}
```

```c
#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

int reversePairs(int* nums, int numsSize) {
    if (nums == NULL || numsSize < 1 || numsSize > 50000) {
        return 0;
    }
    
    int count = 0;
    for (int i = 0; i < numsSize; i++) {
        for (int j = i + 1; j < numsSize; j++) {
            if ((long long)nums[i] > 2LL * (long long)nums[j]) {
                count++;
            }
        }
    }
    return count;
}

int main() {
    int test1[] = {1,3,2,3,1};
    printf("%d\n", reversePairs(test1, 5)); // 2
    
    int test2[] = {2,4,3,5,1};
    printf("%d\n", reversePairs(test2, 5)); // 3
    
    int test3[] = {1};
    printf("%d\n", reversePairs(test3, 1)); // 0
    
    int test4[] = {1,2};
    printf("%d\n", reversePairs(test4, 2)); // 0
    
    int test5[] = {5,4,3,2,1};
    printf("%d\n", reversePairs(test5, 5)); // 4
    
    return 0;
}
