    arr4: List[int] = [0, 5, 3, 1]
    ma4: MountainArray = MountainArray(arr4)
    print(find_in_mountain_array(1, ma4))
    
    arr5: List[int] = [1, 5, 2]
    ma5: MountainArray = MountainArray(arr5)
    print(find_in_mountain_array(2, ma5))
