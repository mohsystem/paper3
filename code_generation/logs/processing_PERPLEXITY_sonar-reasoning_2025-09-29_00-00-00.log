import re
from typing import Optional

def clean_phone_number(phone_number: str) -> str:
    if not phone_number:
        raise ValueError("Phone number cannot be empty")
    
    if len(phone_number) > 20:
        raise ValueError("Phone number too long")
    
    # Remove all non-digit characters except + at start
    cleaned = re.sub(r'[^+\d]', '', phone_number)
    
    # Remove country code if present
    if cleaned.startswith('+1'):
        cleaned = cleaned[2:]
    elif cleaned.startswith('1') and len(cleaned) == 11:
        cleaned = cleaned[1:]
    
    # Validate NANP format
    if len(cleaned) != 10:
        raise ValueError("Invalid phone number length")
    
    # Check NANP format: first digit of area code (2-9), first digit of exchange (2-9)
    if not ('2' <= cleaned <= '9'):
        raise ValueError("Invalid area code")
    if not ('2' <= cleaned[3] <= '9'):
        raise ValueError("Invalid exchange code")
    
    # Ensure all characters are digits
    if not cleaned.isdigit():
        raise ValueError("Invalid character in phone number")
    
    return cleaned

def main():
    test_cases = [
        "+1 (613)-995-0253",
        "613-995-0253", 
        "1 613 995 0253",
        "613.995.0253",
        "(613) 995-0253"
    ]
    
    for test in test_cases:
        try:
            result = clean_phone_number(test)
            print(f"Input: {test} -> Output: {result}")
        except Exception as e:
            print(f"Input: {test} -> Error: {e}")

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <string>
#include <stdexcept>
#include <algorithm>

std::string cleanPhoneNumber(const std::string& phoneNumber) {
    if (phoneNumber.empty()) {
        throw std::invalid_argument("Phone number cannot be empty");
    }
    
    if (phoneNumber.length() > 20) {
        throw std::invalid_argument("Phone number too long");
    }
    
    std::string cleaned;
    bool firstChar = true;
    
    // Remove all non-digit characters except + at start
    for (char c : phoneNumber) {
        if (std::isdigit(c)) {
            cleaned += c;
            firstChar = false;
        } else if (c == '+' && firstChar) {
            cleaned += c;
            firstChar = false;
        }
    }
    
    // Remove country code if present
    if (cleaned.length() >= 2 && cleaned.substr(0, 2) == "+1") {
        cleaned = cleaned.substr(2);
    } else if (cleaned.length() == 11 && cleaned == '1') {
        cleaned = cleaned.substr(1);
    }
    
    // Validate NANP format
    if (cleaned.length() != 10) {
        throw std::invalid_argument("Invalid phone number length");
    }
    
    // Check NANP format: first digit of area code (2-9), first digit of exchange (2-9)
    if (cleaned < '2' || cleaned > '9') {
        throw std::invalid_argument("Invalid area code");
    }
    if (cleaned[3] < '2' || cleaned[3] > '9') {
        throw std::invalid_argument("Invalid exchange code");
    }
    
    // Ensure all characters are digits
    for (char c : cleaned) {
        if (c < '0' || c > '9') {
            throw std::invalid_argument("Invalid character in phone number");
        }
    }
    
    return cleaned;
}

int main() {
    std::string testCases[] = {
        "+1 (613)-995-0253",
        "613-995-0253", 
        "1 613 995 0253",
        "613.995.0253",
        "(613) 995-0253"
    };
    
    for (const auto& test : testCases) {
        try {
            std::string result = cleanPhoneNumber(test);
            std::cout << "Input: " << test << " -> Output: " << result << std::endl;
        } catch (const std::exception& e) {
            std::cout << "Input: " << test << " -> Error: " << e.what() << std::endl;
        }
    }
    
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <ctype.h>

int cleanPhoneNumber(const char* phoneNumber, char* result, size_t resultSize) {
    if (!phoneNumber || !result || resultSize < 11) {
        return -1; // Invalid parameters
    }
    
    size_t len = strlen(phoneNumber);
    if (len == 0 || len > 20) {
        return -1; // Invalid length
    }
    
    char cleaned = {0};
    size_t cleanedPos = 0;
    int firstChar = 1;
    
    // Remove all non-digit characters except + at start
    for (size_t i = 0; i < len && cleanedPos < sizeof(cleaned) - 1; i++) {
        if (isdigit(phoneNumber[i])) {
            cleaned[cleanedPos++] = phoneNumber[i];
            firstChar = 0;
        } else if (phoneNumber[i] == '+' && firstChar && cleanedPos < sizeof(cleaned) - 1) {
            cleaned[cleanedPos++] = phoneNumber[i];
            firstChar = 0;
        }
    }
    
    // Remove country code if present
    if (cleanedPos >= 2 && cleaned == '+' && cleaned[1] == '1') {
        memmove(cleaned, cleaned + 2, cleanedPos - 1);
        cleanedPos -= 2;
    } else if (cleanedPos == 11 && cleaned == '1') {
        memmove(cleaned, cleaned + 1, cleanedPos);
        cleanedPos -= 1;
    }
    
    // Validate NANP format
    if (cleanedPos != 10) {
        return -1; // Invalid length
    }
    
    // Check NANP format: first digit of area code (2-9), first digit of exchange (2-9)
    if (cleaned < '2' || cleaned > '9') {
        return -1; // Invalid area code
    }
    if (cleaned[3] < '2' || cleaned[3] > '9') {
        return -1; // Invalid exchange code
    }
    
    // Ensure all characters are digits
    for (size_t i = 0; i < cleanedPos; i++) {
        if (cleaned[i] < '0' || cleaned[i] > '9') {
            return -1; // Invalid character
        }
    }
    
    strncpy(result, cleaned, resultSize - 1);
    result[resultSize - 1] = '\0';
    
    return 0; // Success
}

int main() {
    const char* testCases[] = {
        "+1 (613)-995-0253",
        "613-995-0253", 
        "1 613 995 0253",
        "613.995.0253",
        "(613) 995-0253"
    };
    
    size_t numTests = sizeof(testCases) / sizeof(testCases);
    
    for (size_t i = 0; i < numTests; i++) {
        char result;
        if (cleanPhoneNumber(testCases[i], result, sizeof(result)) == 0) {
            printf("Input: %s -> Output: %s\n", testCases[i], result);
        } else {
            printf("Input: %s -> Error: Invalid phone number\n", testCases[i]);
        }
    }
    
    return 0;
}
