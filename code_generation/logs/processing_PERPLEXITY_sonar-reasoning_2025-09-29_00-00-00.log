```python
import heapq
from typing import List

class MedianFinder:
    def __init__(self):
        self.max_heap: List[int] = []  # smaller half (negated for max heap)
        self.min_heap: List[int] = []  # larger half
    
    def addNum(self, num: int) -> None:
        if num < -100000 or num > 100000:
            raise ValueError("Number out of range")
        
        if not self.max_heap or num <= -self.max_heap[0]:
            heapq.heappush(self.max_heap, -num)
        else:
            heapq.heappush(self.min_heap, num)
        
        # Balance heaps
        if len(self.max_heap) > len(self.min_heap) + 1:
            val = -heapq.heappop(self.max_heap)
            heapq.heappush(self.min_heap, val)
        elif len(self.min_heap) > len(self.max_heap) + 1:
            val = heapq.heappop(self.min_heap)
            heapq.heappush(self.max_heap, -val)
    
    def findMedian(self) -> float:
        if not self.max_heap and not self.min_heap:
            raise RuntimeError("No elements in data structure")
        
        if len(self.max_heap) > len(self.min_heap):
            return float(-self.max_heap[0])
        elif len(self.min_heap) > len(self.max_heap):
            return float(self.min_heap[0])
        else:
            return (-self.max_heap[0] + self.min_heap[0]) / 2.0

def main():
    # Test case 1
    mf1 = MedianFinder()
    mf1.addNum(1)
    mf1.addNum(2)
    print(f"{mf1.findMedian()}")  # 1.5
    mf1.addNum(3)
    print(f"{mf1.findMedian()}")  # 2.0
    
    # Test case 2
    mf2 = MedianFinder()
    mf2.addNum(6)
    print(f"{mf2.findMedian()}")  # 6.0
    mf2.addNum(10)
    print(f"{mf2.findMedian()}")  # 8.0
    
    # Test case 3
    mf3 = MedianFinder()
    mf3.addNum(2)
    mf3.addNum(3)
    mf3.addNum(4)
    print(f"{mf3.findMedian()}")  # 3.0
    
    # Test case 4
    mf4 = MedianFinder()
    mf4.addNum(-1)
    mf4.addNum(-2)
    print(f"{mf4.findMedian()}")  # -1.5
    
    # Test case 5
    mf5 = MedianFinder()
    mf5.addNum(1)
    mf5.addNum(2)
    mf5.addNum(3)
    mf5.addNum(4)
    mf5.addNum(5)
    print(f"{mf5.findMedian()}")  # 3.0

if __name__ == "__main__":
    main()
