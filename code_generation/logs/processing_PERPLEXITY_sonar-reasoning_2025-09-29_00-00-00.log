```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <pthread.h>
#include <unistd.h>

typedef struct {
    pthread_mutex_t mutex;
    pthread_cond_t hydrogen_cond;
    pthread_cond_t oxygen_cond;
    int hydrogen_count;
    int oxygen_count;
    int hydrogen_released;
    int oxygen_released;
    char* result;
    int result_len;
    pthread_mutex_t result_mutex;
} H2OMolecule;

typedef struct {
    H2OMolecule* molecule;
    char type;
} ThreadData;

void releaseHydrogen(H2OMolecule* mol) {
    pthread_mutex_lock(&mol->result_mutex);
    if (mol->result_len < 1000) {
        mol->result[mol->result_len++] = 'H';
    }
    pthread_mutex_unlock(&mol->result_mutex);
}

void releaseOxygen(H2OMolecule* mol) {
    pthread_mutex_lock(&mol->result_mutex);
    if (mol->result_len < 1000) {
        mol->result[mol->result_len++] = 'O';
    }
    pthread_mutex_unlock(&mol->result_mutex);
}

void* hydrogen(void* arg) {
    H2OMolecule* mol = (H2OMolecule*)arg;
    
    pthread_mutex_lock(&mol->mutex);
    mol->hydrogen_count++;
    
    while (mol->hydrogen_released == 0 && !(mol->hydrogen_count >= 2 && mol->oxygen_count >= 1)) {
        pthread_cond_wait(&mol->hydrogen_cond, &mol->mutex);
    }
    
    if (mol->hydrogen_count >= 2 && mol->oxygen_count >= 1 && mol->hydrogen_released == 0) {
        mol->hydrogen_released = 2;
        mol->oxygen_released = 1;
        mol->hydrogen_count -= 2;
        mol->oxygen_count -= 1;
        pthread_cond_broadcast(&mol->hydrogen_cond);
        pthread_cond_broadcast(&mol->oxygen_cond);
    }
    
    if (mol->hydrogen_released > 0) {
        mol->hydrogen_released--;
        pthread_mutex_unlock(&mol->mutex);
        releaseHydrogen(mol);
    } else {
        pthread_mutex_unlock(&mol->mutex);
    }
    
    return NULL;
}

void* oxygen(void* arg) {
    H2OMolecule* mol = (H2OMolecule*)arg;
    
    pthread_mutex_lock(&mol->mutex);
    mol->oxygen_count++;
    
    while (mol->oxygen_released == 0 && !(mol->hydrogen_count >= 2 && mol->oxygen_count >= 1)) {
        pthread_cond_wait(&mol->oxygen_cond, &mol->mutex);
    }
    
    if (mol->hydrogen_count >= 2 && mol->oxygen_count >= 1 && mol->oxygen_released == 0) {
        mol->hydrogen_released = 2;
        mol->oxygen_released = 1;
        mol->hydrogen_count -= 2;
        mol->oxygen_count -= 1;
        pthread_cond_broadcast(&mol->hydrogen_cond);
        pthread_cond_broadcast(&mol->oxygen_cond);
    }
    
    if (mol->oxygen_released > 0) {
        mol->oxygen_released--;
        pthread_mutex_unlock(&mol->mutex);
        releaseOxygen(mol);
    } else {
        pthread_mutex_unlock(&mol->mutex);
    }
    
    return NULL;
}

char* buildMolecule(const char* water) {
    if (!water || strlen(water) % 3 != 0) {
        return NULL;
    }
    
    int len = strlen(water);
    for (int i = 0; i < len; i++) {
        if (water[i] != 'H' && water[i] != 'O') {
            return NULL;
        }
    }
    
    H2OMolecule mol;
    pthread_mutex_init(&mol.mutex, NULL);
    pthread_cond_init(&mol.hydrogen_cond, NULL);
    pthread_cond_init(&mol.oxygen_cond, NULL);
    pthread_mutex_init(&mol.result_mutex, NULL);
    
    mol.hydrogen_count = 0;
    mol.oxygen_count = 0;
    mol.hydrogen_released = 0;
    mol.oxygen_released = 0;
    mol.result = malloc(len + 1);
    mol.result_len = 0;
    memset(mol.result, 0, len + 1);
    
    pthread_t* threads = malloc(len * sizeof(pthread_t));
    
    for (int i = 0; i < len; i++) {
        if (water[i] == 'H') {
            pthread_create(&threads[i], NULL, hydrogen, &mol);
        } else {
            pthread_create(&threads[i], NULL, oxygen, &mol);
        }
    }
    
    for (int i = 0; i < len; i++) {
        pthread_join(threads[i], NULL);
    }
    
    mol.result[mol.result_len] = '\0';
    
    char* result = malloc(strlen(mol.result) + 1);
    strcpy(result, mol.result);
    
    free(mol.result);
    free(threads);
    pthread_mutex_destroy(&mol.mutex);
    pthread_cond_destroy(&mol.hydrogen_cond);
    pthread_cond_destroy(&mol.oxygen_cond);
    pthread_mutex_destroy(&mol.result_mutex);
    
    return result;
}

int main() {
    const char* testCases[] = {"HOH", "OOHHHH", "HHHOOO", "OHHHHO", "HHOOHH"};
    int numTests = 5;
    
    for (int i = 0; i < numTests; i++) {
        char* output = buildMolecule(testCases[i]);
        if (output) {
            printf("Input: %s -> Output: %s\n", testCases[i], output);
            free(output);
        } else {
            printf("Error with input %s\n", testCases[i]);
        }
    }
    
    return 0;
}
