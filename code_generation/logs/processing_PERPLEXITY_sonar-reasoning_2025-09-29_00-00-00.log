```java
import java.util.*;

public class Task172 {
    public static int distinctEchoSubstrings(String text) {
        if (text == null || text.length() < 1 || text.length() > 2000) {
            throw new IllegalArgumentException("Invalid input");
        }
        
        Set<String> result = new HashSet<>();
        int n = text.length();
        
        // Check all possible substrings with even length
        for (int i = 0; i < n; i++) {
            for (int j = i + 2; j <= n; j += 2) { // j += 2 ensures even length
                String substring = text.substring(i, j);
                int len = substring.length();
                int half = len / 2;
                
                String firstHalf = substring.substring(0, half);
                String secondHalf = substring.substring(half, len);
                
                if (firstHalf.equals(secondHalf)) {
                    result.add(substring);
                }
            }
        }
        
        return result.size();
    }
    
    public static void main(String[] args) {
        // Test cases
        System.out.println(distinctEchoSubstrings("abcabcabc")); // Expected: 3
        System.out.println(distinctEchoSubstrings("leetcodeleetcode")); // Expected: 2
        System.out.println(distinctEchoSubstrings("aa")); // Expected: 1
        System.out.println(distinctEchoSubstrings("abab")); // Expected: 1
        System.out.println(distinctEchoSubstrings("a")); // Expected: 0
    }
}
