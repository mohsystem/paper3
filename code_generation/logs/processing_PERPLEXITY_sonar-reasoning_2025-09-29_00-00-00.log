```cpp
#include <iostream>
#include <string>
#include <unordered_map>
#include <mutex>
#include <shared_mutex>
#include <memory>
#include <atomic>

class BankAccount {
private:
    std::string account_number;
    double balance;
    bool is_open;
    mutable std::shared_mutex account_mutex;

public:
    BankAccount(const std::string& acc_num, double initial_balance) 
        : account_number(acc_num), balance(initial_balance), is_open(true) {
        if (acc_num.empty() || initial_balance < 0) {
            throw std::invalid_argument("Invalid account parameters");
        }
    }

    bool deposit(double amount) {
        if (amount <= 0) {
            return false;
        }
        
        std::unique_lock<std::shared_mutex> lock(account_mutex);
        if (!is_open) {
            return false;
        }
        balance += amount;
        return true;
    }

    bool withdraw(double amount) {
        if (amount <= 0) {
            return false;
        }
        
        std::unique_lock<std::shared_mutex> lock(account_mutex);
        if (!is_open || balance < amount) {
            return false;
        }
        balance -= amount;
        return true;
    }

    double get_balance() const {
        std::shared_lock<std::shared_mutex> lock(account_mutex);
        return is_open ? balance : -1;
    }

    bool close() {
        std::unique_lock<std::shared_mutex> lock(account_mutex);
        if (!is_open) {
            return false;
        }
        is_open = false;
        return true;
    }

    bool is_account_open() const {
        std::shared_lock<std::shared_mutex> lock(account_mutex);
        return is_open;
    }
};

class BankSystem {
private:
    std::unordered_map<std::string, std::unique_ptr<BankAccount>> accounts;
    mutable std::shared_mutex system_mutex;
    std::atomic<int> account_counter{1000};

public:
    std::string open_account(double initial_balance) {
        if (initial_balance < 0) {
            return "";
        }
        
        std::string account_number = std::to_string(account_counter.fetch_add(1));
        
        try {
            auto account = std::make_unique<BankAccount>(account_number, initial_balance);
            std::unique_lock<std::shared_mutex> lock(system_mutex);
            accounts[account_number] = std::move(account);
            return account_number;
        } catch (const std::exception&) {
            return "";
        }
    }

    bool close_account(const std::string& account_number) {
        if (account_number.empty()) {
            return false;
        }
        
        std::shared_lock<std::shared_mutex> lock(system_mutex);
        auto it = accounts.find(account_number);
        if (it == accounts.end()) {
            return false;
        }
        return it->second->close();
    }

    bool deposit(const std::string& account_number, double amount) {
        if (account_number.empty()) {
            return false;
        }
        
        std::shared_lock<std::shared_mutex> lock(system_mutex);
        auto it = accounts.find(account_number);
        if (it == accounts.end()) {
            return false;
        }
        return it->second->deposit(amount);
    }

    bool withdraw(const std::string& account_number, double amount) {
        if (account_number.empty()) {
            return false;
        }
        
        std::shared_lock<std::shared_mutex> lock(system_mutex);
        auto it = accounts.find(account_number);
        if (it == accounts.end()) {
            return false;
        }
        return it->second->withdraw(amount);
    }

    double get_balance(const std::string& account_number) const {
        if (account_number.empty()) {
            return -1;
        }
        
        std::shared_lock<std::shared_mutex> lock(system_mutex);
        auto it = accounts.find(account_number);
        if (it == accounts.end()) {
            return -1;
        }
        return it->second->get_balance();
    }
};

int main() {
    BankSystem bank;
    
    // Test case 1: Open account and deposit
    std::string account1 = bank.open_account(1000.00);
    std::cout << "Test 1 - Account opened: " << (!account1.empty()) << std::endl;
    bool deposit_result = bank.deposit(account1, 500.00);
    std::cout << "Test 1 - Deposit successful: " << deposit_result << std::endl;
    std::cout << "Test 1 - Balance: " << bank.get_balance(account1) << std::endl;
    
    // Test case 2: Withdraw money
    bool withdraw_result = bank.withdraw(account1, 200.00);
    std::cout << "Test 2 - Withdraw successful: " << withdraw_result << std::endl;
    std::cout << "Test 2 - Balance: " << bank.get_balance(account1) << std::endl;
    
    // Test case 3: Insufficient funds
    bool insufficient_withdraw = bank.withdraw(account1, 2000.00);
    std::cout << "Test 3 - Insufficient funds withdraw: " << insufficient_withdraw << std::endl;
    
    // Test case 4: Close account and try operations
    bool close_result = bank.close_account(account1);
    std::cout << "Test 4 - Account closed: " << close_result << std::endl;
    bool deposit_closed = bank.deposit(account1, 100.00);
    std::cout << "Test 4 - Deposit to closed account: " << deposit_closed << std::endl;
    
    // Test case 5: Invalid operations
    bool invalid_account = bank.deposit("invalid", 100.00);
    std::cout << "Test 5 - Invalid account operation: " << invalid_account << std::endl;
    double null_balance = bank.get_balance("nonexistent");
    std::cout << "Test 5 - Nonexistent account balance: " << null_balance << std::endl;
    
    return 0;
}
