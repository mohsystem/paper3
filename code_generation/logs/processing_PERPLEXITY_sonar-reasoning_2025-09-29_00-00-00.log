```python
from typing import List

def shortest_subarray(nums: List[int], k: int) -> int:
    if not nums or len(nums) == 0:
        return -1
    
    n = len(nums)
    min_len = float('inf')
    left = 0
    sum_val = 0
    
    for right in range(n):
        sum_val += nums[right]
        
        while left <= right and sum_val >= k:
            min_len = min(min_len, right - left + 1)
            sum_val -= nums[left]
            left += 1
    
    return -1 if min_len == float('inf') else min_len

if __name__ == "__main__":
    print(shortest_subarray([1], 1))
    print(shortest_subarray([1, 2], 4))
    print(shortest_subarray([2, -1, 2], 3))
    print(shortest_subarray([1, 2, 3, 4], 6))
    print(shortest_subarray([-1, -2, -3], 1))
```

```cpp
#include <iostream>
#include <vector>
#include <climits>
#include <algorithm>

int shortestSubarray(const std::vector<int>& nums, int k) {
    if (nums.empty()) {
        return -1;
    }
    
    int n = nums.size();
    int minLen = INT_MAX;
    int left = 0;
    long long sum = 0;
    
    for (int right = 0; right < n; right++) {
        sum += nums[right];
        
        while (left <= right && sum >= k) {
            minLen = std::min(minLen, right - left + 1);
            sum -= nums[left];
            left++;
        }
    }
    
    return minLen == INT_MAX ? -1 : minLen;
}

int main() {
    std::cout << shortestSubarray({1}, 1) << std::endl;
    std::cout << shortestSubarray({1, 2}, 4) << std::endl;
    std::cout << shortestSubarray({2, -1, 2}, 3) << std::endl;
    std::cout << shortestSubarray({1, 2, 3, 4}, 6) << std::endl;
    std::cout << shortestSubarray({-1, -2, -3}, 1) << std::endl;
    return 0;
}
```

```c
#include <stdio.h>
#include <limits.h>

int shortestSubarray(int* nums, int numsSize, int k) {
    if (nums == NULL || numsSize == 0) {
        return -1;
    }
    
    int minLen = INT_MAX;
    int left = 0;
    long long sum = 0;
    
    for (int right = 0; right < numsSize; right++) {
        sum += nums[right];
        
        while (left <= right && sum >= k) {
            int currentLen = right - left + 1;
            if (currentLen < minLen) {
                minLen = currentLen;
            }
            sum -= nums[left];
            left++;
        }
    }
    
    return minLen == INT_MAX ? -1 : minLen;
}

int main() {
    int test1[] = {1};
    int test2[] = {1, 2};
    int test3[] = {2, -1, 2};
    int test4[] = {1, 2, 3, 4};
    int test5[] = {-1, -2, -3};
    
    printf("%d\n", shortestSubarray(test1, 1, 1));
    printf("%d\n", shortestSubarray(test2, 2, 4));
    printf("%d\n", shortestSubarray(test3, 3, 3));
    printf("%d\n", shortestSubarray(test4, 4, 6));
    printf("%d\n", shortestSubarray(test5, 3, 1));
    
    return 0;
}
