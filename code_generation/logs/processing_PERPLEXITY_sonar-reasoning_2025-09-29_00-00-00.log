import com.sun.net.httpserver.HttpServer;
import com.sun.net.httpserver.HttpHandler;
import com.sun.net.httpserver.HttpExchange;
import java.io.*;
import java.net.InetSocketAddress;
import java.net.URLDecoder;
import java.nio.charset.StandardCharsets;
import java.util.HashMap;
import java.util.Map;

public class Task38 {
    private static final int MAX_INPUT_LENGTH = 1000;
    private static final String FORM_HTML = 
        "<DOCTYPE html><html><head><title>User Input Form</title></head><body>" +
        "<h1>Enter Your Information</h1>" +
        "<form method='post' action='/'>" +
        "<label>Name: <input type='text' name='name' maxlength='100' required></label><br><br>" +
        "<label>Message: <textarea name='message' maxlength='500' required></textarea></label><br><br>" +
        "<input type='submit' value='Submit'>" +
        "</form></body></html>";

    static class FormHandler implements HttpHandler {
        public void handle(HttpExchange exchange) throws IOException {
            String method = exchange.getRequestMethod();
            String response;
            
            if ("GET".equals(method)) {
                response = FORM_HTML;
            } else if ("POST".equals(method)) {
                response = handlePost(exchange);
            } else {
                response = "Method not allowed";
            }
            
            exchange.getResponseHeaders().set("Content-Type", "text/html; charset=UTF-8");
            exchange.sendResponseHeaders(200, response.getBytes(StandardCharsets.UTF_8).length);
            try (OutputStream os = exchange.getResponseBody()) {
                os.write(response.getBytes(StandardCharsets.UTF_8));
            }
        }
        
        private String handlePost(HttpExchange exchange) throws IOException {
            StringBuilder body = new StringBuilder();
            try (BufferedReader reader = new BufferedReader(
                new InputStreamReader(exchange.getRequestBody(), StandardCharsets.UTF_8))) {
                String line;
                int totalLength = 0;
                while ((line = reader.readLine()) != null) {
                    totalLength += line.length();
                    if (totalLength > MAX_INPUT_LENGTH) {
                        return generateErrorPage("Input too long");
                    }
                    body.append(line);
                }
            }
            
            Map<String, String> params = parseFormData(body.toString());
            String name = validateAndSanitize(params.get("name"), 100);
            String message = validateAndSanitize(params.get("message"), 500);
            
            if (name == null || message == null) {
                return generateErrorPage("Invalid input detected");
            }
            
            return generateResultPage(name, message);
        }
        
        private Map<String, String> parseFormData(String formData) {
            Map<String, String> params = new HashMap<>();
            if (formData == null || formData.isEmpty()) {
                return params;
            }
            
            String[] pairs = formData.split("&");
            for (String pair : pairs) {
                String[] keyValue = pair.split("=", 2);
                if (keyValue.length == 2) {
                    try {
                        String key = URLDecoder.decode(keyValue[0], StandardCharsets.UTF_8.name());
                        String value = URLDecoder.decode(keyValue[1], StandardCharsets.UTF_8.name());
                        params.put(key, value);
                    } catch (UnsupportedEncodingException e) {
                        // Skip invalid pairs
                    }
                }
            }
            return params;
        }
        
        private String validateAndSanitize(String input, int maxLength) {
            if (input == null || input.trim().isEmpty()) {
                return null;
            }
            
            input = input.trim();
            if (input.length() > maxLength) {
                return null;
            }
            
            // Allow only alphanumeric, spaces, and basic punctuation
            if (!input.matches("[a-zA-Z0-9\\s.,?'-]*")) {
                return null;
            }
            
            return escapeHtml(input);
        }
        
        private String escapeHtml(String input) {
            return input.replace("&", "&amp;")
                       .replace("<", "&lt;")
                       .replace(">", "&gt;")
                       .replace("\"", "&quot;")
                       .replace("'", "&#x27;");
        }
        
        private String generateResultPage(String name, String message) {
            return "<DOCTYPE html><html><head><title>Form Result</title></head><body>" +
                   "<h1>Thank you for your submission!</h1>" +
                   "<p><strong>Name:</strong> " + name + "</p>" +
                   "<p><strong>Message:</strong> " + message + "</p>" +
                   "<a href='/'>Submit another form</a>" +
                   "</body></html>";
        }
        
        private String generateErrorPage(String error) {
            return "<DOCTYPE html><html><head><title>Error</title></head><body>" +
                   "<h1>Error</h1>" +
                   "<p>" + escapeHtml(error) + "</p>" +
                   "<a href='/'>Try again</a>" +
                   "</body></html>";
        }
    }
    
    public static void main(String[] args) {
        try {
            // Test case 1: Valid input validation
            FormHandler handler = new FormHandler();
            String validName = handler.validateAndSanitize("John Doe", 100);
            System.out.println("Test 1 - Valid name: " + (validName != null ? "PASS" : "FAIL"));
            
            // Test case 2: Input too long
            String longInput = "a".repeat(101);
            String invalidLong = handler.validateAndSanitize(longInput, 100);
            System.out.println("Test 2 - Long input rejected: " + (invalidLong == null ? "PASS" : "FAIL"));
            
            // Test case 3: Invalid characters
            String invalidChars = handler.validateAndSanitize("John<script>", 100);
            System.out.println("Test 3 - Invalid chars rejected: " + (invalidChars == null ? "PASS" : "FAIL"));
            
            // Test case 4: HTML escaping
            String htmlInput = handler.validateAndSanitize("Hello & goodbye", 100);
            System.out.println("Test 4 - HTML escaped: " + (htmlInput != null && htmlInput.contains("&amp;") ? "PASS" : "FAIL"));
            
            // Test case 5: Empty input
            String emptyInput = handler.validateAndSanitize("", 100);
            System.out.println("Test 5 - Empty input rejected: " + (emptyInput == null ? "PASS" : "FAIL"));
            
            // Start server
            HttpServer server = HttpServer.create(new InetSocketAddress(8080), 0);
            server.createContext("/", new FormHandler());
            server.setExecutor(null);
            server.start();
            System.out.println("Server started on http://localhost:8080");
        } catch (Exception e) {
            System.err.println("Server error: " + e.getMessage());
        }
    }
}
