```java
import java.util.*;

public class Task176 {
    static class ProductOfNumbers {
        private List<Integer> stream;
        
        public ProductOfNumbers() {
            this.stream = new ArrayList<>();
        }
        
        public void add(int num) {
            if (num < 0 || num > 100) {
                throw new IllegalArgumentException("Number must be between 0 and 100");
            }
            stream.add(num);
        }
        
        public int getProduct(int k) {
            if (k <= 0 || k > stream.size()) {
                throw new IllegalArgumentException("Invalid k value");
            }
            
            int product = 1;
            int size = stream.size();
            for (int i = size - k; i < size; i++) {
                product *= stream.get(i);
            }
            return product;
        }
    }
    
    public static void main(String[] args) {
        ProductOfNumbers pon1 = new ProductOfNumbers();
        pon1.add(3);
        pon1.add(0);
        pon1.add(2);
        pon1.add(5);
        pon1.add(4);
        System.out.println(pon1.getProduct(2));
        System.out.println(pon1.getProduct(3));
        System.out.println(pon1.getProduct(4));
        pon1.add(8);
        System.out.println(pon1.getProduct(2));
        
        ProductOfNumbers pon2 = new ProductOfNumbers();
        pon2.add(1);
        pon2.add(1);
        pon2.add(1);
        System.out.println(pon2.getProduct(3));
    }
}
