```cpp
#include <iostream>
#include <string>
#include <stdexcept>

std::string dnaComplement(const std::string& dna) {
    if (dna.empty()) {
        throw std::invalid_argument("DNA string cannot be empty");
    }
    
    // Validate input contains only valid DNA characters
    for (char c : dna) {
        if (c != 'A' && c != 'T' && c != 'C' && c != 'G') {
            throw std::invalid_argument("Invalid DNA character: " + std::string(1, c));
        }
    }
    
    std::string complement;
    complement.reserve(dna.length());
    
    for (char nucleotide : dna) {
        switch (nucleotide) {
            case 'A':
                complement += 'T';
                break;
            case 'T':
                complement += 'A';
                break;
            case 'C':
                complement += 'G';
                break;
            case 'G':
                complement += 'C';
                break;
        }
    }
    
    return complement;
}

int main() {
    try {
        // Test case 1
        std::string test1 = "ATTGC";
        std::cout << test1 << " -> " << dnaComplement(test1) << std::endl;
        
        // Test case 2
        std::string test2 = "GTAT";
        std::cout << test2 << " -> " << dnaComplement(test2) << std::endl;
        
        // Test case 3
        std::string test3 = "AAAA";
        std::cout << test3 << " -> " << dnaComplement(test3) << std::endl;
        
        // Test case 4
        std::string test4 = "CCGG";
        std::cout << test4 << " -> " << dnaComplement(test4) << std::endl;
        
        // Test case 5
        std::string test5 = "ATCGATCG";
        std::cout << test5 << " -> " << dnaComplement(test5) << std::endl;
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
