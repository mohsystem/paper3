```python
import threading
from typing import Optional

class H2OMolecule:
    def __init__(self):
        self._lock = threading.Lock()
        self._hydrogen_sem = threading.Semaphore(0)
        self._oxygen_sem = threading.Semaphore(0)
        self._hydrogen_count = 0
        self._oxygen_count = 0
        self._result = []
        self._result_lock = threading.Lock()
    
    def hydrogen(self) -> None:
        with self._lock:
            self._hydrogen_count += 1
            if self._hydrogen_count >= 2 and self._oxygen_count >= 1:
                self._hydrogen_sem.release(1)
                self._oxygen_sem.release(1)
                self._hydrogen_count -= 2
                self._oxygen_count -= 1
        
        self._hydrogen_sem.acquire()
        self._release_hydrogen()
    
    def oxygen(self) -> None:
        with self._lock:
            self._oxygen_count += 1
            if self._hydrogen_count >= 2 and self._oxygen_count >= 1:
                self._hydrogen_sem.release(2)
                self._oxygen_sem.release(1)
                self._hydrogen_count -= 2
                self._oxygen_count -= 1
        
        self._oxygen_sem.acquire()
        self._release_oxygen()
    
    def _release_hydrogen(self) -> None:
        with self._result_lock:
            self._result.append('H')
    
    def _release_oxygen(self) -> None:
        with self._result_lock:
            self._result.append('O')
    
    def build_molecule(self, water: str) -> str:
        if not water or len(water) % 3 != 0:
            raise ValueError("Invalid input length")
        
        for c in water:
            if c not in 'HO':
                raise ValueError("Invalid character")
        
        self._result.clear()
        self._hydrogen_count = 0
        self._oxygen_count = 0
        
        threads = []
        
        for c in water:
            if c == 'H':
                thread = threading.Thread(target=self.hydrogen)
            else:
                thread = threading.Thread(target=self.oxygen)
            threads.append(thread)
            thread.start()
        
        for thread in threads:
            thread.join()
        
        return ''.join(self._result)

def main():
    solution = H2OMolecule()
    test_cases = ["HOH", "OOHHHH", "HHHOOO", "OHHHHO", "HHOOHH"]
    
    for test in test_cases:
        try:
            output = solution.build_molecule(test)
            print(f"Input: {test} -> Output: {output}")
        except Exception as e:
            print(f"Error with input {test}: {e}")

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <string>
#include <thread>
#include <mutex>
#include <condition_variable>
#include <vector>
#include <stdexcept>

class H2OMolecule {
private:
    std::mutex mtx;
    std::condition_variable hydrogen_cv;
    std::condition_variable oxygen_cv;
    int hydrogen_count;
    int oxygen_count;
    int hydrogen_released;
    int oxygen_released;
    std::string result;
    std::mutex result_mtx;

public:
    H2OMolecule() : hydrogen_count(0), oxygen_count(0), hydrogen_released(0), oxygen_released(0) {}
    
    void hydrogen() {
        std::unique_lock<std::mutex> lock(mtx);
        hydrogen_count++;
        
        while (hydrogen_released == 0 && !(hydrogen_count >= 2 && oxygen_count >= 1)) {
            hydrogen_cv.wait(lock);
        }
        
        if (hydrogen_count >= 2 && oxygen_count >= 1 && hydrogen_released == 0) {
            hydrogen_released = 2;
            oxygen_released = 1;
            hydrogen_count -= 2;
            oxygen_count -= 1;
            hydrogen_cv.notify_all();
            oxygen_cv.notify_all();
        }
        
        if (hydrogen_released > 0) {
            hydrogen_released--;
            lock.unlock();
            releaseHydrogen();
        }
    }
    
    void oxygen() {
        std::unique_lock<std::mutex> lock(mtx);
        oxygen_count++;
        
        while (oxygen_released == 0 && !(hydrogen_count >= 2 && oxygen_count >= 1)) {
            oxygen_cv.wait(lock);
        }
        
        if (hydrogen_count >= 2 && oxygen_count >= 1 && oxygen_released == 0) {
            hydrogen_released = 2;
            oxygen_released = 1;
            hydrogen_count -= 2;
            oxygen_count -= 1;
            hydrogen_cv.notify_all();
            oxygen_cv.notify_all();
        }
        
        if (oxygen_released > 0) {
            oxygen_released--;
            lock.unlock();
            releaseOxygen();
        }
    }
    
private:
    void releaseHydrogen() {
        std::lock_guard<std::mutex> lock(result_mtx);
        result += 'H';
    }
    
    void releaseOxygen() {
        std::lock_guard<std::mutex> lock(result_mtx);
        result += 'O';
    }
    
public:
    std::string buildMolecule(const std::string& water) {
        if (water.empty() || water.length() % 3 != 0) {
            throw std::invalid_argument("Invalid input length");
        }
        
        for (char c : water) {
            if (c != 'H' && c != 'O') {
                throw std::invalid_argument("Invalid character");
            }
        }
        
        result.clear();
        hydrogen_count = 0;
        oxygen_count = 0;
        hydrogen_released = 0;
        oxygen_released = 0;
        
        std::vector<std::thread> threads;
        
        for (char c : water) {
            if (c == 'H') {
                threads.emplace_back(&H2OMolecule::hydrogen, this);
            } else {
                threads.emplace_back(&H2OMolecule::oxygen, this);
            }
        }
        
        for (auto& t : threads) {
            t.join();
        }
        
        return result;
    }
};

int main() {
    H2OMolecule solution;
    std::vector<std::string> testCases = {"HOH", "OOHHHH", "HHHOOO", "OHHHHO", "HHOOHH"};
    
    for (const auto& test : testCases) {
        try {
            std::string output = solution.buildMolecule(test);
            std::cout << "Input: " << test << " -> Output: " << output << std::endl;
        } catch (const std::exception& e) {
            std::cout << "Error with input " << test << ": " << e.what() << std::endl;
        }
    }
    
    return 0;
}
