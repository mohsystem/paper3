public class Task191 {
    public static int longestValidParentheses(String s) {
        // Handle null or short input strings
        if (s == null || s.length() <= 1) {
            return 0;
        }
        
        // Initialize dynamic programming array and max length
        int n = s.length();
        int[] dp = new int[n];
        int maxLen = 0;
        
        // Iterate through the string to find valid parentheses
        for (int i = 1; i < n; i++) {
            if (s.charAt(i) == ')') {
                // Direct pair case
                if (s.charAt(i - 1) == '(') {
                    dp[i] = (i >= 2 ? dp[i - 2] : 0) + 2;
                } 
                // Nested or consecutive valid parentheses case
                else if (dp[i - 1] > 0) {
                    int matchIndex = i - dp[i - 1] - 1;
                    if (matchIndex >= 0 && s.charAt(matchIndex) == '(') {
                        dp[i] = dp[i - 1] + 2 + (matchIndex >= 2 ? dp[matchIndex - 1] : 0);
                    }
                }
                
                // Update maximum length
                maxLen = Math.max(maxLen, dp[i]);
            }
        }
        
        return maxLen;
    }
}
