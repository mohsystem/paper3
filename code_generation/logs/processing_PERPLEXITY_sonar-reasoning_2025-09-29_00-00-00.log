```python
from xmlrpc.server import SimpleXMLRPCServer
import threading
import time
from typing import Union

class XMLRPCServerHandler:
    def add(self, a: int, b: int) -> int:
        if not isinstance(a, int) or not isinstance(b, int):
            raise TypeError("Parameters must be integers")
        
        if a > 0 and b > 2**31 - 1 - a:
            raise OverflowError("Integer overflow")
        if a < 0 and b < -2**31 - a:
            raise OverflowError("Integer underflow")
        
        return a + b
    
    def multiply(self, a: int, b: int) -> int:
        if not isinstance(a, int) or not isinstance(b, int):
            raise TypeError("Parameters must be integers")
        
        if a != 0 and b != 0:
            if abs(a) > 2**31 // abs(b):
                raise OverflowError("Integer overflow")
        
        return a * b
    
    def echo(self, message: str) -> str:
        if not isinstance(message, str):
            raise TypeError("Parameter must be a string")
        
        if len(message) > 1000:
            raise ValueError("Message too long")
        
        return f"Echo: {message}"

def run_server():
    try:
        server = SimpleXMLRPCServer(('localhost', 8000), logRequests=False)
        handler = XMLRPCServerHandler()
        
        server.register_function(handler.add, 'add')
        server.register_function(handler.multiply, 'multiply')
        server.register_function(handler.echo, 'echo')
        
        print("XML-RPC Server starting on localhost:8000")
        server.serve_forever()
    except Exception as e:
        print(f"Server error: {e}")

def main():
    handler = XMLRPCServerHandler()
    
    print("Test Case 1 - Add 5 + 3:")
    try:
        result = handler.add(5, 3)
        print(f"Result: {result}")
    except Exception as e:
        print(f"Error: {e}")
    
    print("\nTest Case 2 - Multiply 4 * 6:")
    try:
        result = handler.multiply(4, 6)
        print(f"Result: {result}")
    except Exception as e:
        print(f"Error: {e}")
    
    print("\nTest Case 3 - Echo message:")
    try:
        result = handler.echo("Hello XML-RPC")
        print(f"Result: {result}")
    except Exception as e:
        print(f"Error: {e}")
    
    print("\nTest Case 4 - Add with type error:")
    try:
        result = handler.add("5", 3)
        print(f"Result: {result}")
    except Exception as e:
        print(f"Error: {e}")
    
    print("\nTest Case 5 - Echo with long message:")
    try:
        long_message = "x" * 1001
        result = handler.echo(long_message)
        print(f"Result: {result}")
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
