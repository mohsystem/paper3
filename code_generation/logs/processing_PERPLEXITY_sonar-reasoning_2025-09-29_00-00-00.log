```java
import java.security.SecureRandom;
import java.util.HashSet;
import java.util.Set;

public class Task184 {
    private static final Set<String> usedNames = new HashSet<>();
    private static final SecureRandom secureRandom = new SecureRandom();
    
    private String name;
    
    public Task184() {
        this.name = null;
    }
    
    public String getName() {
        if (this.name == null) {
            this.name = generateUniqueName();
        }
        return this.name;
    }
    
    public void reset() {
        if (this.name != null) {
            usedNames.remove(this.name);
            this.name = null;
        }
    }
    
    private static String generateUniqueName() {
        String name;
        do {
            StringBuilder sb = new StringBuilder();
            for (int i = 0; i < 2; i++) {
                sb.append((char) ('A' + secureRandom.nextInt(26)));
            }
            for (int i = 0; i < 3; i++) {
                sb.append(secureRandom.nextInt(10));
            }
            name = sb.toString();
        } while (usedNames.contains(name));
        
        usedNames.add(name);
        return name;
    }
    
    public static void main(String[] args) {
        Task184 robot1 = new Task184();
        Task184 robot2 = new Task184();
        Task184 robot3 = new Task184();
        Task184 robot4 = new Task184();
        Task184 robot5 = new Task184();
        
        System.out.println("Robot 1: " + robot1.getName());
        System.out.println("Robot 2: " + robot2.getName());
        System.out.println("Robot 3: " + robot3.getName());
        System.out.println("Robot 4: " + robot4.getName());
        System.out.println("Robot 5: " + robot5.getName());
        
        robot1.reset();
        System.out.println("Robot 1 after reset: " + robot1.getName());
    }
}
