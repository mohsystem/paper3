```c
#include <stdio.h>
#include <stdbool.h>

bool xorGame(int* nums, int numsSize) {
    if (nums == NULL || numsSize <= 0 || numsSize > 1000) {
        return false;
    }
    
    int xorResult = 0;
    for (int i = 0; i < numsSize; i++) {
        if (nums[i] < 0 || nums[i] >= 65536) {
            return false;
        }
        xorResult ^= nums[i];
    }
    
    return xorResult == 0 || numsSize % 2 == 0;
}

int main() {
    int test1[] = {1, 1, 2};
    printf("Test 1: %s\n", xorGame(test1, 3) ? "true" : "false");
    
    int test2[] = {0, 1};
    printf("Test 2: %s\n", xorGame(test2, 2) ? "true" : "false");
    
    int test3[] = {1, 2, 3};
    printf("Test 3: %s\n", xorGame(test3, 3) ? "true" : "false");
    
    int test4[] = {1};
    printf("Test 4: %s\n", xorGame(test4, 1) ? "true" : "false");
    
    int test5[] = {2, 2, 2, 2};
    printf("Test 5: %s\n", xorGame(test5, 4) ? "true" : "false");
    
    return 0;
}
