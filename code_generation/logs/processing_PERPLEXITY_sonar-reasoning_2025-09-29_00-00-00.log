import javax.crypto.*;
import javax.crypto.spec.*;
import java.security.SecureRandom;
import java.security.NoSuchAlgorithmException;
import java.security.InvalidKeyException;
import java.security.InvalidAlgorithmParameterException;
import java.security.spec.InvalidKeySpecException;
import java.nio.file.*;
import java.nio.charset.StandardCharsets;
import java.util.Arrays;

public class Task52 {
    private static final String MAGIC = "ENC1";
    private static final int VERSION = 1;
    private static final int SALT_LENGTH = 16;
    private static final int IV_LENGTH = 12;
    private static final int TAG_LENGTH = 16;
    private static final int PBKDF2_ITERATIONS = 210000;
    private static final SecureRandom secureRandom = new SecureRandom();

    public static boolean encryptFile(String inputPath, String outputPath, String password) {
        if (inputPath == null || outputPath == null || password == null || 
            inputPath.trim().isEmpty() || outputPath.trim().isEmpty() || password.isEmpty()) {
            return false;
        }
        
        try {
            byte[] inputData = Files.readAllBytes(Paths.get(inputPath));
            byte[] salt = new byte[SALT_LENGTH];
            byte[] iv = new byte[IV_LENGTH];
            secureRandom.nextBytes(salt);
            secureRandom.nextBytes(iv);
            
            SecretKeyFactory keyFactory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            PBEKeySpec spec = new PBEKeySpec(password.toCharArray(), salt, PBKDF2_ITERATIONS, 256);
            SecretKey key = new SecretKeySpec(keyFactory.generateSecret(spec).getEncoded(), "AES");
            spec.clearPassword();
            
            Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding");
            GCMParameterSpec gcmSpec = new GCMParameterSpec(TAG_LENGTH * 8, iv);
            cipher.init(Cipher.ENCRYPT_MODE, key, gcmSpec);
            byte[] ciphertext = cipher.doFinal(inputData);
            
            byte[] header = MAGIC.getBytes(StandardCharsets.UTF_8);
            byte[] versionBytes = {(byte) VERSION};
            byte[] output = new byte[header.length + 1 + SALT_LENGTH + IV_LENGTH + ciphertext.length];
            
            int pos = 0;
            System.arraycopy(header, 0, output, pos, header.length);
            pos += header.length;
            output[pos++] = versionBytes[0];
            System.arraycopy(salt, 0, output, pos, SALT_LENGTH);
            pos += SALT_LENGTH;
            System.arraycopy(iv, 0, output, pos, IV_LENGTH);
            pos += IV_LENGTH;
            System.arraycopy(ciphertext, 0, output, pos, ciphertext.length);
            
            Files.write(Paths.get(outputPath), output);
            Arrays.fill(inputData, (byte) 0);
            return true;
        } catch (Exception e) {
            return false;
        }
    }
    
    public static boolean decryptFile(String inputPath, String outputPath, String password) {
        if (inputPath == null || outputPath == null || password == null || 
            inputPath.trim().isEmpty() || outputPath.trim().isEmpty() || password.isEmpty()) {
            return false;
        }
        
        try {
            byte[] inputData = Files.readAllBytes(Paths.get(inputPath));
            if (inputData.length < MAGIC.length() + 1 + SALT_LENGTH + IV_LENGTH + TAG_LENGTH) {
                return false;
            }
            
            int pos = 0;
            String magic = new String(inputData, pos, MAGIC.length(), StandardCharsets.UTF_8);
            if (!MAGIC.equals(magic)) return false;
            pos += MAGIC.length();
            
            int version = inputData[pos++] & 0xFF;
            if (version != VERSION) return false;
            
            byte[] salt = Arrays.copyOfRange(inputData, pos, pos + SALT_LENGTH);
            pos += SALT_LENGTH;
            byte[] iv = Arrays.copyOfRange(inputData, pos, pos + IV_LENGTH);
            pos += IV_LENGTH;
            byte[] ciphertext = Arrays.copyOfRange(inputData, pos, inputData.length);
            
            SecretKeyFactory keyFactory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            PBEKeySpec spec = new PBEKeySpec(password.toCharArray(), salt, PBKDF2_ITERATIONS, 256);
            SecretKey key = new SecretKeySpec(keyFactory.generateSecret(spec).getEncoded(), "AES");
            spec.clearPassword();
            
            Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding");
            GCMParameterSpec gcmSpec = new GCMParameterSpec(TAG_LENGTH * 8, iv);
            cipher.init(Cipher.DECRYPT_MODE, key, gcmSpec);
            byte[] plaintext = cipher.doFinal(ciphertext);
            
            Files.write(Paths.get(outputPath), plaintext);
            Arrays.fill(plaintext, (byte) 0);
            return true;
        } catch (Exception e) {
            return false;
        }
    }
    
    public static void main(String[] args) {
        try {
            Files.write(Paths.get("test1.txt"), "Hello World!".getBytes(StandardCharsets.UTF_8));
            Files.write(Paths.get("test2.txt"), "Secret Message".getBytes(StandardCharsets.UTF_8));
            Files.write(Paths.get("test3.txt"), "".getBytes(StandardCharsets.UTF_8));
            Files.write(Paths.get("test4.txt"), "A".repeat(1000).getBytes(StandardCharsets.UTF_8));
            Files.write(Paths.get("test5.txt"), "Unicode: \u4f60\u597d\u4e16\u754c \U0001f30d".getBytes(StandardCharsets.UTF_8));
            
            System.out.println("Test 1: " + (encryptFile("test1.txt", "test1.enc", "password123") && 
                                          decryptFile("test1.enc", "test1.dec", "password123")));
            System.out.println("Test 2: " + (encryptFile("test2.txt", "test2.enc", "secret") && 
                                          decryptFile("test2.enc", "test2.dec", "secret")));
            System.out.println("Test 3: " + (encryptFile("test3.txt", "test3.enc", "empty") && 
                                          decryptFile("test3.enc", "test3.dec", "empty")));
            System.out.println("Test 4: " + (encryptFile("test4.txt", "test4.enc", "long") && 
                                          decryptFile("test4.enc", "test4.dec", "long")));
            System.out.println("Test 5: " + (!decryptFile("test5.enc", "test5.dec", "wrongpass")));
        } catch (Exception e) {
            System.err.println("Test failed: " + e.getMessage());
        }
    }
}
