```python
from typing import List, Tuple

def people_on_bus(bus_stops: List[Tuple[int, int]]) -> int:
    if bus_stops is None:
        raise ValueError("Bus stops list cannot be None")
    
    people_count = 0
    
    for i, stop in enumerate(bus_stops):
        if not isinstance(stop, (tuple, list)) or len(stop) != 2:
            raise ValueError("Each bus stop must have exactly 2 values")
        
        on, off = stop
        if not isinstance(on, int) or not isinstance(off, int):
            raise ValueError("People counts must be integers")
        if on < 0 or off < 0:
            raise ValueError("People counts cannot be negative")
        
        people_count += on - off
        
        if people_count < 0:
            raise ValueError("Bus cannot have negative people count")
    
    return people_count

def main():
    # Test case 1
    test1 = [(10, 0), (3, 5), (5, 8)]
    print(f"Test 1: {people_on_bus(test1)}")  # Expected: 5
    
    # Test case 2
    test2 = [(3, 0), (9, 1), (4, 10), (12, 2), (6, 1), (7, 10)]
    print(f"Test 2: {people_on_bus(test2)}")  # Expected: 17
    
    # Test case 3
    test3 = [(3, 0), (9, 1), (4, 8), (12, 2), (6, 1), (7, 8)]
    print(f"Test 3: {people_on_bus(test3)}")  # Expected: 21
    
    # Test case 4
    test4 = [(0, 0)]
    print(f"Test 4: {people_on_bus(test4)}")  # Expected: 0
    
    # Test case 5
    test5 = [(5, 0), (2, 3), (4, 1)]
    print(f"Test 5: {people_on_bus(test5)}")  # Expected: 7

if __name__ == "__main__":
    main()
```

