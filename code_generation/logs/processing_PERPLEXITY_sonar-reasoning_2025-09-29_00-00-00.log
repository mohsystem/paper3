```java
import java.io.*;
import java.nio.file.*;
import java.util.Scanner;

public class Task36 {
    private static final long MAX_FILE_SIZE = 10 * 1024 * 1024; // 10MB limit
    
    public static String readFileContents(String filename) throws IOException {
        if (filename == null || filename.isEmpty()) {
            throw new IllegalArgumentException("Filename cannot be null or empty");
        }
        
        // Normalize and validate path
        Path path = Paths.get(filename).normalize();
        if (!Files.exists(path)) {
            throw new FileNotFoundException("File not found: " + filename);
        }
        
        if (!Files.isRegularFile(path)) {
            throw new IllegalArgumentException("Path is not a regular file: " + filename);
        }
        
        // Check file size
        long fileSize = Files.size(path);
        if (fileSize > MAX_FILE_SIZE) {
            throw new IOException("File too large: " + fileSize + " bytes");
        }
        
        try {
            return Files.readString(path);
        } catch (IOException e) {
            throw new IOException("Error reading file: " + e.getMessage());
        }
    }
    
    public static void main(String[] args) {
        // Test cases
        String[] testFiles = {"test1.txt", "test2.txt", "nonexistent.txt", "", "test3.txt"};
        
        for (String testFile : testFiles) {
            try {
                System.out.println("Reading file: " + testFile);
                String content = readFileContents(testFile);
                System.out.println("Content: " + content);
            } catch (Exception e) {
                System.err.println("Error: " + e.getMessage());
            }
            System.out.println("---");
        }
        
        // Interactive mode
        Scanner scanner = new Scanner(System.in);
        System.out.print("Enter filename: ");
        String filename = scanner.nextLine().trim();
        
        try {
            String content = readFileContents(filename);
            System.out.println(content);
        } catch (Exception e) {
            System.err.println("Error: " + e.getMessage());
        }
        
        scanner.close();
    }
}
```

```python
import os
import sys
from pathlib import Path
from typing import Optional

MAX_FILE_SIZE = 10 * 1024 * 1024  # 10MB limit

def read_file_contents(filename: str) -> str:
    if not filename or not filename.strip():
        raise ValueError("Filename cannot be empty")
    
    # Normalize and validate path
    try:
        path = Path(filename).resolve()
    except (OSError, ValueError) as e:
        raise ValueError(f"Invalid filename: {e}")
    
    if not path.exists():
        raise FileNotFoundError(f"File not found: {filename}")
    
    if not path.is_file():
        raise ValueError(f"Path is not a regular file: {filename}")
    
    # Check file size
    try:
        file_size = path.stat().st_size
        if file_size > MAX_FILE_SIZE:
            raise ValueError(f"File too large: {file_size} bytes")
    except OSError as e:
        raise ValueError(f"Cannot access file: {e}")
    
    try:
        with open(path, 'r', encoding='utf-8') as file:
            return file.read()
    except (IOError, UnicodeDecodeError) as e:
        raise ValueError(f"Error reading file: {e}")

def main() -> None:
    # Test cases
    test_files = ["test1.txt", "test2.txt", "nonexistent.txt", "", "test3.txt"]
    
    for test_file in test_files:
        try:
            print(f"Reading file: {test_file}")
            content = read_file_contents(test_file)
            print(f"Content: {content}")
        except Exception as e:
            print(f"Error: {e}", file=sys.stderr)
        print("---")
    
    # Interactive mode
    try:
        filename = input("Enter filename: ").strip()
        content = read_file_contents(filename)
        print(content)
    except (EOFError, KeyboardInterrupt):
        print("\nOperation cancelled.")
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <fstream>
#include <string>
#include <stdexcept>
#include <filesystem>

const size_t MAX_FILE_SIZE = 10 * 1024 * 1024; // 10MB limit

std::string readFileContents(const std::string& filename) {
    if (filename.empty()) {
        throw std::invalid_argument("Filename cannot be empty");
    }
    
    // Normalize and validate path
    std::filesystem::path path(filename);
    try {
        path = std::filesystem::canonical(path);
    } catch (const std::filesystem::filesystem_error& e) {
        if (!std::filesystem::exists(path)) {
            throw std::runtime_error("File not found: " + filename);
        }
        throw std::runtime_error("Invalid path: " + std::string(e.what()));
    }
    
    if (!std::filesystem::is_regular_file(path)) {
        throw std::invalid_argument("Path is not a regular file: " + filename);
    }
    
    // Check file size
    std::error_code ec;
    auto file_size = std::filesystem::file_size(path, ec);
    if (ec) {
        throw std::runtime_error("Cannot determine file size: " + ec.message());
    }
    
    if (file_size > MAX_FILE_SIZE) {
        throw std::runtime_error("File too large: " + std::to_string(file_size) + " bytes");
    }
    
    std::ifstream file(path, std::ios::binary);
    if (!file) {
        throw std::runtime_error("Cannot open file: " + filename);
    }
    
    std::string content;
    content.reserve(static_cast<size_t>(file_size));
    
    file.seekg(0, std::ios::end);
    content.resize(file.tellg());
    file.seekg(0, std::ios::beg);
    
    if (!file.read(&content[0], content.size())) {
        throw std::runtime_error("Error reading file: " + filename);
    }
    
    return content;
}

int main() {
    // Test cases
    std::string testFiles[] = {"test1.txt", "test2.txt", "nonexistent.txt", "", "test3.txt"};
    
    for (const auto& testFile : testFiles) {
        try {
            std::cout << "Reading file: " << testFile << std::endl;
            std::string content = readFileContents(testFile);
            std::cout << "Content: " << content << std::endl;
        } catch (const std::exception& e) {
            std::cerr << "Error: " << e.what() << std::endl;
        }
        std::cout << "---" << std::endl;
    }
    
    // Interactive mode
    std::cout << "Enter filename: ";
    std::string filename;
    std::getline(std::cin, filename);
    
    try {
        std::string content = readFileContents(filename);
        std::cout << content << std::endl;
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
    }
    
    return 0;
}
```

```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <errno.h>

#define MAX_FILENAME_LEN 256
#define MAX_FILE_SIZE (10 * 1024 * 1024) /* 10MB limit */
#define BUFFER_SIZE 4096

int validate_filename(const char* filename) {
    if (!filename || strlen(filename) == 0) {
        fprintf(stderr, "Error: Filename cannot be empty\n");
        return 0;
    }
    
    if (strlen(filename) >= MAX_FILENAME_LEN) {
        fprintf(stderr, "Error: Filename too long\n");
        return 0;
    }
    
    /* Basic path traversal prevention */
    if (strstr(filename, "..") != NULL) {
        fprintf(stderr, "Error: Path traversal not allowed\n");
        return 0;
    }
    
    return 1;
}

int read_file_contents(const char* filename) {
    if (!validate_filename(filename)) {
        return 0;
    }
    
    struct stat st;
    if (stat(filename, &st) != 0) {
        fprintf(stderr, "Error: Cannot access file '%s': %s\n", filename, strerror(errno));
        return 0;
    }
    
    if (!S_ISREG(st.st_mode)) {
        fprintf(stderr, "Error: '%s' is not a regular file\n", filename);
        return 0;
    }
    
    if (st.st_size > MAX_FILE_SIZE) {
        fprintf(stderr, "Error: File too large: %ld bytes\n", st.st_size);
        return 0;
    }
    
    FILE* file = fopen(filename, "rb");
    if (!file) {
        fprintf(stderr, "Error: Cannot open file '%s': %s\n", filename, strerror(errno));
        return 0;
    }
    
    char buffer[BUFFER_SIZE];
    size_t bytes_read;
    
    while ((bytes_read = fread(buffer, 1, sizeof(buffer), file)) > 0) {
        if (fwrite(buffer, 1, bytes_read, stdout) != bytes_read) {
            fprintf(stderr, "Error: Cannot write to stdout\n");
            fclose(file);
            return 0;
        }
    }
    
    if (ferror(file)) {
        fprintf(stderr, "Error: Cannot read file '%s'\n", filename);
        fclose(file);
        return 0;
    }
    
    fclose(file);
    return 1;
}

int main() {
    /* Test cases */
    const char* test_files[] = {"test1.txt", "test2.txt", "nonexistent.txt", "", "test3.txt"};
    size_t num_tests = sizeof(test_files) / sizeof(test_files[0]);
    
    for (size_t i = 0; i < num_tests; i++) {
        printf("Reading file: %s\n", test_files[i]);
        if (!read_file_contents(test_files[i])) {
            printf("Failed to read file\n");
        }
        printf("---\n");
    }
    
    /* Interactive mode */
    char filename[MAX_FILENAME_LEN];
    printf("Enter filename: ");
    
    if (fgets(filename, sizeof(filename), stdin) != NULL) {
        /* Remove newline if present */
        size_t len = strlen(filename);
        if (len > 0 && filename[len - 1] == '\n') {
            filename[len - 1] = '\0';
        }
        
        if (!read_file_contents(filename)) {
            return 1;
        }
    } else {
        fprintf(stderr, "Error: Cannot read filename\n");
        return 1;
    }
    
    return 0;
}
