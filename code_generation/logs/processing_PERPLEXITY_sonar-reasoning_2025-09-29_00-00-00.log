#include <iostream>
#include <vector>
using namespace std;

int countRangeSum(vector<int>& nums, int lower, int upper) {
    if (nums.empty() || lower > upper) {
        return 0;
    }
    
    int count = 0;
    int n = nums.size();
    
    for (int i = 0; i < n; i++) {
        long long sum = 0;
        for (int j = i; j < n; j++) {
            sum += nums[j];
            if (sum >= lower && sum <= upper) {
                count++;
            }
        }
    }
    
    return count;
}

int main() {
    vector<int> nums1 = {-2, 5, -1};
    cout << countRangeSum(nums1, -2, 2) << endl;
    
    vector<int> nums2 = {0};
    cout << countRangeSum(nums2, 0, 0) << endl;
    
    vector<int> nums3 = {1, 2, 3};
    cout << countRangeSum(nums3, 3, 5) << endl;
    
    vector<int> nums4 = {-1, -1, -1};
    cout << countRangeSum(nums4, -3, -1) << endl;
    
    vector<int> nums5 = {2147483647, -2147483648, -1, 0};
    cout << countRangeSum(nums5, -1, 0) << endl;
    
    return 0;
}
