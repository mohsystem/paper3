from flask import Flask, render_template_string, request, session
import secrets
import hmac
import re

app = Flask(__name__)
app.secret_key = secrets.token_hex(32)

user_settings = {
    'username': 'john_doe',
    'email': 'john@example.com',
    'theme': 'light'
}

def generate_csrf_token():
    if 'csrf_token' not in session:
        session['csrf_token'] = secrets.token_hex(32)
    return session['csrf_token']

def validate_csrf_token(token):
    return token and 'csrf_token' in session and hmac.compare_digest(session['csrf_token'], token)

def validate_input(value, max_length=100, required=True, field_name="Field"):
    if required and not value:
        return False, f"{field_name} is required"
    if value and len(value) > max_length:
        return False, f"{field_name} must be less than {max_length} characters"
    if value and not re.match(r'^[a-zA-Z0-9@._-]+$', value):
        return False, f"{field_name} contains invalid characters"
    return True, None

@app.route('/', methods=['GET', 'POST'])
def update_settings():
    if request.method == 'POST':
        csrf_token = request.form.get('csrf_token')
        if not validate_csrf_token(csrf_token):
            return "CSRF token validation failed", 403
        
        username = request.form.get('username', '').strip()
        email = request.form.get('email', '').strip()
        theme = request.form.get('theme', '').strip()
        
        valid, error = validate_input(username, 50, True, "Username")
        if not valid:
            return f"Username error: {error}", 400
        
        valid, error = validate_input(email, 100, True, "Email")
