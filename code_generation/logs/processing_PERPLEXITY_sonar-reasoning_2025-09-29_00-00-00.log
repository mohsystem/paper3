def distinct_echo_substrings(text: str) -> int:
    if not isinstance(text, str) or len(text) < 1 or len(text) > 2000:
        raise ValueError("Invalid input")
    
    result = set()
    n = len(text)
    
    # Check all possible substrings with even length
    for i in range(n):
        for j in range(i + 2, n + 1, 2):  # step by 2 ensures even length
            substring = text[i:j]
            length = len(substring)
            half = length // 2
            
            first_half = substring[:half]
            second_half = substring[half:]
            
            if first_half == second_half:
                result.add(substring)
    
    return len(result)

def main():
    # Test cases
    print(distinct_echo_substrings("abcabcabc"))  # Expected: 3
    print(distinct_echo_substrings("leetcodeleetcode"))  # Expected: 2
    print(distinct_echo_substrings("aa"))  # Expected: 1
    print(distinct_echo_substrings("abab"))  # Expected: 1
    print(distinct_echo_substrings("a"))  # Expected: 0

if __name__ == "__main__":
    main()
