```python
import secrets
from typing import Optional, Set

class Robot:
    _used_names: Set[str] = set()
    
    def __init__(self) -> None:
        self._name: Optional[str] = None
    
    def get_name(self) -> str:
        if self._name is None:
            self._name = self._generate_unique_name()
        return self._name
    
    def reset(self) -> None:
        if self._name is not None:
            Robot._used_names.discard(self._name)
            self._name = None
    
    @classmethod
    def _generate_unique_name(cls) -> str:
        while True:
            letters = ''.join(secrets.choice('ABCDEFGHIJKLMNOPQRSTUVWXYZ') for _ in range(2))
            digits = ''.join(str(secrets.randbelow(10)) for _ in range(3))
            name = letters + digits
            
            if name not in cls._used_names:
                cls._used_names.add(name)
                return name

def main() -> None:
    robot1 = Robot()
    robot2 = Robot()
    robot3 = Robot()
    robot4 = Robot()
    robot5 = Robot()
    
    print(f"Robot 1: {robot1.get_name()}")
    print(f"Robot 2: {robot2.get_name()}")
    print(f"Robot 3: {robot3.get_name()}")
    print(f"Robot 4: {robot4.get_name()}")
    print(f"Robot 5: {robot5.get_name()}")
    
    robot1.reset()
    print(f"Robot 1 after reset: {robot1.get_name()}")

if __name__ == "__main__":
    main()
