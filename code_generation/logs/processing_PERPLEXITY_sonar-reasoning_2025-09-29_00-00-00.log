```cpp
#include <iostream>
#include <thread>
#include <mutex>
#include <condition_variable>
#include <functional>
#include <stdexcept>

class ZeroEvenOdd {
private:
    int n;
    std::mutex mtx;
    std::condition_variable cv;
    int state; // 0: zero's turn, 1: odd's turn, 2: even's turn
    int current_num;

public:
    ZeroEvenOdd(int n) {
        if (n < 1 || n > 1000) {
            throw std::invalid_argument("n must be between 1 and 1000");
        }
        this->n = n;
        this->state = 0;
        this->current_num = 1;
    }
    
    void zero(std::function<void(int)> printNumber) {
        for (int i = 0; i < n; i++) {
            std::unique_lock<std::mutex> lock(mtx);
            cv.wait(lock, [this] { return state == 0; });
            
            printNumber(0);
            
            if (current_num % 2 == 1) {
                state = 1; // odd's turn
            } else {
                state = 2; // even's turn
            }
            cv.notify_all();
        }
    }
    
    void even(std::function<void(int)> printNumber) {
        for (int i = 2; i <= n; i += 2) {
            std::unique_lock<std::mutex> lock(mtx);
            cv.wait(lock, [this, i] { return state == 2 && current_num == i; });
            
            printNumber(current_num);
            current_num++;
            state = 0; // zero's turn
            cv.notify_all();
        }
    }
    
    void odd(std::function<void(int)> printNumber) {
        for (int i = 1; i <= n; i += 2) {
            std::unique_lock<std::mutex> lock(mtx);
            cv.wait(lock, [this, i] { return state == 1 && current_num == i; });
            
            printNumber(current_num);
            current_num++;
            state = 0; // zero's turn
            cv.notify_all();
        }
    }
};

int main() {
    int test_cases[] = {2, 5, 1, 3, 4};
    
    for (int n : test_cases) {
        std::cout << "Test case n = " << n << ":\n";
        ZeroEvenOdd zeo(n);
        
        std::thread t1([&zeo](){ zeo.zero([](int x){ std::cout << x; }); });
        std::thread t2([&zeo](){ zeo.even([](int x){ std::cout << x; }); });
        std::thread t3([&zeo](){ zeo.odd([](int x){ std::cout << x; }); });
        
        t1.join();
        t2.join();
        t3.join();
        
        std::cout << std::endl;
    }
    
    return 0;
}
