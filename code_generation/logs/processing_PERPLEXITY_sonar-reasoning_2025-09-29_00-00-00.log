```python
def count_range_sum(nums, lower, upper):
    if not nums or lower > upper:
        return 0
    
    count = 0
    n = len(nums)
    
    for i in range(n):
        sum_val = 0
        for j in range(i, n):
            sum_val += nums[j]
            if lower <= sum_val <= upper:
                count += 1
    
    return count

def main():
    nums1 = [-2, 5, -1]
    print(count_range_sum(nums1, -2, 2))
    
    nums2 = [0]
    print(count_range_sum(nums2, 0, 0))
    
    nums3 = [1, 2, 3]
    print(count_range_sum(nums3, 3, 5))
    
    nums4 = [-1, -1, -1]
    print(count_range_sum(nums4, -3, -1))
    
    nums5 = [2147483647, -2147483648, -1, 0]
    print(count_range_sum(nums5, -1, 0))

if __name__ == "__main__":
    main()
