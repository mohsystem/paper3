char* longestDupSubstring(const char* s) {
    if (!s) {
        char* result = malloc(1);
        if (result) result[0] = '\0';
        return result;
    }
    
    size_t n = strlen(s);
    if (n < 2 || n > 30000) {
        char* result = malloc(1);
        if (result) result[0] = '\0';
        return result;
    }
    
    for (int len = (int)n - 1; len >= 1; len--) {
        for (int i = 0; i <= (int)n - len; i++) {
            for (int j = i + 1; j <= (int)n - len; j++) {
                if (strncmp(s + i, s + j, len) == 0) {
                    char* result = malloc(len + 1);
                    if (result) {
                        strncpy(result, s + i, len);
                        result[len] = '\0';
                        return result;
                    }
                }
            }
        }
    }
    
    char* result = malloc(1);
    if (result) result[0] = '\0';
    return result;
}

int main() {
    char* result;
    
    result = longestDupSubstring("banana");
    printf("\"%s\"\n", result);
    free(result);
    
    result = longestDupSubstring("abcd");
    printf("\"%s\"\n", result);
    free(result);
    
    result = longestDupSubstring("aa");
    printf("\"%s\"\n", result);
    free(result);
    
    result = longestDupSubstring("abcabcbb");
    printf("\"%s\"\n", result);
    free(result);
    
    result = longestDupSubstring("a");
    printf("\"%s\"\n", result);
    free(result);
    
    return 0;
}
