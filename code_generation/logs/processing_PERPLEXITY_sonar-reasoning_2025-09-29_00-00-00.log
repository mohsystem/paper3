```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* dnaComplement(const char* dna) {
    if (dna == NULL) {
        fprintf(stderr, "DNA string cannot be NULL\n");
        return NULL;
    }
    
    size_t len = strlen(dna);
    if (len == 0) {
        fprintf(stderr, "DNA string cannot be empty\n");
        return NULL;
    }
    
    // Validate input contains only valid DNA characters
    for (size_t i = 0; i < len; i++) {
        if (dna[i] != 'A' && dna[i] != 'T' && dna[i] != 'C' && dna[i] != 'G') {
            fprintf(stderr, "Invalid DNA character: %c\n", dna[i]);
            return NULL;
        }
    }
    
    char* complement = malloc(len + 1);
    if (complement == NULL) {
        fprintf(stderr, "Memory allocation failed\n");
        return NULL;
    }
    
    for (size_t i = 0; i < len; i++) {
        switch (dna[i]) {
            case 'A':
                complement[i] = 'T';
                break;
            case 'T':
                complement[i] = 'A';
                break;
            case 'C':
                complement[i] = 'G';
                break;
            case 'G':
                complement[i] = 'C';
                break;
        }
    }
    complement[len] = '\0';
    
    return complement;
}

int main() {
    // Test case 1
    const char* test1 = "ATTGC";
    char* result1 = dnaComplement(test1);
    if (result1) {
        printf("%s -> %s\n", test1, result1);
        free(result1);
    }
    
    // Test case 2
    const char* test2 = "GTAT";
    char* result2 = dnaComplement(test2);
    if (result2) {
        printf("%s -> %s\n", test2, result2);
        free(result2);
    }
    
    // Test case 3
    const char* test3 = "AAAA";
    char* result3 = dnaComplement(test3);
    if (result3) {
        printf("%s -> %s\n", test3, result3);
        free(result3);
    }
    
    // Test case 4
    const char* test4 = "CCGG";
    char* result4 = dnaComplement(test4);
    if (result4) {
        printf("%s -> %s\n", test4, result4);
        free(result4);
    }
    
    // Test case 5
    const char* test5 = "ATCGATCG";
    char* result5 = dnaComplement(test5);
    if (result5) {
        printf("%s -> %s\n", test5, result5);
        free(result5);
    }
    
    return 0;
}
