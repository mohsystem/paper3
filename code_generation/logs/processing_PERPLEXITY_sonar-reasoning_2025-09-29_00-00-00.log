```python
def longest_valid_parentheses(s: str) -> int:
    if not s or len(s) <= 1:
        return 0
    
    n = len(s)
    dp = [0] * n
    max_len = 0
    
    for i in range(1, n):
        if s[i] == ')':
            if s[i - 1] == '(':
                dp[i] = (dp[i - 2] if i >= 2 else 0) + 2
            elif dp[i - 1] > 0:
                match_index = i - dp[i - 1] - 1
                if match_index >= 0 and s[match_index] == '(':
                    dp[i] = dp[i - 1] + 2 + (dp[match_index - 1] if match_index > 0 else 0)
        
        max_len = max(max_len, dp[i])
    
    return max_len

if __name__ == "__main__":
    print(longest_valid_parentheses("(()"))     # 2
    print(longest_valid_parentheses(")()())"))  # 4
    print(longest_valid_parentheses(""))        # 0
    print(longest_valid_parentheses("()()"))    # 4
    print(longest_valid_parentheses("()(()"))   # 2
```

```cpp
#include <iostream>
#include <string>
#include <vector>
#include <algorithm>

int longestValidParentheses(const std::string& s) {
    if (s.empty() || s.length() <= 1) {
        return 0;
    }
    
    int n = s.length();
    std::vector<int> dp(n, 0);
    int maxLen = 0;
    
    for (int i = 1; i < n; i++) {
        if (s[i] == ')') {
            if (s[i - 1] == '(') {
                dp[i] = (i >= 2 ? dp[i - 2] : 0) + 2;
            } else if (dp[i - 1] > 0) {
                int matchIndex = i - dp[i - 1] - 1;
                if (matchIndex >= 0 && s[matchIndex] == '(') {
                    dp[i] = dp[i - 1] + 2 + (matchIndex > 0 ? dp[matchIndex - 1] : 0);
                }
            }
        }
        maxLen = std::max(maxLen, dp[i]);
    }
    
    return maxLen;
}

int main() {
    std::cout << longestValidParentheses("(()") << std::endl;     // 2
    std::cout << longestValidParentheses(")()())") << std::endl;  // 4
    std::cout << longestValidParentheses("") << std::endl;        // 0
    std::cout << longestValidParentheses("()()") << std::endl;    // 4
    std::cout << longestValidParentheses("()(()") << std::endl;   // 2
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int longestValidParentheses(const char* s) {
    if (s == NULL || strlen(s) <= 1) {
        return 0;
    }
    
    int n = strlen(s);
    int* dp = (int*)calloc(n, sizeof(int));
    if (dp == NULL) {
        return 0;
    }
    
    int maxLen = 0;
    
    for (int i = 1; i < n; i++) {
        if (s[i] == ')') {
            if (s[i - 1] == '(') {
                dp[i] = (i >= 2 ? dp[i - 2] : 0) + 2;
            } else if (dp[i - 1] > 0) {
                int matchIndex = i - dp[i - 1] - 1;
                if (matchIndex >= 0 && s[matchIndex] == '(') {
                    dp[i] = dp[i - 1] + 2 + (matchIndex > 0 ? dp[matchIndex - 1] : 0);
                }
            }
        }
        if (dp[i] > maxLen) {
            maxLen = dp[i];
        }
    }
    
    free(dp);
    return maxLen;
}

int main() {
    printf("%d\n", longestValidParentheses("(()"));     // 2
    printf("%d\n", longestValidParentheses(")()())"));  // 4
    printf("%d\n", longestValidParentheses(""));        // 0
    printf("%d\n", longestValidParentheses("()()"));    // 4
    printf("%d\n", longestValidParentheses("()(()"));   // 2
    return 0;
}
```
