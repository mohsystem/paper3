```java
public class Task33 {
    public static int queueTime(int[] customers, int n) {
        if (customers == null || n <= 0) {
            return 0;
        }
        
        int[] tills = new int[n];
        
        for (int customer : customers) {
            if (customer < 0) continue;
            
            int minTill = 0;
            for (int i = 1; i < n; i++) {
                if (tills[i] < tills[minTill]) {
                    minTill = i;
                }
            }
            
            tills[minTill] += customer;
        }
        
        int maxTime = 0;
        for (int tillTime : tills) {
            if (tillTime > maxTime) {
                maxTime = tillTime;
            }
        }
        
        return maxTime;
    }
    
    public static void main(String[] args) {
        System.out.println(queueTime(new int[]{5, 3, 4}, 1));
        System.out.println(queueTime(new int[]{10, 2, 3, 3}, 2));
        System.out.println(queueTime(new int[]{2, 3, 10}, 2));
        System.out.println(queueTime(new int[]{}, 3));
        System.out.println(queueTime(new int[]{1, 2, 3, 4, 5}, 3));
    }
}
```

```python
def queue_time(customers, n):
    if not customers or n <= 0:
        return 0
    
    tills = [0] * n
    
    for customer in customers:
        if customer < 0:
            continue
        
        min_till = 0
        for i in range(1, n):
            if tills[i] < tills[min_till]:
                min_till = i
        
        tills[min_till] += customer
    
    return max(tills) if tills else 0

def main():
    print(queue_time([5, 3, 4], 1))
    print(queue_time([10, 2, 3, 3], 2))
    print(queue_time([2, 3, 10], 2))
    print(queue_time([], 3))
    print(queue_time([1, 2, 3, 4, 5], 3))

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <vector>
#include <algorithm>

int queueTime(const std::vector<int>& customers, int n) {
    if (customers.empty() || n <= 0) {
        return 0;
    }
    
    std::vector<int> tills(n, 0);
    
    for (int customer : customers) {
        if (customer < 0) continue;
        
        int minTill = 0;
        for (int i = 1; i < n; i++) {
            if (tills[i] < tills[minTill]) {
                minTill = i;
            }
        }
        
        tills[minTill] += customer;
    }
    
    return *std::max_element(tills.begin(), tills.end());
}

int main() {
    std::cout << queueTime({5, 3, 4}, 1) << std::endl;
    std::cout << queueTime({10, 2, 3, 3}, 2) << std::endl;
    std::cout << queueTime({2, 3, 10}, 2) << std::endl;
    std::cout << queueTime({}, 3) << std::endl;
    std::cout << queueTime({1, 2, 3, 4, 5}, 3) << std::endl;
    return 0;
}
```

```c
#include <stdio.h>
#include <stdlib.h>

int queueTime(int* customers, int customerCount, int n) {
    if (customers == NULL || customerCount <= 0 || n <= 0) {
        return 0;
    }
    
    int* tills = (int*)calloc(n, sizeof(int));
    if (tills == NULL) {
        return 0;
    }
    
    for (int i = 0; i < customerCount; i++) {
        if (customers[i] < 0) continue;
        
        int minTill = 0;
        for (int j = 1; j < n; j++) {
            if (tills[j] < tills[minTill]) {
                minTill = j;
            }
        }
        
        tills[minTill] += customers[i];
    }
    
    int maxTime = 0;
    for (int i = 0; i < n; i++) {
        if (tills[i] > maxTime) {
            maxTime = tills[i];
        }
    }
    
    free(tills);
    return maxTime;
}

int main() {
    int test1[] = {5, 3, 4};
    printf("%d\n", queueTime(test1, 3, 1));
    
    int test2[] = {10, 2, 3, 3};
    printf("%d\n", queueTime(test2, 4, 2));
    
    int test3[] = {2, 3, 10};
    printf("%d\n", queueTime(test3, 3, 2));
    
    printf("%d\n", queueTime(NULL, 0, 3));
    
    int test5[] = {1, 2, 3, 4, 5};
    printf("%d\n", queueTime(test5, 5, 3));
    
    return 0;
}
```
