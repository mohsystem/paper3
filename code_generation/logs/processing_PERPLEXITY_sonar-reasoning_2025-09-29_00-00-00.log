def calculate_years(principal: float, interest: float, tax: float, desired: float) -> int:
    # Input validation
    if principal < 0 or interest < 0 or tax < 0 or tax >= 1 or desired < 0:
        raise ValueError("Invalid input parameters")
    if any(x != x for x in [principal, interest, tax, desired]):  # Check for NaN
        raise ValueError("Parameters cannot be NaN")
    if any(x == float('inf') or x == float('-inf') for x in [principal, interest, tax, desired]):
        raise ValueError("Parameters cannot be infinite")
    
    if principal >= desired:
        return 0
    
    years = 0
    current_principal = principal
    
    while current_principal < desired:
        yearly_interest = current_principal * interest
        tax_on_interest = yearly_interest * tax
        net_interest = yearly_interest - tax_on_interest
        current_principal += net_interest
        years += 1
        
        # Prevent infinite loop
        if years > 10000:
            raise RuntimeError("Calculation exceeded maximum iterations")
    
    return years

def main():
