    result2 = max_sliding_window(nums2, k2)
    print(f"Test 2: {result2}")
    
    nums3 = [1,3,1,2,0,5]
    k3 = 3
    result3 = max_sliding_window(nums3, k3)
    print(f"Test 3: {result3}")
    
