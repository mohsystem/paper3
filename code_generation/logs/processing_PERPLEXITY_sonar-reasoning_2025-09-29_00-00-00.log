import java.net.*;
import java.nio.ByteBuffer;
import java.util.HashMap;
import java.util.Map;

public class Task91 {
    private static final int DNS_HEADER_SIZE = 12;
    private static final int MAX_PACKET_SIZE = 512;
    private static final Map<String, String> DNS_RECORDS = new HashMap<>();
    
    static {
        DNS_RECORDS.put("example.com", "93.184.216.34");
        DNS_RECORDS.put("google.com", "142.250.191.14");
        DNS_RECORDS.put("localhost", "127.0.0.1");
    }
    
    public static void createDnsServer(String address, int port) {
        if (port < 1 || port > 65535) {
            throw new IllegalArgumentException("Invalid port number");
        }
        
        try (DatagramSocket socket = new DatagramSocket(port, InetAddress.getByName(address))) {
            System.out.println("DNS Server listening on " + address + ":" + port);
            
            while (true) {
                byte[] buffer = new byte[MAX_PACKET_SIZE];
                DatagramPacket packet = new DatagramPacket(buffer, buffer.length);
                
                socket.receive(packet);
                
                byte[] response = processDnsQuery(packet.getData(), packet.getLength());
                if (response != null) {
                    DatagramPacket responsePacket = new DatagramPacket(
                        response, response.length, packet.getAddress(), packet.getPort());
                    socket.send(responsePacket);
                }
            }
        } catch (Exception e) {
            System.err.println("DNS Server error: " + e.getMessage());
        }
    }
    
    private static byte[] processDnsQuery(byte[] data, int length) {
        if (length < DNS_HEADER_SIZE) {
            return null;
        }
        
        ByteBuffer buffer = ByteBuffer.wrap(data, 0, length);
        
        short transactionId = buffer.getShort();
        short flags = buffer.getShort();
        short questionCount = buffer.getShort();
        buffer.getShort(); // answerCount
        buffer.getShort(); // authorityCount
        buffer.getShort(); // additionalCount
        
        if (questionCount != 1) {
            return null;
        }
        
        String domain = parseDomainName(buffer);
        if (domain == null || buffer.remaining() < 4) {
            return null;
        }
        
        short queryType = buffer.getShort();
        short queryClass = buffer.getShort();
        
        if (queryType != 1 || queryClass != 1) {
            return null;
        }
        
        String ipAddress = DNS_RECORDS.get(domain.toLowerCase());
        if (ipAddress == null) {
            return null;
        }
        
        return buildDnsResponse(transactionId, domain, ipAddress);
    }
    
    private static String parseDomainName(ByteBuffer buffer) {
        StringBuilder domain = new StringBuilder();
        int labelLength;
        
        while ((labelLength = buffer.get() & 0xFF) != 0) {
            if (labelLength > 63 || buffer.remaining() < labelLength) {
                return null;
            }
            
            if (domain.length() > 0) {
                domain.append('.');
            }
            
            for (int i = 0; i < labelLength; i++) {
                char c = (char) buffer.get();
                if (c < 32 || c > 126) {
                    return null;
                }
                domain.append(c);
            }
            
            if (domain.length() > 253) {
                return null;
            }
        }
        
        return domain.toString();
    }
    
    private static byte[] buildDnsResponse(short transactionId, String domain, String ipAddress) {
        try {
            ByteBuffer response = ByteBuffer.allocate(MAX_PACKET_SIZE);
            
            response.putShort(transactionId);
            response.putShort((short) 0x8180);
            response.putShort((short) 1);
            response.putShort((short) 1);
            response.putShort((short) 0);
            response.putShort((short) 0);
            
            encodeDomainName(response, domain);
            response.putShort((short) 1);
            response.putShort((short) 1);
            
            encodeDomainName(response, domain);
            response.putShort((short) 1);
            response.putShort((short) 1);
            response.putInt(300);
            response.putShort((short) 4);
            
            String[] ipParts = ipAddress.split("\\.");
            for (String part : ipParts) {
                response.put((byte) Integer.parseInt(part));
            }
            
            byte[] result = new byte[response.position()];
            response.rewind();
            response.get(result);
            return result;
        } catch (Exception e) {
            return null;
        }
    }
    
    private static void encodeDomainName(ByteBuffer buffer, String domain) {
        String[] labels = domain.split("\\.");
        for (String label : labels) {
            byte[] labelBytes = label.getBytes(java.nio.charset.StandardCharsets.UTF_8);
            buffer.put((byte) labelBytes.length);
            buffer.put(labelBytes);
        }
        buffer.put((byte) 0);
    }
    
    public static void main(String[] args) {
        System.out.println("DNS Server Test Cases:");
        System.out.println("1. Server listens on 127.0.0.1:5353");
        System.out.println("2. Supports A records for example.com, google.com, localhost");
        System.out.println("3. Test with: dig @127.0.0.1 -p 5353 example.com");
        System.out.println("4. Handles malformed packets gracefully");
        System.out.println("5. Validates all input data with bounds checking");
        
        createDnsServer("127.0.0.1", 5353);
    }
}
