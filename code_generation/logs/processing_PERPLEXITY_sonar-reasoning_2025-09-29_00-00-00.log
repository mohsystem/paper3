```c
#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>

typedef struct {
    double radius;
    double x_center;
    double y_center;
} Solution;

Solution* createSolution(double radius, double x_center, double y_center) {
    if (radius <= 0) {
        fprintf(stderr, "Error: Radius must be positive\n");
        return NULL;
    }
    
    Solution* sol = (Solution*)malloc(sizeof(Solution));
    if (sol == NULL) {
        fprintf(stderr, "Error: Memory allocation failed\n");
        return NULL;
    }
    
    sol->radius = radius;
    sol->x_center = x_center;
    sol->y_center = y_center;
    
    return sol;
}

void randPoint(Solution* sol, double* result) {
    if (sol == NULL || result == NULL) {
        return;
    }
    
    double r = sqrt((double)rand() / RAND_MAX) * sol->radius;
    double theta = ((double)rand() / RAND_MAX) * 2 * M_PI;
    
    result = sol->x_center + r * cos(theta);
    result[1] = sol->y_center + r * sin(theta);
}

void freeSolution(Solution* sol) {
    if (sol != NULL) {
        free(sol);
    }
}

int main() {
    srand((unsigned int)time(NULL));
    
    double point[2];
    
    Solution* sol1 = createSolution(1.0, 0.0, 0.0);
    if (sol1 != NULL) {
        randPoint(sol1, point);
        printf("Test 1: [%.5f, %.5f]\n", point, point[1]);
        freeSolution(sol1);
    }
    
    Solution* sol2 = createSolution(2.0, 1.0, 1.0);
    if (sol2 != NULL) {
        randPoint(sol2, point);
        printf("Test 2: [%.5f, %.5f]\n", point, point[1]);
        freeSolution(sol2);
    }
    
    Solution* sol3 = createSolution(0.5, -1.0, -1.0);
