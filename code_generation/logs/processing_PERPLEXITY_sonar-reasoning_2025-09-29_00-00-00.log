```java
import java.util.*;

public class Task180 {
    public static Map<Integer, List<Integer>> reparentTree(Map<Integer, List<Integer>> tree, int newRoot) {
        if (tree == null || tree.isEmpty() || !tree.containsKey(newRoot)) {
            return new HashMap<>();
        }
        
        Map<Integer, List<Integer>> result = new HashMap<>();
        Set<Integer> visited = new HashSet<>();
        Queue<Integer> queue = new LinkedList<>();
        
        // Initialize result map
        for (int node : tree.keySet()) {
            result.put(node, new ArrayList<>());
        }
        
        queue.offer(newRoot);
        visited.add(newRoot);
        
        while (!queue.isEmpty()) {
            int current = queue.poll();
            
            if (tree.containsKey(current)) {
                List<Integer> neighbors = tree.get(current);
                if (neighbors != null) {
                    for (int neighbor : neighbors) {
                        if (!visited.contains(neighbor)) {
                            visited.add(neighbor);
                            result.get(current).add(neighbor);
                            queue.offer(neighbor);
                        }
                    }
                }
            }
        }
        
        return result;
    }
    
    public static void main(String[] args) {
        // Test case 1: Example from problem
        Map<Integer, List<Integer>> tree1 = new HashMap<>();
        tree1.put(0, Arrays.asList(1, 2, 3));
        tree1.put(1, Arrays.asList(0, 4, 5));
        tree1.put(2, Arrays.asList(0, 6, 7));
        tree1.put(3, Arrays.asList(0, 8, 9));
        tree1.put(4, Arrays.asList(1));
        tree1.put(5, Arrays.asList(1));
        tree1.put(6, Arrays.asList(2));
        tree1.put(7, Arrays.asList(2));
        tree1.put(8, Arrays.asList(3));
        tree1.put(9, Arrays.asList(3));
        System.out.println("Test 1: " + reparentTree(tree1, 6));
        
        // Test case 2: Single node
        Map<Integer, List<Integer>> tree2 = new HashMap<>();
        tree2.put(1, new ArrayList<>());
        System.out.println("Test 2: " + reparentTree(tree2, 1));
        
        // Test case 3: Two nodes
        Map<Integer, List<Integer>> tree3 = new HashMap<>();
        tree3.put(1, Arrays.asList(2));
        tree3.put(2, Arrays.asList(1));
        System.out.println("Test 3: " + reparentTree(tree3, 2));
        
        // Test case 4: Empty tree
        System.out.println("Test 4: " + reparentTree(new HashMap<>(), 1));
        
        // Test case 5: Linear tree
        Map<Integer, List<Integer>> tree5 = new HashMap<>();
        tree5.put(1, Arrays.asList(2));
        tree5.put(2, Arrays.asList(1, 3));
        tree5.put(3, Arrays.asList(2, 4));
        tree5.put(4, Arrays.asList(3));
        System.out.println("Test 5: " + reparentTree(tree5, 3));
    }
}
