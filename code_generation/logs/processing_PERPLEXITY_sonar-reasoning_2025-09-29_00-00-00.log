```python
import sqlite3
import urllib.request
import urllib.parse
import ssl
import re
from typing import Optional
import contextlib

class WebScraper:
    def __init__(self, db_path: str = "scraped_data.db"):
        self.db_path = db_path
        self.max_content_length = 1048576  # 1MB
        self.timeout = 10
        self.url_pattern = re.compile(r'^https?://[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}(/.*)?$')
        self._create_table()
    
    def _create_table(self) -> None:
        with contextlib.closing(sqlite3.connect(self.db_path)) as conn:
            conn.execute('''CREATE TABLE IF NOT EXISTS scraped_data (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                url TEXT NOT NULL,
                title TEXT,
                content TEXT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
            )''')
            conn.commit()
    
    def is_valid_url(self, url: str) -> bool:
        if not url or len(url) > 2048:
            return False
        return bool(self.url_pattern.match(url))
    
    def scrape_website(self, url: str) -> str:
        if not self.is_valid_url(url):
            raise ValueError("Invalid URL format")
        
        # Create SSL context with verification
        ssl_context = ssl.create_default_context()
        ssl_context.check_hostname = True
        ssl_context.verify_mode = ssl.CERT_REQUIRED
        
        request = urllib.request.Request(
            url,
            headers={'User-Agent': 'WebScraper/1.0'}
        )
        
        with urllib.request.urlopen(request, timeout=self.timeout, context=ssl_context) as response:
            if response.code != 200:
                raise RuntimeError(f"HTTP {response.code}")
            
            content_length = response.getheader('Content-Length')
            if content_length and int(content_length) > self.max_content_length:
                raise RuntimeError("Content too large")
            
            content = b""
            while True:
                chunk = response.read(8192)
                if not chunk:
                    break
                content += chunk
                if len(content) > self.max_content_length:
                    raise RuntimeError("Content too large")
            
            return content.decode('utf-8', errors='replace')
    
    def store_data(self, url: str, content: str) -> None:
        title = self._extract_title(content)
        clean_content = self._sanitize_content(content)
        
        with contextlib.closing(sqlite3.connect(self.db_path)) as conn:
            conn.execute(
                "INSERT INTO scraped_data (url, title, content) VALUES (?, ?, ?)",
                (url, title, clean_content)
            )
            conn.commit()
    
    def _extract_title(self, html: str) -> str:
        if not html:
            return ""
        match = re.search(r'<title[^>]*>(.*?)</title>', html, re.IGNORECASE | re.DOTALL)
        if match:
            title = match.group(1).strip()
            return title[:200] if len(title) > 200 else title
        return ""
    
    def _sanitize_content(self, content: str) -> str:
        if not content:
            return ""
        # Remove scripts and styles
        content = re.sub(r'<script[^>]*>.*?</script>', '', content, flags=re.IGNORECASE | re.DOTALL)
        content = re.sub(r'<style[^>]*>.*?</style>', '', content, flags=re.IGNORECASE | re.DOTALL)
        # Remove HTML tags
        content = re.sub(r'<[^>]+>', '', content)
        return content[:10000] if len(content) > 10000 else content

def main():
    scraper = WebScraper()
    
    test_urls = [
        "https://httpbin.org/html",
        "https://example.com",
        "https://httpbin.org/json",
        "https://www.google.com",
        "https://github.com"
    ]
    
    for url in test_urls:
        try:
            content = scraper.scrape_website(url)
            scraper.store_data(url, content)
            print(f"Successfully scraped: {url}")
        except Exception as e:
            print(f"Failed to scrape {url}: {e}")

if __name__ == "__main__":
    main()
