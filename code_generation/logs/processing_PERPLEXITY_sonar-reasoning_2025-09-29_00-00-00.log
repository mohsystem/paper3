```java
public class Task199 {
    static class Clock {
        private int hours;
        private int minutes;
        private int seconds;
        
        public Clock(int hours, int minutes, int seconds) {
            if (hours < 0 || hours > 23) {
                throw new IllegalArgumentException("Hours must be between 0-23");
            }
            if (minutes < 0 || minutes > 59) {
                throw new IllegalArgumentException("Minutes must be between 0-59");
            }
            if (seconds < 0 || seconds > 59) {
                throw new IllegalArgumentException("Seconds must be between 0-59");
            }
            this.hours = hours;
            this.minutes = minutes;
            this.seconds = seconds;
        }
        
        public Clock addMinutes(int minutesToAdd) {
            if (minutesToAdd < -1440 || minutesToAdd > 1440) {
                throw new IllegalArgumentException("Minutes to add must be between -1440 and 1440");
            }
            int totalMinutes = this.hours * 60 + this.minutes + minutesToAdd;
            totalMinutes = ((totalMinutes % 1440) + 1440) % 1440;
            int newHours = totalMinutes / 60;
            int newMinutes = totalMinutes % 60;
            return new Clock(newHours, newMinutes, this.seconds);
        }
        
        public Clock subtractMinutes(int minutesToSubtract) {
            return addMinutes(-minutesToSubtract);
        }
        
        @Override
        public boolean equals(Object obj) {
            if (this == obj) return true;
            if (obj == null || getClass() != obj.getClass()) return false;
            Clock clock = (Clock) obj;
            return hours == clock.hours && minutes == clock.minutes && seconds == clock.seconds;
        }
        
        @Override
        public int hashCode() {
            return hours * 3600 + minutes * 60 + seconds;
        }
        
        @Override
        public String toString() {
            return String.format("%02d:%02d:%02d", hours, minutes, seconds);
        }
    }
    
    public static void main(String[] args) {
        try {
            Clock clock1 = new Clock(10, 30, 45);
            Clock clock2 = new Clock(10, 30, 45);
            System.out.println("Test 1 - Equal clocks: " + clock1.equals(clock2));
            
            Clock clock3 = clock1.addMinutes(30);
            System.out.println("Test 2 - Add 30 minutes: " + clock3);
            
            Clock clock4 = clock1.subtractMinutes(45);
            System.out.println("Test 3 - Subtract 45 minutes: " + clock4);
            
            Clock clock5 = new Clock(23, 45, 0).addMinutes(30);
            System.out.println("Test 4 - Wrap around midnight: " + clock5);
            
            Clock clock6 = new Clock(0, 15, 0).subtractMinutes(30);
            System.out.println("Test 5 - Wrap around backwards: " + clock6);
        } catch (Exception e) {
            System.err.println("Error: " + e.getMessage());
        }
    }
}
```

```python
class Clock:
    def __init__(self, hours: int, minutes: int, seconds: int):
        if not (0 <= hours <= 23):
            raise ValueError("Hours must be between 0-23")
        if not (0 <= minutes <= 59):
            raise ValueError("Minutes must be between 0-59")
        if not (0 <= seconds <= 59):
            raise ValueError("Seconds must be between 0-59")
        self.hours = hours
        self.minutes = minutes
        self.seconds = seconds
    
    def add_minutes(self, minutes_to_add: int) -> 'Clock':
        if not (-1440 <= minutes_to_add <= 1440):
            raise ValueError("Minutes to add must be between -1440 and 1440")
        total_minutes = self.hours * 60 + self.minutes + minutes_to_add
        total_minutes = ((total_minutes % 1440) + 1440) % 1440
        new_hours = total_minutes // 60
        new_minutes = total_minutes % 60
        return Clock(new_hours, new_minutes, self.seconds)
    
    def subtract_minutes(self, minutes_to_subtract: int) -> 'Clock':
        return self.add_minutes(-minutes_to_subtract)
    
    def __eq__(self, other) -> bool:
        if not isinstance(other, Clock):
            return False
        return (self.hours == other.hours and 
                self.minutes == other.minutes and 
                self.seconds == other.seconds)
    
    def __hash__(self) -> int:
        return self.hours * 3600 + self.minutes * 60 + self.seconds
    
    def __str__(self) -> str:
        return f"{self.hours:02d}:{self.minutes:02d}:{self.seconds:02d}"

def main():
    try:
        clock1 = Clock(10, 30, 45)
        clock2 = Clock(10, 30, 45)
        print(f"Test 1 - Equal clocks: {clock1 == clock2}")
        
        clock3 = clock1.add_minutes(30)
        print(f"Test 2 - Add 30 minutes: {clock3}")
        
        clock4 = clock1.subtract_minutes(45)
        print(f"Test 3 - Subtract 45 minutes: {clock4}")
        
        clock5 = Clock(23, 45, 0).add_minutes(30)
        print(f"Test 4 - Wrap around midnight: {clock5}")
        
        clock6 = Clock(0, 15, 0).subtract_minutes(30)
        print(f"Test 5 - Wrap around backwards: {clock6}")
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <iomanip>
#include <stdexcept>
#include <sstream>

class Clock {
private:
    int hours;
    int minutes;
    int seconds;
    
public:
    Clock(int h, int m, int s) : hours(h), minutes(m), seconds(s) {
        if (h < 0 || h > 23) {
            throw std::invalid_argument("Hours must be between 0-23");
        }
        if (m < 0 || m > 59) {
            throw std::invalid_argument("Minutes must be between 0-59");
        }
        if (s < 0 || s > 59) {
            throw std::invalid_argument("Seconds must be between 0-59");
        }
    }
    
    Clock addMinutes(int minutesToAdd) const {
        if (minutesToAdd < -1440 || minutesToAdd > 1440) {
            throw std::invalid_argument("Minutes to add must be between -1440 and 1440");
        }
        int totalMinutes = hours * 60 + minutes + minutesToAdd;
        totalMinutes = ((totalMinutes % 1440) + 1440) % 1440;
        int newHours = totalMinutes / 60;
        int newMinutes = totalMinutes % 60;
        return Clock(newHours, newMinutes, seconds);
    }
    
    Clock subtractMinutes(int minutesToSubtract) const {
        return addMinutes(-minutesToSubtract);
    }
    
    bool operator==(const Clock& other) const {
        return hours == other.hours && minutes == other.minutes && seconds == other.seconds;
    }
    
    bool operator!=(const Clock& other) const {
        return !(*this == other);
    }
    
    std::string toString() const {
        std::ostringstream oss;
        oss << std::setfill('0') << std::setw(2) << hours << ":"
            << std::setfill('0') << std::setw(2) << minutes << ":"
            << std::setfill('0') << std::setw(2) << seconds;
        return oss.str();
    }
};

int main() {
    try {
        Clock clock1(10, 30, 45);
        Clock clock2(10, 30, 45);
        std::cout << "Test 1 - Equal clocks: " << (clock1 == clock2 ? "true" : "false") << std::endl;
        
        Clock clock3 = clock1.addMinutes(30);
        std::cout << "Test 2 - Add 30 minutes: " << clock3.toString() << std::endl;
        
        Clock clock4 = clock1.subtractMinutes(45);
        std::cout << "Test 3 - Subtract 45 minutes: " << clock4.toString() << std::endl;
        
        Clock clock5 = Clock(23, 45, 0).addMinutes(30);
        std::cout << "Test 4 - Wrap around midnight: " << clock5.toString() << std::endl;
        
        Clock clock6 = Clock(0, 15, 0).subtractMinutes(30);
        std::cout << "Test 5 - Wrap around backwards: " << clock6.toString() << std::endl;
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    return 0;
}
