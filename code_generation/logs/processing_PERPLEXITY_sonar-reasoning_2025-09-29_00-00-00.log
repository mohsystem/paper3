import java.util.*;

public class Task180 {
    public static Map<Integer, List<Integer>> reparentTree(Map<Integer, List<Integer>> tree, int newRoot) {
        if (tree == null || tree.isEmpty()) {
            return new HashMap<>();
        }
        
        if (!tree.containsKey(newRoot)) {
            throw new IllegalArgumentException("New root not found in tree");
        }
        
        Map<Integer, List<Integer>> result = new HashMap<>();
        Set<Integer> visited = new HashSet<>();
        
        // Initialize result map
        for (int node : tree.keySet()) {
            result.put(node, new ArrayList<>());
        }
        
        // DFS to build new tree from newRoot
        dfs(tree, result, visited, newRoot, -1);
        
        return result;
    }
    
    private static void dfs(Map<Integer, List<Integer>> original, Map<Integer, List<Integer>> result, 
                           Set<Integer> visited, int current, int parent) {
        visited.add(current);
        
        List<Integer> neighbors = original.get(current);
        if (neighbors != null) {
            for (int neighbor : neighbors) {
                if (!visited.contains(neighbor)) {
                    result.get(current).add(neighbor);
                    dfs(original, result, visited, neighbor, current);
                }
            }
        }
    }
    
    public static void main(String[] args) {
        // Test case 1: Simple tree
        Map<Integer, List<Integer>> tree1 = new HashMap<>();
