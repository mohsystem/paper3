public class Task170 {
    public static int countRangeSum(int[] nums, int lower, int upper) {
        // Input validation
        if (nums == null || nums.length == 0) {
            return 0;
        }
        if (lower > upper) {
            return 0;
        }
        
        int count = 0;
        int n = nums.length;
        
        for (int i = 0; i < n; i++) {
            long sum = 0; // Use long to prevent overflow
            for (int j = i; j < n; j++) {
                sum += nums[j];
                if (sum >= lower && sum <= upper) {
                    count++;
                }
            }
        }
        
        return count;
    }
    
    public static void main(String[] args) {
        // Test case 1
        int[] nums1 = {-2, 5, -1};
        System.out.println(countRangeSum(nums1, -2, 2)); // Expected: 3
        
        // Additional test cases cover edge scenarios
        int[] nums2 = {0};
