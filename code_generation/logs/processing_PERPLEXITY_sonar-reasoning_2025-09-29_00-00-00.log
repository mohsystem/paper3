#include <iostream>
#include <string>
#include <unordered_set>
#include <stdexcept>

int distinctEchoSubstrings(const std::string& text) {
    if (text.empty() || text.length() > 2000) {
        throw std::invalid_argument("Invalid input");
    }
    
    std::unordered_set<std::string> result;
    int n = text.length();
    
    // Check all possible substrings with even length
    for (int i = 0; i < n; i++) {
        for (int j = i + 2; j <= n; j += 2) { // j += 2 ensures even length
            std::string substring = text.substr(i, j - i);
            int len = substring.length();
            int half = len / 2;
            
            std::string firstHalf = substring.substr(0, half);
            std::string secondHalf = substring.substr(half, half);
            
            if (firstHalf == secondHalf) {
                result.insert(substring);
            }
        }
    }
    
    return result.size();
}

int main() {
    // Test cases
    std::cout << distinctEchoSubstrings("abcabcabc") << std::endl; // Expected: 3
    std::cout << distinctEchoSubstrings("leetcodeleetcode") << std::endl; // Expected: 2
    std::cout << distinctEchoSubstrings("aa") << std::endl; // Expected: 1
    std::cout << distinctEchoSubstrings("abab") << std::endl; // Expected: 1
    std::cout << distinctEchoSubstrings("a") << std::endl; // Expected: 0
    
    return 0;
}
