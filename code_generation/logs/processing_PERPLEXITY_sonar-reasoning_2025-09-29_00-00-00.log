```java
import java.util.*;

public class Task173 {
    public static String longestDupSubstring(String s) {
        if (s == null || s.length() < 2 || s.length() > 30000) {
            return "";
        }
        
        int n = s.length();
        
        for (int len = n - 1; len >= 1; len--) {
            Set<String> seen = new HashSet<>();
            
            for (int i = 0; i <= n - len; i++) {
                String sub = s.substring(i, i + len);
                if (seen.contains(sub)) {
                    return sub;
                }
                seen.add(sub);
            }
        }
        
        return "";
    }
    
    public static void main(String[] args) {
        System.out.println("\"" + longestDupSubstring("banana") + "\"");
        System.out.println("\"" + longestDupSubstring("abcd") + "\"");
        System.out.println("\"" + longestDupSubstring("aa") + "\"");
        System.out.println("\"" + longestDupSubstring("abcabcbb") + "\"");
        System.out.println("\"" + longestDupSubstring("a") + "\"");
    }
}
```

```python
def longest_dup_substring(s: str) -> str:
    if not s or len(s) < 2 or len(s) > 30000:
        return ""
    
    n = len(s)
    
    for length in range(n - 1, 0, -1):
        seen = set()
        
        for i in range(n - length + 1):
            sub = s[i:i + length]
            if sub in seen:
                return sub
            seen.add(sub)
    
    return ""

def main():
    print(f'"{longest_dup_substring("banana")}"')
    print(f'"{longest_dup_substring("abcd")}"')
    print(f'"{longest_dup_substring("aa")}"')
    print(f'"{longest_dup_substring("abcabcbb")}"')
    print(f'"{longest_dup_substring("a")}"')

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <string>
#include <unordered_set>

std::string longestDupSubstring(const std::string& s) {
    if (s.length() < 2 || s.length() > 30000) {
        return "";
    }
    
    int n = static_cast<int>(s.length());
    
    for (int len = n - 1; len >= 1; len--) {
        std::unordered_set<std::string> seen;
        
        for (int i = 0; i <= n - len; i++) {
            std::string sub = s.substr(i, len);
            if (seen.find(sub) != seen.end()) {
                return sub;
            }
            seen.insert(sub);
        }
    }
    
    return "";
}

int main() {
    std::cout << "\"" << longestDupSubstring("banana") << "\"" << std::endl;
    std::cout << "\"" << longestDupSubstring("abcd") << "\"" << std::endl;
    std::cout << "\"" << longestDupSubstring("aa") << "\"" << std::endl;
    std::cout << "\"" << longestDupSubstring("abcabcbb") << "\"" << std::endl;
    std::cout << "\"" << longestDupSubstring("a") << "\"" << std::endl;
    
    return 0;
}
```

