```python
import hashlib
import secrets
import base64
from typing import Dict, Optional

class PasswordStore:
    def __init__(self):
        self.user_database: Dict[str, str] = {}
        self.salt_length = 16
        self.hash_length = 32
        self.iterations = 210000
    
    def hash_password(self, username: str, password: str) -> str:
        if not username or not username.strip() or not password or len(password) < 8:
            raise ValueError("Invalid username or password")
        
        salt = secrets.token_bytes(self.salt_length)
        
        pwdhash = hashlib.pbkdf2_hmac('sha256', 
                                    password.encode('utf-8'), 
                                    salt, 
                                    self.iterations)
        
        salt_b64 = base64.b64encode(salt).decode('ascii')
        hash_b64 = base64.b64encode(pwdhash).decode('ascii')
        
        return f"{salt_b64}:{hash_b64}"
    
    def signup_user(self, username: str, password: str) -> bool:
        if username in self.user_database:
            return False
        
        try:
            hashed_password = self.hash_password(username, password)
            self.user_database[username] = hashed_password
            return True
        except ValueError:
            return False
    
    def verify_password(self, username: str, password: str) -> bool:
        stored = self.user_database.get(username)
        if not stored:
            return False
        
        try:
            parts = stored.split(':')
            if len(parts) != 2:
                return False
            
            salt = base64.b64decode(parts[0])
            stored_hash = base64.b64decode(parts[1])
            
            test_hash = hashlib.pbkdf2_hmac('sha256',
                                          password.encode('utf-8'),
                                          salt,
                                          self.iterations)
            
            return secrets.compare_digest(stored_hash, test_hash)
        except Exception:
            return False

def main():
    password_store = PasswordStore()
    
    # Test case 1: Valid signup
    print("Test 1:", password_store.signup_user("user1", "SecurePass123"))
    
    # Test case 2: Password verification
    print("Test 2:", password_store.verify_password("user1", "SecurePass123"))
    
    # Test case 3: Duplicate username
    print("Test 3:", password_store.signup_user("user1", "AnotherPass456"))
    
    # Test case 4: Invalid password verification
    print("Test 4:", password_store.verify_password("user1", "WrongPassword"))
    
    # Test case 5: Multiple users
    print("Test 5:", password_store.signup_user("user2", "MyPassword789"))

if __name__ == "__main__":
    main()
```

