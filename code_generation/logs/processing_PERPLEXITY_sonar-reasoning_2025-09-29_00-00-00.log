```python
def count_smaller(nums):
    if not nums:
        return []
    
    n = len(nums)
    counts = [0] * n
    
    for i in range(n):
        count = 0
        for j in range(i + 1, n):
            if nums[j] < nums[i]:
                count += 1
        counts[i] = count
    
    return counts

def main():
    # Test case 1
    nums1 = [5, 2, 6, 1]
    result1 = count_smaller(nums1)
    print(f"Test 1: {result1}")
    
    # Test case 2
    nums2 = [-1]
    result2 = count_smaller(nums2)
    print(f"Test 2: {result2}")
    
    # Test case 3
    nums3 = [-1, -1]
    result3 = count_smaller(nums3)
    print(f"Test 3: {result3}")
    
    # Test case 4
    nums4 = [1, 2, 3, 4]
    result4 = count_smaller(nums4)
    print(f"Test 4: {result4}")
    
    # Test case 5
    nums5 = [4, 3, 2, 1]
    result5 = count_smaller(nums5)
    print(f"Test 5: {result5}")

if __name__ == "__main__":
    main()
```

