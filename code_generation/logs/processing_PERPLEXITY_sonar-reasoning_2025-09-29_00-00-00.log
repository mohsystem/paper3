```c
#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

struct ListNode {
    int val;
    struct ListNode *next;
};

struct ListNode* mergeKLists(struct ListNode** lists, int listsSize) {
    if (lists == NULL || listsSize == 0) {
        return NULL;
    }
    
    struct ListNode dummy;
    dummy.next = NULL;
    struct ListNode* current = &dummy;
    
    while (1) {
        int minVal = INT_MAX;
        int minIdx = -1;
        
        for (int i = 0; i < listsSize; i++) {
            if (lists[i] != NULL && lists[i]->val < minVal) {
                minVal = lists[i]->val;
                minIdx = i;
            }
        }
        
        if (minIdx == -1) {
            break;
        }
        
        struct ListNode* node = lists[minIdx];
        lists[minIdx] = lists[minIdx]->next;
        
        current->next = node;
        current = current->next;
        node->next = NULL;
    }
    
    return dummy.next;
}

struct ListNode* createList(int* arr, int size) {
    if (arr == NULL || size == 0) return NULL;
    
    struct ListNode* head = (struct ListNode*)malloc(sizeof(struct ListNode));
    if (head == NULL) return NULL;
    
    head->val = arr[0];
    head->next = NULL;
    
    struct ListNode* current = head;
    for (int i = 1; i < size; i++) {
        struct ListNode* newNode = (struct ListNode*)malloc(sizeof(struct ListNode));
        if (newNode == NULL) return head;
        
        newNode->val = arr[i];
        newNode->next = NULL;
        current->next = newNode;
        current = newNode;
    }
    return head;
}

void printList(struct ListNode* head) {
    printf("[");
    int first = 1;
    while (head != NULL) {
        if (!first) printf(",");
        printf("%d", head->val);
        first = 0;
        head = head->next;
    }
    printf("]\n");
}

int main() {
    // Test case 1
    int arr1[] = {1,4,5};
    int arr2[] = {1,3,4};
    int arr3[] = {2,6};
    struct ListNode* lists1[] = {createList(arr1, 3), createList(arr2, 3), createList(arr3, 2)};
    printList(mergeKLists(lists1, 3));
    
    // Test case 2
    struct ListNode** lists2 = NULL;
    printList(mergeKLists(lists2, 0));
    
    // Test case 3
    struct ListNode* lists3[] = {NULL};
    printList(mergeKLists(lists3, 1));
    
    // Test case 4
    int arr4[] = {1};
    int arr5[] = {0};
    struct ListNode* lists4[] = {createList(arr4, 1), createList(arr5, 1)};
    printList(mergeKLists(lists4, 2));
    
    // Test case 5
    int arr6[] = {1,2,3};
    int arr7[] = {4,5,6};
    int arr8[] = {7,8,9};
    struct ListNode* lists5[] = {createList(arr6, 3), createList(arr7, 3), createList(arr8, 3)};
    printList(mergeKLists(lists5, 3));
    
    return 0;
}
