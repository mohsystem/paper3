```cpp
#include <iostream>
#include <vector>
#include <stdexcept>

class MountainArray {
private:
    std::vector<int> array;
    
public:
    explicit MountainArray(const std::vector<int>& arr) : array(arr) {
        if (arr.empty()) {
            throw std::invalid_argument("Array cannot be empty");
        }
    }
    
    int get(int index) {
        if (index < 0 || index >= static_cast<int>(array.size())) {
            throw std::out_of_range("Index out of bounds");
        }
        return array[static_cast<size_t>(index)];
    }
    
    int length() {
        return static_cast<int>(array.size());
    }
};

class Solution {
public:
    int findInMountainArray(int target, MountainArray& mountainArr) {
        int n = mountainArr.length();
        if (n < 3) {
            return -1;
        }
        
        int peak = findPeak(mountainArr, n);
        
        int result = binarySearchAsc(mountainArr, target, 0, peak);
        if (result != -1) {
            return result;
        }
        
        return binarySearchDesc(mountainArr, target, peak + 1, n - 1);
    }
    
private:
    int findPeak(MountainArray& arr, int n) {
        int left = 1, right = n - 2;
        while (left < right) {
            int mid = left + (right - left) / 2;
            if (arr.get(mid) < arr.get(mid + 1)) {
                left = mid + 1;
            } else {
                right = mid;
            }
        }
        return left;
    }
    
    int binarySearchAsc(MountainArray& arr, int target, int left, int right) {
        while (left <= right) {
            int mid = left + (right - left) / 2;
            int val = arr.get(mid);
            if (val == target) {
                return mid;
            } else if (val < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        return -1;
    }
    
    int binarySearchDesc(MountainArray& arr, int target, int left, int right) {
        while (left <= right) {
            int mid = left + (right - left) / 2;
            int val = arr.get(mid);
            if (val == target) {
                return mid;
            } else if (val > target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        return -1;
    }
};

int main() {
    Solution solution;
    
    std::vector<int> arr1 = {1, 2, 3, 4, 5, 3, 1};
    MountainArray ma1(arr1);
    std::cout << solution.findInMountainArray(3, ma1) << std::endl;
    
    std::vector<int> arr2 = {0, 1, 2, 4, 2, 1};
    MountainArray ma2(arr2);
    std::cout << solution.findInMountainArray(3, ma2) << std::endl;
    
    std::vector<int> arr3 = {1, 2, 3, 4, 5, 6, 4, 3, 2, 1};
    MountainArray ma3(arr3);
    std::cout << solution.findInMountainArray(4, ma3) << std::endl;
    
    std::vector<int> arr4 = {0, 5, 3, 1};
    MountainArray ma4(arr4);
    std::cout << solution.findInMountainArray(1, ma4) << std::endl;
    
    std::vector<int> arr5 = {1, 5, 2};
    MountainArray ma5(arr5);
    std::cout << solution.findInMountainArray(2, ma5) << std::endl;
    
    return 0;
}
```

