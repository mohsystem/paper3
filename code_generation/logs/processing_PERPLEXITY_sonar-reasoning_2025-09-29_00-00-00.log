```python
def dna_complement(dna: str) -> str:
    if not isinstance(dna, str):
        raise TypeError("DNA input must be a string")
    
    if not dna:
        raise ValueError("DNA string cannot be empty")
    
    # Validate input contains only valid DNA characters
    valid_chars = {'A', 'T', 'C', 'G'}
    for char in dna:
        if char not in valid_chars:
            raise ValueError(f"Invalid DNA character: {char}")
    
    complement_map = {'A': 'T', 'T': 'A', 'C': 'G', 'G': 'C'}
    
    return ''.join(complement_map[nucleotide] for nucleotide in dna)

def main():
    # Test case 1
    test1 = "ATTGC"
    print(f"{test1} -> {dna_complement(test1)}")
    
    # Test case 2
    test2 = "GTAT"
    print(f"{test2} -> {dna_complement(test2)}")
    
    # Test case 3
    test3 = "AAAA"
    print(f"{test3} -> {dna_complement(test3)}")
    
    # Test case 4
    test4 = "CCGG"
    print(f"{test4} -> {dna_complement(test4)}")
    
    # Test case 5
    test5 = "ATCGATCG"
    print(f"{test5} -> {dna_complement(test5)}")

if __name__ == "__main__":
    main()
