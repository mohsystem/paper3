from typing import List

class Master:
    def guess(self, word: str) -> int:
        pass

def findSecretWord(words: List[str], master: Master) -> None:
    if not words:
        return
    
    candidates = [word for word in words if word and len(word) == 6]
    
    while candidates:
        guess = candidates[0]
        matches = master.guess(guess)
        
        if matches == 6:
            return
        
        new_candidates = []
        for candidate in candidates:
            if candidate != guess and count_matches(guess, candidate) == matches:
                new_candidates.append(candidate)
        candidates = new_candidates

def count_matches(word1: str, word2: str) -> int:
    if not word1 or not word2 or len(word1) != 6 or len(word2) != 6:
        return 0
    matches = 0
    for i in range(6):
        if word1[i] == word2[i]:
            matches += 1
    return matches

class MockMaster:
    def __init__(self, secret: str):
        self.secret = secret if secret else ""
    
    def guess(self, word: str) -> int:
        if not word or len(word) != 6 or len(self.secret) != 6:
            return -1
        if self.secret == word:
            return 6
        matches = 0
        for i in range(6):
            if self.secret[i] == word[i]:
                matches += 1
        return matches

def main():
    words1 = ["acckzz","ccbazz","eiowzz","abcczz"]
    master1 = MockMaster("acckzz")
    findSecretWord(words1, master1)
    print("Test 1 completed")
    
    words2 = ["hamada","khaled"]
    master2 = MockMaster("hamada")
    findSecretWord(words2, master2)
    print("Test 2 completed")
    
    words3 = ["gaxckt","trlccr","jxwhkz"]
    master3 = MockMaster("gaxckt")
    findSecretWord(words3, master3)
    print("Test 3 completed")
    
    words4 = ["wichbx","oahwep","tpulot"]
    master4 = MockMaster("tpulot")
    findSecretWord(words4, master4)
    print("Test 4 completed")
    
    words5 = ["ccoyyo","wlisgt","qznupb"]
    master5 = MockMaster("qznupb")
    findSecretWord(words5, master5)
    print("Test 5 completed")

if __name__ == "__main__":
    main()
