```cpp
#include <iostream>
#include <string>
#include <regex>
#include <memory>
#include <curl/curl.h>
#include <sqlite3.h>

class WebScraper {
private:
    sqlite3* db;
    static constexpr size_t MAX_CONTENT_LENGTH = 1048576; // 1MB
    std::regex url_pattern;
    
    struct WriteData {
        std::string content;
        size_t max_size;
    };
    
    static size_t WriteCallback(void* contents, size_t size, size_t nmemb, WriteData* data) {
        size_t total_size = size * nmemb;
        if (data->content.size() + total_size > data->max_size) {
            return 0; // Stop download if too large
        }
        data->content.append(static_cast<char*>(contents), total_size);
        return total_size;
    }
    
    void createTable() {
        const char* sql = R"(
            CREATE TABLE IF NOT EXISTS scraped_data (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                url TEXT NOT NULL,
                title TEXT,
                content TEXT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        )";
        
        char* err_msg = nullptr;
        int rc = sqlite3_exec(db, sql, nullptr, nullptr, &err_msg);
        if (rc != SQLITE_OK) {
            std::string error = err_msg ? err_msg : "Unknown error";
            sqlite3_free(err_msg);
            throw std::runtime_error("Failed to create table: " + error);
        }
    }
    
    std::string extractTitle(const std::string& html) {
        std::regex title_regex(R"(<title[^>]*>(.*?)</title>)", 
                              std::regex_constants::icase);
        std::smatch match;
        if (std::regex_search(html, match, title_regex)) {
            std::string title = match[1].str();
            return title.length() > 200 ? title.substr(0, 200) : title;
        }
        return "";
    }
    
    std::string sanitizeContent(const std::string& content) {
        if (content.empty()) return "";
        
        std::string result = content;
        // Remove scripts and styles
        result = std::regex_replace(result, 
            std::regex(R"(<script[^>]*>.*?</script>)", std::regex_constants::icase), "");
        result = std::regex_replace(result,
            std::regex(R"(<style[^>]*>.*?</style>)", std::regex_constants::icase), "");
        // Remove HTML tags
        result = std::regex_replace(result, std::regex(R"(<[^>]+>)"), "");
        
        return result.length() > 10000 ? result.substr(0, 10000) : result;
    }

public:
    WebScraper() : db(nullptr), url_pattern(R"(^https?://[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}(/.*)?$)") {
        int rc = sqlite3_open("scraped_data.db", &db);
        if (rc) {
            throw std::runtime_error("Cannot open database");
        }
        createTable();
        curl_global_init(CURL_GLOBAL_DEFAULT);
    }
    
    ~WebScraper() {
        if (db) {
            sqlite3_close(db);
        }
        curl_global_cleanup();
    }
    
    bool isValidUrl(const std::string& url) {
        if (url.empty() || url.length() > 2048) return false;
        return std::regex_match(url, url_pattern);
    }
    
    std::string scrapeWebsite(const std::string& url) {
        if (!isValidUrl(url)) {
            throw std::invalid_argument("Invalid URL format");
        }
        
        CURL* curl = curl_easy_init();
        if (!curl) {
            throw std::runtime_error("Failed to initialize CURL");
        }
        
        WriteData write_data;
        write_data.max_size = MAX_CONTENT_LENGTH;
        
        curl_easy_setopt(curl, CURLOPT_URL, url.c_str());
        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);
        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &write_data);
        curl_easy_setopt(curl, CURLOPT_USERAGENT, "WebScraper/1.0");
        curl_easy_setopt(curl, CURLOPT_TIMEOUT, 10L);
        curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
        curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);
        curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
        curl_easy_setopt(curl, CURLOPT_MAXREDIRS, 3L);
        
        CURLcode res = curl_easy_perform(curl);
        
        long response_code;
        curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &response_code);
        curl_easy_cleanup(curl);
        
        if (res != CURLE_OK) {
            throw std::runtime_error("CURL error: " + std::string(curl_easy_strerror(res)));
        }
        
        if (response_code != 200) {
            throw std::runtime_error("HTTP " + std::to_string(response_code));
        }
        
        return write_data.content;
    }
    
    void storeData(const std::string& url, const std::string& content) {
        std::string title = extractTitle(content);
        std::string clean_content = sanitizeContent(content);
        
        const char* sql = "INSERT INTO scraped_data (url, title, content) VALUES (?, ?, ?)";
        sqlite3_stmt* stmt;
        
        int rc = sqlite3_prepare_v2(db, sql, -1, &stmt, nullptr);
        if (rc != SQLITE_OK) {
            throw std::runtime_error("Failed to prepare statement");
        }
        
        sqlite3_bind_text(stmt, 1, url.c_str(), -1, SQLITE_STATIC);
        sqlite3_bind_text(stmt, 2, title.c_str(), -1, SQLITE_STATIC);
        sqlite3_bind_text(stmt, 3, clean_content.c_str(), -1, SQLITE_STATIC);
        
        rc = sqlite3_step(stmt);
        sqlite3_finalize(stmt);
        
        if (rc != SQLITE_DONE) {
            throw std::runtime_error("Failed to execute statement");
        }
    }
};

int main() {
    try {
        WebScraper scraper;
        
        std::string test_urls[] = {
            "https://httpbin.org/html",
            "https://example.com",
            "https://httpbin.org/json",
            "https://www.google.com",
            "https://github.com"
        };
        
        for (const std::string& url : test_urls) {
            try {
                std::string content = scraper.scrapeWebsite(url);
                scraper.storeData(url, content);
                std::cout << "Successfully scraped: " << url << std::endl;
            } catch (const std::exception& e) {
                std::cerr << "Failed to scrape " << url << ": " << e.what() << std::endl;
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
