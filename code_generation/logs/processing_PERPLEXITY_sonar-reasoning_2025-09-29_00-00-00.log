#include <iostream>
#include <string>
#include <vector>
#include <thread>
#include <mutex>
#include <set>
#include <memory>
#include <algorithm>
#include <cstring>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>

constexpr int MAX_MESSAGE_LENGTH = 1024;
constexpr int PORT = 12347;

class ChatServer {
private:
    std::set<int> clients;
    std::mutex clients_mutex;
    int server_socket;
    
public:
    ChatServer() : server_socket(-1) {}
    
    ~ChatServer() {
        if (server_socket != -1) {
            close(server_socket);
        }
    }
    
    void start() {
        server_socket = socket(AF_INET, SOCK_STREAM, 0);
        if (server_socket < 0) {
            std::cerr << "Error creating socket" << std::endl;
            return;
        }
        
        int opt = 1;
        setsockopt(server_socket, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));
        
        sockaddr_in server_addr{};
        server_addr.sin_family = AF_INET;
        server_addr.sin_addr.s_addr = INADDR_ANY;
        server_addr.sin_port = htons(PORT);
        
        if (bind(server_socket, reinterpret_cast<sockaddr*>(&server_addr), sizeof(server_addr)) < 0) {
            std::cerr << "Bind failed" << std::endl;
            return;
        }
        
        if (listen(server_socket, 5) < 0) {
            std::cerr << "Listen failed" << std::endl;
            return;
        }
        
        std::cout << "Chat server started on port " << PORT << std::endl;
        
        while (true) {
            sockaddr_in client_addr{};
            socklen_t client_len = sizeof(client_addr);
            int client_socket = accept(server_socket, reinterpret_cast<sockaddr*>(&client_addr), &client_len);
            
            if (client_socket < 0) {
                std::cerr << "Accept failed" << std::endl;
                continue;
            }
            
            {
                std::lock_guard<std::mutex> lock(clients_mutex);
                clients.insert(client_socket);
            }
            
            std::thread client_thread(&ChatServer::handleClient, this, client_socket);
            client_thread.detach();
        }
    }
    
private:
    void handleClient(int client_socket) {
        std::vector<char> buffer(MAX_MESSAGE_LENGTH + 1);
        
        while (true) {
            std::fill(buffer.begin(), buffer.end(), 0);
            ssize_t bytes_received = recv(client_socket, buffer.data(), MAX_MESSAGE_LENGTH, 0);
            
            if (bytes_received <= 0) {
                break;
            }
            
            buffer[bytes_received] = '\0';
            std::string message = "Client: " + std::string(buffer.data());
            
            if (message.length() > MAX_MESSAGE_LENGTH) {
                message = message.substr(0, MAX_MESSAGE_LENGTH);
            }
            
            broadcast(message, client_socket);
        }
        
        {
            std::lock_guard<std::mutex> lock(clients_mutex);
            clients.erase(client_socket);
        }
        close(client_socket);
    }
    
    void broadcast(const std::string& message, int sender_socket) {
        std::lock_guard<std::mutex> lock(clients_mutex);
        std::vector<int> clients_to_remove;
        
        for (int client : clients) {
            if (client != sender_socket) {
                ssize_t sent = send(client, message.c_str(), message.length(), 0);
                if (sent < 0) {
                    clients_to_remove.push_back(client);
                }
            }
        }
        
        for (int client : clients_to_remove) {
            clients.erase(client);
            close(client);
        }
    }
};

class ChatClient {
public:
    void connect(const std::string& host, int port) {
        int client_socket = socket(AF_INET, SOCK_STREAM, 0);
        if (client_socket < 0) {
            std::cerr << "Error creating client socket" << std::endl;
            return;
        }
        
        sockaddr_in server_addr{};
        server_addr.sin_family = AF_INET;
        server_addr.sin_port = htons(port);
        inet_pton(AF_INET, host.c_str(), &server_addr.sin_addr);
        
        if (::connect(client_socket, reinterpret_cast<sockaddr*>(&server_addr), sizeof(server_addr)) < 0) {
            std::cerr << "Connection failed" << std::endl;
            close(client_socket);
            return;
        }
        
        std::thread receiver_thread(&ChatClient::receiveMessages, this, client_socket);
        receiver_thread.detach();
        
        std::string input;
        while (std::getline(std::cin, input)) {
            if (input.length() > MAX_MESSAGE_LENGTH) {
                input = input.substr(0, MAX_MESSAGE_LENGTH);
            }
            
            send(client_socket, input.c_str(), input.length(), 0);
            
            if (input == "exit") {
                break;
            }
        }
        
        close(client_socket);
    }
    
private:
    void receiveMessages(int socket) {
        std::vector<char> buffer(MAX_MESSAGE_LENGTH + 1);
        
        while (true) {
            std::fill(buffer.begin(), buffer.end(), 0);
            ssize_t bytes_received = recv(socket, buffer.data(), MAX_MESSAGE_LENGTH, 0);
            
            if (bytes_received <= 0) {
                break;
            }
            
            buffer[bytes_received] = '\0';
            std::cout << "Received: " << buffer.data() << std::endl;
        }
    }
};

int main() {
    // Test case 1: Start server
    std::thread server_thread([]() {
        ChatServer server;
        server.start();
    });
    server_thread.detach();
    
    // Wait for server to start
    std::this_thread::sleep_for(std::chrono::seconds(1));
    
    // Test cases 2-5: Create multiple clients
    std::vector<std::thread> client_threads;
    for (int i = 0; i < 4; ++i) {
        client_threads.emplace_back([]() {
            ChatClient client;
            client.connect("127.0.0.1", PORT);
        });
        client_threads.back().detach();
    }
    
    // Keep main thread alive
    std::this_thread::sleep_for(std::chrono::seconds(10));
    
    return 0;
}
