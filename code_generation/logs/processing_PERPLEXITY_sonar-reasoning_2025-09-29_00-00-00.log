#include <iostream>
#include <vector>
#include <random>
#include <cmath>
#include <stdexcept>

class Solution {
private:
    double radius;
    double x_center;
    double y_center;
    std::random_device rd;
    std::mt19937 gen;
    std::uniform_real_distribution<double> dis;
    
public:
    Solution(double radius, double x_center, double y_center) 
        : radius(radius), x_center(x_center), y_center(y_center), gen(rd()), dis(0.0, 1.0) {
        if (radius <= 0) {
            throw std::invalid_argument("Radius must be positive");
        }
    }
    
    std::vector<double> randPoint() {
        double r = std::sqrt(dis(gen)) * radius;
        double theta = dis(gen) * 2 * M_PI;
        
        double x = x_center + r * std::cos(theta);
        double y = y_center + r * std::sin(theta);
        
        return {x, y};
    }
};

int main() {
    Solution sol1(1.0, 0.0, 0.0);
    auto point1 = sol1.randPoint();
    std::cout << "Test 1: [" << point1 << ", " << point1[1] << "]" << std::endl;
    
