```cpp
#include <iostream>
#include <string>
#include <set>
#include <random>
#include <memory>

class Robot {
private:
    static std::set<std::string> usedNames;
    static std::random_device rd;
    static std::mt19937 gen;
    static std::uniform_int_distribution<> letterDist;
    static std::uniform_int_distribution<> digitDist;
    
    std::string name;
    
    static std::string generateUniqueName() {
        std::string newName;
        do {
            newName = "";
            for (int i = 0; i < 2; i++) {
                newName += static_cast<char>('A' + letterDist(gen));
            }
            for (int i = 0; i < 3; i++) {
                newName += std::to_string(digitDist(gen));
            }
        } while (usedNames.find(newName) != usedNames.end());
        
        usedNames.insert(newName);
        return newName;
    }
    
public:
    Robot() : name("") {}
    
    std::string getName() {
        if (name.empty()) {
            name = generateUniqueName();
        }
        return name;
    }
    
    void reset() {
        if (!name.empty()) {
            usedNames.erase(name);
            name = "";
        }
    }
};

std::set<std::string> Robot::usedNames;
std::random_device Robot::rd;
std::mt19937 Robot::gen(Robot::rd());
std::uniform_int_distribution<> Robot::letterDist(0, 25);
std::uniform_int_distribution<> Robot::digitDist(0, 9);

int main() {
    Robot robot1, robot2, robot3, robot4, robot5;
    
    std::cout << "Robot 1: " << robot1.getName() << std::endl;
    std::cout << "Robot 2: " << robot2.getName() << std::endl;
    std::cout << "Robot 3: " << robot3.getName() << std::endl;
    std::cout << "Robot 4: " << robot4.getName() << std::endl;
    std::cout << "Robot 5: " << robot5.getName() << std::endl;
    
    robot1.reset();
    std::cout << "Robot 1 after reset: " << robot1.getName() << std::endl;
    
    return 0;
}
