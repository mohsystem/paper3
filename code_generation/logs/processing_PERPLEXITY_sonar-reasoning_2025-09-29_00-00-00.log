```cpp
#include <iostream>
#include <unordered_map>
#include <vector>
#include <queue>
#include <unordered_set>

std::unordered_map<int, std::vector<int>> reparentTree(
    const std::unordered_map<int, std::vector<int>>& tree, int newRoot) {
    
    if (tree.empty() || tree.find(newRoot) == tree.end()) {
        return {};
    }
    
    std::unordered_map<int, std::vector<int>> result;
    std::unordered_set<int> visited;
    std::queue<int> queue;
    
    queue.push(newRoot);
    visited.insert(newRoot);
    
    while (!queue.empty()) {
        int current = queue.front();
        queue.pop();
        
        auto it = tree.find(current);
        if (it != tree.end()) {
            for (int neighbor : it->second) {
                if (visited.find(neighbor) == visited.end()) {
                    visited.insert(neighbor);
                    result[current].push_back(neighbor);
                    queue.push(neighbor);
                }
            }
        }
    }
    
    return result;
}

void printTree(const std::unordered_map<int, std::vector<int>>& tree) {
    std::cout << "{";
    bool first = true;
    for (const auto& pair : tree) {
        if (!first) std::cout << ", ";
        std::cout << pair.first << ": [";
        for (size_t i = 0; i < pair.second.size(); ++i) {
            if (i > 0) std::cout << ", ";
            std::cout << pair.second[i];
        }
        std::cout << "]";
        first = false;
    }
    std::cout << "}" << std::endl;
}

int main() {
    // Test case 1: Example from problem
    std::unordered_map<int, std::vector<int>> tree1 = {
        {0, {1, 2, 3}},
        {1, {0, 4, 5}},
        {2, {0, 6, 7}},
        {3, {0, 8, 9}},
        {4, {1}},
        {5, {1}},
        {6, {2}},
        {7, {2}},
        {8, {3}},
        {9, {3}}
    };
    std::cout << "Test 1: ";
    printTree(reparentTree(tree1, 6));
    
    // Test case 2: Single node
    std::unordered_map<int, std::vector<int>> tree2 = {{1, {}}};
    std::cout << "Test 2: ";
    printTree(reparentTree(tree2, 1));
    
    // Test case 3: Two nodes
    std::unordered_map<int, std::vector<int>> tree3 = {{1, {2}}, {2, {1}}};
    std::cout << "Test 3: ";
    printTree(reparentTree(tree3, 2));
    
    // Test case 4: Empty tree
    std::unordered_map<int, std::vector<int>> tree4;
    std::cout << "Test 4: ";
    printTree(reparentTree(tree4, 1));
    
    // Test case 5: Linear tree
    std::unordered_map<int, std::vector<int>> tree5 = {
        {1, {2}}, {2, {1, 3}}, {3, {2, 4}}, {4, {3}}
    };
    std::cout << "Test 5: ";
    printTree(reparentTree(tree5, 3));
    
    return 0;
}
