#include <stdio.h>
#include <math.h>

int calculateYears(double principal, double interest, double tax, double desired) {
    // Input validation
    if (principal < 0 || interest < 0 || tax < 0 || tax >= 1 || desired < 0) {
        return -1; // Error code for invalid input
    }
    if (isnan(principal) || isnan(interest) || isnan(tax) || isnan(desired)) {
        return -1; // Error code for NaN
    }
    if (isinf(principal) || isinf(interest) || isinf(tax) || isinf(desired)) {
        return -1; // Error code for infinite values
    }
    
    if (principal >= desired) {
        return 0;
    }
    
    int years = 0;
    double currentPrincipal = principal;
    
    while (currentPrincipal < desired) {
        double yearlyInterest = currentPrincipal * interest;
        double taxOnInterest = yearlyInterest * tax;
        double netInterest = yearlyInterest - taxOnInterest;
        currentPrincipal += netInterest;
        years++;
        
        // Prevent infinite loop
        if (years > 10000) {
            return -1; // Error code for too many iterations
        }
    }
    
    return years;
}

int main() {
    int result;
    
    // Test case 1: Example from problem
    result = calculateYears(1000.0, 0.05, 0.18, 1100.0);
    printf("Test 1: %d\n", result); // Expected: 3
    
    // Test case 2: Already at desired amount
    result = calculateYears(1000.0, 0.05, 0.18, 1000.0);
    printf("Test 2: %d\n", result); // Expected: 0
    
    // Test case 3: Low interest
    result = calculateYears(1000.0, 0.01, 0.1, 1050.0);
    printf("Test 3: %d\n", result); // Expected: multiple years
    
    // Test case 4: High interest
    result = calculateYears(1000.0, 0.1, 0.2, 1100.0);
    printf("Test 4: %d\n", result); // Expected: fewer years
    
    // Test case 5: No tax
    result = calculateYears(1000.0, 0.05, 0.0, 1050.0);
    printf("Test 5: %d\n", result); // Expected: 1
    
    return 0;
}
