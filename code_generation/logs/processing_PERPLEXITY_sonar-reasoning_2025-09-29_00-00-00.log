```java
import java.util.concurrent.Semaphore;
import java.util.concurrent.locks.ReentrantLock;
import java.util.*;

public class Task187 {
    private final Semaphore hydrogenSem;
    private final Semaphore oxygenSem;
    private final ReentrantLock lock;
    private int hydrogenCount;
    private int oxygenCount;
    private final StringBuilder result;
    
    public Task187() {
        this.hydrogenSem = new Semaphore(0);
        this.oxygenSem = new Semaphore(0);
        this.lock = new ReentrantLock();
        this.hydrogenCount = 0;
        this.oxygenCount = 0;
        this.result = new StringBuilder();
    }
    
    public void hydrogen() throws InterruptedException {
        lock.lock();
        try {
            hydrogenCount++;
            if (hydrogenCount >= 2 && oxygenCount >= 1) {
                hydrogenSem.release(1);
                oxygenSem.release(1);
                hydrogenCount -= 2;
                oxygenCount -= 1;
            }
        } finally {
            lock.unlock();
        }
        hydrogenSem.acquire();
        releaseHydrogen();
    }
    
    public void oxygen() throws InterruptedException {
        lock.lock();
        try {
            oxygenCount++;
            if (hydrogenCount >= 2 && oxygenCount >= 1) {
                hydrogenSem.release(2);
                oxygenSem.release(1);
                hydrogenCount -= 2;
                oxygenCount -= 1;
            }
        } finally {
            lock.unlock();
        }
        oxygenSem.acquire();
        releaseOxygen();
    }
    
    private void releaseHydrogen() {
        synchronized(result) {
            result.append('H');
        }
    }
    
    private void releaseOxygen() {
        synchronized(result) {
            result.append('O');
        }
    }
    
    public String buildMolecule(String water) {
        if (water == null || water.length() % 3 != 0) {
            throw new IllegalArgumentException("Invalid input");
        }
        
        for (char c : water.toCharArray()) {
            if (c != 'H' && c != 'O') {
                throw new IllegalArgumentException("Invalid character");
            }
        }
        
        result.setLength(0);
        hydrogenCount = 0;
        oxygenCount = 0;
        
        List<Thread> threads = new ArrayList<>();
        
        for (char c : water.toCharArray()) {
            if (c == 'H') {
                threads.add(new Thread(() -> {
                    try { hydrogen(); } catch (InterruptedException e) { 
                        Thread.currentThread().interrupt(); 
                    }
                }));
            } else {
                threads.add(new Thread(() -> {
                    try { oxygen(); } catch (InterruptedException e) { 
                        Thread.currentThread().interrupt(); 
                    }
                }));
            }
        }
        
        for (Thread t : threads) {
            t.start();
        }
        
        for (Thread t : threads) {
            try { t.join(); } catch (InterruptedException e) { 
                Thread.currentThread().interrupt(); 
            }
        }
        
        return result.toString();
    }
    
    public static void main(String[] args) {
        Task187 solution = new Task187();
        
        String[] testCases = {"HOH", "OOHHHH", "HHHOOO", "OHHHHO", "HHOOHH"};
        
        for (String test : testCases) {
            try {
                String output = solution.buildMolecule(test);
                System.out.println("Input: " + test + " -> Output: " + output);
            } catch (Exception e) {
