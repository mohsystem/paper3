import secrets
import hashlib
from typing import Optional
from cryptography.hazmat.primitives.ciphers.aead import AESGCM
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
from cryptography.hazmat.backends import default_backend

class SensitiveDataStorage:
    MAGIC = b"ENC1"
    VERSION = 1
    SALT_LENGTH = 16
    IV_LENGTH = 12
    TAG_LENGTH = 16
    PBKDF2_ITERATIONS = 210000
    
    @staticmethod
    def _derive_key(passphrase: str, salt: bytes) -> bytes:
        if not isinstance(passphrase, str) or not isinstance(salt, bytes):
            raise ValueError("Invalid input types")
        if len(salt) != SensitiveDataStorage.SALT_LENGTH:
            raise ValueError("Invalid salt length")
            
        kdf = PBKDF2HMAC(
            algorithm=hashlib.sha256(),
            length=32,  # 256 bits
            salt=salt,
            iterations=SensitiveDataStorage.PBKDF2_ITERATIONS,
            backend=default_backend()
        )
        return kdf.derive(passphrase.encode('utf-8'))
    
    @staticmethod
    def encrypt_sensitive_data(sensitive_data: str, passphrase: str) -> bytes:
        if not isinstance(sensitive_data, str) or not isinstance(passphrase, str):
            raise ValueError("Input must be strings")
        if not sensitive_data or not passphrase:
            raise ValueError("Input cannot be empty")
            
        # Generate salt and IV
        salt = secrets.token_bytes(SensitiveDataStorage.SALT_LENGTH)
        iv = secrets.token_bytes(SensitiveDataStorage.IV_LENGTH)
        
        # Derive key
        key = SensitiveDataStorage._derive_key(passphrase, salt)
        
        # Encrypt
        aesgcm = AESGCM(key)
        plaintext = sensitive_data.encode('utf-8')
        ciphertext_with_tag = aesgcm.encrypt(iv, plaintext, None)
        
        # Split ciphertext and tag
        ciphertext = ciphertext_with_tag[:-SensitiveDataStorage.TAG_LENGTH]
        tag = ciphertext_with_tag[-SensitiveDataStorage.TAG_LENGTH:]
        
        # Build format: [magic][version][salt][iv][ciphertext][tag]
        result = bytearray()
        result.extend(SensitiveDataStorage.MAGIC)
        result.extend(SensitiveDataStorage.VERSION.to_bytes(4, 'big'))
        result.extend(salt)
        result.extend(iv)
        result.extend(ciphertext)
        result.extend(tag)
        
        return bytes(result)
    
    @staticmethod
    def decrypt_sensitive_data(encrypted_data: bytes, passphrase: str) -> str:
        if not isinstance(encrypted_data, bytes) or not isinstance(passphrase, str):
            raise ValueError("Invalid input types")
        if not encrypted_data or not passphrase:
            raise ValueError("Input cannot be empty")
            
        min_length = (len(SensitiveDataStorage.MAGIC) + 4 + 
                     SensitiveDataStorage.SALT_LENGTH + 
                     SensitiveDataStorage.IV_LENGTH + 
                     SensitiveDataStorage.TAG_LENGTH)
        
        if len(encrypted_data) < min_length:
            raise ValueError("Invalid encrypted data format")
        
        pos = 0
        
        # Validate magic
        magic = encrypted_data[pos:pos + len(SensitiveDataStorage.MAGIC)]
        if magic != SensitiveDataStorage.MAGIC:
            raise ValueError("Invalid magic header")
        pos += len(SensitiveDataStorage.MAGIC)
        
        # Validate version
        version = int.from_bytes(encrypted_data[pos:pos + 4], 'big')
        if version != SensitiveDataStorage.VERSION:
            raise ValueError("Unsupported version")
        pos += 4
        
        # Extract salt
        salt = encrypted_data[pos:pos + SensitiveDataStorage.SALT_LENGTH]
        pos += SensitiveDataStorage.SALT_LENGTH
        
        # Extract IV
        iv = encrypted_data[pos:pos + SensitiveDataStorage.IV_LENGTH]
        pos += SensitiveDataStorage.IV_LENGTH
        
        # Extract ciphertext and tag
        ciphertext = encrypted_data[pos:-SensitiveDataStorage.TAG_LENGTH]
        tag = encrypted_data[-SensitiveDataStorage.TAG_LENGTH:]
        
        # Derive key
        key = SensitiveDataStorage._derive_key(passphrase, salt)
        
        # Decrypt
        aesgcm = AESGCM(key)
        ciphertext_with_tag = ciphertext + tag
        
        try:
            plaintext = aesgcm.decrypt(iv, ciphertext_with_tag, None)
            return plaintext.decode('utf-8')
        except Exception as e:
            raise ValueError("Decryption failed") from e

def main():
    passphrase = "SecurePassphrase123!"
    storage = SensitiveDataStorage()
    
