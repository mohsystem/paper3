```java
import java.util.*;

public class Task35 {
    public static int peopleOnBus(int[][] busStops) {
        if (busStops == null) {
            throw new IllegalArgumentException("Bus stops array cannot be null");
        }
        
        int peopleCount = 0;
        
        for (int i = 0; i < busStops.length; i++) {
            if (busStops[i] == null || busStops[i].length != 2) {
                throw new IllegalArgumentException("Each bus stop must have exactly 2 values");
            }
            if (busStops[i][0] < 0 || busStops[i][1] < 0) {
                throw new IllegalArgumentException("People counts cannot be negative");
            }
            
            peopleCount += busStops[i][0] - busStops[i][1];
            
            if (peopleCount < 0) {
                throw new IllegalArgumentException("Bus cannot have negative people count");
            }
        }
        
        return peopleCount;
    }
    
    public static void main(String[] args) {
        // Test case 1
        int[][] test1 = {{10, 0}, {3, 5}, {5, 8}};
        System.out.println("Test 1: " + peopleOnBus(test1)); // Expected: 5
        
        // Test case 2
        int[][] test2 = {{3, 0}, {9, 1}, {4, 10}, {12, 2}, {6, 1}, {7, 10}};
        System.out.println("Test 2: " + peopleOnBus(test2)); // Expected: 17
        
        // Test case 3
        int[][] test3 = {{3, 0}, {9, 1}, {4, 8}, {12, 2}, {6, 1}, {7, 8}};
        System.out.println("Test 3: " + peopleOnBus(test3)); // Expected: 21
        
        // Test case 4
        int[][] test4 = {{0, 0}};
        System.out.println("Test 4: " + peopleOnBus(test4)); // Expected: 0
        
        // Test case 5
        int[][] test5 = {{5, 0}, {2, 3}, {4, 1}};
        System.out.println("Test 5: " + peopleOnBus(test5)); // Expected: 7
    }
}
