```java
import java.util.*;

interface Master {
    public int guess(String word);
}

class Task194 {
    public void findSecretWord(String[] words, Master master) {
        if (words == null || words.length == 0) {
            return;
        }
        
        List<String> candidates = new ArrayList<>();
        for (String word : words) {
            if (word != null && word.length() == 6) {
                candidates.add(word);
            }
        }
        
        while (!candidates.isEmpty()) {
            String guess = candidates.get(0);
            int matches = master.guess(guess);
            
            if (matches == 6) {
                return;
            }
            
            List<String> newCandidates = new ArrayList<>();
            for (String candidate : candidates) {
                if (!candidate.equals(guess) && countMatches(guess, candidate) == matches) {
                    newCandidates.add(candidate);
                }
            }
            candidates = newCandidates;
        }
    }
    
    private int countMatches(String word1, String word2) {
        if (word1 == null || word2 == null || word1.length() != 6 || word2.length() != 6) {
            return 0;
        }
        int matches = 0;
        for (int i = 0; i < 6; i++) {
            if (word1.charAt(i) == word2.charAt(i)) {
                matches++;
            }
        }
        return matches;
    }
    
    static class MockMaster implements Master {
        private String secret;
        
        public MockMaster(String secret) {
            this.secret = secret != null ? secret : "";
        }
        
        public int guess(String word) {
            if (word == null || word.length() != 6 || secret.length() != 6) {
                return -1;
            }
            if (secret.equals(word)) {
                return 6;
            }
            int matches = 0;
            for (int i = 0; i < 6; i++) {
                if (secret.charAt(i) == word.charAt(i)) {
                    matches++;
                }
            }
            return matches;
        }
    }
    
    public static void main(String[] args) {
        Task194 solution = new Task194();
        
        String[] words1 = {"acckzz","ccbazz","eiowzz","abcczz"};
        MockMaster master1 = new MockMaster("acckzz");
        solution.findSecretWord(words1, master1);
        System.out.println("Test 1 completed");
        
        String[] words2 = {"hamada","khaled"};
        MockMaster master2 = new MockMaster("hamada");
        solution.findSecretWord(words2, master2);
        System.out.println("Test 2 completed");
        
        String[] words3 = {"gaxckt","trlccr","jxwhkz"};
        MockMaster master3 = new MockMaster("gaxckt");
        solution.findSecretWord(words3, master3);
        System.out.println("Test 3 completed");
        
        String[] words4 = {"wichbx","oahwep","tpulot"};
        MockMaster master4 = new MockMaster("tpulot");
        solution.findSecretWord(words4, master4);
        System.out.println("Test 4 completed");
        
        String[] words5 = {"ccoyyo","wlisgt","qznupb"};
        MockMaster master5 = new MockMaster("qznupb");
        solution.findSecretWord(words5, master5);
        System.out.println("Test 5 completed");
    }
}
