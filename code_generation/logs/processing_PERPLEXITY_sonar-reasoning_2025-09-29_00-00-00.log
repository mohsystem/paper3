std::vector<int> countSmaller(std::vector<int>& nums) {
    if (nums.empty()) {
        return {};
    }
    
    int n = nums.size();
    std::vector<int> counts(n, 0);
    
    for (int i = 0; i < n; i++) {
        int count = 0;
        for (int j = i + 1; j < n; j++) {
            if (nums[j] < nums[i]) {
                count++;
            }
        }
        counts[i] = count;
    }
    
    return counts;
}

