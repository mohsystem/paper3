```cpp
#include <iostream>
#include <string>
#include <stdexcept>
#include <algorithm>

long long largestProduct(const std::string& input, int span) {
    // Input validation
    if (input.empty()) {
        throw std::invalid_argument("Input cannot be empty");
    }
    if (span <= 0) {
        throw std::invalid_argument("Span must be positive");
    }
    if (span > static_cast<int>(input.length())) {
        throw std::invalid_argument("Span cannot be larger than input length");
    }
    
    // Validate input contains only digits
    for (char c : input) {
        if (c < '0' || c > '9') {
            throw std::invalid_argument("Input must contain only digits");
        }
    }
    
    long long maxProduct = 0;
    
    // Calculate product for each possible span
    for (int i = 0; i <= static_cast<int>(input.length()) - span; i++) {
        long long product = 1;
        for (int j = i; j < i + span; j++) {
            int digit = input[j] - '0';
            product *= digit;
        }
        maxProduct = std::max(maxProduct, product);
    }
    
    return maxProduct;
}

int main() {
    // Test case 1
    std::cout << largestProduct("63915", 3) << std::endl; // Expected: 162
    
    // Test case 2
    std::cout << largestProduct("123456789", 4) << std::endl; // Expected: 3024
    
    // Test case 3
    std::cout << largestProduct("9876543210", 2) << std::endl; // Expected: 72
    
    // Test case 4
    std::cout << largestProduct("1111", 2) << std::endl; // Expected: 1
    
    // Test case 5
    std::cout << largestProduct("50505", 3) << std::endl; // Expected: 0
    
    return 0;
}
