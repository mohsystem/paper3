```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <ctype.h>

#define MAX_SESSIONS 100
#define TOKEN_SIZE 65
#define SESSION_SIZE 256

typedef struct {
    char session_id[SESSION_SIZE];
    char token[TOKEN_SIZE];
} CSRFEntry;

static CSRFEntry sessions[MAX_SESSIONS];
static int session_count = 0;

static int constant_time_equals(const char *a, const char *b) {
    size_t len_a = strlen(a);
    size_t len_b = strlen(b);
    
    if (len_a != len_b) {
        return 0;
    }
    
    int result = 0;
    for (size_t i = 0; i < len_a; i++) {
        result |= a[i] ^ b[i];
    }
    
    return result == 0;
}

static int is_empty_or_whitespace(const char *str) {
    if (!str) return 1;
    
    while (*str) {
        if (!isspace(*str)) {
            return 0;
        }
        str++;
    }
    return 1;
}

char* generate_csrf_token(const char *session_id) {
    if (is_empty_or_whitespace(session_id)) {
        return NULL;
    }
    
    if (session_count >= MAX_SESSIONS) {
        return NULL;
    }
    
    static char token[TOKEN_SIZE];
    srand((unsigned int)time(NULL) + session_count);
    
    for (int i = 0; i < TOKEN_SIZE - 1; i += 2) {
        unsigned char byte = rand() % 256;
        snprintf(token + i, 3, "%02x", byte);
    }
    token[TOKEN_SIZE - 1] = '\0';
    
    strncpy(sessions[session_count].session_id, session_id, SESSION_SIZE - 1);
    sessions[session_count].session_id[SESSION_SIZE - 1] = '\0';
    strncpy(sessions[session_count].token, token, TOKEN_SIZE - 1);
    sessions[session_count].token[TOKEN_SIZE - 1] = '\0';
    session_count++;
    
    return token;
}

int validate_csrf_token(const char *session_id, const char *provided_token) {
    if (is_empty_or_whitespace(session_id) || is_empty_or_whitespace(provided_token)) {
        return 0;
    }
    
    for (int i = 0; i < session_count; i++) {
        if (strcmp(sessions[i].session_id, session_id) == 0) {
            return constant_time_equals(sessions[i].token, provided_token);
        }
    }
    
    return 0;
}

void invalidate_csrf_token(const char *session_id) {
    if (is_empty_or_whitespace(session_id)) {
        return;
    }
    
    for (int i = 0; i < session_count; i++) {
        if (strcmp(sessions[i].session_id, session_id) == 0) {
            for (int j = i; j < session_count - 1; j++) {
                sessions[j] = sessions[j + 1];
            }
            session_count--;
            break;
        }
    }
}

int main() {
    // Test case 1: Valid token generation and validation
    const char *session1 = "session123";
    char *token1 = generate_csrf_token(session1);
    printf("Test 1 - Valid token: %s\n", validate_csrf_token(session1, token1) ? "true" : "false");
    
    // Test case 2: Invalid token validation
    printf("Test 2 - Invalid token: %s\n", validate_csrf_token(session1, "invalid_token") ? "true" : "false");
    
    // Test case 3: Empty session ID
    printf("Test 3 - Empty session: %s\n", validate_csrf_token("", token1) ? "true" : "false");
    
    // Test case 4: Empty token
    printf("Test 4 - Empty token: %s\n", validate_csrf_token(session1, "") ? "true" : "false");
    
    // Test case 5: Token invalidation
    invalidate_csrf_token(session1);
    printf("Test 5 - After invalidation: %s\n", validate_csrf_token(session1, token1) ? "true" : "false");
    
    return 0;
}
