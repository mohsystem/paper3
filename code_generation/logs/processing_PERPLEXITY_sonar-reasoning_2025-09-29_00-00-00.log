```python
import html
import re
import urllib.parse
from http.server import HTTPServer, BaseHTTPRequestHandler
from typing import Optional, Dict

class FormHandler(BaseHTTPRequestHandler):
    MAX_INPUT_LENGTH = 1000
    FORM_HTML = """<!DOCTYPE html>
<html>
<head><title>User Input Form</title></head>
<body>
<h1>Enter Your Information</h1>
<form method="post" action="/">
<label>Name: <input type="text" name="name" maxlength="100" required></label><br><br>
<label>Message: <textarea name="message" maxlength="500" required></textarea></label><br><br>
<input type="submit" value="Submit">
</form>
</body>
</html>"""

    def do_GET(self) -> None:
        self.send_response(200)
        self.send_header('Content-type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(self.FORM_HTML.encode('utf-8'))

    def do_POST(self) -> None:
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            if content_length > self.MAX_INPUT_LENGTH:
                self._send_error_page("Input too long")
                return
            
            post_data = self.rfile.read(content_length).decode('utf-8')
            params = self._parse_form_data(post_data)
            
            name = self._validate_and_sanitize(params.get('name', ''), 100)
            message = self._validate_and_sanitize(params.get('message', ''), 500)
            
            if name is None or message is None:
                self._send_error_page("Invalid input detected")
                return
            
            self._send_result_page(name, message)
            
        except Exception as e:
            self._send_error_page("Processing error")

    def _parse_form_data(self, form_data: str) -> Dict[str, str]:
        params = {}
        if not form_data:
            return params
        
        pairs = form_data.split('&')
        for pair in pairs:
            if '=' in pair:
                key, value = pair.split('=', 1)
                try:
                    key = urllib.parse.unquote_plus(key)
                    value = urllib.parse.unquote_plus(value)
                    params[key] = value
                except Exception:
                    continue
        return params

    def _validate_and_sanitize(self, input_str: str, max_length: int) -> Optional[str]:
        if not input_str or not input_str.strip():
            return None
        
        input_str = input_str.strip()
        if len(input_str) > max_length:
            return None
        
        # Allow only alphanumeric, spaces, and basic punctuation
        if not re.match(r'^[a-zA-Z0-9\s.,!?\'-]*$', input_str):
            return None
        
        return html.escape(input_str)

    def _send_result_page(self, name: str, message: str) -> None:
        result_html = f"""<!DOCTYPE html>
<html>
<head><title>Form Result</title></head>
<body>
<h1>Thank you for your submission!</h1>
<p><strong>Name:</strong> {name}</p>
<p><strong>Message:</strong> {message}</p>
<a href="/">Submit another form</a>
</body>
</html>"""
        
        self.send_response(200)
        self.send_header('Content-type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(result_html.encode('utf-8'))

    def _send_error_page(self, error: str) -> None:
        error_html = f"""<!DOCTYPE html>
<html>
<head><title>Error</title></head>
<body>
<h1>Error</h1>
<p>{html.escape(error)}</p>
<a href="/">Try again</a>
</body>
</html>"""
        
        self.send_response(400)
        self.send_header('Content-type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(error_html.encode('utf-8'))

def validate_and_sanitize_test(input_str: str, max_length: int) -> Optional[str]:
    if not input_str or not input_str.strip():
        return None
    
    input_str = input_str.strip()
    if len(input_str) > max_length:
        return None
    
    if not re.match(r'^[a-zA-Z0-9\s.,!?\'-]*$', input_str):
        return None
    
    return html.escape(input_str)

if __name__ == '__main__':
    # Test case 1: Valid input validation
    valid_name = validate_and_sanitize_test("John Doe", 100)
    print(f"Test 1 - Valid name: {'PASS' if valid_name is not None else 'FAIL'}")
    
    # Test case 2: Input too long
    long_input = "a" * 101
    invalid_long = validate_and_sanitize_test(long_input, 100)
    print(f"Test 2 - Long input rejected: {'PASS' if invalid_long is None else 'FAIL'}")
    
    # Test case 3: Invalid characters
    invalid_chars = validate_and_sanitize_test("John<script>", 100)
    print(f"Test 3 - Invalid chars rejected: {'PASS' if invalid_chars is None else 'FAIL'}")
    
    # Test case 4: HTML escaping
    html_input = validate_and_sanitize_test("Hello & goodbye", 100)
    print(f"Test 4 - HTML escaped: {'PASS' if html_input is not None and '&amp;' in html_input else 'FAIL'}")
    
    # Test case 5: Empty input
    empty_input = validate_and_sanitize_test("", 100)
    print(f"Test 5 - Empty input rejected: {'PASS' if empty_input is None else 'FAIL'}")
    
    # Start server
    try:
        server = HTTPServer(('localhost', 8080), FormHandler)
        print("Server started on http://localhost:8080")
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nServer stopped")
        server.shutdown()
