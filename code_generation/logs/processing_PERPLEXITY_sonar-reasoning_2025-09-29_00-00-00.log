```python
from typing import List, Optional

class MountainArray:
    def __init__(self, array: List[int]) -> None:
        if array is None:
            raise ValueError("Array cannot be None")
        self._array: List[int] = array.copy()
    
    def get(self, index: int) -> int:
        if not isinstance(index, int) or index < 0 or index >= len(self._array):
            raise IndexError(f"Index out of bounds: {index}")
        return self._array[index]
    
    def length(self) -> int:
        return len(self._array)

def find_in_mountain_array(target: int, mountain_arr: Optional[MountainArray]) -> int:
    if mountain_arr is None:
        return -1
    
    n: int = mountain_arr.length()
    if n < 3:
        return -1
    
    peak: int = find_peak(mountain_arr, n)
    
    result: int = binary_search_asc(mountain_arr, target, 0, peak)
    if result != -1:
        return result
    
    return binary_search_desc(mountain_arr, target, peak + 1, n - 1)

def find_peak(arr: MountainArray, n: int) -> int:
    left: int = 1
    right: int = n - 2
    while left < right:
        mid: int = left + (right - left) // 2
        if arr.get(mid) < arr.get(mid + 1):
            left = mid + 1
        else:
            right = mid
    return left

def binary_search_asc(arr: MountainArray, target: int, left: int, right: int) -> int:
    while left <= right:
        mid: int = left + (right - left) // 2
        val: int = arr.get(mid)
        if val == target:
            return mid
        elif val < target:
            left = mid + 1
        else:
            right = mid - 1
    return -1

def binary_search_desc(arr: MountainArray, target: int, left: int, right: int) -> int:
    while left <= right:
        mid: int = left + (right - left) // 2
        val: int = arr.get(mid)
        if val == target:
            return mid
        elif val > target:
            left = mid + 1
        else:
            right = mid - 1
    return -1

if __name__ == "__main__":
    arr1: List[int] = [1, 2, 3, 4, 5, 3, 1]
    ma1: MountainArray = MountainArray(arr1)
    print(find_in_mountain_array(3, ma1))
    
    arr2: List[int] = [0, 1, 2, 4, 2, 1]
    ma2: MountainArray = MountainArray(arr2)
    print(find_in_mountain_array(3, ma2))
    
    arr3: List[int] = [1, 2, 3, 4, 5, 6, 4, 3, 2, 1]
    ma3: MountainArray = MountainArray(arr3)
