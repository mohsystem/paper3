```cpp
#include <iostream>
#include <vector>
#include <deque>
#include <algorithm>
#include <climits>

int constrainedSubsetSum(std::vector<int>& nums, int k) {
    if (nums.empty()) {
        throw std::invalid_argument("Array cannot be empty");
    }
    if (k < 1 || k > static_cast<int>(nums.size())) {
        throw std::invalid_argument("k must be between 1 and array length");
    }
    
    int n = nums.size();
    std::vector<int> dp(n);
    std::deque<int> dq;
    
    int result = INT_MIN;
    
    for (int i = 0; i < n; i++) {
        while (!dq.empty() && dq.front() < i - k) {
            dq.pop_front();
        }
        
        dp[i] = nums[i];
        if (!dq.empty()) {
            dp[i] = std::max(dp[i], nums[i] + dp[dq.front()]);
        }
        
        result = std::max(result, dp[i]);
        
        while (!dq.empty() && dp[dq.back()] <= dp[i]) {
            dq.pop_back();
        }
        dq.push_back(i);
    }
    
    return result;
}

int main() {
    std::vector<int> nums1 = {10, 2, -10, 5, 20};
    std::cout << constrainedSubsetSum(nums1, 2) << std::endl;
    
    std::vector<int> nums2 = {-1, -2, -3};
    std::cout << constrainedSubsetSum(nums2, 1) << std::endl;
    
    std::vector<int> nums3 = {10, -2, -10, -5, 20};
    std::cout << constrainedSubsetSum(nums3, 2) << std::endl;
    
    std::vector<int> nums4 = {1};
    std::cout << constrainedSubsetSum(nums4, 1) << std::endl;
    
    std::vector<int> nums5 = {1, 2, 3, 4, 5};
    std::cout << constrainedSubsetSum(nums5, 3) << std::endl;
    
    return 0;
}
