```cpp
#include <iostream>
#include <vector>
#include <stdexcept>

class ProductOfNumbers {
private:
    std::vector<int> stream;

public:
    ProductOfNumbers() {}
    
    void add(int num) {
        if (num < 0 || num > 100) {
            throw std::invalid_argument("Number must be between 0 and 100");
        }
        stream.push_back(num);
    }
    
    int getProduct(int k) {
        if (k <= 0 || k > static_cast<int>(stream.size())) {
            throw std::invalid_argument("Invalid k value");
        }
        
        int product = 1;
        int size = static_cast<int>(stream.size());
        for (int i = size - k; i < size; i++) {
            product *= stream[i];
        }
        return product;
    }
};

int main() {
    try {
        ProductOfNumbers pon1;
        pon1.add(3);
        pon1.add(0);
        pon1.add(2);
        pon1.add(5);
        pon1.add(4);
        std::cout << pon1.getProduct(2) << std::endl;
        std::cout << pon1.getProduct(3) << std::endl;
        std::cout << pon1.getProduct(4) << std::endl;
        pon1.add(8);
        std::cout << pon1.getProduct(2) << std::endl;
        
        ProductOfNumbers pon2;
        pon2.add(1);
        pon2.add(1);
        pon2.add(1);
        std::cout << pon2.getProduct(3) << std::endl;
        
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
    }
    
    return 0;
}
