import heapq
from typing import List, Optional

class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next
    
    def __lt__(self, other):
        return self.val < other.val

def mergeKLists(lists: List[Optional[ListNode]]) -> Optional[ListNode]:
    if not lists:
        return None
    
    heap = []
    
    for i, head in enumerate(lists):
        if head:
            heapq.heappush(heap, (head.val, i, head))
    
    dummy = ListNode(0)
    current = dummy
    counter = len(lists)
    
    while heap:
        val, idx, node = heapq.heappop(heap)
        current.next = node
        current = current.next
        
        if node.next:
            heapq.heappush(heap, (node.next.val, counter, node.next))
            counter += 1
    
    return dummy.next

def create_list(arr):
    if not arr:
        return None
    head = ListNode(arr[0])
    current = head
    for i in range(1, len(arr)):
        current.next = ListNode(arr[i])
        current = current.next
    return head

def print_list(head):
    result = []
    while head:
        result.append(head.val)
        head = head.next
    print(result)

if __name__ == "__main__":
    # Test case 1
    lists1 = [create_list([1,4,5]), create_list([1,3,4]), create_list([2,6])]
    print_list(mergeKLists(lists1))
    
    # Test case 2
    lists2 = []
    print_list(mergeKLists(lists2))
    
    # Test case 3
    lists3 = [None]
    print_list(mergeKLists(lists3))
    
    # Test case 4
    lists4 = [create_list([1]), create_list([0])]
    print_list(mergeKLists(lists4))
    
    # Test case 5
    lists5 = [create_list([1,2,3]), create_list([4,5,6]), create_list([7,8,9])]
    print_list(mergeKLists(lists5))
