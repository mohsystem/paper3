```cpp
#include <iostream>
#include <fstream>
#include <string>
#include <vector>
#include <sstream>
#include <filesystem>

std::string transposeFile(const std::string& filename) {
    try {
        if (filename.empty()) {
            return "Error: Invalid filename";
        }
        
        if (!std::filesystem::exists(filename) || !std::filesystem::is_regular_file(filename)) {
            return "Error: File does not exist or is not a regular file";
        }
        
        std::ifstream file(filename);
        if (!file.is_open()) {
            return "Error: Cannot open file";
        }
        
        std::vector<std::vector<std::string>> matrix;
        std::string line;
        int expectedCols = -1;
        
        while (std::getline(file, line)) {
            if (line.empty() || line.find_first_not_of(' ') == std::string::npos) {
                continue;
            }
            
            std::istringstream iss(line);
            std::vector<std::string> fields;
            std::string field;
            
            while (iss >> field) {
                fields.push_back(field);
            }
            
            if (expectedCols == -1) {
                expectedCols = static_cast<int>(fields.size());
            } else if (static_cast<int>(fields.size()) != expectedCols) {
                return "Error: Inconsistent number of columns";
            }
            
            matrix.push_back(fields);
        }
        
        file.close();
        
        if (matrix.empty()) {
            return "";
        }
        
        std::string result;
        for (int col = 0; col < expectedCols; ++col) {
            for (size_t row = 0; row < matrix.size(); ++row) {
                if (row > 0) result += " ";
                result += matrix[row][col];
            }
            if (col < expectedCols - 1) result += "\n";
        }
        
        return result;
    } catch (const std::exception& e) {
        return "Error: " + std::string(e.what());
    }
}

int main() {
    // Test case 1: Basic example
    {
        std::ofstream file("test1.txt");
        if (file.is_open()) {
            file << "name age\n";
            file << "alice 21\n";
            file << "ryan 30\n";
            file.close();
        }
    }
    std::cout << "Test 1:\n" << transposeFile("test1.txt") << "\n\n";
    
    // Test case 2: Single row
    {
        std::ofstream file("test2.txt");
        if (file.is_open()) {
            file << "a b c\n";
            file.close();
        }
    }
    std::cout << "Test 2:\n" << transposeFile("test2.txt") << "\n\n";
    
    // Test case 3: Single column
    {
        std::ofstream file("test3.txt");
        if (file.is_open()) {
            file << "a\n";
            file << "b\n";
            file << "c\n";
            file.close();
        }
    }
    std::cout << "Test 3:\n" << transposeFile("test3.txt") << "\n\n";
    
    // Test case 4: Empty file
    {
        std::ofstream file("test4.txt");
        file.close();
    }
    std::cout << "Test 4:\n" << transposeFile("test4.txt") << "\n\n";
    
    // Test case 5: Non-existent file
    std::cout << "Test 5:\n" << transposeFile("nonexistent.txt") << "\n";
    
    return 0;
}
