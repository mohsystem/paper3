```cpp
#include <mongocxx/client.hpp>
#include <mongocxx/instance.hpp>
#include <mongocxx/uri.hpp>
#include <bsoncxx/builder/stream/document.hpp>
#include <bsoncxx/json.hpp>
#include <bsoncxx/oid.hpp>
#include <iostream>
#include <string>
#include <memory>
#include <stdexcept>
#include <regex>

class MongoCRUD {
private:
    mongocxx::client client;
    mongocxx::database database;
    mongocxx::collection collection;
    
    void validateName(const std::string& name) {
        if (name.empty() || name.find_first_not_of(' ') == std::string::npos) {
            throw std::invalid_argument("Name cannot be empty");
        }
        std::regex namePattern("^[a-zA-Z\\s]+$");
        if (!std::regex_match(name, namePattern)) {
            throw std::invalid_argument("Name can only contain letters and spaces");
        }
    }
    
    void validateAge(int age) {
        if (age < 0 || age > 150) {
            throw std::invalid_argument("Age must be between 0 and 150");
        }
    }
    
    std::string trim(const std::string& str) {
        size_t first = str.find_first_not_of(' ');
        if (first == std::string::npos) return "";
        size_t last = str.find_last_not_of(' ');
        return str.substr(first, (last - first + 1));
    }

public:
    MongoCRUD(const std::string& uri, const std::string& db_name, const std::string& coll_name)
        : client{mongocxx::uri{uri}}, database{client[db_name]}, collection{database[coll_name]} {
        if (uri.empty() || db_name.empty() || coll_name.empty()) {
            throw std::invalid_argument("URI, database name, and collection name cannot be empty");
        }
    }
    
    bsoncxx::oid create(const std::string& name, int age) {
        std::string trimmed_name = trim(name);
        validateName(trimmed_name);
        validateAge(age);
        
        auto builder = bsoncxx::builder::stream::document{};
        bsoncxx::document::value doc = builder
            << "name" << trimmed_name
            << "age" << age
            << bsoncxx::builder::stream::finalize;
        
        auto result = collection.insert_one(doc.view());
        return result->inserted_id().get_oid().value;
    }
    
    std::optional<bsoncxx::document::value> read(const bsoncxx::oid& id) {
        auto builder = bsoncxx::builder::stream::document{};
        bsoncxx::document::value filter = builder << "_id" << id << bsoncxx::builder::stream::finalize;
        
        auto result = collection.find_one(filter.view());
        if (result) {
            return bsoncxx::document::value{result->view()};
        }
        return std::nullopt;
    }
    
    bool update(const bsoncxx::oid& id, const std::string& name, int age) {
        std::string trimmed_name = trim(name);
        validateName(trimmed_name);
        validateAge(age);
        
        auto filter_builder = bsoncxx::builder::stream::document{};
        bsoncxx::document::value filter = filter_builder << "_id" << id << bsoncxx::builder::stream::finalize;
        
        auto update_builder = bsoncxx::builder::stream::document{};
        bsoncxx::document::value update = update_builder
            << "$set" << bsoncxx::builder::stream::open_document
            << "name" << trimmed_name
            << "age" << age
            << bsoncxx::builder::stream::close_document
            << bsoncxx::builder::stream::finalize;
        
        auto result = collection.update_one(filter.view(), update.view());
        return result && result->modified_count() > 0;
    }
    
    bool remove(const bsoncxx::oid& id) {
        auto builder = bsoncxx::builder::stream::document{};
        bsoncxx::document::value filter = builder << "_id" << id << bsoncxx::builder::stream::finalize;
        
        auto result = collection.delete_one(filter.view());
        return result && result->deleted_count() > 0;
    }
};

int main() {
    mongocxx::instance instance{};
    
    try {
        MongoCRUD crud("mongodb://localhost:27017", "testdb", "users");
        
        // Test case 1: Create operation
        auto doc_id = crud.create("Charlie Brown", 35);
        std::cout << "Created document with ID: " << doc_id.to_string() << std::endl;
        
        // Test case 2: Read operation
        auto document = crud.read(doc_id);
        if (document) {
            std::cout << "Read document: " << bsoncxx::to_json(document->view()) << std::endl;
        }
        
        // Test case 3: Update operation
        bool updated = crud.update(doc_id, "Charlie Smith", 36);
        std::cout << "Update result: " << (updated ? "true" : "false") << std::endl;
        
        // Test case 4: Read after update
        auto updated_doc = crud.read(doc_id);
        if (updated_doc) {
            std::cout << "Updated document: " << bsoncxx::to_json(updated_doc->view()) << std::endl;
        }
        
        // Test case 5: Delete operation
        bool deleted = crud.remove(doc_id);
        std::cout << "Delete result: " << (deleted ? "true" : "false") << std::endl;
        
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
