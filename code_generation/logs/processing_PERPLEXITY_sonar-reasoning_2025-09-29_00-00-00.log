```java
import java.nio.charset.StandardCharsets;

public class Task79 {
    public static String encrypt(String message, int key) {
        if (message == null) {
            throw new IllegalArgumentException("Message cannot be null");
        }
        
        // Normalize key to 0-25 range to prevent overflow
        key = ((key % 26) + 26) % 26;
        
        StringBuilder result = new StringBuilder();
        
        for (char c : message.toCharArray()) {
            if (Character.isLetter(c)) {
                char base = Character.isUpperCase(c) ? 'A' : 'a';
                int shifted = (c - base + key) % 26;
                result.append((char) (base + shifted));
            } else {
                result.append(c);
            }
        }
        
        return result.toString();
    }
    
    public static String decrypt(String message, int key) {
        if (message == null) {
            throw new IllegalArgumentException("Message cannot be null");
        }
        return encrypt(message, -key);
    }
    
    public static void main(String[] args) {
        // Test case 1
        System.out.println(encrypt("HELLO", 3));
        
        // Test case 2
        System.out.println(encrypt("World", 13));
        
        // Test case 3
        System.out.println(encrypt("ABC xyz", 1));
        
        // Test case 4
        System.out.println(decrypt("KHOOR", 3));
        
        // Test case 5
        System.out.println(encrypt("", 5));
    }
}
```

```python
def encrypt(message: str, key: int) -> str:
    if message is None:
        raise ValueError("Message cannot be None")
    
    # Normalize key to 0-25 range to prevent overflow
    key = ((key % 26) + 26) % 26
    
    result = []
    
    for c in message:
        if c.isalpha():
            base = ord('A') if c.isupper() else ord('a')
            shifted = (ord(c) - base + key) % 26
            result.append(chr(base + shifted))
        else:
            result.append(c)
    
    return ''.join(result)

def decrypt(message: str, key: int) -> str:
    if message is None:
        raise ValueError("Message cannot be None")
    return encrypt(message, -key)

if __name__ == "__main__":
    # Test case 1
    print(encrypt("HELLO", 3))
    
    # Test case 2
    print(encrypt("World", 13))
    
    # Test case 3
    print(encrypt("ABC xyz", 1))
    
    # Test case 4
    print(decrypt("KHOOR", 3))
    
    # Test case 5
    print(encrypt("", 5))
```

```cpp
#include <iostream>
#include <string>
#include <stdexcept>
#include <cctype>

std::string encrypt(const std::string& message, int key) {
    // Normalize key to 0-25 range to prevent overflow
    key = ((key % 26) + 26) % 26;
    
    std::string result;
    result.reserve(message.length());
    
    for (char c : message) {
        if (std::isalpha(c)) {
            char base = std::isupper(c) ? 'A' : 'a';
            int shifted = (c - base + key) % 26;
            result += static_cast<char>(base + shifted);
        } else {
            result += c;
        }
    }
    
    return result;
}

std::string decrypt(const std::string& message, int key) {
    return encrypt(message, -key);
}

int main() {
    // Test case 1
    std::cout << encrypt("HELLO", 3) << std::endl;
    
    // Test case 2
    std::cout << encrypt("World", 13) << std::endl;
    
    // Test case 3
    std::cout << encrypt("ABC xyz", 1) << std::endl;
    
    // Test case 4
    std::cout << decrypt("KHOOR", 3) << std::endl;
    
    // Test case 5
    std::cout << encrypt("", 5) << std::endl;
    
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>

char* encrypt(const char* message, int key) {
    if (message == NULL) {
        return NULL;
    }
    
    size_t len = strlen(message);
    if (len > 10000) {  // Bounds check
        return NULL;
    }
    
    char* result = malloc(len + 1);
    if (result == NULL) {
        return NULL;
    }
    
    // Normalize key to 0-25 range to prevent overflow
    key = ((key % 26) + 26) % 26;
    
    for (size_t i = 0; i < len; i++) {
        char c = message[i];
        if (isalpha(c)) {
            char base = isupper(c) ? 'A' : 'a';
            int shifted = (c - base + key) % 26;
            result[i] = base + shifted;
        } else {
            result[i] = c;
        }
    }
    
    result[len] = '\0';
    return result;
}

char* decrypt(const char* message, int key) {
    return encrypt(message, -key);
}

int main() {
    char* result;
    
    // Test case 1
    result = encrypt("HELLO", 3);
    if (result) {
        printf("%s\n", result);
        free(result);
    }
    
    // Test case 2
    result = encrypt("World", 13);
    if (result) {
        printf("%s\n", result);
        free(result);
    }
    
    // Test case 3
    result = encrypt("ABC xyz", 1);
    if (result) {
        printf("%s\n", result);
        free(result);
    }
    
    // Test case 4
    result = decrypt("KHOOR", 3);
    if (result) {
        printf("%s\n", result);
        free(result);
    }
    
    // Test case 5
    result = encrypt("", 5);
    if (result) {
        printf("%s\n", result);
        free(result);
    }
    
    return 0;
}
