import threading
from decimal import Decimal, InvalidOperation
from typing import Optional, Dict
import uuid

class BankAccount:
    def __init__(self, account_number: str, initial_balance: Decimal):
        if not account_number or not account_number.strip():
            raise ValueError("Account number cannot be empty")
        if initial_balance < 0:
            raise ValueError("Initial balance cannot be negative")
        
        self._account_number = account_number
        self._balance = initial_balance
        self._is_open = True
        self._lock = threading.RLock()
    
    def deposit(self, amount: Decimal) -> bool:
        if amount <= 0:
            return False
        
        with self._lock:
            if not self._is_open:
                return False
            self._balance += amount
            return True
    
    def withdraw(self, amount: Decimal) -> bool:
        if amount <= 0:
            return False
        
        with self._lock:
            if not self._is_open or self._balance < amount:
                return False
            self._balance -= amount
            return True
    
    def get_balance(self) -> Optional[Decimal]:
        with self._lock:
            return self._balance if self._is_open else None
    
    def close(self) -> bool:
        with self._lock:
            if not self._is_open:
                return False
            self._is_open = False
            return True
    
    def is_open(self) -> bool:
        with self._lock:
            return self._is_open

class BankSystem:
    def __init__(self):
        self._accounts: Dict[str, BankAccount] = {}
        self._lock = threading.RLock()
        self._account_counter = 1000
    
    def open_account(self, initial_balance: Decimal) -> Optional[str]:
        try:
            if initial_balance < 0:
                return None
            
            with self._lock:
                account_number = str(self._account_counter)
                self._account_counter += 1
                account = BankAccount(account_number, initial_balance)
                self._accounts[account_number] = account
                return account_number
        except (ValueError, InvalidOperation):
            return None
    
    def close_account(self, account_number: str) -> bool:
        if not account_number or not account_number.strip():
            return False
        
        with self._lock:
            account = self._accounts.get(account_number)
            if account is None:
                return False
            return account.close()
    
    def deposit(self, account_number: str, amount: Decimal) -> bool:
        if not account_number or not account_number.strip():
            return False
        
        try:
            with self._lock:
                account = self._accounts.get(account_number)
                if account is None:
                    return False
                return account.deposit(amount)
        except (ValueError, InvalidOperation):
            return False
    
    def withdraw(self, account_number: str, amount: Decimal) -> bool:
        if not account_number or not account_number.strip():
            return False
        
        try:
            with self._lock:
                account = self._accounts.get(account_number)
                if account is None:
                    return False
                return account.withdraw(amount)
        except (ValueError, InvalidOperation):
            return False
    
    def get_balance(self, account_number: str) -> Optional[Decimal]:
        if not account_number or not account_number.strip():
            return None
        
        with self._lock:
            account = self._accounts.get(account_number)
            if account is None:
                return None
            return account.get_balance()

def main():
    bank = BankSystem()
    
    # Test case 1: Open account and deposit
    account1 = bank.open_account(Decimal('1000.00'))
    print(f"Test 1 - Account opened: {account1 is not None}")
    deposit_result = bank.deposit(account1, Decimal('500.00'))
    print(f"Test 1 - Deposit successful: {deposit_result}")
    print(f"Test 1 - Balance: {bank.get_balance(account1)}")
    
    # Test case 2: Withdraw money
    withdraw_result = bank.withdraw(account1, Decimal('200.00'))
    print(f"Test 2 - Withdraw successful: {withdraw_result}")
    print(f"Test 2 - Balance: {bank.get_balance(account1)}")
    
    # Test case 3: Insufficient funds
    insufficient_withdraw = bank.withdraw(account1, Decimal('2000.00'))
    print(f"Test 3 - Insufficient funds withdraw: {insufficient_withdraw}")
    
    # Test case 4: Close account and try operations
    close_result = bank.close_account(account1)
    print(f"Test 4 - Account closed: {close_result}")
    deposit_closed = bank.deposit(account1, Decimal('100.00'))
    print(f"Test 4 - Deposit to closed account: {deposit_closed}")
    
    # Test case 5: Invalid operations
    invalid_account = bank.deposit("invalid", Decimal('100.00'))
    print(f"Test 5 - Invalid account operation: {invalid_account}")
    null_balance = bank.get_balance("nonexistent")
    print(f"Test 5 - Nonexistent account balance: {null_balance}")

if __name__ == "__main__":
    main()
