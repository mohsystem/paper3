from cryptography.hazmat.primitives.ciphers.aead import AESGCM
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
from cryptography.hazmat.primitives import hashes
import secrets
import os
from pathlib import Path
from typing import Optional

MAGIC = b"ENC1"
VERSION = 1
SALT_LENGTH = 16
IV_LENGTH = 12
TAG_LENGTH = 16
PBKDF2_ITERATIONS = 210000

def encrypt_file(input_path: str, output_path: str, password: str) -> bool:
    if not input_path or not output_path or not password:
        return False
    
    try:
        input_file = Path(input_path)
        if not input_file.exists() or not input_file.is_file():
            return False
            
        with open(input_file, 'rb') as f:
            plaintext = f.read()
        
        salt = secrets.token_bytes(SALT_LENGTH)
        iv = secrets.token_bytes(IV_LENGTH)
        
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=PBKDF2_ITERATIONS,
        )
        key = kdf.derive(password.encode('utf-8'))
        
        aesgcm = AESGCM(key)
        ciphertext = aesgcm.encrypt(iv, plaintext, None)
        
        output_data = MAGIC + bytes([VERSION]) + salt + iv + ciphertext
        
        temp_path = output_path + '.tmp'
        with open(temp_path, 'wb') as f:
            f.write(output_data)
            f.flush()
            os.fsync(f.fileno())
        
        os.rename(temp_path, output_path)
        return True
        
    except Exception:
        return False

def decrypt_file(input_path: str, output_path: str, password: str) -> bool:
    if not input_path or not output_path or not password:
        return False
    
    try:
        input_file = Path(input_path)
        if not input_file.exists() or not input_file.is_file():
            return False
            
        with open(input_file, 'rb') as f:
            encrypted_data = f.read()
        
        if len(encrypted_data) < len(MAGIC) + 1 + SALT_LENGTH + IV_LENGTH + TAG_LENGTH:
            return False
        
        pos = 0
        magic = encrypted_data[pos:pos + len(MAGIC)]
        if magic != MAGIC:
            return False
        pos += len(MAGIC)
        
        version = encrypted_data[pos]
        if version != VERSION:
            return False
        pos += 1
        
        salt = encrypted_data[pos:pos + SALT_LENGTH]
        pos += SALT_LENGTH
        iv = encrypted_data[pos:pos + IV_LENGTH]
        pos += IV_LENGTH
        ciphertext = encrypted_data[pos:]
        
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=PBKDF2_ITERATIONS,
        )
        key = kdf.derive(password.encode('utf-8'))
        
        aesgcm = AESGCM(key)
        plaintext = aesgcm.decrypt(iv, ciphertext, None)
        
        temp_path = output_path + '.tmp'
        with open(temp_path, 'wb') as f:
            f.write(plaintext)
            f.flush()
            os.fsync(f.fileno())
        
        os.rename(temp_path, output_path)
        return True
        
    except Exception:
        return False

def main():
    # Create test files
    Path("test1.txt").write_text("Hello World!", encoding='utf-8')
    Path("test2.txt").write_text("Secret Message", encoding='utf-8')
    Path("test3.txt").write_text("", encoding='utf-8')
    Path("test4.txt").write_text("A" * 1000, encoding='utf-8')
    Path("test5.txt").write_text("Unicode: \u4f60\u597d\u4e16\u754c \U0001f30d", encoding='utf-8')
    
    print("Test 1:", encrypt_file("test1.txt", "test1.enc", "password123") and 
                     decrypt_file("test1.enc", "test1.dec", "password123"))
    print("Test 2:", encrypt_file("test2.txt", "test2.enc", "secret") and 
                     decrypt_file("test2.enc", "test2.dec", "secret"))
    print("Test 3:", encrypt_file("test3.txt", "test3.enc", "empty") and 
                     decrypt_file("test3.enc", "test3.dec", "empty"))
    print("Test 4:", encrypt_file("test4.txt", "test4.enc", "long") and 
                     decrypt_file("test4.enc", "test4.dec", "long"))
    print("Test 5:", not decrypt_file("test4.enc", "test5.dec", "wrongpass"))

if __name__ == "__main__":
    main()
