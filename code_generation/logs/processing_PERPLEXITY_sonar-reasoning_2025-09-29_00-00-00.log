```python
def shortest_palindrome(s: str) -> str:
    if not s:
        return ""
    
    # Input validation
    if len(s) > 50000:
        raise ValueError("String length exceeds maximum allowed")
    
    if not all('a' <= c <= 'z' for c in s):
        raise ValueError("String must contain only lowercase English letters")
    
    rev_s = s[::-1]
    combined = s + "#" + rev_s
    
    lps = compute_lps(combined)
    overlap = lps[-1]
    
    return rev_s[:len(s) - overlap] + s

def compute_lps(pattern: str) -> list:
    lps = [0] * len(pattern)
    length = 0
    i = 1
    
    while i < len(pattern):
        if pattern[i] == pattern[length]:
            length += 1
            lps[i] = length
            i += 1
        else:
            if length != 0:
                length = lps[length - 1]
            else:
                lps[i] = 0
                i += 1
    return lps

if __name__ == "__main__":
    print(shortest_palindrome("aacecaaa"))
    print(shortest_palindrome("abcd"))
    print(shortest_palindrome(""))
    print(shortest_palindrome("a"))
    print(shortest_palindrome("race"))
