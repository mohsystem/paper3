```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

long long largestProduct(const char* input, int span) {
    // Input validation
    if (input == NULL) {
        return -1; // Error: null input
    }
    
    int len = strlen(input);
    if (len == 0) {
        return -1; // Error: empty input
    }
    if (span <= 0) {
        return -1; // Error: invalid span
    }
    if (span > len) {
        return -1; // Error: span too large
    }
    
    // Validate input contains only digits
    for (int i = 0; i < len; i++) {
        if (input[i] < '0' || input[i] > '9') {
            return -1; // Error: non-digit character
        }
    }
    
    long long maxProduct = 0;
    
    // Calculate product for each possible span
    for (int i = 0; i <= len - span; i++) {
        long long product = 1;
        for (int j = i; j < i + span; j++) {
            int digit = input[j] - '0';
            product *= digit;
        }
        if (product > maxProduct) {
            maxProduct = product;
        }
    }
    
    return maxProduct;
}

int main() {
    // Test case 1
    printf("%lld\n", largestProduct("63915", 3)); // Expected: 162
    
    // Test case 2
    printf("%lld\n", largestProduct("123456789", 4)); // Expected: 3024
    
    // Test case 3
    printf("%lld\n", largestProduct("9876543210", 2)); // Expected: 72
    
    // Test case 4
    printf("%lld\n", largestProduct("1111", 2)); // Expected: 1
    
    // Test case 5
    printf("%lld\n", largestProduct("50505", 3)); // Expected: 0
    
    return 0;
}
