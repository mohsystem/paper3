```cpp
#include <iostream>
#include <string>
#include <unordered_map>
#include <random>
#include <algorithm>
#include <stdexcept>

class CSRFProtection {
private:
    std::unordered_map<std::string, std::string> sessionTokens;
    std::random_device rd;
    std::mt19937 gen;
    std::uniform_int_distribution<> dis;

    bool constantTimeEquals(const std::string& a, const std::string& b) {
        if (a.length() != b.length()) {
            return false;
        }
        
        int result = 0;
        for (size_t i = 0; i < a.length(); ++i) {
            result |= a[i] ^ b[i];
        }
        
        return result == 0;
    }

public:
    CSRFProtection() : gen(rd()), dis(0, 255) {}

    std::string generateCSRFToken(const std::string& sessionId) {
        if (sessionId.empty() || std::all_of(sessionId.begin(), sessionId.end(), ::isspace)) {
            throw std::invalid_argument("Session ID cannot be empty");
        }
        
        std::string token;
        token.reserve(64);
        
        for (int i = 0; i < 32; ++i) {
            unsigned char byte = static_cast<unsigned char>(dis(gen));
            char hex[3];
            snprintf(hex, sizeof(hex), "%02x", byte);
            token += hex;
        }
        
        sessionTokens[sessionId] = token;
        return token;
    }
    
    bool validateCSRFToken(const std::string& sessionId, const std::string& providedToken) {
        if (sessionId.empty() || std::all_of(sessionId.begin(), sessionId.end(), ::isspace)) {
            return false;
        }
        if (providedToken.empty() || std::all_of(providedToken.begin(), providedToken.end(), ::isspace)) {
            return false;
        }
        
        auto it = sessionTokens.find(sessionId);
        if (it == sessionTokens.end()) {
            return false;
        }
        
        return constantTimeEquals(it->second, providedToken);
    }
    
    void invalidateCSRFToken(const std::string& sessionId) {
        if (!sessionId.empty()) {
            sessionTokens.erase(sessionId);
        }
    }
};

int main() {
    CSRFProtection csrf;
    
    // Test case 1: Valid token generation and validation
    std::string session1 = "session123";
    std::string token1 = csrf.generateCSRFToken(session1);
    std::cout << "Test 1 - Valid token: " << std::boolalpha << csrf.validateCSRFToken(session1, token1) << std::endl;
    
    // Test case 2: Invalid token validation
    std::cout << "Test 2 - Invalid token: " << std::boolalpha << csrf.validateCSRFToken(session1, "invalid_token") << std::endl;
    
    // Test case 3: Empty session ID
    std::cout << "Test 3 - Empty session: " << std::boolalpha << csrf.validateCSRFToken("", token1) << std::endl;
    
    // Test case 4: Empty token
    std::cout << "Test 4 - Empty token: " << std::boolalpha << csrf.validateCSRFToken(session1, "") << std::endl;
    
    // Test case 5: Token invalidation
    csrf.invalidateCSRFToken(session1);
    std::cout << "Test 5 - After invalidation: " << std::boolalpha << csrf.validateCSRFToken(session1, token1) << std::endl;
    
    return 0;
}
