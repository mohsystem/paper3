```java
public class Task32 {
    public static int calculateYears(double principal, double interest, double tax, double desired) {
        // Input validation
        if (principal < 0 || interest < 0 || tax < 0 || tax >= 1 || desired < 0) {
            throw new IllegalArgumentException("Invalid input parameters");
        }
        if (Double.isNaN(principal) || Double.isNaN(interest) || Double.isNaN(tax) || Double.isNaN(desired)) {
            throw new IllegalArgumentException("Parameters cannot be NaN");
        }
        if (Double.isInfinite(principal) || Double.isInfinite(interest) || Double.isInfinite(tax) || Double.isInfinite(desired)) {
            throw new IllegalArgumentException("Parameters cannot be infinite");
        }
        
        if (principal >= desired) {
            return 0;
        }
        
        int years = 0;
        double currentPrincipal = principal;
        
        while (currentPrincipal < desired) {
            double yearlyInterest = currentPrincipal * interest;
            double taxOnInterest = yearlyInterest * tax;
            double netInterest = yearlyInterest - taxOnInterest;
            currentPrincipal += netInterest;
            years++;
            
            // Prevent infinite loop
            if (years > 10000) {
                throw new RuntimeException("Calculation exceeded maximum iterations");
            }
        }
        
        return years;
    }
    
    public static void main(String[] args) {
        // Test case 1: Example from problem
        System.out.println("Test 1: " + calculateYears(1000.0, 0.05, 0.18, 1100.0)); // Expected: 3
        
        // Test case 2: Already at desired amount
        System.out.println("Test 2: " + calculateYears(1000.0, 0.05, 0.18, 1000.0)); // Expected: 0
        
        // Test case 3: Low interest
        System.out.println("Test 3: " + calculateYears(1000.0, 0.01, 0.1, 1050.0)); // Expected: multiple years
        
        // Test case 4: High interest
        System.out.println("Test 4: " + calculateYears(1000.0, 0.1, 0.2, 1100.0)); // Expected: fewer years
        
        // Test case 5: No tax
        System.out.println("Test 5: " + calculateYears(1000.0, 0.05, 0.0, 1050.0)); // Expected: 1
    }
}
