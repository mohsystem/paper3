import com.mongodb.client.MongoClient;
import com.mongodb.client.MongoClients;
import com.mongodb.client.MongoCollection;
import com.mongodb.client.MongoDatabase;
import com.mongodb.client.result.DeleteResult;
import com.mongodb.client.result.UpdateResult;
import org.bson.Document;
import org.bson.types.ObjectId;
import java.util.Arrays;
import static com.mongodb.client.model.Filters.eq;
import static com.mongodb.client.model.Updates.set;

public class Task112 {
    private MongoClient mongoClient;
    private MongoDatabase database;
    private MongoCollection<Document> collection;
    
    public Task112(String connectionString, String dbName, String collectionName) {
        if (connectionString == null || dbName == null || collectionName == null) {
            throw new IllegalArgumentException("Parameters cannot be null");
        }
        if (connectionString.trim().isEmpty() || dbName.trim().isEmpty() || collectionName.trim().isEmpty()) {
            throw new IllegalArgumentException("Parameters cannot be empty");
        }
        
        this.mongoClient = MongoClients.create(connectionString);
        this.database = mongoClient.getDatabase(dbName);
        this.collection = database.getCollection(collectionName);
    }
    
    public ObjectId create(String name, int age) {
        if (name == null || name.trim().isEmpty()) {
            throw new IllegalArgumentException("Name cannot be null or empty");
        }
        if (age < 0 || age > 150) {
            throw new IllegalArgumentException("Age must be between 0 and 150");
        }
        
        Document doc = new Document("name", name.trim())
                .append("age", age);
        collection.insertOne(doc);
        return doc.getObjectId("_id");
    }
    
    public Document read(ObjectId id) {
        if (id == null) {
            throw new IllegalArgumentException("ID cannot be null");
        }
        return collection.find(eq("_id", id)).first();
    }
    
    public boolean update(ObjectId id, String name, int age) {
        if (id == null) {
            throw new IllegalArgumentException("ID cannot be null");
        }
        if (name == null || name.trim().isEmpty()) {
            throw new IllegalArgumentException("Name cannot be null or empty");
        }
        if (age < 0 || age > 150) {
            throw new IllegalArgumentException("Age must be between 0 and 150");
        }
        
        UpdateResult result = collection.updateOne(
            eq("_id", id),
            set("name", name.trim()).append("age", age)
        );
        return result.getModifiedCount() > 0;
    }
    
    public boolean delete(ObjectId id) {
        if (id == null) {
            throw new IllegalArgumentException("ID cannot be null");
        }
        DeleteResult result = collection.deleteOne(eq("_id", id));
        return result.getDeletedCount() > 0;
    }
    
    public void close() {
        if (mongoClient != null) {
            mongoClient.close();
        }
    }
    
    public static void main(String[] args) {
        Task112 crud = new Task112("mongodb://localhost:27017", "testdb", "users");
        
        try {
            // Test case 1: Create operation
            ObjectId id1 = crud.create("Alice", 25);
            System.out.println("Created document with ID: " + id1);
            
            // Test case 2: Read operation
            Document doc = crud.read(id1);
            System.out.println("Read document: " + doc);
            
            // Test case 3: Update operation
            boolean updated = crud.update(id1, "Alice Smith", 26);
            System.out.println("Update result: " + updated);
            
            // Test case 4: Read after update
            Document updatedDoc = crud.read(id1);
            System.out.println("Updated document: " + updatedDoc);
            
            // Test case 5: Delete operation
            boolean deleted = crud.delete(id1);
            System.out.println("Delete result: " + deleted);
            
        } catch (Exception e) {
            System.err.println("Error: " + e.getMessage());
        } finally {
            crud.close();
        }
    }
}
