#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/kdf.h>
#include <fstream>
#include <vector>
#include <string>
#include <memory>
#include <iostream>
#include <cstring>

class FileEncryption {
private:
    static constexpr const char* MAGIC = "ENC1";
    static constexpr int VERSION = 1;
    static constexpr int SALT_LENGTH = 16;
    static constexpr int IV_LENGTH = 12;
    static constexpr int TAG_LENGTH = 16;
    static constexpr int PBKDF2_ITERATIONS = 210000;
    static constexpr int KEY_LENGTH = 32;

public:
    static bool encryptFile(const std::string& inputPath, const std::string& outputPath, const std::string& password) {
        if (inputPath.empty() || outputPath.empty() || password.empty()) {
            return false;
        }
        
        std::ifstream inFile(inputPath, std::ios::binary);
        if (!inFile) return false;
        
        std::vector<unsigned char> plaintext((std::istreambuf_iterator<char>(inFile)), 
                                           std::istreambuf_iterator<char>());
        inFile.close();
        
        std::vector<unsigned char> salt(SALT_LENGTH);
        std::vector<unsigned char> iv(IV_LENGTH);
        
        if (RAND_bytes(salt.data(), SALT_LENGTH) != 1 || 
            RAND_bytes(iv.data(), IV_LENGTH) != 1) {
            return false;
        }
        
        std::vector<unsigned char> key(KEY_LENGTH);
        if (PKCS5_PBKDF2_HMAC(password.c_str(), password.length(),
                              salt.data(), SALT_LENGTH,
                              PBKDF2_ITERATIONS, EVP_sha256(),
                              KEY_LENGTH, key.data()) != 1) {
            return false;
        }
        
        std::unique_ptr<EVP_CIPHER_CTX, decltype(&EVP_CIPHER_CTX_free)> ctx(
            EVP_CIPHER_CTX_new(), EVP_CIPHER_CTX_free);
        if (!ctx) return false;
        
        if (EVP_EncryptInit_ex(ctx.get(), EVP_aes_256_gcm(), nullptr, key.data(), iv.data()) != 1) {
            return false;
        }
        
        std::vector<unsigned char> ciphertext(plaintext.size() + TAG_LENGTH);
        int len = 0, ciphertext_len = 0;
        
        if (EVP_EncryptUpdate(ctx.get(), ciphertext.data(), &len, plaintext.data(), plaintext.size()) != 1) {
            return false;
        }
        ciphertext_len = len;
        
        if (EVP_EncryptFinal_ex(ctx.get(), ciphertext.data() + len, &len) != 1) {
