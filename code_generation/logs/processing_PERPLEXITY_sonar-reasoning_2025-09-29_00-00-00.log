from cryptography.hazmat.primitives.ciphers.aead import AESGCM
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
from cryptography.hazmat.primitives import hashes
import secrets
import os
from typing import Optional, Set, Dict

class KeyManager:
    KEY_LENGTH = 32
    IV_LENGTH = 12
    SALT_LENGTH = 16
    KDF_ITERATIONS = 210000
    
    def __init__(self):
        self.key_store: Dict[str, bytes] = {}
        self.master_key: Optional[bytes] = None
        
    def initialize_master_key(self, passphrase: str) -> bool:
        if not passphrase or len(passphrase) < 8:
            return False
            
        try:
            salt = secrets.token_bytes(self.SALT_LENGTH)
            kdf = PBKDF2HMAC(
                algorithm=hashes.SHA256(),
                length=self.KEY_LENGTH,
                salt=salt,
                iterations=self.KDF_ITERATIONS,
            )
            self.master_key = kdf.derive(passphrase.encode('utf-8'))
            return True
        except Exception:
            return False
    
    def generate_key(self, key_id: str) -> Optional[str]:
        if not key_id or not key_id.strip() or not self.master_key:
            return None
            
        try:
            key = secrets.token_bytes(self.KEY_LENGTH)
            encrypted_key = self._encrypt_key(key)
            if encrypted_key:
                self.key_store[key_id.strip()] = encrypted_key
                return key_id.strip()
        except Exception:
            pass
        return None
    
    def retrieve_key(self, key_id: str) -> Optional[bytes]:
        if not key_id or not self.master_key:
            return None
            
        encrypted_key = self.key_store.get(key_id.strip())
        if not encrypted_key:
            return None
            
        return self._decrypt_key(encrypted_key)
    
    def delete_key(self, key_id: str) -> bool:
        if not key_id:
            return False
        return self.key_store.pop(key_id.strip(), None) is not None
    
    def list_keys(self) -> Set[str]:
        return set(self.key_store.keys())
    
    def _encrypt_key(self, key: bytes) -> Optional[bytes]:
        try:
            aesgcm = AESGCM(self.master_key)
            iv = secrets.token_bytes(self.IV_LENGTH)
            ciphertext = aesgcm.encrypt(iv, key, None)
            return iv + ciphertext
        except Exception:
            return None
    
    def _decrypt_key(self, encrypted_data: bytes) -> Optional[bytes]:
        if len(encrypted_data) < self.IV_LENGTH + 16:  # IV + minimum tag
            return None
            
        try:
            iv = encrypted_data[:self.IV_LENGTH]
            ciphertext = encrypted_data[self.IV_LENGTH:]
            aesgcm = AESGCM(self.master_key)
            return aesgcm.decrypt(iv, ciphertext, None)
        except Exception:
            return None

def main():
    key_manager = KeyManager()
    
    # Test 1: Initialize master key
    initialized = key_manager.initialize_master_key("TestPassphrase123!")
    print(f"Test 1 - Master key initialized: {initialized}")
    
    # Test 2: Generate new key
    key_id1 = key_manager.generate_key("database-key")
    print(f"Test 2 - Generated key ID: {'Success' if key_id1 else 'Failed'}")
    
    # Test 3: Retrieve key
    retrieved_key = key_manager.retrieve_key("database-key")
    print(f"Test 3 - Retrieved key: {'Success' if retrieved_key and len(retrieved_key) == KeyManager.KEY_LENGTH else 'Failed'}")
    
    # Test 4: List keys
    key_manager.generate_key("api-key")
    key_manager.generate_key("session-key")
    keys = key_manager.list_keys()
    print(f"Test 4 - Listed keys count: {len(keys)}")
    
    # Test 5: Delete key
    deleted = key_manager.delete_key("api-key")
    print(f"Test 5 - Key deleted: {deleted}")
    print(f"Final key count: {len(key_manager.list_keys())}")

if __name__ == "__main__":
    main()
