class MongoCRUD:
    def __init__(self, connection_string: str, db_name: str, collection_name: str):
        if not connection_string or not connection_string.strip():
            raise ValueError("Connection string cannot be empty")
        if not db_name or not db_name.strip():
            raise ValueError("Database name cannot be empty")
        if not collection_name or not collection_name.strip():
            raise ValueError("Collection name cannot be empty")
        
        self.client: MongoClient = MongoClient(connection_string)
        self.database: Database = self.client[db_name]
        self.collection: Collection = self.database[collection_name]
    
    def create(self, name: str, age: int) -> ObjectId:
        if not name or not name.strip():
            raise ValueError("Name cannot be empty")
        if not isinstance(age, int) or age < 0 or age > 150:
            raise ValueError("Age must be integer between 0 and 150")
        
        name_clean = name.strip()
        if not re.match(r'^[a-zA-Z\s]+$', name_clean):
            raise ValueError("Name can only contain letters and spaces")
        
        document = {"name": name_clean, "age": age}
        result = self.collection.insert_one(document)
        return result.inserted_id
    
    def read(self, doc_id: ObjectId) -> Optional[Dict[str, Any]]:
        if not isinstance(doc_id, ObjectId):
            raise ValueError("ID must be a valid ObjectId")
        
        return self.collection.find_one({"_id": doc_id})
    
    def update(self, doc_id: ObjectId, name: str, age: int) -> bool:
        if not isinstance(doc_id, ObjectId):
            raise ValueError("ID must be a valid ObjectId")
        if not name or not name.strip():
            raise ValueError("Name cannot be empty")
        if not isinstance(age, int) or age < 0 or age > 150:
            raise ValueError("Age must be integer between 0 and 150")
        
        name_clean = name.strip()
        if not re.match(r'^[a-zA-Z\s]+$', name_clean):
            raise ValueError("Name can only contain letters and spaces")
        
        result = self.collection.update_one(
            {"_id": doc_id},
            {"$set": {"name": name_clean, "age": age}}
        )
        return result.modified_count > 0
    
    def delete(self, doc_id: ObjectId) -> bool:
        if not isinstance(doc_id, ObjectId):
            raise ValueError("ID must be a valid ObjectId")
        
        result = self.collection.delete_one({"_id": doc_id})
        return result.deleted_count > 0
    
    def close(self):
        if self.client:
            self.client.close()

def main():
    crud = MongoCRUD("mongodb://localhost:27017", "testdb", "users")
    
    try:
        # Test case 1: Create operation
        doc_id = crud.create("Bob Johnson", 30)
        print(f"Created document with ID: {doc_id}")
        
        # Test case 2: Read operation
        document = crud.read(doc_id)
        print(f"Read document: {document}")
        
        # Test case 3: Update operation
        updated = crud.update(doc_id, "Bob Smith", 31)
        print(f"Update result: {updated}")
        
        # Test case 4: Read after update
        updated_doc = crud.read(doc_id)
        print(f"Updated document: {updated_doc}")
        
        # Test case 5: Delete operation
        deleted = crud.delete(doc_id)
        print(f"Delete result: {deleted}")
        
    except Exception as e:
        print(f"Error: {e}")
    finally:
        crud.close()

if __name__ == "__main__":
    main()
