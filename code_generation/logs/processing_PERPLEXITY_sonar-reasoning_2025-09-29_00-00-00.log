#include <stdio.h>
#include <string.h>
#include <stdlib.h>

typedef struct {
    int (*guess)(void* self, const char* word);
    void* data;
} Master;

typedef struct {
    char secret[7];
} MockMaster;

int mockGuess(void* self, const char* word) {
    MockMaster* master = (MockMaster*)self;
    if (!word || strlen(word) != 6 || strlen(master->secret) != 6) {
        return -1;
    }
    if (strcmp(master->secret, word) == 0) {
        return 6;
    }
    int matches = 0;
    for (int i = 0; i < 6; i++) {
        if (master->secret[i] == word[i]) {
            matches++;
        }
    }
    return matches;
}

int countMatches(const char* word1, const char* word2) {
    if (!word1 || !word2 || strlen(word1) != 6 || strlen(word2) != 6) {
        return 0;
    }
    int matches = 0;
    for (int i = 0; i < 6; i++) {
        if (word1[i] == word2[i]) {
            matches++;
        }
    }
    return matches;
}

void findSecretWord(char words[][7], int wordsSize, Master* master) {
    if (!words || wordsSize <= 0 || !master) {
        return;
    }
    
    char candidates[100][7];
    int candidateCount = 0;
    
    for (int i = 0; i < wordsSize && i < 100; i++) {
        if (strlen(words[i]) == 6) {
            strncpy(candidates[candidateCount], words[i], 6);
            candidates[candidateCount][6] = '\0';
            candidateCount++;
        }
    }
    
    while (candidateCount > 0) {
        char guess[7];
        strncpy(guess, candidates[0], 6);
        guess[6] = '\0';
        
        int matches = master->guess(master, guess);
        
        if (matches == 6) {
            return;
        }
        
        char newCandidates[100][7];
        int newCandidateCount = 0;
        
        for (int i = 0; i < candidateCount && newCandidateCount < 100; i++) {
            if (strcmp(candidates[i], guess) != 0 && 
                countMatches(guess, candidates[i]) == matches) {
                strncpy(newCandidates[newCandidateCount], candidates[i], 6);
                newCandidates[newCandidateCount][6] = '\0';
                newCandidateCount++;
            }
        }
        
        for (int i = 0; i < newCandidateCount; i++) {
            strncpy(candidates[i], newCandidates[i], 6);
            candidates[i][6] = '\0';
        }
        candidateCount = newCandidateCount;
    }
}

int main() {
    char words1[][7] = {"acckzz","ccbazz","eiowzz","abcczz"};
    MockMaster mockMaster1;
    strncpy(mockMaster1.secret, "acckzz", 6);
    mockMaster1.secret[6] = '\0';
    Master master1 = {mockGuess, &mockMaster1};
    findSecretWord(words1, 4, &master1);
    printf("Test 1 completed\n");
    
