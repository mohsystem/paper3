import socket
import secrets
import hashlib
import base64
import threading
import time
import os
from pathlib import Path
from typing import Dict, Optional
from cryptography.hazmat.primitives.ciphers.aead import AESGCM
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC

class ChatServer:
    def __init__(self):
        self.users_file = "users.enc"
        self.port = 8080
        self.users: Dict[str, bytes] = {}
        self.magic = b"ENC1"
        self.version = 1
        self.salt_length = 16
        self.iv_length = 12
        self.tag_length = 16
        self.iterations = 210000
        
    def start_server(self):
        self.load_users()
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as server_socket:
            server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            server_socket.bind(("localhost", self.port))
            server_socket.listen(5)
            
            while True:
                try:
                    client_socket, _ = server_socket.accept()
                    self.handle_client(client_socket)
                except Exception as e:
                    print(f"Server error: {e}")
    
    def handle_client(self, client_socket: socket.socket):
        try:
            with client_socket:
                request = client_socket.recv(1024).decode('utf-8')
                if len(request) <= 1000:
                    parts = request.split(":", 2)
                    if len(parts) == 3 and parts[0] == "LOGIN":
                        username, password = parts[1], parts[2]
                        if self.validate_input(username) and self.validate_input(password):
                            authenticated = self.authenticate(username, password)
                            response = "SUCCESS" if authenticated else "FAILURE"
                        else:
                            response = "INVALID_INPUT"
                    else:
                        response = "INVALID_REQUEST"
                else:
                    response = "REQUEST_TOO_LONG"
                
                client_socket.send(response.encode('utf-8'))
        except Exception as e:
            print(f"Client handling error: {e}")
    
    def validate_input(self, input_str: str) -> bool:
        if not input_str or len(input_str) < 1 or len(input_str) > 50:
            return False
        return input_str.replace('_', '').replace('-', '').isalnum()
    
    def authenticate(self, username: str, password: str) -> bool:
        stored_data = self.users.get(username)
        if not stored_data:
            return False
        
        try:
            salt = stored_data[:self.salt_length]
            expected_hash = stored_data[self.salt_length:]
            actual_hash = self.hash_password(password, salt)
            return secrets.compare_digest(expected_hash, actual_hash)
        except Exception:
            return False
    
    def hash_password(self, password: str, salt: bytes) -> bytes:
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=self.iterations,
        )
        return kdf.derive(password.encode('utf-8'))
    
    def add_user(self, username: str, password: str):
        try:
            salt = secrets.token_bytes(self.salt_length)
            password_hash = self.hash_password(password, salt)
            combined = salt + password_hash
            self.users[username] = combined
            self.save_users()
        except Exception as e:
            print(f"Error adding user: {e}")
    
    def load_users(self):
        if not Path(self.users_file).exists():
            return
        
        try:
            data = self.decrypt_file(self.users_file, "defaultpass")
            content = data.decode('utf-8')
            for line in content.strip().split('\n'):
                if line:
                    parts = line.split(':', 1)
                    if len(parts) == 2:
                        self.users[parts[0]] = base64.b64decode(parts[1])
        except Exception as e:
            print(f"Error loading users: {e}")
    
    def save_users(self):
        try:
            lines = []
            for username, data in self.users.items():
                encoded_data = base64.b64encode(data).decode('ascii')
                lines.append(f"{username}:{encoded_data}")
            content = '\n'.join(lines).encode('utf-8')
            self.encrypt_file(self.users_file, content, "defaultpass")
        except Exception as e:
            print(f"Error saving users: {e}")
    
    def encrypt_file(self, filename: str, data: bytes, passphrase: str):
        salt = secrets.token_bytes(self.salt_length)
        iv = secrets.token_bytes(self.iv_length)
        
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=self.iterations,
        )
        key = kdf.derive(passphrase.encode('utf-8'))
        
        aesgcm = AESGCM(key)
        ciphertext = aesgcm.encrypt(iv, data, None)
        
        temp_file = filename + ".tmp"
        with open(temp_file, 'wb') as f:
            f.write(self.magic)
            f.write(self.version.to_bytes(1, 'big'))
            f.write(salt)
            f.write(iv)
            f.write(ciphertext)
            f.flush()
            os.fsync(f.fileno())
        
        Path(temp_file).rename(filename)
    
    def decrypt_file(self, filename: str, passphrase: str) -> bytes:
        with open(filename, 'rb') as f:
            magic = f.read(4)
            if magic != self.magic:
                raise ValueError("Invalid file format")
            
            version = int.from_bytes(f.read(1), 'big')
            if version != self.version:
                raise ValueError("Unsupported version")
            
            salt = f.read(self.salt_length)
            iv = f.read(self.iv_length)
            ciphertext = f.read()
            
            if len(salt) != self.salt_length or len(iv) != self.iv_length:
                raise ValueError("Incomplete file")
            
            kdf = PBKDF2HMAC(
                algorithm=hashes.SHA256(),
                length=32,
                salt=salt,
                iterations=self.iterations,
            )
            key = kdf.derive(passphrase.encode('utf-8'))
            
