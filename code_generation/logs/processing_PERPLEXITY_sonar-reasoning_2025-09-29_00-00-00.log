from typing import Optional, Dict

DNS_RECORDS: Dict[str, str] = {
    'example.com': '93.184.216.34',
    'google.com': '142.250.191.14',
    'localhost': '127.0.0.1'
}

def create_dns_server(address: str, port: int) -> None:
    if not (1 <= port <= 65535):
        raise ValueError("Invalid port number")
    
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.bind((address, port))
        print(f"DNS Server listening on {address}:{port}")
        
        while True:
            try:
                data, addr = sock.recvfrom(512)
                response = process_dns_query(data)
                if response:
                    sock.sendto(response, addr)
            except Exception as e:
                print(f"Error processing request: {e}")

def process_dns_query(data: bytes) -> Optional[bytes]:
    if len(data) < 12:
        return None
    
    transaction_id, flags, question_count, answer_count, authority_count, additional_count = struct.unpack('HHHHHH', data[:12])
    
    if question_count != 1:
        return None
    
    offset = 12
    domain, offset = parse_domain_name(data, offset)
    if domain is None or offset + 4 > len(data):
        return None
    
    query_type, query_class = struct.unpack('HH', data[offset:offset+4])
    
    if query_type != 1 or query_class != 1:
        return None
    
    ip_address = DNS_RECORDS.get(domain.lower())
    if ip_address is None:
        return None
    
    return build_dns_response(transaction_id, domain, ip_address)

