import javax.crypto.*;
import javax.crypto.spec.*;
import java.security.SecureRandom;
import java.security.NoSuchAlgorithmException;
import java.security.InvalidKeyException;
import java.security.InvalidAlgorithmParameterException;
import java.util.*;
import java.util.concurrent.ConcurrentHashMap;
import java.nio.charset.StandardCharsets;
import java.util.Arrays;

public class Task134 {
    private static final String CIPHER_ALGORITHM = "AES/GCM/NoPadding";
    private static final String KDF_ALGORITHM = "PBKDF2WithHmacSHA256";
    private static final int KEY_LENGTH = 32;
    private static final int IV_LENGTH = 12;
    private static final int SALT_LENGTH = 16;
    private static final int TAG_LENGTH = 16;
    private static final int KDF_ITERATIONS = 210000;
    
    private final SecureRandom secureRandom;
    private final Map<String, byte[]> keyStore;
    private byte[] masterKey;
    
    public Task134() {
        this.secureRandom = new SecureRandom();
        this.keyStore = new ConcurrentHashMap<>();
    }
    
    public boolean initializeMasterKey(String passphrase) {
        if (passphrase == null || passphrase.length() < 8) {
            return false;
        }
        
        try {
            byte[] salt = new byte[SALT_LENGTH];
            secureRandom.nextBytes(salt);
            
            SecretKeyFactory factory = SecretKeyFactory.getInstance(KDF_ALGORITHM);
            PBEKeySpec spec = new PBEKeySpec(passphrase.toCharArray(), salt, KDF_ITERATIONS, KEY_LENGTH * 8);
            SecretKey tmp = factory.generateSecret(spec);
            this.masterKey = tmp.getEncoded();
            
            Arrays.fill(spec.getPassword(), '\0');
            return true;
        } catch (Exception e) {
            return false;
        }
    }
    
    public String generateKey(String keyId) {
        if (keyId == null || keyId.trim().isEmpty() || masterKey == null) {
            return null;
        }
        
        try {
            byte[] key = new byte[KEY_LENGTH];
            secureRandom.nextBytes(key);
            
            byte[] encryptedKey = encryptKey(key);
            if (encryptedKey != null) {
                keyStore.put(keyId.trim(), encryptedKey);
                Arrays.fill(key, (byte) 0);
                return keyId.trim();
            }
        } catch (Exception e) {
            return null;
        }
        return null;
    }
    
    public byte[] retrieveKey(String keyId) {
        if (keyId == null || masterKey == null) {
            return null;
        }
        
        byte[] encryptedKey = keyStore.get(keyId.trim());
        if (encryptedKey == null) {
            return null;
        }
        
        return decryptKey(encryptedKey);
    }
    
    public boolean deleteKey(String keyId) {
        if (keyId == null) {
            return false;
        }
        return keyStore.remove(keyId.trim()) != null;
    }
    
    public Set<String> listKeys() {
        return new HashSet<>(keyStore.keySet());
    }
    
    private byte[] encryptKey(byte[] key) {
        try {
            Cipher cipher = Cipher.getInstance(CIPHER_ALGORITHM);
            SecretKeySpec keySpec = new SecretKeySpec(masterKey, "AES");
            
            byte[] iv = new byte[IV_LENGTH];
            secureRandom.nextBytes(iv);
            
            GCMParameterSpec gcmSpec = new GCMParameterSpec(TAG_LENGTH * 8, iv);
            cipher.init(Cipher.ENCRYPT_MODE, keySpec, gcmSpec);
            
            byte[] ciphertext = cipher.doFinal(key);
            
            byte[] result = new byte[IV_LENGTH + ciphertext.length];
            System.arraycopy(iv, 0, result, 0, IV_LENGTH);
            System.arraycopy(ciphertext, 0, result, IV_LENGTH, ciphertext.length);
            
            return result;
        } catch (Exception e) {
            return null;
        }
    }
    
    private byte[] decryptKey(byte[] encryptedData) {
        if (encryptedData.length < IV_LENGTH + TAG_LENGTH) {
            return null;
        }
        
        try {
            byte[] iv = Arrays.copyOfRange(encryptedData, 0, IV_LENGTH);
            byte[] ciphertext = Arrays.copyOfRange(encryptedData, IV_LENGTH, encryptedData.length);
            
            Cipher cipher = Cipher.getInstance(CIPHER_ALGORITHM);
            SecretKeySpec keySpec = new SecretKeySpec(masterKey, "AES");
            GCMParameterSpec gcmSpec = new GCMParameterSpec(TAG_LENGTH * 8, iv);
            
            cipher.init(Cipher.DECRYPT_MODE, keySpec, gcmSpec);
            return cipher.doFinal(ciphertext);
        } catch (Exception e) {
            return null;
        }
    }
    
    public static void main(String[] args) {
        Task134 keyManager = new Task134();
        
        // Test 1: Initialize master key
        boolean initialized = keyManager.initializeMasterKey("TestPassphrase123!");
        System.out.println("Test 1 - Master key initialized: " + initialized);
        
        // Test 2: Generate new key
        String keyId1 = keyManager.generateKey("database-key");
        System.out.println("Test 2 - Generated key ID: " + (keyId1 != null ? "Success" : "Failed"));
        
        // Test 3: Retrieve key
        byte[] retrievedKey = keyManager.retrieveKey("database-key");
        System.out.println("Test 3 - Retrieved key: " + (retrievedKey != null && retrievedKey.length == KEY_LENGTH ? "Success" : "Failed"));
        
        // Test 4: List keys
        keyManager.generateKey("api-key");
        keyManager.generateKey("session-key");
        Set<String> keys = keyManager.listKeys();
        System.out.println("Test 4 - Listed keys count: " + keys.size());
        
        // Test 5: Delete key
        boolean deleted = keyManager.deleteKey("api-key");
        System.out.println("Test 5 - Key deleted: " + deleted);
        System.out.println("Final key count: " + keyManager.listKeys().size());
    }
}
