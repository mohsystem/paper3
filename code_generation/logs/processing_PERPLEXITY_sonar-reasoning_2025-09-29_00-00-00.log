        int[] nums3 = {1, 2, 3};
        System.out.println(countRangeSum(nums3, 3, 5)); // Multiple valid ranges
        
        int[] nums4 = {-1, -1, -1};
        System.out.println(countRangeSum(nums4, -3, -1)); // Negative number scenarios
    }
}
