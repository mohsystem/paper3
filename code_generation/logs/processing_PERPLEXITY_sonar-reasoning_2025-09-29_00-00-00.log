```python
from collections import defaultdict, deque
from typing import Dict, List, Set

def reparent_tree(tree: Dict[int, List[int]], new_root: int) -> Dict[int, List[int]]:
    if not tree or new_root not in tree:
        return {}
    
    result = defaultdict(list)
    visited: Set[int] = set()
    queue = deque([new_root])
    visited.add(new_root)
    
    while queue:
        current = queue.popleft()
        
        for neighbor in tree.get(current, []):
            if neighbor not in visited:
                visited.add(neighbor)
                result[current].append(neighbor)
                queue.append(neighbor)
    
    return dict(result)

def main():
    # Test case 1: Example from problem
    tree1 = {
        0: [1, 2, 3],
        1: [0, 4, 5],
        2: [0, 6, 7],
        3: [0, 8, 9],
        4: [1],
        5: [1],
        6: [2],
        7: [2],
        8: [3],
        9: [3]
    }
    print("Test 1:", reparent_tree(tree1, 6))
    
    # Test case 2: Single node
    tree2 = {1: []}
    print("Test 2:", reparent_tree(tree2, 1))
    
    # Test case 3: Two nodes
    tree3 = {1: [2], 2: [1]}
    print("Test 3:", reparent_tree(tree3, 2))
    
    # Test case 4: Empty tree
    print("Test 4:", reparent_tree({}, 1))
    
    # Test case 5: Linear tree
    tree5 = {1: [2], 2: [1, 3], 3: [2, 4], 4: [3]}
    print("Test 5:", reparent_tree(tree5, 3))

if __name__ == "__main__":
    main()
