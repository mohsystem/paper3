```java
import java.util.regex.Pattern;

public class Task182 {
    public static String cleanPhoneNumber(String phoneNumber) {
        if (phoneNumber == null || phoneNumber.isEmpty()) {
            throw new IllegalArgumentException("Phone number cannot be null or empty");
        }
        
        if (phoneNumber.length() > 20) {
            throw new IllegalArgumentException("Phone number too long");
        }
        
        // Remove all non-digit characters except + at start
        String cleaned = phoneNumber.replaceAll("[^+\\d]", "");
        
        // Remove country code if present
        if (cleaned.startsWith("+1")) {
            cleaned = cleaned.substring(2);
        } else if (cleaned.startsWith("1") && cleaned.length() == 11) {
            cleaned = cleaned.substring(1);
        }
        
        // Validate NANP format
        if (cleaned.length() != 10) {
            throw new IllegalArgumentException("Invalid phone number length");
        }
        
        // Check NANP format: first digit of area code (2-9), first digit of exchange (2-9)
        if (cleaned.charAt(0) < '2' || cleaned.charAt(0) > '9') {
            throw new IllegalArgumentException("Invalid area code");
        }
        if (cleaned.charAt(3) < '2' || cleaned.charAt(3) > '9') {
            throw new IllegalArgumentException("Invalid exchange code");
        }
        
        // Ensure all characters are digits
        for (char c : cleaned.toCharArray()) {
            if (c < '0' || c > '9') {
                throw new IllegalArgumentException("Invalid character in phone number");
            }
        }
        
        return cleaned;
    }
    
    public static void main(String[] args) {
        String[] testCases = {
            "+1 (613)-995-0253",
            "613-995-0253", 
            "1 613 995 0253",
            "613.995.0253",
            "(613) 995-0253"
        };
        
        for (String test : testCases) {
            try {
                System.out.println("Input: " + test + " -> Output: " + cleanPhoneNumber(test));
            } catch (Exception e) {
                System.out.println("Input: " + test + " -> Error: " + e.getMessage());
            }
        }
    }
}
```

