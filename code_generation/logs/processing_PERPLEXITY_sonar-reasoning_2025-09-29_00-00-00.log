import java.util.*;

public class Task183 {
    public static long largestProduct(String input, int span) {
        // Input validation
        if (input == null || input.isEmpty()) {
            throw new IllegalArgumentException("Input cannot be null or empty");
        }
        if (span <= 0) {
            throw new IllegalArgumentException("Span must be positive");
        }
        if (span > input.length()) {
            throw new IllegalArgumentException("Span cannot be larger than input length");
        }
        
        // Validate input contains only digits
        for (int i = 0; i < input.length(); i++) {
            if (!Character.isDigit(input.charAt(i))) {
                throw new IllegalArgumentException("Input must contain only digits");
            }
        }
        
        long maxProduct = 0;
        
        // Iterate through input to find maximum product of consecutive digits
        for (int i = 0; i <= input.length() - span; i++) {
            long product = 1;
            for (int j = i; j < i + span; j++) {
                int digit = Character.getNumericValue(input.charAt(j));
                product *= digit;
            }
            maxProduct = Math.max(maxProduct, product);
        }
        
        return maxProduct;
    }
    
