#include <mongoc/mongoc.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

typedef struct {
    mongoc_client_t *client;
    mongoc_collection_t *collection;
} mongo_crud_t;

int validate_name(const char *name) {
    if (!name || strlen(name) == 0) return 0;
    
    size_t len = strlen(name);
    if (len > 100) return 0;
    
    for (size_t i = 0; i < len; i++) {
        if (!isalpha(name[i]) && !isspace(name[i])) {
            return 0;
        }
    }
    return 1;
}

int validate_age(int age) {
    return age >= 0 && age <= 150;
}

void trim_string(char *str) {
    if (!str) return;
    
    char *end = str + strlen(str) - 1;
    while (end > str && isspace(*end)) end--;
    end[1] = '\0';
    
    char *start = str;
    while (*start && isspace(*start)) start++;
    
    if (start != str) {
        memmove(str, start, strlen(start) + 1);
    }
}

mongo_crud_t* mongo_crud_init(const char *uri, const char *db_name, const char *coll_name) {
    if (!uri || !db_name || !coll_name) {
        return NULL;
    }
    
    mongo_crud_t *crud = malloc(sizeof(mongo_crud_t));
    if (!crud) return NULL;
    
    mongoc_init();
    
    crud->client = mongoc_client_new(uri);
    if (!crud->client) {
        free(crud);
        return NULL;
    }
    
    crud->collection = mongoc_client_get_collection(crud->client, db_name, coll_name);
    if (!crud->collection) {
        mongoc_client_destroy(crud->client);
        free(crud);
        return NULL;
    }
    
    return crud;
}

int mongo_crud_create(mongo_crud_t *crud, const char *name, int age, bson_oid_t *out_id) {
    if (!crud || !name || !validate_name(name) || !validate_age(age) || !out_id) {
        return 0;
    }
    
    char name_copy[256];
    if (strlen(name) >= sizeof(name_copy)) return 0;
    
    strcpy(name_copy, name);
    trim_string(name_copy);
    
    if (!validate_name(name_copy)) return 0;
    
    bson_t *doc = bson_new();
    bson_oid_t oid;
    bson_oid_init(&oid, NULL);
    
    BSON_APPEND_OID(doc, "_id", &oid);
    BSON_APPEND_UTF8(doc, "name", name_copy);
    BSON_APPEND_INT32(doc, "age", age);
    
    bson_error_t error;
    bool result = mongoc_collection_insert_one(crud->collection, doc, NULL, NULL, &error);
    
    if (result) {
        *out_id = oid;
    }
    
    bson_destroy(doc);
    return result ? 1 : 0;
}

bson_t* mongo_crud_read(mongo_crud_t *crud, const bson_oid_t *id) {
    if (!crud || !id) return NULL;
    
    bson_t *query = bson_new();
    BSON_APPEND_OID(query, "_id", id);
    
    mongoc_cursor_t *cursor = mongoc_collection_find_with_opts(crud->collection, query, NULL, NULL);
    const bson_t *doc;
    bson_t *result = NULL;
    
    if (mongoc_cursor_next(cursor, &doc)) {
        result = bson_copy(doc);
    }
    
    mongoc_cursor_destroy(cursor);
    bson_destroy(query);
    return result;
}

