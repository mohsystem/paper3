```java
interface MountainArray {
    int get(int index);
    int length();
}

class ConcreteMountainArray implements MountainArray {
    private final int[] array;
    
    public ConcreteMountainArray(int[] array) {
        if (array == null) {
            throw new IllegalArgumentException("Array cannot be null");
        }
        this.array = array.clone();
    }
    
    public int get(int index) {
        if (index < 0 || index >= array.length) {
            throw new IndexOutOfBoundsException("Index out of bounds: " + index);
        }
        return array[index];
    }
    
    public int length() {
        return array.length;
    }
}

public class Task175 {
    public int findInMountainArray(int target, MountainArray mountainArr) {
        if (mountainArr == null) {
            return -1;
        }
        
        int n = mountainArr.length();
        if (n < 3) {
            return -1;
        }
        
        int peak = findPeak(mountainArr, n);
        
        int result = binarySearchAsc(mountainArr, target, 0, peak);
        if (result != -1) {
            return result;
        }
        
        return binarySearchDesc(mountainArr, target, peak + 1, n - 1);
    }
    
    private int findPeak(MountainArray arr, int n) {
        int left = 1, right = n - 2;
        while (left < right) {
            int mid = left + (right - left) / 2;
            if (arr.get(mid) < arr.get(mid + 1)) {
                left = mid + 1;
            } else {
                right = mid;
            }
        }
        return left;
    }
    
    private int binarySearchAsc(MountainArray arr, int target, int left, int right) {
        while (left <= right) {
            int mid = left + (right - left) / 2;
            int val = arr.get(mid);
            if (val == target) {
                return mid;
            } else if (val < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        return -1;
    }
    
    private int binarySearchDesc(MountainArray arr, int target, int left, int right) {
        while (left <= right) {
            int mid = left + (right - left) / 2;
            int val = arr.get(mid);
            if (val == target) {
                return mid;
            } else if (val > target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        return -1;
    }
    
    public static void main(String[] args) {
        Task175 solution = new Task175();
        
        int[] arr1 = {1, 2, 3, 4, 5, 3, 1};
        ConcreteMountainArray ma1 = new ConcreteMountainArray(arr1);
        System.out.println(solution.findInMountainArray(3, ma1));
        
        int[] arr2 = {0, 1, 2, 4, 2, 1};
        ConcreteMountainArray ma2 = new ConcreteMountainArray(arr2);
        System.out.println(solution.findInMountainArray(3, ma2));
        
        int[] arr3 = {1, 2, 3, 4, 5, 6, 4, 3, 2, 1};
        ConcreteMountainArray ma3 = new ConcreteMountainArray(arr3);
