        tree1.put(1, Arrays.asList(0, 4, 5));
        tree1.put(2, Arrays.asList(0, 6, 7));
        tree1.put(3, Arrays.asList(0, 8, 9));
        tree1.put(4, Arrays.asList(1));
        tree1.put(5, Arrays.asList(1));
        tree1.put(6, Arrays.asList(2));
        tree1.put(7, Arrays.asList(2));
        tree1.put(8, Arrays.asList(3));
        tree1.put(9, Arrays.asList(3));
        
        Map<Integer, List<Integer>> result1 = reparentTree(tree1, 6);
        System.out.println("Test 1 - Reparent from 6: " + result1);
        
        // Test case 2: Linear tree
        Map<Integer, List<Integer>> tree2 = new HashMap<>();
        tree2.put(1, Arrays.asList(2));
        tree2.put(2, Arrays.asList(1, 3));
        tree2.put(3, Arrays.asList(2, 4));
        tree2.put(4, Arrays.asList(3));
        
        Map<Integer, List<Integer>> result2 = reparentTree(tree2, 3);
        System.out.println("Test 2 - Reparent from 3: " + result2);
        
        // Test case 3: Single node
        Map<Integer, List<Integer>> tree3 = new HashMap<>();
        tree3.put(1, new ArrayList<>());
        
        Map<Integer, List<Integer>> result3 = reparentTree(tree3, 1);
