def xor_game(nums):
    if not nums:
        return True
    
    xor_result = 0
    for num in nums:
        xor_result ^= num
    
    return xor_result == 0 or len(nums) % 2 == 0

def main():
    # Test case 1
    nums1 = [1, 1, 2]
    print(xor_game(nums1))  # False
    
    # Test case 2
    nums2 = [0, 1] 
    print(xor_game(nums2))  # True
    
    # Test case 3
    nums3 = [1, 2, 3]
    print(xor_game(nums3))  # True
    
    # Test case 4
    nums4 = [1]
    print(xor_game(nums4))  # False
    
    # Test case 5
