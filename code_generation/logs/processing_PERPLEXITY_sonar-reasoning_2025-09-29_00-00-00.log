#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/kdf.h>
#include <openssl/err.h>
#include <map>
#include <string>
#include <vector>
#include <set>
#include <memory>
#include <iostream>
#include <cstring>

class KeyManager {
private:
    static constexpr size_t KEY_LENGTH = 32;
    static constexpr size_t IV_LENGTH = 12;
    static constexpr size_t SALT_LENGTH = 16;
    static constexpr size_t TAG_LENGTH = 16;
    static constexpr int KDF_ITERATIONS = 210000;
    
    std::map<std::string, std::vector<unsigned char>> keyStore;
    std::vector<unsigned char> masterKey;
    
    std::vector<unsigned char> encryptKey(const std::vector<unsigned char>& key) {
        if (masterKey.empty() || key.size() != KEY_LENGTH) {
            return {};
        }
        
        std::vector<unsigned char> iv(IV_LENGTH);
        if (RAND_bytes(iv.data(), IV_LENGTH) != 1) {
            return {};
        }
        
        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) return {};
        
        std::vector<unsigned char> result;
        
        if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, masterKey.data(), iv.data()) == 1) {
            std::vector<unsigned char> ciphertext(key.size() + TAG_LENGTH);
            int len;
            
            if (EVP_EncryptUpdate(ctx, ciphertext.data(), &len, key.data(), key.size()) == 1) {
                int ciphertext_len = len;
                
                if (EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len) == 1) {
                    ciphertext_len += len;
                    
                    std::vector<unsigned char> tag(TAG_LENGTH);
                    if (EVP_CIPHER_CTK_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_LENGTH, tag.data()) == 1) {
                        result.insert(result.end(), iv.begin(), iv.end());
                        result.insert(result.end(), ciphertext.begin(), ciphertext.begin() + ciphertext_len);
                        result.insert(result.end(), tag.begin(), tag.end());
                    }
                }
            }
        }
        
        EVP_CIPHER_CTX_free(ctx);
        return result;
    }
    
    std::vector<unsigned char> decryptKey(const std::vector<unsigned char>& encryptedData) {
        if (masterKey.empty() || encryptedData.size() < IV_LENGTH + TAG_LENGTH) {
            return {};
        }
        
        std::vector<unsigned char> iv(encryptedData.begin(), encryptedData.begin() + IV_LENGTH);
        std::vector<unsigned char> ciphertext(encryptedData.begin() + IV_LENGTH, 
                                            encryptedData.end() - TAG_LENGTH);
        std::vector<unsigned char> tag(encryptedData.end() - TAG_LENGTH, encryptedData.end());
        
        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) return {};
        
        std::vector<unsigned char> plaintext(ciphertext.size());
        
        if (EVP_DecryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, masterKey.data(), iv.data()) == 1) {
            if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_TAG, TAG_LENGTH, tag.data()) == 1) {
                int len;
                if (EVP_DecryptUpdate(ctx, plaintext.data(), &len, ciphertext.data(), ciphertext.size()) == 1) {
                    int plaintext_len = len;
                    
                    if (EVP_DecryptFinal_ex(ctx, plaintext.data() + len, &len) == 1) {
                        plaintext_len += len;
                        plaintext.resize(plaintext_len);
                        EVP_CIPHER_CTX_free(ctx);
                        return plaintext;
                    }
                }
            }
        }
        
        EVP_CIPHER_CTX_free(ctx);
        return {};
    }
    
public:
    KeyManager() {
        ERR_load_crypto_strings();
        OpenSSL_add_all_algorithms();
    }
    
    ~KeyManager() {
        if (!masterKey.empty()) {
            OPENSSL_cleanse(masterKey.data(), masterKey.size());
        }
    }
    
    bool initializeMasterKey(const std::string& passphrase) {
        if (passphrase.length() < 8) {
            return false;
        }
        
        std::vector<unsigned char> salt(SALT_LENGTH);
        if (RAND_bytes(salt.data(), SALT_LENGTH) != 1) {
            return false;
        }
        
        masterKey.resize(KEY_LENGTH);
        
        if (PKCS5_PBKDF2_HMAC(passphrase.c_str(), passphrase.length(),
                             salt.data(), SALT_LENGTH,
                             KDF_ITERATIONS, EVP_sha256(),
                             KEY_LENGTH, masterKey.data()) == 1) {
            return true;
        }
        
        masterKey.clear();
        return false;
    }
    
    std::string generateKey(const std::string& keyId) {
        if (keyId.empty() || masterKey.empty()) {
            return "";
        }
        
        std::vector<unsigned char> key(KEY_LENGTH);
        if (RAND_bytes(key.data(), KEY_LENGTH) != 1) {
            return "";
        }
        
        auto encryptedKey = encryptKey(key);
        OPENSSL_cleanse(key.data(), key.size());
        
        if (!encryptedKey.empty()) {
            keyStore[keyId] = std::move(encryptedKey);
            return keyId;
        }
        
        return "";
    }
    
    std::vector<unsigned char> retrieveKey(const std::string& keyId) {
        if (keyId.empty() || masterKey.empty()) {
            return {};
        }
        
        auto it = keyStore.find(keyId);
        if (it == keyStore.end()) {
            return {};
        }
        
        return decryptKey(it->second);
    }
    
    bool deleteKey(const std::string& keyId) {
        if (keyId.empty()) {
            return false;
        }
        return keyStore.erase(keyId) > 0;
    }
    
    std::set<std::string> listKeys() const {
        std::set<std::string> keys;
        for (const auto& pair : keyStore) {
            keys.insert(pair.first);
        }
        return keys;
    }
};

