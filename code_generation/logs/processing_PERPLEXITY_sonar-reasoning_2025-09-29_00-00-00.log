```python
from typing import List
import os
from pathlib import Path

def transpose_file(filename: str) -> str:
    try:
        if not filename or not filename.strip():
            return "Error: Invalid filename"
        
        path = Path(filename)
        if not path.exists() or not path.is_file():
            return "Error: File does not exist or is not a regular file"
        
        with open(filename, 'r', encoding='utf-8') as file:
            lines = file.readlines()
        
        if not lines:
            return ""
        
        matrix: List[List[str]] = []
        expected_cols = -1
        
        for line in lines:
            line = line.strip()
            if not line:
                continue
            fields = line.split()
            if expected_cols == -1:
                expected_cols = len(fields)
            elif len(fields) != expected_cols:
                return "Error: Inconsistent number of columns"
            matrix.append(fields)
        
        if not matrix:
            return ""
        
        result = []
        for col in range(expected_cols):
            row_data = []
            for row in range(len(matrix)):
                row_data.append(matrix[row][col])
            result.append(" ".join(row_data))
        
        return "\n".join(result)
    
    except Exception as e:
        return f"Error: {e}"

def main():
    # Test case 1: Basic example
    try:
        with open("test1.txt", "w", encoding="utf-8") as f:
            f.write("name age\n")
            f.write("alice 21\n")
            f.write("ryan 30\n")
    except Exception:
        print("Test 1 setup failed")
    
    print("Test 1:")
    print(transpose_file("test1.txt"))
    print()
    
    # Test case 2: Single row
    try:
        with open("test2.txt", "w", encoding="utf-8") as f:
            f.write("a b c\n")
    except Exception:
        print("Test 2 setup failed")
    
    print("Test 2:")
    print(transpose_file("test2.txt"))
    print()
    
    # Test case 3: Single column
    try:
        with open("test3.txt", "w", encoding="utf-8") as f:
            f.write("a\n")
            f.write("b\n")
            f.write("c\n")
    except Exception:
        print("Test 3 setup failed")
    
    print("Test 3:")
    print(transpose_file("test3.txt"))
    print()
    
    # Test case 4: Empty file
    try:
        with open("test4.txt", "w", encoding="utf-8") as f:
            pass
    except Exception:
        print("Test 4 setup failed")
    
    print("Test 4:")
    print(transpose_file("test4.txt"))
    print()
    
    # Test case 5: Non-existent file
    print("Test 5:")
    print(transpose_file("nonexistent.txt"))

if __name__ == "__main__":
    main()
