#include <cmath>

int calculateYears(double principal, double interest, double tax, double desired) {
    // Input validation
    if (principal < 0 || interest < 0 || tax < 0 || tax >= 1 || desired < 0) {
        throw std::invalid_argument("Invalid input parameters");
    }
    if (std::isnan(principal) || std::isnan(interest) || std::isnan(tax) || std::isnan(desired)) {
        throw std::invalid_argument("Parameters cannot be NaN");
    }
    if (std::isinf(principal) || std::isinf(interest) || std::isinf(tax) || std::isinf(desired)) {
        throw std::invalid_argument("Parameters cannot be infinite");
    }
    
    if (principal >= desired) {
        return 0;
    }
    
    int years = 0;
    double currentPrincipal = principal;
    
    while (currentPrincipal < desired) {
        double yearlyInterest = currentPrincipal * interest;
        double taxOnInterest = yearlyInterest * tax;
        double netInterest = yearlyInterest - taxOnInterest;
        currentPrincipal += netInterest;
        years++;
        
        // Prevent infinite loop
        if (years > 10000) {
            throw std::runtime_error("Calculation exceeded maximum iterations");
        }
    }
    
    return years;
}

int main() {
    try {
        // Test case 1: Example from problem
        std::cout << "Test 1: " << calculateYears(1000.0, 0.05, 0.18, 1100.0) << std::endl; // Expected: 3
        
        // Test case 2: Already at desired amount
        std::cout << "Test 2: " << calculateYears(1000.0, 0.05, 0.18, 1000.0) << std::endl; // Expected: 0
        
        // Test case 3: Low interest
        std::cout << "Test 3: " << calculateYears(1000.0, 0.01, 0.1, 1050.0) << std::endl;   // Expected: multiple years
        
        // Test case 4: High interest
        std::cout << "Test 4: " << calculateYears(1000.0, 0.1, 0.2, 1100.0) << std::endl;    // Expected: fewer years
        
        // Test case 5: No tax
        std::cout << "Test 5: " << calculateYears(1000.0, 0.05, 0.0, 1050.0) << std::endl;   // Expected: 1
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
