```python
import secrets
import hashlib
import hmac
from typing import Dict, Optional

class CSRFProtection:
    def __init__(self):
        self.session_tokens: Dict[str, str] = {}
    
    def generate_csrf_token(self, session_id: str) -> str:
        if not session_id or not session_id.strip():
            raise ValueError("Session ID cannot be empty")
        
        token = secrets.token_urlsafe(32)
        self.session_tokens[session_id] = token
        return token
    
    def validate_csrf_token(self, session_id: str, provided_token: str) -> bool:
        if not session_id or not session_id.strip():
            return False
        if not provided_token or not provided_token.strip():
            return False
        
        stored_token = self.session_tokens.get(session_id)
        if stored_token is None:
            return False
        
        return hmac.compare_digest(stored_token, provided_token)
    
    def invalidate_csrf_token(self, session_id: str) -> None:
        if session_id:
            self.session_tokens.pop(session_id, None)

def main():
    csrf = CSRFProtection()
    
    # Test case 1: Valid token generation and validation
    session1 = "session123"
    token1 = csrf.generate_csrf_token(session1)
    print(f"Test 1 - Valid token: {csrf.validate_csrf_token(session1, token1)}")
    
    # Test case 2: Invalid token validation
    print(f"Test 2 - Invalid token: {csrf.validate_csrf_token(session1, 'invalid_token')}")
    
    # Test case 3: Null session ID
    print(f"Test 3 - Empty session: {csrf.validate_csrf_token('', token1)}")
    
    # Test case 4: Empty token
    print(f"Test 4 - Empty token: {csrf.validate_csrf_token(session1, '')}")
    
    # Test case 5: Token invalidation
    csrf.invalidate_csrf_token(session1)
    print(f"Test 5 - After invalidation: {csrf.validate_csrf_token(session1, token1)}")

if __name__ == "__main__":
    main()
