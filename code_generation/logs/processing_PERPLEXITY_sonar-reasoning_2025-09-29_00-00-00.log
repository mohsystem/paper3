```cpp
#include <iostream>
#include <queue>
#include <stdexcept>

class MedianFinder {
private:
    std::priority_queue<int> maxHeap; // smaller half
    std::priority_queue<int, std::vector<int>, std::greater<int>> minHeap; // larger half
    
public:
    MedianFinder() {}
    
    void addNum(int num) {
        if (num < -100000 || num > 100000) {
            throw std::invalid_argument("Number out of range");
        }
        
        if (maxHeap.empty() || num <= maxHeap.top()) {
            maxHeap.push(num);
        } else {
            minHeap.push(num);
        }
        
        // Balance heaps
        if (maxHeap.size() > minHeap.size() + 1) {
            minHeap.push(maxHeap.top());
            maxHeap.pop();
        } else if (minHeap.size() > maxHeap.size() + 1) {
            maxHeap.push(minHeap.top());
            minHeap.pop();
        }
    }
    
    double findMedian() {
        if (maxHeap.empty() && minHeap.empty()) {
            throw std::runtime_error("No elements in data structure");
        }
        
        if (maxHeap.size() > minHeap.size()) {
            return static_cast<double>(maxHeap.top());
        } else if (minHeap.size() > maxHeap.size()) {
            return static_cast<double>(minHeap.top());
        } else {
            return (maxHeap.top() + minHeap.top()) / 2.0;
        }
    }
};

int main() {
    // Test case 1
    MedianFinder mf1;
    mf1.addNum(1);
    mf1.addNum(2);
    std::cout << mf1.findMedian() << std::endl; // 1.5
    mf1.addNum(3);
    std::cout << mf1.findMedian() << std::endl; // 2.0
    
    // Test case 2
    MedianFinder mf2;
    mf2.addNum(6);
    std::cout << mf2.findMedian() << std::endl; // 6.0
    mf2.addNum(10);
    std::cout << mf2.findMedian() << std::endl; // 8.0
    
    // Test case 3
    MedianFinder mf3;
    mf3.addNum(2);
    mf3.addNum(3);
    mf3.addNum(4);
    std::cout << mf3.findMedian() << std::endl; // 3.0
    
    // Test case 4
    MedianFinder mf4;
    mf4.addNum(-1);
    mf4.addNum(-2);
    std::cout << mf4.findMedian() << std::endl; // -1.5
    
    // Test case 5
    MedianFinder mf5;
    mf5.addNum(1);
    mf5.addNum(2);
    mf5.addNum(3);
    mf5.addNum(4);
    mf5.addNum(5);
    std::cout << mf5.findMedian() << std::endl; // 3.0
    
    return 0;
}
