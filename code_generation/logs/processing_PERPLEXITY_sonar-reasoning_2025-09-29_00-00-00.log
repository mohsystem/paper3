import java.security.SecureRandom;
import java.util.HashMap;
import java.util.Map;
import java.nio.charset.StandardCharsets;

public class Task40 {
    private static final SecureRandom random = new SecureRandom();
    private static final Map<String, String> userSettings = new HashMap<>();
    private static final Map<String, String> csrfTokens = new HashMap<>();
    
    static {
        userSettings.put("username", "john_doe");
        userSettings.put("email", "john@example.com");
        userSettings.put("theme", "light");
    }
    
    public static String generateCSRFToken(String sessionId) {
        byte[] tokenBytes = new byte[32];
        random.nextBytes(tokenBytes);
        String token = bytesToHex(tokenBytes);
        csrfTokens.put(sessionId, token);
        return token;
    }
    
    public static boolean validateCSRFToken(String sessionId, String token) {
        if (token == null || sessionId == null) {
            return false;
        }
        String storedToken = csrfTokens.get(sessionId);
        if (storedToken == null) {
            return false;
        }
        return constantTimeEquals(storedToken, token);
    }
    
    private static boolean constantTimeEquals(String a, String b) {
        if (a.length() != b.length()) {
            return false;
        }
        int result = 0;
        for (int i = 0; i < a.length(); i++) {
            result |= a.charAt(i) ^ b.charAt(i);
        }
        return result == 0;
    }
    
    public static ValidationResult validateInput(String value, int maxLength, boolean required, String fieldName) {
        if (required && (value == null || value.trim().isEmpty())) {
            return new ValidationResult(false, fieldName + " is required");
        }
        if (value != null && value.length() > maxLength) {
            return new ValidationResult(false, fieldName + " must be less than " + maxLength + " characters");
        }
        if (value != null && !isValidInput(value)) {
            return new ValidationResult(false, fieldName + " contains invalid characters");
        }
        return new ValidationResult(true, null);
    }
    
    private static boolean isValidInput(String value) {
        return value.matches("^[a-zA-Z0-9@._-]+$");
    }
    
    public static String updateUserSettings(String sessionId, String csrfToken, String username, String email, String theme) {
        if (!validateCSRFToken(sessionId, csrfToken)) {
            return "CSRF token validation failed";
        }
        
        ValidationResult result = validateInput(username, 50, true, "Username");
        if (!result.isValid) {
            return "Username error: " + result.error;
        }
        
        result = validateInput(email, 100, true, "Email");
        if (!result.isValid) {
            return "Email error: " + result.error;
        }
        
        if (theme == null || (!theme.equals("light") && !theme.equals("dark"))) {
            return "Invalid theme";
        }
        
        userSettings.put("username", username.trim());
        userSettings.put("email", email.trim());
        userSettings.put("theme", theme);
        
        return "Settings updated successfully!";
    }
    
    public static String renderSettingsForm(String sessionId) {
        String csrfToken = generateCSRFToken(sessionId);
        StringBuilder html = new StringBuilder();
        html.append("<DOCTYPE html>\n<html>\n<head>\n<title>User Settings</title>\n</head>\n<body>\n");
        html.append("<h1>Update User Settings</h1>\n<form method=\"POST\">\n");
        html.append("<input type=\"hidden\" name=\"csrf_token\" value=\"").append(csrfToken).append("\">\n");
        html.append("<div>\n<label>Username:</label>\n");
        html.append("<input type=\"text\" name=\"username\" value=\"").append(userSettings.get("username")).append("\" required>\n</div>\n");
        html.append("<div>\n<label>Email:</label>\n");
        html.append("<input type=\"email\" name=\"email\" value=\"").append(userSettings.get("email")).append("\" required>\n</div>\n");
        html.append("<div>\n<label>Theme:</label>\n<select name=\"theme\">\n");
        html.append("<option value=\"light\"").append("light".equals(userSettings.get("theme")) ? " selected" : "").append(">Light</option>\n");
        html.append("<option value=\"dark\"").append("dark".equals(userSettings.get("theme")) ? " selected" : "").append(">Dark</option>\n");
        html.append("</select>\n</div>\n<button type=\"submit\">Update Settings</button>\n</form>\n</body>\n</html>");
        return html.toString();
    }
    
    private static String bytesToHex(byte[] bytes) {
        StringBuilder result = new StringBuilder();
        for (byte b : bytes) {
            result.append(String.format("%02x", b));
        }
        return result.toString();
    }
    
    static class ValidationResult {
        boolean isValid;
        String error;
        
        ValidationResult(boolean isValid, String error) {
            this.isValid = isValid;
            this.error = error;
        }
    }
    
    public static void main(String[] args) {
        String sessionId = "session123";
        String token = generateCSRFToken(sessionId);
        System.out.println("Test 1 passed: CSRF token generated: " + (token.length() == 64));
        
        boolean isValid = validateCSRFToken(sessionId, token);
        System.out.println("Test 2 passed: Valid CSRF token: " + isValid);
        
        boolean isInvalid = !validateCSRFToken(sessionId, "invalid_token");
        System.out.println("Test 3 passed: Invalid CSRF token rejected: " + isInvalid);
        
        String result = updateUserSettings(sessionId, token, "newuser", "new@example.com", "dark");
        System.out.println("Test 4 passed: Valid update: " + result.equals("Settings updated successfully"));
        
        String token2 = generateCSRFToken("session456");
        String invalidResult = updateUserSettings("session456", token2, "x".repeat(101), "test@example.com", "light");
        System.out.println("Test 5 passed: Input validation: " + invalidResult.contains("error"));
    }
}
