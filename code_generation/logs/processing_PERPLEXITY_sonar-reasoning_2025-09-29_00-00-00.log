```cpp
#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

class Master {
public:
    virtual int guess(std::string word) = 0;
};

class Solution {
public:
    void findSecretWord(std::vector<std::string>& words, Master& master) {
        if (words.empty()) {
            return;
        }
        
        std::vector<std::string> candidates;
        for (const std::string& word : words) {
            if (word.length() == 6) {
                candidates.push_back(word);
            }
        }
        
        while (!candidates.empty()) {
            std::string guess = candidates[0];
            int matches = master.guess(guess);
            
            if (matches == 6) {
                return;
            }
            
            std::vector<std::string> newCandidates;
            for (const std::string& candidate : candidates) {
                if (candidate != guess && countMatches(guess, candidate) == matches) {
                    newCandidates.push_back(candidate);
                }
            }
            candidates = newCandidates;
        }
    }
    
private:
    int countMatches(const std::string& word1, const std::string& word2) {
        if (word1.length() != 6 || word2.length() != 6) {
            return 0;
        }
        int matches = 0;
        for (size_t i = 0; i < 6; ++i) {
            if (word1[i] == word2[i]) {
                matches++;
            }
        }
        return matches;
    }
};

class MockMaster : public Master {
private:
    std::string secret;
    
public:
    MockMaster(const std::string& secret) : secret(secret) {}
    
    int guess(std::string word) override {
        if (word.length() != 6 || secret.length() != 6) {
            return -1;
        }
        if (secret == word) {
            return 6;
        }
        int matches = 0;
        for (size_t i = 0; i < 6; ++i) {
            if (secret[i] == word[i]) {
                matches++;
            }
        }
        return matches;
    }
};

int main() {
    Solution solution;
    
    std::vector<std::string> words1 = {"acckzz","ccbazz","eiowzz","abcczz"};
    MockMaster master1("acckzz");
    solution.findSecretWord(words1, master1);
    std::cout << "Test 1 completed" << std::endl;
    
    std::vector<std::string> words2 = {"hamada","khaled"};
    MockMaster master2("hamada");
    solution.findSecretWord(words2, master2);
    std::cout << "Test 2 completed" << std::endl;
    
    std::vector<std::string> words3 = {"gaxckt","trlccr","jxwhkz"};
    MockMaster master3("gaxckt");
    solution.findSecretWord(words3, master3);
    std::cout << "Test 3 completed" << std::endl;
    
    std::vector<std::string> words4 = {"wichbx","oahwep","tpulot"};
    MockMaster master4("tpulot");
    solution.findSecretWord(words4, master4);
    std::cout << "Test 4 completed" << std::endl;
    
    std::vector<std::string> words5 = {"ccoyyo","wlisgt","qznupb"};
    MockMaster master5("qznupb");
    solution.findSecretWord(words5, master5);
    std::cout << "Test 5 completed" << std::endl;
    
    return 0;
}
