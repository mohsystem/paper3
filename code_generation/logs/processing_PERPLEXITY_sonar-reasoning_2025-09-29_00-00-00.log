#include <unordered_map>
#include <random>
#include <stdexcept>
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/buffer.h>

class PasswordStore {
private:
    std::unordered_map<std::string, std::string> userDatabase;
    static const int SALT_LENGTH = 16;
    static const int HASH_LENGTH = 32;
    static const int ITERATIONS = 210000;
    
    std::string base64Encode(const unsigned char* data, int length) {
        BIO* bio = BIO_new(BIO_s_mem());
        BIO* b64 = BIO_new(BIO_f_base64());
        BIO_set_flags(b64, BIO_FLAGS_BASE64_NO_NL);
        bio = BIO_push(b64, bio);
        
        BIO_write(bio, data, length);
        BIO_flush(bio);
        
        BUF_MEM* bufferPtr;
        BIO_get_mem_ptr(bio, &bufferPtr);
        std::string result(bufferPtr->data, bufferPtr->length);
        
        BIO_free_all(bio);
        return result;
    }
    
    std::vector<unsigned char> base64Decode(const std::string& input) {
        BIO* bio = BIO_new_mem_buf(input.c_str(), input.length());
        BIO* b64 = BIO_new(BIO_f_base64());
        BIO_set_flags(b64, BIO_FLAGS_BASE64_NO_NL);
        bio = BIO_push(b64, bio);
        
        std::vector<unsigned char> result(input.length());
        int decodedLength = BIO_read(bio, result.data(), input.length());
        result.resize(decodedLength);
        
        BIO_free_all(bio);
        return result;
    }
    
public:
    std::string hashPassword(const std::string& username, const std::string& password) {
        if (username.empty() || password.length() < 8) {
            throw std::invalid_argument("Invalid username or password");
        }
        
        unsigned char salt[SALT_LENGTH];
        unsigned char hash[HASH_LENGTH];
        
        if (RAND_bytes(salt, SALT_LENGTH) != 1) {
            throw std::runtime_error("Failed to generate salt");
        }
        
        if (PKCS5_PBKDF2_HMAC(password.c_str(), password.length(),
                             salt, SALT_LENGTH,
                             ITERATIONS,
                             EVP_sha256(),
                             HASH_LENGTH, hash) != 1) {
            throw std::runtime_error("Password hashing failed");
        }
        
        std::string saltB64 = base64Encode(salt, SALT_LENGTH);
        std::string hashB64 = base64Encode(hash, HASH_LENGTH);
        
        return saltB64 + ":" + hashB64;
    }
    
    bool signupUser(const std::string& username, const std::string& password) {
        if (userDatabase.find(username) != userDatabase.end()) {
            return false;
        }
        
        try {
            std::string hashedPassword = hashPassword(username, password);
            userDatabase[username] = hashedPassword;
            return true;
        } catch (const std::exception&) {
            return false;
        }
    }
    
    bool verifyPassword(const std::string& username, const std::string& password) {
        auto it = userDatabase.find(username);
        if (it == userDatabase.end()) {
            return false;
        }
        
        try {
            size_t colonPos = it->second.find(':');
            if (colonPos == std::string::npos) {
                return false;
            }
            
            std::string saltB64 = it->second.substr(0, colonPos);
            std::string hashB64 = it->second.substr(colonPos + 1);
            
            std::vector<unsigned char> salt = base64Decode(saltB64);
            std::vector<unsigned char> storedHash = base64Decode(hashB64);
            
            unsigned char testHash[HASH_LENGTH];
            if (PKCS5_PBKDF2_HMAC(password.c_str(), password.length(),
                                 salt.data(), salt.size(),
                                 ITERATIONS,
                                 EVP_sha256(),
                                 HASH_LENGTH, testHash) != 1) {
                return false;
            }
            
            return CRYPTO_memcmp(storedHash.data(), testHash, HASH_LENGTH) == 0;
        } catch (const std::exception&) {
            return false;
        }
    }
};

int main() {
    PasswordStore passwordStore;
    
    // Test case 1: Valid signup
    std::cout << "Test 1: " << passwordStore.signupUser("user1", "SecurePass123") << std::endl;
    
    // Test case 2: Password verification
    std::cout << "Test 2: " << passwordStore.verifyPassword("user1", "SecurePass123") << std::endl;
    
    // Test case 3: Duplicate username
    std::cout << "Test 3: " << passwordStore.signupUser("user1", "AnotherPass456") << std::endl;
    
    // Test case 4: Invalid password verification
    std::cout << "Test 4: " << passwordStore.verifyPassword("user1", "WrongPassword") << std::endl;
    
    // Test case 5: Multiple users
    std::cout << "Test 5: " << passwordStore.signupUser("user2", "MyPassword789") << std::endl;
    
    return 0;
}
