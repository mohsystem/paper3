```c
#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

typedef struct {
    int hours;
    int minutes;
    int seconds;
} Clock;

Clock createClock(int hours, int minutes, int seconds) {
    Clock clock = {0, 0, 0};
    if (hours < 0 || hours > 23 || minutes < 0 || minutes > 59 || seconds < 0 || seconds > 59) {
        fprintf(stderr, "Invalid time values\n");
        exit(1);
    }
    clock.hours = hours;
    clock.minutes = minutes;
    clock.seconds = seconds;
    return clock;
}

Clock addMinutes(Clock clock, int minutesToAdd) {
    if (minutesToAdd < -1440 || minutesToAdd > 1440) {
        fprintf(stderr, "Minutes to add must be between -1440 and 1440\n");
        exit(1);
    }
    int totalMinutes = clock.hours * 60 + clock.minutes + minutesToAdd;
    totalMinutes = ((totalMinutes % 1440) + 1440) % 1440;
    int newHours = totalMinutes / 60;
    int newMinutes = totalMinutes % 60;
    return createClock(newHours, newMinutes, clock.seconds);
}

Clock subtractMinutes(Clock clock, int minutesToSubtract) {
    return addMinutes(clock, -minutesToSubtract);
}

bool clocksEqual(Clock clock1, Clock clock2) {
    return clock1.hours == clock2.hours && 
           clock1.minutes == clock2.minutes && 
           clock1.seconds == clock2.seconds;
}

void printClock(Clock clock) {
    printf("%02d:%02d:%02d", clock.hours, clock.minutes, clock.seconds);
}

int main() {
    Clock clock1 = createClock(10, 30, 45);
    Clock clock2 = createClock(10, 30, 45);
    printf("Test 1 - Equal clocks: %s\n", clocksEqual(clock1, clock2) ? "true" : "false");
    
    Clock clock3 = addMinutes(clock1, 30);
    printf("Test 2 - Add 30 minutes: ");
    printClock(clock3);
    printf("\n");
    
    Clock clock4 = subtractMinutes(clock1, 45);
    printf("Test 3 - Subtract 45 minutes: ");
    printClock(clock4);
    printf("\n");
    
    Clock clock5 = addMinutes(createClock(23, 45, 0), 30);
    printf("Test 4 - Wrap around midnight: ");
    printClock(clock5);
    printf("\n");
    
    Clock clock6 = subtractMinutes(createClock(0, 15, 0), 30);
    printf("Test 5 - Wrap around backwards: ");
    printClock(clock6);
    printf("\n");
    
    return 0;
}
```
