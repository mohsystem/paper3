```c
#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

#define MAX_SIZE 40000

typedef struct {
    int stream[MAX_SIZE];
    int size;
} ProductOfNumbers;

ProductOfNumbers* productOfNumbersCreate() {
    ProductOfNumbers* obj = (ProductOfNumbers*)malloc(sizeof(ProductOfNumbers));
    if (!obj) return NULL;
    obj->size = 0;
    return obj;
}

bool productOfNumbersAdd(ProductOfNumbers* obj, int num) {
    if (!obj || num < 0 || num > 100 || obj->size >= MAX_SIZE) {
        return false;
    }
    obj->stream[obj->size++] = num;
    return true;
}

int productOfNumbersGetProduct(ProductOfNumbers* obj, int k) {
    if (!obj || k <= 0 || k > obj->size) {
        return -1;
    }
    
    int product = 1;
    for (int i = obj->size - k; i < obj->size; i++) {
        product *= obj->stream[i];
    }
    return product;
}

void productOfNumbersFree(ProductOfNumbers* obj) {
    if (obj) {
        free(obj);
    }
}

int main() {
    ProductOfNumbers* pon1 = productOfNumbersCreate();
    if (!pon1) return 1;
    
    productOfNumbersAdd(pon1, 3);
    productOfNumbersAdd(pon1, 0);
    productOfNumbersAdd(pon1, 2);
    productOfNumbersAdd(pon1, 5);
    productOfNumbersAdd(pon1, 4);
    printf("%d\n", productOfNumbersGetProduct(pon1, 2));
    printf("%d\n", productOfNumbersGetProduct(pon1, 3));
    printf("%d\n", productOfNumbersGetProduct(pon1, 4));
    productOfNumbersAdd(pon1, 8);
    printf("%d\n", productOfNumbersGetProduct(pon1, 2));
    
    ProductOfNumbers* pon2 = productOfNumbersCreate();
    if (!pon2) return 1;
    productOfNumbersAdd(pon2, 1);
    productOfNumbersAdd(pon2, 1);
    productOfNumbersAdd(pon2, 1);
    printf("%d\n", productOfNumbersGetProduct(pon2, 3));
    
    productOfNumbersFree(pon1);
    productOfNumbersFree(pon2);
    
    return 0;
}
