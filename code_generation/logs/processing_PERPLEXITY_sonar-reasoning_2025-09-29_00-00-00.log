```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

void computeLPS(const char* pattern, int* lps, int patternLen) {
    int length = 0;
    int i = 1;
    lps[0] = 0;
    
    while (i < patternLen) {
        if (pattern[i] == pattern[length]) {
            length++;
            lps[i] = length;
            i++;
        } else {
            if (length != 0) {
                length = lps[length - 1];
            } else {
                lps[i] = 0;
                i++;
            }
        }
    }
}

char* shortestPalindrome(const char* s) {
    if (!s || strlen(s) == 0) {
        char* result = malloc(1);
        if (!result) return NULL;
        result[0] = '\0';
        return result;
    }
    
    int sLen = strlen(s);
    
    // Input validation
    if (sLen > 50000) {
        return NULL;
    }
    
    for (int i = 0; i < sLen; i++) {
        if (s[i] < 'a' || s[i] > 'z') {
            return NULL;
        }
    }
    
    char* revS = malloc(sLen + 1);
    if (!revS) return NULL;
    
    for (int i = 0; i < sLen; i++) {
        revS[i] = s[sLen - 1 - i];
    }
    revS[sLen] = '\0';
    
    int combinedLen = sLen * 2 + 1;
    char* combined = malloc(combinedLen + 1);
    if (!combined) {
        free(revS);
        return NULL;
    }
    
    snprintf(combined, combinedLen + 1, "%s#%s", s, revS);
    
    int* lps = malloc(combinedLen * sizeof(int));
    if (!lps) {
        free(revS);
        free(combined);
        return NULL;
    }
    
    computeLPS(combined, lps, combinedLen);
    int overlap = lps[combinedLen - 1];
    
    int prefixLen = sLen - overlap;
    char* result = malloc(sLen + prefixLen + 1);
    if (!result) {
        free(revS);
        free(combined);
        free(lps);
        return NULL;
    }
    
    strncpy(result, revS, prefixLen);
    strcpy(result + prefixLen, s);
    
    free(revS);
    free(combined);
    free(lps);
    
    return result;
}

int main() {
    char* test1 = shortestPalindrome("aacecaaa");
    char* test2 = shortestPalindrome("abcd");
    char* test3 = shortestPalindrome("");
    char* test4 = shortestPalindrome("a");
    char* test5 = shortestPalindrome("race");
    
    if (test1) { printf("%s\n", test1); free(test1); }
    if (test2) { printf("%s\n", test2); free(test2); }
    if (test3) { printf("%s\n", test3); free(test3); }
    if (test4) { printf("%s\n", test4); free(test4); }
    if (test5) { printf("%s\n", test5); free(test5); }
    
    return 0;
}
