import java.util.*;

public class Task172 {
    public static int distinctEchoSubstrings(String text) {
        if (text == null || text.length() < 1 || text.length() > 2000) {
            throw new IllegalArgumentException("Invalid input");
        }
        
        Set<String> result = new HashSet<>();
        int n = text.length();
        
        // Iterate through possible substring starting positions
        for (int i = 0; i < n; i++) {
            // Ensure even-length substrings and within text bounds
            for (int j = i + 2; j <= n; j += 2) {
                String current = text.substring(i, j);
                int midpoint = current.length() / 2;
                
                // Compare first and second halves
                if (current.substring(0, midpoint).equals(current.substring(midpoint))) {
                    result.add(current);
                }
            }
        }
        
        return result.size();
    }
}
