import javax.crypto.Cipher;
import javax.crypto.SecretKey;
import javax.crypto.SecretKeyFactory;
import javax.crypto.spec.GCMParameterSpec;
import javax.crypto.spec.PBEKeySpec;
import javax.crypto.spec.SecretKeySpec;
import java.nio.charset.StandardCharsets;
import java.security.SecureRandom;
import java.security.spec.KeySpec;
import java.util.Arrays;
import java.util.Base64;

public class Task124 {
    private static final String MAGIC = "ENC1";
    private static final int VERSION = 1;
    private static final int SALT_LENGTH = 16;
    private static final int IV_LENGTH = 12;
    private static final int TAG_LENGTH = 16;
    private static final int PBKDF2_ITERATIONS = 210000;
    private static final SecureRandom secureRandom = new SecureRandom();
    
    public static class EncryptedData {
        private final byte[] data;
        
        public EncryptedData(byte[] data) {
            this.data = data.clone();
        }
        
        public byte[] getData() {
            return data.clone();
        }
    }
    
    public static EncryptedData encryptSensitiveData(String sensitiveData, String passphrase) {
        try {
            if (sensitiveData == null || passphrase == null) {
                throw new IllegalArgumentException("Input cannot be null");
            }
            
            byte[] salt = new byte[SALT_LENGTH];
            secureRandom.nextBytes(salt);
            
            byte[] iv = new byte[IV_LENGTH];
            secureRandom.nextBytes(iv);
            
            KeySpec spec = new PBEKeySpec(passphrase.toCharArray(), salt, PBKDF2_ITERATIONS, 256);
            SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            SecretKey tmp = factory.generateSecret(spec);
            SecretKey secretKey = new SecretKeySpec(tmp.getEncoded(), "AES");
            
            Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding");
            GCMParameterSpec gcmSpec = new GCMParameterSpec(128, iv);
            cipher.init(Cipher.ENCRYPT_MODE, secretKey, gcmSpec);
            
            byte[] plaintext = sensitiveData.getBytes(StandardCharsets.UTF_8);
            byte[] ciphertext = cipher.doFinal(plaintext);
            
            // Extract tag from ciphertext (last 16 bytes)
            byte[] actualCiphertext = Arrays.copyOf(ciphertext, ciphertext.length - TAG_LENGTH);
            byte[] tag = Arrays.copyOfRange(ciphertext, ciphertext.length - TAG_LENGTH, ciphertext.length);
            
            // Build final format: [magic][version][salt][iv][ciphertext][tag]
            byte[] result = new byte[MAGIC.length() + 4 + SALT_LENGTH + IV_LENGTH + actualCiphertext.length + TAG_LENGTH];
            int pos = 0;
            
            System.arraycopy(MAGIC.getBytes(StandardCharsets.UTF_8), 0, result, pos, MAGIC.length());
            pos += MAGIC.length();
            
            result[pos++] = (byte) ((VERSION >>> 24) & 0xFF);
            result[pos++] = (byte) ((VERSION >>> 16) & 0xFF);
            result[pos++] = (byte) ((VERSION >>> 8) & 0xFF);
            result[pos++] = (byte) (VERSION & 0xFF);
            
            System.arraycopy(salt, 0, result, pos, SALT_LENGTH);
            pos += SALT_LENGTH;
            
            System.arraycopy(iv, 0, result, pos, IV_LENGTH);
            pos += IV_LENGTH;
            
            System.arraycopy(actualCiphertext, 0, result, pos, actualCiphertext.length);
            pos += actualCiphertext.length;
            
            System.arraycopy(tag, 0, result, pos, TAG_LENGTH);
            
            return new EncryptedData(result);
        } catch (Exception e) {
            throw new RuntimeException("Encryption failed", e);
        }
    }
    
    public static String decryptSensitiveData(EncryptedData encryptedData, String passphrase) {
        try {
            if (encryptedData == null || passphrase == null) {
                throw new IllegalArgumentException("Input cannot be null");
            }
            
            byte[] data = encryptedData.getData();
            
            if (data.length < MAGIC.length() + 4 + SALT_LENGTH + IV_LENGTH + TAG_LENGTH) {
                throw new IllegalArgumentException("Invalid encrypted data format");
            }
            
            int pos = 0;
            
            // Validate magic
            String magic = new String(Arrays.copyOfRange(data, pos, pos + MAGIC.length()), StandardCharsets.UTF_8);
            if (!MAGIC.equals(magic)) {
                throw new IllegalArgumentException("Invalid magic header");
            }
            pos += MAGIC.length();
            
            // Validate version
            int version = ((data[pos] & 0xFF) << 24) | ((data[pos + 1] & 0xFF) << 16) | 
                         ((data[pos + 2] & 0xFF) << 8) | (data[pos + 3] & 0xFF);
            if (version != VERSION) {
                throw new IllegalArgumentException("Unsupported version");
            }
            pos += 4;
            
            // Extract salt
            byte[] salt = Arrays.copyOfRange(data, pos, pos + SALT_LENGTH);
            pos += SALT_LENGTH;
            
            // Extract IV
            byte[] iv = Arrays.copyOfRange(data, pos, pos + IV_LENGTH);
            pos += IV_LENGTH;
            
            // Extract ciphertext and tag
            int ciphertextLength = data.length - pos - TAG_LENGTH;
            byte[] ciphertext = Arrays.copyOfRange(data, pos, pos + ciphertextLength);
            pos += ciphertextLength;
            byte[] tag = Arrays.copyOfRange(data, pos, pos + TAG_LENGTH);
            
            // Derive key
            KeySpec spec = new PBEKeySpec(passphrase.toCharArray(), salt, PBKDF2_ITERATIONS, 256);
            SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
            SecretKey tmp = factory.generateSecret(spec);
            SecretKey secretKey = new SecretKeySpec(tmp.getEncoded(), "AES");
            
            // Decrypt
            Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding");
            GCMParameterSpec gcmSpec = new GCMParameterSpec(128, iv);
            cipher.init(Cipher.DECRYPT_MODE, secretKey, gcmSpec);
            
            // Combine ciphertext and tag for GCM
            byte[] ciphertextWithTag = new byte[ciphertext.length + tag.length];
            System.arraycopy(ciphertext, 0, ciphertextWithTag, 0, ciphertext.length);
            System.arraycopy(tag, 0, ciphertextWithTag, ciphertext.length, tag.length);
            
            byte[] plaintext = cipher.doFinal(ciphertextWithTag);
            return new String(plaintext, StandardCharsets.UTF_8);
        } catch (Exception e) {
            throw new RuntimeException("Decryption failed", e);
        }
    }
    
    public static void main(String[] args) {
        String passphrase = "SecurePassphrase123!";
        
        // Test case 1: Credit card number
        String creditCard = "4532-1234-5678-9012";
        EncryptedData encrypted1 = encryptSensitiveData(creditCard, passphrase);
        String decrypted1 = decryptSensitiveData(encrypted1, passphrase);
        System.out.println("Test 1 - Credit Card: " + (creditCard.equals(decrypted1) ? "PASS" : "FAIL"));
        
        // Test case 2: SSN
        String ssn = "123-45-6789";
        EncryptedData encrypted2 = encryptSensitiveData(ssn, passphrase);
        String decrypted2 = decryptSensitiveData(encrypted2, passphrase);
        System.out.println("Test 2 - SSN: " + (ssn.equals(decrypted2) ? "PASS" : "FAIL"));
        
        // Test case 3: Personal info
        String personalInfo = "John Doe, DOB: 1985-03-15, Address: 123 Main St";
        EncryptedData encrypted3 = encryptSensitiveData(personalInfo, passphrase);
        String decrypted3 = decryptSensitiveData(encrypted3, passphrase);
        System.out.println("Test 3 - Personal Info: " + (personalInfo.equals(decrypted3) ? "PASS" : "FAIL"));
        
        // Test case 4: Bank account
        String bankAccount = "Account: 9876543210, Routing: 021000021";
        EncryptedData encrypted4 = encryptSensitiveData(bankAccount, passphrase);
        String decrypted4 = decryptSensitiveData(encrypted4, passphrase);
        System.out.println("Test 4 - Bank Account: " + (bankAccount.equals(decrypted4) ? "PASS" : "FAIL"));
        
        // Test case 5: Medical record ID
        String medicalId = "Patient ID: MRN-789456123, Insurance: 987654321";
