        for (char c : str.toCharArray()) {
            int digit = Character.getNumericValue(c);
            sum += Math.pow(digit, numDigits);
        }
        
        return sum == value;
    }
    
    public static void main(String[] args) {
        System.out.println(narcissistic(153));   // true
        System.out.println(narcissistic(1652));  // false
        System.out.println(narcissistic(9));     // true
        System.out.println(narcissistic(371));   // true
        System.out.println(narcissistic(123));   // false
    }
}
