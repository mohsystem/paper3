```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_NODES 100

typedef struct {
    int nodes[MAX_NODES];
    int count;
} NodeList;

typedef struct {
    NodeList adjacency[MAX_NODES];
    int nodeCount;
} Tree;

Tree reparentTree(Tree* tree, int newRoot) {
    Tree result = {{0}, 0};
    int visited[MAX_NODES] = {0};
    int queue[MAX_NODES];
    int front = 0, rear = 0;
    
    if (tree == NULL || newRoot < 0 || newRoot >= MAX_NODES) {
        return result;
    }
    
    result.nodeCount = tree->nodeCount;
    queue[rear++] = newRoot;
    visited[newRoot] = 1;
    
    while (front < rear) {
        int current = queue[front++];
        
        for (int i = 0; i < tree->adjacency[current].count; i++) {
            int neighbor = tree->adjacency[current].nodes[i];
            if (!visited[neighbor]) {
                visited[neighbor] = 1;
                if (result.adjacency[current].count < MAX_NODES) {
                    result.adjacency[current].nodes[result.adjacency[current].count++] = neighbor;
                }
                if (rear < MAX_NODES) {
                    queue[rear++] = neighbor;
                }
            }
        }
    }
    
    return result;
}

void printTree(Tree* tree) {
    printf("{");
    int first = 1;
    for (int i = 0; i < MAX_NODES; i++) {
        if (tree->adjacency[i].count > 0) {
            if (!first) printf(", ");
            printf("%d: [", i);
            for (int j = 0; j < tree->adjacency[i].count; j++) {
                if (j > 0) printf(", ");
                printf("%d", tree->adjacency[i].nodes[j]);
            }
            printf("]");
            first = 0;
        }
    }
    printf("}\n");
}

int main() {
    // Test case 1: Example from problem
    Tree tree1 = {{0}, 10};
    tree1.adjacency[0] = (NodeList){{1, 2, 3}, 3};
    tree1.adjacency[1] = (NodeList){{0, 4, 5}, 3};
    tree1.adjacency[2] = (NodeList){{0, 6, 7}, 3};
    tree1.adjacency[3] = (NodeList){{0, 8, 9}, 3};
    tree1.adjacency[4] = (NodeList){{1}, 1};
    tree1.adjacency[5] = (NodeList){{1}, 1};
    tree1.adjacency[6] = (NodeList){{2}, 1};
    tree1.adjacency[7] = (NodeList){{2}, 1};
    tree1.adjacency[8] = (NodeList){{3}, 1};
    tree1.adjacency[9] = (NodeList){{3}, 1};
    
    Tree result1 = reparentTree(&tree1, 6);
    printf("Test 1: ");
    printTree(&result1);
    
    // Test case 2: Single node
    Tree tree2 = {{0}, 1};
    tree2.adjacency[1] = (NodeList){{}, 0};
    Tree result2 = reparentTree(&tree2, 1);
    printf("Test 2: ");
    printTree(&result2);
    
    // Test case 3: Two nodes
    Tree tree3 = {{0}, 2};
    tree3.adjacency[1] = (NodeList){{2}, 1};
    tree3.adjacency[2] = (NodeList){{1}, 1};
    Tree result3 = reparentTree(&tree3, 2);
    printf("Test 3: ");
    printTree(&result3);
    
    // Test case 4: Empty tree
    Tree tree4 = {{0}, 0};
    Tree result4 = reparentTree(&tree4, 1);
    printf("Test 4: ");
    printTree(&result4);
    
    // Test case 5: Linear tree
    Tree tree5 = {{0}, 4};
    tree5.adjacency[1] = (NodeList){{2}, 1};
    tree5.adjacency[2] = (NodeList){{1, 3}, 2};
    tree5.adjacency[3] = (NodeList){{2, 4}, 2};
    tree5.adjacency[4] = (NodeList){{3}, 1};
    Tree result5 = reparentTree(&tree5, 3);
    printf("Test 5: ");
    printTree(&result5);
    
    return 0;
}
