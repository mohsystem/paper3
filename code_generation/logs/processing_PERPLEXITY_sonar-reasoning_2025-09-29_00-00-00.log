```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

#define MAX_ROBOTS 1000
#define NAME_LENGTH 6

static char usedNames[MAX_ROBOTS][NAME_LENGTH];
static int usedCount = 0;

typedef struct {
    char name[NAME_LENGTH];
    int hasName;
} Robot;

int isNameUsed(const char* name) {
    for (int i = 0; i < usedCount; i++) {
        if (strcmp(usedNames[i], name) == 0) {
            return 1;
        }
    }
    return 0;
}

void addUsedName(const char* name) {
    if (usedCount < MAX_ROBOTS) {
        strncpy(usedNames[usedCount], name, NAME_LENGTH - 1);
        usedNames[usedCount][NAME_LENGTH - 1] = '\0';
        usedCount++;
    }
}

void removeUsedName(const char* name) {
    for (int i = 0; i < usedCount; i++) {
        if (strcmp(usedNames[i], name) == 0) {
            for (int j = i; j < usedCount - 1; j++) {
                strcpy(usedNames[j], usedNames[j + 1]);
            }
            usedCount--;
            break;
        }
    }
}

void generateUniqueName(char* name) {
    do {
        name[0] = 'A' + (rand() % 26);
        name[1] = 'A' + (rand() % 26);
        name[2] = '0' + (rand() % 10);
        name[3] = '0' + (rand() % 10);
        name[4] = '0' + (rand() % 10);
        name[5] = '\0';
    } while (isNameUsed(name));
    
    addUsedName(name);
}

Robot* createRobot() {
    Robot* robot = malloc(sizeof(Robot));
    if (robot != NULL) {
        robot->hasName = 0;
        memset(robot->name, 0, NAME_LENGTH);
    }
    return robot;
}

char* getName(Robot* robot) {
    if (robot != NULL && !robot->hasName) {
        generateUniqueName(robot->name);
        robot->hasName = 1;
    }
    return robot != NULL ? robot->name : NULL;
}

void resetRobot(Robot* robot) {
    if (robot != NULL && robot->hasName) {
        removeUsedName(robot->name);
        robot->hasName = 0;
        memset(robot->name, 0, NAME_LENGTH);
    }
}

void freeRobot(Robot* robot) {
    if (robot != NULL) {
        if (robot->hasName) {
            removeUsedName(robot->name);
        }
        free(robot);
    }
}

int main() {
    srand((unsigned int)time(NULL));
    
    Robot* robot1 = createRobot();
    Robot* robot2 = createRobot();
    Robot* robot3 = createRobot();
    Robot* robot4 = createRobot();
    Robot* robot5 = createRobot();
    
    printf("Robot 1: %s\n", getName(robot1));
    printf("Robot 2: %s\n", getName(robot2));
    printf("Robot 3: %s\n", getName(robot3));
    printf("Robot 4: %s\n", getName(robot4));
    printf("Robot 5: %s\n", getName(robot5));
    
    resetRobot(robot1);
    printf("Robot 1 after reset: %s\n", getName(robot1));
    
    freeRobot(robot1);
    freeRobot(robot2);
    freeRobot(robot3);
    freeRobot(robot4);
    freeRobot(robot5);
    
    return 0;
}
