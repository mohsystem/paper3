```python
from typing import List

class ProductOfNumbers:
    def __init__(self):
        self.stream: List[int] = []
    
    def add(self, num: int) -> None:
        if not (0 <= num <= 100):
            raise ValueError("Number must be between 0 and 100")
        self.stream.append(num)
    
    def getProduct(self, k: int) -> int:
        if k <= 0 or k > len(self.stream):
            raise ValueError("Invalid k value")
        
        product = 1
        for i in range(len(self.stream) - k, len(self.stream)):
            product *= self.stream[i]
        return product

def main():
    pon1 = ProductOfNumbers()
    pon1.add(3)
    pon1.add(0)
    pon1.add(2)
    pon1.add(5)
    pon1.add(4)
    print(pon1.getProduct(2))
    print(pon1.getProduct(3))
    print(pon1.getProduct(4))
    pon1.add(8)
    print(pon1.getProduct(2))
    
    pon2 = ProductOfNumbers()
    pon2.add(1)
    pon2.add(1)
    pon2.add(1)
    print(pon2.getProduct(3))

if __name__ == "__main__":
    main()
