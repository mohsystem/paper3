```java
import java.util.*;

public class Task177 {
    public static int constrainedSubsetSum(int[] nums, int k) {
        if (nums == null || nums.length == 0) {
            throw new IllegalArgumentException("Array cannot be null or empty");
        }
        if (k < 1 || k > nums.length) {
            throw new IllegalArgumentException("k must be between 1 and array length");
        }
        
        int n = nums.length;
        int[] dp = new int[n];
        Deque<Integer> deque = new ArrayDeque<>();
        
        int result = Integer.MIN_VALUE;
        
        for (int i = 0; i < n; i++) {
            // Remove elements that are out of window
            while (!deque.isEmpty() && deque.peekFirst() < i - k) {
                deque.pollFirst();
            }
            
            // Calculate dp[i] and manage sliding window maximum
            dp[i] = nums[i];
            if (!deque.isEmpty()) {
                dp[i] = Math.max(dp[i], nums[i] + dp[deque.peekFirst()]);
            }
            
            // Track the overall maximum subsequence sum
            result = Math.max(result, dp[i]);
            
            // Maintain deque in decreasing order of dp values
            while (!deque.isEmpty() && dp[deque.peekLast()] <= dp[i]) {
                deque.pollLast();
            }
            deque.offerLast(i);
        }
        
        return result;
    }
}
