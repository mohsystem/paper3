import java.io.*;
import java.net.*;
import java.util.regex.*;
import java.util.*;

public class Task111 {
    public static int add(int a, int b) {
        if (a > 0 && b > Integer.MAX_VALUE - a) {
            throw new ArithmeticException("Integer overflow");
        }
        if (a < 0 && b < Integer.MIN_VALUE - a) {
            throw new ArithmeticException("Integer underflow");
        }
        return a + b;
    }
    
    public static int multiply(int a, int b) {
        if (a != 0 && b != 0) {
            if (a > Integer.MAX_VALUE / b || a < Integer.MIN_VALUE / b) {
                throw new ArithmeticException("Integer overflow");
            }
        }
        return a * b;
    }
    
    public static String processXMLRPCRequest(String xmlRequest) {
        if (xmlRequest == null || xmlRequest.length() > 10000) {
            return createErrorResponse("Invalid request length");
        }
        
        try {
            Pattern methodPattern = Pattern.compile("<methodName>([^<]+)</methodName>");
            Matcher methodMatcher = methodPattern.matcher(xmlRequest);
            
            if (!methodMatcher.find()) {
                return createErrorResponse("Method name not found");
            }
            
            String methodName = methodMatcher.group(1);
            Pattern paramPattern = Pattern.compile("<int>(-?\\d+)</int>");
            Matcher paramMatcher = paramPattern.matcher(xmlRequest);
            
            List<Integer> params = new ArrayList<>();
            while (paramMatcher.find()) {
                try {
                    int param = Integer.parseInt(paramMatcher.group(1));
                    params.add(param);
                } catch (NumberFormatException e) {
                    return createErrorResponse("Invalid parameter format");
                }
            }
            
            switch (methodName) {
                case "add":
                    if (params.size() != 2) {
                        return createErrorResponse("Add method requires 2 parameters");
                    }
                    int result = add(params.get(0), params.get(1));
                    return createSuccessResponse(result);
                case "multiply":
                    if (params.size() != 2) {
                        return createErrorResponse("Multiply method requires 2 parameters");
                    }
                    int result2 = multiply(params.get(0), params.get(1));
                    return createSuccessResponse(result2);
                default:
                    return createErrorResponse("Unknown method: " + methodName);
            }
        } catch (Exception e) {
            return createErrorResponse("Processing error: " + e.getMessage());
        }
    }
    
    private static String createSuccessResponse(int value) {
        return "<?xml version=\"1.0\"?>\n" +
               "<methodResponse>\n" +
               "<params>\n" +
               "<param><value><int>" + value + "</int></value></param>\n" +
               "</params>\n" +
               "</methodResponse>";
    }
    
    private static String createErrorResponse(String message) {
        return "<?xml version=\"1.0\"?>\n" +
               "<methodResponse>\n" +
               "<fault>\n" +
               "<value><struct>\n" +
               "<member><name>faultCode</name><value><int>1</int></value></member>\n" +
               "<member><name>faultString</name><value><string>" + message + "</string></value></member>\n" +
               "</struct></value>\n" +
               "</fault>\n" +
               "</methodResponse>";
    }
    
    public static void main(String[] args) {
        System.out.println("Test Case 1 - Add 5 + 3:");
        String request1 = "<?xml version=\"1.0\"?>\n<methodCall>\n<methodName>add</methodName>\n<params>\n<param><value><int>5</int></value></param>\n<param><value><int>3</int></value></param>\n</params>\n</methodCall>";
        System.out.println(processXMLRPCRequest(request1));
        
        System.out.println("\nTest Case 2 - Multiply 4 * 6:");
        String request2 = "<?xml version=\"1.0\"?>\n<methodCall>\n<methodName>multiply</methodName>\n<params>\n<param><value><int>4</int></value></param>\n<param><value><int>6</int></value></param>\n</params>\n</methodCall>";
        System.out.println(processXMLRPCRequest(request2));
        
        System.out.println("\nTest Case 3 - Add with negative numbers:");
        String request3 = "<?xml version=\"1.0\"?>\n<methodCall>\n<methodName>add</methodName>\n<params>\n<param><value><int>-10</int></value></param>\n<param><value><int>15</int></value></param>\n</params>\n</methodCall>";
        System.out.println(processXMLRPCRequest(request3));
        
        System.out.println("\nTest Case 4 - Invalid method:");
        String request4 = "<?xml version=\"1.0\"?>\n<methodCall>\n<methodName>subtract</methodName>\n<params>\n<param><value><int>10</int></value></param>\n<param><value><int>5</int></value></param>\n</params>\n</methodCall>";
        System.out.println(processXMLRPCRequest(request4));
        
        System.out.println("\nTest Case 5 - Invalid parameter count:");
        String request5 = "<?xml version=\"1.0\"?>\n<methodCall>\n<methodName>add</methodName>\n<params>\n<param><value><int>10</int></value></param>\n</params>\n</methodCall>";
        System.out.println(processXMLRPCRequest(request5));
    }
}
