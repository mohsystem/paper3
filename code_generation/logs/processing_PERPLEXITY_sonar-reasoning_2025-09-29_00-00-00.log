```java
import java.security.SecureRandom;

public class Task197 {
    static class Solution {
        private double radius;
        private double x_center;
        private double y_center;
        private SecureRandom random;
        
        public Solution(double radius, double x_center, double y_center) {
            if (radius <= 0) {
                throw new IllegalArgumentException("Radius must be positive");
            }
            this.radius = radius;
            this.x_center = x_center;
            this.y_center = y_center;
            this.random = new SecureRandom();
        }
        
        public double[] randPoint() {
            double r = Math.sqrt(random.nextDouble()) * radius;
            double theta = random.nextDouble() * 2 * Math.PI;
            
            double x = x_center + r * Math.cos(theta);
            double y = y_center + r * Math.sin(theta);
            
            return new double[]{x, y};
        }
    }
    
    public static void main(String[] args) {
        Solution sol1 = new Solution(1.0, 0.0, 0.0);
        double[] point1 = sol1.randPoint();
        System.out.printf("Test 1: [%.5f, %.5f]\n", point1, point1[1]);
        
        Solution sol2 = new Solution(2.0, 1.0, 1.0);
        double[] point2 = sol2.randPoint();
        System.out.printf("Test 2: [%.5f, %.5f]\n", point2, point2[1]);
        
        Solution sol3 = new Solution(0.5, -1.0, -1.0);
        double[] point3 = sol3.randPoint();
        System.out.printf("Test 3: [%.5f, %.5f]\n", point3, point3[1]);
        
        Solution sol4 = new Solution(10.0, 0.0, 0.0);
        double[] point4 = sol4.randPoint();
        System.out.printf("Test 4: [%.5f, %.5f]\n", point4, point4[1]);
        
        Solution sol5 = new Solution(1.0, 100.0, -100.0);
        double[] point5 = sol5.randPoint();
        System.out.printf("Test 5: [%.5f, %.5f]\n", point5, point5[1]);
    }
}
