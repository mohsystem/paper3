```cpp
#include <iostream>
#include <vector>
#include <map>
#include <set>
#include <functional>
#include <stdexcept>

std::map<int, std::vector<int>> reparentTree(const std::map<int, std::vector<int>>& tree, int newRoot) {
    if (tree.empty()) {
        return std::map<int, std::vector<int>>();
    }
    
    if (tree.find(newRoot) == tree.end()) {
        throw std::invalid_argument("New root not found in tree");
    }
    
    std::map<int, std::vector<int>> result;
    std::set<int> visited;
    
    // Initialize result map
    for (const auto& pair : tree) {
        result[pair.first] = std::vector<int>();
    }
    
    std::function<void(int, int)> dfs = [&](int current, int parent) {
        visited.insert(current);
        
        auto it = tree.find(current);
        if (it != tree.end()) {
            for (int neighbor : it->second) {
                if (visited.find(neighbor) == visited.end()) {
                    result[current].push_back(neighbor);
                    dfs(neighbor, current);
                }
            }
        }
    };
    
    dfs(newRoot, -1);
    return result;
}

int main() {
    // Test case 1: Simple tree
    std::map<int, std::vector<int>> tree1 = {
        {0, {1, 2, 3}},
        {1, {0, 4, 5}},
        {2, {0, 6, 7}},
        {3, {0, 8, 9}},
        {4, {1}},
        {5, {1}},
        {6, {2}},
        {7, {2}},
        {8, {3}},
        {9, {3}}
    };
    
    auto result1 = reparentTree(tree1, 6);
    std::cout << "Test 1 - Reparent from 6:" << std::endl;
    for (const auto& pair : result1) {
        std::cout << pair.first << ": ";
        for (int child : pair.second) {
            std::cout << child << " ";
        }
        std::cout << std::endl;
    }
    
    // Test case 2: Linear tree
    std::map<int, std::vector<int>> tree2 = {
        {1, {2}},
        {2, {1, 3}},
        {3, {2, 4}},
        {4, {3}}
    };
    
    auto result2 = reparentTree(tree2, 3);
    std::cout << "Test 2 - Reparent from 3:" << std::endl;
    for (const auto& pair : result2) {
        std::cout << pair.first << ": ";
        for (int child : pair.second) {
            std::cout << child << " ";
