    bio = BIO_push(b64, bio);
    
    BIO_write(bio, data, length);
    BIO_flush(bio);
    
    BUF_MEM* bufferPtr;
    BIO_get_mem_ptr(bio, &bufferPtr);
    
    char* result = malloc(bufferPtr->length + 1);
    if (result) {
        memcpy(result, bufferPtr->data, bufferPtr->length);
        result[bufferPtr->length] = '\0';
    }
    
    BIO_free_all(bio);
    return result;
}

int base64_decode(const char* input, unsigned char** output) {
    BIO* bio = BIO_new_mem_buf(input, strlen(input));
    BIO* b64 = BIO_new(BIO_f_base64());
    BIO_set_flags(b64, BIO_FLAGS_BASE64_NO_NL);
    bio = BIO_push(b64, bio);
    
    int maxlen = strlen(input);
    *output = malloc(maxlen);
    if (!*output) {
        BIO_free_all(bio);
        return -1;
    }
    
    int len = BIO_read(bio, *output, maxlen);
    BIO_free_all(bio);
    return len;
}

int hash_password(const char* username, const char* password, char* result) {
    if (!username || !password || strlen(username) == 0 || strlen(password) < 8) {
