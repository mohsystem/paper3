```c
#include <stdio.h>
#include <pthread.h>
#include <stdlib.h>
#include <stdbool.h>

typedef struct {
    int n;
    pthread_mutex_t mtx;
    pthread_cond_t cv;
    int state; // 0 = zero turn, 1 = odd turn, 2 = even turn
    int current;
} ZeroEvenOdd;

typedef struct {
    ZeroEvenOdd* zeo;
    void (*printNumber)(int);
} ThreadArgs;

ZeroEvenOdd* create_ZeroEvenOdd(int n) {
    if (n < 1 || n > 1000) {
        return NULL;
    }
    
    ZeroEvenOdd* zeo = malloc(sizeof(ZeroEvenOdd));
    if (!zeo) return NULL;
    
    zeo->n = n;
    pthread_mutex_init(&zeo->mtx, NULL);
    pthread_cond_init(&zeo->cv, NULL);
    zeo->state = 0;
    zeo->current = 1;
    return zeo;
}

void* zero_thread(void* arg) {
    ThreadArgs* args = (ThreadArgs*)arg;
    ZeroEvenOdd* zeo = args->zeo;
    
    for (int i = 0; i < zeo->n; i++) {
        pthread_mutex_lock(&zeo->mtx);
        while (zeo->state != 0) {
            pthread_cond_wait(&zeo->cv, &zeo->mtx);
        }
        
        args->printNumber(0);
        
        if (zeo->current % 2 == 1) {
            zeo->state = 1; // odd turn
        } else {
            zeo->state = 2; // even turn
        }
        pthread_cond_broadcast(&zeo->cv);
        pthread_mutex_unlock(&zeo->mtx);
    }
    return NULL;
}

void* even_thread(void* arg) {
    ThreadArgs* args = (ThreadArgs*)arg;
    ZeroEvenOdd* zeo = args->zeo;
    
    for (int i = 2; i <= zeo->n; i += 2) {
        pthread_mutex_lock(&zeo->mtx);
        while (zeo->state != 2) {
            pthread_cond_wait(&zeo->cv, &zeo->mtx);
        }
        
        args->printNumber(zeo->current);
        zeo->current++;
        zeo->state = 0; // zero turn
        pthread_cond_broadcast(&zeo->cv);
        pthread_mutex_unlock(&zeo->mtx);
    }
    return NULL;
}

void* odd_thread(void* arg) {
    ThreadArgs* args = (ThreadArgs*)arg;
    ZeroEvenOdd* zeo = args->zeo;
    
    for (int i = 1; i <= zeo->n; i += 2) {
        pthread_mutex_lock(&zeo->mtx);
        while (zeo->state != 1) {
            pthread_cond_wait(&zeo->cv, &zeo->mtx);
        }
        
        args->printNumber(zeo->current);
        zeo->current++;
        zeo->state = 0; // zero turn
        pthread_cond_broadcast(&zeo->cv);
        pthread_mutex_unlock(&zeo->mtx);
    }
    return NULL;
}

void print_num(int x) {
    printf("%d", x);
}

void destroy_ZeroEvenOdd(ZeroEvenOdd* zeo) {
    if (zeo) {
        pthread_mutex_destroy(&zeo->mtx);
        pthread_cond_destroy(&zeo->cv);
        free(zeo);
    }
}

int main() {
    int test_cases[] = {1, 2, 3, 4, 5};
    int num_tests = sizeof(test_cases) / sizeof(test_cases[0]);
    
    for (int i = 0; i < num_tests; i++) {
        int n = test_cases[i];
        printf("n=%d: ", n);
        
        ZeroEvenOdd* zeo = create_ZeroEvenOdd(n);
        if (!zeo) {
            printf("Error creating ZeroEvenOdd\n");
            continue;
        }
        
        ThreadArgs args1 = {zeo, print_num};
        ThreadArgs args2 = {zeo, print_num};
        ThreadArgs args3 = {zeo, print_num};
        
        pthread_t t1, t2, t3;
        
        pthread_create(&t1, NULL, zero_thread, &args1);
        pthread_create(&t2, NULL, even_thread, &args2);
        pthread_create(&t3, NULL, odd_thread, &args3);
        
        pthread_join(t1, NULL);
        pthread_join(t2, NULL);
        pthread_join(t3, NULL);
        
        destroy_ZeroEvenOdd(zeo);
        
        printf("\n");
    }
    
    return 0;
}
