/*
 Secure C program that fetches an HTTPS URL and extracts the HTML <title>.
 Requirements met:
 - Uses libcurl with strict TLS verification and hostname checks
 - Validates input URLs (HTTPS only, reasonable length)
 - Safe dynamic buffers with bounds checks
 - No dangerous C functions; checks all return values
 - Includes a main with 5 test cases (used if no CLI args given)
 Build: cc -Wall -Wextra -O2 task76.c -o task76 -lcurl
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <curl/curl.h>

#define URL_MAX_LEN 2048
#define FETCH_MAX_BYTES (5UL * 1024UL * 1024UL) /* 5 MB cap */
#define INITIAL_CAP 8192

typedef struct {
    char *data;
    size_t size;
    size_t cap;
    size_t max;
    int error; /* 0 ok, non-zero on truncation/alloc error */
} Memory;

/* Safe allocation helpers */
static void *xrealloc(void *ptr, size_t new_size) {
    if (new_size == 0) {
        free(ptr);
        return NULL;
    }
    return realloc(ptr, new_size);
}

/* Case-insensitive character */
static int ci_eq(char a, char b) {
    return tolower((unsigned char)a) == tolower((unsigned char)b);
}

/* Case-insensitive strstr */
static const char *istrstr(const char *haystack, const char *needle) {
    if (!haystack || !needle) return NULL;
    size_t nlen = strlen(needle);
    if (nlen == 0) return haystack;
    for (const char *h = haystack; *h; ++h) {
        size_t i = 0;
        while (i < nlen && h[i] && ci_eq(h[i], needle[i])) {
            i++;
        }
        if (i == nlen) {
            return h;
        }
        if (!h[i]) break;
    }
    return NULL;
}

/* Trim leading/trailing whitespace into a newly allocated string */
static char *str_trim_new(const char *s, size_t len) {
    if (!s) return NULL;
    size_t start = 0, end = len;
    while (start < len && isspace((unsigned char)s[start])) start++;
    while (end > start && isspace((unsigned char)s[end - 1])) end--;
    size_t out_len = end > start ? (end - start) : 0;
    char *out = (char *)malloc(out_len + 1);
    if (!out) return NULL;
    if (out_len) memcpy(out, s + start, out_len);
    out[out_len] = '\0';
    return out;
}

/* Validate HTTPS URL */
static int is_valid_https_url(const char *url) {
    if (!url) return 0;
    size_t len = strnlen(url, URL_MAX_LEN + 1);
    if (len == 0 || len > URL_MAX_LEN) return 0;
    const char *scheme = "https://";
    size_t slen = strlen(scheme);
    if (len < slen) return 0;
    if (strncmp(url, scheme, slen) != 0) return 0;
    /* Basic character screening: allow typical URL chars */
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)url[i];
        if (c < 0x20 || c == ' ' || c == '"') return 0;
    }
    return 1;
}

/* CURL write callback with bounds checking */
static size_t curl_write_cb(void *ptr, size_t size, size_t nmemb, void *userdata) {
    Memory *mem = (Memory *)userdata;
    if (!mem || !ptr) return 0;

    size_t chunk = size * nmemb;
    if (chunk == 0) return 0;

    /* Enforce overall max */
    if (mem->size >= mem->max) {
        mem->error = 1;
        return 0; /* Abort transfer */
    }
    if (chunk > mem->max - mem->size) {
        chunk = mem->max - mem->size;
        mem->error = 1; /* Note truncation */
    }

    /* Ensure capacity for new data + null */
    size_t need = mem->size + chunk + 1;
    if (need > mem->cap) {
        size_t new_cap = mem->cap ? mem->cap : INITIAL_CAP;
        while (new_cap < need) {
            if (new_cap > (SIZE_MAX / 2)) { mem->error = 1; return 0; }
            new_cap *= 2;
        }
        char *new_data = (char *)xrealloc(mem->data, new_cap);
        if (!new_data) { mem->error = 1; return 0; }
        mem->data = new_data;
        mem->cap = new_cap;
    }

    memcpy(mem->data + mem->size, ptr, chunk);
    mem->size += chunk;
    mem->data[mem->size] = '\0';
    return chunk;
}

/* Fetch HTTPS content using libcurl. Returns malloc'd buffer or NULL on error. */
static char *fetch_https_content(const char *url, long timeout_sec) {
    if (!is_valid_https_url(url)) {
        return NULL;
    }

    CURLcode ginit = curl_global_init(CURL_GLOBAL_DEFAULT);
    if (ginit != CURLE_OK) {
        return NULL;
    }

    char *result = NULL;
    CURL *curl = curl_easy_init();
    if (!curl) {
        curl_global_cleanup();
        return NULL;
    }

    Memory mem;
    mem.data = NULL;
    mem.size = 0;
    mem.cap = 0;
    mem.max = FETCH_MAX_BYTES;
    mem.error = 0;

    if (curl_easy_setopt(curl, CURLOPT_URL, url) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_PROTOCOLS, CURLPROTO_HTTPS) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS, CURLPROTO_HTTPS) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_MAXREDIRS, 5L) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_USERAGENT, "TitleFetcher/1.0") != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, curl_write_cb) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_WRITEDATA, &mem) != CURLE_OK) goto cleanup;
    if (curl_easy_setopt(curl, CURLOPT_ACCEPT_ENCODING, "") != CURLE_OK) goto cleanup; /* enable compression */
#ifdef CURL_HTTP_VERSION_2TLS
    if (curl_easy_setopt(curl, CURLOPT_HTTP_VERSION, CURL_HTTP_VERSION_2TLS) != CURLE_OK) goto cleanup;
#endif
    if (timeout_sec > 0) {
        if (curl_easy_setopt(curl, CURLOPT_TIMEOUT, timeout_sec) != CURLE_OK) goto cleanup;
        if (curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, timeout_sec) != CURLE_OK) goto cleanup;
    }

    CURLcode res = curl_easy_perform(curl);
    if (res != CURLE_OK || mem.error) {
        goto cleanup;
    }

    long http_code = 0;
    if (curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code) != CURLE_OK) goto cleanup;
    if (http_code < 200 || http_code > 299) goto cleanup;

    /* Success: take ownership of buffer (ensure null-terminated) */
    if (!mem.data) goto cleanup;
    /* Already null-terminated by callback */
    result = mem.data;
    mem.data = NULL; /* prevent free */

cleanup:
    if (mem.data) {
        /* clear buffer before free (not sensitive, but good hygiene) */
        memset(mem.data, 0, mem.cap);
        free(mem.data);
    }
    curl_easy_cleanup(curl);
    curl_global_cleanup();
    return result;
}

/* Extract the <title>...</title> content from HTML. Returns malloc'd string or NULL */
static char *extract_html_title(const char *html) {
    if (!html) return NULL;
    const char *p = istrstr(html, "<title");
    if (!p) return NULL;

    /* Find end of start tag '>' */
    const char *gt = strchr(p, '>');
    if (!gt) return NULL;
    const char *start = gt + 1;

    const char *end = istrstr(start, "</title");
    if (!end || end < start) return NULL;

    size_t len = (size_t)(end - start);
    char *raw = (char *)malloc(len + 1);
    if (!raw) return NULL;
    memcpy(raw, start, len);
    raw[len] = '\0';

    /* Trim whitespace */
    char *trimmed = str_trim_new(raw, len);
    /* Clear and free raw */
    memset(raw, 0, len);
    free(raw);

    if (trimmed && trimmed[0] == '\0') {
        free(trimmed);
        return NULL;
    }
    return trimmed;
}

/* High-level function: fetch then extract title. Returns malloc'd title or NULL. */
static char *get_page_title_from_https_url(const char *url, long timeout_sec) {
    char *html = fetch_https_content(url, timeout_sec);
    if (!html) return NULL;
    char *title = extract_html_title(html);
    /* Clear and free HTML buffer */
    size_t html_len = strlen(html);
    memset(html, 0, html_len);
    free(html);
    return title;
}

/* Run a single test case: returns 0 on success, non-zero on error (for internal use) */
static int run_test_case(const char *url) {
    if (!url) {
        printf("URL: (null)\nError: invalid URL\n\n");
        return 1;
    }
    printf("URL: %s\n", url);
    if (!is_valid_https_url(url)) {
        printf("Error: invalid HTTPS URL\n\n");
        return 1;
    }
    char *title = get_page_title_from_https_url(url, 15L);
    if (title) {
        printf("Title: %s\n\n", title);
        memset(title, 0, strlen(title));
        free(title);
        return 0;
    } else {
        printf("Error: could not retrieve or parse title\n\n");
        return 2;
    }
}

int main(int argc, char **argv) {
    int exit_code = 0;
    if (argc > 1) {
        for (int i = 1; i < argc; i++) {
            int r = run_test_case(argv[i]);
            if (r != 0) exit_code = r;
        }
        return exit_code;
    }

    /* 5 default test cases if no arguments provided */
    const char *tests[5] = {
        "https://example.com/",
        "https://www.wikipedia.org/",
        "https://www.ietf.org/",
        "https://www.gnu.org/",
        "https://www.rfc-editor.org/"
    };

    for (int i = 0; i < 5; i++) {
        int r = run_test_case(tests[i]);
        if (r != 0 && exit_code == 0) exit_code = r;
    }
    return exit_code;
}
