            if (!content.empty() && content.back() != '\n') std::cout << "\n";
            std::cout << "------ END CONTENT ------\n";
        } else {
            std::cout << "Error: " << e << "\n";
        }
        std::cout << "=========================\n";
    }

    // Example of reading a user-specified filename (simulated here)
    // In a real environment, obtain user input safely and pass to secureReadFile.
    return 0;
}
