/*
Secure HTTP/HTTPS client in C using libcurl.
- Validates user-provided URL (scheme http/https, host present, no credentials).
- Enforces TLS certificate and hostname verification.
- Restricts protocols to HTTP/HTTPS and limits redirects.
- Bounds-checks all buffers and response size.
- Includes 5 test cases and also allows one interactive URL entry.
Build (example): cc -Wall -Wextra -O2 -o task160 task160.c -lcurl
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <stdint.h>
#include <stdbool.h>
#include <curl/curl.h>

#define MAX_URL_LEN 2048
#define MAX_BODY_SIZE (1024 * 1024) /* 1 MiB maximum response size */
#define INITIAL_BUF_CAP 8192

typedef struct MemoryBuffer {
    char *data;
    size_t size;
    size_t capacity;
    size_t limit;
    bool overflowed;
} MemoryBuffer;

static size_t bounded_strnlen(const char *s, size_t maxlen) {
    size_t n = 0U;
    if (s == NULL) return 0U;
    while (n < maxlen && s[n] != '\0') {
        n++;
    }
    return n;
}

static int init_memory_buffer(MemoryBuffer *mb, size_t initial_capacity, size_t hard_limit) {
    if (mb == NULL) return -1;
    if (initial_capacity == 0U) initial_capacity = 1U;
    if (initial_capacity > hard_limit) initial_capacity = hard_limit;
    mb->data = (char*)malloc(initial_capacity);
    if (mb->data == NULL) {
        mb->size = 0U;
        mb->capacity = 0U;
        mb->limit = hard_limit;
        mb->overflowed = false;
        return -1;
    }
    mb->size = 0U;
    mb->capacity = initial_capacity;
    mb->limit = hard_limit;
    mb->overflowed = false;
    mb->data[0] = '\0';
    return 0;
}

static void free_memory_buffer(MemoryBuffer *mb) {
    if (mb == NULL) return;
    if (mb->data != NULL) {
        /* No sensitive data, but ensure null to avoid UAF patterns */
        free(mb->data);
        mb->data = NULL;
    }
    mb->size = 0U;
    mb->capacity = 0U;
    mb->limit = 0U;
    mb->overflowed = false;
}

static int ensure_capacity(MemoryBuffer *mb, size_t additional) {
    if (mb == NULL) return -1;
    if (additional > (SIZE_MAX - mb->size)) return -1; /* overflow check */
    size_t needed = mb->size + additional;
    if (needed + 1U > mb->limit) {
        return -1; /* would exceed hard limit */
    }
    if (needed + 1U <= mb->capacity) {
        return 0;
    }
    size_t newcap = mb->capacity ? mb->capacity : 1U;
    while (newcap < needed + 1U) {
        if (newcap > SIZE_MAX / 2U) {
            newcap = needed + 1U; /* last resort exact fit */
            break;
        }
        newcap *= 2U;
        if (newcap > mb->limit) {
            newcap = needed + 1U;
            break;
        }
    }
    if (newcap > mb->limit) {
        return -1;
    }
    char *tmp = (char*)realloc(mb->data, newcap);
    if (tmp == NULL) return -1;
    mb->data = tmp;
    mb->capacity = newcap;
    return 0;
}

static size_t write_callback(char *ptr, size_t size, size_t nmemb, void *userdata) {
    /* libcurl write callback: appends received data to MemoryBuffer safely */
    size_t total = size * nmemb;
    MemoryBuffer *mb = (MemoryBuffer*)userdata;
    if (mb == NULL || ptr == NULL) return 0;
    if (total == 0U) return 0U;

    if (total > SIZE_MAX - mb->size - 1U) {
        mb->overflowed = true;
        return 0U; /* prevent overflow */
    }
    if (mb->size + total + 1U > mb->limit) {
        mb->overflowed = true;
        return 0U; /* hard limit exceeded */
    }
    if (ensure_capacity(mb, total) != 0) {
        mb->overflowed = true;
        return 0U;
    }
    memcpy(mb->data + mb->size, ptr, total);
    mb->size += total;
    mb->data[mb->size] = '\0';
    return total;
}

/* Validate that URL is http/https, has host, and no userinfo. Returns 0 on success. */
static int validate_url_http_https(const char *input_url) {
    if (input_url == NULL) return 1;
    size_t len = bounded_strnlen(input_url, MAX_URL_LEN + 1U);
    if (len == 0U || len > MAX_URL_LEN) {
        return 2; /* length invalid */
    }

    /* Use libcurl URL API for robust parsing */
    CURLU *u = curl_url();
    if (u == NULL) return 3;
    CURLUcode uc = curl_url_set(u, CURLUPART_URL, input_url, CURLU_NON_SUPPORT_SCHEME);
    if (uc != CURLUE_OK) {
        curl_url_cleanup(u);
        return 4;
    }

    char *scheme = NULL;
    char *host = NULL;
    char *user = NULL;
    char *password = NULL;

    uc = curl_url_get(u, CURLUPART_SCHEME, &scheme, 0);
    if (uc != CURLUE_OK || scheme == NULL) {
        if (scheme) curl_free(scheme);
        curl_url_cleanup(u);
        return 5;
    }
    /* Case-insensitive compare for scheme */
    bool https = false, http = false;
    {
        size_t slen = bounded_strnlen(scheme, 10U);
        if (slen == 4U &&
            (scheme[0] == 'h' || scheme[0] == 'H') &&
            (scheme[1] == 't' || scheme[1] == 'T') &&
            (scheme[2] == 't' || scheme[2] == 'T') &&
            (scheme[3] == 'p' || scheme[3] == 'P')) {
            http = true;
        } else if (slen == 5U &&
            (scheme[0] == 'h' || scheme[0] == 'H') &&
            (scheme[1] == 't' || scheme[1] == 'T') &&
            (scheme[2] == 't' || scheme[2] == 'T') &&
            (scheme[3] == 'p' || scheme[3] == 'P') &&
            (scheme[4] == 's' || scheme[4] == 'S')) {
            https = true;
        }
    }
    if (!http && !https) {
        curl_free(scheme);
        curl_url_cleanup(u);
        return 6; /* unsupported scheme */
    }

    uc = curl_url_get(u, CURLUPART_HOST, &host, 0);
    if (uc != CURLUE_OK || host == NULL || bounded_strnlen(host, 1U) == 0U) {
        if (host) curl_free(host);
        curl_free(scheme);
        curl_url_cleanup(u);
        return 7; /* host missing */
    }

    /* Disallow credentials in URL to avoid leaking secrets */
    uc = curl_url_get(u, CURLUPART_USER, &user, CURLU_URLDECODE);
    if (uc == CURLUE_OK && user != NULL && bounded_strnlen(user, 1U) > 0U) {
        if (user) curl_free(user);
        if (password) curl_free(password);
        curl_free(host);
        curl_free(scheme);
        curl_url_cleanup(u);
        return 8; /* userinfo not allowed */
    }
    uc = curl_url_get(u, CURLUPART_PASSWORD, &password, CURLU_URLDECODE);
    if (uc == CURLUE_OK && password != NULL && bounded_strnlen(password, 1U) > 0U) {
        if (user) curl_free(user);
        if (password) curl_free(password);
        curl_free(host);
        curl_free(scheme);
        curl_url_cleanup(u);
        return 9; /* password not allowed */
    }

    if (user) curl_free(user);
    if (password) curl_free(password);
    if (host) curl_free(host);
    if (scheme) curl_free(scheme);
    curl_url_cleanup(u);
    return 0;
}

/* Makes HTTP(S) request. Returns 0 on success. Caller must free(*out_body) if success. */
static int make_http_request(const char *url, long timeout_ms, char **out_body, long *out_status_code, char *out_err, size_t out_err_sz) {
    if (out_body == NULL || out_status_code == NULL) return -1;
    *out_body = NULL;
    *out_status_code = 0L;
    if (out_err != NULL && out_err_sz > 0U) out_err[0] = '\0';

    if (validate_url_http_https(url) != 0) {
        if (out_err && out_err_sz > 0U) {
            /* Safe formatting */
            snprintf(out_err, out_err_sz, "Invalid URL (must be http/https with host, no credentials)");
        }
        return -2;
    }

    CURL *curl = curl_easy_init();
    if (curl == NULL) {
        if (out_err && out_err_sz > 0U) {
            snprintf(out_err, out_err_sz, "Failed to initialize CURL");
        }
        return -3;
    }

    MemoryBuffer mb;
    if (init_memory_buffer(&mb, INITIAL_BUF_CAP, MAX_BODY_SIZE) != 0) {
        curl_easy_cleanup(curl);
        if (out_err && out_err_sz > 0U) snprintf(out_err, out_err_sz, "Out of memory");
        return -4;
    }

    char errbuf[CURL_ERROR_SIZE];
    memset(errbuf, 0, sizeof(errbuf));

    /* Configure CURL with strict, secure settings */
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS, CURLPROTO_HTTP | CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS, CURLPROTO_HTTP | CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, 5L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L); /* Verify CA */
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L); /* Verify hostname */
    /* Revocation status: libcurl may depend on backend/OS configuration. */
    curl_easy_setopt(curl, CURLOPT_ERRORBUFFER, errbuf);
    curl_easy_setopt(curl, CURLOPT_NOSIGNAL, 1L);
    curl_easy_setopt(curl, CURLOPT_USERAGENT, "SecureClient/1.0");
    curl_easy_setopt(curl, CURLOPT_ACCEPT_ENCODING, ""); /* enable all built-in encodings */
    if (timeout_ms > 0) {
        curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT_MS, timeout_ms / 2L + (timeout_ms % 2L));
        curl_easy_setopt(curl, CURLOPT_TIMEOUT_MS, timeout_ms);
    }
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void*)&mb);

    CURLcode res = curl_easy_perform(curl);
    long http_code = 0L;
    curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);

    int ret = 0;
    if (res != CURLE_OK || mb.overflowed) {
        ret = -5;
        if (mb.overflowed && out_err && out_err_sz > 0U) {
            snprintf(out_err, out_err_sz, "Response too large (limit %u bytes)", (unsigned)MAX_BODY_SIZE);
        } else if (out_err && out_err_sz > 0U) {
            if (errbuf[0] != '\0') {
                snprintf(out_err, out_err_sz, "%s", errbuf);
            } else {
                snprintf(out_err, out_err_sz, "CURL error: %d", (int)res);
            }
        }
        free_memory_buffer(&mb);
        curl_easy_cleanup(curl);
        return ret;
    }

    /* Success: transfer ownership of buffer to caller */
    *out_body = mb.data;
    *out_status_code = http_code;

    /* Detach mb so free_memory_buffer doesn't free the data we return */
    mb.data = NULL;
    free_memory_buffer(&mb);
    curl_easy_cleanup(curl);
    return 0;
}

static int http_client_global_init(void) {
    CURLcode rc = curl_global_init(CURL_GLOBAL_DEFAULT);
    return (rc == CURLE_OK) ? 0 : -1;
}

static int http_client_global_cleanup(void) {
    curl_global_cleanup();
    return 0;
}

/* Run one request and print a concise result. Returns 0 on success. */
static int run_single_request(const char *url) {
    char *body = NULL;
    long status = 0L;
    char err[256];
    int rc = make_http_request(url, 10000L, &body, &status, err, sizeof(err));
    if (rc != 0) {
        printf("URL: %s\n", url);
        printf("Error: %s\n\n", err[0] ? err : "Unknown error");
        return rc;
    }
    /* Print first 200 bytes of body safely as text */
    size_t body_len = bounded_strnlen(body, MAX_BODY_SIZE);
    size_t preview_len = body_len < 200U ? body_len : 200U;

    printf("URL: %s\n", url);
    printf("HTTP Status: %ld\n", status);
    printf("Body (first %zu bytes):\n", preview_len);
    if (preview_len > 0U) {
        /* Print printable characters, replace others with '.' to avoid terminal issues */
        for (size_t i = 0; i < preview_len; i++) {
            unsigned char c = (unsigned char)body[i];
            if (isprint(c) || c == '\n' || c == '\r' || c == '\t') {
                putchar((int)c);
            } else {
                putchar('.');
            }
        }
        if (preview_len > 0U && body[preview_len - 1] != '\n') putchar('\n');
    } else {
        printf("(empty)\n");
    }
    printf("\n");

    free(body);
    return 0;
}

int main(void) {
    if (http_client_global_init() != 0) {
        fprintf(stderr, "Failed to initialize HTTP client (libcurl).\n");
        return 1;
    }

    /* Five test cases */
    const char *tests[5] = {
        "https://example.com/",
        "http://example.com/",
        "https://www.iana.org/domains/example",
        "https://httpbin.org/get",
        "ftp://example.com/" /* should be rejected by validation */
    };

    printf("=== Running 5 automated test cases ===\n\n");
    for (size_t i = 0; i < 5; i++) {
        run_single_request(tests[i]);
    }

    /* Interactive: accept one URL from user */
    printf("=== Enter a URL (http or https) to fetch (or press Enter to skip): ===\n");
    char input[MAX_URL_LEN + 4];
    if (fgets(input, (int)sizeof(input), stdin) != NULL) {
        /* Strip newline */
        size_t inlen = bounded_strnlen(input, sizeof(input));
        if (inlen > 0U && input[inlen - 1U] == '\n') {
            input[inlen - 1U] = '\0';
            inlen--;
        }
        if (inlen > 0U) {
            run_single_request(input);
        } else {
            printf("No URL entered. Exiting.\n");
        }
    } else {
        printf("No input read. Exiting.\n");
    }

    http_client_global_cleanup();
    return 0;
}
