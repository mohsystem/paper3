    int t5a = auth_register(&svc, "diana", "Sup3r!Secur3PW");
    auth_set_ttl(&svc, 1);
    char token5[65]; memset(token5, 0, sizeof(token5));
    int t5b = auth_login(&svc, "diana", "Sup3r!Secur3PW", token5, sizeof(token5));
    // Sleep ~1.2 seconds
