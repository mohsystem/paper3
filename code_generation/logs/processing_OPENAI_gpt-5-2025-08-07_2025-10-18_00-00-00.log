# Python version
# Run: python3 task76.py [https_url...]
import re
import sys
import urllib.parse
from typing import Optional

import requests

MAX_URL_LEN = 2048
MAX_BODY_SIZE = 5 * 1024 * 1024  # 5 MiB
USER_AGENT = "Task76-Client/1.0 (+https://example.local)"

TITLE_RE = re.compile(r"(?is)<title[^>]*>(.*?)</title>")

def is_valid_https_url(url: str) -> bool:
    if not isinstance(url, str):
        return False
    if len(url) == 0 or len(url) > MAX_URL_LEN:
        return False
    parts = urllib.parse.urlsplit(url)
    return parts.scheme.lower() == "https" and bool(parts.netloc)

def extract_title(html: str) -> str:
    if not html:
        return ""
    m = TITLE_RE.search(html)
    if not m:
        return ""
    title = re.sub(r"\s+", " ", m.group(1)).strip()
    return title

def get_page_title_from_url(url: str) -> str:
    if not is_valid_https_url(url):
        return ""
    try:
        with requests.Session() as s:
            headers = {"User-Agent": USER_AGENT}
            resp = s.get(url, headers=headers, timeout=(15, 45), allow_redirects=True, stream=True)
            if not (200 <= resp.status_code < 300):
                return ""
            content = b""
            size = 0
            for chunk in resp.iter_content(chunk_size=8192):
                if chunk:
                    size += len(chunk)
                    if size > MAX_BODY_SIZE:
                        return ""
                    content += chunk
            resp.close()
            # requests will try to guess encoding; fall back to utf-8
            enc = resp.encoding or "utf-8"
            try:
                text = content.decode(enc, errors="replace")
            except Exception:
                text = content.decode("utf-8", errors="replace")
            return extract_title(text)
    except Exception:
        return ""

def run_test(url: str) -> None:
    title = get_page_title_from_url(url)
    print(f"URL: {url}")
    print(f"Title: {title if title else '[Not found or fetch failed]'}\n")

def main() -> None:
    if len(sys.argv) > 1:
        for u in sys.argv[1:]:
            run_test(u)
    else:
        tests = [
            "https://www.example.com/",
            "https://www.iana.org/domains/reserved",
            "https://www.wikipedia.org/",
            "https://httpbin.org/html",
            "https://www.rfc-editor.org/",
        ]
        for t in tests:
            run_test(t)

if __name__ == "__main__":
    main()
