static int mkdir_p(const char *path, mode_t mode) {
    // Simple mkdir -p for single-level or nested with '/'
    char tmp[MAX_PATH_LEN];
    size_t len = safe_strnlen(path, sizeof(tmp));
    if (len == 0 || len >= sizeof(tmp)) return -1;
    memcpy(tmp, path, len);
    tmp[len] = '\0';
    for (size_t i = 1; i < len; i++) {
        if (tmp[i] == '/') {
            tmp[i] = '\0';
            if (mkdir(tmp, mode) != 0 && errno != EEXIST) return -1;
            tmp[i] = '/';
        }
    }
    if (mkdir(tmp, mode) != 0 && errno != EEXIST) return -1;
    return 0;
}

static int write_text_file_secure(const char *path, const char *content) {
    // Write new file with O_CREAT|O_EXCL to avoid clobbering
    int fd = open(path, O_WRONLY | O_CREAT | O_EXCL | O_CLOEXEC, 0600);
    if (fd < 0) return -1;
    size_t len = safe_strnlen(content, SIZE_MAX);
    if (write_all(fd, (const unsigned char *)content, len) != 0) {
        int e = errno;
        close(fd);
        errno = e;
        return -1;
    }
    // Flush to disk
    if (fsync(fd) != 0) {
        int e = errno;
        close(fd);
        errno = e;
        return -1;
    }
    if (close(fd) != 0) {
        return -1;
    }
    return 0;
}

static void print_separator(const char *title) {
    fprintf(stderr, "\n===== %s =====\n", title);
}

int main(int argc, char *argv[]) {
    // If arguments provided, run in normal mode: base_dir and relative path
    if (argc == 3) {
        return read_and_print_file_secure(argv[1], argv[2]);
    }

    // Otherwise, run 5 test cases
    char base_dir[256];
    pid_t pid = getpid();
    snprintf(base_dir, sizeof(base_dir), "test_base_%ld", (long)pid);

    // Setup
    if (mkdir_p(base_dir, 0700) != 0) {
        perror("Failed to create base test directory");
        return 1;
    }
    char subdir[512];
    snprintf(subdir, sizeof(subdir), "%s/dir", base_dir);
    if (mkdir_p(subdir, 0700) != 0) {
        perror("Failed to create subdir");
        return 1;
    }

    char file1[512];
    snprintf(file1, sizeof(file1), "%s/a.txt", base_dir);
    if (write_text_file_secure(file1, "Hello from a.txt\nLine2\n") != 0) {
        perror("Failed to create a.txt");
        return 1;
    }

    char file2[512];
    snprintf(file2, sizeof(file2), "%s/dir/b.txt", base_dir);
    if (write_text_file_secure(file2, "Content of dir/b.txt") != 0) {
        perror("Failed to create dir/b.txt");
        return 1;
    }

    // Outside file for traversal/symlink tests
    const char *outside_file = "outside.txt";
    // Allow overwrite attempt guard: try create; if exists, ignore
    if (write_text_file_secure(outside_file, "Outside content") != 0 && errno != EEXIST) {
        perror("Failed to create outside.txt");
        return 1;
    }

    // Optional symlink inside base -> outside
    char linkpath[512];
    snprintf(linkpath, sizeof(linkpath), "%s/link_to_outside", base_dir);
    int made_symlink = 0;
#if defined(__unix__) || defined(__APPLE__)
    // Remove if exists
    unlink(linkpath);
    if (symlink("../outside.txt", linkpath) == 0) {
        made_symlink = 1;
    }
#endif

    int rc_total = 0;

    // Test 1: Valid file
    print_separator("TEST 1: valid file a.txt");
    rc_total |= (read_and_print_file_secure(base_dir, "a.txt") == 0) ? 0 : 1;

    // Test 2: Valid nested file
    print_separator("TEST 2: valid nested file dir/b.txt");
    rc_total |= (read_and_print_file_secure(base_dir, "dir/b.txt") == 0) ? 0 : 1;

    // Test 3: Attempt path traversal
    print_separator("TEST 3: traversal attempt ../outside.txt (should fail)");
    rc_total |= (read_and_print_file_secure(base_dir, "../outside.txt") != 0) ? 0 : 1;

    // Test 4: Symlink attempt (if available)
    print_separator("TEST 4: symlink to outside (should fail if symlinks supported)");
    if (made_symlink) {
        rc_total |= (read_and_print_file_secure(base_dir, "link_to_outside") != 0) ? 0 : 1;
    } else {
        fprintf(stderr, "Symlink not created or not supported on this platform; skipping failure expectation.\n");
        // Still run: expect either fail (preferred) or success on platforms without O_NOFOLLOW.
        (void)read_and_print_file_secure(base_dir, "link_to_outside");
    }

    // Test 5: Directory read attempt (should fail)
    print_separator("TEST 5: attempt to open directory 'dir' (should fail)");
    rc_total |= (read_and_print_file_secure(base_dir, "dir") != 0) ? 0 : 1;

    // Cleanup (best-effort)
    unlink(file1);
    unlink(file2);
#if defined(__unix__) || defined(__APPLE__)
    unlink(linkpath);
#endif
    rmdir(subdir);
    rmdir(base_dir);

    fprintf(stderr, "\nOverall test result: %s\n", (rc_total == 0) ? "PASS" : "FAIL");
    return rc_total;
}
