            } else if (i < n && s[i] == '}') {
                ++i;
                if (!appendChar('}')) return false;
                return true;
            } else {
                setError("Expected ',' or '}' in object");
                return false;
            }
        }
        setError("Unterminated object");
        return false;
    }

    bool parseArray() {
        if (s[i] != '[') { setError("Expected ["); return false; }
        ++i;
        skipWS();
        if (!appendChar('[')) return false;
        bool first = true;
        size_t count = 0;
        if (i < n && s[i] == ']') {
            ++i;
