/*
 * Secure HTTP(S) GET requester using libcurl.
 * - Validates input URL (scheme must be https, host required, no credentials).
 * - Enforces TLS certificate and hostname verification.
 * - Restricts protocols to HTTPS and follows limited redirects.
 * - Writes response to memory with strict bounds checks.
 *
 * Build (example):
 *   cc -std=c11 -Wall -Wextra -O2 task160.c -o task160 -lcurl
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>
#include <ctype.h>

#include <curl/curl.h>
#include <curl/urlapi.h>

#define MAX_URL_LEN          2048
#define DEFAULT_TIMEOUT_MS   10000L
#define DEFAULT_CONNECT_MS   5000L
#define MAX_REDIRECTS        5L
#define DEFAULT_MAX_BYTES    (256 * 1024) /* 256 KiB */
#define PREVIEW_BYTES        200

typedef enum {
    REQ_OK = 0,
    REQ_ERR_INVALID_INPUT = 1,
    REQ_ERR_CURL_GLOBAL = 2,
    REQ_ERR_CURL_EASY = 3,
    REQ_ERR_CURL_PERFORM = 4,
    REQ_ERR_MEMORY = 5
} ReqResult;

typedef struct {
    char *data;
    size_t size;
    size_t capacity;
    size_t limit;
    int had_error;
} MemoryBlock;

static void mb_init(MemoryBlock *mb, size_t limit) {
    if (mb == NULL) return;
    mb->data = NULL;
    mb->size = 0;
    mb->capacity = 0;
    mb->limit = limit;
    mb->had_error = 0;
}

static void *safe_realloc(void *ptr, size_t new_size) {
    if (new_size == 0) {
        free(ptr);
        return NULL;
    }
    return realloc(ptr, new_size);
}

static int mb_reserve(MemoryBlock *mb, size_t needed) {
    if (!mb) return 0;
    if (needed <= mb->capacity) return 1;

    size_t new_cap = mb->capacity ? mb->capacity : 1024;
    while (new_cap < needed) {
        if (new_cap > SIZE_MAX / 2) {
            new_cap = needed; /* fall back to exact need to avoid overflow */
            break;
        }
        new_cap *= 2;
    }
    char *new_data = (char *)safe_realloc(mb->data, new_cap);
    if (!new_data) return 0;
    mb->data = new_data;
    mb->capacity = new_cap;
    return 1;
}

static size_t write_callback(char *ptr, size_t size, size_t nmemb, void *userdata) {
    MemoryBlock *mb = (MemoryBlock *)userdata;
    if (!mb || !ptr) return 0;

    /* Compute total bytes with overflow check */
    if (size != 0 && nmemb > SIZE_MAX / size) {
        mb->had_error = 1;
        return 0;
    }
    size_t total = size * nmemb;

    /* Enforce limit */
    size_t remaining = (mb->limit > mb->size) ? (mb->limit - mb->size) : 0;
    size_t to_write = (total <= remaining) ? total : remaining;
    if (to_write == 0) {
        mb->had_error = 1;
        return 0; /* signal error to curl */
    }

    /* Ensure capacity (+1 for NUL-terminator) with overflow-safe check */
    if (mb->size > SIZE_MAX - to_write - 1) {
        mb->had_error = 1;
        return 0;
    }
    size_t needed = mb->size + to_write + 1;
    if (!mb_reserve(mb, needed)) {
        mb->had_error = 1;
        return 0;
    }

    memcpy(mb->data + mb->size, ptr, to_write);
    mb->size += to_write;
    mb->data[mb->size] = '\0';

    /* Returning less than total makes libcurl fail with a write error, which is desired if capped */
    return to_write;
}

/* Case-insensitive ASCII compare */
static int ascii_casecmp(const char *a, const char *b) {
    if (!a || !b) return -1;
    while (*a && *b) {
        unsigned char ca = (unsigned char)*a++;
        unsigned char cb = (unsigned char)*b++;
        ca = (unsigned char)tolower((int)ca);
        cb = (unsigned char)tolower((int)cb);
        if (ca != cb) return (int)ca - (int)cb;
    }
    return (int)(unsigned char)*a - (int)(unsigned char)*b;
}

/* Validate URL: length, scheme=https, host present, no credentials */
static int validate_https_url(const char *url, char *errbuf, size_t errsz) {
    if (!url) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "URL is NULL");
        return 0;
    }
    size_t len = strnlen(url, MAX_URL_LEN + 1);
    if (len == 0 || len > MAX_URL_LEN) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "URL length invalid (1..%d required)", MAX_URL_LEN);
        return 0;
    }

    CURLU *u = curl_url();
    if (!u) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "Failed to create URL parser");
        return 0;
    }
    CURLUcode uc = curl_url_set(u, CURLUPART_URL, url, CURLU_DEFAULT_SCHEME);
    if (uc != CURLUE_OK) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "Malformed URL");
        curl_url_cleanup(u);
        return 0;
    }

    char *scheme = NULL;
    char *host = NULL;
    char *user = NULL;
    char *password = NULL;

    uc = curl_url_get(u, CURLUPART_SCHEME, &scheme, 0);
    if (uc != CURLUE_OK || !scheme) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "URL missing scheme");
        curl_url_cleanup(u);
        return 0;
    }
    if (ascii_casecmp(scheme, "https") != 0) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "Only HTTPS URLs are allowed");
        curl_free(scheme);
        curl_url_cleanup(u);
        return 0;
    }

    uc = curl_url_get(u, CURLUPART_HOST, &host, 0);
    if (uc != CURLUE_OK || !host || host[0] == '\0') {
        if (errbuf && errsz) snprintf(errbuf, errsz, "URL missing host");
        if (scheme) curl_free(scheme);
        curl_url_cleanup(u);
        return 0;
    }

    /* Disallow embedded credentials */
    (void)curl_url_get(u, CURLUPART_USER, &user, 0);
    (void)curl_url_get(u, CURLUPART_PASSWORD, &password, 0);
    if ((user && user[0] != '\0') || (password && password[0] != '\0')) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "Credentials in URL are not allowed");
        if (scheme) curl_free(scheme);
        if (host) curl_free(host);
        if (user) curl_free(user);
        if (password) curl_free(password);
        curl_url_cleanup(u);
        return 0;
    }

    if (scheme) curl_free(scheme);
    if (host) curl_free(host);
    if (user) curl_free(user);
    if (password) curl_free(password);
    curl_url_cleanup(u);
    return 1;
}

/* Perform HTTPS GET into memory with limits and TLS verification. Returns 0 on success. */
static int https_get_to_memory(const char *url,
                               long timeout_ms,
                               long connect_timeout_ms,
                               long max_redirects,
                               size_t max_bytes,
                               char **out_data,
                               size_t *out_size,
                               char *errbuf,
                               size_t errsz) {
    if (!out_data || !out_size) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "Output pointers are NULL");
        return REQ_ERR_INVALID_INPUT;
    }
    *out_data = NULL;
    *out_size = 0;

    char vbuf[128];
    if (!validate_https_url(url, vbuf, sizeof(vbuf))) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "Invalid URL: %s", vbuf);
        return REQ_ERR_INVALID_INPUT;
    }

    CURLcode ginit = curl_global_init(CURL_GLOBAL_DEFAULT);
    if (ginit != CURLE_OK) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "curl_global_init failed: %s", curl_easy_strerror(ginit));
        return REQ_ERR_CURL_GLOBAL;
    }

    CURL *curl = curl_easy_init();
    if (!curl) {
        if (errbuf && errsz) snprintf(errbuf, errsz, "curl_easy_init failed");
        curl_global_cleanup();
        return REQ_ERR_CURL_EASY;
    }

    char curl_err[CURL_ERROR_SIZE];
    curl_err[0] = '\0';

    MemoryBlock mb;
    mb_init(&mb, (max_bytes == 0) ? DEFAULT_MAX_BYTES : max_bytes);

    /* Set robust, secure options */
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS_STR, "https");
    curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS_STR, "https");
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, (max_redirects < 0) ? MAX_REDIRECTS : max_redirects);

    /* TLS verification */
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);

    /* Timeouts */
    curl_easy_setopt(curl, CURLOPT_NOSIGNAL, 1L);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT_MS, (timeout_ms <= 0) ? DEFAULT_TIMEOUT_MS : timeout_ms);
    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT_MS, (connect_timeout_ms <= 0) ? DEFAULT_CONNECT_MS : connect_timeout_ms);

    /* HTTP specifics */
    curl_easy_setopt(curl, CURLOPT_HTTPGET, 1L);
    curl_easy_setopt(curl, CURLOPT_ACCEPT_ENCODING, ""); /* enable compression if available */
    curl_easy_setopt(curl, CURLOPT_USERAGENT, "Task160/1.0 (+https)");

    /* Write callback */
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &mb);

    /* Error buffer */
    curl_easy_setopt(curl, CURLOPT_ERRORBUFFER, curl_err);

    CURLcode rc = curl_easy_perform(curl);
    long response_code = 0;
    if (rc == CURLE_OK) {
        (void)curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &response_code);
    }

    int result = REQ_OK;
    if (rc != CURLE_OK || mb.had_error) {
        if (errbuf && errsz) {
            const char *msg = curl_err[0] ? curl_err : curl_easy_strerror(rc);
            snprintf(errbuf, errsz, "Request failed: %s", msg);
        }
        result = REQ_ERR_CURL_PERFORM;
        free(mb.data);
        mb.data = NULL;
        mb.size = 0;
    } else {
        /* Ensure NUL-terminated */
        if (!mb.data) {
            /* No data received; still allocate empty buffer */
            mb.data = (char *)malloc(1);
            if (!mb.data) {
                if (errbuf && errsz) snprintf(errbuf, errsz, "Out of memory");
                result = REQ_ERR_MEMORY;
            } else {
                mb.data[0] = '\0';
                mb.size = 0;
            }
        }
        if (result == REQ_OK) {
            *out_data = mb.data;
            *out_size = mb.size;
        } else {
            if (mb.data) free(mb.data);
        }
    }

    curl_easy_cleanup(curl);
    curl_global_cleanup();
    return result;
}

/* Produce a sanitized preview string (printable ASCII) */
static void print_preview(const char *data, size_t size, size_t max_preview) {
    if (!data) return;
    size_t n = (size < max_preview) ? size : max_preview;
    for (size_t i = 0; i < n; i++) {
        unsigned char c = (unsigned char)data[i];
        if (c == '\r' || c == '\n' || (c >= 32 && c <= 126)) {
            putchar((int)c);
        } else {
            putchar('.');
        }
    }
    if (size > n) {
        printf("... [truncated]");
    }
    putchar('\n');
}

/* Trim trailing newline from fgets */
static void trim_newline(char *s) {
    if (!s) return;
    size_t len = strlen(s);
    while (len > 0 && (s[len - 1] == '\n' || s[len - 1] == '\r')) {
        s[len - 1] = '\0';
        len--;
    }
}

int main(void) {
    const char *tests[5] = {
        "https://www.example.com/",
        "https://httpbin.org/get",
        "ftp://example.com/",                       /* invalid scheme: should fail */
        "https://expired.badssl.com/",              /* TLS expired: should fail */
        "https://this-domain-should-not-exist.invalid/" /* DNS fail: should fail */
    };

    printf("Running 5 test cases:\n");
    for (int i = 0; i < 5; i++) {
        const char *url = tests[i];
        char *body = NULL;
        size_t body_len = 0;
        char err[256];
        err[0] = '\0';

        int rc = https_get_to_memory(url,
                                     DEFAULT_TIMEOUT_MS,
                                     DEFAULT_CONNECT_MS,
                                     MAX_REDIRECTS,
                                     DEFAULT_MAX_BYTES,
                                     &body,
                                     &body_len,
                                     err,
                                     sizeof(err));

        printf("Test %d: %s\n", i + 1, url);
        if (rc == REQ_OK) {
            printf("  Success. Bytes received: %zu\n", body_len);
            printf("  Preview: ");
            print_preview(body, body_len, PREVIEW_BYTES);
            free(body);
        } else {
            printf("  Failed. Error: %s\n", err[0] ? err : "Unknown error");
        }
    }

    /* Accept URL from user */
    char input[MAX_URL_LEN + 4];
    printf("\nEnter an HTTPS URL to fetch (or press Enter to quit): ");
    if (fgets(input, sizeof(input), stdin) != NULL) {
        trim_newline(input);
        if (input[0] != '\0') {
            char *body = NULL;
            size_t body_len = 0;
            char err[256];
            err[0] = '\0';
            int rc = https_get_to_memory(input,
                                         DEFAULT_TIMEOUT_MS,
                                         DEFAULT_CONNECT_MS,
                                         MAX_REDIRECTS,
                                         DEFAULT_MAX_BYTES,
                                         &body,
                                         &body_len,
                                         err,
                                         sizeof(err));
            if (rc == REQ_OK) {
                printf("Request successful. Bytes received: %zu\n", body_len);
                printf("Preview: ");
                print_preview(body, body_len, PREVIEW_BYTES);
                free(body);
            } else {
                printf("Request failed. Error: %s\n", err[0] ? err : "Unknown error");
            }
        } else {
            printf("No URL entered. Exiting.\n");
        }
    } else {
        printf("Input error. Exiting.\n");
    }

    return 0;
}
