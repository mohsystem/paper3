// Java version: Task76
import java.net.URI;
import java.net.URISyntaxException;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import java.nio.ByteBuffer;
import java.nio.charset.Charset;
import java.nio.charset.StandardCharsets;
import java.time.Duration;
import java.util.Optional;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class Task76 {

    private static final int MAX_URL_LEN = 2048;
    private static final int MAX_BODY_SIZE = 5 * 1024 * 1024; // 5 MiB
    private static final String USER_AGENT = "Task76-Client/1.0 (+https://example.local)";
    private static final Pattern TITLE_RE = Pattern.compile("(?is)<title[^>]*>(.*?)</title>");

    public static boolean isValidHttpsUrl(String url) {
        if (url == null) return false;
        if (url.length() == 0 || url.length() > MAX_URL_LEN) return false;
        return url.regionMatches(true, 0, "https://", 0, "https://".length());
    }

    private static Charset charsetFromContentType(String ct) {
        if (ct == null) return StandardCharsets.UTF_8;
        String lower = ct.toLowerCase();
        int idx = lower.indexOf("charset=");
        if (idx >= 0) {
            String cs = ct.substring(idx + 8).trim();
            int semi = cs.indexOf(';');
            if (semi >= 0) cs = cs.substring(0, semi);
            cs = cs.replaceAll("[\"']", "").trim();
            try {
                return Charset.forName(cs);
            } catch (Exception ignored) {}
        }
        return StandardCharsets.UTF_8;
    }

    private static String trimAndCollapseWs(String s) {
        String t = s.replaceAll("\\s+", " ").trim();
        return t;
    }

    public static String extractTitle(String html) {
        if (html == null) return "";
        Matcher m = TITLE_RE.matcher(html);
        if (m.find()) {
            return trimAndCollapseWs(m.group(1));
        }
        return "";
    }

    public static String getPageTitleFromUrl(String url) throws Exception {
        if (!isValidHttpsUrl(url)) {
            return "";
        }

        URI uri;
        try {
            uri = new URI(url);
        } catch (URISyntaxException e) {
            return "";
        }
        if (!"https".equalsIgnoreCase(uri.getScheme())) {
            return "";
        }

        HttpClient client = HttpClient.newBuilder()
                .followRedirects(HttpClient.Redirect.NORMAL)
                .connectTimeout(Duration.ofSeconds(15))
                .build();

        HttpRequest request = HttpRequest.newBuilder(uri)
                .timeout(Duration.ofSeconds(45))
                .header("User-Agent", USER_AGENT)
                .GET()
                .build();

        HttpResponse<byte[]> resp = client.send(request, HttpResponse.BodyHandlers.ofByteArray());

        int code = resp.statusCode();
        if (code < 200 || code >= 300) {
            return "";
        }

        byte[] bodyBytes = resp.body();
        if (bodyBytes == null) return "";
        if (bodyBytes.length > MAX_BODY_SIZE) {
            return "";
        }

        Optional<String> ct = resp.headers().firstValue("content-type");
        Charset cs = charsetFromContentType(ct.orElse(null));

        String body = new String(bodyBytes, cs);
        return extractTitle(body);
    }

    private static void runTest(String url) {
        try {
            String title = getPageTitleFromUrl(url);
            System.out.println("URL: " + url);
            System.out.println("Title: " + (title.isEmpty() ? "[Not found or fetch failed]" : title));
            System.out.println();
        } catch (Exception e) {
            System.out.println("URL: " + url);
            System.out.println("Title: [Not found or fetch failed]");
            System.out.println();
        }
    }

    public static void main(String[] args) {
        if (args != null && args.length > 0) {
            for (String arg : args) {
                runTest(arg);
            }
        } else {
            String[] tests = new String[] {
                "https://www.example.com/",
                "https://www.iana.org/domains/reserved",
                "https://www.wikipedia.org/",
                "https://httpbin.org/html",
                "https://www.rfc-editor.org/"
            };
            for (String t : tests) {
                runTest(t);
            }
        }
    }
}
