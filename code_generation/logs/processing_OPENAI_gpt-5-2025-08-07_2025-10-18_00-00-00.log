}

/* Compute SHA-256 hex of data for non-sensitive reporting */
static int sha256_hex(const unsigned char *data, size_t len, char out_hex[SHA256_DIGEST_LENGTH * 2 + 1]) {
    unsigned char digest[SHA256_DIGEST_LENGTH];
    if (!data || !out_hex) return 0;
    if (!SHA256(data, len, digest)) return 0;
    static const char *hex = "0123456789abcdef";
    for (size_t i = 0; i < SHA256_DIGEST_LENGTH; i++) {
        out_hex[i*2]     = hex[(digest[i] >> 4) & 0xF];
        out_hex[i*2 + 1] = hex[digest[i] & 0xF];
    }
    out_hex[SHA256_DIGEST_LENGTH * 2] = '\0';
    OPENSSL_cleanse(digest, sizeof(digest));
    return 1;
}

/* Generate random bytes */
static int random_bytes(unsigned char *buf, size_t len) {
    if (!buf || len == 0) return 0;
    return RAND_bytes(buf, (int)len) == 1;
}

/* Test: Single case runner */
static int run_test_case(size_t case_no, size_t pass_len, size_t key_len) {
    int ok = 0;
    unsigned char *pass = NULL;
    unsigned char *key = NULL;
    unsigned char *pkg = NULL;
    size_t pkg_len = 0;
    unsigned char *dec = NULL;
    size_t dec_len = 0;
    char hash_hex[SHA256_DIGEST_LENGTH * 2 + 1];

    pass = (unsigned char *)OPENSSL_malloc(pass_len);
    key  = (unsigned char *)OPENSSL_malloc(key_len);
    if (!pass || !key) goto cleanup;

    if (!random_bytes(pass, pass_len)) goto cleanup;
    if (!random_bytes(key, key_len)) goto cleanup;

    if (!encrypt_key_cbc_etm(pass, pass_len, key, key_len, &pkg, &pkg_len)) goto cleanup;

    if (!decrypt_key_cbc_etm(pass, pass_len, pkg, pkg_len, &dec, &dec_len)) goto cleanup;

    /* Verify decrypted equals original without printing secrets */
    if (dec_len != key_len || CRYPTO_memcmp(dec, key, key_len) != 0) goto cleanup;

    if (!sha256_hex(pkg, pkg_len, hash_hex)) goto cleanup;

    printf("Case %zu: package_len=%zu verify=OK package_sha256=%s\n",
           case_no, pkg_len, hash_hex);

    ok = 1;

cleanup:
    if (!ok) {
        printf("Case %zu: failure\n", case_no);
    }
    if (pass) { secure_free(pass, pass_len); }
    if (key)  { secure_free(key, key_len); }
    if (pkg)  { secure_free(pkg, pkg_len); }
    if (dec)  { secure_free(dec, dec_len); }
    return ok;
}

/* Main with 5 test cases */
int main(void) {
    /* Initialize OpenSSL algorithms if needed (OpenSSL 1.1.0+ initializes automatically). */
    size_t cases[5][2] = {
        {16u, 16u},
        {24u, 32u},
        {32u, 1u},
        {20u, 64u},
        {48u, 50u}
    };

    int all_ok = 1;
    for (size_t i = 0; i < 5; i++) {
        if (!run_test_case(i + 1, cases[i][0], cases[i][1])) {
            all_ok = 0;
        }
    }
    /* Return non-zero on failure */
    return all_ok ? 0 : 1;
}
