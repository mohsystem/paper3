```c
#include <arpa/inet.h>
#include <errno.h>
#include <netinet/in.h>
#include <netinet/tcp.h>
#include <pthread.h>
#include <signal.h>
#include <stdatomic.h>
#include <stdbool.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/socket.h>
#include <sys/types.h>
#include <unistd.h>

#ifndef MSG_NOSIGNAL
#define MSG_NOSIGNAL 0
#endif

#define MAX_LINE 512
#define MAX_CLIENTS 64

typedef struct {
    int fd;
    int id;
    bool in_use;
} client_entry_t;

typedef struct {
    int listen_fd;
    atomic_bool running;
    pthread_t accept_thread;
    pthread_mutex_t clients_mtx;
    client_entry_t clients[MAX_CLIENTS];
    atomic_int next_id;
} chat_server_t;

static bool set_tcp_nodelay(int fd) {
    int flag = 1;
    return setsockopt(fd, IPPROTO_TCP, TCP_NODELAY, &flag, sizeof(flag)) == 0;
}

static bool set_reuseaddr(int fd) {
    int flag = 1;
    return setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &flag, sizeof(flag)) == 0;
}

static int create_listen_socket(uint16_t port) {
    int fd = socket(AF_INET, SOCK_STREAM, 0);
    if (fd < 0) return -1;
    if (!set_reuseaddr(fd)) {
        close(fd);
        return -1;
    }
    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    if (inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr) != 1) {
        close(fd);
        return -1;
    }
    if (bind(fd, (struct sockaddr*)&addr, sizeof(addr)) != 0) {
        close(fd);
        return -1;
    }
    if (listen(fd, 16) != 0) {
        close(fd);
        return -1;
    }
    return fd;
}

static int connect_socket(const char* host, uint16_t port) {
    int fd = socket(AF_INET, SOCK_STREAM, 0);
    if (fd < 0) return -1;
    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    if (inet_pton(AF_INET, host, &addr.sin_addr) != 1) {
        close(fd);
        return -1;
    }
    if (connect(fd, (struct sockaddr*)&addr, sizeof(addr)) != 0) {
        close(fd);
        return -1;
    }
    set_tcp_nodelay(fd);
    return fd;
}

static bool send_all(int fd, const char* data, size_t len) {
    size_t sent = 0;
    while (sent < len) {
        ssize_t n = send(fd, data + sent, len - sent, MSG_NOSIGNAL);
        if (n < 0) {
            if (errno == EINTR) continue;
            return false;
        }
        if (n == 0) return false;
        sent += (size_t)n;
    }
    return true;
}

static bool send_line(int fd, const char* line) {
    size_t len = strlen(line);
    char* buf = (char*)malloc(len + 2);
    if (buf == NULL) return false;
    memcpy(buf, line, len);
    if (len == 0 || line[len - 1] != '\n') {
        buf[len] = '\n';
        buf[len + 1] = '\0';
        len += 1;
    } else {
        buf[len] = '\0';
    }
    bool ok = send_all(fd, buf, len);
    free(buf);
    return ok;
}

static bool recv_line(int fd, char out[MAX_LINE]) {
    size_t idx = 0;
    memset(out, 0, MAX_LINE);
    for (;;) {
        char ch;
        ssize_t n = recv(fd, &ch, 1, 0);
        if (n < 0) {
            if (errno == EINTR) continue;
            return false;
        }
        if (n == 0) return false;
        if (ch == '\n') break;
        if (ch != '\r') {
            if (idx + 1 < MAX_LINE) {
                unsigned char uc = (unsigned char)ch;
                if (uc >= 32 && uc <= 126) {
                    out[idx++] = ch;
                }
            } else {
                // drop remaining bytes until newline
            }
        }
    }
    out[MAX_LINE - 1] = '\0';
    return true;
}

static void server_broadcast(chat_server_t* srv, const char* msg) {
    char line[MAX_LINE];
    // Truncate message to avoid overflow
    size_t msg_len = strnlen(msg, MAX_LINE - 2);
    memcpy(line, msg, msg_len);
    line[msg_len] = '\n';
    line[msg_len + 1] = '\0';
    pthread_mutex_lock(&srv->clients_mtx);
    for (int i = 0; i < MAX_CLIENTS; ++i) {
        if (srv->clients[i].in_use) {
            if (!send_all(srv->clients[i].fd, line, msg_len + 1)) {
                shutdown(srv->clients[i].fd, SHUT_RDWR);
                close(srv->clients[i].fd);
                srv->clients[i].in_use = false;
            }
        }
    }
    pthread_mutex_unlock(&srv->clients_mtx);
}

typedef struct {
    chat_server_t* srv;
    int fd;
    int id;
} client_thread_arg_t;

static void* client_worker(void* arg) {
    client_thread_arg_t* cta = (client_thread_arg_t*)arg;
    chat_server_t* srv = cta->srv;
    int fd = cta->fd;
    int id = cta->id;
    free(cta);
    char buf[MAX_LINE];
    while (atomic_load(&srv->running)) {
        if (!recv_line(fd, buf)) break;
        if (buf[0] == '\0') continue;
        char msg[MAX_LINE];
        int n = snprintf(msg, sizeof(msg), "Client %d: %s", id, buf);
        if (n < 0) break;
        server_broadcast(srv, msg);
    }
    pthread_mutex_lock(&srv->clients_mtx);
    for (int i = 0; i < MAX_CLIENTS; ++i) {
        if (srv->clients[i].in_use && srv->clients[i].fd == fd) {
            srv->clients[i].in_use = false;
            break;
        }
    }
    pthread_mutex_unlock(&srv->clients_mtx);
    shutdown(fd, SHUT_RDWR);
    close(fd);

    char leave_msg[64];
    snprintf(leave_msg, sizeof(leave_msg), "Server: Client %d left", id);
    server_broadcast(srv, leave_msg);
    return NULL;
}

static void* accept_loop(void* arg) {
    chat_server_t* srv = (chat_server_t*)arg;
    while (atomic_load(&srv->running)) {
        struct sockaddr_in cli;
        socklen_t len = sizeof(cli);
        int cfd = accept(srv->listen_fd, (struct sockaddr*)&cli, &len);
        if (cfd < 0) {
            if (!atomic_load(&srv->running)) break;
            if (errno == EINTR) continue;
            usleep(10000);
            continue;
        }
        set_tcp_nodelay(cfd);
        int cid = atomic_fetch_add(&srv->next_id, 1);
        bool added = false;
        pthread_mutex_lock(&srv->clients_mtx);
        for (int i = 0; i < MAX_CLIENTS; ++i) {
            if (!srv->clients[i].in_use) {
                srv->clients[i].fd = cfd;
                srv->clients[i].id = cid;
                srv->clients[i].in_use = true;
                added = true;
                break;
            }
        }
        pthread_mutex_unlock(&srv->clients_mtx);
        if (!added) {
            const char* full = "Server full\n";
            send_all(cfd, full, strlen(full));
            shutdown(cfd, SHUT_RDWR);
            close(cfd);
            continue;
        }
        client_thread_arg_t* cta = (client_thread_arg_t*)malloc(sizeof(client_thread_arg_t));
        if (cta == NULL) {
            shutdown(cfd, SHUT_RDWR);
            close(cfd);
            continue;
        }
        cta->srv = srv;
        cta->fd = cfd;
        cta->id = cid;
        pthread_t t;
        if (pthread_create(&t, NULL, client_worker, cta) != 0) {
            shutdown(cfd, SHUT_RDWR);
            close(cfd);
            free(cta);
            continue;
        }
        pthread_detach(t);

        char join_msg[64];
        snprintf(join_msg, sizeof(join_msg), "Server: Client %d joined", cid);
        server_broadcast(srv, join_msg);
    }
    return NULL;
}

static bool server_start(chat_server_t* srv, uint16_t port) {
    memset(srv, 0, sizeof(*srv));
    srv->listen_fd = create_listen_socket(port);
    if (srv->listen_fd < 0) return false;
    pthread_mutex_init(&srv->clients_mtx, NULL);
    atomic_store(&srv->running, true);
    atomic_store(&srv->next_id, 1);
    if (pthread_create(&srv->accept_thread, NULL, accept_loop, srv) != 0) {
        close(srv->listen_fd);
        srv->listen_fd = -1;
        pthread_mutex_destroy(&srv->clients_mtx);
        atomic_store(&srv->running, false);
        return false;
    }
    return true;
}

static void server_stop(chat_server_t* srv) {
    if (!atomic_exchange(&srv->running, false)) return;
    if (srv->listen_fd >= 0) {
        shutdown(srv->listen_fd, SHUT_RDWR);
        close(srv->listen_fd);
        srv->listen_fd = -1;
    }
    pthread_join(srv->accept_thread, NULL);

    pthread_mutex_lock(&srv->clients_mtx);
    for (int i = 0; i < MAX_CLIENTS; ++i) {
        if (srv->clients[i].in_use) {
            shutdown(srv->clients[i].fd, SHUT_RDWR);
            close(srv->clients[i].fd);
            srv->clients[i].in_use = false;
        }
    }
    pthread_mutex_unlock(&srv->clients_mtx);
    pthread_mutex_destroy(&srv->clients_mtx);
}

typedef struct {
    int fd;
    atomic_bool running;
    pthread_t reader;
} chat_client_t;

static void* client_reader(void* arg) {
    chat_client_t* c = (chat_client_t*)arg;
    char line[MAX_LINE];
    while (atomic_load(&c->running)) {
        if (!recv_line(c->fd, line)) break;
        printf("[Client] Recv: %s\n", line);
        fflush(stdout);
    }
    return NULL;
}

static bool client_connect(chat_client_t* c, const char* host, uint16_t port) {
    memset(c, 0, sizeof(*c));
    c->fd = connect_socket(host, port);
    if (c->fd < 0) return false;
    atomic_store(&c->running, true);
    if (pthread_create(&c->reader, NULL, client_reader, c) != 0) {
        shutdown(c->fd, SHUT_RDWR);
        close(c->fd);
        c->fd = -1;
        atomic_store(&c->running, false);
        return false;
    }
    return true;
}

static bool client_send(chat_client_t* c, const char* msg) {
    if (c->fd < 0) return false;
    // sanitize to printable ASCII
    char filtered[MAX_LINE];
    size_t len = 0;
    size_t inlen = strnlen(msg, MAX_LINE - 1);
    for (size_t i = 0; i < inlen && len + 1 < sizeof(filtered); ++i) {
        unsigned char ch = (unsigned char)msg[i];
        if (ch >= 32 && ch <= 126) {
            filtered[len++] = (char)ch;
        }
    }
    if (len == 0) {
        const char* placeholder = "(empty)";
        len = strnlen(placeholder, sizeof(filtered) - 2);
        memcpy(filtered, placeholder, len);
    }
    filtered[len] = '\0';
    return send_line(c->fd, filtered);
}

static void client_close(chat_client_t* c) {
    if (!atomic_exchange(&c->running, false)) return;
    if (c->fd >= 0) {
        shutdown(c->fd, SHUT_RDWR);
        close(c->fd);
        c->fd = -1;
    }
    pthread_join(c->reader, NULL);
}

int main(void) {
    signal(SIGPIPE, SIG_IGN);

    const uint16_t PORT = 19049;
    chat_server_t server;
    if (!server_start(&server, PORT)) {
        fprintf(stderr, "Failed to start server\n");
        return 1;
    }

    // Create 5 clients (5 test cases)
    const int N = 5;
    chat_client_t* clients = (chat_client_t*)calloc(N, sizeof(chat_client_t));
    if (clients == NULL) {
        server_stop(&server);
        return 1;
    }
    int connected = 0;
    for (int i = 0; i < N; ++i) {
        if (client_connect(&clients[i], "127.0.0.1", PORT)) {
            connected++;
        } else {
            fprintf(stderr, "Client %d failed to connect\n", i + 1);
        }
    }

    // Give time for connections
    usleep(200 * 1000);

    // Each client sends one message
    for (int i = 0; i < N; ++i) {
        char msg[64];
        snprintf(msg, sizeof(msg), "Hello from test client #%d", i + 1);
        client_send(&clients[i], msg);
    }

    // Wait to receive broadcasts
    sleep(2);

    // Close clients
    for (int i = 0; i < N; ++i) {
        client_close(&clients[i]);
    }
    free(clients);

    // Stop server
    server_stop(&server);

    printf("Chat demo complete.\n");
    return 0;
}
