/*
  Program: HTTPS Title Extractor in C (using libcurl)
  Build:   cc -O2 -Wall -Wextra -pedantic -std=c11 task76.c -o task76 -lcurl
  Usage:   ./task76 https://example.com
           ./task76 (will run 5 built-in test URLs)
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <curl/curl.h>
#include <limits.h>

#define MAX_URL_LENGTH         2048
#define MAX_DOWNLOAD_SIZE      (8 * 1024 * 1024) /* 8 MiB safeguard */
#define CONNECT_TIMEOUT_MS     10000L
#define TRANSFER_TIMEOUT_MS    20000L
#define USER_AGENT_STRING      "Task76-HTTPS-Title-Extractor/1.0"
#define REDIRECT_LIMIT         5L

typedef struct {
    char *data;
    size_t size;
    size_t capacity;
    size_t max_allowed;
    int aborted; /* flag set if we abort due to size */
} MemoryBuffer;

/* -------- Utility: Safe size multiplication with overflow check -------- */
static int safe_mul_size(size_t a, size_t b, size_t *out) {
    if (a != 0 && b > SIZE_MAX / a) return 0;
    *out = a * b;
    return 1;
}

/* -------- Utility: Initialize memory buffer -------- */
static int mbuf_init(MemoryBuffer *mb, size_t initial_capacity, size_t max_allowed) {
    if (!mb) return 0;
    mb->data = NULL;
    mb->size = 0;
    mb->capacity = 0;
    mb->max_allowed = max_allowed;
    mb->aborted = 0;

    if (initial_capacity == 0) initial_capacity = 4096;
    if (initial_capacity > max_allowed) initial_capacity = max_allowed;

    mb->data = (char *)malloc(initial_capacity);
    if (!mb->data) return 0;
    mb->capacity = initial_capacity;
    mb->data[0] = '\0';
    return 1;
}

/* -------- Utility: Free memory buffer -------- */
static void mbuf_free(MemoryBuffer *mb) {
    if (!mb) return;
    if (mb->data) {
        /* not sensitive, no need to scrub */
        free(mb->data);
        mb->data = NULL;
    }
    mb->size = 0;
    mb->capacity = 0;
    mb->max_allowed = 0;
    mb->aborted = 0;
}

/* -------- Utility: Ensure capacity -------- */
static int mbuf_ensure_capacity(MemoryBuffer *mb, size_t needed) {
    if (!mb) return 0;
    if (needed <= mb->capacity) return 1;

    size_t new_cap = mb->capacity;
    while (new_cap < needed) {
        if (new_cap > SIZE_MAX / 2) { new_cap = needed; break; }
        new_cap *= 2;
        if (new_cap > mb->max_allowed) {
            new_cap = mb->max_allowed;
            break;
        }
    }
    if (new_cap < needed) return 0;

    char *new_data = (char *)realloc(mb->data, new_cap);
    if (!new_data) return 0;
    mb->data = new_data;
    mb->capacity = new_cap;
    return 1;
}

/* -------- cURL write callback -------- */
static size_t curl_write_callback(void *contents, size_t size, size_t nmemb, void *userp) {
    MemoryBuffer *mb = (MemoryBuffer *)userp;
    size_t total = 0;
    if (!safe_mul_size(size, nmemb, &total)) return 0;

    if (mb->size + total > mb->max_allowed) {
        mb->aborted = 1;
        return 0; /* abort transfer */
    }

    if (!mbuf_ensure_capacity(mb, mb->size + total + 1)) {
        return 0;
    }

    memcpy(mb->data + mb->size, contents, total);
    mb->size += total;
    mb->data[mb->size] = '\0';
    return total;
}

/* -------- Input validation: Simple HTTPS URL check -------- */
static int is_valid_https_url(const char *url) {
    if (!url) return 0;
    size_t len = strnlen(url, MAX_URL_LENGTH + 1);
    if (len == 0 || len > MAX_URL_LENGTH) return 0;
    const char *prefix = "https://";
    size_t prelen = strlen(prefix);
    if (len < prelen) return 0;
    if (strncmp(url, prefix, prelen) != 0) return 0;
    /* Basic character validation (ASCII, no spaces or control chars) */
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)url[i];
        if (c < 0x20 || c > 0x7E) return 0; /* restrict to visible ASCII */
        if (c == ' ' || c == '"') return 0; /* common dangerous chars */
    }
    return 1;
}

/* -------- Case-insensitive search (ASCII) -------- */
static const char *strcasestr_ascii(const char *haystack, const char *needle) {
    if (!haystack || !needle) return NULL;
    size_t nlen = strlen(needle);
    if (nlen == 0) return haystack;

    for (const char *h = haystack; *h; ++h) {
        size_t i = 0;
        while (i < nlen) {
            unsigned char hc = (unsigned char)h[i];
            unsigned char nc = (unsigned char)needle[i];
            if (tolower(hc) != tolower(nc)) break;
            i++;
        }
        if (i == nlen) return h;
        if (!h[1]) break;
    }
    return NULL;
}

/* -------- Trim leading/trailing whitespace in-place on a newly allocated string -------- */
static void trim_inplace(char *s) {
    if (!s) return;
    size_t len = strlen(s);
    size_t start = 0;
    while (start < len && isspace((unsigned char)s[start])) start++;
    size_t end = len;
    while (end > start && isspace((unsigned char)s[end - 1])) end--;

    if (start > 0) memmove(s, s + start, end - start);
    s[end - start] = '\0';
}

/* -------- Extract HTML <title>...</title> (case-insensitive) -------- */
static char *extract_title(const char *html) {
    if (!html) return NULL;

    const char *open = strcasestr_ascii(html, "<title");
    if (!open) return NULL;

    /* Find closing '>' of the opening title tag */
    const char *gt = strchr(open, '>');
    if (!gt) return NULL;

    const char *content = gt + 1;

    const char *close = strcasestr_ascii(content, "</title>");
    if (!close || close < content) return NULL;

    size_t tlen = (size_t)(close - content);
    /* Limit title length to something reasonable to avoid huge allocations */
    if (tlen > 65536) tlen = 65536;

    char *title = (char *)malloc(tlen + 1);
    if (!title) return NULL;
    memcpy(title, content, tlen);
    title[tlen] = '\0';
    trim_inplace(title);
    return title;
}

/* -------- Fetch URL over HTTPS securely and return body (malloc'ed) -------- */
static char *https_fetch_body(const char *url, long connect_timeout_ms, long transfer_timeout_ms, char **err_msg_out) {
    if (err_msg_out) *err_msg_out = NULL;
    if (!is_valid_https_url(url)) {
        if (err_msg_out) *err_msg_out = strdup("Invalid HTTPS URL");
        return NULL;
    }

    CURL *curl = NULL;
    CURLcode res;
    MemoryBuffer mb;
    char *body = NULL;

    if (!mbuf_init(&mb, 16384, MAX_DOWNLOAD_SIZE)) {
        if (err_msg_out) *err_msg_out = strdup("Memory allocation failed");
        return NULL;
    }

    curl = curl_easy_init();
    if (!curl) {
        mbuf_free(&mb);
        if (err_msg_out) *err_msg_out = strdup("Failed to initialize cURL");
        return NULL;
    }

    /* Enforce HTTPS only protocols (including redirects) */
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS, CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS, CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, REDIRECT_LIMIT);

    /* SSL certificate and hostname verification (secure defaults but make explicit) */
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);

    /* Timeouts and safe options */
    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT_MS, connect_timeout_ms);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT_MS, transfer_timeout_ms);
    curl_easy_setopt(curl, CURLOPT_NOSIGNAL, 1L);

    /* Compression accepted */
    curl_easy_setopt(curl, CURLOPT_ACCEPT_ENCODING, "");

    /* Set URL and UA */
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_USERAGENT, USER_AGENT_STRING);

    /* Write callback */
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, curl_write_callback);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void *)&mb);

    res = curl_easy_perform(curl);
    if (res != CURLE_OK || mb.aborted) {
        if (err_msg_out) {
            const char *ce = curl_easy_strerror(res);
            if (mb.aborted) {
                *err_msg_out = strdup("Download aborted: size limit exceeded");
            } else if (ce) {
                size_t l = strlen(ce);
                char *msg = (char *)malloc(l + 32);
                if (msg) {
                    snprintf(msg, l + 32, "cURL error: %s", ce);
                    *err_msg_out = msg;
                }
            } else {
                *err_msg_out = strdup("Unknown cURL error");
            }
        }
        curl_easy_cleanup(curl);
        mbuf_free(&mb);
        return NULL;
    }

    /* Success: take ownership of buffer data */
    body = mb.data;
    /* Detach so mbuf_free doesn't free it */
    mb.data = NULL;
    curl_easy_cleanup(curl);
    mbuf_free(&mb);
    return body;
}

/* -------- Public API: Get page title from HTTPS URL (malloc'ed return) -------- */
char *get_page_title_from_https_url(const char *url) {
    char *err = NULL;
    char *html = https_fetch_body(url, CONNECT_TIMEOUT_MS, TRANSFER_TIMEOUT_MS, &err);
    if (!html) {
        if (err) {
            /* For library use, we do not print errors; caller can handle. */
            free(err);
        }
        return NULL;
    }

    char *title = extract_title(html);
    free(html);
    return title;
}

/* -------- Simple printing helper with safe fallback -------- */
static void print_title_result(const char *url) {
    printf("URL: %s\n", url ? url : "(null)");
    char *title = get_page_title_from_https_url(url);
    if (title) {
        printf("Title: %s\n", title);
        free(title);
    } else {
        printf("Title: (not found or error)\n");
    }
    printf("----\n");
}

/* -------- Main: If args provided, use them; else run 5 test cases -------- */
int main(int argc, char *argv[]) {
    /* Initialize global cURL state securely */
    if (curl_global_init(CURL_GLOBAL_DEFAULT) != 0) {
        fprintf(stderr, "Failed to initialize cURL\n");
        return 1;
    }

    int exit_code = 0;
    if (argc > 1) {
        for (int i = 1; i < argc; i++) {
            if (!is_valid_https_url(argv[i])) {
                fprintf(stderr, "Invalid HTTPS URL skipped: %s\n", argv[i]);
                exit_code = 1;
                continue;
            }
            print_title_result(argv[i]);
        }
    } else {
        /* Five test URLs (may vary depending on network availability) */
        const char *tests[5] = {
            "https://example.com/",
            "https://www.wikipedia.org/",
            "https://www.iana.org/domains/reserved",
            "https://www.gnu.org/",
            "https://developer.mozilla.org/"
        };
        for (int i = 0; i < 5; i++) {
            print_title_result(tests[i]);
        }
    }

    curl_global_cleanup();
    return exit_code;
}
