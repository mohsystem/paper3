#include <arpa/inet.h>
#include <errno.h>
#include <fcntl.h>
#include <netinet/in.h>
#include <pthread.h>
#include <stdarg.h>
#include <stdbool.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/socket.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <unistd.h>

#define MAX_HEADER_SIZE 16384
#define MAX_FILE_SIZE (10 * 1024 * 1024)
#define SOCKET_TIMEOUT_SEC 10

typedef struct {
    char bindAddress[64];
    uint16_t port;
    char baseDir[256];
    int maxRequests;
} ServerConfig;

static void safe_strcpy(char *dst, size_t dstsz, const char *src) {
    if (dstsz == 0) return;
    strncpy(dst, src, dstsz - 1);
    dst[dstsz - 1] = '\0';
}

static char *sanitizeFilename(const char *input) {
    size_t n = strlen(input);
    char *out = (char *)malloc(128);
    if (!out) return NULL;
    size_t j = 0;
    for (size_t i = 0; i < n && j < 127; ++i) {
        char c = input[i];
        int ok = (c >= 'a' && c <= 'z') ||
                 (c >= 'A' && c <= 'Z') ||
                 (c >= '0' && c <= '9') ||
                 c == '.' || c == '_' || c == '-';
        out[j++] = ok ? c : '_';
    }
    out[j] = '\0';
    // remove leading '.' or '_'
    while (out[0] == '.' || out[0] == '_') {
        memmove(out, out + 1, strlen(out));
    }
    if (out[0] == '\0') {
        safe_strcpy(out, 128, "file");
    }
    // limit length to 100
    if (strlen(out) > 100) out[100] = '\0';
    return out;
}

static int createSecureDir(const char *path) {
    struct stat st;
    if (stat(path, &st) == 0) {
        if (!S_ISDIR(st.st_mode)) return -1;
    } else {
        if (mkdir(path, 0700) != 0) {
            if (errno != EEXIST) return -1;
        }
    }
    chmod(path, 0700);
    return 0;
}

static int setSocketTimeouts(int fd, int seconds) {
    struct timeval tv;
    tv.tv_sec = seconds;
    tv.tv_usec = 0;
    if (setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv)) != 0) return -1;
    if (setsockopt(fd, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof(tv)) != 0) return -1;
    return 0;
}

static int readUntil(int fd, char **outBuf, size_t *outLen, const char *delim, size_t maxBytes) {
    size_t cap = 4096;
    size_t len = 0;
    char *buf = (char *)malloc(cap);
    if (!buf) return -1;
    for (;;) {
        // check delimiter
        if (len >= 4) {
            for (size_t i = 0; i + 3 <= len; ++i) {
                if (buf[i] == '\r' && buf[i+1] == '\n' && buf[i+2] == '\r' && buf[i+3] == '\n') {
                    *outBuf = buf;
                    *outLen = len;
                    return 0;
                }
            }
        }
        if (len >= maxBytes) {
            free(buf);
            return -1;
        }
        if (len + 2048 > cap) {
            size_t ncap = cap * 2;
            if (ncap > maxBytes) ncap = maxBytes;
            char *nb = (char *)realloc(buf, ncap);
            if (!nb) {
                free(buf);
                return -1;
            }
            buf = nb;
            cap = ncap;
        }
        ssize_t rn = recv(fd, buf + len, cap - len, 0);
        if (rn == 0) {
            free(buf);
            return -1;
        }
        if (rn < 0) {
            if (errno == EINTR) continue;
            free(buf);
            return -1;
        }
        len += (size_t)rn;
    }
}

static char *http_response(int code, const char *body, size_t *outLen) {
    const char *status = "Internal Server Error";
    if (code == 200) status = "OK";
    else if (code == 400) status = "Bad Request";
    else if (code == 413) status = "Payload Too Large";
    size_t blen = strlen(body);
    char header[256];
    int hn = snprintf(header, sizeof(header),
                      "HTTP/1.1 %d %s\r\nContent-Type: text/plain; charset=utf-8\r\nContent-Length: %zu\r\nConnection: close\r\n\r\n",
                      code, status, blen);
    if (hn < 0 || (size_t)hn >= sizeof(header)) return NULL;
    size_t total = (size_t)hn + blen;
    char *resp = (char *)malloc(total + 1);
    if (!resp) return NULL;
    memcpy(resp, header, (size_t)hn);
    memcpy(resp + hn, body, blen);
    resp[total] = '\0';
    *outLen = total;
    return resp;
}

static int hexlify(const unsigned char *in, size_t n, char *out, size_t outsz) {
    static const char *hex = "0123456789abcdef";
    if (outsz < n * 2 + 1) return -1;
    for (size_t i = 0; i < n; ++i) {
        out[i*2] = hex[(in[i] >> 4) & 0xF];
        out[i*2+1] = hex[in[i] & 0xF];
    }
    out[n*2] = '\0';
    return 0;
}

static int getRandomHex(char *out, size_t hexLen) {
    size_t bytes = hexLen / 2;
    if (hexLen % 2 != 0) return -1;
    unsigned char *buf = (unsigned char *)malloc(bytes);
    if (!buf) return -1;
    int fd = open("/dev/urandom", O_RDONLY);
    if (fd < 0) { free(buf); return -1; }
    size_t got = 0;
    while (got < bytes) {
        ssize_t rn = read(fd, buf + got, bytes - got);
        if (rn <= 0) { close(fd); free(buf); return -1; }
        got += (size_t)rn;
    }
    close(fd);
    int rc = hexlify(buf, bytes, out, hexLen + 1);
    free(buf);
    return rc;
}

typedef struct {
    int clientFd;
    ServerConfig cfg;
    int *processedPtr;
} ClientCtx;

static int atomicWriteAndMove(const char *baseDir, const char *finalBaseName, int clientFd, size_t contentLen, const char *initialBody, size_t initialBodyLen, char *outFinalName, size_t outFinalNameSz, char *errMsg, size_t errMsgSz) {
    char tmpl[512];
    if (snprintf(tmpl, sizeof(tmpl), "%s/%s", baseDir, "upload-XXXXXX.tmp") <= 0) {
        safe_strcpy(errMsg, errMsgSz, "template error");
        return -1;
    }
    char *tmpPath = strdup(tmpl);
    if (!tmpPath) {
        safe_strcpy(errMsg, errMsgSz, "alloc error");
        return -1;
    }
    int tmpFd = mkstemp(tmpPath);
    if (tmpFd < 0) {
        safe_strcpy(errMsg, errMsgSz, "mkstemp failed");
        free(tmpPath);
        return -1;
    }
    fchmod(tmpFd, S_IRUSR | S_IWUSR);

    size_t remaining = contentLen;
    // write initialBody first
    if (initialBodyLen > 0) {
        size_t chunk = initialBodyLen;
        if (chunk > remaining) chunk = remaining;
        size_t off = 0;
        while (off < chunk) {
            ssize_t wn = write(tmpFd, initialBody + off, chunk - off);
            if (wn <= 0) {
                safe_strcpy(errMsg, errMsgSz, "write failed");
                close(tmpFd);
                unlink(tmpPath);
                free(tmpPath);
                return -1;
            }
            off += (size_t)wn;
        }
        remaining -= chunk;
    }

    char buf[8192];
    while (remaining > 0) {
        size_t toRead = sizeof(buf);
        if (toRead > remaining) toRead = remaining;
        ssize_t rn = recv(clientFd, buf, toRead, 0);
        if (rn <= 0) {
            safe_strcpy(errMsg, errMsgSz, "socket read failed");
            close(tmpFd);
            unlink(tmpPath);
            free(tmpPath);
            return -1;
        }
        size_t off = 0;
        while (off < (size_t)rn) {
            ssize_t wn = write(tmpFd, buf + off, (size_t)rn - off);
            if (wn <= 0) {
                safe_strcpy(errMsg, errMsgSz, "write failed");
                close(tmpFd);
                unlink(tmpPath);
                free(tmpPath);
                return -1;
            }
            off += (size_t)wn;
        }
        remaining -= (size_t)rn;
        if (contentLen - remaining > MAX_FILE_SIZE) {
            safe_strcpy(errMsg, errMsgSz, "exceeded max size");
            close(tmpFd);
            unlink(tmpPath);
            free(tmpPath);
            return -1;
        }
    }

    if (fsync(tmpFd) != 0) {
        safe_strcpy(errMsg, errMsgSz, "fsync failed");
        close(tmpFd);
        unlink(tmpPath);
        free(tmpPath);
        return -1;
    }
    if (close(tmpFd) != 0) {
        safe_strcpy(errMsg, errMsgSz, "close failed");
        unlink(tmpPath);
        free(tmpPath);
        return -1;
    }

    // Build unique final name: <sanitized>_<random>
    char rnd[13];
    if (getRandomHex(rnd, sizeof(rnd) - 1) != 0) {
        safe_strcpy(errMsg, errMsgSz, "rand failed");
        unlink(tmpPath);
        free(tmpPath);
        return -1;
    }

    char finalName[256];
    if (snprintf(finalName, sizeof(finalName), "%s_%s", finalBaseName, rnd) <= 0) {
        safe_strcpy(errMsg, errMsgSz, "final name error");
        unlink(tmpPath);
        free(tmpPath);
        return -1;
    }

    char finalPath[512];
    if (snprintf(finalPath, sizeof(finalPath), "%s/%s", baseDir, finalName) <= 0) {
        safe_strcpy(errMsg, errMsgSz, "final path error");
        unlink(tmpPath);
        free(tmpPath);
        return -1;
    }

    // Try rename, retry a couple times on EEXIST
    for (int i = 0; i < 3; ++i) {
        if (rename(tmpPath, finalPath) == 0) {
            safe_strcpy(outFinalName, outFinalNameSz, finalName);
            free(tmpPath);
            return 0;
        }
        if (errno == EEXIST) {
            if (getRandomHex(rnd, sizeof(rnd) - 1) != 0) break;
            if (snprintf(finalName, sizeof(finalName), "%s_%s", finalBaseName, rnd) <= 0) break;
            if (snprintf(finalPath, sizeof(finalPath), "%s/%s", baseDir, finalName) <= 0) break;
            continue;
        } else {
            break;
        }
    }

    safe_strcpy(errMsg, errMsgSz, "rename failed");
    unlink(tmpPath);
    free(tmpPath);
    return -1;
}

static void *serverThread(void *arg) {
    ServerConfig cfg = *(ServerConfig *)arg;

    int sfd = socket(AF_INET, SOCK_STREAM, 0);
    if (sfd < 0) {
        perror("socket");
        return NULL;
    }
    int yes = 1;
    setsockopt(sfd, SOL_SOCKET, SO_REUSEADDR, &yes, sizeof(yes));

    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(cfg.port);
    if (inet_pton(AF_INET, cfg.bindAddress, &addr.sin_addr) != 1) {
        perror("inet_pton");
        close(sfd);
        return NULL;
    }
    if (bind(sfd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {
        perror("bind");
        close(sfd);
        return NULL;
    }
    if (listen(sfd, 16) != 0) {
        perror("listen");
        close(sfd);
        return NULL;
    }

    if (createSecureDir(cfg.baseDir) != 0) {
        fprintf(stderr, "Failed to create base directory\n");
        close(sfd);
        return NULL;
    }

    int processed = 0;
    while (processed < cfg.maxRequests) {
        struct sockaddr_in caddr;
        socklen_t clen = sizeof(caddr);
        int cfd = accept(sfd, (struct sockaddr *)&caddr, &clen);
        if (cfd < 0) {
            if (errno == EINTR) continue;
            break;
        }
        setSocketTimeouts(cfd, SOCKET_TIMEOUT_SEC);

        // Read headers
        char *hdrBuf = NULL;
        size_t hdrLen = 0;
        if (readUntil(cfd, &hdrBuf, &hdrLen, "\r\n\r\n", MAX_HEADER_SIZE) != 0) {
            size_t rl;
            char *resp = http_response(400, "Invalid HTTP request\n", &rl);
            if (resp) {
                send(cfd, resp, rl, 0);
                free(resp);
            }
            close(cfd);
            continue;
        }
        // Find end of headers
        size_t sep = 0;
        for (size_t i = 0; i + 3 < hdrLen; ++i) {
            if (hdrBuf[i] == '\r' && hdrBuf[i+1] == '\n' && hdrBuf[i+2] == '\r' && hdrBuf[i+3] == '\n') {
                sep = i + 4;
                break;
            }
        }
        if (sep == 0) {
            size_t rl;
            char *resp = http_response(400, "Bad headers\n", &rl);
            if (resp) {
                send(cfd, resp, rl, 0);
                free(resp);
            }
            free(hdrBuf);
            close(cfd);
            continue;
        }
        // Parse request line
        char *reqLineEnd = memchr(hdrBuf, '\n', hdrLen);
        if (!reqLineEnd) {
            size_t rl;
            char *resp = http_response(400, "Bad request line\n", &rl);
            if (resp) { send(cfd, resp, rl, 0); free(resp); }
            free(hdrBuf);
            close(cfd);
            continue;
        }
        size_t rlLen = (size_t)(reqLineEnd - hdrBuf);
        if (rlLen > 0 && hdrBuf[rlLen - 1] == '\r') rlLen--;
        char reqLine[256];
        size_t copyLen = rlLen < sizeof(reqLine) - 1 ? rlLen : sizeof(reqLine) - 1;
        memcpy(reqLine, hdrBuf, copyLen);
        reqLine[copyLen] = '\0';

        char method[16], path[128], version[32];
        method[0] = path[0] = version[0] = '\0';
        sscanf(reqLine, "%15s %127s %31s", method, path, version);

        if (strcmp(method, "POST") != 0 || strcmp(path, "/upload") != 0) {
            size_t rl;
            char *resp = http_response(400, "Only POST /upload allowed\n", &rl);
            if (resp) { send(cfd, resp, rl, 0); free(resp); }
            free(hdrBuf);
            close(cfd);
            continue;
        }

        // Search headers for Content-Length and X-Filename
        size_t contentLen = 0;
        char filenameHeader[128];
        filenameHeader[0] = '\0';

        char *cursor = hdrBuf + (rlLen + 2); // skip request line CRLF
        while ((size_t)(cursor - hdrBuf) < sep) {
            char *eol = memchr(cursor, '\n', hdrBuf + hdrLen - cursor);
            if (!eol) break;
            size_t lineLen = (size_t)(eol - cursor);
            if (lineLen > 0 && cursor[lineLen - 1] == '\r') lineLen--;
            if (lineLen == 0) break;

            // Lowercase header name copy for comparison
            const char *colon = memchr(cursor, ':', lineLen);
            if (colon) {
                size_t nameLen = (size_t)(colon - cursor);
                size_t valueLen = lineLen - nameLen - 1;
                // Extract name and value
                char name[128];
                char value[256];
                size_t ncp = nameLen < sizeof(name) - 1 ? nameLen : sizeof(name) - 1;
                memcpy(name, cursor, ncp);
                name[ncp] = '\0';
                // to lowercase
                for (size_t i = 0; i < ncp; ++i) {
                    if (name[i] >= 'A' && name[i] <= 'Z') name[i] = (char)(name[i] - 'A' + 'a');
                }
                // value trimming
                const char *vstart = colon + 1;
                while (valueLen > 0 && (*vstart == ' ' || *vstart == '\t')) { vstart++; valueLen--; }
                while (valueLen > 0 && (vstart[valueLen - 1] == ' ' || vstart[valueLen - 1] == '\t')) { valueLen--; }
                size_t vcp = valueLen < sizeof(value) - 1 ? valueLen : sizeof(value) - 1;
                memcpy(value, vstart, vcp);
                value[vcp] = '\0';

                if (strcmp(name, "content-length") == 0) {
                    char *endp = NULL;
                    unsigned long long tmp = strtoull(value, &endp, 10);
                    if (endp && *endp == '\0' && tmp <= MAX_FILE_SIZE) {
                        contentLen = (size_t)tmp;
                    } else {
                        contentLen = (size_t)-1;
                    }
                } else if (strcmp(name, "x-filename") == 0 || strcmp(name, "filename") == 0) {
                    safe_strcpy(filenameHeader, sizeof(filenameHeader), value);
                }
            }
            cursor = eol + 1;
        }

        if (contentLen == (size_t)-1 || contentLen == 0) {
            size_t rl;
            char *resp = http_response(400, "Invalid Content-Length\n", &rl);
            if (resp) { send(cfd, resp, rl, 0); free(resp); }
            free(hdrBuf);
            close(cfd);
            continue;
        }
        if (filenameHeader[0] == '\0') {
            size_t rl;
            char *resp = http_response(400, "Missing X-Filename header\n", &rl);
            if (resp) { send(cfd, resp, rl, 0); free(resp); }
            free(hdrBuf);
            close(cfd);
            continue;
        }

        char *san = sanitizeFilename(filenameHeader);
        if (!san) {
            size_t rl;
            char *resp = http_response(500, "Server error\n", &rl);
            if (resp) { send(cfd, resp, rl, 0); free(resp); }
            free(hdrBuf);
            close(cfd);
            continue;
        }

        // initial body after headers
        size_t initialLen = 0;
        if (hdrLen > sep) initialLen = hdrLen - sep;
        const char *initialBody = (initialLen > 0) ? (hdrBuf + sep) : NULL;
        if (initialLen > contentLen) initialLen = contentLen;

        char storedName[256];
        char err[128];
        storedName[0] = '\0';
        err[0] = '\0';

        if (atomicWriteAndMove(cfg.baseDir, san, cfd, contentLen, initialBody, initialLen, storedName, sizeof(storedName), err, sizeof(err)) == 0) {
            char body[384];
            snprintf(body, sizeof(body), "Upload successful: %s\n", storedName);
            size_t bl;
            char *resp = http_response(200, body, &bl);
            if (resp) { send(cfd, resp, bl, 0); free(resp); }
            processed++;
        } else {
            char body[256];
            snprintf(body, sizeof(body), "Failed to store file: %s\n", err);
            size_t bl;
            char *resp = http_response(500, body, &bl);
            if (resp) { send(cfd, resp, bl, 0); free(resp); }
        }

        free(san);
        free(hdrBuf);
        close(cfd);
    }

    close(sfd);
    return NULL;
}

static char *sendUpload(const char *host, uint16_t port, const char *filename, const char *content, size_t contentLen) {
    int fd = socket(AF_INET, SOCK_STREAM, 0);
    if (fd < 0) return strdup("socket error");
    setSocketTimeouts(fd, SOCKET_TIMEOUT_SEC);

    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    if (inet_pton(AF_INET, host, &addr.sin_addr) != 1) {
        close(fd);
        return strdup("inet_pton error");
    }
    if (connect(fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {
        close(fd);
        return strdup("connect error");
    }

    char header[512];
    int hn = snprintf(header, sizeof(header),
                      "POST /upload HTTP/1.1\r\nHost: %s\r\nContent-Length: %zu\r\nX-Filename: %s\r\nConnection: close\r\n\r\n",
                      host, contentLen, filename);
    if (hn < 0 || (size_t)hn >= sizeof(header)) {
        close(fd);
        return strdup("snprintf error");
    }

    size_t off = 0;
    while (off < (size_t)hn) {
        ssize_t wn = send(fd, header + off, (size_t)hn - off, 0);
        if (wn <= 0) { close(fd); return strdup("send error"); }
        off += (size_t)wn;
    }
    off = 0;
    while (off < contentLen) {
        ssize_t wn = send(fd, content + off, contentLen - off, 0);
        if (wn <= 0) { close(fd); return strdup("send body error"); }
        off += (size_t)wn;
    }

    size_t cap = 2048;
    size_t len = 0;
    char *resp = (char *)malloc(cap);
    if (!resp) { close(fd); return strdup("alloc error"); }
    for (;;) {
        if (len + 1024 > cap) {
            size_t ncap = cap * 2;
            char *nr = (char *)realloc(resp, ncap);
            if (!nr) { free(resp); close(fd); return strdup("realloc error"); }
            resp = nr;
            cap = ncap;
        }
        ssize_t rn = recv(fd, resp + len, cap - len, 0);
        if (rn < 0) { if (errno == EINTR) continue; break; }
        if (rn == 0) break;
        len += (size_t)rn;
        if (len > 65536) break;
    }
    close(fd);
    resp[len] = '\0';
    return resp;
}

int main(void) {
    ServerConfig cfg;
    safe_strcpy(cfg.bindAddress, sizeof(cfg.bindAddress), "127.0.0.1");
    cfg.port = 9091;
    safe_strcpy(cfg.baseDir, sizeof(cfg.baseDir), "uploads_c");
    cfg.maxRequests = 5;

    pthread_t tid;
    if (pthread_create(&tid, NULL, serverThread, &cfg) != 0) {
        fprintf(stderr, "Failed to start server thread\n");
        return 1;
    }

    // Give server time to start
    usleep(200 * 1000);

    struct TestCase { const char *name; const char *content; size_t len; } tests[5];
    char bigBuf[1024];
    memset(bigBuf, 'B', sizeof(bigBuf));
    tests[0].name = "doc1.txt"; tests[0].content = "Hello C Upload 1"; tests[0].len = strlen(tests[0].content);
    tests[1].name = "../bad/evil.bin"; tests[1].content = "evil"; tests[1].len = 4;
    tests[2].name = "..hidden"; tests[2].content = "no hide"; tests[2].len = strlen(tests[2].content);
    tests[3].name = "safe_name-03.log"; tests[3].content = bigBuf; tests[3].len = sizeof(bigBuf);
    tests[4].name = "name_with*bad?chars_and_very_long___________________________________________________________end.txt";
    tests[4].content = "small"; tests[4].len = strlen(tests[4].content);

    for (int i = 0; i < 5; ++i) {
        char *resp = sendUpload("127.0.0.1", cfg.port, tests[i].name, tests[i].content, tests[i].len);
        if (!resp) { printf("Test %d: no response\n", i + 1); continue; }
        // Print status line and body
        char *firstCRLF = strstr(resp, "\r\n");
        if (firstCRLF) {
            size_t slen = (size_t)(firstCRLF - resp);
            char status[256];
            size_t cpy = slen < sizeof(status) - 1 ? slen : sizeof(status) - 1;
            memcpy(status, resp, cpy);
            status[cpy] = '\0';
            printf("Test %d: %s\n", i + 1, status);
            char *body = strstr(resp, "\r\n\r\n");
            if (body) {
                body += 4;
                printf("%s", body);
            }
        } else {
            printf("Test %d: %s\n", i + 1, resp);
        }
        free(resp);
    }

    pthread_join(tid, NULL);
    return 0;
}
