#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <errno.h>
#include <fcntl.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <unistd.h>
#include <limits.h>

#ifndef O_CLOEXEC
#define O_CLOEXEC 0
#endif

#ifndef O_NOFOLLOW
#define O_NOFOLLOW 0
#endif

#define MAX_PATH_LEN 4096
#define MAX_SEG_LEN 255
#define READ_BUF_SIZE 8192

static size_t safe_strnlen(const char *s, size_t max) {
    if (s == NULL) return 0;
    const char *p = memchr(s, '\0', max);
    return p ? (size_t)(p - s) : max;
}

static int validate_base_dir_path(const char *base_dir) {
    if (base_dir == NULL) return 0;
    size_t len = safe_strnlen(base_dir, MAX_PATH_LEN);
    if (len == 0 || len >= MAX_PATH_LEN) return 0;
    // Disallow newline/control chars
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)base_dir[i];
        if (c < 0x20 && c != '\t') return 0;
    }
    return 1;
}

static int validate_user_relpath(const char *relpath) {
    if (relpath == NULL) return 0;
    size_t len = safe_strnlen(relpath, MAX_PATH_LEN);
    if (len == 0 || len >= MAX_PATH_LEN) return 0;
    // Must be relative and not contain NUL/control characters
    if (relpath[0] == '/') return 0;
    // Disallow backslash as path separator to avoid cross-platform confusion
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)relpath[i];
        if (c == '\\') return 0;
        if (c < 0x20 && c != '\t') return 0;
    }
    return 1;
}

static int is_forbidden_segment(const char *seg) {
    return (strcmp(seg, ".") == 0) || (strcmp(seg, "..") == 0) || (seg[0] == '\0');
}

static int open_base_dir_fd(const char *base_dir) {
    if (!validate_base_dir_path(base_dir)) {
        errno = EINVAL;
        return -1;
    }

    struct stat sb;
    if (lstat(base_dir, &sb) != 0) {
        return -1;
    }
    if (!S_ISDIR(sb.st_mode)) {
        errno = ENOTDIR;
        return -1;
    }
#if O_NOFOLLOW
    // If lstat says it's a symlink, reject
    if (S_ISLNK(sb.st_mode)) {
        errno = ELOOP;
        return -1;
    }
#endif

    int flags = O_RDONLY | O_DIRECTORY | O_CLOEXEC;
#if O_NOFOLLOW
    flags |= O_NOFOLLOW;
#endif
    int fd = open(base_dir, flags);
    if (fd < 0) {
        return -1;
    }
    // Double-check it's a directory via fstat
    if (fstat(fd, &sb) != 0) {
        int e = errno;
        close(fd);
        errno = e;
        return -1;
    }
    if (!S_ISDIR(sb.st_mode)) {
        int e = ENOTDIR;
        close(fd);
        errno = e;
        return -1;
    }
    return fd;
}

static int secure_open_relative(int basefd, const char *relpath) {
    if (!validate_user_relpath(relpath)) {
        errno = EINVAL;
        return -1;
    }

    // Walk through each path segment safely
    int curfd = basefd; // do not close basefd
    int owned_curfd = 0; // whether we own curfd and must close it
    char segment[MAX_SEG_LEN + 1];
    size_t seglen = 0;
    size_t i = 0;
    size_t len = safe_strnlen(relpath, MAX_PATH_LEN);
    if (len == 0) { errno = EINVAL; return -1; }

    // Process directory components on the fly
    while (i < len) {
        char c = relpath[i++];
        if (c == '/') {
            if (seglen == 0 || seglen > MAX_SEG_LEN) { errno = EINVAL; if (owned_curfd) close(curfd); return -1; }
            segment[seglen] = '\0';
            if (is_forbidden_segment(segment)) { errno = EINVAL; if (owned_curfd) close(curfd); return -1; }
            int nextfd;
            int dflags = O_RDONLY | O_DIRECTORY | O_CLOEXEC;
#if O_NOFOLLOW
            dflags |= O_NOFOLLOW;
#endif
            nextfd = openat(curfd, segment, dflags);
            if (nextfd < 0) {
                int e = errno;
                if (owned_curfd) close(curfd);
                errno = e;
                return -1;
            }
            if (owned_curfd) close(curfd);
            curfd = nextfd;
            owned_curfd = 1;
            seglen = 0; // reset for next segment
        } else {
            if (seglen >= MAX_SEG_LEN) { errno = ENAMETOOLONG; if (owned_curfd) close(curfd); return -1; }
            segment[seglen++] = c;
        }
    }

    // The last segment should be the file name
    if (seglen == 0 || seglen > MAX_SEG_LEN) { errno = EINVAL; if (owned_curfd) close(curfd); return -1; }
    segment[seglen] = '\0';
    if (is_forbidden_segment(segment)) { errno = EINVAL; if (owned_curfd) close(curfd); return -1; }

    int oflags = O_RDONLY | O_CLOEXEC;
#if O_NOFOLLOW
    oflags |= O_NOFOLLOW;
#endif
    int filefd = openat(curfd, segment, oflags);
    int saved_errno = errno;
    if (owned_curfd) {
        close(curfd);
    }
    if (filefd < 0) {
        errno = saved_errno;
        return -1;
    }

    // Ensure it's a regular file
    struct stat fsb;
    if (fstat(filefd, &fsb) != 0) {
        int e = errno;
        close(filefd);
        errno = e;
        return -1;
    }
    if (!S_ISREG(fsb.st_mode)) {
        close(filefd);
        errno = EISDIR;
        return -1;
    }

    return filefd;
}

static int write_all(int fd, const unsigned char *buf, size_t len) {
    size_t off = 0;
    while (off < len) {
        ssize_t w = write(fd, buf + off, len - off);
        if (w < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        off += (size_t)w;
    }
    return 0;
}

static int print_fd_to_stdout(int fd) {
    unsigned char buf[READ_BUF_SIZE];
    for (;;) {
        ssize_t r = read(fd, buf, sizeof(buf));
        if (r < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        if (r == 0) break;
        if (write_all(STDOUT_FILENO, buf, (size_t)r) != 0) {
            return -1;
        }
    }
    return 0;
}

// Public API: reads a file specified by user_path within base_dir and prints to stdout.
// Returns 0 on success, non-zero on failure.
int read_and_print_file_secure(const char *base_dir, const char *user_path) {
    if (!validate_base_dir_path(base_dir) || !validate_user_relpath(user_path)) {
        fprintf(stderr, "Invalid input.\n");
        return 1;
    }

    int basefd = open_base_dir_fd(base_dir);
    if (basefd < 0) {
        perror("Failed to open base directory");
        return 2;
    }

    int fd = secure_open_relative(basefd, user_path);
    int saved_errno = errno;
    close(basefd);
    if (fd < 0) {
        errno = saved_errno;
        perror("Failed to open target file securely");
        return 3;
    }

    int rc = print_fd_to_stdout(fd);
    saved_errno = errno;
    close(fd);
    if (rc != 0) {
        errno = saved_errno;
        perror("Failed while reading/printing file");
        return 4;
    }
    return 0;
}

