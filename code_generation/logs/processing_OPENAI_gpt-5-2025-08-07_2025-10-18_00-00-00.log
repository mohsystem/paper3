            printf("accum(\"%s\") -> <null>\n", tests[i] ? tests[i] : "(null)");
        } else {
            printf("accum(\"%s\") -> \"%s\"\n", tests[i] ? tests[i] : "(null)", r);
            free(r);
        }
    }
    return 0;
}
