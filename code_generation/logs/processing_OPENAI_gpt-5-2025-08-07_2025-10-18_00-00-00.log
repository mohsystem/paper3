/*
Build (Linux/macOS): cc -Wall -Wextra -O2 ftps_download.c -o ftps_download -lcurl
Usage:
  ./ftps_download <hostname> <username> <password> <remote_path>
Example:
  ./ftps_download ftp.example.com user pass /secure/secret.txt
Note: This program uses FTPS (FTP over TLS) and requires a valid server certificate.
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <errno.h>
#include <limits.h>
#include <unistd.h>
#include <fcntl.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <curl/curl.h>

/* ------------------ Validation Utilities ------------------ */

static int is_valid_hostname_char(char c) {
    return (isalnum((unsigned char)c) || c == '-' || c == '.');
}

static int is_valid_hostname(const char *host) {
    if (!host) return 0;
    size_t len = strlen(host);
    if (len == 0 || len > 253) return 0;
    // Must contain only allowed chars and labels 1..63 chars, no leading/trailing dot or hyphen in labels
    size_t label_len = 0;
    int last_was_dot = 1;
    for (size_t i = 0; i < len; i++) {
        char c = host[i];
        if (!is_valid_hostname_char(c)) return 0;
        if (c == '.') {
            if (last_was_dot) return 0; // empty label
            if (label_len == 0 || label_len > 63) return 0;
            label_len = 0;
            last_was_dot = 1;
        } else {
            if (label_len == 0 && (c == '-' )) return 0; // label cannot start with '-'
            label_len++;
            last_was_dot = 0;
        }
    }
    if (last_was_dot) return 0;
    if (label_len == 0 || label_len > 63) return 0;
    // Last char of hostname label cannot be '-'
    if (host[len-1] == '-') return 0;
    return 1;
}

static int is_valid_username(const char *user) {
    if (!user) return 0;
    size_t len = strlen(user);
    if (len == 0 || len > 128) return 0;
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)user[i];
        if (!(isalnum(c) || c == '.' || c == '_' || c == '-' || c == '@')) {
            return 0;
        }
    }
    return 1;
}

static int is_valid_remote_path(const char *path) {
    if (!path) return 0;
    size_t len = strlen(path);
    if (len == 0 || len > 1024) return 0;
    if (path[0] != '/') return 0; // require absolute path on server
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)path[i];
        if (!(isalnum(c) || c == '.' || c == '_' || c == '-' || c == '/' )) {
            return 0;
        }
    }
    if (strstr(path, "..") != NULL) return 0; // prevent traversal attempts
    return 1;
}

static int is_simple_safe_filename(const char *name) {
    if (!name) return 0;
    size_t len = strlen(name);
    if (len == 0 || len > NAME_MAX - 32) return 0; // reserve space for suffix
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)name[i];
        if (!(isalnum(c) || c == '.' || c == '_' || c == '-')) {
            return 0;
        }
    }
    return 1;
}

static char* basename_sanitized(const char *remote_path) {
    // Extract basename and sanitize to a simple safe filename
    const char *base = strrchr(remote_path, '/');
    base = base ? base + 1 : remote_path;
    if (!base || *base == '\0') return NULL;

    // Copy and filter to allowed characters
    size_t len = strlen(base);
    if (len > NAME_MAX - 32) len = NAME_MAX - 32; // keep space for temp suffix
    char *out = (char*)malloc(len + 1);
    if (!out) return NULL;

    size_t j = 0;
    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)base[i];
        if (isalnum(c) || c == '.' || c == '_' || c == '-') {
            out[j++] = (char)c;
        } else {
            // replace with underscore to maintain position
            out[j++] = '_';
        }
    }
    if (j == 0) {
        free(out);
        return NULL;
    }
    out[j] = '\0';
    // ensure not "." or ".."
    if (strcmp(out, ".") == 0 || strcmp(out, "..") == 0) {
        free(out);
        return NULL;
    }
    return out;
}

/* ------------------ Write Callback for libcurl ------------------ */

struct WriteCtx {
    int fd;
    size_t total;
};

static size_t write_to_fd_cb(void *ptr, size_t size, size_t nmemb, void *userdata) {
    struct WriteCtx *ctx = (struct WriteCtx*)userdata;
    if (!ctx || ctx->fd < 0) return 0;

    if (size == 0 || nmemb == 0) return 0;
    size_t bytes = size * nmemb;
    // Bounded addition check
    if (bytes > SIZE_MAX - ctx->total) {
        errno = EOVERFLOW;
        return 0;
    }

    unsigned char *buf = (unsigned char*)ptr;
    size_t written_total = 0;

    while (written_total < bytes) {
        ssize_t w = write(ctx->fd, buf + written_total, bytes - written_total);
        if (w < 0) {
            if (errno == EINTR) continue;
            return 0;
        }
        if (w == 0) {
            // Should not happen, but avoid infinite loop
            errno = EIO;
            return 0;
        }
        written_total += (size_t)w;
    }

    ctx->total += written_total;
    return written_total;
}

/* ------------------ FTPS Download Function ------------------ */

static int secure_ftps_download(const char *hostname,
                                const char *username,
                                const char *password,
                                const char *remote_path,
                                char **out_local_filename) {
    if (out_local_filename) *out_local_filename = NULL;

    // Validate inputs
    if (!is_valid_hostname(hostname)) {
        fprintf(stderr, "Error: Invalid hostname format.\n");
        return 1001;
    }
    if (!is_valid_username(username)) {
        fprintf(stderr, "Error: Invalid username format.\n");
        return 1002;
    }
    if (!password || strlen(password) == 0 || strlen(password) > 256) {
        fprintf(stderr, "Error: Invalid password length.\n");
        return 1003;
    }
    if (!is_valid_remote_path(remote_path)) {
        fprintf(stderr, "Error: Invalid remote path format.\n");
        return 1004;
    }

    // Derive safe local filename from remote path
    char *base_name = basename_sanitized(remote_path);
    if (!base_name || !is_simple_safe_filename(base_name)) {
        if (base_name) free(base_name);
        fprintf(stderr, "Error: Could not derive a safe local filename.\n");
        return 1005;
    }

    // Build FTPS URL
    char url[2048];
    int rc = snprintf(url, sizeof(url), "ftps://%s%s", hostname, remote_path);
    if (rc < 0 || (size_t)rc >= sizeof(url)) {
        free(base_name);
        fprintf(stderr, "Error: URL too long.\n");
        return 1006;
    }

    // Prepare temp file in current directory
    char tmp_pattern[NAME_MAX];
    rc = snprintf(tmp_pattern, sizeof(tmp_pattern), "%s.tmp.XXXXXX", base_name);
    if (rc < 0 || (size_t)rc >= sizeof(tmp_pattern)) {
        free(base_name);
        fprintf(stderr, "Error: Temporary filename pattern too long.\n");
        return 1007;
    }

    // Ensure final filename does not contain path separators
    if (strchr(base_name, '/')) {
        free(base_name);
        fprintf(stderr, "Error: Invalid local filename.\n");
        return 1008;
    }

    int tmp_fd = mkstemp(tmp_pattern);
    if (tmp_fd < 0) {
        free(base_name);
        perror("Error creating temporary file");
        return 1009;
    }

    // Set file permissions to 0600 for sensitive file
    if (fchmod(tmp_fd, S_IRUSR | S_IWUSR) != 0) {
        perror("Warning: could not set file permissions");
        // Not fatal; continue
    }

    CURLcode cres;
    CURL *curl = curl_easy_init();
    if (!curl) {
        close(tmp_fd);
        unlink(tmp_pattern);
        free(base_name);
        fprintf(stderr, "Error: Failed to initialize libcurl.\n");
        return 1010;
    }

    // Write context
    struct WriteCtx wctx;
    wctx.fd = tmp_fd;
    wctx.total = 0;

    char errbuf[CURL_ERROR_SIZE];
    memset(errbuf, 0, sizeof(errbuf));

    // Configure libcurl for secure FTPS
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_USERNAME, username);
    curl_easy_setopt(curl, CURLOPT_PASSWORD, password);

    // Enforce TLS and certificate validation
    curl_easy_setopt(curl, CURLOPT_USE_SSL, (long)CURLUSESSL_ALL);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);
#if defined(CURL_SSLVERSION_TLSv1_2) && defined(CURL_SSLVERSION_MAX_TLSv1_3)
    curl_easy_setopt(curl, CURLOPT_SSLVERSION, CURL_SSLVERSION_TLSv1_2 | CURL_SSLVERSION_MAX_TLSv1_3);
#elif defined(CURL_SSLVERSION_TLSv1_2)
    curl_easy_setopt(curl, CURLOPT_SSLVERSION, CURL_SSLVERSION_TLSv1_2);
#endif

#ifdef CURLOPT_PROTOCOLS_STR
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS_STR, "ftps");
#else
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS, (long)CURLPROTO_FTPS);
#endif

    curl_easy_setopt(curl, CURLOPT_FTP_SSL_CCC, (long)CURLFTPSSL_CCC_NONE);
    curl_easy_setopt(curl, CURLOPT_FTPSSLAUTH, (long)CURLFTPAUTH_DEFAULT);
    curl_easy_setopt(curl, CURLOPT_FTP_FILEMETHOD, (long)CURLFTPMETHOD_NOCWD);

    // Timeouts and keepalive
    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, 20L);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT, 0L); // No overall timeout; change if desired
    curl_easy_setopt(curl, CURLOPT_TCP_KEEPALIVE, 1L);

    // Error buffer
    curl_easy_setopt(curl, CURLOPT_ERRORBUFFER, errbuf);

    // Write callback
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_to_fd_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &wctx);

    // Perform download
    cres = curl_easy_perform(curl);

    // Clean up curl first to release any sensitive internal buffers
    curl_easy_cleanup(curl);

    // Ensure data is flushed to disk
    int fsr = 0;
    if (cres == CURLE_OK) {
        if (fsync(tmp_fd) != 0) {
            perror("Error syncing file to disk");
            fsr = -1;
        }
    }
    if (close(tmp_fd) != 0) {
        perror("Error closing temporary file");
        if (fsr == 0) fsr = -1;
    }

    if (cres != CURLE_OK) {
        if (errbuf[0] != '\0') {
            fprintf(stderr, "Download failed: %s\n", errbuf);
        } else {
            fprintf(stderr, "Download failed: %s\n", curl_easy_strerror(cres));
        }
        unlink(tmp_pattern);
        free(base_name);
        return 1011;
    }
    if (fsr != 0) {
        unlink(tmp_pattern);
        free(base_name);
        return 1012;
    }

    // Atomically create final file via hard link (prevents TOCTOU between check and use).
    // This succeeds only if final does not already exist. Refuse to overwrite.
    if (link(tmp_pattern, base_name) != 0) {
        if (errno == EEXIST) {
            fprintf(stderr, "Error: Target file '%s' already exists. Refusing to overwrite.\n", base_name);
        } else {
            perror("Error creating final file");
        }
        unlink(tmp_pattern);
        free(base_name);
        return 1013;
    }

    // Remove the temporary name; final link remains.
    if (unlink(tmp_pattern) != 0) {
        perror("Warning: could not remove temporary file name");
    }

    if (out_local_filename) {
        *out_local_filename = base_name; // transfer ownership to caller
    } else {
        free(base_name);
    }
    return 0;
}

/* ------------------ Test Harness / Main ------------------ */

static void print_result(const char *label, int code, const char *outfile) {
    if (code == 0) {
        printf("[OK] %s -> saved as '%s'\n", label, outfile ? outfile : "(unknown)");
    } else {
        printf("[ERR %d] %s\n", code, label);
    }
}

static int run_single_download(const char *host, const char *user, const char *pass, const char *rpath) {
    char *outfile = NULL;
    int rc = secure_ftps_download(host, user, pass, rpath, &outfile);
    if (rc == 0 && outfile) {
        // Avoid printing sensitive data; only filename
        printf("Downloaded file saved as: %s\n", outfile);
        free(outfile);
    }
    return rc;
}

int main(int argc, char **argv) {
    // If user provided command line args: hostname username password remote_path
    if (argc == 5) {
        const char *hostname = argv[1];
        const char *username = argv[2];
        const char *password = argv[3];
        const char *remote_path = argv[4];
        int rc = run_single_download(hostname, username, password, remote_path);
        return (rc == 0) ? 0 : 1;
    }

    // Otherwise, run 5 built-in test cases (will likely fail without a real server).
    printf("No command-line args provided. Running 5 test cases (expected to fail without a valid FTPS server):\n");

    // Test 1: invalid host
    {
        char *out = NULL;
        int rc = secure_ftps_download("bad host", "user", "pass", "/file.txt", &out);
        print_result("Test1: invalid host", rc, out);
        free(out);
    }

    // Test 2: invalid username
    {
        char *out = NULL;
        int rc = secure_ftps_download("example.com", "bad user!", "pass", "/file.txt", &out);
        print_result("Test2: invalid username", rc, out);
        free(out);
    }

    // Test 3: invalid remote path
    {
        char *out = NULL;
        int rc = secure_ftps_download("example.com", "user", "pass", "not/absolute.txt", &out);
        print_result("Test3: invalid path", rc, out);
        free(out);
    }

    // Test 4: valid-looking inputs but likely no server
    {
        char *out = NULL;
        int rc = secure_ftps_download("ftps.example.com", "user", "pass", "/secure/secret.txt", &out);
        print_result("Test4: ftps.example.com no real server", rc, out);
        free(out);
    }

    // Test 5: localhost scenario (if a local FTPS server is running, this may succeed)
    {
        char *out = NULL;
        int rc = secure_ftps_download("localhost", "user", "pass", "/secret.txt", &out);
        print_result("Test5: localhost", rc, out);
        free(out);
    }

    return 0;
}
