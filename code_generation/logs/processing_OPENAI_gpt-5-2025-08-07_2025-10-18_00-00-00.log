/*
Secure FTP (plain FTP over TCP) downloader in C.

Note:
- This implements plain FTP (not FTPS). As such, TLS certificate validation rules are not applicable.
- Credentials are provided via command line; they are not logged and should be handled carefully.
- Data is downloaded via passive mode (PASV) and saved atomically to a sanitized filename in the current directory.
- Defensive measures included: input validation, filename sanitization, safe I/O, timeouts, bounds checks, and TOCTOU mitigations for file writes.
- This code handles IPv4 servers and basic single-line and multi-line FTP responses.

Build:
  cc -Wall -Wextra -O2 -D_POSIX_C_SOURCE=200809L -o ftp_get ftp_get.c

Usage:
  ./ftp_get <hostname> <username> <password> <remote_path>

If run without 4 arguments, main executes 5 local test cases that are expected to fail gracefully unless matching real servers.
*/

#include <stdio.h>
#include <stdlib.h>
#include <stdarg.h>
#include <string.h>
#include <ctype.h>
#include <errno.h>
#include <time.h>
#include <unistd.h>
#include <fcntl.h>
#include <sys/types.h>
#include <sys/socket.h>
#include <sys/select.h>
#include <sys/stat.h>
#include <netdb.h>
#include <arpa/inet.h>
#include <netinet/in.h>

#ifndef O_NOFOLLOW
#define O_NOFOLLOW 0
#endif

#ifndef MSG_NOSIGNAL
#define MSG_NOSIGNAL 0
#endif

#define FTP_CTRL_PORT "21"
#define RECV_LINE_MAX 2048
#define FTP_TIMEOUT_CONNECT_SEC 15
#define FTP_TIMEOUT_IO_MS 20000
#define DATA_TIMEOUT_IO_MS 30000
#define TEMP_SUFFIX ".part"
#define MAX_FILENAME_LEN 255

typedef struct {
    int ctrl_sock;
    char ctrl_ip[INET_ADDRSTRLEN]; // IPv4 dotted-decimal
} ftp_session;

/* Utility: set nonblocking */
static int set_nonblocking(int fd, int nb) {
    int flags = fcntl(fd, F_GETFL, 0);
    if (flags < 0) return -1;
    if (nb) flags |= O_NONBLOCK;
    else flags &= ~O_NONBLOCK;
    return fcntl(fd, F_SETFL, flags);
}

/* Utility: connect with timeout (seconds) */
static int connect_with_timeout(const struct addrinfo *ai, int timeout_sec) {
    int fd = -1;
    int ret;
    fd = socket(ai->ai_family, ai->ai_socktype, ai->ai_protocol);
    if (fd < 0) return -1;

    if (set_nonblocking(fd, 1) != 0) {
        close(fd);
        return -1;
    }
    ret = connect(fd, ai->ai_addr, ai->ai_addrlen);
    if (ret == 0) {
        set_nonblocking(fd, 0);
        return fd;
    }
    if (ret < 0 && errno != EINPROGRESS) {
        close(fd);
        return -1;
    }

    fd_set wfds;
    FD_ZERO(&wfds);
    FD_SET(fd, &wfds);
    struct timeval tv;
    tv.tv_sec = timeout_sec;
    tv.tv_u_sec = 0;
    ret = select(fd + 1, NULL, &wfds, NULL, &tv);
    if (ret <= 0) {
        close(fd);
        errno = (ret == 0) ? ETIMEDOUT : errno;
        return -1;
    }
    int soerr = 0;
    socklen_t slen = sizeof(soerr);
    if (getsockopt(fd, SOL_SOCKET, SO_ERROR, &soerr, &slen) != 0 || soerr != 0) {
        close(fd);
        errno = soerr ? soerr : errno;
        return -1;
    }
    set_nonblocking(fd, 0);
    return fd;
}

/* Utility: TCP connect hostname:port with timeout */
static int tcp_connect_host(const char *hostname, const char *port, int timeout_sec, char out_ip[INET_ADDRSTRLEN]) {
    if (!hostname || !port) { errno = EINVAL; return -1; }
    struct addrinfo hints, *res = NULL, *rp = NULL;
    memset(&hints, 0, sizeof(hints));
    hints.ai_family = AF_INET;        // IPv4
    hints.ai_socktype = SOCK_STREAM;
    hints.ai_protocol = IPPROTO_TCP;

    int gai = getaddrinfo(hostname, port, &hints, &res);
    if (gai != 0) {
        return -1;
    }
    int fd = -1;
    for (rp = res; rp != NULL; rp = rp->ai_next) {
        fd = connect_with_timeout(rp, timeout_sec);
        if (fd >= 0) {
            // Store connected peer IP
            struct sockaddr_in sin;
            socklen_t sl = sizeof(sin);
            if (getpeername(fd, (struct sockaddr *)&sin, &sl) == 0) {
                if (out_ip) {
                    const char *ip = inet_ntop(AF_INET, &sin.sin_addr, out_ip, INET_ADDRSTRLEN);
                    if (!ip) strncpy(out_ip, "0.0.0.0", INET_ADDRSTRLEN);
                }
            }
            break;
        }
    }
    freeaddrinfo(res);
    return fd;
}

/* Utility: set socket recv/send timeouts in ms */
static int set_socket_timeouts_ms(int fd, int recv_ms, int send_ms) {
    struct timeval tv;
    if (recv_ms > 0) {
        tv.tv_sec = recv_ms / 1000;
        tv.tv_usec = (recv_ms % 1000) * 1000;
        if (setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv)) != 0) return -1;
    }
    if (send_ms > 0) {
        tv.tv_sec = send_ms / 1000;
        tv.tv_usec = (send_ms % 1000) * 1000;
        if (setsockopt(fd, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof(tv)) != 0) return -1;
    }
    return 0;
}

/* Read one line from socket until CRLF. Returns length or -1 on error/timeout. */
static ssize_t recv_line(int sock, char *buf, size_t buflen, int timeout_ms) {
    if (!buf || buflen == 0) { errno = EINVAL; return -1; }
    size_t pos = 0;
    char c = 0, prev = 0;
    int rv = set_socket_timeouts_ms(sock, timeout_ms, timeout_ms);
    if (rv != 0) { /* continue anyway */ }
    while (pos + 1 < buflen) {
        ssize_t r = recv(sock, &c, 1, 0);
        if (r == 0) { // connection closed
            break;
        } else if (r < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        buf[pos++] = c;
        if (prev == '\r' && c == '\n') {
            // strip CRLF
            pos -= 2;
            buf[pos] = '\0';
            return (ssize_t)pos;
        }
        prev = c;
    }
    // buffer full or no CRLF
    buf[pos < buflen ? pos : buflen - 1] = '\0';
    return (ssize_t)pos;
}

/* Read FTP response: handle multi-line. Returns code or -1. Stores last line in out_line (optional). */
static int ftp_read_response(int ctrl_sock, char *out_line, size_t out_line_len) {
    char line[RECV_LINE_MAX];
    int code = -1;
    int expect_multi = 0;
    int initial_code = -1;
    for (;;) {
        ssize_t n = recv_line(ctrl_sock, line, sizeof(line), FTP_TIMEOUT_IO_MS);
        if (n <= 0) return -1;
        // Ensure null-terminated
        line[sizeof(line) - 1] = '\0';

        // Validate 3-digit prefix
        if (n >= 3 && isdigit((unsigned char)line[0]) && isdigit((unsigned char)line[1]) && isdigit((unsigned char)line[2])) {
            code = (line[0] - '0') * 100 + (line[1] - '0') * 10 + (line[2] - '0');
            if (!expect_multi) {
                if (line[3] == '-') {
                    expect_multi = 1;
                    initial_code = code;
                } else if (line[3] == ' ') {
                    // Single-line
                    if (out_line && out_line_len > 0) {
                        snprintf(out_line, out_line_len, "%s", line);
                    }
                    return code;
                }
            } else {
                // multi-line, look for terminating "code<space>"
                if (line[3] == ' ' && code == initial_code) {
                    if (out_line && out_line_len > 0) {
                        snprintf(out_line, out_line_len, "%s", line);
                    }
                    return code;
                }
            }
        } else {
            // No code at start; continue reading until terminating line if in multi-line
            // ignore
        }
        // store last line anyway
        if (out_line && out_line_len > 0) {
            snprintf(out_line, out_line_len, "%s", line);
        }
    }
}

/* Send FTP command with CRLF. Returns 0 on success. */
static int ftp_send_cmd(int ctrl_sock, const char *fmt, ...) {
    char buf[RECV_LINE_MAX];
    va_list ap;
    va_start(ap, fmt);
    int n = vsnprintf(buf, sizeof(buf), fmt, ap);
    va_end(ap);
    if (n < 0 || (size_t)n >= sizeof(buf) - 2) {
        errno = EOVERFLOW;
        return -1;
    }
    size_t len = (size_t)n;
    buf[len++] = '\r';
    buf[len++] = '\n';
    ssize_t s = send(ctrl_sock, buf, len, MSG_NOSIGNAL);
    if (s < 0 || (size_t)s != len) return -1;
    return 0;
}

/* Login procedure */
static int ftp_login(ftp_session *ses, const char *user, const char *pass) {
    char line[RECV_LINE_MAX];
    int code = ftp_read_response(ses->ctrl_sock, line, sizeof(line));
    if (code != 220) return -1;

    if (ftp_send_cmd(ses->ctrl_sock, "USER %s", user ? user : "anonymous") != 0) return -1;
    code = ftp_read_response(ses->ctrl_sock, line, sizeof(line));
    if (code == 331) {
        if (ftp_send_cmd(ses->ctrl_sock, "PASS %s", pass ? pass : "guest@example.com") != 0) return -1;
        code = ftp_read_response(ses->ctrl_sock, line, sizeof(line));
        if (code != 230) return -1;
    } else if (code == 230) {
        // Logged in without password required
    } else {
        return -1;
    }
    // Set binary mode
    if (ftp_send_cmd(ses->ctrl_sock, "TYPE I") != 0) return -1;
    code = ftp_read_response(ses->ctrl_sock, line, sizeof(line));
    if (code != 200) return -1;
    return 0;
}

/* Parse PASV response like: 227 Entering Passive Mode (h1,h2,h3,h4,p1,p2) */
static int ftp_parse_pasv(const char *resp, char out_ip[INET_ADDRSTRLEN], uint16_t *out_port) {
    const char *p = strchr(resp, '(');
    const char *q = strrchr(resp, ')');
    if (!p || !q || q <= p) return -1;
    int h1,h2,h3,h4,p1,p2;
    if (sscanf(p+1, "%d,%d,%d,%d,%d,%d", &h1,&h2,&h3,&h4,&p1,&p2) != 6) {
        return -1;
    }
    if (h1<0||h1>255||h2<0||h2>255||h3<0||h3>255||h4<0||h4>255||
        p1<0||p1>255||p2<0||p2>255) return -1;
    snprintf(out_ip, INET_ADDRSTRLEN, "%d.%d.%d.%d", h1,h2,h3,h4);
    *out_port = (uint16_t)(p1 * 256 + p2);
    return 0;
}

/* Enter passive mode; returns data socket fd or -1 */
static int ftp_enter_pasv(ftp_session *ses, int *out_data_fd) {
    char line[RECV_LINE_MAX];
    int code;

    if (ftp_send_cmd(ses->ctrl_sock, "PASV") != 0) return -1;
    code = ftp_read_response(ses->ctrl_sock, line, sizeof(line));
    if (code != 227) return -1;

    char pasv_ip[INET_ADDRSTRLEN];
    uint16_t pasv_port = 0;
    if (ftp_parse_pasv(line, pasv_ip, &pasv_port) != 0) return -1;

    // Security: ensure PASV IP matches control connection IP. If not, use control IP with PASV port.
    // This mitigates FTP bounce attacks and some NAT oddities.
    char use_ip[INET_ADDRSTRLEN];
    if (strncmp(pasv_ip, ses->ctrl_ip, INET_ADDRSTRLEN) == 0) {
        snprintf(use_ip, sizeof(use_ip), "%s", pasv_ip);
    } else {
        // Prefer control IP to avoid connecting to attacker-controlled host
        snprintf(use_ip, sizeof(use_ip), "%s", ses->ctrl_ip);
    }

    char portstr[16];
    snprintf(portstr, sizeof(portstr), "%u", (unsigned)pasv_port);
    int data_fd = tcp_connect_host(use_ip, portstr, FTP_TIMEOUT_CONNECT_SEC, NULL);
    if (data_fd < 0) return -1;
    if (set_socket_timeouts_ms(data_fd, DATA_TIMEOUT_IO_MS, DATA_TIMEOUT_IO_MS) != 0) {
        // continue but note timeouts may be default
    }
    *out_data_fd = data_fd;
    return 0;
}

/* Sanitize filename: allow [A-Za-z0-9._-], replace others with '_' and enforce max length. Remove leading dots and empty names. */
static int sanitize_filename(const char *input, char *out, size_t outlen) {
    if (!input || !out || outlen < 2) return -1;
    // Extract basename: after last '/' or '\'
    const char *base = input;
    for (const char *p = input; *p; ++p) {
        if (*p == '/' || *p == '\\') base = p + 1;
    }
    // If empty after extraction, use default
    if (*base == '\0') base = "download.bin";

    size_t j = 0;
    for (size_t i = 0; base[i] != '\0' && j + 1 < outlen; ++i) {
        unsigned char c = (unsigned char)base[i];
        if (isalnum(c) || c == '.' || c == '_' || c == '-') {
            out[j++] = (char)c;
        } else {
            out[j++] = '_';
        }
        if (j >= MAX_FILENAME_LEN) break;
    }
    // Avoid names like "." or ".." or starting with dot
    if (j == 0 || (j == 1 && out[0] == '.') || (j == 2 && out[0] == '.' && out[1] == '.')) {
        const char *fallback = "download.bin";
        j = 0;
        for (size_t k = 0; fallback[k] != '\0' && j + 1 < outlen; ++k) {
            out[j++] = fallback[k];
        }
    }
    // Remove leading dots
    while (j > 0 && out[0] == '.') {
        // shift left
        memmove(out, out + 1, j - 1);
        j--;
    }
    if (j == 0) {
        if (outlen >= 2) { out[0] = 'f'; out[1] = '\0'; }
        else return -1;
    } else {
        out[j] = '\0';
    }
    return 0;
}

/* Create a unique temp file in current dir based on final name. Returns fd and writes temp path. */
static int create_temp_file(const char *final_name, char *temp_path, size_t temp_path_len) {
    if (!final_name || !temp_path || temp_path_len < 8) { errno = EINVAL; return -1; }
    // Build template: "<final_name>.part.<pid>.<time>.<rand>"
    unsigned int r = 0;
    {
        int ur = open("/dev/urandom", O_RDONLY);
        if (ur >= 0) {
            (void)read(ur, &r, sizeof(r));
            close(ur);
        } else {
            r = (unsigned)time(NULL) ^ (unsigned)getpid();
        }
    }
    char candidate[512];
    snprintf(candidate, sizeof(candidate), "%s%s.%ld.%u", final_name, TEMP_SUFFIX, (long)time(NULL), r);
    // Ensure not too long
    if (strlen(candidate) + 1 > temp_path_len) {
        errno = ENAMETOOLONG;
        return -1;
    }
    snprintf(temp_path, temp_path_len, "%s", candidate);

    int flags = O_WRONLY | O_CREAT | O_EXCL | O_NOFOLLOW;
    int fd = open(temp_path, flags, 0600);
    if (fd < 0) return -1;
    return fd;
}

/* Atomically rename temp file to a unique final filename (avoid overwrite). Returns 0 on success and writes chosen final name. */
static int atomic_rename_unique(const char *temp_path, char *final_name, size_t final_name_len) {
    if (!temp_path || !final_name || final_name_len < 2) { errno = EINVAL; return -1; }

    // Try base name first; if exists, add numeric suffixes
    char base[MAX_FILENAME_LEN + 1];
    if (sanitize_filename(final_name, base, sizeof(base)) != 0) snprintf(base, sizeof(base), "download.bin");

    char candidate[MAX_FILENAME_LEN + 32];
    int attempt = 0;
    for (;;) {
        if (attempt == 0) {
            snprintf(candidate, sizeof(candidate), "%s", base);
        } else {
            // Ensure base without extension overflow
            snprintf(candidate, sizeof(candidate), "%s_%d", base, attempt);
        }
        // lstat to check existence
        struct stat st;
        if (lstat(candidate, &st) == 0) {
            attempt++;
            if (attempt > 1000) { errno = EEXIST; return -1; }
            continue;
        }
        // Attempt rename; if EEXIST, try again
        if (rename(temp_path, candidate) == 0) {
            if (strlen(candidate) + 1 > final_name_len) { errno = ENAMETOOLONG; return -1; }
            snprintf(final_name, final_name_len, "%s", candidate);
            return 0;
        } else {
            if (errno == EEXIST) {
                attempt++;
                if (attempt > 1000) { return -1; }
                continue;
            } else {
                return -1;
            }
        }
    }
}

/* Download file via RETR into current directory with safe write. Returns 0 on success. Saves final filename in out_saved (optional). */
static int ftp_download_file(ftp_session *ses, const char *remote_path, char *out_saved, size_t out_saved_len) {
    if (!ses || !remote_path) { errno = EINVAL; return -1; }
    int data_fd = -1;
    if (ftp_enter_pasv(ses, &data_fd) != 0) return -1;

    // Issue RETR
    if (ftp_send_cmd(ses->ctrl_sock, "RETR %s", remote_path) != 0) {
        close(data_fd);
        return -1;
    }
    char line[RECV_LINE_MAX];
    int code = ftp_read_response(ses->ctrl_sock, line, sizeof(line));
    if (!(code == 150 || code == 125)) {
        close(data_fd);
        return -1;
    }

    char safe_name[MAX_FILENAME_LEN + 1];
    if (sanitize_filename(remote_path, safe_name, sizeof(safe_name)) != 0) {
        snprintf(safe_name, sizeof(safe_name), "download.bin");
    }
    char temp_path[512];
    int out_fd = create_temp_file(safe_name, temp_path, sizeof(temp_path));
    if (out_fd < 0) {
        close(data_fd);
        return -1;
    }

    // Receive data and write to temp
    char buf[8192];
    ssize_t r;
    int write_error = 0;
    for (;;) {
        r = recv(data_fd, buf, sizeof(buf), 0);
        if (r == 0) break; // EOF
        if (r < 0) {
            if (errno == EINTR) continue;
            write_error = 1;
            break;
        }
        ssize_t off = 0;
        while (off < r) {
            ssize_t w = write(out_fd, buf + off, (size_t)(r - off));
            if (w < 0) {
                if (errno == EINTR) continue;
                write_error = 1;
                break;
            }
            off += w;
        }
        if (write_error) break;
    }
    // Close data connection first
    close(data_fd);

    int rc = 0;
    if (!write_error) {
        // Flush and fsync
        if (fsync(out_fd) != 0) write_error = 1;
    }
    if (close(out_fd) != 0) write_error = 1;

    if (write_error) {
        // Cleanup temp
        unlink(temp_path);
        // Read final response (likely 426/451)
        (void)ftp_read_response(ses->ctrl_sock, line, sizeof(line));
        return -1;
    }

    // Expect transfer complete 226/250
    code = ftp_read_response(ses->ctrl_sock, line, sizeof(line));
    if (!(code == 226 || code == 250)) {
        unlink(temp_path);
        return -1;
    }

    // Atomically rename temp to final unique name
    char final_name_buf[MAX_FILENAME_LEN + 32];
    snprintf(final_name_buf, sizeof(final_name_buf), "%s", safe_name);
    if (atomic_rename_unique(temp_path, final_name_buf, sizeof(final_name_buf)) != 0) {
        unlink(temp_path);
        return -1;
    }
    if (out_saved && out_saved_len > 0) {
        snprintf(out_saved, out_saved_len, "%s", final_name_buf);
    }
    return 0;
}

/* High-level function: connect, login, download, quit */
int ftp_download(const char *hostname, const char *username, const char *password, const char *remote_path, char *saved_as, size_t saved_as_len) {
    if (!hostname || !username || !password || !remote_path) { errno = EINVAL; return -1; }

    ftp_session ses;
    memset(&ses, 0, sizeof(ses));
    ses.ctrl_sock = tcp_connect_host(hostname, FTP_CTRL_PORT, FTP_TIMEOUT_CONNECT_SEC, ses.ctrl_ip);
    if (ses.ctrl_sock < 0) return -1;

    if (set_socket_timeouts_ms(ses.ctrl_sock, FTP_TIMEOUT_IO_MS, FTP_TIMEOUT_IO_MS) != 0) {
        // continue
    }

    int rc = -1;
    if (ftp_login(&ses, username, password) != 0) goto cleanup;

    // Download
    if (ftp_download_file(&ses, remote_path, saved_as, saved_as_len) != 0) goto cleanup;

    // Quit politely
    (void)ftp_send_cmd(ses.ctrl_sock, "QUIT");
    (void)ftp_read_response(ses.ctrl_sock, NULL, 0);

    rc = 0;

cleanup:
    close(ses.ctrl_sock);
    return rc;
}

/* Test harness: 5 test cases (expected to fail safely unless a real server matches) */
static void run_tests(void) {
    struct {
        const char *host, *user, *pass, *path;
    } tests[5] = {
        {"127.0.0.1", "anonymous", "guest@example.com", "/readme.txt"},
        {"invalid.localdomain", "user", "pass", "secret.dat"},
        {"example.com", "anonymous", "guest@example.com", "/pub/nonexistent.file"},
        {"192.0.2.1", "user", "badpass", "/sensitive.bin"},  // 192.0.2.0/24 is TEST-NET-1
        {"localhost", "user", "pass", "folder/../../escape.txt"},
    };

    for (int i = 0; i < 5; ++i) {
        char saved[512];
        memset(saved, 0, sizeof(saved));
        int rc = ftp_download(tests[i].host, tests[i].user, tests[i].pass, tests[i].path, saved, sizeof(saved));
        printf("Test %d: host=%s path=%s => rc=%d%s%s\n",
               i+1, tests[i].host, tests[i].path, rc,
               (rc == 0 ? " saved_as=" : ""),
               (rc == 0 ? saved : ""));
    }
}

/* Main: expects 4 args: hostname username password remote_path */
int main(int argc, char **argv) {
    if (argc != 5) {
        printf("Usage: %s <hostname> <username> <password> <remote_path>\n", argv[0]);
        printf("Running 5 self-tests (these may fail without matching servers)...\n");
        run_tests();
        return 0;
    }
    const char *host = argv[1];
    const char *user = argv[2];
    const char *pass = argv[3];
    const char *path = argv[4];

    // Basic input validation
    if (strnlen(host, 256) == 0 || strnlen(user, 256) == 0 || strnlen(pass, 256) == 0 || strnlen(path, 1024) == 0) {
        fprintf(stderr, "Invalid inputs.\n");
        return 1;
    }

    char saved[512];
    memset(saved, 0, sizeof(saved));
    int rc = ftp_download(host, user, pass, path, saved, sizeof(saved));
    if (rc != 0) {
        fprintf(stderr, "Download failed.\n");
        return 2;
    }
    printf("Downloaded to: %s\n", saved);
    return 0;
}
