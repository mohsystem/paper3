    size_t len;
    size_t cap;
    size_t max;
    int error;
} StrBuilder;

static void sb_init(StrBuilder* sb, size_t initial, size_t maxcap) {
    sb->buf = (char*)malloc(initial);
    if (sb->buf == NULL) {
        sb->len = sb->cap = 0;
        sb->max = maxcap;
        sb->error = 1;
        return;
