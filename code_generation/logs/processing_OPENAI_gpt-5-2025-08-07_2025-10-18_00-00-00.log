/*
Build with: cc -std=c11 -Wall -Wextra -pedantic -O2 task.c -o task -lcurl
Run:
  ./task https://example.com
If no arguments are provided, 5 built-in test cases will run.
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <curl/curl.h>

#define MAX_URL_LEN 2048
#define MAX_CONTENT_SIZE (1024 * 1024) /* 1 MiB */
#define INITIAL_BUF_CAP 8192
#define CONNECT_TIMEOUT_SEC 10L
#define TRANSFER_TIMEOUT_SEC 20L
#define MAX_REDIRECTS 5L

typedef struct {
    char *data;
    size_t size;
    size_t cap;
    size_t max;
} MemBuf;

/* Utility: safe strnlen */
static size_t safe_strnlen(const char *s, size_t maxlen) {
    size_t i = 0;
    if (!s) return 0;
    for (; i < maxlen && s[i] != '\0'; ++i) { /* nothing */ }
    return i;
}

/* ASCII case-insensitive equality for a prefix "https://" */
static int starts_with_https_scheme(const char *url) {
    if (!url) return 0;
    const char target[] = "https://";
    for (size_t i = 0; target[i] != '\0'; ++i) {
        char c = url[i];
        if (c == '\0') return 0;
        char a = (char)tolower((unsigned char)c);
        if (a != target[i]) return 0;
    }
    return 1;
}

static int is_valid_https_url(const char *url) {
    if (url == NULL) return 0;
    size_t len = safe_strnlen(url, MAX_URL_LEN + 1);
    if (len == 0 || len > MAX_URL_LEN) return 0;
    if (!starts_with_https_scheme(url)) return 0;
    /* rudimentary check to avoid spaces/control chars */
    for (size_t i = 0; i < len; ++i) {
        unsigned char c = (unsigned char)url[i];
        if (c <= 0x20 || c == 0x7f) return 0; /* no spaces or control chars */
    }
    return 1;
}

static int membuf_init(MemBuf *b, size_t max_cap) {
    if (!b) return 0;
    b->data = NULL;
    b->size = 0;
    b->cap = 0;
    b->max = max_cap;
    return 1;
}

static void membuf_free(MemBuf *b) {
    if (!b) return;
    free(b->data);
    b->data = NULL;
    b->size = 0;
    b->cap = 0;
    b->max = 0;
}

static int membuf_reserve(MemBuf *b, size_t needed) {
    if (!b) return 0;
    if (needed > b->max) return 0;
    if (needed <= b->cap) return 1;

    size_t newcap = b->cap ? b->cap : INITIAL_BUF_CAP;
    while (newcap < needed) {
        size_t prev = newcap;
        newcap *= 2;
        if (newcap < prev) { /* overflow */
            newcap = b->max;
            break;
        }
        if (newcap > b->max) {
            newcap = b->max;
            break;
        }
    }
    if (newcap < needed) return 0;
    if (newcap > (SIZE_MAX - 1)) return 0; /* space for null terminator */

    char *p = (char *)realloc(b->data, newcap + 1);
    if (!p) return 0;
    b->data = p;
    b->cap = newcap;
    if (b->size == 0) b->data[0] = '\0';
    return 1;
}

static size_t curl_write_cb(char *ptr, size_t size, size_t nmemb, void *userdata) {
    MemBuf *b = (MemBuf *)userdata;
    if (!b || !ptr) return 0;
    if (size == 0 || nmemb == 0) return 0;

    /* Check overflow in multiplication */
    if (nmemb != 0 && size > (SIZE_MAX / nmemb)) {
        return 0;
    }
    size_t total = size * nmemb;

    /* Check addition overflow */
    if (b->size > SIZE_MAX - total) {
        return 0;
    }
    size_t needed = b->size + total;

    if (needed > b->max) {
        /* Exceeds allowed buffer; abort transfer */
        return 0;
    }
    if (!membuf_reserve(b, needed)) {
        return 0;
    }
    memcpy(b->data + b->size, ptr, total);
    b->size += total;
    b->data[b->size] = '\0';
    return total;
}

/* Simple ASCII case-insensitive substring search */
static const char *find_substr_ci(const char *haystack, const char *needle) {
    if (!haystack || !needle) return NULL;
    size_t nlen = strlen(needle);
    if (nlen == 0) return haystack;
    for (const char *h = haystack; *h; ++h) {
        size_t i = 0;
        while (i < nlen && h[i]) {
            char a = (char)tolower((unsigned char)h[i]);
            char b = (char)tolower((unsigned char)needle[i]);
            if (a != b) break;
            ++i;
        }
        if (i == nlen) return h;
        if (!h[1]) break;
    }
    return NULL;
}

/* Trim leading and trailing whitespace, and collapse internal whitespace to single spaces */
static void normalize_whitespace(char *s) {
    if (!s) return;
    size_t len = strlen(s);
    size_t r = 0, w = 0;
    /* skip leading spaces */
    while (r < len && isspace((unsigned char)s[r])) r++;
    int in_space = 0;
    for (; r < len; ++r) {
        unsigned char c = (unsigned char)s[r];
        if (isspace(c)) {
            in_space = 1;
        } else {
            if (in_space && w > 0) {
                s[w++] = ' ';
            }
            s[w++] = (char)c;
            in_space = 0;
        }
    }
    /* remove trailing space if exists */
    if (w > 0 && s[w - 1] == ' ') w--;
    s[w] = '\0';
}

/* Extracts the <title> ... </title> content (case-insensitive). Returns malloc'd string or NULL. */
static char *extract_title(const char *html) {
    if (!html) return NULL;

    const char *topen = find_substr_ci(html, "<title");
    if (!topen) return NULL;

    const char *gt = strchr(topen, '>');
    if (!gt) return NULL;
    const char *content_start = gt + 1;
    const char *tclose = find_substr_ci(content_start, "</title>");
    if (!tclose || tclose <= content_start) return NULL;

    size_t raw_len = (size_t)(tclose - content_start);
    /* Allocate buffer for title plus null terminator */
    char *title = (char *)malloc(raw_len + 1);
    if (!title) return NULL;
    memcpy(title, content_start, raw_len);
    title[raw_len] = '\0';

    normalize_whitespace(title);

    /* If title becomes empty after normalization, treat as not found */
    if (title[0] == '\0') {
        free(title);
        return NULL;
    }
    return title;
}

/* Performs HTTPS GET and returns allocated content buffer and length. Caller must free(*out). */
static int http_get_content(const char *url, char **out, size_t *out_len) {
    if (!out || !out_len) return -1;
    *out = NULL;
    *out_len = 0;

    if (!is_valid_https_url(url)) {
        return -2;
    }

    CURLcode res;
    CURL *curl = curl_easy_init();
    if (!curl) return -3;

    MemBuf buf;
    if (!membuf_init(&buf, MAX_CONTENT_SIZE)) {
        curl_easy_cleanup(curl);
        return -4;
    }

    char errbuf[CURL_ERROR_SIZE] = {0};

    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS_STR, "https");
    curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS_STR, "https");
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, MAX_REDIRECTS);
    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, CONNECT_TIMEOUT_SEC);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT, TRANSFER_TIMEOUT_SEC);
    curl_easy_setopt(curl, CURLOPT_USERAGENT, "TitleFetcher/1.0 (+https)");
    curl_easy_setopt(curl, CURLOPT_ACCEPT_ENCODING, "");
    curl_easy_setopt(curl, CURLOPT_NOSIGNAL, 1L);

    /* Strict TLS */
    curl_easy_setopt(curl, CURLOPT_USE_SSL, (long)CURLUSESSL_ALL);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);

    /* Write callback */
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, curl_write_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &buf);
    curl_easy_setopt(curl, CURLOPT_ERRORBUFFER, errbuf);

    res = curl_easy_perform(curl);
    long response_code = 0;
    if (res == CURLE_OK) {
        curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &response_code);
    }

    curl_easy_cleanup(curl);

    if (res != CURLE_OK) {
        membuf_free(&buf);
        return -5;
    }
    if (response_code < 200 || response_code >= 300) {
        membuf_free(&buf);
        return -6;
    }

    /* NUL-terminated by callback; duplicate into tight buffer for caller */
    char *outbuf = (char *)malloc(buf.size + 1);
    if (!outbuf) {
        membuf_free(&buf);
        return -7;
    }
    memcpy(outbuf, buf.data, buf.size + 1);
    *out = outbuf;
    *out_len = buf.size;

    membuf_free(&buf);
    return 0;
}

/* High-level function: fetch URL and return extracted title. Caller must free returned string. */
static char *fetch_and_extract_title(const char *url) {
    char *html = NULL;
    size_t len = 0;
    int rc = http_get_content(url, &html, &len);
    if (rc != 0 || !html) {
        if (html) free(html);
        return NULL;
    }
    char *title = extract_title(html);
    free(html);
    return title;
}

/* CLI helper: process one URL and print result */
static void process_url_and_print(const char *url) {
    if (!is_valid_https_url(url)) {
        fprintf(stderr, "Invalid HTTPS URL: %s\n", url ? url : "(null)");
        return;
    }
    char *title = fetch_and_extract_title(url);
    if (title) {
        printf("URL: %s\nTitle: %s\n\n", url, title);
        free(title);
    } else {
        printf("URL: %s\nTitle: [Not found or fetch error]\n\n", url);
    }
}

int main(int argc, char **argv) {
    if (curl_global_init(CURL_GLOBAL_DEFAULT) != 0) {
        fprintf(stderr, "Failed to initialize libcurl\n");
        return 1;
    }

    int exit_code = 0;

    if (argc > 1) {
        for (int i = 1; i < argc; ++i) {
            process_url_and_print(argv[i]);
        }
    } else {
        /* 5 test cases */
        const char *tests[5] = {
            "https://example.com/",
            "https://www.iana.org/",
            "https://httpbin.org/html",
            "https://expired.badssl.com/",
            "https://www.wikipedia.org/"
        };
        for (int i = 0; i < 5; ++i) {
            process_url_and_print(tests[i]);
        }
    }

    curl_global_cleanup();
    return exit_code;
}
