#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <unistd.h>
#include <errno.h>
#include <limits.h>

#ifndef O_NOFOLLOW
#define O_NOFOLLOW 0
#endif

typedef struct {
    int ok;        // 1 on success, 0 on error
    char* data;    // malloc'd content on success, NULL on error
    char* error;   // malloc'd error message on error, NULL on success
} ReadResultC;

static char* dupstr(const char* s) {
    if (!s) return NULL;
    size_t len = strlen(s);
    char* out = (char*)malloc(len + 1);
    if (!out) return NULL;
    memcpy(out, s, len + 1);
    return out;
}

static char* fmt_error(const char* msg, const char* detail) {
    size_t lm = strlen(msg);
    size_t ld = detail ? strlen(detail) : 0;
    size_t n = lm + (ld ? 2 + ld : 0) + 1;
    char* out = (char*)malloc(n);
    if (!out) return NULL;
    if (detail && ld > 0) {
        snprintf(out, n, "%s: %s", msg, detail);
    } else {
        snprintf(out, n, "%s", msg);
    }
    return out;
}

static int isAllowedPathCharC(char c) {
    return (isalnum((unsigned char)c) || c=='_' || c=='-' || c=='.' || c=='/');
}

static int ensureDir(const char* path) {
    if (mkdir(path, 0700) == 0) return 1;
    if (errno == EEXIST) {
        struct stat st;
        if (stat(path, &st) == 0 && S_ISDIR(st.st_mode)) return 1;
    }
    return 0;
}

static int writeFileAtomic(const char* dir, const char* name, const char* content) {
    // Construct temp path template
    char tmpl[PATH_MAX];
    if (snprintf(tmpl, sizeof(tmpl), "%s/%s.tmpXXXXXX", dir, name) >= (int)sizeof(tmpl)) {
        return 0;
    }
    int tfd = mkstemp(tmpl);
    if (tfd < 0) return 0;

    size_t left = strlen(content);
    const char* p = content;
    while (left > 0) {
        ssize_t w = write(tfd, p, left > 8192 ? 8192 : left);
        if (w < 0) {
            if (errno == EINTR) continue;
            close(tfd);
            unlink(tmpl);
            return 0;
        }
        p += w;
        left -= (size_t)w;
    }
    if (fsync(tfd) != 0) {
        close(tfd);
        unlink(tmpl);
        return 0;
    }
    close(tfd);

    char final[PATH_MAX];
    if (snprintf(final, sizeof(final), "%s/%s", dir, name) >= (int)sizeof(final)) {
        unlink(tmpl);
        return 0;
    }
    if (rename(tmpl, final) != 0) {
        unlink(tmpl);
        return 0;
    }
    return 1;
}

static ReadResultC readFileWithinBaseC(const char* baseDir, const char* userPath, size_t maxBytes) {
    ReadResultC rr;
    rr.ok = 0;
    rr.data = NULL;
    rr.error = NULL;

    if (!baseDir || baseDir[0] == '\0') {
        rr.error = dupstr("Base directory is empty");
        return rr;
    }
    if (!userPath || userPath[0] == '\0') {
        rr.error = dupstr("Filename is empty");
        return rr;
    }
    size_t upLen = strnlen(userPath, 2048);
    if (upLen >= 1024) {
        rr.error = dupstr("Filename too long");
        return rr;
    }
    if (userPath[0] == '/') {
        rr.error = dupstr("Absolute paths are not allowed");
        return rr;
    }
    for (size_t i = 0; i < upLen; ++i) {
        if (userPath[i] == '\0') {
            rr.error = dupstr("Invalid NUL character in path");
            return rr;
        }
        if (!isAllowedPathCharC(userPath[i])) {
            rr.error = dupstr("Invalid character in path");
            return rr;
        }
    }

    // Open base directory
    int dirfd = open(baseDir, O_RDONLY | O_DIRECTORY | O_CLOEXEC);
    if (dirfd < 0) {
        rr.error = fmt_error("Failed to open base directory", strerror(errno));
        return rr;
    }

    // Traverse components
    const char* p = userPath;
    char segment[256];
    size_t segLen = 0;
    int curDirFd = dirfd; // holds ownership
    int i = 0;

    // Helper to close fd safely
    auto close_fd = [](int* fdptr) {
        if (*fdptr >= 0) { close(*fdptr); *fdptr = -1; }
    };

    // Count segments to determine final component
    int totalSegments = 0;
    for (size_t j = 0; j <= upLen; ++j) {
        if (userPath[j] == '/' || userPath[j] == '\0') {
            if (segLen > 0) { totalSegments++; segLen = 0; }
        } else {
            segLen++;
        }
    }
    segLen = 0;

    int processed = 0;
    while (1) {
        char c = *p++;
        if (c == '/' || c == '\0') {
            if (segLen > 0) {
                segment[segLen] = '\0';
                // Validate segment
                if (strcmp(segment, "..") == 0) {
                    rr.error = dupstr("Parent directory reference '..' is not allowed");
                    close_fd(&curDirFd);
                    return rr;
                }
                if (strcmp(segment, ".") == 0) {
                    // skip
                } else {
                    processed++;
                    if (processed < totalSegments) {
                        // Intermediate dir: open without following symlinks
                        int nfd = openat(curDirFd, segment, O_RDONLY | O_DIRECTORY | O_NOFOLLOW | O_CLOEXEC);
                        if (nfd < 0) {
                            rr.error = fmt_error("Failed to access directory", strerror(errno));
                            close_fd(&curDirFd);
                            return rr;
                        }
                        close_fd(&curDirFd);
                        curDirFd = nfd;
                    } else {
                        // Final component: open file
                        int ffd = openat(curDirFd, segment, O_RDONLY | O_NOFOLLOW | O_CLOEXEC);
                        if (ffd < 0) {
                            rr.error = fmt_error("Failed to open file", strerror(errno));
                            close_fd(&curDirFd);
                            return rr;
                        }
                        struct stat st;
                        if (fstat(ffd, &st) != 0) {
                            rr.error = fmt_error("Failed to stat file", strerror(errno));
                            close_fd(&ffd);
                            close_fd(&curDirFd);
                            return rr;
                        }
                        if (!S_ISREG(st.st_mode)) {
                            rr.error = dupstr("Not a regular file");
                            close_fd(&ffd);
                            close_fd(&curDirFd);
                            return rr;
                        }

                        // Read file with cap
                        size_t cap = 0, size = 0;
                        char* buf = NULL;
                        const size_t CHUNK = 8192;
                        while (1) {
                            if (size + CHUNK > maxBytes) {
                                // Adjust to maxBytes boundary
                                size_t remain = maxBytes - size;
                                if (remain == 0) {
                                    rr.error = dupstr("File too large");
                                    free(buf);
                                    close_fd(&ffd);
                                    close_fd(&curDirFd);
                                    return rr;
                                }
                                // read up to remain, then if more data exists, error
                                if (cap < size + remain) {
                                    size_t ncap = size + remain;
                                    char* nbuf = (char*)realloc(buf, ncap);
                                    if (!nbuf) {
                                        free(buf);
                                        rr.error = dupstr("Out of memory");
                                        close_fd(&ffd);
                                        close_fd(&curDirFd);
                                        return rr;
                                    }
                                    buf = nbuf;
                                    cap = ncap;
                                }
                                ssize_t r = read(ffd, buf + size, remain);
                                if (r < 0) {
                                    if (errno == EINTR) continue;
                                    free(buf);
                                    rr.error = fmt_error("Read error", strerror(errno));
                                    close_fd(&ffd);
                                    close_fd(&curDirFd);
                                    return rr;
                                }
                                if (r == 0) {
                                    size += 0;
                                    break;
                                }
                                size += (size_t)r;
                                // Try to read one more byte to detect overflow
                                char tmp;
                                r = read(ffd, &tmp, 1);
                                if (r > 0) {
                                    free(buf);
                                    rr.error = dupstr("File too large");
                                    close_fd(&ffd);
                                    close_fd(&curDirFd);
                                    return rr;
                                }
                                break;
                            } else {
                                if (cap < size + CHUNK) {
                                    size_t ncap = (cap == 0) ? CHUNK : (cap * 2);
                                    if (ncap < size + CHUNK) ncap = size + CHUNK;
                                    char* nbuf = (char*)realloc(buf, ncap);
                                    if (!nbuf) {
                                        free(buf);
                                        rr.error = dupstr("Out of memory");
                                        close_fd(&ffd);
                                        close_fd(&curDirFd);
                                        return rr;
                                    }
                                    buf = nbuf;
                                    cap = ncap;
                                }
                                ssize_t r = read(ffd, buf + size, CHUNK);
                                if (r < 0) {
                                    if (errno == EINTR) continue;
                                    free(buf);
                                    rr.error = fmt_error("Read error", strerror(errno));
                                    close_fd(&ffd);
                                    close_fd(&curDirFd);
                                    return rr;
                                }
                                if (r == 0) break;
                                size += (size_t)r;
                            }
                        }
                        // Null-terminate for convenience (data may be binary)
                        char* out = (char*)malloc(size + 1);
                        if (!out) {
                            free(buf);
                            rr.error = dupstr("Out of memory");
                            close_fd(&ffd);
                            close_fd(&curDirFd);
                            return rr;
                        }
                        if (size > 0 && buf) memcpy(out, buf, size);
                        out[size] = '\0';
                        free(buf);

                        rr.ok = 1;
                        rr.data = out;
                        rr.error = NULL;

                        close_fd(&ffd);
                        close_fd(&curDirFd);
                        return rr;
                    }
                }
                segLen = 0;
            }
            if (c == '\0') break;
        } else {
            if (segLen + 1 >= sizeof(segment)) {
                rr.error = dupstr("Path segment too long");
                close_fd(&curDirFd);
                return rr;
            }
            segment[segLen++] = c;
        }
    }

    rr.error = dupstr("Invalid path");
    close_fd(&curDirFd);
    return rr;
}

int main(int argc, char* argv[]) {
    const char* base = "sandbox_c";
    const char* sub = "sandbox_c/sub";
    if (!ensureDir(base)) {
        fprintf(stderr, "Failed to create base sandbox directory\n");
        return 1;
    }
    if (!ensureDir(sub)) {
        fprintf(stderr, "Failed to create sub directory\n");
        return 1;
    }
    (void)writeFileAtomic(base, "a.txt", "Hello from C A\n");
    (void)writeFileAtomic(sub, "b.txt", "Hello from C B in subdir\n");

    const char* tests[5];
    if (argc > 1) tests[0] = argv[1];
    else tests[0] = "a.txt";
    tests[1] = "sub/b.txt";
    tests[2] = "../etc/passwd";
    tests[3] = "missing.txt";
    tests[4] = "sub";

    for (int i = 0; i < 5; ++i) {
        ReadResultC r = readFileWithinBaseC(base, tests[i], 1024 * 1024);
        printf("Test %d [%s]: ", i + 1, tests[i]);
        if (r.ok) {
            size_t len = strlen(r.data);
            printf("SUCCESS, bytes=%zu\n", len);
            // Preview up to 60 chars without newlines
            char preview[61];
            size_t n = len < 60 ? len : 60;
            for (size_t j = 0; j < n; ++j) {
                char c = r.data[j];
                preview[j] = (c == '\n' || c == '\r') ? ' ' : c;
            }
            preview[n] = '\0';
            printf("  Preview: %s%s\n", preview, (len > 60 ? "..." : ""));
            free(r.data);
        } else {
            printf("ERROR: %s\n", r.error ? r.error : "Unknown error");
        }
        free(r.error);
    }
    return 0;
}
