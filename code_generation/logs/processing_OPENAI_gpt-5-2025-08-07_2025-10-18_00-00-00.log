/*
  C - Fetch HTTPS URL and extract HTML <title>
  Build: cc -Wall -Wextra -pedantic -O2 task76.c -o task76 -lcurl
*/
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <curl/curl.h>

#define MAX_URL_LEN 2048
#define MAX_DOWNLOAD_SIZE (5 * 1024 * 1024) /* 5 MiB */
#define USER_AGENT "Task76-Client/1.0 (+https://example.local)"
#define TIMEOUT_CONNECT 15L
#define TIMEOUT total_TIMEOUT 45L

typedef struct {
    char *data;
    size_t size;
    size_t capacity;
    size_t limit;
} Buffer;

static int is_valid_https_url(const char *url) {
    if (!url) return 0;
    size_t len = strnlen(url, MAX_URL_LEN + 1);
    if (len == 0 || len > MAX_URL_LEN) return 0;
    const char prefix[] = "https://";
    size_t pfxlen = sizeof(prefix) - 1;
    if (len < pfxlen) return 0;
    for (size_t i = 0; i < pfxlen; ++i) {
        if (tolower((unsigned char)url[i]) != prefix[i]) return 0;
    }
    return 1;
}

static void buffer_init(Buffer *b, size_t initial_capacity, size_t limit) {
    b->data = (char*)malloc(initial_capacity);
    if (b->data) b->data[0] = '\0';
    b->size = 0;
    b->capacity = b->data ? initial_capacity : 0;
    b->limit = limit;
}

static void buffer_free(Buffer *b) {
    if (b->data) {
        free(b->data);
        b->data = NULL;
    }
    b->size = b->capacity = b->limit = 0;
}

static size_t safe_add_size(size_t a, size_t b, int *ok) {
    if (SIZE_MAX - a < b) {
        *ok = 0;
        return 0;
    }
    *ok = 1;
    return a + b;
}

static size_t write_cb(char *ptr, size_t size, size_t nmemb, void *userdata) {
    Buffer *buf = (Buffer*)userdata;
    int okmul = 1;
    size_t total = (nmemb == 0) ? 0 : size * nmemb;
    if (nmemb != 0 && total / nmemb != size) {
        return 0; /* overflow detected */
    }
    if (total == 0) return 0;

    if (buf->size + total > buf->limit) {
        return 0; /* prevent exceeding maximum allowed download size */
    }

    if (buf->size + total + 1 > buf->capacity) {
        size_t newcap = buf->capacity ? buf->capacity : 8192;
        while (buf->size + total + 1 > newcap) {
            if (newcap > SIZE_MAX / 2) { return 0; }
            newcap *= 2;
        }
        char *nd = (char*)realloc(buf->data, newcap);
        if (!nd) return 0;
        buf->data = nd;
        buf->capacity = newcap;
    }

    memcpy(buf->data + buf->size, ptr, total);
    buf->size += total;
    buf->data[buf->size] = '\0';
    (void)okmul;
    return total;
}

static const char* ci_strstr(const char *haystack, const char *needle) {
    if (!*needle) return haystack;
    size_t nlen = strlen(needle);
    for (const char *h = haystack; *h; ++h) {
        size_t i = 0;
        while (i < nlen) {
            unsigned char ch = (unsigned char)h[i];
            unsigned char cn = (unsigned char)needle[i];
            if (tolower(ch) != tolower(cn)) break;
            i++;
        }
        if (i == nlen) return h;
    }
    return NULL;
}

static void trim_and_collapse_ws(char *s) {
    if (!s) return;
    size_t len = strlen(s);
    size_t start = 0;
    while (start < len && isspace((unsigned char)s[start])) start++;
    size_t end = len;
    while (end > start && isspace((unsigned char)s[end - 1])) end--;
    size_t w = 0;
    int in_ws = 0;
    for (size_t i = start; i < end; ++i) {
        if (isspace((unsigned char)s[i])) {
            if (!in_ws) {
                s[w++] = ' ';
                in_ws = 1;
            }
        } else {
            s[w++] = s[i];
            in_ws = 0;
        }
    }
    s[w] = '\0';
}

static char* extract_title(const char *html) {
    if (!html) return NULL;
    const char *open = ci_strstr(html, "<title");
    if (!open) return NULL;
    const char *gt = strchr(open, '>');
    if (!gt) return NULL;
    const char *start = gt + 1;
    const char *close = ci_strstr(start, "</title");
    if (!close || close <= start) return NULL;
    size_t rawlen = (size_t)(close - start);
    if (rawlen == 0 || rawlen > 4096) { /* limit title length */
        return NULL;
    }
    char *title = (char*)malloc(rawlen + 1);
    if (!title) return NULL;
    memcpy(title, start, rawlen);
    title[rawlen] = '\0';
    trim_and_collapse_ws(title);
    return title;
}

static char* fetch_https(const char *url) {
    if (!is_valid_https_url(url)) {
        return NULL;
    }

    CURLcode ginit = curl_global_init(CURL_GLOBAL_DEFAULT);
    if (ginit != CURLE_OK) {
        return NULL;
    }

    CURL *curl = curl_easy_init();
    if (!curl) {
        curl_global_cleanup();
        return NULL;
    }

    Buffer buf;
    buffer_init(&buf, 8192, MAX_DOWNLOAD_SIZE);
    if (!buf.data) {
        curl_easy_cleanup(curl);
        curl_global_cleanup();
        return NULL;
    }

    long sslver = CURL_SSLVERSION_TLSv1_2;
    #ifdef CURL_SSLVERSION_MAX_TLSv1_3
    sslver |= CURL_SSLVERSION_MAX_TLSv1_3;
    #endif

    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_USERAGENT, USER_AGENT);
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, 10L);
    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, TIMEOUT_CONNECT);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT, TIMEOUT);
    curl_easy_setopt(curl, CURLOPT_ACCEPT_ENCODING, "");
    curl_easy_setopt(curl, CURLOPT_HTTP_VERSION, (long)CURL_HTTP_VERSION_2TLS);

    /* TLS security */
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);
    curl_easy_setopt(curl, CURLOPT_SSLVERSION, sslver);

    /* Write callback */
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &buf);

    CURLcode res = curl_easy_perform(curl);
    long http_code = 0;
    if (res == CURLE_OK) {
        curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);
    }

    curl_easy_cleanup(curl);
    curl_global_cleanup();

    if (res != CURLE_OK || http_code < 200 || http_code >= 300) {
        buffer_free(&buf);
        return NULL;
    }

    return buf.data; /* caller must free */
}

char* get_page_title_from_url(const char *url) {
    char *html = fetch_https(url);
    if (!html) {
        return NULL;
    }
    char *title = extract_title(html);
    free(html);
    return title;
}

static void run_test(const char *url) {
    if (!is_valid_https_url(url)) {
        fprintf(stderr, "Invalid HTTPS URL: %s\n", url);
        return;
    }
    char *title = get_page_title_from_url(url);
    if (title) {
        printf("URL: %s\nTitle: %s\n\n", url, title);
        free(title);
    } else {
        printf("URL: %s\nTitle: [Not found or fetch failed]\n\n", url);
    }
}

int main(int argc, char **argv) {
    if (argc > 1) {
        for (int i = 1; i < argc; ++i) {
            run_test(argv[i]);
        }
    } else {
        const char *tests[5] = {
            "https://www.example.com/",
            "https://www.iana.org/domains/reserved",
            "https://www.wikipedia.org/",
            "https://httpbin.org/html",
            "https://www.rfc-editor.org/"
        };
        for (int i = 0; i < 5; ++i) {
            run_test(tests[i]);
        }
    }
    return 0;
}
