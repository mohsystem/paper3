#define _XOPEN_SOURCE 700
#include <errno.h>
#include <fcntl.h>
#include <inttypes.h>
#include <limits.h>
#include <pthread.h>
#include <stdarg.h>
#include <stdbool.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <dirent.h>
#include <unistd.h>

typedef struct {
    char path[PATH_MAX];
    uint64_t bytes;
    uint64_t lines;
    int success; // 1 ok, 0 fail
    char message[128];
} FileStats;

typedef struct {
    char **items;
    size_t cap;
    size_t head;
    size_t tail;
    size_t count;
    int closed;
    pthread_mutex_t mu;
    pthread_cond_t cv;
} TSQueue;

static int queue_init(TSQueue *q, size_t cap) {
    if (!q || cap == 0) return 0;
    q->items = (char **)calloc(cap, sizeof(char*));
    if (!q->items) return 0;
    q->cap = cap; q->head = 0; q->tail = 0; q->count = 0; q->closed = 0;
    if (pthread_mutex_init(&q->mu, NULL) != 0) return 0;
    if (pthread_cond_init(&q->cv, NULL) != 0) return 0;
    return 1;
}
static void queue_destroy(TSQueue *q) {
    if (!q) return;
    pthread_mutex_destroy(&q->mu);
    pthread_cond_destroy(&q->cv);
    for (size_t i = 0; i < q->count; ++i) {
        size_t idx = (q->head + i) % q->cap;
        free(q->items[idx]);
    }
    free(q->items);
}
static int queue_push(TSQueue *q, const char *s) {
    pthread_mutex_lock(&q->mu);
    if (q->count == q->cap) {
        size_t ncap = q->cap * 2;
        char **nitems = (char **)calloc(ncap, sizeof(char*));
        if (!nitems) { pthread_mutex_unlock(&q->mu); return 0; }
        for (size_t i = 0; i < q->count; ++i) {
            size_t idx = (q->head + i) % q->cap;
            nitems[i] = q->items[idx];
        }
        free(q->items);
        q->items = nitems;
        q->cap = ncap;
        q->head = 0;
        q->tail = q->count;
    }
    size_t len = strnlen(s, PATH_MAX - 1);
    char *dup = (char *)malloc(len + 1);
    if (!dup) { pthread_mutex_unlock(&q->mu); return 0; }
    memcpy(dup, s, len);
    dup[len] = '\0';
    q->items[q->tail] = dup;
    q->tail = (q->tail + 1) % q->cap;
    q->count++;
    pthread_cond_signal(&q->cv);
    pthread_mutex_unlock(&q->mu);
    return 1;
}
static void queue_close(TSQueue *q) {
    pthread_mutex_lock(&q->mu);
    q->closed = 1;
    pthread_cond_broadcast(&q->cv);
    pthread_mutex_unlock(&q->mu);
}
static int queue_pop(TSQueue *q, char *out, size_t outsz) {
    pthread_mutex_lock(&q->mu);
    while (q->count == 0 && !q->closed) {
        pthread_cond_wait(&q->cv, &q->mu);
    }
    if (q->count == 0) { pthread_mutex_unlock(&q->mu); return 0; }
    char *s = q->items[q->head];
    q->items[q->head] = NULL;
    q->head = (q->head + 1) % q->cap;
    q->count--;
    pthread_mutex_unlock(&q->mu);
    size_t len = strnlen(s, outsz - 1);
    memcpy(out, s, len);
    out[len] = '\0';
    free(s);
    return 1;
}

typedef struct {
    TSQueue *queue;
    char base_real[PATH_MAX];
    FileStats *stats;
    size_t stats_cap;
    size_t *stats_idx;
    pthread_mutex_t *stats_mu;
} WorkerArgs;

static int get_realpath(const char *in, char *out, size_t outsz) {
    if (!in || !out || outsz == 0) return 0;
    char buf[PATH_MAX];
    if (!realpath(in, buf)) return 0;
    size_t len = strnlen(buf, sizeof(buf));
    if (len + 1 > outsz) return 0;
    memcpy(out, buf, len + 1);
    return 1;
}

static int is_within_dir(const char *base_real, const char *path_real) {
    size_t b = strnlen(base_real, PATH_MAX - 1);
    size_t p = strnlen(path_real, PATH_MAX - 1);
    char tmp[PATH_MAX];
    if (b + 2 >= sizeof(tmp)) return 0;
    memcpy(tmp, base_real, b);
    if (b == 0 || tmp[b-1] != '/') { tmp[b] = '/'; tmp[b+1] = '\0'; b += 1; }
    else { tmp[b] = '\0'; }
    if (p < b) return 0;
    if (memcmp(tmp, path_real, b) == 0) return 1;
    return 0;
}

static int try_exclusive_lock(int fd) {
    struct flock fl;
    memset(&fl, 0, sizeof(fl));
    fl.l_type = F_WRLCK;
    fl.l_whence = SEEK_SET;
    fl.l_start = 0;
    fl.l_len = 0;
    if (fcntl(fd, F_SETLK, &fl) == -1) {
        if (errno == EACCES || errno == EAGAIN) return 0;
        return 0;
    }
    return 1;
}

static int write_atomic_sidecar(const char *final_path, const char *content) {
    size_t fplen = strnlen(final_path, PATH_MAX - 1);
    const char *slash = strrchr(final_path, '/');
    char dir[PATH_MAX];
    char name[PATH_MAX];
    if (slash) {
        size_t dlen = (size_t)(slash - final_path);
        if (dlen >= sizeof(dir)) return 0;
        memcpy(dir, final_path, dlen);
        dir[dlen] = '\0';
        size_t nlen = fplen - dlen - 1;
        if (nlen >= sizeof(name)) return 0;
        memcpy(name, slash + 1, nlen);
        name[nlen] = '\0';
    } else {
        snprintf(dir, sizeof(dir), "%s", ".");
        if (fplen >= sizeof(name)) return 0;
        memcpy(name, final_path, fplen + 1);
    }
    char tmpl[PATH_MAX];
    if (snprintf(tmpl, sizeof(tmpl), "%s/.tmp-%s-XXXXXX", dir, name) >= (int)sizeof(tmpl)) return 0;
    int tmpfd = mkstemp(tmpl);
    if (tmpfd == -1) return 0;
    fchmod(tmpfd, 0644);

    size_t left = strnlen(content, SIZE_MAX);
    const char *p = content;
    while (left > 0) {
        size_t chunk = left > 65536 ? 65536 : left;
        ssize_t w = write(tmpfd, p, chunk);
        if (w == -1) {
            if (errno == EINTR) continue;
            close(tmpfd);
            unlink(tmpl);
            return 0;
        }
        p += w;
        left -= (size_t)w;
    }
    if (fsync(tmpfd) == -1) {
        close(tmpfd);
        unlink(tmpl);
        return 0;
    }
    if (close(tmpfd) == -1) {
        unlink(tmpl);
        return 0;
    }
    if (rename(tmpl, final_path) == -1) {
        unlink(tmpl);
        return 0;
    }
    return 1;
}

static FileStats process_one_file(const char *base_real, const char *file_path) {
    FileStats st;
    memset(&st, 0, sizeof(st));
    snprintf(st.path, sizeof(st.path), "%s", file_path);
    struct stat lst;
    if (lstat(file_path, &lst) == -1) {
        snprintf(st.message, sizeof(st.message), "%s", "lstat failed");
        return st;
    }
    if (!S_ISREG(lst.st_mode)) {
        snprintf(st.message, sizeof(st.message), "%s", "not regular");
        return st;
    }
    char realp[PATH_MAX];
    if (!get_realpath(file_path, realp, sizeof(realp))) {
        snprintf(st.message, sizeof(st.message), "%s", "realpath fail");
        return st;
    }
    if (!is_within_dir(base_real, realp)) {
        snprintf(st.message, sizeof(st.message), "%s", "escapes base");
        return st;
    }

    int fd = open(file_path, O_RDONLY | O_CLOEXEC);
    if (fd == -1) {
        snprintf(st.message, sizeof(st.message), "%s", "open fail");
        return st;
    }
    if (!try_exclusive_lock(fd)) {
        close(fd);
        snprintf(st.message, sizeof(st.message), "%s", "lock busy");
        return st;
    }

    const size_t BUFSZ = 1 << 16;
    char *buf = (char*)malloc(BUFSZ);
    if (!buf) {
        close(fd);
        snprintf(st.message, sizeof(st.message), "%s", "oom");
        return st;
    }
    while (1) {
        ssize_t r = read(fd, buf, BUFSZ);
        if (r == -1) {
            if (errno == EINTR) continue;
            free(buf);
            close(fd);
            snprintf(st.message, sizeof(st.message), "%s", "read fail");
            return st;
        }
        if (r == 0) break;
        st.bytes += (uint64_t)r;
        for (ssize_t i = 0; i < r; ++i) {
            if (buf[i] == '\n') st.lines++;
        }
    }
    free(buf);
    if (close(fd) == -1) {
        snprintf(st.message, sizeof(st.message), "%s", "close fail");
        return st;
    }

    char outpath[PATH_MAX];
    if (snprintf(outpath, sizeof(outpath), "%s.out", file_path) >= (int)sizeof(outpath)) {
        snprintf(st.message, sizeof(st.message), "%s", "path too long");
        return st;
    }
    char content[512];
    int n = snprintf(content, sizeof(content),
                     "file: %s\nbytes: %" PRIu64 "\nlines: %" PRIu64 "\n",
                     realp, st.bytes, st.lines);
    if (n <= 0 || (size_t)n >= sizeof(content)) {
        snprintf(st.message, sizeof(st.message), "%s", "format fail");
        return st;
    }
    if (!write_atomic_sidecar(outpath, content)) {
        snprintf(st.message, sizeof(st.message), "%s", "atomic write fail");
        return st;
    }
    st.success = 1;
    snprintf(st.message, sizeof(st.message), "%s", "ok");
    return st;
}

static void *worker_run(void *arg) {
    WorkerArgs *wa = (WorkerArgs*)arg;
    char path[PATH_MAX];
    while (queue_pop(wa->queue, path, sizeof(path))) {
        FileStats fs = process_one_file(wa->base_real, path);
        pthread_mutex_lock(wa->stats_mu);
        if (*wa->stats_idx < wa->stats_cap) {
            wa->stats[*wa->stats_idx] = fs;
            (*wa->stats_idx)++;
        }
        pthread_mutex_unlock(wa->stats_mu);
    }
    return NULL;
}

typedef struct {
    int processed;
    int skipped;
} ProcessResult;

static int list_regular_files(const char *base_dir, char ***out, size_t *out_count, char *base_real, size_t base_real_sz) {
    *out = NULL; *out_count = 0;
    if (!get_realpath(base_dir, base_real, base_real_sz)) return 0;
    DIR *dir = opendir(base_real);
    if (!dir) return 0;
    size_t cap = 16;
    char **arr = (char**)calloc(cap, sizeof(char*));
    if (!arr) { closedir(dir); return 0; }

    struct dirent *ent;
    while ((ent = readdir(dir)) != NULL) {
        if (strcmp(ent->d_name, ".") == 0 || strcmp(ent->d_name, "..") == 0) continue;
        char candidate[PATH_MAX];
        if (snprintf(candidate, sizeof(candidate), "%s/%s", base_real, ent->d_name) >= (int)sizeof(candidate)) continue;
        struct stat st;
        if (lstat(candidate, &st) == -1) continue;
        if (!S_ISREG(st.st_mode)) continue;
        char rp[PATH_MAX];
        if (!get_realpath(candidate, rp, sizeof(rp))) continue;
        if (!is_within_dir(base_real, rp)) continue;
        if (*out_count == cap) {
            size_t ncap = cap * 2;
            char **narr = (char**)realloc(arr, ncap * sizeof(char*));
            if (!narr) { break; }
            arr = narr; cap = ncap;
        }
        size_t len = strnlen(rp, PATH_MAX - 1);
        char *dup = (char*)malloc(len + 1);
        if (!dup) break;
        memcpy(dup, rp, len);
        dup[len] = '\0';
        arr[*out_count] = dup;
        (*out_count)++;
    }
    closedir(dir);
    *out = arr;
    return 1;
}

static ProcessResult process_directory_concurrently(const char *base_dir, size_t threads, FileStats *stats, size_t stats_cap, size_t *stats_out_count) {
    ProcessResult pr = {0,0};
    *stats_out_count = 0;

    char base_real[PATH_MAX];
    char **files = NULL;
    size_t file_count = 0;
    if (!list_regular_files(base_dir, &files, &file_count, base_real, sizeof(base_real))) {
        return pr;
    }

    TSQueue q;
    if (!queue_init(&q, file_count > 0 ? file_count : 16)) {
        for (size_t i = 0; i < file_count; ++i) free(files[i]);
        free(files);
        return pr;
    }
    for (size_t i = 0; i < file_count; ++i) {
        queue_push(&q, files[i]);
    }
    queue_close(&q);

    pthread_t *tids = (pthread_t*)calloc(threads ? threads : 1, sizeof(pthread_t));
    if (!tids) {
        queue_destroy(&q);
        for (size_t i = 0; i < file_count; ++i) free(files[i]);
        free(files);
        return pr;
    }
    pthread_mutex_t stats_mu;
    pthread_mutex_init(&stats_mu, NULL);
    size_t idx = 0;

    WorkerArgs wa;
    wa.queue = &q;
    snprintf(wa.base_real, sizeof(wa.base_real), "%s", base_real);
    wa.stats = stats;
    wa.stats_cap = stats_cap;
    wa.stats_idx = &idx;
    wa.stats_mu = &stats_mu;

    size_t nthreads = threads ? threads : 1;
    for (size_t i = 0; i < nthreads; ++i) {
        pthread_create(&tids[i], NULL, worker_run, &wa);
    }
    for (size_t i = 0; i < nthreads; ++i) {
        pthread_join(tids[i], NULL);
    }
    pthread_mutex_destroy(&stats_mu);
    queue_destroy(&q);
    for (size_t i = 0; i < file_count; ++i) free(files[i]);
    free(files);
    free(tids);

    *stats_out_count = idx;
    for (size_t i = 0; i < idx; ++i) {
        if (stats[i].success) pr.processed++;
        else pr.skipped++;
    }
    return pr;
}

// Test helpers
static int mkdir_p(const char *path, mode_t mode) {
    if (mkdir(path, mode) == 0) return 1;
    if (errno == EEXIST) {
        struct stat st;
        if (stat(path, &st) == 0 && S_ISDIR(st.st_mode)) return 1;
    }
    return 0;
}

static int write_file_atomic(const char *path, const char *content, size_t content_len) {
    char dir[PATH_MAX], name[PATH_MAX], tmpl[PATH_MAX];
    const char *slash = strrchr(path, '/');
    if (slash) {
        size_t dlen = (size_t)(slash - path);
        if (dlen >= sizeof(dir)) return 0;
        memcpy(dir, path, dlen);
        dir[dlen] = '\0';
        size_t nlen = strnlen(slash + 1, PATH_MAX - 1);
        if (nlen >= sizeof(name)) return 0;
        memcpy(name, slash + 1, nlen + 1);
    } else {
        snprintf(dir, sizeof(dir), "%s", ".");
        size_t nlen = strnlen(path, PATH_MAX - 1);
        if (nlen >= sizeof(name)) return 0;
        memcpy(name, path, nlen + 1);
    }
    if (snprintf(tmpl, sizeof(tmpl), "%s/.gen-%s-XXXXXX", dir, name) >= (int)sizeof(tmpl)) return 0;
    int fd = mkstemp(tmpl);
    if (fd == -1) return 0;
    fchmod(fd, 0644);
    const char *p = content;
    size_t left = content_len;
    while (left > 0) {
        size_t chunk = left > 65536 ? 65536 : left;
        ssize_t w = write(fd, p, chunk);
        if (w == -1) {
            if (errno == EINTR) continue;
            close(fd);
            unlink(tmpl);
            return 0;
        }
        p += w;
        left -= (size_t)w;
    }
    if (fsync(fd) == -1) {
        close(fd);
        unlink(tmpl);
        return 0;
    }
    if (close(fd) == -1) {
        unlink(tmpl);
        return 0;
    }
    if (rename(tmpl, path) == -1) {
        unlink(tmpl);
        return 0;
    }
    return 1;
}

static char *make_temp_dir(const char *prefix) {
    char tmpl[PATH_MAX];
    if (snprintf(tmpl, sizeof(tmpl), "/tmp/%s-XXXXXX", prefix) >= (int)sizeof(tmpl)) return NULL;
    char *buf = strdup(tmpl);
    if (!buf) return NULL;
    if (!mkdtemp(buf)) { free(buf); return NULL; }
    return buf;
}

static void create_test_files(const char *dir, int count, size_t size_each, int with_newlines) {
    for (int i = 0; i < count; ++i) {
        char path[PATH_MAX];
        snprintf(path, sizeof(path), "%s/file_%d.txt", dir, i);
        char *content = (char*)malloc(size_each + size_each / 64 + 2);
        if (!content) continue;
        size_t idx = 0;
        for (size_t j = 0; j < size_each; ++j) {
            char c = (char)('a' + ((i + j) % 26));
            content[idx++] = c;
            if (with_newlines && j % 64 == 63) content[idx++] = '\n';
        }
        write_file_atomic(path, content, idx);
        free(content);
    }
}

static void create_symlink_safe(const char *target, const char *linkpath) {
    unlink(linkpath);
    symlink(target, linkpath);
}

int main(void) {
    // Allocate stats buffer large enough for tests
    FileStats stats[1024];
    size_t out_count = 0;

    // Test 1: Basic processing
    char *d1 = make_temp_dir("cfpc1");
    mkdir_p(d1, 0700);
    create_test_files(d1, 5, 1024, 1);
    ProcessResult r1 = process_directory_concurrently(d1, 4, stats, 1024, &out_count);
    printf("Test1 processed=%d skipped=%d total=%zu\n", r1.processed, r1.skipped, out_count);
    free(d1);

    // Test 2: With symlink
    char *d2 = make_temp_dir("cfpc2");
    mkdir_p(d2, 0700);
    char realp[PATH_MAX]; snprintf(realp, sizeof(realp), "%s/real.txt", d2);
    write_file_atomic(realp, "hello\nworld\n", strlen("hello\nworld\n"));
    char lnk[PATH_MAX]; snprintf(lnk, sizeof(lnk), "%s/link.txt", d2);
    create_symlink_safe(realp, lnk);
    ProcessResult r2 = process_directory_concurrently(d2, 3, stats, 1024, &out_count);
    printf("Test2 processed=%d skipped=%d total=%zu\n", r2.processed, r2.skipped, out_count);
    free(d2);

    // Test 3: Subdirectory present
    char *d3 = make_temp_dir("cfpc3");
    mkdir_p(d3, 0700);
    char sub[PATH_MAX]; snprintf(sub, sizeof(sub), "%s/sub", d3);
    mkdir_p(sub, 0700);
    char a[PATH_MAX]; snprintf(a, sizeof(a), "%s/a.txt", d3);
    write_file_atomic(a, "xxxx", 4);
    char b[PATH_MAX]; snprintf(b, sizeof(b), "%s/b.txt", sub);
    write_file_atomic(b, "should not be seen", strlen("should not be seen"));
    ProcessResult r3 = process_directory_concurrently(d3, 2, stats, 1024, &out_count);
    printf("Test3 processed=%d skipped=%d total=%zu\n", r3.processed, r3.skipped, out_count);
    free(d3);

    // Test 4: Larger files
    char *d4 = make_temp_dir("cfpc4");
    mkdir_p(d4, 0700);
    create_test_files(d4, 3, 300000, 1);
    ProcessResult r4 = process_directory_concurrently(d4, 6, stats, 1024, &out_count);
    printf("Test4 processed=%d skipped=%d total=%zu\n", r4.processed, r4.skipped, out_count);

    // Test 5: Re-run on same dir to overwrite sidecars atomically
    ProcessResult r5 = process_directory_concurrently(d4, 4, stats, 1024, &out_count);
    printf("Test5 processed=%d skipped=%d total=%zu\n", r5.processed, r5.skipped, out_count);
    free(d4);

    // Print example sidecar path
    if (out_count > 0) {
        printf("Example sidecar: %s.out\n", stats[0].path);
    }
    return 0;
}
