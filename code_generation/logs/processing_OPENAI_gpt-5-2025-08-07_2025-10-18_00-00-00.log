#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <curl/curl.h>

typedef enum {
    JSON_NULL,
    JSON_BOOL,
    JSON_NUMBER,
    JSON_STRING,
    JSON_ARRAY,
    JSON_OBJECT
} JsonType;

struct JsonValue;

typedef struct {
    size_t len;
    size_t cap;
    struct JsonValue** items;
} JsonArray;

typedef struct {
    char* key;
    struct JsonValue* value;
} JsonPair;

typedef struct {
    size_t len;
    size_t cap;
    JsonPair* items;
} JsonObject;

typedef struct JsonValue {
    JsonType type;
    union {
        int boolean;
        double number;
        char* string;
        JsonArray array;
        JsonObject object;
    } as;
} JsonValue;

static void* xrealloc(void* p, size_t n) {
    void* r = realloc(p, n);
    return r;
}

static JsonValue* json_new_value(void) {
    JsonValue* v = (JsonValue*)calloc(1, sizeof(JsonValue));
    return v;
}

static void json_array_init(JsonArray* a) {
    a->len = 0; a->cap = 0; a->items = NULL;
}
static int json_array_push(JsonArray* a, JsonValue* v) {
    if (a->len == a->cap) {
        size_t ncap = a->cap ? a->cap * 2 : 4;
        void* np = xrealloc(a->items, ncap * sizeof(JsonValue*));
        if (!np) return 0;
        a->items = (JsonValue**)np;
        a->cap = ncap;
    }
    a->items[a->len++] = v;
    return 1;
}

static void json_object_init(JsonObject* o) {
    o->len = 0; o->cap = 0; o->items = NULL;
}
static int json_object_put(JsonObject* o, char* key, JsonValue* v) {
    if (o->len == o->cap) {
        size_t ncap = o->cap ? o->cap * 2 : 4;
        void* np = xrealloc(o->items, ncap * sizeof(JsonPair));
        if (!np) return 0;
        o->items = (JsonPair*)np;
        o->cap = ncap;
    }
    o->items[o->len].key = key;
    o->items[o->len].value = v;
    o->len++;
    return 1;
}

static void json_free(JsonValue* v) {
    if (!v) return;
    switch (v->type) {
        case JSON_STRING:
            free(v->as.string);
            break;
        case JSON_ARRAY:
            for (size_t i=0;i<v->as.array.len;i++) {
                json_free(v->as.array.items[i]);
            }
            free(v->as.array.items);
            break;
        case JSON_OBJECT:
            for (size_t i=0;i<v->as.object.len;i++) {
                free(v->as.object.items[i].key);
                json_free(v->as.object.items[i].value);
            }
            free(v->as.object.items);
            break;
        default: break;
    }
    free(v);
}

typedef struct {
    const char* s;
    size_t len;
    size_t pos;
    const char* error;
} Parser;

static void skip_ws(Parser* p) {
    while (p->pos < p->len) {
        char c = p->s[p->pos];
        if (c==' ' || c=='\n' || c=='\r' || c=='\t') p->pos++;
        else break;
    }
}

static int consume(Parser* p, char c) {
    if (p->pos < p->len && p->s[p->pos] == c) { p->pos++; return 1; }
    return 0;
}

static int match(Parser* p, const char* lit) {
    size_t start = p->pos;
    size_t i=0;
    while (lit[i]) {
        if (p->pos >= p->len || p->s[p->pos] != lit[i]) { p->pos = start; return 0; }
        p->pos++; i++;
    }
    return 1;
}

static int is_hex(char c) {
    return (c>='0' && c<='9') || (c>='a'&&c<='f') || (c>='A'&&c<='F');
}
static int hex_val(char c) {
    if (c>='0'&&c<='9') return c-'0';
    if (c>='a'&&c<='f') return 10 + (c-'a');
    if (c>='A'&&c<='F') return 10 + (c-'A');
    return -1;
}

static void append_utf8_from_codepoint(unsigned int cp, char** out, size_t* outlen, size_t* cap) {
    unsigned char buf[4];
    size_t n = 0;
    if (cp <= 0x7F) {
        buf[0] = (unsigned char)cp; n = 1;
    } else if (cp <= 0x7FF) {
        buf[0] = 0xC0 | ((cp >> 6) & 0x1F);
        buf[1] = 0x80 | (cp & 0x3F); n = 2;
    } else if (cp <= 0xFFFF) {
        buf[0] = 0xE0 | ((cp >> 12) & 0x0F);
        buf[1] = 0x80 | ((cp >> 6) & 0x3F);
        buf[2] = 0x80 | (cp & 0x3F); n = 3;
    } else {
        buf[0] = 0xF0 | ((cp >> 18) & 0x07);
        buf[1] = 0x80 | ((cp >> 12) & 0x3F);
        buf[2] = 0x80 | ((cp >> 6) & 0x3F);
        buf[3] = 0x80 | (cp & 0x3F); n = 4;
    }
    if (*outlen + n + 1 > *cap) {
        size_t ncap = (*cap) ? (*cap)*2 : 32;
        while (ncap < *outlen + n + 1) ncap *= 2;
        char* np = (char*)xrealloc(*out, ncap);
        if (!np) return;
        *out = np; *cap = ncap;
    }
    memcpy(*out + *outlen, buf, n);
    *outlen += n;
    (*out)[*outlen] = '\0';
}

static char* parse_string_raw(Parser* p) {
    if (!consume(p, '"')) { p->error = "Expected '\"'"; return NULL; }
    char* out = NULL;
    size_t outlen = 0, cap = 0;
    while (p->pos < p->len) {
        char c = p->s[p->pos++];
        if ((unsigned char)c < 0x20) { p->error = "Control char in string"; free(out); return NULL; }
        if (c == '"') {
            if (out == NULL) {
                out = (char*)malloc(1);
                if (!out) { p->error = "OOM"; return NULL; }
                out[0] = '\0';
            }
            return out;
        }
        if (c == '\\') {
            if (p->pos >= p->len) { p->error = "Invalid escape"; free(out); return NULL; }
            char e = p->s[p->pos++];
            switch (e) {
                case '"': case '\\': case '/': {
                    if (outlen + 2 > cap) {
                        size_t ncap = cap ? cap*2 : 32;
                        char* np = (char*)xrealloc(out, ncap);
                        if (!np) { free(out); p->error = "OOM"; return NULL; }
                        out = np; cap = ncap;
                    }
                    out[outlen++] = e;
                    out[outlen] = '\0';
                    break;
                }
                case 'b': {
                    if (outlen + 2 > cap) {
                        size_t ncap = cap ? cap*2 : 32;
                        char* np = (char*)xrealloc(out, ncap);
                        if (!np) { free(out); p->error = "OOM"; return NULL; }
                        out = np; cap = ncap;
                    }
                    out[outlen++] = '\b'; out[outlen] = '\0'; break;
                }
                case 'f': {
                    if (outlen + 2 > cap) {
                        size_t ncap = cap ? cap*2 : 32;
                        char* np = (char*)xrealloc(out, ncap);
                        if (!np) { free(out); p->error = "OOM"; return NULL; }
                        out = np; cap = ncap;
                    }
                    out[outlen++] = '\f'; out[outlen] = '\0'; break;
                }
                case 'n': {
                    if (outlen + 2 > cap) {
                        size_t ncap = cap ? cap*2 : 32;
                        char* np = (char*)xrealloc(out, ncap);
                        if (!np) { free(out); p->error = "OOM"; return NULL; }
                        out = np; cap = ncap;
                    }
                    out[outlen++] = '\n'; out[outlen] = '\0'; break;
                }
                case 'r': {
                    if (outlen + 2 > cap) {
                        size_t ncap = cap ? cap*2 : 32;
                        char* np = (char*)xrealloc(out, ncap);
                        if (!np) { free(out); p->error = "OOM"; return NULL; }
                        out = np; cap = ncap;
                    }
                    out[outlen++] = '\r'; out[outlen] = '\0'; break;
                }
                case 't': {
                    if (outlen + 2 > cap) {
                        size_t ncap = cap ? cap*2 : 32;
                        char* np = (char*)xrealloc(out, ncap);
                        if (!np) { free(out); p->error = "OOM"; return NULL; }
                        out = np; cap = ncap;
                    }
                    out[outlen++] = '\t'; out[outlen] = '\0'; break;
                }
                case 'u': {
                    if (p->pos + 4 > p->len) { p->error = "Invalid \\u"; free(out); return NULL; }
                    unsigned int code = 0;
                    for (int k=0;k<4;k++) {
                        char h = p->s[p->pos++];
                        if (!is_hex(h)) { p->error = "Invalid hex in \\u"; free(out); return NULL; }
                        code = (code<<4) | (unsigned int)hex_val(h);
                    }
                    if (code >= 0xD800 && code <= 0xDBFF) {
                        if (p->pos + 6 <= p->len && p->s[p->pos] == '\\' && p->s[p->pos+1] == 'u') {
                            p->pos += 2;
                            unsigned int low = 0;
                            for (int k=0;k<4;k++) {
                                char h = p->s[p->pos++];
                                if (!is_hex(h)) { p->error = "Invalid hex in low surrogate"; free(out); return NULL; }
                                low = (low<<4) | (unsigned int)hex_val(h);
                            }
                            if (low >= 0xDC00 && low <= 0xDFFF) {
                                unsigned int cp = 0x10000 + (((code - 0xD800) << 10) | (low - 0xDC00));
                                append_utf8_from_codepoint(cp, &out, &outlen, &cap);
                            } else { p->error = "Expected low surrogate"; free(out); return NULL; }
                        } else { p->error = "Missing low surrogate"; free(out); return NULL; }
                    } else {
                        append_utf8_from_codepoint(code, &out, &outlen, &cap);
                    }
                    break;
                }
                default:
                    p->error = "Invalid escape";
                    free(out);
                    return NULL;
            }
        } else {
            if (outlen + 2 > cap) {
                size_t ncap = cap ? cap*2 : 32;
                char* np = (char*)xrealloc(out, ncap);
                if (!np) { free(out); p->error = "OOM"; return NULL; }
                out = np; cap = ncap;
            }
            out[outlen++] = c;
            out[outlen] = '\0';
        }
    }
    p->error = "Unterminated string";
    free(out);
    return NULL;
}

static int parse_number_raw(Parser* p, double* out) {
    size_t start = p->pos;
    if (p->pos < p->len && p->s[p->pos] == '-') p->pos++;
    if (p->pos < p->len && p->s[p->pos] == '0') {
        p->pos++;
    } else {
        if (p->pos >= p->len || !isdigit((unsigned char)p->s[p->pos])) { p->error = "Invalid number"; return 0; }
        while (p->pos < p->len && isdigit((unsigned char)p->s[p->pos])) p->pos++;
    }
    if (p->pos < p->len && p->s[p->pos] == '.') {
        p->pos++;
        if (p->pos >= p->len || !isdigit((unsigned char)p->s[p->pos])) { p->error = "Invalid fraction"; return 0; }
        while (p->pos < p->len && isdigit((unsigned char)p->s[p->pos])) p->pos++;
    }
    if (p->pos < p->len && (p->s[p->pos] == 'e' || p->s[p->pos] == 'E')) {
        p->pos++;
        if (p->pos < p->len && (p->s[p->pos] == '+' || p->s[p->pos] == '-')) p->pos++;
        if (p->pos >= p->len || !isdigit((unsigned char)p->s[p->pos])) { p->error = "Invalid exponent"; return 0; }
        while (p->pos < p->len && isdigit((unsigned char)p->s[p->pos])) p->pos++;
    }
    size_t n = p->pos - start;
    if (n == 0 || n > 256) { p->error = "Invalid number length"; return 0; }
    char buf[260];
    memcpy(buf, p->s + start, n);
    buf[n] = '\0';
    char* endp = NULL;
    *out = strtod(buf, &endp);
    if (endp == buf) { p->error = "Failed to parse number"; return 0; }
    return 1;
}

static JsonValue* parse_value(Parser* p);

static JsonValue* parse_array(Parser* p) {
    if (!consume(p, '[')) { p->error = "Expected '['"; return NULL; }
    JsonValue* v = json_new_value();
    if (!v) { p->error = "OOM"; return NULL; }
    v->type = JSON_ARRAY;
    json_array_init(&v->as.array);
    skip_ws(p);
    if (consume(p, ']')) return v;
    while (1) {
        skip_ws(p);
        JsonValue* elem = parse_value(p);
        if (!elem) { json_free(v); return NULL; }
        if (!json_array_push(&v->as.array, elem)) { p->error = "OOM"; json_free(elem); json_free(v); return NULL; }
        skip_ws(p);
        if (consume(p, ']')) break;
        if (!consume(p, ',')) { p->error = "Expected ',' or ']'"; json_free(v); return NULL; }
        skip_ws(p);
    }
    return v;
}

static JsonValue* parse_object(Parser* p) {
    if (!consume(p, '{')) { p->error = "Expected '{'"; return NULL; }
    JsonValue* v = json_new_value();
    if (!v) { p->error = "OOM"; return NULL; }
    v->type = JSON_OBJECT;
    json_object_init(&v->as.object);
    skip_ws(p);
    if (consume(p, '}')) return v;
    while (1) {
        skip_ws(p);
        char* key = parse_string_raw(p);
        if (!key) { json_free(v); return NULL; }
        skip_ws(p);
        if (!consume(p, ':')) { p->error = "Expected ':'"; free(key); json_free(v); return NULL; }
        skip_ws(p);
        JsonValue* val = parse_value(p);
        if (!val) { free(key); json_free(v); return NULL; }
        if (!json_object_put(&v->as.object, key, val)) { p->error = "OOM"; free(key); json_free(val); json_free(v); return NULL; }
        skip_ws(p);
        if (consume(p, '}')) break;
        if (!consume(p, ',')) { p->error = "Expected ',' or '}'"; json_free(v); return NULL; }
        skip_ws(p);
    }
    return v;
}

static JsonValue* parse_value(Parser* p) {
    skip_ws(p);
    if (p->pos >= p->len) { p->error = "Unexpected end of input"; return NULL; }
    char c = p->s[p->pos];
    if (c == 'n') {
        if (match(p, "null")) {
            JsonValue* v = json_new_value();
            if (!v) { p->error = "OOM"; return NULL; }
            v->type = JSON_NULL;
            return v;
        }
        p->error = "Invalid token";
        return NULL;
    } else if (c == 't') {
        if (match(p, "true")) {
            JsonValue* v = json_new_value();
            if (!v) { p->error = "OOM"; return NULL; }
            v->type = JSON_BOOL; v->as.boolean = 1; return v;
        }
        p->error = "Invalid token"; return NULL;
    } else if (c == 'f') {
        if (match(p, "false")) {
            JsonValue* v = json_new_value();
            if (!v) { p->error = "OOM"; return NULL; }
            v->type = JSON_BOOL; v->as.boolean = 0; return v;
        }
        p->error = "Invalid token"; return NULL;
    } else if (c == '"') {
        char* str = parse_string_raw(p);
        if (!str) return NULL;
        JsonValue* v = json_new_value();
        if (!v) { free(str); p->error = "OOM"; return NULL; }
        v->type = JSON_STRING; v->as.string = str; return v;
    } else if (c == '[') {
        return parse_array(p);
    } else if (c == '{') {
        return parse_object(p);
    } else if (c == '-' || isdigit((unsigned char)c)) {
        double num = 0.0;
        if (!parse_number_raw(p, &num)) return NULL;
        JsonValue* v = json_new_value();
        if (!v) { p->error = "OOM"; return NULL; }
        v->type = JSON_NUMBER; v->as.number = num; return v;
    } else {
        p->error = "Unexpected character";
        return NULL;
    }
}

typedef struct {
    char* data;
    size_t len;
    size_t cap;
    size_t max;
} Buffer;

static size_t curl_write_cb(char* ptr, size_t size, size_t nmemb, void* userdata) {
    size_t bytes = size * nmemb;
    Buffer* b = (Buffer*)userdata;
    if (!b) return 0;
    if (bytes == 0) return 0;
    if (b->len + bytes > b->max) {
        return 0; // prevent excessive memory usage
    }
    if (b->len + bytes + 1 > b->cap) {
        size_t ncap = b->cap ? b->cap * 2 : 8192;
        while (ncap < b->len + bytes + 1) ncap *= 2;
        char* np = (char*)xrealloc(b->data, ncap);
        if (!np) return 0;
        b->data = np; b->cap = ncap;
    }
    memcpy(b->data + b->len, ptr, bytes);
    b->len += bytes;
    b->data[b->len] = '\0';
    return bytes;
}

static int validate_url(const char* url, char* err, size_t errsz) {
    if (!url) { snprintf(err, errsz, "%s", "URL is NULL"); return 0; }
    size_t n = strnlen(url, 4097);
    if (n == 0 || n > 2048) { snprintf(err, errsz, "%s", "URL length invalid"); return 0; }
    if (strncmp(url, "https://", 8) != 0 && strncmp(url, "http://", 7) != 0) {
        snprintf(err, errsz, "%s", "URL must start with http:// or https://");
        return 0;
    }
    return 1;
}

typedef struct {
    int ok;
    char* data;
    char error[256];
    long http_status;
} FetchResult;

static FetchResult https_get(const char* url, size_t max_bytes) {
    FetchResult r; r.ok = 0; r.data = NULL; r.error[0] = '\0'; r.http_status = 0;
    char verr[128];
    if (!validate_url(url, verr, sizeof(verr))) {
        snprintf(r.error, sizeof(r.error), "%s", verr);
        return r;
    }

    CURL* curl = curl_easy_init();
    if (!curl) { snprintf(r.error, sizeof(r.error), "%s", "Failed to init CURL"); return r; }

    Buffer buf; buf.data = NULL; buf.len = 0; buf.cap = 0; buf.max = max_bytes;
    char errbuf[CURL_ERROR_SIZE]; errbuf[0] = '\0';

    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS, CURLPROTO_HTTP | CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS, CURLPROTO_HTTP | CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, 10L);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT, 20L);
    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, 10L);
    curl_easy_setopt(curl, CURLOPT_USERAGENT, "Task64/1.0 (libcurl)");
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, curl_write_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &buf);
    curl_easy_setopt(curl, CURLOPT_ERRORBUFFER, errbuf);

    CURLcode code = curl_easy_perform(curl);
    long status = 0;
    curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &status);
    r.http_status = status;

    if (code != CURLE_OK) {
        if (code == CURLE_WRITE_ERROR && buf.len >= buf.max) {
            snprintf(r.error, sizeof(r.error), "%s", "Response exceeds maximum size");
        } else {
            const char* emsg = errbuf[0] ? errbuf : curl_easy_strerror(code);
            snprintf(r.error, sizeof(r.error), "CURL error: %s", emsg);
        }
        free(buf.data);
        curl_easy_cleanup(curl);
        return r;
    }

    if (status >= 400) {
        snprintf(r.error, sizeof(r.error), "HTTP error status %ld", status);
        free(buf.data);
        curl_easy_cleanup(curl);
        return r;
    }

    r.ok = 1;
    r.data = buf.data;
    curl_easy_cleanup(curl);
    return r;
}

static int fetch_and_parse_json(const char* url, JsonValue** out_value, char* error, size_t errsz) {
    if (!out_value) { snprintf(error, errsz, "%s", "Invalid output pointer"); return 0; }
    *out_value = NULL;
    FetchResult fr = https_get(url, 5 * 1024 * 1024);
    if (!fr.ok) {
        snprintf(error, errsz, "%s", fr.error);
        return 0;
    }
    Parser p; p.s = fr.data; p.len = strlen(fr.data); p.pos = 0; p.error = NULL;
    JsonValue* v = parse_value(&p);
    if (!v) {
        snprintf(error, errsz, "JSON parse error: %s", p.error ? p.error : "Unknown");
        free(fr.data);
        return 0;
    }
    skip_ws(&p);
    if (p.pos != p.len) {
        snprintf(error, errsz, "%s", "Trailing data after JSON");
        json_free(v);
        free(fr.data);
        return 0;
    }
    free(fr.data);
    *out_value = v;
    return 1;
}

static void print_json_summary(const JsonValue* v, int indent, int depth, int max_depth) {
    for (int i=0;i<indent;i++) printf(" ");
    switch (v->type) {
        case JSON_NULL: printf("null\n"); break;
        case JSON_BOOL: printf("bool: %s\n", v->as.boolean ? "true" : "false"); break;
        case JSON_NUMBER: printf("number: %.6g\n", v->as.number); break;
        case JSON_STRING: {
            const char* s = v->as.string ? v->as.string : "";
            printf("string: \"%.*s%s\"\n", (int)((strlen(s) > 60) ? 57 : strlen(s)), s, (strlen(s) > 60) ? "..." : "");
            break;
        }
        case JSON_ARRAY:
            printf("array size=%zu\n", v->as.array.len);
            if (depth < max_depth) {
                for (size_t i=0;i<v->as.array.len;i++) {
                    print_json_summary(v->as.array.items[i], indent+2, depth+1, max_depth);
                }
            }
            break;
        case JSON_OBJECT:
            printf("object size=%zu\n", v->as.object.len);
            if (depth < max_depth) {
                for (size_t i=0;i<v->as.object.len;i++) {
                    for (int j=0;j<indent+2;j++) printf(" ");
                    printf("\"%s\": ", v->as.object.items[i].key ? v->as.object.items[i].key : "");
                    JsonValue* val = v->as.object.items[i].value;
                    if (val) {
                        switch (val->type) {
                            case JSON_NULL: printf("null\n"); break;
                            case JSON_BOOL: printf("bool\n"); break;
                            case JSON_NUMBER: printf("number\n"); break;
                            case JSON_STRING: printf("string\n"); break;
                            case JSON_ARRAY: printf("array\n"); break;
                            case JSON_OBJECT: printf("object\n"); break;
                        }
                    } else {
                        printf("null\n");
                    }
                }
            }
            break;
    }
}

int main(int argc, char** argv) {
    curl_global_init(CURL_GLOBAL_DEFAULT);

    if (argc > 1) {
        const char* url = argv[1];
        JsonValue* v = NULL;
        char err[256];
        if (!fetch_and_parse_json(url, &v, err, sizeof(err))) {
            fprintf(stderr, "Error: %s\n", err);
            curl_global_cleanup();
            return 1;
        }
        printf("Successfully parsed JSON from %s\n", url);
        print_json_summary(v, 0, 0, 2);
        json_free(v);
        curl_global_cleanup();
        return 0;
    }

    const char* tests[5] = {
        "https://jsonplaceholder.typicode.com/todos/1",
        "https://httpbin.org/json",
        "https://api.github.com",
        "https://example.com",
        "notaurl"
    };
    for (int i=0;i<5;i++) {
        printf("Test URL: %s\n", tests[i]);
        JsonValue* v = NULL;
        char err[256];
        if (fetch_and_parse_json(tests[i], &v, err, sizeof(err))) {
            printf("OK\n");
            print_json_summary(v, 0, 0, 2);
            json_free(v);
        } else {
            printf("Failed: %s\n", err);
        }
        printf("-------------------------\n");
    }

    curl_global_cleanup();
    return 0;
}
