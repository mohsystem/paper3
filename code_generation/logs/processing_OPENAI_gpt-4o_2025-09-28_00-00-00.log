```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sqlite3.h>

typedef struct {
    int id;
    char username[50];
    char name[100];
    char email[100];
} Customer;

Customer* getCustomerInformation(const char* customerUsername) {
    sqlite3* db;
    sqlite3_stmt* stmt;
    Customer* customer = NULL;

    if (sqlite3_open("yourdatabase.db", &db) == SQLITE_OK) {
        const char* query = "SELECT * FROM customer WHERE customerusername = ?";
        
        if (sqlite3_prepare_v2(db, query, -1, &stmt, NULL) == SQLITE_OK) {
            sqlite3_bind_text(stmt, 1, customerUsername, -1, SQLITE_STATIC);
            
            if (sqlite3_step(stmt) == SQLITE_ROW) {
                customer = (Customer*)malloc(sizeof(Customer));
                if (customer) {
                    customer->id = sqlite3_column_int(stmt, 0);
                    strncpy(customer->username, (const char*)sqlite3_column_text(stmt, 1), sizeof(customer->username) - 1);
                    strncpy(customer->name, (const char*)sqlite3_column_text(stmt, 2), sizeof(customer->name) - 1);
                    strncpy(customer->email, (const char*)sqlite3_column_text(stmt, 3), sizeof(customer->email) - 1);
                }
            }
        }
        sqlite3_finalize(stmt);
    }
    sqlite3_close(db);
    return customer;
}

int main(int argc, char* argv[]) {
    if (argc != 2) {
        fprintf(stderr, "Please provide the customer username as a command line argument.\n");
        return 1;
    }

    const char* customerUsername = argv[1];
    Customer* customer = getCustomerInformation(customerUsername);

    if (customer) {
        printf("Customer Found: ID=%d, Username=%s, Name=%s, Email=%s\n",
               customer->id, customer->username, customer->name, customer->email);
        free(customer);
    } else {
        printf("Customer not found.\n");
    }

    return 0;
}
