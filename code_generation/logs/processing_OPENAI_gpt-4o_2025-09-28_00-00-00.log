```cpp
#include <iostream>
#include <mysql/mysql.h>

std::string getUserInfo(const std::string& username) {
    MYSQL *conn;
    MYSQL_RES *res;
    MYSQL_ROW row;
    std::string userInfo = "User not found";

    conn = mysql_init(NULL);
    if (conn == NULL) {
        std::cerr << "mysql_init() failed\n";
        return userInfo;
    }

    if (mysql_real_connect(conn, "localhost", "username", "password", "testdb", 0, NULL, 0) == NULL) {
        std::cerr << "mysql_real_connect() failed\n";
        mysql_close(conn);
        return userInfo;
    }

    std::string query = "SELECT * FROM users WHERE username = '" + username + "'";
    if (mysql_query(conn, query.c_str())) {
        std::cerr << "SELECT * error: " << mysql_error(conn) << "\n";
        mysql_close(conn);
        return userInfo;
    }

    res = mysql_store_result(conn);
    if (res) {
        if ((row = mysql_fetch_row(res)) != NULL) {
            userInfo = "ID: " + std::string(row[0]) + ", Username: " + std::string(row[1]) +
                       ", Email: " + std::string(row[2]);
        }
        mysql_free_result(res);
    }

    mysql_close(conn);
    return userInfo;
}

int main() {
    std::cout << getUserInfo("alice") << std::endl;
    std::cout << getUserInfo("bob") << std::endl;
    std::cout << getUserInfo("charlie") << std::endl;
    std::cout << getUserInfo("david") << std::endl;
    std::cout << getUserInfo("eve") << std::endl;

    return 0;
}
```
```c
#include <stdio.h>
#include <mysql/mysql.h>

char* getUserInfo(const char* username) {
    MYSQL *conn;
    MYSQL_RES *res;
    MYSQL_ROW row;
    static char userInfo[256];

    conn = mysql_init(NULL);
    if (conn == NULL) {
        fprintf(stderr, "mysql_init() failed\n");
        return "User not found";
    }

    if (mysql_real_connect(conn, "localhost", "username", "password", "testdb", 0, NULL, 0) == NULL) {
        fprintf(stderr, "mysql_real_connect() failed\n");
        mysql_close(conn);
        return "User not found";
    }

    char query[256];
    snprintf(query, sizeof(query), "SELECT * FROM users WHERE username = '%s'", username);

    if (mysql_query(conn, query)) {
        fprintf(stderr, "SELECT * error: %s\n", mysql_error(conn));
        mysql_close(conn);
        return "User not found";
    }

    res = mysql_store_result(conn);
    if (res) {
        if ((row = mysql_fetch_row(res)) != NULL) {
            snprintf(userInfo, sizeof(userInfo), "ID: %s, Username: %s, Email: %s", row[0], row[1], row[2]);
        } else {
            snprintf(userInfo, sizeof(userInfo), "User not found");
        }
        mysql_free_result(res);
    }

    mysql_close(conn);
    return userInfo;
}

int main() {
    printf("%s\n", getUserInfo("alice"));
    printf("%s\n", getUserInfo("bob"));
    printf("%s\n", getUserInfo("charlie"));
    printf("%s\n", getUserInfo("david"));
    printf("%s\n", getUserInfo("eve"));

    return 0;
}
