import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;
import javax.servlet.http.HttpSession;
import java.io.IOException;
import java.io.PrintWriter;

@WebServlet("/Task40")
public class Task40 extends HttpServlet {

    protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        HttpSession session = request.getSession(false);
        String csrfToken = (String) session.getAttribute("csrfToken");

        String submittedToken = request.getParameter("csrfToken");
        String userName = request.getParameter("userName");
        String userEmail = request.getParameter("userEmail");

        response.setContentType("text/html");
        PrintWriter out = response.getWriter();

        if (csrfToken == null || !csrfToken.equals(submittedToken)) {
            out.println("CSRF Token mismatch. Request denied.");
            return;
        }

        if (userName == null || userEmail == null) {
            out.println("Invalid input.");
            return;
        }

        // Simulate user settings update
        out.println("User settings updated successfully for " + userName);
    }

    protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        HttpSession session = request.getSession();
        String csrfToken = (String) session.getAttribute("csrfToken");

        if (csrfToken == null) {
            csrfToken = generateCSRFToken();
            session.setAttribute("csrfToken", csrfToken);
        }

        response.setContentType("text/html");
        PrintWriter out = response.getWriter();
        out.println("<form method='POST' action='Task40'>");
        out.println("Username: <input type='text' name='userName'><br>");
        out.println("Email: <input type='email' name='userEmail'><br>");
        out.println("<input type='hidden' name='csrfToken' value='" + csrfToken + "'>");
        out.println("<input type='submit' value='Update Settings'>");
        out.println("</form>");
    }

    private String generateCSRFToken() {
        return Long.toHexString(Double.doubleToLongBits(Math.random()));
    }

    public static void main(String[] args) {
        // Cannot test servlet directly, but the form and CSRF prevention logic is in place.
    }
}
