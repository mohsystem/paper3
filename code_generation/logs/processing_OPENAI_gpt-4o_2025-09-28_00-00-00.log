```cpp
#include <iostream>
#include <string>
#include <regex>
#include <cpprest/http_listener.h>

using namespace web;
using namespace web::http;
using namespace web::http::experimental::listener;

std::string escape_html(const std::string& input) {
    std::string escaped = input;
    escaped = std::regex_replace(escaped, std::regex("&"), "&amp;");
    escaped = std::regex_replace(escaped, std::regex("<"), "&lt;");
    escaped = std::regex_replace(escaped, std::regex(">"), "&gt;");
    escaped = std::regex_replace(escaped, std::regex("\""), "&quot;");
    escaped = std::regex_replace(escaped, std::regex("'"), "&#x27;");
    return escaped;
}

void handle_request(http_request request) {
    auto paths = uri::split_path(uri::decode(request.relative_uri().path()));
    if (request.method() == methods::POST) {
        request.extract_string().then([=](std::string body) {
            std::regex form_regex("userInput=([^&]*)");
            std::smatch match;
            std::string response_body;
            if (std::regex_search(body, match, form_regex)) {
                response_body = "<html><body>You entered: " + escape_html(match[1]) + "<br><a href='/'>Go Back</a></body></html>";
            }
            request.reply(status_codes::OK, response_body, "text/html");
        }).wait();
    } else {
        std::string response_body = "<html><body><form method='POST'>"
                                    "Enter something: <input type='text' name='userInput' required>"
                                    "<input type='submit' value='Submit'></form></body></html>";
        request.reply(status_codes::OK, response_body, "text/html");
    }
}

int main() {
    http_listener listener("http://localhost:8080");
    listener.support(handle_request);
    listener
        .open()
        .then([]() { std::cout << "Listening on http://localhost:8080" << std::endl; })
        .wait();
    std::string line;
    std::getline(std::cin, line);
    listener.close().wait();
    return 0;
}
