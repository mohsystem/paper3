#include <openssl/evp.h>
#include <openssl/rand.h>
#include <iostream>
#include <vector>
#include <cstring>

std::vector<unsigned char> encrypt(const std::string& data, const std::vector<unsigned char>& key, const std::vector<unsigned char>& iv) {
    EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
    if (!ctx) throw std::runtime_error("Failed to create cipher context");

    if (1 != EVP_EncryptInit_ex(ctx, EVP_aes_128_cbc(), nullptr, key.data(), iv.data()))
        throw std::runtime_error("Failed to initialize encryption");

    std::vector<unsigned char> ciphertext(data.size() + EVP_CIPHER_block_size(EVP_aes_128_cbc()));
    int len;
    if (1 != EVP_EncryptUpdate(ctx, ciphertext.data(), &len, reinterpret_cast<const unsigned char*>(data.c_str()), data.size()))
        throw std::runtime_error("Failed to encrypt data");

    int ciphertext_len = len;
    if (1 != EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len))
        throw std::runtime_error("Failed to finalize encryption");

    ciphertext_len += len;
    ciphertext.resize(ciphertext_len);

    EVP_CIPHER_CTX_free(ctx);
    return ciphertext;
}

int main() {
    // Generate a random AES key
    std::vector<unsigned char> key(16);
    if (!RAND_bytes(key.data(), key.size()))
        throw std::runtime_error("Failed to generate random key");

    // Static IV (should be unique per encryption in real-world applications)
    std::vector<unsigned char> static_iv(16);
    if (!RAND_bytes(static_iv.data(), static_iv.size()))
        throw std::runtime_error("Failed to generate random IV");

    // Test cases
    std::string test_cases[] = {
        "Hello, World!",
        "C++ encryption example",
        "AES with CBC mode",
        "Static IV test",
        "Encrypt this message"
    };

    for (const auto& test_case : test_cases) {
        auto encrypted_data = encrypt(test_case, key, static_iv);
        std::cout << "Encrypted: ";
        for (unsigned char c : encrypted_data) {
            std::cout << std::hex << (int)c;
        }
        std::cout << std::endl;
    }

    return 0;
}
