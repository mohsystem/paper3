```cpp
#include <iostream>
#include <string>
#include <sqlite3.h>

struct Customer {
    int id;
    std::string username;
    std::string name;
    std::string email;
};

Customer* getCustomerInformation(const std::string& customerUsername) {
    sqlite3* db;
    sqlite3_stmt* stmt;
    Customer* customer = nullptr;

    if (sqlite3_open("yourdatabase.db", &db) == SQLITE_OK) {
        std::string query = "SELECT * FROM customer WHERE customerusername = ?";
        
        if (sqlite3_prepare_v2(db, query.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
            sqlite3_bind_text(stmt, 1, customerUsername.c_str(), -1, SQLITE_STATIC);
            
            if (sqlite3_step(stmt) == SQLITE_ROW) {
                customer = new Customer{
                    sqlite3_column_int(stmt, 0),
                    reinterpret_cast<const char*>(sqlite3_column_text(stmt, 1)),
                    reinterpret_cast<const char*>(sqlite3_column_text(stmt, 2)),
                    reinterpret_cast<const char*>(sqlite3_column_text(stmt, 3))
                };
            }
        }
        sqlite3_finalize(stmt);
    }
    sqlite3_close(db);
    return customer;
}

int main(int argc, char* argv[]) {
    if (argc != 2) {
        std::cerr << "Please provide the customer username as a command line argument." << std::endl;
        return 1;
    }

    std::string customerUsername = argv[1];
    Customer* customer = getCustomerInformation(customerUsername);

    if (customer) {
        std::cout << "Customer Found: ID=" << customer->id
                  << ", Username=" << customer->username
                  << ", Name=" << customer->name
                  << ", Email=" << customer->email << std::endl;
        delete customer;
    } else {
        std::cout << "Customer not found." << std::endl;
    }

    return 0;
}
