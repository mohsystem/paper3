from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.backends import default_backend
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
import os
import base64

def encrypt_key(key_to_encrypt: bytes) -> str:
    # Generate AES key
    aes_key = os.urandom(32)  # 256-bit key for AES-256

    # Generate IV
    iv = os.urandom(16)  # 128-bit IV for AES-CBC

    # Initialize Cipher
    cipher = Cipher(algorithms.AES(aes_key), modes.CBC(iv), backend=default_backend())
    encryptor = cipher.encryptor()

    # Encrypt the key
    padded_key = key_to_encrypt + b'\0' * (16 - len(key_to_encrypt) % 16)
    encrypted_key = encryptor.update(padded_key) + encryptor.finalize()

    # Return Base64 encoded result
    return base64.b64encode(encrypted_key).decode('utf-8')

def main():
    key = os.urandom(32)  # Example key, 32 bytes for AES-256

    # Test cases
    for i in range(5):
        print(f"Encrypted Key {i + 1}: {encrypt_key(key)}")

if __name__ == "__main__":
    main()
