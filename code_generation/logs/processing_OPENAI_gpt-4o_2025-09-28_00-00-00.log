```c
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

void handleErrors() {
    fprintf(stderr, "An error occurred\n");
    exit(1);
}

char* encryptKey(const unsigned char* keyToEncrypt, size_t keyLen) {
    unsigned char aesKey[32];
    unsigned char iv[16];
    if (!RAND_bytes(aesKey, sizeof(aesKey)) || !RAND_bytes(iv, sizeof(iv))) {
        handleErrors();
    }

    EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
    if (!ctx) handleErrors();

    unsigned char* encryptedKey = malloc(keyLen + 16);
    if (!encryptedKey) handleErrors();

    int len, ciphertext_len;

    if (EVP_EncryptInit_ex(ctx, EVP_aes_256_cbc(), NULL, aesKey, iv) != 1) {
        handleErrors();
    }

    if (EVP_EncryptUpdate(ctx, encryptedKey, &len, keyToEncrypt, keyLen) != 1) {
        handleErrors();
    }
    ciphertext_len = len;

    if (EVP_EncryptFinal_ex(ctx, encryptedKey + len, &len) != 1) {
        handleErrors();
    }
    ciphertext_len += len;

    char* base64 = malloc((4 * ((ciphertext_len + 2) / 3)) + 1);
    if (!base64) handleErrors();

    EVP_EncodeBlock((unsigned char*)base64, encryptedKey, ciphertext_len);

    EVP_CIPHER_CTX_free(ctx);
    free(encryptedKey);

    return base64;
}

int main() {
    unsigned char key[32];
    if (!RAND_bytes(key, sizeof(key))) {
        fprintf(stderr, "Failed to generate key\n");
        return 1;
    }

    for (int i = 0; i < 5; ++i) {
        char* encrypted = encryptKey(key, sizeof(key));
        printf("Encrypted Key %d: %s\n", i + 1, encrypted);
        free(encrypted);
    }

    return 0;
}
