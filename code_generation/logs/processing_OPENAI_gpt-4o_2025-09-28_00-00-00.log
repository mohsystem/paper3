    cursor = connection.cursor()
    
    try:
        cursor.execute("SELECT * FROM customer WHERE customerusername = ?", (customer_username,))
        customer = cursor.fetchone()
        return customer
    finally:
        connection.close()

def main():
    if len(sys.argv) != 2:
        print("Please provide the customer username as a command line argument.")
        return

    customer_username = sys.argv[1]
    customer = get_customer_information(customer_username)
    
