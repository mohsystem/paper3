```c
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

unsigned char* encrypt(const char* data, const unsigned char* key, const unsigned char* iv, int* out_len) {
    EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
    if (!ctx) return NULL;

    if (1 != EVP_EncryptInit_ex(ctx, EVP_aes_128_cbc(), NULL, key, iv)) {
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    int data_len = strlen(data);
    int ciphertext_len;
    unsigned char* ciphertext = malloc(data_len + EVP_CIPHER_block_size(EVP_aes_128_cbc()));
    if (!ciphertext) {
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    int len;
    if (1 != EVP_EncryptUpdate(ctx, ciphertext, &len, (unsigned char*)data, data_len)) {
        EVP_CIPHER_CTX_free(ctx);
        free(ciphertext);
        return NULL;
    }
    ciphertext_len = len;

    if (1 != EVP_EncryptFinal_ex(ctx, ciphertext + len, &len)) {
        EVP_CIPHER_CTX_free(ctx);
        free(ciphertext);
        return NULL;
    }
    ciphertext_len += len;
    EVP_CIPHER_CTX_free(ctx);

    *out_len = ciphertext_len;
    return ciphertext;
}

int main() {
    // Generate a random AES key
    unsigned char key[16];
    if (!RAND_bytes(key, sizeof(key))) {
        fprintf(stderr, "Failed to generate random key\n");
        return 1;
    }

    // Static IV (should be unique per encryption in real-world applications)
    unsigned char static_iv[16];
    if (!RAND_bytes(static_iv, sizeof(static_iv))) {
        fprintf(stderr, "Failed to generate random IV\n");
        return 1;
    }

    // Test cases
    const char* test_cases[] = {
        "Hello, World!",
        "C encryption example",
        "AES with CBC mode",
        "Static IV test",
        "Encrypt this message"
    };

    for (int i = 0; i < 5; i++) {
        int out_len;
        unsigned char* encrypted_data = encrypt(test_cases[i], key, static_iv, &out_len);
        if (encrypted_data) {
            printf("Encrypted: ");
            for (int j = 0; j < out_len; j++) {
                printf("%02x", encrypted_data[j]);
            }
            printf("\n");
            free(encrypted_data);
        } else {
            fprintf(stderr, "Encryption failed for test case %d\n", i);
        }
    }

    return 0;
}
