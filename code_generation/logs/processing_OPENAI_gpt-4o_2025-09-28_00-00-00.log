import javax.crypto.Cipher;
import javax.crypto.KeyGenerator;
import javax.crypto.SecretKey;
import javax.crypto.spec.IvParameterSpec;
import java.security.SecureRandom;
import java.util.Base64;

public class Task83 {
    private static final int AES_KEY_SIZE = 256;
    private static final int IV_SIZE = 16;

    public static String encryptKey(byte[] keyToEncrypt) throws Exception {
        // Generate AES key
        KeyGenerator keyGen = KeyGenerator.getInstance("AES");
        keyGen.init(AES_KEY_SIZE);
        SecretKey aesKey = keyGen.generateKey();

        // Generate IV
        byte[] iv = new byte[IV_SIZE];
        SecureRandom secureRandom = new SecureRandom();
        secureRandom.nextBytes(iv);
        IvParameterSpec ivSpec = new IvParameterSpec(iv);

        // Initialize Cipher
        Cipher cipher = Cipher.getInstance("AES/CBC/PKCS5Padding");
        cipher.init(Cipher.ENCRYPT_MODE, aesKey, ivSpec);

        // Encrypt the key
        byte[] encryptedKey = cipher.doFinal(keyToEncrypt);

        // Return Base64 encoded result
        return Base64.getEncoder().encodeToString(encryptedKey);
    }

    public static void main(String[] args) {
        try {
            byte[] key = new byte[32]; // Example key, 32 bytes for AES-256
            new SecureRandom().nextBytes(key);

            // Test cases
            for (int i = 0; i < 5; i++) {
                System.out.println("Encrypted Key " + (i + 1) + ": " + encryptKey(key));
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
