```cpp
#include <iostream>
#include <string>
#include <map>

std::string generateCSRFToken() {
    // In a real-world application, use a secure random token generator
    return "secure_random_token";
}

bool validateCSRFToken(const std::string& sessionToken, const std::string& submittedToken) {
    return sessionToken == submittedToken;
}

std::string handleRequest(const std::map<std::string, std::string>& requestParams, std::map<std::string, std::string>& session) {
    if (session.find("csrfToken") == session.end()) {
        session["csrfToken"] = generateCSRFToken();
    }

    std::string response;
    if (requestParams.find("csrfToken") != requestParams.end() &&
        validateCSRFToken(session["csrfToken"], requestParams.at("csrfToken"))) {
        std::string userName = requestParams.at("userName");
        std::string userEmail = requestParams.at("userEmail");

        if (!userName.empty() && !userEmail.empty()) {
            response = "User settings updated successfully for " + userName;
        } else {
            response = "Invalid input.";
        }
    } else {
        response = "CSRF Token mismatch. Request denied.";
    }
    return response;
}

int main() {
    std::map<std::string, std::string> session;
    std::map<std::string, std::string> requestParams;

    // Simulate setting CSRF token in session
    session["csrfToken"] = generateCSRFToken();

    // Test cases
    requestParams = {{"csrfToken", session["csrfToken"]}, {"userName", "Alice"}, {"userEmail", "alice@example.com"}};
    std::cout << handleRequest(requestParams, session) << std::endl;

    requestParams = {{"csrfToken", "wrong_token"}, {"userName", "Bob"}, {"userEmail", "bob@example.com"}};
    std::cout << handleRequest(requestParams, session) << std::endl;

    requestParams = {{"csrfToken", session["csrfToken"]}, {"userName", ""}, {"userEmail", "carol@example.com"}};
    std::cout << handleRequest(requestParams, session) << std::endl;

    requestParams = {{"csrfToken", session["csrfToken"]}, {"userName", "David"}, {"userEmail", ""}};
    std::cout << handleRequest(requestParams, session) << std::endl;

    requestParams = {{"csrfToken", session["csrfToken"]}, {"userName", "Eve"}, {"userEmail", "eve@example.com"}};
    std::cout << handleRequest(requestParams, session) << std::endl;

    return 0;
}
