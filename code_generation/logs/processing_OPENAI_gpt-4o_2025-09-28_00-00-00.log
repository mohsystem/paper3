```c
#include <stdio.h>
#include <string.h>

#define TOKEN_SIZE 32

void generateCSRFToken(char* token) {
    snprintf(token, TOKEN_SIZE, "secure_random_token");
}

int validateCSRFToken(const char* sessionToken, const char* submittedToken) {
    return strcmp(sessionToken, submittedToken) == 0;
}

const char* handleRequest(const char* submittedToken, const char* userName, const char* userEmail, char* sessionToken) {
    if (sessionToken[0] == '\0') {
        generateCSRFToken(sessionToken);
    }

    if (submittedToken != NULL && validateCSRFToken(sessionToken, submittedToken)) {
        if (userName != NULL && userEmail != NULL && strlen(userName) > 0 && strlen(userEmail) > 0) {
            return "User settings updated successfully.";
        } else {
            return "Invalid input.";
        }
    } else {
        return "CSRF Token mismatch. Request denied.";
    }
}

int main() {
    char sessionToken[TOKEN_SIZE] = "";

    // Simulate setting CSRF token in session
    generateCSRFToken(sessionToken);

    // Test cases
    printf("%s\n", handleRequest("secure_random_token", "Alice", "alice@example.com", sessionToken));
    printf("%s\n", handleRequest("wrong_token", "Bob", "bob@example.com", sessionToken));
    printf("%s\n", handleRequest("secure_random_token", "", "carol@example.com", sessionToken));
    printf("%s\n", handleRequest("secure_random_token", "David", "", sessionToken));
    printf("%s\n", handleRequest("secure_random_token", "Eve", "eve@example.com", sessionToken));

    return 0;
}
