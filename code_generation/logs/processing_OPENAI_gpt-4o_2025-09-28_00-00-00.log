#include <openssl/evp.h>
#include <openssl/rand.h>
#include <iostream>
#include <vector>
#include <iomanip>
#include <cstring>
#include <stdexcept>

std::string encryptKey(const std::vector<unsigned char>& keyToEncrypt) {
    // Generate AES key
    unsigned char aesKey[32];
    if (!RAND_bytes(aesKey, sizeof(aesKey))) {
        throw std::runtime_error("Error generating AES key");
    }

    // Generate IV
    unsigned char iv[16];
    if (!RAND_bytes(iv, sizeof(iv))) {
        throw std::runtime_error("Error generating IV");
    }

    // Initialize context
    EVP_CIPHER_CTX *ctx = EVP_CIPHER_CTX_new();
    if (!ctx) {
        throw std::runtime_error("Error creating context");
    }

    std::vector<unsigned char> encryptedKey(keyToEncrypt.size() + 16);
    int len;

    try {
        // Initialize Cipher
        if (EVP_EncryptInit_ex(ctx, EVP_aes_256_cbc(), NULL, aesKey, iv) != 1) {
            throw std::runtime_error("Error initializing cipher");
        }

        // Encrypt the key
        if (EVP_EncryptUpdate(ctx, encryptedKey.data(), &len, keyToEncrypt.data(), keyToEncrypt.size()) != 1) {
            throw std::runtime_error("Error during encryption");
        }
        int ciphertext_len = len;

        if (EVP_EncryptFinal_ex(ctx, encryptedKey.data() + len, &len) != 1) {
            throw std::runtime_error("Error finalizing encryption");
        }
        ciphertext_len += len;

        encryptedKey.resize(ciphertext_len);
    } catch (...) {
        EVP_CIPHER_CTX_free(ctx);
        throw;
    }

    EVP_CIPHER_CTX_free(ctx);

    // Convert to Base64
    std::string base64;
    base64.resize(EVP_ENCODE_LENGTH(encryptedKey.size()));
    int base64_len = EVP_EncodeBlock(reinterpret_cast<unsigned char*>(&base64[0]), encryptedKey.data(), encryptedKey.size());

    return base64;
}

int main() {
    std::vector<unsigned char> key(32); // Example key, 32 bytes for AES-256
    RAND_bytes(key.data(), key.size());

    // Test cases
    try {
        for (int i = 0; i < 5; ++i) {
            std::cout << "Encrypted Key " << (i + 1) << ": " << encryptKey(key) << std::endl;
        }
    } catch (const std::exception& e) {
        std::cerr << "Encryption failed: " << e.what() << std::endl;
    }

    return 0;
}
