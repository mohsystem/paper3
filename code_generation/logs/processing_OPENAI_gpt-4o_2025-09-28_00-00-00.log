from flask import Flask, request, session, render_template_string
import secrets

app = Flask(__name__)
app.secret_key = secrets.token_hex(16)

form_template = """
<!doctype html>
<title>Update User Settings</title>
<h1>Update User Settings</h1>
<form method=post>
  <label for="userName">Username:</label><br>
  <input type="text" id="userName" name="userName"><br>
  <label for="userEmail">Email:</label><br>
  <input type="email" id="userEmail" name="userEmail"><br>
  <input type="hidden" name="csrfToken" value="{{ csrfToken }}">
  <input type="submit" value="Update Settings">
</form>
"""

@app.route('/', methods=['GET', 'POST'])
def update_settings():
    if 'csrfToken' not in session:
        session['csrfToken'] = secrets.token_hex(16)

    if request.method == 'POST':
        if session['csrfToken'] != request.form.get('csrfToken'):
            return "CSRF Token mismatch. Request denied."
        
        userName = request.form.get('userName')
        userEmail = request.form.get('userEmail')
        
        if not userName or not userEmail:
            return "Invalid input."
        
        # Simulate user settings update
        return f"User settings updated successfully for {userName}"

    return render_template_string(form_template, csrfToken=session['csrfToken'])

if __name__ == "__main__":
    app.run(debug=True)
