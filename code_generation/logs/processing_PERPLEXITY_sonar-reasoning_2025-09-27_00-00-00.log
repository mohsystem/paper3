```java
public class Task23 {
    public static long findNb(long m) {
        if (m < 0) return -1;
        
        long sqrtM = (long) Math.sqrt(m);
        if (sqrtM * sqrtM != m) return -1;
        
        // Check if sqrtM is a triangular number: sqrtM = n(n+1)/2
        // Solve: n˛ + n - 2*sqrtM = 0
        // n = (-1 + sqrt(1 + 8*sqrtM)) / 2
        
        long discriminant = 1 + 8 * sqrtM;
        if (discriminant < 0) return -1;
        
        long sqrtDisc = (long) Math.sqrt(discriminant);
        if (sqrtDisc * sqrtDisc != discriminant) return -1;
        
        if ((sqrtDisc - 1) % 2 != 0) return -1;
        
        long n = (sqrtDisc - 1) / 2;
        
        // Verify the result
        if (n > 0 && n * (n + 1) / 2 == sqrtM) {
            return n;
        }
        
        return -1;
    }
    
    public static void main(String[] args) {
        System.out.println(findNb(1071225L));
        System.out.println(findNb(91716553919377L));
        System.out.println(findNb(1L));
        System.out.println(findNb(36L));
        System.out.println(findNb(100L));
    }
}
