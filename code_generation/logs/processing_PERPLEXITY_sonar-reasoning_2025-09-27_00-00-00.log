```c
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct {
    unsigned char* data;
    size_t length;
} ByteArray;

ByteArray encrypt(const unsigned char* data, size_t data_len, const unsigned char* key) {
    const int IV_LEN = 12;
    const int TAG_LEN = 16;
    ByteArray result = {NULL, 0};
    
    unsigned char iv[IV_LEN];
    if (RAND_bytes(iv, IV_LEN) != 1) {
        return result;
    }
    
    EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
    if (!ctx) return result;
    
    if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), NULL, NULL, NULL) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        return result;
    }
    
    if (EVP_EncryptInit_ex(ctx, NULL, NULL, key, iv) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        return result;
    }
    
    unsigned char* ciphertext = malloc(data_len + TAG_LEN);
    if (!ciphertext) {
        EVP_CIPHER_CTX_free(ctx);
        return result;
    }
    
    int len;
    if (EVP_EncryptUpdate(ctx, ciphertext, &len, data, data_len) != 1) {
        free(ciphertext);
        EVP_CIPHER_CTX_free(ctx);
        return result;
    }
    
    int ciphertext_len = len;
    
    if (EVP_EncryptFinal_ex(ctx, ciphertext + len, &len) != 1) {
        free(ciphertext);
        EVP_CIPHER_CTX_free(ctx);
        return result;
    }
    
    ciphertext_len += len;
    
    unsigned char tag[TAG_LEN];
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_LEN, tag) != 1) {
        free(ciphertext);
        EVP_CIPHER_CTX_free(ctx);
        return result;
    }
    
    EVP_CIPHER_CTX_free(ctx);
    
    result.length = IV_LEN + ciphertext_len + TAG_LEN;
    result.data = malloc(result.length);
    
    if (result.data) {
        memcpy(result.data, iv, IV_LEN);
        memcpy(result.data + IV_LEN, ciphertext, ciphertext_len);
        memcpy(result.data + IV_LEN + ciphertext_len, tag, TAG_LEN);
    }
    
    free(ciphertext);
    return result;
}

int main() {
    unsigned char key[32];
    if (RAND_bytes(key, 32) != 1) {
        fprintf(stderr, "Failed to generate key\n");
        return 1;
    }
    
    const char* test_cases[] = {
        "Hello World",
        "Test message 123",
        "AES GCM encryption test",
        "Short", 
        "This is a longer test message with multiple words and punctuation!"
    };
    
    for (int i = 0; i < 5; i++) {
        ByteArray encrypted = encrypt((const unsigned char*)test_cases[i], strlen(test_cases[i]), key);
        if (encrypted.data) {
            printf("Encrypted length: %zu\n", encrypted.length);
            free(encrypted.data);
        }
    }
    
    return 0;
}
