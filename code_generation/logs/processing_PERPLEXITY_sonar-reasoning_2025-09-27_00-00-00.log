```python
def count_people_on_bus(bus_stops: list) -> int:
    if not bus_stops or not isinstance(bus_stops, list):
        return 0
    
    people_on_bus = 0
    for stop in bus_stops:
        if not isinstance(stop, (list, tuple)) or len(stop) != 2:
            continue
        
        get_on, get_off = stop[0], stop[1]
        
        if not isinstance(get_on, int) or not isinstance(get_off, int):
            continue
        if get_on < 0 or get_off < 0:
            continue
            
        people_on_bus += get_on - get_off
        
        if people_on_bus < 0:
            people_on_bus = 0
    
    return people_on_bus

def main():
    test1 = [[10, 0], [3, 5], [5, 8]]
    print(f"Test 1: {count_people_on_bus(test1)}")
    
    test2 = [[3, 0], [9, 1], [4, 10], [12, 2], [6, 1], [7, 10]]
    print(f"Test 2: {count_people_on_bus(test2)}")
    
    test3 = [[3, 0], [9, 1], [4, 8], [12, 2], [6, 1], [7, 8]]
    print(f"Test 3: {count_people_on_bus(test3)}")
    
    test4 = []
    print(f"Test 4: {count_people_on_bus(test4)}")
    
    test5 = [[5, 0]]
    print(f"Test 5: {count_people_on_bus(test5)}")

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <vector>

int countPeopleOnBus(const std::vector<std::vector<int>>& busStops) {
    if (busStops.empty()) {
        return 0;
    }
    
    int peopleOnBus = 0;
    for (const auto& stop : busStops) {
        if (stop.size() != 2) {
            continue;
        }
        
        int getOn = stop[0];
        int getOff = stop[1];
        
        if (getOn < 0 || getOff < 0) {
            continue;
        }
        
        peopleOnBus += getOn - getOff;
        
        if (peopleOnBus < 0) {
            peopleOnBus = 0;
        }
    }
    return peopleOnBus;
}

int main() {
    std::vector<std::vector<int>> test1 = {{10, 0}, {3, 5}, {5, 8}};
    std::cout << "Test 1: " << countPeopleOnBus(test1) << std::endl;
    
    std::vector<std::vector<int>> test2 = {{3, 0}, {9, 1}, {4, 10}, {12, 2}, {6, 1}, {7, 10}};
    std::cout << "Test 2: " << countPeopleOnBus(test2) << std::endl;
    
    std::vector<std::vector<int>> test3 = {{3, 0}, {9, 1}, {4, 8}, {12, 2}, {6, 1}, {7, 8}};
    std::cout << "Test 3: " << countPeopleOnBus(test3) << std::endl;
    
    std::vector<std::vector<int>> test4 = {};
    std::cout << "Test 4: " << countPeopleOnBus(test4) << std::endl;
    
    std::vector<std::vector<int>> test5 = {{5, 0}};
    std::cout << "Test 5: " << countPeopleOnBus(test5) << std::endl;
    
    return 0;
}
```

```c
#include <stdio.h>

int countPeopleOnBus(int busStops[][2], int numStops) {
    if (busStops == NULL || numStops <= 0) {
        return 0;
    }
    
    int peopleOnBus = 0;
    for (int i = 0; i < numStops; i++) {
        int getOn = busStops[i][0];
        int getOff = busStops[i][1];
        
        if (getOn < 0 || getOff < 0) {
            continue;
        }
        
        peopleOnBus += getOn - getOff;
        
        if (peopleOnBus < 0) {
            peopleOnBus = 0;
        }
    }
    return peopleOnBus;
}

int main() {
    int test1[][2] = {{10, 0}, {3, 5}, {5, 8}};
    printf("Test 1: %d\n", countPeopleOnBus(test1, 3));
    
    int test2[][2] = {{3, 0}, {9, 1}, {4, 10}, {12, 2}, {6, 1}, {7, 10}};
    printf("Test 2: %d\n", countPeopleOnBus(test2, 6));
    
    int test3[][2] = {{3, 0}, {9, 1}, {4, 8}, {12, 2}, {6, 1}, {7, 8}};
    printf("Test 3: %d\n", countPeopleOnBus(test3, 6));
    
    printf("Test 4: %d\n", countPeopleOnBus(NULL, 0));
    
    int test5[][2] = {{5, 0}};
    printf("Test 5: %d\n", countPeopleOnBus(test5, 1));
    
    return 0;
}
```
