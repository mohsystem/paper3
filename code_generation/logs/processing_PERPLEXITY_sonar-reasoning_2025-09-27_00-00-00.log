```python
def is_valid_walk(walk):
    if walk is None or len(walk) != 10:
        return False
    
    x, y = 0, 0
    
    for direction in walk:
        if not isinstance(direction, str) or len(direction) != 1:
            return False
        
        if direction == 'n':
            y += 1
        elif direction == 's':
            y -= 1
        elif direction == 'e':
            x += 1
        elif direction == 'w':
            x -= 1
        else:
            return False
    
    return x == 0 and y == 0

def main():
    tests = [
        ['n', 's', 'n', 's', 'n', 's', 'n', 's', 'n', 's'],
        ['e', 'w', 'e', 'w', 'n', 's', 'n', 's', 'e', 'w'],
        ['n', 'n', 'n', 's', 'n', 's', 'n', 's', 'n', 's'],
        ['e', 'e', 'w', 'n', 'n', 's', 'n', 's', 'e', 'w'],
        ['n', 's', 'e', 'w', 'n', 's', 'e', 'w', 'n', 's']
    ]
    
    for i, test in enumerate(tests, 1):
        print(f"Test {i}: {is_valid_walk(test)}")

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <vector>
#include <string>

bool isValidWalk(const std::vector<std::string>& walk) {
    if (walk.size() != 10) {
        return false;
    }
    
    int x = 0, y = 0;
    
    for (const std::string& direction : walk) {
        if (direction.length() != 1) {
            return false;
        }
        
        char dir = direction[0];
        switch (dir) {
            case 'n': y++; break;
            case 's': y--; break;
            case 'e': x++; break;
            case 'w': x--; break;
            default: return false;
        }
    }
    
    return x == 0 && y == 0;
}

int main() {
    std::vector<std::vector<std::string>> tests = {
        {"n", "s", "n", "s", "n", "s", "n", "s", "n", "s"},
        {"e", "w", "e", "w", "n", "s", "n", "s", "e", "w"},
        {"n", "n", "n", "s", "n", "s", "n", "s", "n", "s"},
        {"e", "e", "w", "n", "n", "s", "n", "s", "e", "w"},
        {"n", "s", "e", "w", "n", "s", "e", "w", "n", "s"}
    };
    
    for (size_t i = 0; i < tests.size(); i++) {
        std::cout << "Test " << (i + 1) << ": " << (isValidWalk(tests[i]) ? "true" : "false") << std::endl;
    }
    
    return 0;
}
