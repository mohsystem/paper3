```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char** buildTower(int nFloors, int* returnSize) {
    if (nFloors <= 0 || returnSize == NULL) {
        if (returnSize) *returnSize = 0;
        return NULL;
    }
    
    char** tower = (char**)malloc(nFloors * sizeof(char*));
    if (tower == NULL) {
        *returnSize = 0;
        return NULL;
    }
    
    int totalWidth = 2 * nFloors - 1;
    
    for (int floor = 1; floor <= nFloors; floor++) {
        int spaces = nFloors - floor;
        int stars = 2 * floor - 1;
        
        tower[floor - 1] = (char*)malloc((totalWidth + 1) * sizeof(char));
        if (tower[floor - 1] == NULL) {
            for (int i = 0; i < floor - 1; i++) {
                free(tower[i]);
            }
            free(tower);
            *returnSize = 0;
            return NULL;
        }
        
        int pos = 0;
        for (int i = 0; i < spaces; i++) {
            tower[floor - 1][pos++] = ' ';
        }
        for (int i = 0; i < stars; i++) {
            tower[floor - 1][pos++] = '*';
        }
        for (int i = 0; i < spaces; i++) {
            tower[floor - 1][pos++] = ' ';
        }
        tower[floor - 1][pos] = '\0';
    }
    
    *returnSize = nFloors;
    return tower;
}

void freeTower(char** tower, int size) {
    if (tower == NULL) return;
    for (int i = 0; i < size; i++) {
        free(tower[i]);
    }
    free(tower);
}

void printTower(char** tower, int size) {
    for (int i = 0; i < size; i++) {
        printf("\"%s\"\n", tower[i]);
    }
}

int main() {
    int size;
    
    // Test case 1
    char** tower1 = buildTower(1, &size);
    printf("Tower 1:\n");
    printTower(tower1, size);
    freeTower(tower1, size);
    
    // Test case 2
    char** tower2 = buildTower(3, &size);
    printf("\nTower 3:\n");
    printTower(tower2, size);
    freeTower(tower2, size);
    
    // Test case 3
    char** tower3 = buildTower(6, &size);
    printf("\nTower 6:\n");
    printTower(tower3, size);
    freeTower(tower3, size);
    
    // Test case 4
    char** tower4 = buildTower(4, &size);
    printf("\nTower 4:\n");
    printTower(tower4, size);
    freeTower(tower4, size);
    
    // Test case 5
    char** tower5 = buildTower(8, &size);
    printf("\nTower 8:\n");
    printTower(tower5, size);
    freeTower(tower5, size);
    
    return 0;
}
