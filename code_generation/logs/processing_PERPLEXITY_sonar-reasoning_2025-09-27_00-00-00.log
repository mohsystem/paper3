```java
import java.nio.charset.StandardCharsets;
import java.util.HashSet;
import java.util.Set;

public class Task3 {
    public static boolean isPangram(String sentence) {
        if (sentence == null) {
            return false;
        }
        
        if (sentence.length() > 10000) {
            return false; // Prevent excessive memory usage
        }
        
        Set<Character> seenLetters = new HashSet<>();
        String lowerSentence = sentence.toLowerCase();
        
        for (int i = 0; i < lowerSentence.length(); i++) {
            char c = lowerSentence.charAt(i);
            if (c >= 'a' && c <= 'z') {
                seenLetters.add(c);
                if (seenLetters.size() == 26) {
                    return true;
                }
            }
        }
        
        return seenLetters.size() == 26;
    }
    
    public static void main(String[] args) {
        // Test cases
        System.out.println(isPangram("The quick brown fox jumps over the lazy dog")); // true
        System.out.println(isPangram("Hello world")); // false
        System.out.println(isPangram("ABCDEFGHIJKLMNOPQRSTUVWXYZ")); // true
        System.out.println(isPangram("Pack my box with five dozen liquor jugs")); // true
        System.out.println(isPangram("")); // false
    }
}
```

```python
def is_pangram(sentence: str) -> bool:
    if sentence is None:
        return False
    
    if len(sentence) > 10000:
        return False  # Prevent excessive memory usage
    
    seen_letters = set()
    lower_sentence = sentence.lower()
    
    for char in lower_sentence:
        if 'a' <= char <= 'z':
            seen_letters.add(char)
            if len(seen_letters) == 26:
                return True
    
    return len(seen_letters) == 26

def main():
    # Test cases
    print(is_pangram("The quick brown fox jumps over the lazy dog"))  # True
    print(is_pangram("Hello world"))  # False
    print(is_pangram("ABCDEFGHIJKLMNOPQRSTUVWXYZ"))  # True
    print(is_pangram("Pack my box with five dozen liquor jugs"))  # True
    print(is_pangram(""))  # False

if __name__ == "__main__":
    main()
