```java
public class Task11 {
    public static int nb_year(int p0, double percent, int aug, int p) {
        if (p0 <= 0 || percent < 0 || p <= 0) {
            throw new IllegalArgumentException("Invalid input parameters");
        }
        
        int population = p0;
        int years = 0;
        
        while (population < p) {
            population = (int)(population + population * (percent / 100.0) + aug);
            years++;
        }
        
        return years;
    }
    
    public static void main(String[] args) {
        System.out.println(nb_year(1000, 2, 50, 1200));
        System.out.println(nb_year(1500, 5, 100, 5000));
        System.out.println(nb_year(1500000, 2.5, 10000, 2000000));
        System.out.println(nb_year(1000, 0, 100, 1500));
        System.out.println(nb_year(2000, 1, 0, 2100));
    }
}
```

```python
def nb_year(p0: int, percent: float, aug: int, p: int) -> int:
    if p0 <= 0 or percent < 0 or p <= 0:
        raise ValueError("Invalid input parameters")
    
    population = p0
    years = 0
    
    while population < p:
        population = int(population + population * (percent / 100.0) + aug)
        years += 1
    
    return years

if __name__ == "__main__":
    print(nb_year(1000, 2, 50, 1200))
    print(nb_year(1500, 5, 100, 5000))
    print(nb_year(1500000, 2.5, 10000, 2000000))
    print(nb_year(1000, 0, 100, 1500))
    print(nb_year(2000, 1, 0, 2100))
```

```cpp
#include <iostream>
#include <stdexcept>

int nb_year(int p0, double percent, int aug, int p) {
    if (p0 <= 0 || percent < 0 || p <= 0) {
        throw std::invalid_argument("Invalid input parameters");
    }
    
    int population = p0;
    int years = 0;
    
    while (population < p) {
        population = static_cast<int>(population + population * (percent / 100.0) + aug);
        years++;
    }
    
    return years;
}

int main() {
    std::cout << nb_year(1000, 2, 50, 1200) << std::endl;
    std::cout << nb_year(1500, 5, 100, 5000) << std::endl;
    std::cout << nb_year(1500000, 2.5, 10000, 2000000) << std::endl;
    std::cout << nb_year(1000, 0, 100, 1500) << std::endl;
    std::cout << nb_year(2000, 1, 0, 2100) << std::endl;
    return 0;
}
```

```c
#include <stdio.h>

int nb_year(int p0, double percent, int aug, int p) {
    if (p0 <= 0 || percent < 0 || p <= 0) {
        return -1;
    }
    
    int population = p0;
    int years = 0;
    
    while (population < p) {
        population = (int)(population + population * (percent / 100.0) + aug);
        years++;
    }
    
    return years;
}

int main() {
    printf("%d\n", nb_year(1000, 2, 50, 1200));
    printf("%d\n", nb_year(1500, 5, 100, 5000));
    printf("%d\n", nb_year(1500000, 2.5, 10000, 2000000));
    printf("%d\n", nb_year(1000, 0, 100, 1500));
    printf("%d\n", nb_year(2000, 1, 0, 2100));
    return 0;
}
```
