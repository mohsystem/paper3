public class Task13 {
    public static boolean isValidWalk(String[] walk) {
        if (walk == null || walk.length != 10) {
            return false;
        }
        
        int x = 0, y = 0;
        
        for (String direction : walk) {
            if (direction == null || direction.length() != 1) {
                return false;
            }
            
            char dir = direction.charAt(0);
            switch (dir) {
                case 'n': y++; break;
                case 's': y--; break;
                case 'e': x++; break;
                case 'w': x--; break;
                default: return false;
            }
        }
        
        return x == 0 && y == 0;
    }
    
