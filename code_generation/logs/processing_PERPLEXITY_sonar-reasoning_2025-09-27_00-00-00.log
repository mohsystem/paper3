#include <stdio.h>
#include <stdlib.h>

double findUniq(const double* arr, size_t size) {
    if (arr == NULL || size < 3) {
        fprintf(stderr, "Error: Array must not be NULL and have at least 3 elements\n");
        exit(EXIT_FAILURE);
    }
    
    // Compare first three elements to determine which is the unique one
    if (arr == arr[1]) {
        // arr and arr[1] are the same, so find the different one
        for (size_t i = 2; i < size; i++) {
            if (arr[i] != arr) {
                return arr[i];
            }
        }
    } else {
        // arr and arr[1] are different, check which one matches arr[2]
        if (arr == arr[2]) {
            return arr[1];
        } else {
            return arr;
        }
