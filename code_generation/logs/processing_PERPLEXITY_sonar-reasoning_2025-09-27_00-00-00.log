import socket
import hashlib
import secrets
import base64
import os
from typing import Optional
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
import hmac

class ChatClient:
    def send_login_request(self, username: str, password: str, server_host: str = 'localhost', port: int = 8080) -> str:
        if not username or not password or len(username) > 50 or len(password) > 100:
            return "INVALID_INPUT"
        
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
                sock.connect((server_host, port))
                message = f"LOGIN:{username}:{password}"
                sock.sendall(message.encode('utf-8'))
                response = sock.recv(1024).decode('utf-8')
                return response
        except Exception:
            return "CONNECTION_ERROR"

class ChatServer:
    def __init__(self):
        self.credentials_file = "credentials.txt"
        self.salt_length = 16
        self.iterations = 210000
    
    def authenticate_user(self, username: str, password: str) -> str:
        if not username or not password or len(username) > 50 or len(password) > 100:
            return "INVALID_INPUT"
        
        try:
            if not os.path.exists(self.credentials_file):
                return "USER_NOT_FOUND"
                
            with open(self.credentials_file, 'r', encoding='utf-8') as f:
                for line in f:
                    parts = line.strip().split(':', 2)
                    if len(parts) == 3 and parts[0] == username:
                        stored_salt = base64.b64decode(parts[1])
                        stored_hash = parts[2]
                        
                        computed_hash = self._hash_password(password, stored_salt)
                        
                        if self._constant_time_compare(stored_hash, computed_hash):
                            return "AUTH_SUCCESS"
                        else:
                            return "AUTH_FAILED"
        except Exception:
            return "SERVER_ERROR"
        
        return "USER_NOT_FOUND"
    
    def store_user(self, username: str, password: str) -> bool:
        if not username or not password or len(username) > 50 or len(password) > 100:
            return False
        
        try:
            salt = secrets.token_bytes(self.salt_length)
            hashed_password = self._hash_password(password, salt)
            salt_base64 = base64.b64encode(salt).decode('utf-8')
            
            with open(self.credentials_file, 'a', encoding='utf-8') as f:
                f.write(f"{username}:{salt_base64}:{hashed_password}\n")
            return True
        except Exception:
            return False
    
    def _hash_password(self, password: str, salt: bytes) -> str:
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=self.iterations,
        )
        key = kdf.derive(password.encode('utf-8'))
        return base64.b64encode(key).decode('utf-8')
    
    def _constant_time_compare(self, a: str, b: str) -> bool:
        if not a or not b:
            return False
        return hmac.compare_digest(a.encode('utf-8'), b.encode('utf-8'))

if __name__ == "__main__":
    server = ChatServer()
    client = ChatClient()
    
    # Test Case 1: Store and authenticate valid user
    server.store_user("user1", "password123")
    result1 = server.authenticate_user("user1", "password123")
    print(f"Test 1 - Valid auth: {result1}")
    
    # Test Case 2: Invalid password
    result2 = server.authenticate_user("user1", "wrongpassword")
    print(f"Test 2 - Invalid password: {result2}")
    
    # Test Case 3: Non-existent user
    result3 = server.authenticate_user("nonexistent", "password")
    print(f"Test 3 - Non-existent user: {result3}")
    
    # Test Case 4: Invalid input (empty username)
    result4 = server.authenticate_user("", "password")
    print(f"Test 4 - Empty username: {result4}")
    
    # Test Case 5: Input validation (too long password)
    long_password = "a" * 101
    result5 = server.authenticate_user("user1", long_password)
    print(f"Test 5 - Long password: {result5}")
