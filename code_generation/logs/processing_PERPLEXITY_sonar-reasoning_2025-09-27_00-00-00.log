```c
#include <stdio.h>
#include <stdlib.h>

int* twoSum(int* nums, int numsSize, int target, int* returnSize) {
    if (nums == NULL || numsSize < 2) {
        *returnSize = 0;
        return NULL;
    }
    
    *returnSize = 2;
    int* result = (int*)malloc(2 * sizeof(int));
    if (result == NULL) {
        *returnSize = 0;
        return NULL;
    }
    
    for (int i = 0; i < numsSize - 1; i++) {
        for (int j = i + 1; j < numsSize; j++) {
            if (nums[i] + nums[j] == target) {
                result[0] = i;
                result[1] = j;
                return result;
            }
        }
    }
    
    free(result);
    *returnSize = 0;
    return NULL;
}

int main() {
    int returnSize;
    
    // Test case 1
    int nums1[] = {1, 2, 3};
    int* result1 = twoSum(nums1, 3, 4, &returnSize);
    if (result1 != NULL) {
        printf("Test 1: [%d, %d]\n", result1[0], result1[1]);
        free(result1);
    }
    
    // Test case 2
    int nums2[] = {3, 2, 4};
    int* result2 = twoSum(nums2, 3, 6, &returnSize);
    if (result2 != NULL) {
        printf("Test 2: [%d, %d]\n", result2[0], result2[1]);
        free(result2);
    }
    
    // Test case 3
    int nums3[] = {2, 7, 11, 15};
    int* result3 = twoSum(nums3, 4, 9, &returnSize);
    if (result3 != NULL) {
        printf("Test 3: [%d, %d]\n", result3[0], result3[1]);
        free(result3);
    }
    
    // Test case 4
    int nums4[] = {3, 3};
    int* result4 = twoSum(nums4, 2, 6, &returnSize);
    if (result4 != NULL) {
        printf("Test 4: [%d, %d]\n", result4[0], result4[1]);
        free(result4);
    }
    
    // Test case 5
    int nums5[] = {-1, -2, -3, -4, -5};
    int* result5 = twoSum(nums5, 5, -8, &returnSize);
    if (result5 != NULL) {
        printf("Test 5: [%d, %d]\n", result5[0], result5[1]);
        free(result5);
    }
    
    return 0;
}
