#include <iostream>
#include <vector>
#include <string>

std::string checkOddEven(const std::vector<int>& arr) {
    // Handle empty input
    if (arr.empty()) {
        return "even"; // treat as 
    }
    
    long long sum = 0; // use long long to prevent overflow
    for (int num : arr) {
        sum += num;
    }
    
    return (sum % 2 == 0) ? "even" : "odd";
}

int main() {
    // Test case 1: 
    std::cout << checkOddEven({0}) << std::endl;
    
    // Test case 2: [0, 1, 4]
    std::cout << checkOddEven({0, 1, 4}) << std::endl;
    
    // Test case 3: [0, -1, -5]
    std::cout << checkOddEven({0, -1, -5}) << std::endl;
    
    // Test case 4: empty array
    std::cout << checkOddEven({}) << std::endl;
    
    // Test case 5: single negative
    std::cout << checkOddEven({-3}) << std::endl;
    
    return 0;
}
