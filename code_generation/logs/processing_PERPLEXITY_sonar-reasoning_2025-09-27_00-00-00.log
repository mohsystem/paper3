class ChatClient {
public:
    std::string sendLoginRequest(const std::string& username, const std::string& password, 
                                const std::string& serverHost = "127.0.0.1", int port = 8080) {
        if (username.empty() || password.empty() || username.length() > 50 || password.length() > 100) {
            return "INVALID_INPUT";
        }
        
        int sock = socket(AF_INET, SOCK_STREAM, 0);
        if (sock < 0) {
            return "SOCKET_ERROR";
        }
        
        struct sockaddr_in server_addr;
        server_addr.sin_family = AF_INET;
        server_addr.sin_port = htons(port);
        inet_pton(AF_INET, serverHost.c_str(), &server_addr.sin_addr);
        
        if (connect(sock, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
            close(sock);
            return "CONNECTION_ERROR";
        }
        
        std::string message = "LOGIN:" + username + ":" + password;
        send(sock, message.c_str(), message.length(), 0);
        
        char buffer[1024] = {0};
        int bytesRead = recv(sock, buffer, sizeof(buffer) - 1, 0);
        close(sock);
        
        if (bytesRead > 0) {
            buffer[bytesRead] = '\0';
            return std::string(buffer);
        }
        return "NO_RESPONSE";
    }
};

class ChatServer {
private:
    static const int SALT_LENGTH = 16;
    static const int ITERATIONS = 210000;
    static const int KEY_LENGTH = 32;
    std::string credentialsFile = "credentials.txt";
    
    std::string base64Encode(const std::vector<unsigned char>& data) {
        const char* chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
        std::string result;
        int val = 0, valb = -6;
        for (unsigned char c : data) {
            val = (val << 8) + c;
            valb += 8;
            while (valb >= 0) {
                result.push_back(chars[(val >> valb) & 0x3F]);
                valb -= 6;
            }
        }
        if (valb > -6) result.push_back(chars[((val << 8) >> (valb + 8)) & 0x3F]);
        while (result.size() % 4) result.push_back('=');
        return result;
    }
    
    std::vector<unsigned char> base64Decode(const std::string& input) {
        std::vector<unsigned char> result;
        int val = 0, valb = -8;
        for (unsigned char c : input) {
            if (c >= 'A' && c <= 'Z') c = c - 'A';
            else if (c >= 'a' && c <= 'z') c = c - 'a' + 26;
            else if (c >= '0' && c <= '9') c = c - '0' + 52;
            else if (c == '+') c = 62;
            else if (c == '/') c = 63;
            else if (c == '=') break;
            else continue;
            
            val = (val << 6) + c;
            valb += 6;
            if (valb >= 0) {
                result.push_back(char((val >> valb) & 0xFF));
                valb -= 8;
            }
        }
        return result;
    }
    
    std::string hashPassword(const std::string& password, const std::vector<unsigned char>& salt) {
        std::vector<unsigned char> key(KEY_LENGTH);
        
        if (PKCS5_PBKDF2_HMAC(password.c_str(), password.length(),
                              salt.data(), salt.size(),
                              ITERATIONS, EVP_sha256(),
                              KEY_LENGTH, key.data()) != 1) {
            return "";
        }
        
        return base64Encode(key);
    }
    
    bool constantTimeEquals(const std::string& a, const std::string& b) {
        if (a.length() != b.length()) return false;
        
        int result = 0;
        for (size_t i = 0; i < a.length(); i++) {
            result |= a[i] ^ b[i];
        }
        return result == 0;
    }
    
public:
    std::string authenticateUser(const std::string& username, const std::string& password) {
        if (username.empty() || password.empty() || username.length() > 50 || password.length() > 100) {
            return "INVALID_INPUT";
        }
        
        std::ifstream file(credentialsFile);
        if (!file.is_open()) {
            return "USER_NOT_FOUND";
        }
        
        std::string line;
        while (std::getline(file, line)) {
            std::istringstream iss(line);
            std::string storedUser, storedSalt, storedHash;
            
            if (std::getline(iss, storedUser, ':') &&
                std::getline(iss, storedSalt, ':') &&
                std::getline(iss, storedHash)) {
                
                if (storedUser == username) {
                    std::vector<unsigned char> salt = base64Decode(storedSalt);
                    std::string computedHash = hashPassword(password, salt);
                    
                    if (constantTimeEquals(storedHash, computedHash)) {
                        return "AUTH_SUCCESS";
                    } else {
                        return "AUTH_FAILED";
                    }
                }
            }
        }
        
        return "USER_NOT_FOUND";
    }
    
    bool storeUser(const std::string& username, const std::string& password) {
        if (username.empty() || password.empty() || username.length() > 50 || password.length() > 100) {
            return false;
        }
        
        std::vector<unsigned char> salt(SALT_LENGTH);
        if (RAND_bytes(salt.data(), SALT_LENGTH) != 1) {
            return false;
        }
        
        std::string hashedPassword = hashPassword(password, salt);
        if (hashedPassword.empty()) {
            return false;
        }
        
        std::string saltBase64 = base64Encode(salt);
        
        std::ofstream file(credentialsFile, std::ios::app);
        if (!file.is_open()) {
            return false;
        }
        
        file << username << ":" << saltBase64 << ":" << hashedPassword << "\n";
        return true;
    }
};

