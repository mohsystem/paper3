```java
import java.util.*;

public class Task25 {
    public static List<String> addLineNumbers(List<String> lines) {
        if (lines == null) {
            return new ArrayList<>();
        }
        
        List<String> result = new ArrayList<>();
        for (int i = 0; i < lines.size(); i++) {
            String line = lines.get(i);
            if (line == null) {
                line = "";
            }
            result.add((i + 1) + ": " + line);
        }
        return result;
    }
    
    public static void main(String[] args) {
        // Test case 1: Empty list
        System.out.println(addLineNumbers(new ArrayList<>()));
        
        // Test case 2: Single line
        System.out.println(addLineNumbers(Arrays.asList("hello")));
        
        // Test case 3: Multiple lines
        System.out.println(addLineNumbers(Arrays.asList("a", "b", "c")));
        
        // Test case 4: Lines with spaces
        System.out.println(addLineNumbers(Arrays.asList("hello world", "foo bar")));
        
        // Test case 5: Empty strings in list
        System.out.println(addLineNumbers(Arrays.asList("", "test", "")));
    }
}
