```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef enum {
    TYPE_INT,
    TYPE_STRING
} ItemType;

typedef struct {
    ItemType type;
    union {
        int int_value;
        char* string_value;
    } data;
} Item;

typedef struct {
    int* values;
    size_t count;
    size_t capacity;
} IntList;

IntList filter_list(Item* input, size_t input_size) {
    IntList result = {0};
    result.capacity = input_size;
    result.values = malloc(result.capacity * sizeof(int));
    
    if (!result.values) {
        result.capacity = 0;
        return result;
    }
    
    for (size_t i = 0; i < input_size; i++) {
        if (input[i].type == TYPE_INT && input[i].data.int_value >= 0) {
            result.values[result.count++] = input[i].data.int_value;
        }
    }
    
    return result;
}

void free_int_list(IntList* list) {
    if (list->values) {
        free(list->values);
        list->values = NULL;
        list->count = 0;
        list->capacity = 0;
    }
}

int main() {
    // Test case 1
    Item test1[] = {
        {TYPE_INT, .data.int_value = 1},
        {TYPE_INT, .data.int_value = 2},
        {TYPE_STRING, .data.string_value = "a"},
        {TYPE_STRING, .data.string_value = "b"}
    };
    IntList result1 = filter_list(test1, 4);
    printf("Test 1: ");
    for (size_t i = 0; i < result1.count; i++) {
        printf("%d ", result1.values[i]);
    }
    printf("\n");
    free_int_list(&result1);
    
    // Test case 2
    Item test2[] = {
        {TYPE_INT, .data.int_value = 1},
        {TYPE_STRING, .data.string_value = "a"},
        {TYPE_STRING, .data.string_value = "b"},
        {TYPE_INT, .data.int_value = 0},
        {TYPE_INT, .data.int_value = 15}
    };
    IntList result2 = filter_list(test2, 5);
    printf("Test 2: ");
    for (size_t i = 0; i < result2.count; i++) {
        printf("%d ", result2.values[i]);
    }
    printf("\n");
    free_int_list(&result2);
    
    // Test case 3
    Item test3[] = {
        {TYPE_INT, .data.int_value = 1},
        {TYPE_INT, .data.int_value = 2},
        {TYPE_STRING, .data.string_value = "a"},
        {TYPE_STRING, .data.string_value = "b"},
        {TYPE_STRING, .data.string_value = "aasf"},
        {TYPE_STRING, .data.string_value = "1"},
        {TYPE_STRING, .data.string_value = "123"},
        {TYPE_INT, .data.int_value = 123}
    };
    IntList result3 = filter_list(test3, 8);
    printf("Test 3: ");
    for (size_t i = 0; i < result3.count; i++) {
        printf("%d ", result3.values[i]);
    }
    printf("\n");
    free_int_list(&result3);
    
    // Test case 4
    Item test4[] = {
        {TYPE_STRING, .data.string_value = "hello"},
        {TYPE_STRING, .data.string_value = "world"},
        {TYPE_INT, .data.int_value = 42},
        {TYPE_INT, .data.int_value = 100}
    };
    IntList result4 = filter_list(test4, 4);
    printf("Test 4: ");
    for (size_t i = 0; i < result4.count; i++) {
