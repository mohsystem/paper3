```cpp
#include <iostream>
#include <vector>
#include <stdexcept>

double findUniq(const std::vector<double>& arr) {
    if (arr.size() < 3) {
        throw std::invalid_argument("Array must have at least 3 elements");
    }
    
    // Compare first three elements to determine which is the unique one
    if (arr == arr[1]) {
        // arr and arr[1] are the same, so find the different one
        for (size_t i = 2; i < arr.size(); ++i) {
            if (arr[i] != arr) {
                return arr[i];
            }
        }
    } else {
        // arr and arr[1] are different, check which one matches arr[2]
        if (arr == arr[2]) {
            return arr[1];
        } else {
            return arr;
        }
    }
    
    // Should never reach here if input is valid
    throw std::runtime_error("No unique element found");
}

int main() {
    // Test case 1
    std::cout << findUniq({1, 1, 1, 2, 1, 1}) << std::endl;  // Expected: 2
    
    // Test case 2
    std::cout << findUniq({0, 0, 0.55, 0, 0}) << std::endl;  // Expected: 0.55
    
    // Test case 3
    std::cout << findUniq({3, 10, 3, 3, 3}) << std::endl;  // Expected: 10
    
    // Test case 4
    std::cout << findUniq({-1, -1, -1, -1, 5}) << std::endl;  // Expected: 5
    
    // Test case 5
    std::cout << findUniq({7, 2, 2, 2}) << std::endl;  // Expected: 7
    
    return 0;
}
```

