public class Task18 {
    public static int binaryArrayToInt(int[] binary) {
        if (binary == null || binary.length == 0) {
            throw new IllegalArgumentException("Array cannot be null or empty");
        }
        
        if (binary.length > 32) {
            throw new IllegalArgumentException("Array length exceeds safe integer range");
        }
        
        int result = 0;
        for (int i = 0; i < binary.length; i++) {
            if (binary[i] != 0 && binary[i] != 1) {
                throw new IllegalArgumentException("Array must contain only 0s and 1s");
            }
            result = result * 2 + binary[i];
        }
        return result;
    }
    
