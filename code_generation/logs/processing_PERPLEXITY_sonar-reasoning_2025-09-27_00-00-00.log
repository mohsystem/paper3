import java.util.ArrayList;
import java.util.List;

public class Task15 {
    
    public static List<String> buildTower(int nFloors) {
        if (nFloors <= 0) {
            throw new IllegalArgumentException("Number of floors must be positive");
        }
        
        List<String> tower = new ArrayList<>();
        int totalWidth = 2 * nFloors - 1;
        
        for (int floor = 1; floor <= nFloors; floor++) {
            int spaces = nFloors - floor;
            int stars = 2 * floor - 1;
            
            StringBuilder sb = new StringBuilder();
            for (int i = 0; i < spaces; i++) {
                sb.append(" ");
            }
            for (int i = 0; i < stars; i++) {
                sb.append("*");
            }
            for (int i = 0; i < spaces; i++) {
                sb.append(" ");
            }
            
            tower.add(sb.toString());
        }
        
        return tower;
    }
    
    public static void main(String[] args) {
        // Test case 1
        List<String> tower1 = buildTower(1);
        System.out.println("Tower 1:");
        for (String floor : tower1) {
            System.out.println("\"" + floor + "\"");
        }
        
        // Test case 2
        List<String> tower2 = buildTower(3);
        System.out.println("\nTower 3:");
        for (String floor : tower2) {
            System.out.println("\"" + floor + "\"");
        }
        
        // Test case 3
        List<String> tower3 = buildTower(6);
        System.out.println("\nTower 6:");
        for (String floor : tower3) {
            System.out.println("\"" + floor + "\"");
        }
        
        // Test case 4
        List<String> tower4 = buildTower(4);
        System.out.println("\nTower 4:");
        for (String floor : tower4) {
            System.out.println("\"" + floor + "\"");
        }
        
        // Test case 5
        List<String> tower5 = buildTower(8);
        System.out.println("\nTower 8:");
        for (String floor : tower5) {
            System.out.println("\"" + floor + "\"");
        }
    }
}
