```cpp
#include <iostream>
#include <string>
#include <set>
#include <cctype>

bool isPangram(const std::string& sentence) {
    if (sentence.empty()) {
        return false;
    }
    
    if (sentence.length() > 10000) {
        return false; // Prevent excessive memory usage
    }
    
    std::set<char> seenLetters;
    
    for (size_t i = 0; i < sentence.length(); i++) {
        char c = std::tolower(sentence[i]);
        if (c >= 'a' && c <= 'z') {
            seenLetters.insert(c);
            if (seenLetters.size() == 26) {
                return true;
            }
        }
    }
    
    return seenLetters.size() == 26;
}

int main() {
    // Test cases
    std::cout << std::boolalpha;
    std::cout << isPangram("The quick brown fox jumps over the lazy dog") << std::endl; // true
    std::cout << isPangram("Hello world") << std::endl; // false
    std::cout << isPangram("ABCDEFGHIJKLMNOPQRSTUVWXYZ") << std::endl; // true
    std::cout << isPangram("Pack my box with five dozen liquor jugs") << std::endl; // true
    std::cout << isPangram("") << std::endl; // false
    
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <stdbool.h>
#include <ctype.h>

bool isPangram(const char* sentence) {
    if (sentence == NULL) {
        return false;
    }
    
    size_t len = strlen(sentence);
    if (len > 10000) {
        return false; // Prevent excessive memory usage
    }
    
    bool letterSeen[26] = {false};
    int uniqueLetters = 0;
    
    for (size_t i = 0; i < len; i++) {
        char c = tolower(sentence[i]);
        if (c >= 'a' && c <= 'z') {
            int index = c - 'a';
            if (!letterSeen[index]) {
                letterSeen[index] = true;
                uniqueLetters++;
                if (uniqueLetters == 26) {
                    return true;
                }
            }
        }
    }
    
    return uniqueLetters == 26;
}

int main() {
    // Test cases
    printf("%s\n", isPangram("The quick brown fox jumps over the lazy dog") ? "true" : "false");
    printf("%s\n", isPangram("Hello world") ? "true" : "false");
    printf("%s\n", isPangram("ABCDEFGHIJKLMNOPQRSTUVWXYZ") ? "true" : "false");
    printf("%s\n", isPangram("Pack my box with five dozen liquor jugs") ? "true" : "false");
    printf("%s\n", isPangram("") ? "true" : "false");
    
    return 0;
}
```
