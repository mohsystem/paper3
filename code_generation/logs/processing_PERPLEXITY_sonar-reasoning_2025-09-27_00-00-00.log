```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct {
    char** lines;
    size_t count;
} StringArray;

StringArray addLineNumbers(const char** lines, size_t count) {
    StringArray result = {NULL, 0};
    
    if (lines == NULL) {
        return result;
    }
    
    result.lines = malloc(count * sizeof(char*));
    if (result.lines == NULL) {
        return result;
    }
    
    result.count = count;
    
    for (size_t i = 0; i < count; i++) {
        const char* line = lines[i] ? lines[i] : "";
        size_t needed = snprintf(NULL, 0, "%zu: %s", i + 1, line) + 1;
        
        result.lines[i] = malloc(needed);
        if (result.lines[i] == NULL) {
            for (size_t j = 0; j < i; j++) {
                free(result.lines[j]);
            }
            free(result.lines);
            result.lines = NULL;
            result.count = 0;
            return result;
        }
        
        snprintf(result.lines[i], needed, "%zu: %s", i + 1, line);
    }
    
    return result;
}

void freeStringArray(StringArray* arr) {
    if (arr && arr->lines) {
        for (size_t i = 0; i < arr->count; i++) {
            free(arr->lines[i]);
        }
        free(arr->lines);
        arr->lines = NULL;
        arr->count = 0;
    }
}

void printStringArray(StringArray arr) {
    printf("[");
    for (size_t i = 0; i < arr.count; i++) {
        printf("\"%s\"", arr.lines[i]);
        if (i < arr.count - 1) printf(", ");
    }
    printf("]\n");
}

int main() {
    // Test case 1: Empty array
    const char* test1[] = {};
    StringArray result1 = addLineNumbers(test1, 0);
    printf("Test 1: ");
    printStringArray(result1);
    freeStringArray(&result1);
    
    // Test case 2: Single line
    const char* test2[] = {"hello"};
    StringArray result2 = addLineNumbers(test2, 1);
    printf("Test 2: ");
    printStringArray(result2);
    freeStringArray(&result2);
    
    // Test case 3: Multiple lines
    const char* test3[] = {"a", "b", "c"};
    StringArray result3 = addLineNumbers(test3, 3);
    printf("Test 3: ");
    printStringArray(result3);
    freeStringArray(&result3);
    
    // Test case 4: Lines with spaces
    const char* test4[] = {"hello world", "foo bar"};
    StringArray result4 = addLineNumbers(test4, 2);
    printf("Test 4: ");
    printStringArray(result4);
    freeStringArray(&result4);
    
    // Test case 5: Empty strings in array
    const char* test5[] = {"", "test", ""};
    StringArray result5 = addLineNumbers(test5, 3);
    printf("Test 5: ");
    printStringArray(result5);
    freeStringArray(&result5);
    
    return 0;
}
