public class Task8 {
    public static char findMissingLetter(char[] letters) {
        // Input validation
        if (letters == null || letters.length < 2) {
            throw new IllegalArgumentException("Invalid input array");
        }
        
        // Find missing letter by checking consecutive sequence
        for (int i = 0; i < letters.length - 1; i++) {
            if (letters[i + 1] - letters[i] > 1) {
                return (char)(letters[i] + 1);
            }
        }
        
        // Should not reach here based on problem constraints
        throw new IllegalStateException("No missing letter found");
    }
    
    public static void main(String[] args) {
        // Test cases
