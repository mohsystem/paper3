public class Task4 {
    public static boolean isIsogram(String word) {
        if (word == null) {
            return false;
        }
        
        word = word.toLowerCase();
        int[] charCount = new int;
        
        for (int i = 0; i < word.length(); i++) {
            char c = word.charAt(i);
            if (c < 'a' || c > 'z') {
                return false;
            }
            charCount[c - 'a']++;
            if (charCount[c - 'a'] > 1) {
                return false;
            }
        }
        
