        System.out.println("Test 4 - Null username: " + result4);
        
        // Test Case 5: Input validation (too long username)
        String longUsername = "a".repeat(51);
        String result5 = server.authenticateUser(longUsername, "password");
        System.out.println("Test 5 - Long username: " + result5);
    }
}
