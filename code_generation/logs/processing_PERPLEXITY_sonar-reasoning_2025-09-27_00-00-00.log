from typing import List

def build_tower(n_floors: int) -> List[str]:
    if n_floors <= 0:
        raise ValueError("Number of floors must be positive")
    
    tower = []
    
    for floor in range(1, n_floors + 1):
        spaces = n_floors - floor
        stars = 2 * floor - 1
        
        floor_str = " " * spaces + "*" * stars + " " * spaces
        tower.append(floor_str)
    
    return tower

def main():
    # Test case 1
    tower1 = build_tower(1)
    print("Tower 1:")
    for floor in tower1:
        print(f'"{floor}"')
    
    # Test case 2
    tower2 = build_tower(3)
    print("\nTower 3:")
    for floor in tower2:
        print(f'"{floor}"')
    
