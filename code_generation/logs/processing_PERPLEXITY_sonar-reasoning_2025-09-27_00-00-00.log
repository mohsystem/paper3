```python
def binary_array_to_int(binary):
    if not binary:
        raise ValueError("Array cannot be empty")
    
    if len(binary) > 32:
        raise ValueError("Array length exceeds safe integer range")
    
    result = 0
    for bit in binary:
        if bit not in (0, 1):
            raise ValueError("Array must contain only 0s and 1s")
        result = result * 2 + bit
    
    return result

def main():
    print(binary_array_to_int([0, 0, 0, 1]))  # 1
    print(binary_array_to_int([0, 0, 1, 0]))  # 2
    print(binary_array_to_int([0, 1, 0, 1]))  # 5
    print(binary_array_to_int([1, 0, 0, 1]))  # 9
    print(binary_array_to_int([1, 1, 1, 1]))  # 15

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <vector>
#include <stdexcept>

int binaryArrayToInt(const std::vector<int>& binary) {
    if (binary.empty()) {
        throw std::invalid_argument("Array cannot be empty");
    }
    
    if (binary.size() > 32) {
        throw std::invalid_argument("Array length exceeds safe integer range");
    }
    
    int result = 0;
    for (size_t i = 0; i < binary.size(); ++i) {
        if (binary[i] != 0 && binary[i] != 1) {
            throw std::invalid_argument("Array must contain only 0s and 1s");
        }
        result = result * 2 + binary[i];
    }
    return result;
}

int main() {
    std::cout << binaryArrayToInt({0, 0, 0, 1}) << std::endl; // 1
    std::cout << binaryArrayToInt({0, 0, 1, 0}) << std::endl; // 2
    std::cout << binaryArrayToInt({0, 1, 0, 1}) << std::endl; // 5
    std::cout << binaryArrayToInt({1, 0, 0, 1}) << std::endl; // 9
    std::cout << binaryArrayToInt({1, 1, 1, 1}) << std::endl; // 15
    
    return 0;
}
```

```c
#include <stdio.h>
#include <stdlib.h>

int binaryArrayToInt(const int* binary, size_t length) {
    if (binary == NULL || length == 0) {
        fprintf(stderr, "Error: Array cannot be null or empty\n");
        return -1;
    }
    
    if (length > 32) {
        fprintf(stderr, "Error: Array length exceeds safe integer range\n");
        return -1;
    }
    
    int result = 0;
    for (size_t i = 0; i < length; i++) {
        if (binary[i] != 0 && binary[i] != 1) {
            fprintf(stderr, "Error: Array must contain only 0s and 1s\n");
            return -1;
        }
        result = result * 2 + binary[i];
    }
    return result;
}

int main() {
    int test1[] = {0, 0, 0, 1};
    int test2[] = {0, 0, 1, 0};
    int test3[] = {0, 1, 0, 1};
    int test4[] = {1, 0, 0, 1};
    int test5[] = {1, 1, 1, 1};
    
    printf("%d\n", binaryArrayToInt(test1, 4)); // 1
    printf("%d\n", binaryArrayToInt(test2, 4)); // 2
    printf("%d\n", binaryArrayToInt(test3, 4)); // 5
    printf("%d\n", binaryArrayToInt(test4, 4)); // 9
    printf("%d\n", binaryArrayToInt(test5, 4)); // 15
    
    return 0;
}
```
