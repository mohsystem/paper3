```java
import java.io.*;
import java.nio.file.*;
import java.util.concurrent.*;
import java.util.concurrent.locks.*;
import java.util.*;

public class Task0 {
    private final ConcurrentHashMap<String, ReentrantLock> fileLocks = new ConcurrentHashMap<>();
    private final Path baseDirectory;
    private final ExecutorService executor;
    
    public Task0(String baseDir) throws IOException {
        this.baseDirectory = Paths.get(baseDir).toRealPath().normalize();
        this.executor = Executors.newFixedThreadPool(4);
    }
    
    private boolean isValidPath(Path path) {
        try {
            Path normalized = path.toRealPath().normalize();
            return normalized.startsWith(baseDirectory);
        } catch (IOException e) {
            return false;
        }
    }
    
    public void processFile(String filename) {
        Path filePath = baseDirectory.resolve(filename).normalize();
        
        if (!isValidPath(filePath) || !Files.isRegularFile(filePath)) {
            System.err.println("Invalid file: " + filename);
            return;
        }
        
        String absolutePath = filePath.toString();
        ReentrantLock lock = fileLocks.computeIfAbsent(absolutePath, k -> new ReentrantLock());
        
        executor.submit(() -> {
            lock.lock();
            try {
                Path tempFile = Files.createTempFile(baseDirectory, "temp_", ".tmp");
                try (BufferedReader reader = Files.newBufferedReader(filePath);
                     BufferedWriter writer = Files.newBufferedWriter(tempFile)) {
                    
                    String line;
                    while ((line = reader.readLine()) != null) {
                        writer.write("[PROCESSED] " + line);
                        writer.newLine();
                    }
                }
                
                Path processedFile = baseDirectory.resolve("processed_" + filename);
                Files.move(tempFile, processedFile, StandardCopyOption.ATOMIC_MOVE);
                System.out.println("Thread " + Thread.currentThread().getId() + " processed: " + filename);
                
            } catch (IOException e) {
                System.err.println("Error processing file " + filename + ": " + e.getMessage());
            } finally {
                lock.unlock();
            }
        });
    }
    
    public void shutdown() throws InterruptedException {
        executor.shutdown();
        if (!executor.awaitTermination(10, TimeUnit.SECONDS)) {
            executor.shutdownNow();
        }
    }
    
    public static void main(String[] args) throws Exception {
        Path testDir = Files.createTempDirectory("fileprocessor_test");
        Task0 processor = new Task0(testDir.toString());
        
        // Create test files
        for (int i = 1; i <= 5; i++) {
            Path testFile = testDir.resolve("test" + i + ".txt");
            Files.write(testFile, ("Content of file " + i).getBytes());
            processor.processFile("test" + i + ".txt");
        }
        
        processor.shutdown();
        
        // Cleanup
        Files.walk(testDir).sorted((a, b) -> b.compareTo(a)).forEach(p -> {
            try { Files.deleteIfExists(p); } catch (IOException e) {}
        });
    }
}
