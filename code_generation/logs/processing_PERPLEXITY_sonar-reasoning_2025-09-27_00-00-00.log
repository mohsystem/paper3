```java
import java.util.*;

public class Task22 {
    public static class Kata {
        public static List<Integer> filterList(List<Object> input) {
            if (input == null) {
                throw new IllegalArgumentException("Input cannot be null");
            }
            
            List<Integer> result = new ArrayList<>();
            
            for (Object item : input) {
                if (item instanceof Integer) {
                    int value = (Integer) item;
                    if (value >= 0) {
                        result.add(value);
                    }
                }
            }
            
            return result;
        }
    }
    
    public static void main(String[] args) {
        // Test case 1
        List<Object> test1 = List.of(1, 2, "a", "b");
        System.out.println("Test 1: " + Kata.filterList(test1));
        
        // Test case 2
        List<Object> test2 = List.of(1, "a", "b", 0, 15);
        System.out.println("Test 2: " + Kata.filterList(test2));
        
        // Test case 3
        List<Object> test3 = List.of(1, 2, "a", "b", "aasf", "1", "123", 123);
        System.out.println("Test 3: " + Kata.filterList(test3));
        
        // Test case 4
        List<Object> test4 = List.of("hello", "world", 42, 100);
        System.out.println("Test 4: " + Kata.filterList(test4));
        
        // Test case 5
        List<Object> test5 = List.of();
        System.out.println("Test 5: " + Kata.filterList(test5));
    }
}
