```java
public class Task16 {
    public static boolean solution(String str, String suffix) {
        if (str == null || suffix == null) {
            return false;
        }
        if (suffix.length() > str.length()) {
            return false;
        }
        return str.endsWith(suffix);
    }
    
    public static void main(String[] args) {
        System.out.println(solution("abc", "bc"));
        System.out.println(solution("abc", "d"));
        System.out.println(solution("hello", "lo"));
        System.out.println(solution("test", "testing"));
        System.out.println(solution("", ""));
    }
}
```

```python
def solution(s: str, suffix: str) -> bool:
    if s is None or suffix is None:
        return False
    if len(suffix) > len(s):
        return False
    return s.endswith(suffix)

def main():
    print(solution("abc", "bc"))
    print(solution("abc", "d"))
    print(solution("hello", "lo"))
    print(solution("test", "testing"))
    print(solution("", ""))

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <string>

bool solution(const std::string& str, const std::string& suffix) {
    if (suffix.length() > str.length()) {
        return false;
    }
    return str.length() >= suffix.length() && 
           str.substr(str.length() - suffix.length()) == suffix;
}

int main() {
    std::cout << std::boolalpha;
    std::cout << solution("abc", "bc") << std::endl;
    std::cout << solution("abc", "d") << std::endl;
    std::cout << solution("hello", "lo") << std::endl;
    std::cout << solution("test", "testing") << std::endl;
    std::cout << solution("", "") << std::endl;
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <stdbool.h>

bool solution(const char* str, const char* suffix) {
    if (str == NULL || suffix == NULL) {
        return false;
    }
    
    size_t str_len = strlen(str);
    size_t suffix_len = strlen(suffix);
    
    if (suffix_len > str_len) {
        return false;
    }
    
    return strcmp(str + str_len - suffix_len, suffix) == 0;
}

int main() {
