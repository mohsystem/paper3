```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <openssl/evp.h>
#include <openssl/rand.h>

#define KEY_SIZE 32
#define IV_SIZE 12
#define TAG_SIZE 16

typedef struct {
    unsigned char* data;
    size_t length;
} EncryptedData;

EncryptedData* encrypt_data(const unsigned char* key, const unsigned char* data, size_t data_len) {
    if (!key || !data || data_len == 0) {
        return NULL;
    }

    EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
    if (!ctx) return NULL;

    unsigned char iv[IV_SIZE];
    if (RAND_bytes(iv, IV_SIZE) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), NULL, NULL, NULL) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, IV_SIZE, NULL) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    if (EVP_EncryptInit_ex(ctx, NULL, NULL, key, iv) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    unsigned char* ciphertext = malloc(data_len + TAG_SIZE);
    if (!ciphertext) {
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    int len = 0, ciphertext_len = 0;
    if (EVP_EncryptUpdate(ctx, ciphertext, &len, data, data_len) != 1) {
        free(ciphertext);
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }
    ciphertext_len = len;

    if (EVP_EncryptFinal_ex(ctx, ciphertext + len, &len) != 1) {
        free(ciphertext);
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }
    ciphertext_len += len;

    unsigned char tag[TAG_SIZE];
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_SIZE, tag) != 1) {
        free(ciphertext);
        EVP_CIPHER_CTX_free(ctx);
        return NULL;
    }

    EVP_CIPHER_CTX_free(ctx);

    EncryptedData* result = malloc(sizeof(EncryptedData));
    if (!result) {
        free(ciphertext);
        return NULL;
    }

    size_t total_len = IV_SIZE + ciphertext_len + TAG_SIZE;
    result->data = malloc(total_len);
    if (!result->data) {
        free(ciphertext);
        free(result);
        return NULL;
    }

    memcpy(result->data, iv, IV_SIZE);
    memcpy(result->data + IV_SIZE, ciphertext, ciphertext_len);
    memcpy(result->data + IV_SIZE + ciphertext_len, tag, TAG_SIZE);
    result->length = total_len;

    free(ciphertext);
    return result;
}

void free_encrypted_data(EncryptedData* data) {
    if (data) {
        if (data->data) {
            free(data->data);
        }
        free(data);
    }
}

int main() {
    unsigned char key[KEY_SIZE];
    if (RAND_bytes(key, KEY_SIZE) != 1) {
        fprintf(stderr, "Failed to generate key\n");
        return 1;
    }

    const char* test_data[] = {
        "Hello World",
        "Test data 123",
        "AES encryption test",
        "Another test case",
        "Final test string"
    };

    for (int i = 0; i < 5; i++) {
        EncryptedData* encrypted = encrypt_data(key, (const unsigned char*)test_data[i], strlen(test_data[i]));
        if (encrypted) {
            printf("Encrypted length: %zu\n", encrypted->length);
            free_encrypted_data(encrypted);
        } else {
            fprintf(stderr, "Encryption failed for test case %d\n", i + 1);
        }
    }

    return 0;
}
