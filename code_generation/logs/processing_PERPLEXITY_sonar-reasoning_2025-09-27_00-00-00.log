from cryptography.hazmat.primitives.ciphers.aead import AESGCM
import secrets

def encrypt_data(key_material: bytes, data_to_encrypt: bytes) -> bytes:
    if key_material is None or len(key_material) != 32:
        raise ValueError("Key must be 32 bytes for AES-256")
    if data_to_encrypt is None:
        raise ValueError("Data to encrypt cannot be None")
    
    aesgcm = AESGCM(key_material)
    iv = secrets.token_bytes(12)
    
    encrypted = aesgcm.encrypt(iv, data_to_encrypt, None)
    
    return iv + encrypted

def main():
    try:
        key = secrets.token_bytes(32)
        
        test_data = [
            b"Hello World",
            b"Test data 123",
            b"AES encryption test",
            b"Another test case",
            b"Final test string"
        ]
        
        for data in test_data:
            encrypted = encrypt_data(key, data)
            print(f"Encrypted length: {len(encrypted)}")
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
