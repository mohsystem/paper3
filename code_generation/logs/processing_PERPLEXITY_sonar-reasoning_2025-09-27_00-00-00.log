#include <iostream>
#include <vector>
#include <unordered_map>
#include <stdexcept>

std::vector<int> twoSum(const std::vector<int>& nums, int target) {
    if (nums.size() < 2) {
        throw std::invalid_argument("Array must contain at least 2 elements");
    }
    
    std::unordered_map<int, int> numMap;
    
    for (int i = 0; i < static_cast<int>(nums.size()); i++) {
        int complement = target - nums[i];
        auto it = numMap.find(complement);
        if (it != numMap.end()) {
            return {it->second, i};
        }
        numMap[nums[i]] = i;
    }
    
    throw std::invalid_argument("No valid pair found");
}

int main() {
    // Test case 1
    std::vector<int> result1 = twoSum({1, 2, 3}, 4);
    std::cout << "Test 1: [" << result1[0] << ", " << result1[1] << "]" << std::endl;
    
    // Test case 2
    std::vector<int> result2 = twoSum({3, 2, 4}, 6);
    std::cout << "Test 2: [" << result2[0] << ", " << result2[1] << "]" << std::endl;
    
    // Test case 3
    std::vector<int> result3 = twoSum({2, 7, 11, 15}, 9);
    std::cout << "Test 3: [" << result3[0] << ", " << result3[1] << "]" << std::endl;
    
    // Test case 4
    std::vector<int> result4 = twoSum({3, 3}, 6);
    std::cout << "Test 4: [" << result4[0] << ", " << result4[1] << "]" << std::endl;
    
    // Test case 5
    std::vector<int> result5 = twoSum({-1, -2, -3, -4, -5}, -8);
    std::cout << "Test 5: [" << result5[0] << ", " << result5[1] << "]" << std::endl;
    
    return 0;
}
