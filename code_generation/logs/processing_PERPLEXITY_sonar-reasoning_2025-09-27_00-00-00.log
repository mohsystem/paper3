```python
from typing import List, Any

def filter_list(input_list: List[Any]) -> List[int]:
    if input_list is None:
        raise ValueError("Input cannot be None")
    
    result = []
    
    for item in input_list:
        if isinstance(item, int) and not isinstance(item, bool):
            if item >= 0:
                result.append(item)
    
    return result

def main():
    # Test case 1
    test1 = [1, 2, "a", "b"]
    print(f"Test 1: {filter_list(test1)}")
    
    # Test case 2
    test2 = [1, "a", "b", 0, 15]
    print(f"Test 2: {filter_list(test2)}")
    
    # Test case 3
    test3 = [1, 2, "a", "b", "aasf", "1", "123", 123]
    print(f"Test 3: {filter_list(test3)}")
    
    # Test case 4
    test4 = ["hello", "world", 42, 100]
    print(f"Test 4: {filter_list(test4)}")
    
    # Test case 5
    test5 = []
    print(f"Test 5: {filter_list(test5)}")

if __name__ == "__main__":
    main()
