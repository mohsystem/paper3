#include <stdio.h>

const char* checkOddEven(int* arr, int size) {
    // Handle invalid input
    if (arr == NULL || size < 0) {
        return "even"; // treat as 
    }
    
    // Handle empty array
    if (size == 0) {
        return "even"; // treat as 
    }
    
    long long sum = 0; // use long long to prevent overflow
    for (int i = 0; i < size; i++) {
        sum += arr[i];
    }
    
    return (sum % 2 == 0) ? "even" : "odd";
}

int main() {
    // Test case 1: 
    int test1[] = {0};
    printf("%s\n", checkOddEven(test1, 1));
    
    // Test case 2: [0, 1, 4]
    int test2[] = {0, 1, 4};
