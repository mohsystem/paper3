def remove_smallest(arr):
    if not arr:
        return []
    
    # Find minimum value and its first index
    min_value = min(arr)
    min_index = arr.index(min_value)
    
    # Create new list without the element at min_index
    result = []
    for i in range(len(arr)):
        if i != min_index:
            result.append(arr[i])
    
