```cpp
#include <iostream>
#include <vector>
#include <stdexcept>

int findOutlier(const std::vector<int>& arr) {
    if (arr.size() < 3) {
        throw std::invalid_argument("Array must have at least 3 elements");
    }
    
    int evenCount = 0;
    int oddCount = 0;
    int lastEven = 0;
    int lastOdd = 0;
    
    for (int num : arr) {
        if (num % 2 == 0) {
            evenCount++;
            lastEven = num;
        } else {
            oddCount++;
            lastOdd = num;
        }
    }
    
    if (evenCount == 1) {
        return lastEven;
    } else {
        return lastOdd;
    }
}

int main() {
    std::cout << findOutlier({2, 4, 0, 100, 4, 11, 2602, 36}) << std::endl; // 11
