```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

void reverseString(char* str, int start, int end) {
    while (start < end) {
        char temp = str[start];
        str[start] = str[end];
        str[end] = temp;
        start++;
        end--;
    }
}

char* reverseWords(const char* input) {
    if (input == NULL || strlen(input) == 0) {
        char* result = malloc(1);
        if (result) result[0] = '\0';
        return result;
    }
    
    int len = strlen(input);
    char* result = malloc(len + 1);
    if (!result) return NULL;
    
    strncpy(result, input, len);
    result[len] = '\0';
    
    int start = 0;
    for (int i = 0; i <= len; i++) {
        if (result[i] == ' ' || result[i] == '\0') {
            int wordLen = i - start;
            if (wordLen >= 5) {
                reverseString(result, start, i - 1);
            }
            start = i + 1;
        }
    }
    
    return result;
}

int main() {
    char* result1 = reverseWords("Hey fellow warriors");
    printf("%s\n", result1);
    free(result1);
    
    char* result2 = reverseWords("This is a test");
    printf("%s\n", result2);
    free(result2);
    
    char* result3 = reverseWords("This is another test");
    printf("%s\n", result3);
    free(result3);
    
    char* result4 = reverseWords("Hello");
    printf("%s\n", result4);
    free(result4);
    
    char* result5 = reverseWords("a");
    printf("%s\n", result5);
    free(result5);
    
    return 0;
}
