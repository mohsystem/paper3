```python
def longest(s1: str, s2: str) -> str:
    if not isinstance(s1, str) or not isinstance(s2, str):
        return ""
    
    if not all(c.islower() and c.isalpha() for c in s1) or not all(c.islower() and c.isalpha() for c in s2):
        return ""
    
    unique_chars = set(s1) | set(s2)
    
    return ''.join(sorted(unique_chars))

if __name__ == "__main__":
    print(longest("xyaabbbccccdefww", "xxxxyyyyabklmopq"))
    print(longest("abcdefghijklmnopqrstuvwxyz", "abcdefghijklmnopqrstuvwxyz"))
    print(longest("", "abc"))
    print(longest("abc", ""))
    print(longest("aaa", "bbb"))
```

```cpp
#include <iostream>
#include <string>
#include <set>

std::string longest(const std::string& s1, const std::string& s2) {
    for (char c : s1) {
        if (c < 'a' || c > 'z') {
            return "";
        }
    }
    for (char c : s2) {
        if (c < 'a' || c > 'z') {
            return "";
        }
    }
    
    std::set<char> uniqueChars;
    
    for (char c : s1) {
        uniqueChars.insert(c);
    }
    
    for (char c : s2) {
        uniqueChars.insert(c);
    }
    
    std::string result;
    for (char c : uniqueChars) {
        result += c;
    }
    
    return result;
}

int main() {
    std::cout << longest("xyaabbbccccdefww", "xxxxyyyyabklmopq") << std::endl;
    std::cout << longest("abcdefghijklmnopqrstuvwxyz", "abcdefghijklmnopqrstuvwxyz") << std::endl;
    std::cout << longest("", "abc") << std::endl;
    std::cout << longest("abc", "") << std::endl;
    std::cout << longest("aaa", "bbb") << std::endl;
    
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

char* longest(const char* s1, const char* s2) {
    if (s1 == NULL || s2 == NULL) {
        char* result = malloc(1);
        if (result) result = '\0';
        return result;
    }
    
    for (int i = 0; s1[i]; i++) {
        if (s1[i] < 'a' || s1[i] > 'z') {
            char* result = malloc(1);
            if (result) result = '\0';
            return result;
        }
    }
    for (int i = 0; s2[i]; i++) {
        if (s2[i] < 'a' || s2[i] > 'z') {
            char* result = malloc(1);
            if (result) result = '\0';
            return result;
        }
    }
    
    int present = {0};
    
    for (int i = 0; s1[i]; i++) {
        present[s1[i] - 'a'] = 1;
    }
    
    for (int i = 0; s2[i]; i++) {
        present[s2[i] - 'a'] = 1;
    }
    
    int count = 0;
    for (int i = 0; i < 26; i++) {
        if (present[i]) count++;
    }
    
    char* result = malloc(count + 1);
    if (!result) return NULL;
    
    int index = 0;
    for (int i = 0; i < 26; i++) {
        if (present[i]) {
            result[index++] = 'a' + i;
        }
    }
    result[index] = '\0';
    
    return result;
}

int main() {
    char* result1 = longest("xyaabbbccccdefww", "xxxxyyyyabklmopq");
    printf("%s\n", result1);
    free(result1);
    
    char* result2 = longest("abcdefghijklmnopqrstuvwxyz", "abcdefghijklmnopqrstuvwxyz");
    printf("%s\n", result2);
    free(result2);
    
    char* result3 = longest("", "abc");
    printf("%s\n", result3);
    free(result3);
    
    char* result4 = longest("abc", "");
    printf("%s\n", result4);
    free(result4);
    
    char* result5 = longest("aaa", "bbb");
    printf("%s\n", result5);
    free(result5);
    
    return 0;
}
