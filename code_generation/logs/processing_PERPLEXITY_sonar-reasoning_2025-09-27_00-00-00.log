```java
public class Task10 {
    public static int sumRange(int a, int b) {
        if (a == b) {
            return a;
        }
        
        int min = Math.min(a, b);
        int max = Math.max(a, b);
        
        // Use long for intermediate calculations to avoid overflow
        long n = (long)max - min + 1;
        long sum = n * ((long)min + max) / 2;
        
        return (int)sum;
    }
    
    public static void main(String[] args) {
        System.out.println(sumRange(1, 0));
        System.out.println(sumRange(1, 2));
        System.out.println(sumRange(0, 1));
        System.out.println(sumRange(1, 1));
        System.out.println(sumRange(-1, 2));
    }
}
```

```python
def sum_range(a: int, b: int) -> int:
    if a == b:
        return a
    
    min_val = min(a, b)
    max_val = max(a, b)
    
    n = max_val - min_val + 1
    return n * (min_val + max_val) // 2

if __name__ == "__main__":
    print(sum_range(1, 0))
    print(sum_range(1, 2))
    print(sum_range(0, 1))
    print(sum_range(1, 1))
    print(sum_range(-1, 2))
```

```cpp
#include <iostream>
#include <algorithm>

int sumRange(int a, int b) {
    if (a == b) {
        return a;
    }
    
    int minVal = std::min(a, b);
    int maxVal = std::max(a, b);
    
    // Use long long for intermediate calculations
    long long n = static_cast<long long>(maxVal) - minVal + 1;
    long long sum = n * (static_cast<long long>(minVal) + maxVal) / 2;
    
    return static_cast<int>(sum);
}

int main() {
    std::cout << sumRange(1, 0) << std::endl;
    std::cout << sumRange(1, 2) << std::endl;
    std::cout << sumRange(0, 1) << std::endl;
    std::cout << sumRange(1, 1) << std::endl;
    std::cout << sumRange(-1, 2) << std::endl;
    
    return 0;
}
```

```c
#include <stdio.h>

int sumRange(int a, int b) {
    if (a == b) {
        return a;
    }
    
    int minVal = (a < b) ? a : b;
    int maxVal = (a > b) ? a : b;
    
    // Use long long for intermediate calculations
    long long n = (long long)maxVal - minVal + 1;
    long long sum = n * ((long long)minVal + maxVal) / 2;
    
    return (int)sum;
}

int main() {
    printf("%d\n", sumRange(1, 0));
    printf("%d\n", sumRange(1, 2));
    printf("%d\n", sumRange(0, 1));
    printf("%d\n", sumRange(1, 1));
    printf("%d\n", sumRange(-1, 2));
    
    return 0;
}
```
