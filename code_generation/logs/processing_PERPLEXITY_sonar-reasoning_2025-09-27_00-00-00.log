```c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

char* highestScoringWord(const char* words, char* result, size_t resultSize) {
    if (words == NULL || result == NULL || resultSize == 0) {
        return NULL;
    }
    
    result[0] = '\0';
    
    size_t len = strlen(words);
    if (len == 0) {
        return result;
    }
    
    char* wordsCopy = malloc(len + 1);
    if (wordsCopy == NULL) {
        return NULL;
    }
    strncpy(wordsCopy, words, len);
    wordsCopy[len] = '\0';
    
    char* token = strtok(wordsCopy, " \t\n");
    int highestScore = 0;
    
    while (token != NULL) {
        int score = 0;
        for (int i = 0; token[i] != '\0'; i++) {
            if (token[i] >= 'a' && token[i] <= 'z') {
                score += (token[i] - 'a' + 1);
            }
        }
        
        if (score > highestScore) {
            highestScore = score;
            size_t tokenLen = strlen(token);
            if (tokenLen < resultSize) {
                strncpy(result, token, tokenLen);
                result[tokenLen] = '\0';
            }
        }
        
        token = strtok(NULL, " \t\n");
    }
    
    free(wordsCopy);
    return result;
}

int main() {
    char result[256];
    
    highestScoringWord("man i need a taxi up to ubud", result, sizeof(result));
    printf("%s\n", result);
    
    highestScoringWord("what time are we climbing up the volcano", result, sizeof(result));
    printf("%s\n", result);
    
    highestScoringWord("take me to semynak", result, sizeof(result));
    printf("%s\n", result);
    
    highestScoringWord("aa b", result, sizeof(result));
    printf("%s\n", result);
    
    highestScoringWord("b aa", result, sizeof(result));
    printf("%s\n", result);
    
    return 0;
}
