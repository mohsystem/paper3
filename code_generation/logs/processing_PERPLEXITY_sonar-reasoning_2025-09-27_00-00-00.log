```python
def is_isogram(word):
    if word is None:
        return False
    
    word = word.lower()
    seen = set()
    
    for char in word:
        if not char.isalpha():
            return False
        if char in seen:
            return False
        seen.add(char)
    
    return True

if __name__ == "__main__":
    print(is_isogram("Dermatoglyphics"))
    print(is_isogram("aba"))
    print(is_isogram("moOse"))
    print(is_isogram(""))
    print(is_isogram("abcdefg"))
```

```cpp
#include <iostream>
#include <string>
#include <unordered_set>
#include <algorithm>

bool isIsogram(const std::string& word) {
    if (word.empty()) {
        return true;
    }
    
    std::string lowerWord = word;
    std::transform(lowerWord.begin(), lowerWord.end(), lowerWord.begin(), ::tolower);
    
    std::unordered_set<char> seen;
    
    for (char c : lowerWord) {
        if (c < 'a' || c > 'z') {
            return false;
        }
        if (seen.find(c) != seen.end()) {
            return false;
        }
        seen.insert(c);
    }
    
    return true;
}

int main() {
    std::cout << std::boolalpha;
    std::cout << isIsogram("Dermatoglyphics") << std::endl;
    std::cout << isIsogram("aba") << std::endl;
    std::cout << isIsogram("moOse") << std::endl;
    std::cout << isIsogram("") << std::endl;
    std::cout << isIsogram("abcdefg") << std::endl;
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdbool.h>

bool isIsogram(const char* word) {
    if (word == NULL) {
        return false;
    }
    
    int len = strlen(word);
    if (len == 0) {
        return true;
    }
    
    bool seen = {false};
    
    for (int i = 0; i < len; i++) {
        char c = tolower(word[i]);
        if (c < 'a' || c > 'z') {
            return false;
        }
        if (seen[c - 'a']) {
            return false;
        }
        seen[c - 'a'] = true;
    }
    
    return true;
}

int main() {
    printf("%s\n", isIsogram("Dermatoglyphics") ? "true" : "false");
    printf("%s\n", isIsogram("aba") ? "true" : "false");
    printf("%s\n", isIsogram("moOse") ? "true" : "false");
    printf("%s\n", isIsogram("") ? "true" : "false");
    printf("%s\n", isIsogram("abcdefg") ? "true" : "false");
    return 0;
}
