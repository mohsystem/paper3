```c
#include <stdio.h>
#include <stdlib.h>

int findOutlier(int* arr, int size) {
    if (arr == NULL || size < 3) {
        fprintf(stderr, "Error: Array must not be NULL and have at least 3 elements\n");
        return -1;
    }
    
    int evenCount = 0;
    int oddCount = 0;
    int lastEven = 0;
    int lastOdd = 0;
    
    for (int i = 0; i < size; i++) {
        if (arr[i] % 2 == 0) {
            evenCount++;
            lastEven = arr[i];
        } else {
            oddCount++;
            lastOdd = arr[i];
        }
    }
    
    if (evenCount == 1) {
        return lastEven;
    } else {
        return lastOdd;
    }
}

int main() {
    int test1[] = {2, 4, 0, 100, 4, 11, 2602, 36};
    printf("%d\n", findOutlier(test1, 8)); // 11
    
    int test2[] = {160, 3, 1719, 19, 11, 13, -21};
    printf("%d\n", findOutlier(test2, 7)); // 160
    
    int test3[] = {1, 2, 3};
    printf("%d\n", findOutlier(test3, 3)); // 2
    
    int test4[] = {2, 6, 8, -10, 3};
    printf("%d\n", findOutlier(test4, 5)); // 3
    
    int test5[] = {1, 1, 0};
    printf("%d\n", findOutlier(test5, 3)); // 0
    
    return 0;
}
```
