```python
import math

def find_nb(m):
    if m < 0:
        return -1
    
    sqrt_m = int(math.sqrt(m))
    if sqrt_m * sqrt_m != m:
        return -1
    
    # Check if sqrt_m is a triangular number: sqrt_m = n(n+1)/2
    # Solve: n˛ + n - 2*sqrt_m = 0
    # n = (-1 + sqrt(1 + 8*sqrt_m)) / 2
    
    discriminant = 1 + 8 * sqrt_m
    if discriminant < 0:
        return -1
    
    sqrt_disc = int(math.sqrt(discriminant))
    if sqrt_disc * sqrt_disc != discriminant:
        return -1
    
    if (sqrt_disc - 1) % 2 != 0:
        return -1
    
    n = (sqrt_disc - 1) // 2
    
    # Verify the result
    if n > 0 and n * (n + 1) // 2 == sqrt_m:
        return n
    
    return -1

if __name__ == "__main__":
    print(find_nb(1071225))
    print(find_nb(91716553919377))
    print(find_nb(1))
    print(find_nb(36))
    print(find_nb(100))
```

