```python
def find_uniq(arr):
    if not arr or len(arr) < 3:
        raise ValueError("Array must not be empty and have at least 3 elements")
    
    # Compare first three elements to determine which is the unique one
    if arr == arr[1]:
        # arr and arr[1] are the same, so find the different one
        for i in range(2, len(arr)):
            if arr[i] != arr:
                return arr[i]
    else:
        # arr and arr[1] are different, check which one matches arr[2]
        if arr == arr[2]:
            return arr[1]
        else:
            return arr
    
    # Should never reach here if input is valid
    raise RuntimeError("No unique element found")

if __name__ == "__main__":
    # Test case 1
    print(find_uniq([1, 1, 1, 2, 1, 1]))  # Expected: 2
    
    # Test case 2
    print(find_uniq([0, 0, 0.55, 0, 0]))  # Expected: 0.55
    
    # Test case 3
    print(find_uniq([3, 10, 3, 3, 3]))  # Expected: 10
    
    # Test case 4
    print(find_uniq([-1, -1, -1, -1, 5]))  # Expected: 5
    
    # Test case 5
    print(find_uniq([7, 2, 2, 2]))  # Expected: 7
