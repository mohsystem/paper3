import javax.crypto.spec.PBEKeySpec;

public class Task7 {
    private static final int SALT_LENGTH = 16;
    private static final int ITERATIONS = 210000;
    private static final int KEY_LENGTH = 256;
    private static final int PORT = 8080;
    
    public static class ChatClient {
        public String sendLoginRequest(String username, String password, String serverHost, int port) {
            if (username == null || password == null || username.length() > 50 || password.length() > 100) {
                return "INVALID_INPUT";
            }
            
            try (Socket socket = new Socket(serverHost, port);
                 PrintWriter out = new PrintWriter(socket.getOutputStream(), true, StandardCharsets.UTF_8);
                 BufferedReader in = new BufferedReader(new InputStreamReader(socket.getInputStream(), StandardCharsets.UTF_8))) {
                
                String message = "LOGIN:" + username + ":" + password;
                out.println(message);
                return in.readLine();
            } catch (IOException e) {
                return "CONNECTION_ERROR";
            }
        }
    }
    
    public static class ChatServer {
        private final String credentialsFile = "credentials.txt";
        
        public String authenticateUser(String username, String password) {
            if (username == null || password == null || username.length() > 50 || password.length() > 100) {
                return "INVALID_INPUT";
            }
            
            try (BufferedReader reader = new BufferedReader(new FileReader(credentialsFile, StandardCharsets.UTF_8))) {
                String line;
                while ((line = reader.readLine()) != null) {
                    String[] parts = line.split(":", 3);
                    if (parts.length == 3 && parts[0].equals(username)) {
                        String storedSalt = parts[1];
                        String storedHash = parts[2];
                        
                        byte[] salt = Base64.getDecoder().decode(storedSalt);
                        String computedHash = hashPassword(password, salt);
                        
                        if (constantTimeEquals(storedHash, computedHash)) {
                            return "AUTH_SUCCESS";
                        } else {
                            return "AUTH_FAILED";
                        }
                    }
                }
            } catch (IOException e) {
                return "SERVER_ERROR";
            }
            return "USER_NOT_FOUND";
        }
        
        public boolean storeUser(String username, String password) {
            if (username == null || password == null || username.length() > 50 || password.length() > 100) {
                return false;
            }
            
            try {
                SecureRandom random = new SecureRandom();
                byte[] salt = new byte[SALT_LENGTH];
                random.nextBytes(salt);
                
                String hashedPassword = hashPassword(password, salt);
                String saltBase64 = Base64.getEncoder().encodeToString(salt);
                
                try (FileWriter writer = new FileWriter(credentialsFile, StandardCharsets.UTF_8, true)) {
                    writer.write(username + ":" + saltBase64 + ":" + hashedPassword + "\n");
                }
                return true;
            } catch (IOException e) {
                return false;
            }
        }
        
        private String hashPassword(String password, byte[] salt) {
            try {
                PBEKeySpec spec = new PBEKeySpec(password.toCharArray(), salt, ITERATIONS, KEY_LENGTH);
                SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
                byte[] hash = factory.generateSecret(spec).getEncoded();
                spec.clearPassword();
                return Base64.getEncoder().encodeToString(hash);
            } catch (Exception e) {
                throw new RuntimeException("Password hashing failed", e);
            }
        }
        
        private boolean constantTimeEquals(String a, String b) {
            if (a == null || b == null) return false;
            byte[] aBytes = a.getBytes(StandardCharsets.UTF_8);
            byte[] bBytes = b.getBytes(StandardCharsets.UTF_8);
            return MessageDigest.isEqual(aBytes, bBytes);
        }
    }
    
    public static void main(String[] args) {
        ChatServer server = new ChatServer();
        ChatClient client = new ChatClient();
        
        // Test Case 1: Store and authenticate valid user
        server.storeUser("user1", "password123");
        String result1 = server.authenticateUser("user1", "password123");
        System.out.println("Test 1 - Valid auth: " + result1);
        
        // Test Case 2: Invalid password
        String result2 = server.authenticateUser("user1", "wrongpassword");
        System.out.println("Test 2 - Invalid password: " + result2);
        
        // Test Case 3: Non-existent user
        String result3 = server.authenticateUser("nonexistent", "password");
        System.out.println("Test 3 - Non-existent user: " + result3);
        
        // Test Case 4: Invalid input (null username)
