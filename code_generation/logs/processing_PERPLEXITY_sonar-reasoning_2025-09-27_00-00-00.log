```python
def add_line_numbers(lines):
    if lines is None:
        return []
    
    if not isinstance(lines, list):
        return []
    
    result = []
    for i, line in enumerate(lines):
        if line is None:
            line = ""
        result.append(f"{i + 1}: {line}")
    return result

def main():
    # Test case 1: Empty list
    print(add_line_numbers([]))
    
    # Test case 2: Single line
    print(add_line_numbers(["hello"]))
    
    # Test case 3: Multiple lines
    print(add_line_numbers(["a", "b", "c"]))
    
    # Test case 4: Lines with spaces
    print(add_line_numbers(["hello world", "foo bar"]))
    
    # Test case 5: Empty strings in list
    print(add_line_numbers(["", "test", ""]))

if __name__ == "__main__":
    main()
```

