public class Task1 {
    public static int countPeopleOnBus(int[][] busStops) {
        if (busStops == null || busStops.length == 0) {
            return 0;
        }
        
        int peopleOnBus = 0;
        for (int i = 0; i < busStops.length; i++) {
            if (busStops[i] == null || busStops[i].length != 2) {
                continue; // Skip invalid pairs
            }
            int getOn = busStops[i][0];
            int getOff = busStops[i][1];
            
            // Validate that values are non-negative
            if (getOn < 0 || getOff < 0) {
                continue;
            }
            
            peopleOnBus += getOn - getOff;
            
            // Prevent negative passenger count
            if (peopleOnBus < 0) {
                peopleOnBus = 0;
            }
        }
        return peopleOnBus;
    }
    
    public static void main(String[] args) {
        // Test case 1
        int[][] test1 = {{10, 0}, {3, 5}, {5, 8}};
        System.out.println("Test 1: " + countPeopleOnBus(test1)); // Expected: 5
        
        // Additional test cases will help verify the method's robustness
        int[][] test2 = {{3, 0}, {5, 1}, {6, 1}};
        System.out.println("Test 2: " + countPeopleOnBus(test2)); // Expected: 12

        return;
    }
}
