```python
def find_equal_sum_index(arr):
    if not arr or len(arr) == 0:
        return -1
    
    total_sum = sum(arr)
    left_sum = 0
    
    for i in range(len(arr)):
        right_sum = total_sum - left_sum - arr[i]
        if left_sum == right_sum:
            return i
        left_sum += arr[i]
    
    return -1

def main():
    test1 = [1, 2, 3, 4, 3, 2, 1]
    print(f"Test 1: {find_equal_sum_index(test1)}")
    
    test2 = [1, 100, 50, -51, 1, 1]
    print(f"Test 2: {find_equal_sum_index(test2)}")
    
    test3 = [20, 10, -80, 10, 10, 15, 35]
    print(f"Test 3: {find_equal_sum_index(test3)}")
    
    test4 = [1, 2, 3]
    print(f"Test 4: {find_equal_sum_index(test4)}")
    
    test5 = [0]
    print(f"Test 5: {find_equal_sum_index(test5)}")

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <vector>

int findEqualSumIndex(const std::vector<int>& arr) {
    if (arr.empty()) {
        return -1;
    }
    
    long long totalSum = 0;
    for (int num : arr) {
        totalSum += num;
    }
    
    long long leftSum = 0;
    for (size_t i = 0; i < arr.size(); ++i) {
        long long rightSum = totalSum - leftSum - arr[i];
        if (leftSum == rightSum) {
            return static_cast<int>(i);
        }
        leftSum += arr[i];
    }
    
    return -1;
}

int main() {
    std::vector<int> test1 = {1, 2, 3, 4, 3, 2, 1};
    std::cout << "Test 1: " << findEqualSumIndex(test1) << std::endl;
    
    std::vector<int> test2 = {1, 100, 50, -51, 1, 1};
    std::cout << "Test 2: " << findEqualSumIndex(test2) << std::endl;
    
    std::vector<int> test3 = {20, 10, -80, 10, 10, 15, 35};
    std::cout << "Test 3: " << findEqualSumIndex(test3) << std::endl;
    
    std::vector<int> test4 = {1, 2, 3};
    std::cout << "Test 4: " << findEqualSumIndex(test4) << std::endl;
    
    std::vector<int> test5 = {0};
    std::cout << "Test 5: " << findEqualSumIndex(test5) << std::endl;
    
    return 0;
}
```

```c
#include <stdio.h>
#include <stdlib.h>

int findEqualSumIndex(const int* arr, int size) {
    if (arr == NULL || size <= 0) {
        return -1;
    }
    
    long long totalSum = 0;
    for (int i = 0; i < size; i++) {
        totalSum += arr[i];
    }
    
    long long leftSum = 0;
    for (int i = 0; i < size; i++) {
        long long rightSum = totalSum - leftSum - arr[i];
        if (leftSum == rightSum) {
            return i;
        }
        leftSum += arr[i];
    }
    
    return -1;
}

int main() {
    int test1[] = {1, 2, 3, 4, 3, 2, 1};
    printf("Test 1: %d\n", findEqualSumIndex(test1, 7));
    
    int test2[] = {1, 100, 50, -51, 1, 1};
    printf("Test 2: %d\n", findEqualSumIndex(test2, 6));
    
    int test3[] = {20, 10, -80, 10, 10, 15, 35};
    printf("Test 3: %d\n", findEqualSumIndex(test3, 7));
    
    int test4[] = {1, 2, 3};
    printf("Test 4: %d\n", findEqualSumIndex(test4, 3));
    
    int test5[] = {0};
    printf("Test 5: %d\n", findEqualSumIndex(test5, 1));
    
    return 0;
}
```
