```python
def persistence(num: int) -> int:
    if num < 0:
        raise ValueError("Number must be positive")
    
    count = 0
    while num >= 10:
        product = 1
        temp = num
        while temp > 0:
            product *= temp % 10
            temp //= 10
        num = product
        count += 1
    return count

if __name__ == "__main__":
    print(persistence(39))   # Expected: 3
    print(persistence(999))  # Expected: 4
    print(persistence(4))    # Expected: 0
    print(persistence(25))   # Expected: 2
    print(persistence(10))   # Expected: 1
```

```cpp
#include <iostream>
#include <stdexcept>

int persistence(int num) {
    if (num < 0) {
        throw std::invalid_argument("Number must be positive");
    }
    
    int count = 0;
    while (num >= 10) {
        int product = 1;
        int temp = num;
        while (temp > 0) {
            product *= temp % 10;
            temp /= 10;
        }
        num = product;
        count++;
    }
    return count;
}

int main() {
    std::cout << persistence(39) << std::endl;   // Expected: 3
    std::cout << persistence(999) << std::endl;  // Expected: 4
    std::cout << persistence(4) << std::endl;    // Expected: 0
    std::cout << persistence(25) << std::endl;   // Expected: 2
    std::cout << persistence(10) << std::endl;   // Expected: 1
    return 0;
}
```

```c
#include <stdio.h>

int persistence(int num) {
    if (num < 0) {
        return -1; // Error case for negative input
    }
    
    int count = 0;
    while (num >= 10) {
        int product = 1;
        int temp = num;
        while (temp > 0) {
            product *= temp % 10;
            temp /= 10;
        }
        num = product;
        count++;
    }
    return count;
}

int main() {
    printf("%d\n", persistence(39));   // Expected: 3
    printf("%d\n", persistence(999));  // Expected: 4
    printf("%d\n", persistence(4));    // Expected: 0
    printf("%d\n", persistence(25));   // Expected: 2
    printf("%d\n", persistence(10));   // Expected: 1
    return 0;
}
```
