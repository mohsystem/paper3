```cpp
#include <iostream>
#include <vector>
#include <string>
#include <stdexcept>
#include <openssl/evp.h>
#include <openssl/rand.h>

class AESEncryptor {
private:
    static const int KEY_SIZE = 32;
    static const int IV_SIZE = 12;
    static const int TAG_SIZE = 16;

public:
    static std::vector<uint8_t> encryptData(const std::vector<uint8_t>& key, const std::vector<uint8_t>& data) {
        if (key.size() != KEY_SIZE) {
            throw std::invalid_argument("Key must be 32 bytes for AES-256");
        }
        if (data.empty()) {
            throw std::invalid_argument("Data to encrypt cannot be empty");
        }

        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) throw std::runtime_error("Failed to create cipher context");

        std::vector<uint8_t> iv(IV_SIZE);
        if (RAND_bytes(iv.data(), IV_SIZE) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to generate IV");
        }

        if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, nullptr, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to initialize encryption");
        }

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, IV_SIZE, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to set IV length");
        }

        if (EVP_EncryptInit_ex(ctx, nullptr, nullptr, key.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to set key and IV");
        }

        std::vector<uint8_t> ciphertext(data.size() + TAG_SIZE);
        int len = 0, ciphertext_len = 0;

        if (EVP_EncryptUpdate(ctx, ciphertext.data(), &len, data.data(), data.size()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to encrypt data");
        }
        ciphertext_len = len;

        if (EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to finalize encryption");
        }
        ciphertext_len += len;

        std::vector<uint8_t> tag(TAG_SIZE);
        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_SIZE, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to get authentication tag");
        }

        EVP_CIPHER_CTX_free(ctx);

        std::vector<uint8_t> result;
        result.reserve(IV_SIZE + ciphertext_len + TAG_SIZE);
        result.insert(result.end(), iv.begin(), iv.end());
        result.insert(result.end(), ciphertext.begin(), ciphertext.begin() + ciphertext_len);
        result.insert(result.end(), tag.begin(), tag.end());

        return result;
    }
};

int main() {
    try {
        std::vector<uint8_t> key(32);
        if (RAND_bytes(key.data(), 32) != 1) {
            std::cerr << "Failed to generate key" << std::endl;
            return 1;
        }

        std::vector<std::string> testData = {
            "Hello World",
            "Test data 123",
            "AES encryption test",
            "Another test case",
            "Final test string"
        };

        for (const auto& data : testData) {
            std::vector<uint8_t> dataBytes(data.begin(), data.end());
            auto encrypted = AESEncryptor::encryptData(key, dataBytes);
            std::cout << "Encrypted length: " << encrypted.size() << std::endl;
        }
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    return 0;
}
