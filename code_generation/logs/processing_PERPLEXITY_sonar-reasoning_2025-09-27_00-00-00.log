#include <iostream>
#include <vector>
#include <string>
#include <stdexcept>

std::vector<std::string> buildTower(int nFloors) {
    if (nFloors <= 0) {
        throw std::invalid_argument("Number of floors must be positive");
    }
    
    std::vector<std::string> tower;
    tower.reserve(nFloors);
    
    for (int floor = 1; floor <= nFloors; floor++) {
        int spaces = nFloors - floor;
        int stars = 2 * floor - 1;
        
        std::string floorStr;
        floorStr.reserve(2 * nFloors - 1);
        
        for (int i = 0; i < spaces; i++) {
            floorStr += " ";
        }
        for (int i = 0; i < stars; i++) {
            floorStr += "*";
        }
        for (int i = 0; i < spaces; i++) {
            floorStr += " ";
        }
        
        tower.push_back(floorStr);
    }
    
    return tower;
}

int main() {
    // Test case 1
    std::vector<std::string> tower1 = buildTower(1);
    std::cout << "Tower 1:" << std::endl;
    for (const auto& floor : tower1) {
        std::cout << "\"" << floor << "\"" << std::endl;
    }
    
    // Test case 2
    std::vector<std::string> tower2 = buildTower(3);
    std::cout << "\nTower 3:" << std::endl;
    for (const auto& floor : tower2) {
        std::cout << "\"" << floor << "\"" << std::endl;
    }
    
    // Test case 3
    std::vector<std::string> tower3 = buildTower(6);
    std::cout << "\nTower 6:" << std::endl;
    for (const auto& floor : tower3) {
        std::cout << "\"" << floor << "\"" << std::endl;
    }
    
    // Test case 4
    std::vector<std::string> tower4 = buildTower(4);
    std::cout << "\nTower 4:" << std::endl;
    for (const auto& floor : tower4) {
        std::cout << "\"" << floor << "\"" << std::endl;
    }
    
    // Test case 5
    std::vector<std::string> tower5 = buildTower(8);
    std::cout << "\nTower 8:" << std::endl;
    for (const auto& floor : tower5) {
        std::cout << "\"" << floor << "\"" << std::endl;
    }
    
    return 0;
}
