```python
import os
import threading
import tempfile
import shutil
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor
from typing import Dict

class FileProcessor:
    def __init__(self, base_directory: str):
        self.base_directory = Path(base_directory).resolve()
        self.file_locks: Dict[str, threading.Lock] = {}
        self.locks_lock = threading.Lock()
        self.executor = ThreadPoolExecutor(max_workers=4)
    
    def _is_valid_path(self, file_path: Path) -> bool:
        try:
            resolved_path = file_path.resolve()
            return resolved_path.is_relative_to(self.base_directory) and resolved_path.is_file()
        except (OSError, ValueError):
            return False
    
    def _get_file_lock(self, file_path: str) -> threading.Lock:
        with self.locks_lock:
            if file_path not in self.file_locks:
                self.file_locks[file_path] = threading.Lock()
            return self.file_locks[file_path]
    
    def process_file(self, filename: str) -> None:
        file_path = (self.base_directory / filename).resolve()
        
        if not self._is_valid_path(file_path):
            print(f"Invalid file: {filename}", file=os.sys.stderr)
            return
        
        file_lock = self._get_file_lock(str(file_path))
        
        def _process():
            with file_lock:
                try:
                    with tempfile.NamedTemporaryFile(mode='w', dir=self.base_directory, 
                                                   delete=False, prefix='temp_', suffix='.tmp') as temp_file:
                        with open(file_path, 'r', encoding='utf-8') as input_file:
                            for line in input_file:
                                temp_file.write(f"[PROCESSED] {line}")
                        temp_name = temp_file.name
                    
                    processed_path = self.base_directory / f"processed_{filename}"
                    shutil.move(temp_name, processed_path)
                    print(f"Thread {threading.get_ident()} processed: {filename}")
                    
                except Exception as e:
                    print(f"Error processing file {filename}: {e}", file=os.sys.stderr)
        
        self.executor.submit(_process)
    
    def shutdown(self) -> None:
        self.executor.shutdown(wait=True)

def main():
    with tempfile.TemporaryDirectory(prefix="fileprocessor_test_") as test_dir:
        processor = FileProcessor(test_dir)
        
        # Create test files
        for i in range(1, 6):
            test_file = Path(test_dir) / f"test{i}.txt"
            test_file.write_text(f"Content of file {i}")
            processor.process_file(f"test{i}.txt")
        
        processor.shutdown()

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <fstream>
#include <filesystem>
#include <thread>
#include <mutex>
#include <unordered_map>
#include <vector>
#include <memory>
#include <atomic>

class FileProcessor {
private:
    std::filesystem::path baseDirectory;
    std::unordered_map<std::string, std::unique_ptr<std::mutex>> fileLocks;
    std::mutex locksMapMutex;
    
    bool isValidPath(const std::filesystem::path& path) {
        try {
            auto canonicalPath = std::filesystem::canonical(path);
            auto canonicalBase = std::filesystem::canonical(baseDirectory);
            return canonicalPath.string().find(canonicalBase.string()) == 0 
                   && std::filesystem::is_regular_file(canonicalPath);
        } catch (const std::filesystem::filesystem_error&) {
            return false;
        }
    }
    
    std::mutex* getFileLock(const std::string& filePath) {
        std::lock_guard<std::mutex> lock(locksMapMutex);
        if (fileLocks.find(filePath) == fileLocks.end()) {
            fileLocks[filePath] = std::make_unique<std::mutex>();
        }
        return fileLocks[filePath].get();
    }

public:
    FileProcessor(const std::string& baseDir) : baseDirectory(baseDir) {
        baseDirectory = std::filesystem::canonical(baseDirectory);
    }
    
    void processFile(const std::string& filename) {
        auto filePath = baseDirectory / filename;
        
        if (!isValidPath(filePath)) {
            std::cerr << "Invalid file: " << filename << std::endl;
            return;
        }
        
        std::mutex* fileLock = getFileLock(filePath.string());
        
        std::thread([this, filePath, filename, fileLock]() {
            std::lock_guard<std::mutex> lock(*fileLock);
            
            try {
                auto tempPath = baseDirectory / ("temp_" + filename);
                std::ifstream inputFile(filePath);
                std::ofstream tempFile(tempPath);
                
                if (!inputFile.is_open() || !tempFile.is_open()) {
                    throw std::runtime_error("Failed to open files");
                }
                
                std::string line;
                while (std::getline(inputFile, line)) {
                    tempFile << "[PROCESSED] " << line << std::endl;
                }
                
                inputFile.close();
                tempFile.close();
                
                auto processedPath = baseDirectory / ("processed_" + filename);
                std::filesystem::rename(tempPath, processedPath);
                
                std::cout << "Thread " << std::this_thread::get_id() 
                         << " processed: " << filename << std::endl;
                         
            } catch (const std::exception& e) {
                std::cerr << "Error processing file " << filename 
                         << ": " << e.what() << std::endl;
            }
        }).detach();
    }
};

int main() {
    try {
        auto tempDir = std::filesystem::temp_directory_path() / "fileprocessor_test";
        std::filesystem::create_directories(tempDir);
        
        FileProcessor processor(tempDir.string());
        
        // Create test files
        for (int i = 1; i <= 5; ++i) {
            std::string filename = "test" + std::to_string(i) + ".txt";
            auto testFile = tempDir / filename;
            std::ofstream file(testFile);
            file << "Content of file " << i << std::endl;
            file.close();
            
            processor.processFile(filename);
        }
        
        // Wait for processing to complete
        std::this_thread::sleep_for(std::chrono::seconds(2));
        
        // Cleanup
        std::filesystem::remove_all(tempDir);
        
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
