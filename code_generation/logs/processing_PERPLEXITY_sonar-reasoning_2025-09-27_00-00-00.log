```java
public class Task24 {
    public static boolean isValidPin(String pin) {
        // Input validation
        if (pin == null) {
            return false;
        }
        
        // Check length (must be exactly 4 or 6)
        int length = pin.length();
        if (length != 4 && length != 6) {
            return false;
        }
        
        // Check if all characters are digits
        for (int i = 0; i < length; i++) {
            char c = pin.charAt(i);
            if (c < '0' || c > '9') {
                return false;
            }
        }
        
        return true;
    }
    
    public static void main(String[] args) {
        // Test cases
        System.out.println(isValidPin("1234"));   // true
        System.out.println(isValidPin("12345"));  // false
        System.out.println(isValidPin("a234"));   // false
        System.out.println(isValidPin("123456")); // true
        System.out.println(isValidPin(null));     // false
    }
}
```

```python
def is_valid_pin(pin: str) -> bool:
    # Input validation
    if pin is None:
        return False
    
    # Check length (must be exactly 4 or 6)
    length = len(pin)
    if length != 4 and length != 6:
        return False
    
    # Check if all characters are digits
    for char in pin:
        if not char.isdigit():
            return False
    
    return True

def main():
    # Test cases
    print(is_valid_pin("1234"))   # True
    print(is_valid_pin("12345"))  # False
    print(is_valid_pin("a234"))   # False
    print(is_valid_pin("123456")) # True
    print(is_valid_pin(None))     # False

if __name__ == "__main__":
    main()
```

```cpp
#include <iostream>
#include <string>

bool isValidPin(const std::string& pin) {
    // Check length (must be exactly 4 or 6)
    size_t length = pin.length();
    if (length != 4 && length != 6) {
        return false;
    }
    
    // Check if all characters are digits
    for (size_t i = 0; i < length; i++) {
        char c = pin[i];
        if (c < '0' || c > '9') {
            return false;
        }
    }
    
    return true;
}

int main() {
    // Test cases
    std::cout << std::boolalpha;
    std::cout << isValidPin("1234") << std::endl;   // true
    std::cout << isValidPin("12345") << std::endl;  // false
    std::cout << isValidPin("a234") << std::endl;   // false
    std::cout << isValidPin("123456") << std::endl; // true
    std::cout << isValidPin("") << std::endl;       // false
    
    return 0;
}
```

```c
#include <stdio.h>
#include <string.h>
#include <stdbool.h>

bool isValidPin(const char* pin) {
    // Input validation
    if (pin == NULL) {
        return false;
    }
    
    // Check length (must be exactly 4 or 6)
    size_t length = strlen(pin);
    if (length != 4 && length != 6) {
        return false;
    }
    
    // Check if all characters are digits
    for (size_t i = 0; i < length; i++) {
        char c = pin[i];
        if (c < '0' || c > '9') {
            return false;
        }
    }
    
    return true;
}

int main() {
    // Test cases
    printf("%s\n", isValidPin("1234") ? "true" : "false");   // true
    printf("%s\n", isValidPin("12345") ? "true" : "false");  // false
    printf("%s\n", isValidPin("a234") ? "true" : "false");   // false
    printf("%s\n", isValidPin("123456") ? "true" : "false"); // true
    printf("%s\n", isValidPin(NULL) ? "true" : "false");     // false
    
    return 0;
}
```
