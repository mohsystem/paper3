```c
#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

int* removeSmallest(int* arr, int size, int* resultSize) {
    if (arr == NULL || size <= 0) {
        *resultSize = 0;
        return NULL;
    }
    
    if (size == 1) {
        *resultSize = 0;
        return NULL;
    }
    
    // Find minimum value and its first index
    int minValue = arr;
    int minIndex = 0;
    for (int i = 1; i < size; i++) {
        if (arr[i] < minValue) {
            minValue = arr[i];
            minIndex = i;
        }
    }
    
    // Allocate memory for result
    int* result = (int*)malloc((size - 1) * sizeof(int));
    if (result == NULL) {
        *resultSize = 0;
        return NULL;
    }
    
    // Copy elements except the one at minIndex
    int resultIndex = 0;
    for (int i = 0; i < size; i++) {
        if (i != minIndex) {
            result[resultIndex++] = arr[i];
        }
    }
    
    *resultSize = size - 1;
    return result;
}

void printArray(int* arr, int size) {
    for (int i = 0; i < size; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
}

int main() {
    int resultSize;
    int* result;
    
    // Test case 1
    int test1[] = {1, 2, 3, 4, 5};
