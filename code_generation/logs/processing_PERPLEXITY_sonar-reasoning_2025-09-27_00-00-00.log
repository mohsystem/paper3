```cpp
#include <iostream>
#include <vector>
#include <algorithm>

std::vector<int> removeSmallest(const std::vector<int>& arr) {
    if (arr.empty()) {
        return std::vector<int>();
    }
    
    // Find minimum value and its first index
    auto minIt = std::min_element(arr.begin(), arr.end());
    int minIndex = std::distance(arr.begin(), minIt);
    
    // Create new vector without the element at minIndex
    std::vector<int> result;
    result.reserve(arr.size() - 1);
    for (size_t i = 0; i < arr.size(); ++i) {
        if (static_cast<int>(i) != minIndex) {
            result.push_back(arr[i]);
        }
    }
    
    return result;
}

int main() {
    // Test case 1
    std::vector<int> test1 = {1, 2, 3, 4, 5};
    auto result1 = removeSmallest(test1);
    for (int val : result1) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 2
    std::vector<int> test2 = {5, 3, 2, 1, 4};
    auto result2 = removeSmallest(test2);
    for (int val : result2) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 3
    std::vector<int> test3 = {2, 2, 1, 2, 1};
    auto result3 = removeSmallest(test3);
    for (int val : result3) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 4
    std::vector<int> test4 = {};
    auto result4 = removeSmallest(test4);
    for (int val : result4) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 5
    std::vector<int> test5 = {7};
    auto result5 = removeSmallest(test5);
    for (int val : result5) std::cout << val << " ";
    std::cout << std::endl;
    
    return 0;
}
