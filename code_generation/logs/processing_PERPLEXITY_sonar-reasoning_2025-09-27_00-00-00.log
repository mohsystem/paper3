```cpp
#include <iostream>
#include <vector>
#include <variant>
#include <string>

class Kata {
public:
    static std::vector<int> filterList(const std::vector<std::variant<int, std::string>>& input) {
        std::vector<int> result;
        
        for (const auto& item : input) {
            if (std::holds_alternative<int>(item)) {
                int value = std::get<int>(item);
                if (value >= 0) {
                    result.push_back(value);
                }
            }
        }
        
        return result;
    }
};

int main() {
    // Test case 1
    std::vector<std::variant<int, std::string>> test1 = {1, 2, std::string("a"), std::string("b")};
    auto result1 = Kata::filterList(test1);
    std::cout << "Test 1: ";
    for (int val : result1) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 2
    std::vector<std::variant<int, std::string>> test2 = {1, std::string("a"), std::string("b"), 0, 15};
    auto result2 = Kata::filterList(test2);
    std::cout << "Test 2: ";
    for (int val : result2) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 3
    std::vector<std::variant<int, std::string>> test3 = {1, 2, std::string("a"), std::string("b"), std::string("aasf"), std::string("1"), std::string("123"), 123};
    auto result3 = Kata::filterList(test3);
    std::cout << "Test 3: ";
    for (int val : result3) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 4
    std::vector<std::variant<int, std::string>> test4 = {std::string("hello"), std::string("world"), 42, 100};
    auto result4 = Kata::filterList(test4);
    std::cout << "Test 4: ";
    for (int val : result4) std::cout << val << " ";
    std::cout << std::endl;
    
    // Test case 5
    std::vector<std::variant<int, std::string>> test5 = {};
    auto result5 = Kata::filterList(test5);
    std::cout << "Test 5: ";
    for (int val : result5) std::cout << val << " ";
    std::cout << std::endl;
    
    return 0;
}
