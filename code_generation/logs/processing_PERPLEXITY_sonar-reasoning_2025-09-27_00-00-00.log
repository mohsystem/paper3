```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <pthread.h>
#include <unistd.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <errno.h>
#include <limits.h>

#define MAX_PATH_LEN 256
#define MAX_FILES 100
#define MAX_THREADS 4

typedef struct {
    char filename[MAX_PATH_LEN];
    char base_directory[MAX_PATH_LEN];
    pthread_mutex_t* file_mutex;
} ProcessTask;

static pthread_mutex_t file_mutexes[MAX_FILES];
static char tracked_files[MAX_FILES][MAX_PATH_LEN];
static int file_count = 0;
static pthread_mutex_t tracking_mutex = PTHREAD_MUTEX_INITIALIZER;

int is_valid_path(const char* base_dir, const char* filename, char* full_path) {
    if (!base_dir || !filename || !full_path) return 0;
    
    if (strlen(base_dir) + strlen(filename) + 2 >= MAX_PATH_LEN) return 0;
    
    if (strchr(filename, '/') || strchr(filename, '\\') || 
        strstr(filename, "..") || strstr(filename, "~")) return 0;
    
    snprintf(full_path, MAX_PATH_LEN, "%s/%s", base_dir, filename);
    
    struct stat st;
    return (stat(full_path, &st) == 0 && S_ISREG(st.st_mode));
}

pthread_mutex_t* get_file_mutex(const char* filepath) {
    pthread_mutex_lock(&tracking_mutex);
    
    for (int i = 0; i < file_count; i++) {
        if (strcmp(tracked_files[i], filepath) == 0) {
            pthread_mutex_unlock(&tracking_mutex);
            return &file_mutexes[i];
        }
    }
    
    if (file_count < MAX_FILES) {
        strncpy(tracked_files[file_count], filepath, MAX_PATH_LEN - 1);
        tracked_files[file_count][MAX_PATH_LEN - 1] = '\0';
        pthread_mutex_init(&file_mutexes[file_count], NULL);
        pthread_mutex_t* result = &file_mutexes[file_count];
        file_count++;
        pthread_mutex_unlock(&tracking_mutex);
        return result;
    }
    
    pthread_mutex_unlock(&tracking_mutex);
    return NULL;
}

void* process_file_thread(void* arg) {
    ProcessTask* task = (ProcessTask*)arg;
    char full_path[MAX_PATH_LEN];
    char temp_path[MAX_PATH_LEN];
    char processed_path[MAX_PATH_LEN];
    
    if (!is_valid_path(task->base_directory, task->filename, full_path)) {
        fprintf(stderr, "Invalid file: %s\n", task->filename);
        free(task);
        return NULL;
    }
    
    pthread_mutex_t* file_mutex = get_file_mutex(full_path);
    if (!file_mutex) {
        fprintf(stderr, "Failed to get mutex for file: %s\n", task->filename);
        free(task);
        return NULL;
    }
    
    pthread_mutex_lock(file_mutex);
    
    snprintf(temp_path, MAX_PATH_LEN, "%s/temp_%s", task->base_directory, task->filename);
    snprintf(processed_path, MAX_PATH_LEN, "%s/processed_%s", task->base_directory, task->filename);
    
    FILE* input_file = fopen(full_path, "r");
    FILE* temp_file = fopen(temp_path, "w");
    
    if (!input_file || !temp_file) {
        fprintf(stderr, "Failed to open files for: %s\n", task->filename);
        if (input_file) fclose(input_file);
        if (temp_file) fclose(temp_file);
        pthread_mutex_unlock(file_mutex);
        free(task);
        return NULL;
    }
    
    char line[1024];
    while (fgets(line, sizeof(line), input_file)) {
        fprintf(temp_file, "[PROCESSED] %s", line);
    }
    
    fclose(input_file);
    fclose(temp_file);
    
    if (rename(temp_path, processed_path) == 0) {
        printf("Thread %lu processed: %s\n", pthread_self(), task->filename);
    } else {
        fprintf(stderr, "Failed to rename file: %s\n", task->filename);
        unlink(temp_path);
    }
    
    pthread_mutex_unlock(file_mutex);
    free(task);
    return NULL;
}

void process_file(const char* base_directory, const char* filename) {
    ProcessTask* task = malloc(sizeof(ProcessTask));
    if (!task) return;
    
    strncpy(task->filename, filename, MAX_PATH_LEN - 1);
    task->filename[MAX_PATH_LEN - 1] = '\0';
    strncpy(task->base_directory, base_directory, MAX_PATH_LEN - 1);
    task->base_directory[MAX_PATH_LEN - 1] = '\0';
    
    pthread_t thread;
    if (pthread_create(&thread, NULL, process_file_thread, task) != 0) {
        fprintf(stderr, "Failed to create thread for: %s\n", filename);
        free(task);
    } else {
        pthread_detach(thread);
    }
}

int main() {
    char temp_dir[] = "/tmp/fileprocessor_test_XXXXXX";
    if (!mkdtemp(temp_dir)) {
        perror("mkdtemp");
        return 1;
    }
    
    // Create test files
    for (int i = 1; i <= 5; i++) {
        char filename[64];
        char filepath[MAX_PATH_LEN];
        snprintf(filename, sizeof(filename), "test%d.txt", i);
        snprintf(filepath, sizeof(filepath), "%s/%s", temp_dir, filename);
        
        FILE* file = fopen(filepath, "w");
        if (file) {
            fprintf(file, "Content of file %d\n", i);
            fclose(file);
            process_file(temp_dir, filename);
        }
    }
    
    sleep(2);  // Wait for processing to complete
    
    // Cleanup
    char rm_command[MAX_PATH_LEN + 16];
    snprintf(rm_command, sizeof(rm_command), "rm -rf %s", temp_dir);
    system(rm_command);
    
    return 0;
}
