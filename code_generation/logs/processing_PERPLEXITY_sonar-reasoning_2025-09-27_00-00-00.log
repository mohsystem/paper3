public class Task1 {
    public static int countPeopleOnBus(int[][] busStops) {
        if (busStops == null || busStops.length == 0) {
            return 0;
        }
        
        int peopleOnBus = 0;
        for (int i = 0; i < busStops.length; i++) {
            if (busStops[i] == null || busStops[i].length != 2) {
                continue;
            }
            int getOn = busStops[i][0];
            int getOff = busStops[i][1];
            
            if (getOn < 0 || getOff < 0) {
                continue;
            }
            
            peopleOnBus += getOn - getOff;
            
            if (peopleOnBus < 0) {
                peopleOnBus = 0;
            }
        }
        return peopleOnBus;
    }
    
    public static void main(String[] args) {
        int[][] test1 = {{10, 0}, {3, 5}, {5, 8}};
        System.out.println("Test 1: " + countPeopleOnBus(test1));
        
        int[][] test2 = {{3, 0}, {9, 1}, {4, 10}, {12, 2}, {6, 1}, {7, 10}};
        System.out.println("Test 2: " + countPeopleOnBus(test2));
        
