```c
#include <stdio.h>
#include <stdlib.h>

int findOddOccurrence(int arr[], int size) {
    if (arr == NULL || size <= 0) {
        fprintf(stderr, "Invalid input: array is NULL or size is non-positive\n");
        exit(1);
    }
    
    int result = 0;
    for (int i = 0; i < size; i++) {
        result ^= arr[i];
    }
    return result;
}

int main() {
    // Test case 1: [7] should return 7
    int test1[] = {7};
    printf("Test 1: %d\n", findOddOccurrence(test1, 1));
    
    // Test case 2:  should return 0
    int test2[] = {0};
    printf("Test 2: %d\n", findOddOccurrence(test2, 1));
    
    // Test case 3: [1,1,2] should return 2
