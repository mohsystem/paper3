#include <stdbool.h>

bool isValidWalk(char directions[][2], int length) {
    if (length != 10) {
        return false;
    }
    
    int x = 0, y = 0;
    
    for (int i = 0; i < length; i++) {
        if (strlen(directions[i]) != 1) {
            return false;
        }
        
        char dir = directions[i][0];
        switch (dir) {
            case 'n': y++; break;
            case 's': y--; break;
            case 'e': x++; break;
            case 'w': x--; break;
            default: return false;
        }
    }
    
    return x == 0 && y == 0;
}

int main() {
    char test1[][2] = {"n", "s", "n", "s", "n", "s", "n", "s", "n", "s"};
    char test2[][2] = {"e", "w", "e", "w", "n", "s", "n", "s", "e", "w"};
