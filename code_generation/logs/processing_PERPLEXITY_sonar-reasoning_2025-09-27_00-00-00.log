```python
def find_outlier(arr):
    if not arr or len(arr) < 3:
        raise ValueError("Array must not be empty and have at least 3 elements")
    
    even_count = 0
    odd_count = 0
    last_even = None
    last_odd = None
    
    for num in arr:
        if num % 2 == 0:
            even_count += 1
            last_even = num
        else:
            odd_count += 1
            last_odd = num
    
    if even_count == 1:
        return last_even
    else:
        return last_odd

def main():
    print(find_outlier([2, 4, 0, 100, 4, 11, 2602, 36]))  # 11
    print(find_outlier([160, 3, 1719, 19, 11, 13, -21]))  # 160
    print(find_outlier([1, 2, 3]))  # 2
    print(find_outlier([2, 6, 8, -10, 3]))  # 3
    print(find_outlier([1, 1, 0]))  # 0

if __name__ == "__main__":
    main()
