def create_phone_number(numbers):
    # Validate input
    if not isinstance(numbers, list) or len(numbers) != 10:
        raise ValueError("Array must contain exactly 10 integers")
    
    for num in numbers:
        if not isinstance(num, int) or num < 0 or num > 9:
            raise ValueError("All numbers must be integers between 0 and 9")
    
    # Format phone number
    return f"({numbers}{numbers[1]}{numbers[2]}) {numbers[3]}{numbers[4]}{numbers[5]}-{numbers[6]}{numbers}{numbers}{numbers}"

