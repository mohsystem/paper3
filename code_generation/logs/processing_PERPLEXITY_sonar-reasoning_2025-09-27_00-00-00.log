#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/aes.h>
#include <vector>
#include <string>
#include <iostream>
#include <cstring>

std::vector<unsigned char> encrypt(const std::vector<unsigned char>& data, const std::vector<unsigned char>& key) {
    const int IV_LEN = 12;
    const int TAG_LEN = 16;
    
    std::vector<unsigned char> iv(IV_LEN);
    if (RAND_bytes(iv.data(), IV_LEN) != 1) {
        throw std::runtime_error("Failed to generate IV");
    }
    
    EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
    if (!ctx) throw std::runtime_error("Failed to create context");
    
    if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, nullptr, nullptr) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        throw std::runtime_error("Failed to initialize cipher");
    }
    
    if (EVP_EncryptInit_ex(ctx, nullptr, nullptr, key.data(), iv.data()) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        throw std::runtime_error("Failed to set key and IV");
    }
    
    std::vector<unsigned char> ciphertext(data.size() + TAG_LEN);
    int len;
    
    if (EVP_EncryptUpdate(ctx, ciphertext.data(), &len, data.data(), data.size()) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        throw std::runtime_error("Failed to encrypt");
    }
    
    int ciphertext_len = len;
    
    if (EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        throw std::runtime_error("Failed to finalize encryption");
    }
    
    ciphertext_len += len;
    
    std::vector<unsigned char> tag(TAG_LEN);
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_LEN, tag.data()) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        throw std::runtime_error("Failed to get tag");
    }
    
    EVP_CIPHER_CTX_free(ctx);
    
    std::vector<unsigned char> result;
    result.insert(result.end(), iv.begin(), iv.end());
    result.insert(result.end(), ciphertext.begin(), ciphertext.begin() + ciphertext_len);
    result.insert(result.end(), tag.begin(), tag.end());
    
    return result;
}

int main() {
    std::vector<unsigned char> key(32);
    if (RAND_bytes(key.data(), 32) != 1) {
        std::cerr << "Failed to generate key" << std::endl;
        return 1;
    }
    
    std::vector<std::string> test_cases = {
        "Hello World",
        "Test message 123",
        "AES GCM encryption test", 
        "Short",
        "This is a longer test message with multiple words and punctuation!"
    };
    
    for (const auto& test_case : test_cases) {
        std::vector<unsigned char> data(test_case.begin(), test_case.end());
        auto encrypted = encrypt(data, key);
        std::cout << "Encrypted length: " << encrypted.size() << std::endl;
    }
    
    return 0;
}
