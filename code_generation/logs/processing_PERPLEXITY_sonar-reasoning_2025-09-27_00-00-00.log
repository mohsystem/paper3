#include <iostream>
#include <vector>
#include <string>

std::vector<std::string> addLineNumbers(const std::vector<std::string>& lines) {
    std::vector<std::string> result;
    
    for (size_t i = 0; i < lines.size(); ++i) {
        result.push_back(std::to_string(i + 1) + ": " + lines[i]);
    }
    
    return result;
}

int main() {
    // Test case 1: Empty vector
    std::vector<std::string> test1 = {};
    auto result1 = addLineNumbers(test1);
    std::cout << "Test 1: ";
