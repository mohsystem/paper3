#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/kdf.h>
#include <iostream>
#include <fstream>
#include <vector>
#include <string>
#include <memory>
#include <cstring>

class FileEncryption {
private:
    static const size_t SALT_SIZE = 16;
    static const size_t IV_SIZE = 12;
    static const size_t TAG_SIZE = 16;
    static const size_t KEY_SIZE = 32;
    static const int PBKDF2_ITERATIONS = 210000;
    static const char MAGIC[5];
    static const uint32_t VERSION = 1;

    static std::vector<uint8_t> deriveKey(const std::string& password, const std::vector<uint8_t>& salt) {
        std::vector<uint8_t> key(KEY_SIZE);
        EVP_KDF* kdf = EVP_KDF_fetch(nullptr, "PBKDF2", nullptr);
        if (!kdf) return {};
        
        EVP_KDF_CTX* ctx = EVP_KDF_CTX_new(kdf);
        if (!ctx) {
            EVP_KDF_free(kdf);
            return {};
        }

        OSSL_PARAM params[] = {
            OSSL_PARAM_construct_utf8_string("pass", const_cast<char*>(password.c_str()), password.length()),
            OSSL_PARAM_construct_octet_string("salt", const_cast<unsigned char*>(salt.data()), salt.size()),
            OSSL_PARAM_construct_int("iter", const_cast<int*>(&PBKDF2_ITERATIONS)),
            OSSL_PARAM_construct_utf8_string("digest", const_cast<char*>("SHA256"), 0),
            OSSL_PARAM_construct_end()
        };

        int ret = EVP_KDF_derive(ctx, key.data(), key.size(), params);
        EVP_KDF_CTX_free(ctx);
        EVP_KDF_free(kdf);
        
        return ret == 1 ? key : std::vector<uint8_t>{};
    }

public:
    static bool encryptFile(const std::string& inputPath, const std::string& outputPath, const std::string& password) {
        if (inputPath.empty() || outputPath.empty() || password.empty()) return false;
        
        std::ifstream inFile(inputPath, std::ios::binary);
        if (!inFile) return false;

        std::vector<uint8_t> plaintext((std::istreambuf_iterator<char>(inFile)), std::istreambuf_iterator<char>());
        inFile.close();

        std::vector<uint8_t> salt(SALT_SIZE);
        std::vector<uint8_t> iv(IV_SIZE);
        if (RAND_bytes(salt.data(), salt.size()) != 1 || RAND_bytes(iv.data(), iv.size()) != 1) return false;

        std::vector<uint8_t> key = deriveKey(password, salt);
        if (key.empty()) return false;

        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) return false;

        if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, nullptr, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, IV_SIZE, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        if (EVP_EncryptInit_ex(ctx, nullptr, nullptr, key.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        std::vector<uint8_t> ciphertext(plaintext.size());
        int len, ciphertext_len = 0;

        if (EVP_EncryptUpdate(ctx, ciphertext.data(), &len, plaintext.data(), plaintext.size()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }
        ciphertext_len = len;

        if (EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }
        ciphertext_len += len;
        ciphertext.resize(ciphertext_len);

        std::vector<uint8_t> tag(TAG_SIZE);
        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_SIZE, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        EVP_CIPHER_CTX_free(ctx);
        OPENSSL_cleanse(key.data(), key.size());

        std::ofstream outFile(outputPath, std::ios::binary);
        if (!outFile) return false;

        outFile.write(MAGIC, 4);
        uint32_t version = VERSION;
        outFile.write(reinterpret_cast<const char*>(&version), sizeof(version));
        outFile.write(reinterpret_cast<const char*>(salt.data()), salt.size());
        outFile.write(reinterpret_cast<const char*>(iv.data()), iv.size());
        outFile.write(reinterpret_cast<const char*>(ciphertext.data()), ciphertext.size());
        outFile.write(reinterpret_cast<const char*>(tag.data()), tag.size());

        return outFile.good();
    }

    static bool decryptFile(const std::string& inputPath, const std::string& outputPath, const std::string& password) {
        if (inputPath.empty() || outputPath.empty() || password.empty()) return false;
        
        std::ifstream inFile(inputPath, std::ios::binary);
        if (!inFile) return false;

        char magic[5] = {0};
        uint32_t version;
        inFile.read(magic, 4);
        inFile.read(reinterpret_cast<char*>(&version), sizeof(version));

        if (std::string(magic) != "ENC1" || version != VERSION) {
            inFile.close();
            return false;
        }

        std::vector<uint8_t> salt(SALT_SIZE);
        std::vector<uint8_t> iv(IV_SIZE);
        inFile.read(reinterpret_cast<char*>(salt.data()), salt.size());
        inFile.read(reinterpret_cast<char*>(iv.data()), iv.size());

        std::vector<uint8_t> ciphertext((std::istreambuf_iterator<char>(inFile)), std::istreambuf_iterator<char>());
        inFile.close();

        if (ciphertext.size() < TAG_SIZE) return false;

        std::vector<uint8_t> tag(ciphertext.end() - TAG_SIZE, ciphertext.end());
        ciphertext.resize(ciphertext.size() - TAG_SIZE);

        std::vector<uint8_t> key = deriveKey(password, salt);
        if (key.empty()) return false;

        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) return false;

        if (EVP_DecryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, nullptr, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, IV_SIZE, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        if (EVP_DecryptInit_ex(ctx, nullptr, nullptr, key.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        std::vector<uint8_t> plaintext(ciphertext.size());
        int len, plaintext_len = 0;

        if (EVP_DecryptUpdate(ctx, plaintext.data(), &len, ciphertext.data(), ciphertext.size()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }
        plaintext_len = len;

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_TAG, TAG_SIZE, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        if (EVP_DecryptFinal_ex(ctx, plaintext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }
        plaintext_len += len;
        plaintext.resize(plaintext_len);

        EVP_CIPHER_CTX_free(ctx);
        OPENSSL_cleanse(key.data(), key.size());

        std::ofstream outFile(outputPath, std::ios::binary);
        if (!outFile) return false;

        outFile.write(reinterpret_cast<const char*>(plaintext.data()), plaintext.size());
        return outFile.good();
    }
};

const char FileEncryption::MAGIC[5] = "ENC1";

int main() {
    std::cout << "File Encryption Test Cases:\n";

    std::ofstream testFile("test.txt");
    testFile << "Hello, World This is a test file for encryption.";
    testFile.close();

    // Test Case 1: Basic encryption and decryption
    bool result1 = FileEncryption::encryptFile("test.txt", "test.enc", "password123");
    bool result2 = FileEncryption::decryptFile("test.enc", "test_decrypted.txt", "password123");
    std::cout << "Test 1 (Basic): " << (result1 && result2 ? "PASS" : "FAIL") << std::endl;

    // Test Case 2: Wrong password
    bool result3 = FileEncryption::decryptFile("test.enc", "test_wrong.txt", "wrongpassword");
    std::cout << "Test 2 (Wrong password): " << (!result3 ? "PASS" : "FAIL") << std::endl;

    // Test Case 3: Empty password
    bool result4 = FileEncryption::encryptFile("test.txt", "test_empty.enc", "");
    std::cout << "Test 3 (Empty password): " << (!result4 ? "PASS" : "FAIL") << std::endl;

    // Test Case 4: Non-existent input file
    bool result5 = FileEncryption::encryptFile("nonexistent.txt", "output.enc", "password");
    std::cout << "Test 4 (Non-existent file): " << (!result5 ? "PASS" : "FAIL") << std::endl;

    // Test Case 5: Large password
    std::string largePassword(1000, 'x');
    bool result6 = FileEncryption::encryptFile("test.txt", "test_large.enc", largePassword);
    bool result7 = FileEncryption::decryptFile("test_large.enc", "test_large_dec.txt", largePassword);
    std::cout << "Test 5 (Large password): " << (result6 && result7 ? "PASS" : "FAIL") << std::endl;

    return 0;
}
