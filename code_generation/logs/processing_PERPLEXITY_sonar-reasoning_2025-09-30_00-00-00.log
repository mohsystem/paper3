#include <iostream>
#include <string>
#include <fstream>
#include <sstream>
#include <cstring>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>
#include <thread>
#include <vector>
#include <algorithm>

#define MAX_BUFFER_SIZE 1024
#define MAX_USERNAME_LENGTH 50
#define MAX_PASSWORD_LENGTH 100
#define SERVER_PORT 8080

class ChatServer {
private:
    int server_socket;
    std::vector<int> client_sockets;
    
    bool validateInput(const std::string& input, size_t maxLength) {
        return !input.empty() && input.length() <= maxLength && 
               input.find('\n') == std::string::npos && input.find('\r') == std::string::npos;
    }
    
    bool authenticateUser(const std::string& username, const std::string& password) {
        if (!validateInput(username, MAX_USERNAME_LENGTH) || !validateInput(password, MAX_PASSWORD_LENGTH)) {
            return false;
        }
        
        std::ifstream credFile("credentials.txt");
        if (!credFile.is_open()) {
            return false;
        }
        
        std::string line, fileUser, filePass;
        while (std::getline(credFile, line)) {
            std::istringstream iss(line);
            if (std::getline(iss, fileUser, ':') && std::getline(iss, filePass)) {
                if (fileUser == username && filePass == password) {
                    credFile.close();
                    return true;
                }
            }
        }
        credFile.close();
        return false;
    }
    
    void handleClient(int clientSocket) {
        char buffer[MAX_BUFFER_SIZE];
        memset(buffer, 0, sizeof(buffer));
        
        ssize_t bytesReceived = recv(clientSocket, buffer, sizeof(buffer) - 1, 0);
        if (bytesReceived <= 0) {
            close(clientSocket);
            return;
        }
        
        buffer[bytesReceived] = '\0';
        std::string request(buffer);
        
        size_t delimPos = request.find(':');
        if (delimPos == std::string::npos) {
            const char* response = "INVALID_FORMAT";
            send(clientSocket, response, strlen(response), 0);
            close(clientSocket);
            return;
        }
        
        std::string username = request.substr(0, delimPos);
        std::string password = request.substr(delimPos + 1);
        
        if (authenticateUser(username, password)) {
            const char* response = "AUTH_SUCCESS";
            send(clientSocket, response, strlen(response), 0);
            client_sockets.push_back(clientSocket);
            
            // Handle chat messages
            while (true) {
                memset(buffer, 0, sizeof(buffer));
                bytesReceived = recv(clientSocket, buffer, sizeof(buffer) - 1, 0);
                if (bytesReceived <= 0) break;
                
                buffer[bytesReceived] = '\0';
                std::string message = username + ": " + std::string(buffer);
                
                // Broadcast to all clients
                for (int sock : client_sockets) {
                    if (sock != clientSocket) {
                        send(sock, message.c_str(), message.length(), 0);
                    }
                }
            }
        } else {
            const char* response = "AUTH_FAILED";
            send(clientSocket, response, strlen(response), 0);
        }
        
        close(clientSocket);
        client_sockets.erase(std::remove(client_sockets.begin(), client_sockets.end(), clientSocket), client_sockets.end());
    }
    
public:
    bool startServer() {
        server_socket = socket(AF_INET, SOCK_STREAM, 0);
        if (server_socket < 0) {
            return false;
        }
        
        int opt = 1;
        setsockopt(server_socket, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));
        
        struct sockaddr_in server_addr;
        memset(&server_addr, 0, sizeof(server_addr));
        server_addr.sin_family = AF_INET;
        server_addr.sin_addr.s_addr = INADDR_ANY;
        server_addr.sin_port = htons(SERVER_PORT);
        
        if (bind(server_socket, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
            close(server_socket);
            return false;
        }
        
        if (listen(server_socket, 5) < 0) {
            close(server_socket);
            return false;
        }
        
        return true;
    }
    
    void acceptConnections() {
        while (true) {
            struct sockaddr_in client_addr;
            socklen_t client_len = sizeof(client_addr);
            int client_socket = accept(server_socket, (struct sockaddr*)&client_addr, &client_len);
            
            if (client_socket >= 0) {
                std::thread clientThread(&ChatServer::handleClient, this, client_socket);
                clientThread.detach();
            }
        }
    }
    
    ~ChatServer() {
        if (server_socket >= 0) {
            close(server_socket);
        }
    }
};

class ChatClient {
private:
    int client_socket;
    
    bool validateInput(const std::string& input, size_t maxLength) {
        return !input.empty() && input.length() <= maxLength && 
               input.find('\n') == std::string::npos && input.find('\r') == std::string::npos;
    }
    
public:
    bool connectToServer(const std::string& serverIP) {
        client_socket = socket(AF_INET, SOCK_STREAM, 0);
        if (client_socket < 0) {
            return false;
        }
        
        struct sockaddr_in server_addr;
        memset(&server_addr, 0, sizeof(server_addr));
        server_addr.sin_family = AF_INET;
        server_addr.sin_port = htons(SERVER_PORT);
        
        if (inet_pton(AF_INET, serverIP.c_str(), &server_addr.sin_addr) <= 0) {
            close(client_socket);
            return false;
        }
        
        if (connect(client_socket, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
            close(client_socket);
            return false;
        }
        
        return true;
    }
    
    bool authenticate(const std::string& username, const std::string& password) {
        if (!validateInput(username, MAX_USERNAME_LENGTH) || !validateInput(password, MAX_PASSWORD_LENGTH)) {
            return false;
        }
        
        std::string credentials = username + ":" + password;
        if (send(client_socket, credentials.c_str(), credentials.length(), 0) < 0) {
            return false;
        }
        
        char response[MAX_BUFFER_SIZE];
        memset(response, 0, sizeof(response));
        ssize_t bytesReceived = recv(client_socket, response, sizeof(response) - 1, 0);
        
        if (bytesReceived > 0) {
            response[bytesReceived] = '\0';
            return std::string(response) == "AUTH_SUCCESS";
        }
        
        return false;
    }
    
    void sendMessage(const std::string& message) {
        if (validateInput(message, MAX_BUFFER_SIZE - 100)) {
            send(client_socket, message.c_str(), message.length(), 0);
        }
    }
    
    ~ChatClient() {
        if (client_socket >= 0) {
            close(client_socket);
        }
    }
};

// Test cases
int main() {
    // Create credentials file for testing
    std::ofstream credFile("credentials.txt");
    credFile << "user1:pass1\n";
    credFile << "user2:pass2\n";
    credFile << "testuser:testpass\n";
    credFile.close();
    
    std::cout << "Running 5 test cases:\n";
    
    // Test Case 1: Valid authentication
    std::cout << "Test 1 - Valid authentication: ";
    ChatClient client1;
    if (client1.connectToServer("127.0.0.1")) {
        if (client1.authenticate("user1", "pass1")) {
            std::cout << "PASSED\n";
        } else {
            std::cout << "FAILED\n";
        }
    } else {
        std::cout << "CONNECTION FAILED\n";
    }
    
    // Test Case 2: Invalid username/password
    std::cout << "Test 2 - Invalid credentials: ";
    ChatClient client2;
    if (client2.connectToServer("127.0.0.1")) {
        if (!client2.authenticate("invalid", "invalid")) {
            std::cout << "PASSED\n";
        } else {
            std::cout << "FAILED\n";
        }
    } else {
        std::cout << "CONNECTION FAILED\n";
    }
    
    // Test Case 3: Input validation - empty username
    std::cout << "Test 3 - Empty username validation: ";
    ChatClient client3;
    if (client3.connectToServer("127.0.0.1")) {
        if (!client3.authenticate("", "password")) {
            std::cout << "PASSED\n";
        } else {
            std::cout << "FAILED\n";
        }
    } else {
        std::cout << "CONNECTION FAILED\n";
    }
    
    // Test Case 4: Input validation - overly long password
    std::cout << "Test 4 - Long password validation: ";
    std::string longPassword(MAX_PASSWORD_LENGTH + 10, 'a');
    ChatClient client4;
    if (client4.connectToServer("127.0.0.1")) {
        if (!client4.authenticate("user1", longPassword)) {
            std::cout << "PASSED\n";
        } else {
            std::cout << "FAILED\n";
        }
    } else {
        std::cout << "CONNECTION FAILED\n";
    }
    
    // Test Case 5: Valid second user authentication
    std::cout << "Test 5 - Second valid user: ";
    ChatClient client5;
    if (client5.connectToServer("127.0.0.1")) {
        if (client5.authenticate("testuser", "testpass")) {
            std::cout << "PASSED\n";
        } else {
            std::cout << "FAILED\n";
        }
    } else {
        std::cout << "CONNECTION FAILED\n";
    }
    
    return 0;
}
