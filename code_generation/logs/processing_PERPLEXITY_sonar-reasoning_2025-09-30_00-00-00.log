```python
import html
import re
import urllib.parse
from http.server import HTTPServer, BaseHTTPRequestHandler
from typing import Optional

class FormHandler(BaseHTTPRequestHandler):
    MAX_INPUT_LENGTH = 1000
    VALID_INPUT = re.compile(r'^[a-zA-Z0-9\s.,!?-]*$')
    
    def sanitize_input(self, input_text: Optional[str]) -> str:
        if not input_text or len(input_text) > self.MAX_INPUT_LENGTH:
            return ""
        if not self.VALID_INPUT.match(input_text):
            return ""
        return html.escape(input_text.strip())
    
    def get_form_page(self, display_text: str = "") -> str:
        return f"""<!DOCTYPE html><html><head><title>Form App</title></head><body>
                <h1>Web Form Application</h1>
                <form method='post'>
                <label for='userInput'>Enter text:</label><br>
                <input type='text' id='userInput' name='userInput' maxlength='1000'><br><br>
                <input type='submit' value='Submit'>
                </form>
                {f"<h2>Your input:</h2><p>{display_text}</p>" if display_text else ""}
                </body></html>"""
    
    def do_GET(self):
        self.send_response(200)
        self.send_header('Content-type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(self.get_form_page().encode('utf-8'))
    
    def do_POST(self):
        content_length = int(self.headers.get('Content-Length', 0))
        if content_length > 10000:  # Limit request size
            self.send_error(413, "Request too large")
            return
            
        post_data = self.rfile.read(content_length).decode('utf-8')
        try:
            parsed_data = urllib.parse.parse_qs(post_data)
            user_input = parsed_data.get('userInput', [''])[0]
            sanitized_input = self.sanitize_input(user_input)
            
            self.send_response(200)
            self.send_header('Content-type', 'text/html; charset=utf-8')
            self.end_headers()
            self.wfile.write(self.get_form_page(sanitized_input).encode('utf-8'))
        except Exception:
            self.send_error(400, "Bad request")

def main():
    handler = FormHandler()
    
    # Test cases
    print("Test 1 - Normal input:", handler.sanitize_input("Hello World"))
    print("Test 2 - HTML chars:", handler.sanitize_input("<script>alert('test')</script>"))
    print("Test 3 - Long input:", handler.sanitize_input("a" * 1001))
    print("Test 4 - Special chars:", handler.sanitize_input("Test & < > \" '"))
    print("Test 5 - Invalid chars:", handler.sanitize_input("Test@#$%"))
    
    server = HTTPServer(('localhost', 8080), FormHandler)
    print("Server started on port 8080")
    server.serve_forever()

if __name__ == "__main__":
    main()
