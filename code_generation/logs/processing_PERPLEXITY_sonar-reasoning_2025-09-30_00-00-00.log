import javax.crypto.spec.PBEKeySpec;

public class Task7 {
    private static final int SALT_LENGTH = 16;
    private static final int HASH_ITERATIONS = 210000;
    private static final int HASH_LENGTH = 256;
    private static final String USERS_FILE = "users.txt";
    private static final int PORT = 8080;
    
    public static class ChatClient {
        public String sendLoginRequest(String username, String password, String serverHost, int port) {
            if (username == null || password == null || username.length() == 0 || username.length() > 50 || 
                password.length() == 0 || password.length() > 100) {
                return "INVALID_INPUT";
            }
            
            try (Socket socket = new Socket(serverHost, port);
                 PrintWriter out = new PrintWriter(socket.getOutputStream(), true);
                 BufferedReader in = new BufferedReader(new InputStreamReader(socket.getInputStream(), StandardCharsets.UTF_8))) {
                
                String sanitizedUsername = username.replaceAll("[^a-zA-Z0-9_]", "");
                out.println("LOGIN " + sanitizedUsername + " " + password);
                return in.readLine();
            } catch (Exception e) {
                return "CONNECTION_ERROR";
            }
        }
    }
    
    public static class ChatServer {
        private SecureRandom secureRandom = new SecureRandom();
        
        public void startServer(int port) {
            try (ServerSocket serverSocket = new ServerSocket(port)) {
                while (true) {
                    try (Socket clientSocket = serverSocket.accept();
                         BufferedReader in = new BufferedReader(new InputStreamReader(clientSocket.getInputStream(), StandardCharsets.UTF_8));
                         PrintWriter out = new PrintWriter(clientSocket.getOutputStream(), true)) {
                        
                        String request = in.readLine();
                        if (request != null && request.startsWith("LOGIN ")) {
                            String[] parts = request.split(" ", 3);
                            if (parts.length == 3) {
                                String username = parts[1];
                                String password = parts[2];
                                boolean authenticated = authenticateUser(username, password);
                                out.println(authenticated ? "SUCCESS" : "FAILURE");
                            } else {
                                out.println("FAILURE");
                            }
                        } else {
                            out.println("FAILURE");
                        }
                    }
                }
            } catch (Exception e) {
                // Server error handling
            }
        }
        
        public boolean authenticateUser(String username, String password) {
            if (username == null || password == null || username.length() == 0 || username.length() > 50) {
                return false;
            }
            
            try (BufferedReader reader = new BufferedReader(new FileReader(USERS_FILE, StandardCharsets.UTF_8))) {
                String line;
                while ((line = reader.readLine()) != null) {
                    String[] parts = line.split(":", 3);
                    if (parts.length == 3 && constantTimeEquals(parts[0], username)) {
                        byte[] salt = Base64.getDecoder().decode(parts[1]);
                        byte[] storedHash = Base64.getDecoder().decode(parts[2]);
                        byte[] passwordHash = hashPassword(password, salt);
                        return constantTimeEquals(storedHash, passwordHash);
                    }
                }
            } catch (Exception e) {
                return false;
            }
            return false;
        }
        
        public void createUser(String username, String password) {
            if (username == null || password == null || username.length() == 0 || username.length() > 50 || 
                password.length() < 8 || password.length() > 100) {
                return;
            }
            
            byte[] salt = new byte[SALT_LENGTH];
            secureRandom.nextBytes(salt);
            byte[] hash = hashPassword(password, salt);
            
            try (FileWriter writer = new FileWriter(USERS_FILE, StandardCharsets.UTF_8, true)) {
                writer.write(username + ":" + Base64.getEncoder().encodeToString(salt) + ":" + 
                           Base64.getEncoder().encodeToString(hash) + "\n");
            } catch (Exception e) {
                // Error handling
            }
        }
        
        private byte[] hashPassword(String password, byte[] salt) {
            try {
                PBEKeySpec spec = new PBEKeySpec(password.toCharArray(), salt, HASH_ITERATIONS, HASH_LENGTH);
                SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");
                byte[] hash = factory.generateSecret(spec).getEncoded();
                spec.clearPassword();
                return hash;
            } catch (Exception e) {
                return new byte[0];
            }
        }
        
        private boolean constantTimeEquals(String a, String b) {
            if (a == null || b == null) return false;
            return MessageDigest.isEqual(a.getBytes(StandardCharsets.UTF_8), b.getBytes(StandardCharsets.UTF_8));
        }
        
        private boolean constantTimeEquals(byte[] a, byte[] b) {
            return MessageDigest.isEqual(a, b);
        }
    }
    
    public static void main(String[] args) {
        ChatServer server = new ChatServer();
        ChatClient client = new ChatClient();
        
        // Test case 1: Create test users
        server.createUser("testuser1", "password123");
        server.createUser("admin", "securepass456");
        
        // Test case 2: Valid authentication
        boolean auth1 = server.authenticateUser("testuser1", "password123");
        System.out.println("Test 1 - Valid auth: " + auth1);
        
        // Test case 3: Invalid password
        boolean auth2 = server.authenticateUser("testuser1", "wrongpass");
        System.out.println("Test 2 - Invalid password: " + !auth2);
        
        // Test case 4: Non-existent user
        boolean auth3 = server.authenticateUser("nonexistent", "anypass");
        System.out.println("Test 3 - Non-existent user: " + !auth3);
        
        // Test case 5: Input validation
        String result = client.sendLoginRequest("", "", "localhost", PORT);
        System.out.println("Test 4 - Empty input: " + result.equals("INVALID_INPUT"));
        
        // Test case 6: Long input validation
        String longUser = "a".repeat(60);
        String result2 = client.sendLoginRequest(longUser, "pass", "localhost", PORT);
        System.out.println("Test 5 - Long username: " + result2.equals("INVALID_INPUT"));
    }
}
