#include <iostream>
#include <string>
#include <cstring>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>
#include <map>
#include <stdexcept>

#define MAX_BUFFER_SIZE 512
#define MAX_DOMAIN_LEN 255

struct DNSHeader {
    uint16_t id;
    uint16_t flags;
    uint16_t qdcount;
    uint16_t ancount;
    uint16_t nscount;
    uint16_t arcount;
};

struct DNSQuestion {
    std::string qname;
    uint16_t qtype;
    uint16_t qclass;
};

class DNSServer {
private:
    int sockfd;
    struct sockaddr_in server_addr;
    std::map<std::string, std::string> dns_records;
    
    bool validateBuffer(const uint8_t* buffer, int len, int offset, int required_bytes) {
        return buffer != nullptr && len > 0 && offset >= 0 && 
               offset + required_bytes <= len && offset + required_bytes <= MAX_BUFFER_SIZE;
    }
    
    std::string parseDomainName(const uint8_t* buffer, int& offset, int max_len) {
        if (!validateBuffer(buffer, max_len, offset, 1)) {
            return "";
        }
        
        std::string domain;
        int jumped = 0;
        int original_offset = offset;
        int steps = 0;
        
        while (offset < max_len && buffer[offset] != 0 && steps < 100) {
            steps++;
            if ((buffer[offset] & 0xC0) == 0xC0) {
                if (!validateBuffer(buffer, max_len, offset, 2)) break;
                if (!jumped) {
                    original_offset = offset + 2;
                }
                offset = ((buffer[offset] & 0x3F) << 8) | buffer[offset + 1];
                if (offset >= max_len) break;
                jumped = 1;
            } else {
                int len = buffer[offset++];
                if (len > 63 || !validateBuffer(buffer, max_len, offset, len)) break;
                if (!domain.empty()) domain += ".";
                if (domain.length() + len > MAX_DOMAIN_LEN) break;
                domain.append((char*)&buffer[offset], len);
                offset += len;
            }
        }
        
        if (jumped) {
            offset = original_offset;
        } else {
            offset++;
        }
        
        return domain;
    }
    
    void createDNSResponse(uint8_t* response, int& response_len, 
                          const DNSHeader& header, const DNSQuestion& question) {
        if (!response || question.qname.empty()) {
            response_len = 0;
            return;
        }
        
        int offset = 0;
        memset(response, 0, MAX_BUFFER_SIZE);
        
        DNSHeader* resp_header = (DNSHeader*)response;
        resp_header->id = header.id;
        resp_header->flags = htons(0x8180);
        resp_header->qdcount = htons(1);
        resp_header->ancount = htons(1);
        resp_header->nscount = 0;
        resp_header->arcount = 0;
        offset += sizeof(DNSHeader);
        
        for (size_t i = 0; i < question.qname.length() && offset < MAX_BUFFER_SIZE - 1; ) {
            size_t dot_pos = question.qname.find('.', i);
            if (dot_pos == std::string::npos) {
                dot_pos = question.qname.length();
            }
            uint8_t len = std::min((size_t)63, dot_pos - i);
            if (offset + len + 1 >= MAX_BUFFER_SIZE) break;
            response[offset++] = len;
            memcpy(&response[offset], question.qname.c_str() + i, len);
            offset += len;
            i = dot_pos + 1;
        }
        if (offset < MAX_BUFFER_SIZE) response[offset++] = 0;
        
        if (offset + 8 < MAX_BUFFER_SIZE) {
            *(uint16_t*)&response[offset] = htons(question.qtype);
            offset += 2;
            *(uint16_t*)&response[offset] = htons(question.qclass);
            offset += 2;
            *(uint16_t*)&response[offset] = htons(0xC00C);
            offset += 2;
            *(uint16_t*)&response[offset] = htons(1);
            offset += 2;
        }
        
        if (offset + 10 < MAX_BUFFER_SIZE) {
            *(uint16_t*)&response[offset] = htons(1);
            offset += 2;
            *(uint32_t*)&response[offset] = htonl(300);
            offset += 4;
            *(uint16_t*)&response[offset] = htons(4);
            offset += 2;
        }
        
        std::string ip = dns_records.count(question.qname) ? 
                        dns_records[question.qname] : "127.0.0.1";
        if (offset + 4 <= MAX_BUFFER_SIZE) {
            inet_pton(AF_INET, ip.c_str(), &response[offset]);
            offset += 4;
        }
        
        response_len = offset;
    }
    
public:
    DNSServer(const std::string& ip, int port) : sockfd(-1) {
        if (port <= 0 || port > 65535) {
            throw std::invalid_argument("Invalid port number");
        }
        
        dns_records["example.com"] = "192.168.1.1";
        dns_records["test.com"] = "192.168.1.2";
        dns_records["google.com"] = "8.8.8.8";
        dns_records["localhost"] = "127.0.0.1";
        dns_records["dns.test"] = "10.0.0.1";
        
        sockfd = socket(AF_INET, SOCK_DGRAM, 0);
        if (sockfd < 0) {
            throw std::runtime_error("Socket creation failed");
        }
        
        memset(&server_addr, 0, sizeof(server_addr));
        server_addr.sin_family = AF_INET;
        server_addr.sin_port = htons(port);
        if (inet_pton(AF_INET, ip.c_str(), &server_addr.sin_addr) <= 0) {
            close(sockfd);
            throw std::invalid_argument("Invalid IP address");
        }
        
        if (bind(sockfd, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
            close(sockfd);
            throw std::runtime_error("Bind failed");
        }
    }
    
    ~DNSServer() {
        if (sockfd >= 0) {
            close(sockfd);
        }
    }
    
    bool processRequest(const uint8_t* buffer, int len, struct sockaddr_in& client_addr) {
        if (!validateBuffer(buffer, len, 0, sizeof(DNSHeader))) {
            return false;
        }
        
        DNSHeader header;
        memcpy(&header, buffer, sizeof(DNSHeader));
        header.id = ntohs(header.id);
        header.flags = ntohs(header.flags);
        header.qdcount = ntohs(header.qdcount);
        
        if (header.qdcount == 0 || header.qdcount > 10) {
            return false;
        }
        
        int offset = sizeof(DNSHeader);
        DNSQuestion question;
        question.qname = parseDomainName(buffer, offset, len);
        
        if (question.qname.empty() || !validateBuffer(buffer, len, offset, 4)) {
            return false;
        }
        
        question.qtype = ntohs(*(uint16_t*)&buffer[offset]);
        offset += 2;
        question.qclass = ntohs(*(uint16_t*)&buffer[offset]);
        
        uint8_t response[MAX_BUFFER_SIZE];
        int response_len;
        createDNSResponse(response, response_len, header, question);
        
        if (response_len > 0) {
            sendto(sockfd, response, response_len, 0, 
                   (struct sockaddr*)&client_addr, sizeof(client_addr));
        }
        return true;
    }
    
    void listen() {
        uint8_t buffer[MAX_BUFFER_SIZE];
        struct sockaddr_in client_addr;
        socklen_t client_len = sizeof(client_addr);
        
        while (true) {
            memset(buffer, 0, sizeof(buffer));
            int len = recvfrom(sockfd, buffer, sizeof(buffer) - 1, 0,
                              (struct sockaddr*)&client_addr, &client_len);
            if (len > 0 && len < MAX_BUFFER_SIZE) {
                processRequest(buffer, len, client_addr);
            }
        }
    }
};

