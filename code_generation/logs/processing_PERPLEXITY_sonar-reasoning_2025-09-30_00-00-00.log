#include <iostream>
#include <string>
#include <vector>
#include <fstream>
#include <sstream>
#include <memory>
#include <random>
#include <algorithm>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/crypto.h>

class ChatClient {
public:
    std::string sendLoginRequest(const std::string& username, const std::string& password, const std::string& serverHost, int port) {
        if (username.empty() || password.empty() || username.length() > 50 || password.length() > 100) {
            return "INVALID_INPUT";
        }
        
        int sock = socket(AF_INET, SOCK_STREAM, 0);
        if (sock < 0) return "CONNECTION_ERROR";
        
        struct sockaddr_in serv_addr;
        serv_addr.sin_family = AF_INET;
        serv_addr.sin_port = htons(port);
        inet_pton(AF_INET, serverHost.c_str(), &serv_addr.sin_addr);
        
        if (connect(sock, (struct sockaddr*)&serv_addr, sizeof(serv_addr)) < 0) {
            close(sock);
            return "CONNECTION_ERROR";
        }
        
        std::string sanitizedUsername = username;
        sanitizedUsername.erase(std::remove_if(sanitizedUsername.begin(), sanitizedUsername.end(),
            [](char c) { return !std::isalnum(c) && c != '_'; }), sanitizedUsername.end());
            
        std::string message = "LOGIN " + sanitizedUsername + " " + password + "\n";
        send(sock, message.c_str(), message.length(), 0);
        
        char buffer[1024] = {0};
        int bytesRead = read(sock, buffer, sizeof(buffer) - 1);
        close(sock);
        
        if (bytesRead > 0) {
            buffer[bytesRead] = '\0';
            return std::string(buffer);
        }
        return "CONNECTION_ERROR";
    }
};

class ChatServer {
private:
    static const int SALT_LENGTH = 16;
    static const int ITERATIONS = 210000;
    static const int HASH_LENGTH = 32;
    std::string usersFile = "users.txt";
    
    std::vector<unsigned char> hashPassword(const std::string& password, const std::vector<unsigned char>& salt) {
        std::vector<unsigned char> hash(HASH_LENGTH);
        
        if (PKCS5_PBKDF2_HMAC(password.c_str(), password.length(),
                              salt.data(), salt.size(),
                              ITERATIONS, EVP_sha256(),
                              HASH_LENGTH, hash.data()) != 1) {
            return std::vector<unsigned char>();
        }
        return hash;
    }
    
    bool constantTimeEquals(const std::vector<unsigned char>& a, const std::vector<unsigned char>& b) {
        if (a.size() != b.size()) return false;
        return CRYPTO_memcmp(a.data(), b.data(), a.size()) == 0;
    }
    
    bool constantTimeEquals(const std::string& a, const std::string& b) {
        if (a.length() != b.length()) return false;
        return CRYPTO_memcmp(a.c_str(), b.c_str(), a.length()) == 0;
    }
    
