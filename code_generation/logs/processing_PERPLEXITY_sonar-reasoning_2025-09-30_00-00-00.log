import secrets
import hashlib
import re
from typing import Dict, Optional, Tuple

class CSRFProtectedApp:
    def __init__(self):
        self.sessions: Dict[str, str] = {}
        self.users: Dict[str, Dict[str, str]] = {}
    
    def generate_csrf_token(self, session_id: str) -> str:
        token = secrets.token_urlsafe(32)
        self.sessions[session_id] = token
        return token
    
    def validate_csrf_token(self, session_id: str, submitted_token: str) -> bool:
        if not session_id or not submitted_token:
            return False
        
        stored_token = self.sessions.get(session_id)
        if not stored_token:
            return False
        
        return secrets.compare_digest(stored_token, submitted_token)
    
    def generate_form(self, session_id: str) -> str:
        csrf_token = self.generate_csrf_token(session_id)
        return f"""<form method='post'>
        <input type='hidden' name='csrf_token' value='{csrf_token}'>
        <input type='email' name='email' required>
        <select name='theme'>
        <option value='light'>Light</option>
        <option value='dark'>Dark</option>
        </select>
        <button type='submit'>Update Settings</button>
        </form>"""
    
    def update_user_settings(self, session_id: str, csrf_token: str, 
                           email: str, theme: str) -> str:
        if not self.validate_csrf_token(session_id, csrf_token):
            return "CSRF token validation failed"
        
        if not email or not re.match(r'^[\w.-]+@[\w.-]+\.[a-zA-Z]{2,}$', email):
            return "Invalid email format"
        
        if theme not in ['light', 'dark']:
            return "Invalid theme selection"
        
        self.users[session_id] = {'email': email, 'theme': theme}
        if session_id in self.sessions:
            del self.sessions[session_id]
        
        return "Settings updated successfully"

def main():
    app = CSRFProtectedApp()
    
    # Test case 1: Valid form generation
    form = app.generate_form("session1")
    print("Test 1:", "csrf_token" in form)
    
    # Test case 2: Valid settings update
    token = app.generate_csrf_token("session2")
    result = app.update_user_settings("session2", token, "user@example.com", "dark")
    print("Test 2:", result == "Settings updated successfully")
    
    # Test case 3: Invalid CSRF token
    result = app.update_user_settings("session3", "invalid_token", "user@example.com", "light")
    print("Test 3:", "CSRF token validation failed" in result)
    
    # Test case 4: Invalid email format
    token4 = app.generate_csrf_token("session4")
    result = app.update_user_settings("session4", token4, "invalid-email", "light")
    print("Test 4:", "Invalid email format" in result)
    
    # Test case 5: Invalid theme
    token5 = app.generate_csrf_token("session5")
    result = app.update_user_settings("session5", token5, "user@example.com", "invalid_theme")
    print("Test 5:", "Invalid theme selection" in result)

if __name__ == "__main__":
    main()
