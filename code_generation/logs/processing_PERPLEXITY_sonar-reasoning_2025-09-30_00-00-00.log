```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>
#include <time.h>

#define MAX_SESSIONS 100
#define MAX_TOKEN_LEN 33
#define MAX_SESSION_LEN 65
#define MAX_EMAIL_LEN 101
#define MAX_NAME_LEN 51

typedef struct {
    char email[MAX_EMAIL_LEN];
    char name[MAX_NAME_LEN];
    bool notifications;
} UserSettings;

typedef struct {
    char sessionId[MAX_SESSION_LEN];
    char token[MAX_TOKEN_LEN];
} CSRFSession;

typedef struct {
    char sessionId[MAX_SESSION_LEN];
    UserSettings settings;
} UserSession;

CSRFSession csrf_sessions[MAX_SESSIONS];
UserSession user_sessions[MAX_SESSIONS];
int csrf_count = 0;
int user_count = 0;

char* generate_csrf_token(const char* sessionId) {
    if (!sessionId || strlen(sessionId) == 0 || strlen(sessionId) >= MAX_SESSION_LEN) {
        return NULL;
    }
    
    static char token[MAX_TOKEN_LEN];
    const char chars[] = "0123456789abcdef";
    
    srand((unsigned int)time(NULL));
    
    for (int i = 0; i < 32; i++) {
        token[i] = chars[rand() % 16];
    }
    token[32] = '\0';
    
    if (csrf_count < MAX_SESSIONS) {
        strncpy(csrf_sessions[csrf_count].sessionId, sessionId, MAX_SESSION_LEN - 1);
        csrf_sessions[csrf_count].sessionId[MAX_SESSION_LEN - 1] = '\0';
        strncpy(csrf_sessions[csrf_count].token, token, MAX_TOKEN_LEN - 1);
        csrf_sessions[csrf_count].token[MAX_TOKEN_LEN - 1] = '\0';
        csrf_count++;
    }
    
    return token;
}

bool validate_csrf_token(const char* sessionId, const char* token) {
    if (!sessionId || !token || strlen(sessionId) == 0 || strlen(token) != 32 || strlen(sessionId) >= MAX_SESSION_LEN) {
        return false;
    }
    
    for (int i = 0; i < csrf_count; i++) {
        if (strcmp(csrf_sessions[i].sessionId, sessionId) == 0) {
            return strcmp(csrf_sessions[i].token, token) == 0;
        }
    }
    
    return false;
}

bool validate_email(const char* email) {
    if (!email || strlen(email) >= MAX_EMAIL_LEN) {
        return false;
    }
    
    return strchr(email, '@') != NULL;
}

bool update_user_settings(const char* sessionId, const char* csrfToken, 
                         const char* email, const char* name, bool notifications) {
    if (!validate_csrf_token(sessionId, csrfToken)) {
        return false;
    }
    
    if (!email || !name || strlen(email) >= MAX_EMAIL_LEN || strlen(name) >= MAX_NAME_LEN) {
        return false;
    }
    
    if (!validate_email(email)) {
        return false;
    }
    
    for (int i = 0; i < user_count; i++) {
        if (strcmp(user_sessions[i].sessionId, sessionId) == 0) {
            strncpy(user_sessions[i].settings.email, email, MAX_EMAIL_LEN - 1);
            user_sessions[i].settings.email[MAX_EMAIL_LEN - 1] = '\0';
            strncpy(user_sessions[i].settings.name, name, MAX_NAME_LEN - 1);
            user_sessions[i].settings.name[MAX_NAME_LEN - 1] = '\0';
            user_sessions[i].settings.notifications = notifications;
            return true;
        }
    }
    
    if (user_count < MAX_SESSIONS) {
        strncpy(user_sessions[user_count].sessionId, sessionId, MAX_SESSION_LEN - 1);
        user_sessions[user_count].sessionId[MAX_SESSION_LEN - 1] = '\0';
        strncpy(user_sessions[user_count].settings.email, email, MAX_EMAIL_LEN - 1);
        user_sessions[user_count].settings.email[MAX_EMAIL_LEN - 1] = '\0';
        strncpy(user_sessions[user_count].settings.name, name, MAX_NAME_LEN - 1);
        user_sessions[user_count].settings.name[MAX_NAME_LEN - 1] = '\0';
        user_sessions[user_count].settings.notifications = notifications;
        user_count++;
        return true;
    }
    
    return false;
}

UserSettings* get_user_settings(const char* sessionId) {
    if (!sessionId) {
        return NULL;
    }
    
    for (int i = 0; i < user_count; i++) {
        if (strcmp(user_sessions[i].sessionId, sessionId) == 0) {
            return &user_sessions[i].settings;
        }
    }
    
    return NULL;
}

int main() {
    // Initialize
    csrf_count = 0;
    user_count = 0;
    
    // Test Case 1: Valid CSRF token and update
    char* token1 = generate_csrf_token("user123");
    bool result1 = update_user_settings("user123", token1, "user@example.com", "John Doe", true);
    printf("Test 1 (Valid CSRF): %s\n", result1 ? "PASS" : "FAIL");
    
    // Test Case 2: Invalid CSRF token
    generate_csrf_token("user456");
    bool result2 = update_user_settings("user456", "invalid_token", "user2@example.com", "Jane Doe", false);
    printf("Test 2 (Invalid CSRF): %s\n", !result2 ? "PASS" : "FAIL");
    
    // Test Case 3: Empty CSRF token
    generate_csrf_token("user789");
    bool result3 = update_user_settings("user789", "", "user3@example.com", "Bob Smith", true);
    printf("Test 3 (Empty CSRF): %s\n", !result3 ? "PASS" : "FAIL");
    
    // Test Case 4: Invalid email format
    char* token4 = generate_csrf_token("user101");
    bool result4 = update_user_settings("user101", token4, "invalid_email", "Alice Brown", false);
    printf("Test 4 (Invalid email): %s\n", !result4 ? "PASS" : "FAIL");
    
    // Test Case 5: Valid update and verify settings
    char* token5 = generate_csrf_token("user202");
    bool result5 = update_user_settings("user202", token5, "test@example.com", "Test User", true);
    UserSettings* settings5 = get_user_settings("user202");
    bool verify5 = settings5 && (strcmp(settings5->email, "test@example.com") == 0) && 
                   (strcmp(settings5->name, "Test User") == 0) && settings5->notifications;
    printf("Test 5 (Settings verify): %s\n", (result5 && verify5) ? "PASS" : "FAIL");
    
    return 0;
}
