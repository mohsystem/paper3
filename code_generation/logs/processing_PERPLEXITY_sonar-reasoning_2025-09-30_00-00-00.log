#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/sha.h>
#include <fcntl.h>
#include <errno.h>
#include <sys/wait.h>

#define MAX_USERNAME 32
#define MAX_PASSWORD 64
#define MAX_MESSAGE 256
#define SALT_SIZE 16
#define HASH_SIZE 32
#define PORT 8080

int secure_compare(const unsigned char *a, const unsigned char *b, size_t len) {
    unsigned char result = 0;
    for (size_t i = 0; i < len; i++) {
        result |= a[i] ^ b[i];
    }
    return result == 0;
}

int generate_salt(unsigned char *salt) {
    return RAND_bytes(salt, SALT_SIZE) == 1;
}

int hash_password(const char *password, const unsigned char *salt, unsigned char *hash) {
    return PKCS5_PBKDF2_HMAC(password, strlen(password), salt, SALT_SIZE, 210000, EVP_sha256(), HASH_SIZE, hash) == 1;
}

int validate_input(const char *input, size_t max_len) {
    if (!input) return 0;
    size_t len = strnlen(input, max_len + 1);
    if (len == 0 || len > max_len) return 0;
    
    for (size_t i = 0; i < len; i++) {
        char c = input[i];
        if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || 
              (c >= '0' && c <= '9') || c == '_' || c == '@' || c == '.' || c == '-')) {
            return 0;
        }
    }
    return 1;
}

int store_user(const char *username, const char *password) {
    if (!validate_input(username, MAX_USERNAME) || !validate_input(password, MAX_PASSWORD)) {
        return 0;
    }
    
    unsigned char salt[SALT_SIZE];
    unsigned char hash[HASH_SIZE];
    
    if (!generate_salt(salt) || !hash_password(password, salt, hash)) {
        return 0;
    }
    
    FILE *fp = fopen("users.dat", "ab");
    if (!fp) return 0;
    
    uint8_t username_len = strlen(username);
    if (fwrite(&username_len, 1, 1, fp) != 1 ||
        fwrite(username, 1, username_len, fp) != username_len ||
        fwrite(salt, 1, SALT_SIZE, fp) != SALT_SIZE ||
        fwrite(hash, 1, HASH_SIZE, fp) != HASH_SIZE) {
        fclose(fp);
        return 0;
    }
    
    fclose(fp);
    return 1;
}

int verify_user(const char *username, const char *password) {
    if (!validate_input(username, MAX_USERNAME) || !validate_input(password, MAX_PASSWORD)) {
        return 0;
    }
    
    FILE *fp = fopen("users.dat", "rb");
    if (!fp) return 0;
    
    uint8_t stored_username_len;
    char stored_username[MAX_USERNAME + 1];
    unsigned char stored_salt[SALT_SIZE];
    unsigned char stored_hash[HASH_SIZE];
    unsigned char computed_hash[HASH_SIZE];
    
    while (fread(&stored_username_len, 1, 1, fp) == 1) {
        if (stored_username_len > MAX_USERNAME) {
            fclose(fp);
            return 0;
        }
        
        if (fread(stored_username, 1, stored_username_len, fp) != stored_username_len ||
            fread(stored_salt, 1, SALT_SIZE, fp) != SALT_SIZE ||
            fread(stored_hash, 1, HASH_SIZE, fp) != HASH_SIZE) {
            fclose(fp);
            return 0;
        }
        
        stored_username[stored_username_len] = '\0';
        
        if (strcmp(username, stored_username) == 0) {
            fclose(fp);
            if (!hash_password(password, stored_salt, computed_hash)) {
                return 0;
            }
            return secure_compare(stored_hash, computed_hash, HASH_SIZE);
        }
    }
    
    fclose(fp);
    return 0;
}

int run_server() {
    int server_fd, client_fd;
    struct sockaddr_in address;
    int addrlen = sizeof(address);
    char buffer[MAX_MESSAGE] = {0};
    
    if ((server_fd = socket(AF_INET, SOCK_STREAM, 0)) == 0) {
        return 1;
    }
    
    int opt = 1;
    if (setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt))) {
        close(server_fd);
        return 1;
    }
    
    address.sin_family = AF_INET;
    address.sin_addr.s_addr = INADDR_ANY;
    address.sin_port = htons(PORT);
    
    if (bind(server_fd, (struct sockaddr *)&address, sizeof(address)) < 0) {
        close(server_fd);
        return 1;
    }
    
    if (listen(server_fd, 3) < 0) {
        close(server_fd);
        return 1;
    }
    
    while (1) {
        if ((client_fd = accept(server_fd, (struct sockaddr *)&address, (socklen_t*)&addrlen)) < 0) {
            continue;
        }
        
        ssize_t bytes_read = recv(client_fd, buffer, MAX_MESSAGE - 1, 0);
        if (bytes_read <= 0) {
            close(client_fd);
            continue;
        }
        buffer[bytes_read] = '\0';
        
        if (strncmp(buffer, "LOGIN:", 6) != 0) {
            send(client_fd, "INVALID", 7, 0);
            close(client_fd);
            continue;
        }
        
        char *username_start = buffer + 6;
        char *password_start = strchr(username_start, ':');
        if (!password_start) {
            send(client_fd, "INVALID", 7, 0);
            close(client_fd);
            continue;
        }
        
        *password_start = '\0';
        password_start++;
        
        if (verify_user(username_start, password_start)) {
            send(client_fd, "SUCCESS", 7, 0);
        } else {
            send(client_fd, "FAILURE", 7, 0);
        }
        
        close(client_fd);
    }
    
    close(server_fd);
    return 0;
}

int test_client_login(const char *username, const char *password) {
    int sock = 0;
    struct sockaddr_in serv_addr;
    char message[MAX_MESSAGE];
    char response[MAX_MESSAGE] = {0};
    
    if ((sock = socket(AF_INET, SOCK_STREAM, 0)) < 0) {
        return 0;
    }
    
    serv_addr.sin_family = AF_INET;
    serv_addr.sin_port = htons(PORT);
    
    if (inet_pton(AF_INET, "127.0.0.1", &serv_addr.sin_addr) <= 0) {
        close(sock);
        return 0;
    }
    
    if (connect(sock, (struct sockaddr *)&serv_addr, sizeof(serv_addr)) < 0) {
        close(sock);
        return 0;
    }
    
    int ret = snprintf(message, sizeof(message), "LOGIN:%s:%s", username, password);
    if (ret < 0 || ret >= sizeof(message)) {
        close(sock);
        return 0;
    }
    
    send(sock, message, strlen(message), 0);
    
    ssize_t bytes_read = recv(sock, response, sizeof(response) - 1, 0);
    close(sock);
    
    if (bytes_read > 0) {
        response[bytes_read] = '\0';
        return strncmp(response, "SUCCESS", 7) == 0;
    }
    
    return 0;
}

void setup_test_environment() {
    remove("users.dat");
    store_user("alice", "password123");
    store_user("bob", "secret456");
    store_user("charlie", "mypass789");
    store_user("diana", "secure321");
    store_user("eve", "hidden654");
}

int main(int argc, char *argv[]) {
    OpenSSL_add_all_algorithms();
    
    if (argc >= 2 && strcmp(argv[1], "server") == 0) {
        return run_server();
    }
    
    if (argc >= 2 && strcmp(argv[1], "test") == 0) {
        setup_test_environment();
        
        pid_t server_pid = fork();
        if (server_pid == 0) {
            run_server();
            exit(0);
        }
        
        sleep(1);
        
        printf("Test 1 - Valid login alice: %s\n", 
               test_client_login("alice", "password123") ? "PASS" : "FAIL");
        
        printf("Test 2 - Valid login bob: %s\n", 
               test_client_login("bob", "secret456") ? "PASS" : "FAIL");
        
        printf("Test 3 - Invalid password: %s\n", 
               test_client_login("alice", "wrongpass") ? "FAIL" : "PASS");
        
        printf("Test 4 - Invalid username: %s\n", 
               test_client_login("nonexistent", "password") ? "FAIL" : "PASS");
        
        printf("Test 5 - Valid login charlie: %s\n", 
               test_client_login("charlie", "mypass789") ? "PASS" : "FAIL");
        
        kill(server_pid, SIGTERM);
        wait(NULL);
        return 0;
    }
    
    printf("Usage: %s <server|test>\n", argv[0]);
    return 0;
}
