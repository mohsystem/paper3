#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/kdf.h>
#include <openssl/sha.h>
#include <vector>
#include <string>
#include <memory>
#include <cstring>
#include <iostream>
#include <stdexcept>

class KeyManager {
private:
    std::vector<uint8_t> generateSalt() {
        std::vector<uint8_t> salt(16);
        if (RAND_bytes(salt.data(), 16) != 1) {
            throw std::runtime_error("Failed to generate salt");
        }
        return salt;
    }
    
    std::vector<uint8_t> generateIV() {
        std::vector<uint8_t> iv(12);
        if (RAND_bytes(iv.data(), 12) != 1) {
            throw std::runtime_error("Failed to generate IV");
        }
        return iv;
    }
    
    std::vector<uint8_t> deriveKey(const std::string& passphrase, const std::vector<uint8_t>& salt) {
        std::vector<uint8_t> key(32);
        
        if (PKCS5_PBKDF2_HMAC(passphrase.c_str(), passphrase.length(),
                              salt.data(), salt.size(),
                              210000, EVP_sha256(),
                              32, key.data()) != 1) {
            throw std::runtime_error("Key derivation failed");
        }
        
        return key;
    }

public:
    std::vector<uint8_t> generateKey() {
        std::vector<uint8_t> key(32);
        if (RAND_bytes(key.data(), 32) != 1) {
            throw std::runtime_error("Failed to generate key");
        }
        return key;
    }
    
    std::vector<uint8_t> encryptKey(const std::vector<uint8_t>& key, const std::string& passphrase) {
        if (key.size() != 32) {
            throw std::invalid_argument("Invalid key size");
        }
        if (passphrase.length() < 8 || passphrase.length() > 256) {
            throw std::invalid_argument("Invalid passphrase length");
        }
        
        auto salt = generateSalt();
        auto iv = generateIV();
        auto encKey = deriveKey(passphrase, salt);
        
        EVP_CIPHER_CTX *ctx = EVP_CIPHER_CTX_new();
        if (!ctx) {
            throw std::runtime_error("Failed to create cipher context");
        }
        
        if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, encKey.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Encryption init failed");
        }
        
        std::vector<uint8_t> ciphertext(key.size());
        int len;
        
        if (EVP_EncryptUpdate(ctx, ciphertext.data(), &len, key.data(), key.size()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Encryption update failed");
        }
        
        if (EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Encryption final failed");
        }
        
        std::vector<uint8_t> tag(16);
        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, 16, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to get authentication tag");
        }
        
        EVP_CIPHER_CTX_free(ctx);
        
        // Format: [magic="ENC1"][version=1][salt(16)][iv(12)][ciphertext(32)][tag(16)]
        std::vector<uint8_t> result;
        result.reserve(4 + 1 + 16 + 12 + 32 + 16);
        
        result.insert(result.end(), {'E', 'N', 'C', '1'});
        result.push_back(1);
        result.insert(result.end(), salt.begin(), salt.end());
        result.insert(result.end(), iv.begin(), iv.end());
        result.insert(result.end(), ciphertext.begin(), ciphertext.end());
        result.insert(result.end(), tag.begin(), tag.end());
        
        OPENSSL_cleanse(encKey.data(), encKey.size());
        return result;
    }
    
    std::vector<uint8_t> decryptKey(const std::vector<uint8_t>& encryptedData, const std::string& passphrase) {
        if (encryptedData.size() != 4 + 1 + 16 + 12 + 32 + 16) {
            throw std::invalid_argument("Invalid encrypted data size");
        }
        if (passphrase.length() < 8 || passphrase.length() > 256) {
            throw std::invalid_argument("Invalid passphrase length");
        }
        
        if (encryptedData[0] != 'E' || encryptedData[1] != 'N' || 
            encryptedData[2] != 'C' || encryptedData[3] != '1') {
            throw std::invalid_argument("Invalid magic header");
        }
        
        if (encryptedData[4] != 1) {
            throw std::invalid_argument("Unsupported version");
        }
        
        std::vector<uint8_t> salt(encryptedData.begin() + 5, encryptedData.begin() + 21);
        std::vector<uint8_t> iv(encryptedData.begin() + 21, encryptedData.begin() + 33);
        std::vector<uint8_t> ciphertext(encryptedData.begin() + 33, encryptedData.begin() + 65);
        std::vector<uint8_t> tag(encryptedData.begin() + 65, encryptedData.end());
        
        auto encKey = deriveKey(passphrase, salt);
        
        EVP_CIPHER_CTX *ctx = EVP_CIPHER_CTX_new();
        if (!ctx) {
            throw std::runtime_error("Failed to create cipher context");
        }
        
        if (EVP_DecryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, encKey.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Decryption init failed");
        }
        
        std::vector<uint8_t> plaintext(32);
        int len;
        
        if (EVP_DecryptUpdate(ctx, plaintext.data(), &len, ciphertext.data(), ciphertext.size()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Decryption update failed");
        }
        
        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_TAG, 16, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            throw std::runtime_error("Failed to set authentication tag");
        }
        
        if (EVP_DecryptFinal_ex(ctx, plaintext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(encKey.data(), encKey.size());
            throw std::runtime_error("Authentication failed");
        }
        
        EVP_CIPHER_CTX_free(ctx);
        OPENSSL_cleanse(encKey.data(), encKey.size());
        
        return plaintext;
    }
    
    bool validateKey(const std::vector<uint8_t>& key) {
        return key.size() == 32;
    }
    
    void secureDestroy(std::vector<uint8_t>& key) {
        if (!key.empty()) {
            OPENSSL_cleanse(key.data(), key.size());
            key.clear();
        }
    }
};

int main() {
    try {
        KeyManager km;
        
        std::cout << "Test 1: Generate and validate key" << std::endl;
        auto key1 = km.generateKey();
        std::cout << "Key generated: " << (km.validateKey(key1) ? "Valid" : "Invalid") << std::endl;
        
        std::cout << "Test 2: Encrypt and decrypt key" << std::endl;
        std::string passphrase = "SecurePassphrase123!";
        auto encrypted = km.encryptKey(key1, passphrase);
        auto decrypted = km.decryptKey(encrypted, passphrase);
        std::cout << "Round-trip successful: " << (key1 == decrypted ? "Yes" : "No") << std::endl;
        
        std::cout << "Test 3: Invalid passphrase" << std::endl;
        try {
            km.decryptKey(encrypted, "WrongPassword");
            std::cout << "Unexpected success" << std::endl;
        } catch (const std::exception& e) {
            std::cout << "Expected failure: Authentication failed" << std::endl;
        }
        
        std::cout << "Test 4: Invalid key size validation" << std::endl;
        std::vector<uint8_t> shortKey(16);
        std::cout << "Short key valid: " << (km.validateKey(shortKey) ? "Yes" : "No") << std::endl;
        
        std::cout << "Test 5: Secure key destruction" << std::endl;
        auto key2 = km.generateKey();
        km.secureDestroy(key2);
        std::cout << "Key destroyed: " << (key2.empty() ? "Yes" : "No") << std::endl;
        
        km.secureDestroy(key1);
        km.secureDestroy(decrypted);
        
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
