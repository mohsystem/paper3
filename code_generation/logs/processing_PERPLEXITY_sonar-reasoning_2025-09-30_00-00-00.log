        len = fread(buffer, 1, to_read, input);
        if (len <= 0) break;
        
        if (EVP_DecryptUpdate(ctx, out_buffer, &out_len, buffer, len) != 1) goto cleanup;
        if (fwrite(out_buffer, 1, out_len, temp) != (size_t)out_len) goto cleanup;
        remaining -= len;
    }

    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_AEAD_SET_TAG, AES_TAG_SIZE, tag) != 1) goto cleanup;
    if (EVP_DecryptFinal_ex(ctx, out_buffer, &out_len) != 1) goto cleanup;
    if (out_len > 0 && fwrite(out_buffer, 1, out_len, temp) != (size_t)out_len) goto cleanup;

    if (fflush(temp) != 0 || fsync(fileno(temp)) != 0) goto cleanup;
    fclose(temp);
    temp = NULL;

    if (rename(temp_path, output_path) != 0) goto cleanup;

    ret = 1;

cleanup:
    secure_zero(key, sizeof(key));
    secure_zero(buffer, sizeof(buffer));
    if (input) fclose(input);
    if (temp) {
        fclose(temp);
        unlink(temp_path);
    }
    if (ctx) EVP_CIPHER_CTX_free(ctx);
    return ret;
}

