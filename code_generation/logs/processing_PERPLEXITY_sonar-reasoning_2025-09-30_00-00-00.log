```cpp
#include <iostream>
#include <string>
#include <regex>
#include <algorithm>
#include <sstream>
#include <vector>
#include <map>
#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>
#include <cstring>

class WebFormApp {
private:
    static const size_t MAX_INPUT_LENGTH = 1000;
    std::regex validInput;
    
public:
    WebFormApp() : validInput("^[a-zA-Z0-9\\s.,!?-]*$") {}
    
    std::string htmlEscape(const std::string& input) {
        std::string result = input;
        std::vector<std::pair<std::string, std::string>> replacements = {
            {"&", "&amp;"},
            {"<", "&lt;"},
            {">", "&gt;"},
            {"\"", "&quot;"},
            {"'", "&#x27;"}
        };
        
        for (const auto& replacement : replacements) {
            size_t pos = 0;
            while ((pos = result.find(replacement.first, pos)) != std::string::npos) {
                result.replace(pos, replacement.first.length(), replacement.second);
                pos += replacement.second.length();
            }
        }
        return result;
    }
    
    std::string sanitizeInput(const std::string& input) {
        if (input.empty() || input.length() > MAX_INPUT_LENGTH) {
            return "";
        }
        if (!std::regex_match(input, validInput)) {
            return "";
        }
        return htmlEscape(input);
    }
    
    std::string urlDecode(const std::string& encoded) {
        std::string decoded;
        for (size_t i = 0; i < encoded.length(); ++i) {
            if (encoded[i] == '%' && i + 2 < encoded.length()) {
                int value;
                std::istringstream iss(encoded.substr(i + 1, 2));
                if (iss >> std::hex >> value) {
                    decoded += static_cast<char>(value);
                    i += 2;
                } else {
                    decoded += encoded[i];
                }
            } else if (encoded[i] == '+') {
                decoded += ' ';
            } else {
                decoded += encoded[i];
            }
        }
        return decoded;
    }
    
    std::string getFormPage(const std::string& displayText = "") {
        std::string page = "<DOCTYPE html><html><head><title>Form App</title></head><body>"
                          "<h1>Web Form Application</h1>"
                          "<form method='post'>"
                          "<label for='userInput'>Enter text:</label><br>"
                          "<input type='text' id='userInput' name='userInput' maxlength='1000'><br><br>"
                          "<input type='submit' value='Submit'>"
                          "</form>";
        
        if (!displayText.empty()) {
            page += "<h2>Your input:</h2><p>" + displayText + "</p>";
        }
        page += "</body></html>";
        return page;
    }
    
    void handleRequest(int clientSocket) {
        char buffer[4096] = {0};
        ssize_t bytesRead = recv(clientSocket, buffer, sizeof(buffer) - 1, 0);
        
        if (bytesRead <= 0) {
            close(clientSocket);
            return;
        }
        
        std::string request(buffer, bytesRead);
        std::string response;
        
        if (request.find("POST") == 0) {
            size_t bodyStart = request.find("\r\n\r\n");
            if (bodyStart != std::string::npos) {
                std::string body = request.substr(bodyStart + 4);
                size_t pos = body.find("userInput=");
                if (pos != std::string::npos) {
                    std::string userInput = body.substr(pos + 10);
                    size_t end = userInput.find("&");
                    if (end != std::string::npos) {
                        userInput = userInput.substr(0, end);
                    }
                    userInput = urlDecode(userInput);
                    userInput = sanitizeInput(userInput);
                    response = "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n" + getFormPage(userInput);
                } else {
                    response = "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n" + getFormPage();
                }
            } else {
                response = "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n" + getFormPage();
            }
        } else {
            response = "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n" + getFormPage();
        }
        
        send(clientSocket, response.c_str(), response.length(), 0);
        close(clientSocket);
    }
};

int main() {
    WebFormApp app;
    
    // Test cases
    std::cout << "Test 1 - Normal input: " << app.sanitizeInput("Hello World") << std::endl;
    std::cout << "Test 2 - HTML chars: " << app.sanitizeInput("<script>alert('test')</script>") << std::endl;
    std::cout << "Test 3 - Long input: " << app.sanitizeInput(std::string(1001, 'a')) << std::endl;
    std::cout << "Test 4 - Special chars: " << app.sanitizeInput("Test & < > \" '") << std::endl;
    std::cout << "Test 5 - Invalid chars: " << app.sanitizeInput("Test@#$%") << std::endl;
    
    int serverSocket = socket(AF_INET, SOCK_STREAM, 0);
    if (serverSocket == -1) {
        std::cerr << "Failed to create socket" << std::endl;
        return 1;
    }
    
    int opt = 1;
    setsockopt(serverSocket, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));
    
    sockaddr_in serverAddr = {};
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_addr.s_addr = INADDR_ANY;
    serverAddr.sin_port = htons(8080);
    
    if (bind(serverSocket, (sockaddr*)&serverAddr, sizeof(serverAddr)) == -1) {
        close(serverSocket);
        std::cerr << "Bind failed" << std::endl;
        return 1;
    }
    
    if (listen(serverSocket, 10) == -1) {
        close(serverSocket);
        std::cerr << "Listen failed" << std::endl;
        return 1;
    }
    
    std::cout << "Server started on port 8080" << std::endl;
    
    while (true) {
        sockaddr_in clientAddr = {};
        socklen_t clientLen = sizeof(clientAddr);
        int clientSocket = accept(serverSocket, (sockaddr*)&clientAddr, &clientLen);
        if (clientSocket != -1) {
            app.handleRequest(clientSocket);
        }
    }
    
    close(serverSocket);
    return 0;
}
