#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <stdint.h>

// DNS header structure
typedef struct {
    uint16_t id;
    uint16_t flags;
    uint16_t questions;
    uint16_t answers;
    uint16_t authority;
    uint16_t additional;
} dns_header_t;

// DNS question structure
typedef struct {
    uint16_t qtype;
    uint16_t qclass;
} dns_question_t;

// DNS record structure for responses
typedef struct {
    char domain;
    char ip;
} dns_record_t;

// Simple DNS lookup table
static dns_record_t dns_table[] = {
    {"google.com", "8.8.8.8"},
    {"example.com", "93.184.216.34"},
    {"localhost", "127.0.0.1"},
    {"test.com", "192.168.1.1"},
    {"demo.org", "10.0.0.1"}
};
static const int dns_table_size = sizeof(dns_table) / sizeof(dns_record_t);

// Function to create and bind UDP socket
int create_udp_socket(const char* ip_address, int port) {
    if (!ip_address || port <= 0 || port > 65535) {
        return -1;
    }
    
    int sockfd = socket(AF_INET, SOCK_DGRAM, 0);
    if (sockfd < 0) {
        return -1;
    }
    
    struct sockaddr_in server_addr;
    memset(&server_addr, 0, sizeof(server_addr));
    server_addr.sin_family = AF_INET;
    server_addr.sin_port = htons(port);
    
    if (inet_pton(AF_INET, ip_address, &server_addr.sin_addr) <= 0) {
        close(sockfd);
        return -1;
    }
    
    if (bind(sockfd, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
        close(sockfd);
        return -1;
    }
    
    return sockfd;
}

// Function to parse domain name from DNS question
int parse_domain_name(const unsigned char* buffer, int buffer_size, int offset, char* domain, int domain_size) {
    if (!buffer || !domain || domain_size <= 0 || offset < 0 || offset >= buffer_size) {
        return -1;
    }
    
    int pos = offset;
    int domain_pos = 0;
    int jumped = 0;
    int jump_count = 0;
    
    while (pos < buffer_size && jump_count < 10) {
        unsigned char len = buffer[pos];
        
        if (len == 0) {
            pos++;
            break;
        }
        
        if ((len & 0xC0) == 0xC0) {
            // Compression pointer
            if (!jumped) {
                offset = pos + 2;
            }
            pos = ((len & 0x3F) << 8) | buffer[pos + 1];
            jumped = 1;
            jump_count++;
            continue;
        }
        
        if (len > 63 || pos + len + 1 >= buffer_size) {
            return -1;
        }
        
        pos++;
        
        if (domain_pos > 0 && domain_pos < domain_size - 1) {
            domain[domain_pos++] = '.';
        }
        
        for (int i = 0; i < len && domain_pos < domain_size - 1 && pos < buffer_size; i++) {
            domain[domain_pos++] = buffer[pos++];
        }
    }
    
    if (domain_pos < domain_size) {
        domain[domain_pos] = '\0';
    }
    
    return jumped ? offset : pos;
}

// Function to lookup DNS record
const char* lookup_dns_record(const char* domain) {
    if (!domain) {
        return NULL;
    }
    
    for (int i = 0; i < dns_table_size; i++) {
        if (strcmp(dns_table[i].domain, domain) == 0) {
            return dns_table[i].ip;
        }
    }
    return NULL;
}

// Function to create DNS response
int create_dns_response(unsigned char* response_buffer, int buffer_size, 
                       uint16_t query_id, const char* domain, const char* ip_address) {
    if (!response_buffer || buffer_size < 512 || !domain || !ip_address) {
        return -1;
    }
    
    memset(response_buffer, 0, buffer_size);
    
    dns_header_t* header = (dns_header_t*)response_buffer;
    header->id = query_id;
    header->flags = htons(0x8180); // Response, recursion desired & available
    header->questions = htons(1);
    header->answers = htons(1);
    header->authority = 0;
    header->additional = 0;
    
    int pos = sizeof(dns_header_t);
    
    // Add question section
    int domain_len = strlen(domain);
    if (domain_len > 253 || pos + domain_len + 10 >= buffer_size) {
        return -1;
    }
    
    // Encode domain name
    const char* src = domain;
    while (*src && pos < buffer_size - 1) {
        const char* next_dot = strchr(src, '.');
        int label_len = next_dot ? (next_dot - src) : strlen(src);
        
        if (label_len > 63 || pos + label_len + 1 >= buffer_size) {
            return -1;
        }
        
        response_buffer[pos++] = (unsigned char)label_len;
        memcpy(response_buffer + pos, src, label_len);
        pos += label_len;
        
        src = next_dot ? (next_dot + 1) : (src + label_len);
    }
    response_buffer[pos++] = 0; // End of domain name
    
    // Question type and class
    if (pos + 4 >= buffer_size) {
        return -1;
    }
    *(uint16_t*)(response_buffer + pos) = htons(1); // Type A
    pos += 2;
    *(uint16_t*)(response_buffer + pos) = htons(1); // Class IN
    pos += 2;
    
    // Add answer section
    if (pos + 16 >= buffer_size) {
        return -1;
    }
    
    // Name (compression pointer to question)
    *(uint16_t*)(response_buffer + pos) = htons(0xC00C);
    pos += 2;
    
    // Type, class, TTL
    *(uint16_t*)(response_buffer + pos) = htons(1); // Type A
    pos += 2;
    *(uint16_t*)(response_buffer + pos) = htons(1); // Class IN
    pos += 2;
    *(uint32_t*)(response_buffer + pos) = htonl(3600); // TTL
    pos += 4;
    *(uint16_t*)(response_buffer + pos) = htons(4); // Data length
    pos += 2;
    
    // IP address
    struct in_addr addr;
    if (inet_pton(AF_INET, ip_address, &addr) <= 0) {
        return -1;
    }
    memcpy(response_buffer + pos, &addr, 4);
    pos += 4;
    
    return pos;
}

// Function to process DNS request
int process_dns_request(int sockfd, const char* listen_ip, int listen_port) {
    if (sockfd < 0 || !listen_ip || listen_port <= 0) {
        return -1;
    }
    
    unsigned char buffer;
    unsigned char response;
    struct sockaddr_in client_addr;
    socklen_t addr_len = sizeof(client_addr);
    
    printf("DNS Server listening on %s:%d\n", listen_ip, listen_port);
    
    while (1) {
        memset(buffer, 0, sizeof(buffer));
        memset(&client_addr, 0, sizeof(client_addr));
        
        ssize_t recv_len = recvfrom(sockfd, buffer, sizeof(buffer) - 1, 0,
                                   (struct sockaddr*)&client_addr, &addr_len);
        
        if (recv_len < 0) {
            continue;
        }
        
        if (recv_len < sizeof(dns_header_t)) {
            continue;
        }
        
        dns_header_t* header = (dns_header_t*)buffer;
        
        // Validate header
        if (ntohs(header->questions) != 1 || (ntohs(header->flags) & 0x8000)) {
            continue;
        }
        
        char domain;
        memset(domain, 0, sizeof(domain));
        
        int offset = parse_domain_name(buffer, recv_len, sizeof(dns_header_t), 
                                     domain, sizeof(domain) - 1);
        
        if (offset < 0 || strlen(domain) == 0) {
            continue;
        }
        
        printf("DNS Query for: %s\n", domain);
        
        const char* ip_address = lookup_dns_record(domain);
        if (!ip_address) {
            ip_address = "0.0.0.0"; // NXDOMAIN response
        }
        
        int response_len = create_dns_response(response, sizeof(response),
                                             header->id, domain, ip_address);
        
        if (response_len > 0) {
            ssize_t sent = sendto(sockfd, response, response_len, 0,
                                 (struct sockaddr*)&client_addr, addr_len);
            if (sent > 0) {
                printf("Response sent: %s -> %s\n", domain, ip_address);
            }
        }
    }
    
    return 0;
}

// Test cases
void run_test_cases() {
    printf("Running DNS Server Test Cases:\n\n");
    
    // Test case 1: Create UDP socket
    printf("Test 1: Creating UDP socket on 127.0.0.1:5353\n");
    int sockfd = create_udp_socket("127.0.0.1", 5353);
    if (sockfd >= 0) {
        printf("\u2713 Socket created successfully\n");
        close(sockfd);
    } else {
        printf("\u2717 Failed to create socket\n");
    }
    
    // Test case 2: Invalid IP address
    printf("\nTest 2: Invalid IP address\n");
    sockfd = create_udp_socket("999.999.999.999", 5353);
    if (sockfd < 0) {
        printf("\u2713 Correctly rejected invalid IP\n");
    } else {
        printf("\u2717 Should have rejected invalid IP\n");
        close(sockfd);
    }
    
    // Test case 3: DNS record lookup
    printf("\nTest 3: DNS record lookup\n");
    const char* ip = lookup_dns_record("google.com");
    if (ip && strcmp(ip, "8.8.8.8") == 0) {
        printf("\u2713 google.com -> %s\n", ip);
    } else {
        printf("\u2717 Failed to lookup google.com\n");
    }
    
    // Test case 4: Unknown domain lookup
    printf("\nTest 4: Unknown domain lookup\n");
    ip = lookup_dns_record("unknown.domain");
    if (!ip) {
        printf("\u2713 Correctly returned NULL for unknown domain\n");
    } else {
        printf("\u2717 Should return NULL for unknown domain\n");
    }
    
    // Test case 5: Domain name parsing
    printf("\nTest 5: Domain name parsing\n");
    unsigned char test_query[] = {
        0x00, 0x01, 0x01, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
        0x07, 'e', 'x', 'a', 'm', 'p', 'l', 'e', 0x03, 'c', 'o', 'm', 0x00,
        0x00, 0x01, 0x00, 0x01
    };
    char parsed_domain;
    int result = parse_domain_name(test_query, sizeof(test_query), 12, 
                                  parsed_domain, sizeof(parsed_domain));
    if (result > 0 && strcmp(parsed_domain, "example.com") == 0) {
        printf("\u2713 Parsed domain: %s\n", parsed_domain);
    } else {
        printf("\u2717 Failed to parse domain name\n");
    }
}

