#include <iostream>
#include <string>
#include <vector>
#include <random>
#include <chrono>
#include <unordered_map>
#include <algorithm>
#include <iomanip>
#include <sstream>
#include <cstring>

class PasswordResetSystem {
private:
    struct UserRecord {
        std::string email;
        std::string passwordHash;
        std::string salt;
    };
    
    struct ResetToken {
        std::string token;
        std::string email;
        std::chrono::time_point<std::chrono::steady_clock> expiry;
    };
    
    std::unordered_map<std::string, UserRecord> users;
    std::unordered_map<std::string, ResetToken> resetTokens;
    std::random_device rd;
    std::mt19937 gen;

    std::string generateSalt(size_t length = 16) {
        const std::string chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
        std::uniform_int_distribution<> dis(0, chars.size() - 1);
        std::string salt;
        salt.reserve(length);
        for (size_t i = 0; i < length; ++i) {
            salt += chars[dis(gen)];
        }
        return salt;
    }
    
    std::string generateSecureToken(size_t length = 32) {
        const std::string chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
        std::uniform_int_distribution<> dis(0, chars.size() - 1);
        std::string token;
        token.reserve(length);
        for (size_t i = 0; i < length; ++i) {
            token += chars[dis(gen)];
        }
        return token;
    }
    
    std::string hashPassword(const std::string& password, const std::string& salt) {
        // Simplified PBKDF2-like implementation for demonstration
        std::string combined = password + salt;
        std::hash<std::string> hasher;
        size_t hash = hasher(combined);
        
        // Multiple iterations for security
        for (int i = 0; i < 10000; ++i) {
            combined = std::to_string(hash) + salt;
            hash = hasher(combined);
        }
        
        std::stringstream ss;
        ss << std::hex << hash;
        return ss.str();
    }
    
    bool constantTimeCompare(const std::string& a, const std::string& b) {
        if (a.length() != b.length()) return false;
        int result = 0;
        for (size_t i = 0; i < a.length(); ++i) {
            result |= a[i] ^ b[i];
        }
        return result == 0;
    }
    
    bool isValidEmail(const std::string& email) {
        if (email.length() > 254 || email.length() < 5) return false;
        size_t atPos = email.find('@');
        return atPos != std::string::npos && atPos > 0 && atPos < email.length() - 1;
    }
    
    bool isValidPassword(const std::string& password) {
        return password.length() >= 8 && password.length() <= 128;
    }

public:
    PasswordResetSystem() : gen(rd()) {}
    
    bool registerUser(const std::string& email, const std::string& password) {
        if (!isValidEmail(email) || !isValidPassword(password)) return false;
        if (users.find(email) != users.end()) return false;
        
        std::string salt = generateSalt();
        std::string passwordHash = hashPassword(password, salt);
        
        users[email] = {email, passwordHash, salt};
        return true;
    }
    
    std::string generateResetToken(const std::string& email) {
        if (!isValidEmail(email)) return "";
        if (users.find(email) == users.end()) return "";
        
        std::string token = generateSecureToken();
        auto expiry = std::chrono::steady_clock::now() + std::chrono::minutes(15);
        
        resetTokens[token] = {token, email, expiry};
        return token;
    }
    
    bool validateResetToken(const std::string& token) {
        if (token.empty() || token.length() > 64) return false;
        
        auto it = resetTokens.find(token);
        if (it == resetTokens.end()) return false;
        
        if (std::chrono::steady_clock::now() > it->second.expiry) {
            resetTokens.erase(it);
            return false;
        }
        
        return true;
    }
    
    bool resetPassword(const std::string& token, const std::string& newPassword) {
        if (!validateResetToken(token) || !isValidPassword(newPassword)) return false;
        
        auto tokenIt = resetTokens.find(token);
        if (tokenIt == resetTokens.end()) return false;
        
        std::string email = tokenIt->second.email;
        auto userIt = users.find(email);
        if (userIt == users.end()) return false;
        
        std::string newSalt = generateSalt();
        std::string newPasswordHash = hashPassword(newPassword, newSalt);
        
        userIt->second.passwordHash = newPasswordHash;
        userIt->second.salt = newSalt;
        
        resetTokens.erase(tokenIt);
        return true;
    }
    
    bool verifyPassword(const std::string& email, const std::string& password) {
        if (!isValidEmail(email) || !isValidPassword(password)) return false;
        
        auto it = users.find(email);
        if (it == users.end()) return false;
        
        std::string computedHash = hashPassword(password, it->second.salt);
        return constantTimeCompare(computedHash, it->second.passwordHash);
    }
};

int main() {
    PasswordResetSystem system;
    
    // Test case 1: Register user
    std::cout << "Test 1 - Register user: " << (system.registerUser("user@example.com", "password123") ? "PASS" : "FAIL") << std::endl;
    
    // Test case 2: Generate reset token
    std::string token = system.generateResetToken("user@example.com");
    std::cout << "Test 2 - Generate token: " << (!token.empty() ? "PASS" : "FAIL") << std::endl;
    
    // Test case 3: Validate token
    std::cout << "Test 3 - Validate token: " << (system.validateResetToken(token) ? "PASS" : "FAIL") << std::endl;
    
    // Test case 4: Reset password
    std::cout << "Test 4 - Reset password: " << (system.resetPassword(token, "newPassword456") ? "PASS" : "FAIL") << std::endl;
    
    // Test case 5: Verify new password
    std::cout << "Test 5 - Verify new password: " << (system.verifyPassword("user@example.com", "newPassword456") ? "PASS" : "FAIL") << std::endl;
    
    return 0;
}
