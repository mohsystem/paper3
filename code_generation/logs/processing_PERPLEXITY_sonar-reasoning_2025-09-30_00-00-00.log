import java.security.SecureRandom;
import java.util.Base64;
import java.util.HashMap;
import java.util.Map;
import java.nio.charset.StandardCharsets;
import java.security.MessageDigest;
import java.security.NoSuchAlgorithmException;

public class Task40 {
    private static final SecureRandom secureRandom = new SecureRandom();
    private static final Map<String, String> sessions = new HashMap<>();
    private static final Map<String, UserSettings> users = new HashMap<>();
    
    static class UserSettings {
        String email;
        String theme;
        
        UserSettings(String email, String theme) {
            this.email = email;
            this.theme = theme;
        }
    }
    
    public static String generateCSRFToken(String sessionId) {
        byte[] tokenBytes = new byte[32];
        secureRandom.nextBytes(tokenBytes);
        String token = Base64.getEncoder().encodeToString(tokenBytes);
        sessions.put(sessionId, token);
        return token;
    }
    
    public static boolean validateCSRFToken(String sessionId, String submittedToken) {
        if (sessionId == null || submittedToken == null) return false;
        String storedToken = sessions.get(sessionId);
        if (storedToken == null) return false;
        
        byte[] stored = storedToken.getBytes(StandardCharsets.UTF_8);
        byte[] submitted = submittedToken.getBytes(StandardCharsets.UTF_8);
        
        if (stored.length != submitted.length) return false;
        
        int result = 0;
        for (int i = 0; i < stored.length; i++) {
            result |= stored[i] ^ submitted[i];
        }
        return result == 0;
    }
    
    public static String generateForm(String sessionId) {
        String csrfToken = generateCSRFToken(sessionId);
        return "<form method='post'>" +
               "<input type='hidden' name='csrf_token' value='" + csrfToken + "'>" +
               "<input type='email' name='email' required>" +
               "<select name='theme'>" +
               "<option value='light'>Light</option>" +
               "<option value='dark'>Dark</option>" +
               "</select>" +
               "<button type='submit'>Update Settings</button>" +
               "</form>";
    }
    
    public static String updateUserSettings(String sessionId, String csrfToken, String email, String theme) {
        if (!validateCSRFToken(sessionId, csrfToken)) {
            return "CSRF token validation failed";
        }
        
        if (email == null || !email.matches("^[\\w.-]+@[\\w.-]+\\.[a-zA-Z]{2,}$")) {
            return "Invalid email format";
        }
        
        if (theme == null || (!theme.equals("light") && !theme.equals("dark"))) {
            return "Invalid theme selection";
        }
        
        users.put(sessionId, new UserSettings(email, theme));
        sessions.remove(sessionId);
        return "Settings updated successfully";
    }
    
    public static void main(String[] args) {
        // Test case 1: Valid form generation
        System.out.println("Test 1: " + generateForm("session1").contains("csrf_token"));
        
        // Test case 2: Valid settings update
        String token = generateCSRFToken("session2");
        System.out.println("Test 2: " + updateUserSettings("session2", token, "user@example.com", "dark").equals("Settings updated successfully"));
        
        // Test case 3: Invalid CSRF token
        System.out.println("Test 3: " + updateUserSettings("session3", "invalid_token", "user@example.com", "light").contains("CSRF token validation failed"));
        
        // Test case 4: Invalid email format
        String token4 = generateCSRFToken("session4");
        System.out.println("Test 4: " + updateUserSettings("session4", token4, "invalid-email", "light").contains("Invalid email format"));
        
        // Test case 5: Invalid theme
        String token5 = generateCSRFToken("session5");
        System.out.println("Test 5: " + updateUserSettings("session5", token5, "user@example.com", "invalid_theme").contains("Invalid theme selection"));
    }
}
