        } else {
            printf("Test 3 FAILED: %s\n", env.fault_string);
        }
        xmlrpc_DECREF(paramArray);
    }
    xmlrpc_env_clean(&env);
    
    // Test 4: Add with negative numbers
    xmlrpc_env_init(&env);
    paramArray = xmlrpc_build_value(&env, "(ii)", -10, 15);
    if (!env.fault_occurred) {
        result = sample_add(&env, paramArray, NULL, NULL);
        if (!env.fault_occurred && result) {
            xmlrpc_decompose_value(&env, result, "i", &intResult);
            if (!env.fault_occurred && intResult == 5) {
                printf("Test 4 PASSED: -10 + 15 = %d\n", intResult);
                testsPassed++;
            } else {
                printf("Test 4 FAILED: Expected 5, got %d\n", intResult);
            }
            xmlrpc_DECREF(result);
        } else {
            printf("Test 4 FAILED: %s\n", env.fault_string);
        }
        xmlrpc_DECREF(paramArray);
    }
    xmlrpc_env_clean(&env);
    
    // Test 5: Multiply by zero
    xmlrpc_env_init(&env);
    paramArray = xmlrpc_build_value(&env, "(ii)", 42, 0);
    if (!env.fault_occurred) {
        result = sample_multiply(&env, paramArray, NULL, NULL);
        if (!env.fault_occurred && result) {
            xmlrpc_decompose_value(&env, result, "i", &intResult);
            if (!env.fault_occurred && intResult == 0) {
                printf("Test 5 PASSED: 42 * 0 = %d\n", intResult);
                testsPassed++;
            } else {
                printf("Test 5 FAILED: Expected 0, got %d\n", intResult);
            }
            xmlrpc_DECREF(result);
        } else {
            printf("Test 5 FAILED: %s\n", env.fault_string);
        }
        xmlrpc_DECREF(paramArray);
    }
    xmlrpc_env_clean(&env);
    
    printf("\nTests passed: %d/5\n", testsPassed);
    return testsPassed == 5 ? 0 : 1;
}

