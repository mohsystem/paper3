#include <iostream>
#include <string>
#include <vector>
#include <fstream>
#include <memory>
#include <cstring>
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/kdf.h>
#include <openssl/sha.h>

class SecureDataStorage {
private:
    static const int SALT_SIZE = 16;
    static const int IV_SIZE = 12;
    static const int TAG_SIZE = 16;
    static const int KEY_SIZE = 32;
    static const int PBKDF2_ITERATIONS = 210000;
    static const std::string MAGIC;
    static const uint32_t VERSION = 1;

    bool deriveKey(const std::string& passphrase, const std::vector<uint8_t>& salt, std::vector<uint8_t>& key) {
        key.resize(KEY_SIZE);
        EVP_KDF* kdf = EVP_KDF_fetch(nullptr, "PBKDF2", nullptr);
        if (!kdf) return false;
        
        EVP_KDF_CTX* ctx = EVP_KDF_CTX_new(kdf);
        if (!ctx) {
            EVP_KDF_free(kdf);
            return false;
        }
        
        OSSL_PARAM params[] = {
            OSSL_PARAM_construct_octet_string("pass", (void*)passphrase.c_str(), passphrase.length()),
            OSSL_PARAM_construct_octet_string("salt", (void*)salt.data(), salt.size()),
            OSSL_PARAM_construct_int("iter", const_cast<int*>(&PBKDF2_ITERATIONS)),
            OSSL_PARAM_construct_utf8_string("digest", "SHA256", 0),
            OSSL_PARAM_construct_end()
        };
        
        bool success = EVP_KDF_derive(ctx, key.data(), key.size(), params) > 0;
        
        EVP_KDF_CTX_free(ctx);
        EVP_KDF_free(kdf);
        return success;
    }

public:
    bool encryptData(const std::string& data, const std::string& passphrase, const std::string& filename) {
        if (data.empty() || passphrase.length() < 8 || filename.empty()) {
            return false;
        }

        std::vector<uint8_t> salt(SALT_SIZE);
        std::vector<uint8_t> iv(IV_SIZE);
        
        if (RAND_bytes(salt.data(), SALT_SIZE) != 1 || RAND_bytes(iv.data(), IV_SIZE) != 1) {
            return false;
        }

        std::vector<uint8_t> key;
        if (!deriveKey(passphrase, salt, key)) {
            return false;
        }

        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) return false;

        if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, key.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        std::vector<uint8_t> ciphertext(data.length());
        int len;
        if (EVP_EncryptUpdate(ctx, ciphertext.data(), &len, (uint8_t*)data.c_str(), data.length()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }
        ciphertext.resize(len);

        if (EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        std::vector<uint8_t> tag(TAG_SIZE);
        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_SIZE, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        EVP_CIPHER_CTX_free(ctx);

        std::ofstream file(filename, std::ios::binary);
        if (!file) return false;

        file.write(MAGIC.c_str(), 4);
        uint32_t version = VERSION;
        file.write(reinterpret_cast<char*>(&version), sizeof(version));
        file.write(reinterpret_cast<char*>(salt.data()), SALT_SIZE);
        file.write(reinterpret_cast<char*>(iv.data()), IV_SIZE);
        file.write(reinterpret_cast<char*>(ciphertext.data()), ciphertext.size());
        file.write(reinterpret_cast<char*>(tag.data()), TAG_SIZE);

        return file.good();
    }

    bool decryptData(const std::string& filename, const std::string& passphrase, std::string& data) {
        if (filename.empty() || passphrase.length() < 8) {
            return false;
        }

        std::ifstream file(filename, std::ios::binary);
        if (!file) return false;

        char magic = {0};
        file.read(magic, 4);
        if (std::string(magic) != MAGIC) return false;

        uint32_t version;
        file.read(reinterpret_cast<char*>(&version), sizeof(version));
        if (version != VERSION) return false;

        std::vector<uint8_t> salt(SALT_SIZE);
        std::vector<uint8_t> iv(IV_SIZE);
        file.read(reinterpret_cast<char*>(salt.data()), SALT_SIZE);
        file.read(reinterpret_cast<char*>(iv.data()), IV_SIZE);

        file.seekg(0, std::ios::end);
        size_t fileSize = file.tellg();
        size_t ciphertextSize = fileSize - 4 - sizeof(version) - SALT_SIZE - IV_SIZE - TAG_SIZE;
        file.seekg(4 + sizeof(version) + SALT_SIZE + IV_SIZE);

        std::vector<uint8_t> ciphertext(ciphertextSize);
        file.read(reinterpret_cast<char*>(ciphertext.data()), ciphertextSize);

        std::vector<uint8_t> tag(TAG_SIZE);
        file.read(reinterpret_cast<char*>(tag.data()), TAG_SIZE);

        if (!file) return false;

        std::vector<uint8_t> key;
        if (!deriveKey(passphrase, salt, key)) {
            return false;
        }

        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) return false;

        if (EVP_DecryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, key.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_TAG, TAG_SIZE, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        std::vector<uint8_t> plaintext(ciphertext.size());
        int len;
        if (EVP_DecryptUpdate(ctx, plaintext.data(), &len, ciphertext.data(), ciphertext.size()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }
        plaintext.resize(len);

        if (EVP_DecryptFinal_ex(ctx, plaintext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            return false;
        }

        EVP_CIPHER_CTX_free(ctx);
        data = std::string(plaintext.begin(), plaintext.end());
        return true;
    }
};

