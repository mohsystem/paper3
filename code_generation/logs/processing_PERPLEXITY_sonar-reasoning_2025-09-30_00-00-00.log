#include <iostream>
#include <string>
#include <stdexcept>
#include <memory>
#include <climits>
#include <xmlrpc-c/base.hpp>
#include <xmlrpc-c/registry.hpp>
#include <xmlrpc-c/server_abyss.hpp>

class addNumbers : public xmlrpc_c::method {
public:
    addNumbers() {
        this->_signature = "i:ii";
        this->_help = "Add two integers";
    }
    
    void execute(xmlrpc_c::paramList const& paramList,
                xmlrpc_c::value* const retvalP) {
        
        if (paramList.size() != 2) {
            throw xmlrpc_c::fault("Invalid parameter count", xmlrpc_c::fault::CODE_INVALID_PARAMS);
        }
        
        try {
            int const addend = paramList.getInt(0);
            int const adder = paramList.getInt(1);
            
            if ((adder > 0 && addend > INT_MAX - adder) ||
                (adder < 0 && addend < INT_MIN - adder)) {
                throw xmlrpc_c::fault("Integer overflow", xmlrpc_c::fault::CODE_INVALID_PARAMS);
            }
            
            int const sum = addend + adder;
            *retvalP = xmlrpc_c::value_int(sum);
            
        } catch (xmlrpc_c::girerr::error const& error) {
            throw xmlrpc_c::fault("Invalid parameter type", xmlrpc_c::fault::CODE_INVALID_PARAMS);
        }
    }
};

class concatenateStrings : public xmlrpc_c::method {
public:
    concatenateStrings() {
        this->_signature = "s:ss";
        this->_help = "Concatenate two strings";
    }
    
    void execute(xmlrpc_c::paramList const& paramList,
                xmlrpc_c::value* const retvalP) {
        
        if (paramList.size() != 2) {
            throw xmlrpc_c::fault("Invalid parameter count", xmlrpc_c::fault::CODE_INVALID_PARAMS);
        }
        
        try {
            std::string const str1 = paramList.getString(0);
            std::string const str2 = paramList.getString(1);
            
            if (str1.length() > 1000 || str2.length() > 1000) {
                throw xmlrpc_c::fault("String too long", xmlrpc_c::fault::CODE_INVALID_PARAMS);
            }
            
            if (str1.length() + str2.length() > 2000) {
                throw xmlrpc_c::fault("Result string would be too long", xmlrpc_c::fault::CODE_INVALID_PARAMS);
            }
            
            std::string const result = str1 + str2;
            *retvalP = xmlrpc_c::value_string(result);
            
        } catch (xmlrpc_c::girerr::error const& error) {
            throw xmlrpc_c::fault("Invalid parameter type", xmlrpc_c::fault::CODE_INVALID_PARAMS);
        }
    }
};

class factorial : public xmlrpc_c::method {
public:
    factorial() {
        this->_signature = "i:i";
        this->_help = "Calculate factorial of a number";
    }
    
    void execute(xmlrpc_c::paramList const& paramList,
                xmlrpc_c::value* const retvalP) {
        
        if (paramList.size() != 1) {
            throw xmlrpc_c::fault("Invalid parameter count", xmlrpc_c::fault::CODE_INVALID_PARAMS);
        }
        
        try {
            int const n = paramList.getInt(0);
            
            if (n < 0) {
                throw xmlrpc_c::fault("Factorial not defined for negative numbers", xmlrpc_c::fault::CODE_INVALID_PARAMS);
            }
            
            if (n > 12) {
                throw xmlrpc_c::fault("Number too large for factorial calculation", xmlrpc_c::fault::CODE_INVALID_PARAMS);
            }
            
            int result = 1;
            for (int i = 2; i <= n; ++i) {
                result *= i;
            }
            
            *retvalP = xmlrpc_c::value_int(result);
            
        } catch (xmlrpc_c::girerr::error const& error) {
            throw xmlrpc_c::fault("Invalid parameter type", xmlrpc_c::fault::CODE_INVALID_PARAMS);
        }
    }
};

class XMLRPCServer {
private:
    std::unique_ptr<xmlrpc_c::registry> registryP;
    std::unique_ptr<xmlrpc_c::serverAbyss> serverP;
    int port;
    
public:
    XMLRPCServer(int serverPort) : port(serverPort) {
        if (port < 1024 || port > 65535) {
            throw std::invalid_argument("Port must be between 1024 and 65535");
        }
        
        try {
            registryP = std::make_unique<xmlrpc_c::registry>();
            
            registryP->addMethod("add", std::make_unique<addNumbers>());
            registryP->addMethod("concat", std::make_unique<concatenateStrings>());
            registryP->addMethod("factorial", std::make_unique<factorial>());
            
            serverP = std::make_unique<xmlrpc_c::serverAbyss>(
                xmlrpc_c::serverAbyss::constrOpt()
                .registryP(registryP.get())
                .portNumber(port)
            );
            
        } catch (std::exception const& e) {
            throw std::runtime_error("Failed to initialize XML-RPC server: " + std::string(e.what()));
        }
    }
    
    void run() {
        try {
            std::cout << "XML-RPC Server running on port " << port << std::endl;
            serverP->run();
        } catch (std::exception const& e) {
            throw std::runtime_error("Server error: " + std::string(e.what()));
        }
    }
    
    void runOnce() {
        try {
            serverP->runOnce();
        } catch (std::exception const& e) {
            std::cerr << "Server error: " << e.what() << std::endl;
        }
    }
    
    int getPort() const { return port; }
    
    ~XMLRPCServer() = default;
};

int main() {
    try {
        // Test case 1: Basic server creation with valid port
        std::cout << "Test 1: Creating XML-RPC server on port 8080..." << std::endl;
        XMLRPCServer server1(8080);
        std::cout << "\u2713 Server created successfully on port " << server1.getPort() << std::endl;
        
        // Test case 2: Invalid port handling (too low)
        std::cout << "\nTest 2: Testing invalid port (too low)..." << std::endl;
        try {
