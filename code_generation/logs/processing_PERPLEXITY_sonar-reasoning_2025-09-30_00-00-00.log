#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <limits.h>
#include <unistd.h>
#include <pthread.h>
#include <ctype.h>
#include <xmlrpc.h>
#include <xmlrpc_server.h>
#include <xmlrpc_server_abyss.h>
#include <xmlrpc_client.h>

#define MAX_STRING_LENGTH 1000
#define SERVER_PORT 8081
#define SERVER_URL "http://localhost:8081/RPC2"

static void die_if_fault_occurred(xmlrpc_env *env) {
    if (env->fault_occurred) {
        fprintf(stderr, "XML-RPC Fault: %s (%d)\n", 
                env->fault_string, env->fault_code);
        exit(1);
    }
}

static int validate_string_length(const char *str) {
    if (!str) return 0;
    size_t len = strlen(str);
    return len <= MAX_STRING_LENGTH;
}

static void sanitize_string(char *dest, const char *src, size_t dest_size) {
    if (!dest || !src || dest_size == 0) return;
    
    size_t i = 0, j = 0;
    size_t src_len = strlen(src);
    
    while (i < src_len && j < dest_size - 1) {
        if (src[i] >= 32 && src[i] <= 126) {
            dest[j++] = src[i];
        }
        i++;
    }
    dest[j] = '\0';
}

static xmlrpc_value* echo_method(xmlrpc_env *env, 
                                xmlrpc_value *param_array, 
                                void *server_info) {
    const char *input;
    char *response = NULL;
    char sanitized[MAX_STRING_LENGTH + 1];
    xmlrpc_value *result = NULL;
    
    xmlrpc_decompose_value(env, param_array, "(s)", &input);
    if (env->fault_occurred) return NULL;
    
    if (!validate_string_length(input)) {
        xmlrpc_env_set_fault(env, 400, "Input string too long");
        return NULL;
    }
    
    sanitize_string(sanitized, input, sizeof(sanitized));
    
    size_t response_len = strlen("Echo: ") + strlen(sanitized) + 1;
    response = malloc(response_len);
    if (!response) {
        xmlrpc_env_set_fault(env, 500, "Memory allocation failed");
        return NULL;
    }
    
    int ret = snprintf(response, response_len, "Echo: %s", sanitized);
    if (ret < 0 || (size_t)ret >= response_len) {
        free(response);
        xmlrpc_env_set_fault(env, 500, "String formatting error");
        return NULL;
    }
    
    result = xmlrpc_string_new(env, response);
    free(response);
    return result;
}

static xmlrpc_value* add_method(xmlrpc_env *env, 
                               xmlrpc_value *param_array, 
                               void *server_info) {
    int a, b;
    
    xmlrpc_decompose_value(env, param_array, "(ii)", &a, &b);
    if (env->fault_occurred) return NULL;
    
    // Check for integer overflow
    if ((b > 0 && a > INT_MAX - b) || (b < 0 && a < INT_MIN - b)) {
        xmlrpc_env_set_fault(env, 400, "Integer overflow");
        return NULL;
    }
    
    return xmlrpc_int_new(env, a + b);
}

typedef struct {
    xmlrpc_registry *registry;
    xmlrpc_server_abyss_parms server_parms;
} server_data_t;

static void* run_server(void *arg) {
    server_data_t *data = (server_data_t*)arg;
    xmlrpc_env env;
    
    xmlrpc_env_init(&env);
    xmlrpc_server_abyss(&env, &data->server_parms, XMLRPC_APSIZE(port));
    xmlrpc_env_clean(&env);
    
    return NULL;
}

static int test_echo_client(const char *input, const char *expected) {
    xmlrpc_env env;
    xmlrpc_value *result;
    const char *response;
    int success = 0;
    
    xmlrpc_env_init(&env);
    xmlrpc_client_init2(&env, XMLRPC_CLIENT_NO_FLAGS, "Test Client", "1.0", NULL, 0);
    if (env.fault_occurred) {
        xmlrpc_env_clean(&env);
        return 0;
    }
    
    result = xmlrpc_client_call(&env, SERVER_URL, "echo", "(s)", input);
    if (!env.fault_occurred) {
        xmlrpc_decompose_value(&env, result, "s", &response);
        if (!env.fault_occurred && strcmp(response, expected) == 0) {
            success = 1;
        }
        xmlrpc_DECREF(result);
    }
    
    xmlrpc_client_cleanup();
    xmlrpc_env_clean(&env);
    return success;
}

static int test_add_client(int a, int b, int expected) {
    xmlrpc_env env;
    xmlrpc_value *result;
    int response;
    int success = 0;
    
    xmlrpc_env_init(&env);
    xmlrpc_client_init2(&env, XMLRPC_CLIENT_NO_FLAGS, "Test Client", "1.0", NULL, 0);
    if (env.fault_occurred) {
        xmlrpc_env_clean(&env);
        return 0;
    }
    
    result = xmlrpc_client_call(&env, SERVER_URL, "add", "(ii)", a, b);
    if (!env.fault_occurred) {
        xmlrpc_decompose_value(&env, result, "i", &response);
        if (!env.fault_occurred && response == expected) {
            success = 1;
        }
        xmlrpc_DECREF(result);
    }
    
    xmlrpc_client_cleanup();
    xmlrpc_env_clean(&env);
    return success;
}

int main() {
    xmlrpc_env env;
    server_data_t server_data;
    pthread_t server_thread;
    
    xmlrpc_env_init(&env);
    xmlrpc_server_abyss_global_init(&env);
    die_if_fault_occurred(&env);
    
    server_data.registry = xmlrpc_registry_new(&env);
    die_if_fault_occurred(&env);
    
    xmlrpc_registry_add_method(&env, server_data.registry, NULL, "echo",
                              &echo_method, NULL);
    die_if_fault_occurred(&env);
    
    xmlrpc_registry_add_method(&env, server_data.registry, NULL, "add",
                              &add_method, NULL);
    die_if_fault_occurred(&env);
    
    server_data.server_parms.config_file_name = NULL;
    server_data.server_parms.registryP = server_data.registry;
    server_data.server_parms.port = SERVER_PORT;
    
    printf("Starting XML-RPC Server on port %d\n", SERVER_PORT);
    
    if (pthread_create(&server_thread, NULL, run_server, &server_data) != 0) {
        fprintf(stderr, "Failed to create server thread\n");
        exit(1);
    }
    
    sleep(1); // Give server time to start
    
    // Test case 1: Echo simple string
    int test1 = test_echo_client("hello", "Echo: hello");
    printf("Test 1 (echo simple): %s\n", test1 ? "PASS" : "FAIL");
    
    // Test case 2: Echo empty string
    int test2 = test_echo_client("", "Echo: ");
    printf("Test 2 (echo empty): %s\n", test2 ? "PASS" : "FAIL");
    
    // Test case 3: Add positive numbers
    int test3 = test_add_client(5, 3, 8);
    printf("Test 3 (add positive): %s\n", test3 ? "PASS" : "FAIL");
    
    // Test case 4: Add negative numbers
    int test4 = test_add_client(-10, 5, -5);
    printf("Test 4 (add negative): %s\n", test4 ? "PASS" : "FAIL");
    
    // Test case 5: Add zero
    int test5 = test_add_client(0, 42, 42);
    printf("Test 5 (add zero): %s\n", test5 ? "PASS" : "FAIL");
    
    printf("All tests completed. Server running for 2 more seconds...\n");
    sleep(2);
    
    xmlrpc_registry_free(server_data.registry);
    xmlrpc_env_clean(&env);
    xmlrpc_server_abyss_global_term();
    
    return 0;
}
