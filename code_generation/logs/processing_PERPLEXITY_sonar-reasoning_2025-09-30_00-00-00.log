class SecureHash {
private:
    static constexpr size_t SALT_SIZE = 16;
    static constexpr size_t HASH_SIZE = 32;
    static constexpr int ITERATIONS = 210000;

    static std::vector<uint8_t> generateSalt() {
        std::vector<uint8_t> salt(SALT_SIZE);
        std::random_device rd;
        std::mt19937 gen(rd());
        std::uniform_int_distribution<uint8_t> dis(0, 255);
        
        for (size_t i = 0; i < SALT_SIZE; ++i) {
            salt[i] = dis(gen);
        }
        return salt;
    }

    static std::vector<uint8_t> pbkdf2(const std::string& password, const std::vector<uint8_t>& salt) {
        std::vector<uint8_t> hash(HASH_SIZE);
        std::hash<std::string> hasher;
        
        // Simplified PBKDF2 implementation using standard library
        std::string combined = password + std::string(salt.begin(), salt.end());
        for (int i = 0; i < ITERATIONS; ++i) {
            size_t hashValue = hasher(combined + std::to_string(i));
            for (size_t j = 0; j < HASH_SIZE; ++j) {
                hash[j] ^= static_cast<uint8_t>((hashValue >> (j % 8)) & 0xFF);
            }
        }
        return hash;
    }

public:
    static std::string hashPassword(const std::string& password) {
        if (password.empty() || password.length() > 1000) {
            return "";
        }
        
        auto salt = generateSalt();
        auto hash = pbkdf2(password, salt);
        
        std::ostringstream oss;
        for (uint8_t b : salt) {
            oss << std::hex << std::setw(2) << std::setfill('0') << static_cast<int>(b);
        }
        oss << ":";
        for (uint8_t b : hash) {
            oss << std::hex << std::setw(2) << std::setfill('0') << static_cast<int>(b);
        }
        return oss.str();
    }

    static bool verifyPassword(const std::string& password, const std::string& storedHash) {
        if (password.empty() || storedHash.empty() || password.length() > 1000) {
            return false;
        }
        
        size_t colonPos = storedHash.find(':');
        if (colonPos == std::string::npos || colonPos != SALT_SIZE * 2) {
            return false;
        }
        
        std::string saltHex = storedHash.substr(0, colonPos);
        std::string hashHex = storedHash.substr(colonPos + 1);
        
        if (saltHex.length() != SALT_SIZE * 2 || hashHex.length() != HASH_SIZE * 2) {
            return false;
        }
        
        std::vector<uint8_t> salt(SALT_SIZE);
        for (size_t i = 0; i < SALT_SIZE; ++i) {
            std::string byteStr = saltHex.substr(i * 2, 2);
            salt[i] = static_cast<uint8_t>(std::stoi(byteStr, nullptr, 16));
        }
        
        auto computedHash = pbkdf2(password, salt);
        
        // Constant-time comparison
        bool match = true;
        for (size_t i = 0; i < HASH_SIZE; ++i) {
            std::string byteStr = hashHex.substr(i * 2, 2);
            uint8_t storedByte = static_cast<uint8_t>(std::stoi(byteStr, nullptr, 16));
            match &= (computedHash[i] == storedByte);
        }
        return match;
    }
};

class InputValidator {
public:
    static bool isValidUsername(const std::string& username) {
        if (username.empty() || username.length() > 50) {
            return false;
        }
        
        for (char c : username) {
            if (!std::isalnum(c) && c != '_' && c != '-') {
                return false;
            }
        }
        return true;
    }
    
    static bool isValidPassword(const std::string& password) {
        if (password.length() < 8 || password.length() > 100) {
            return false;
        }
        
        bool hasUpper = false, hasLower = false, hasDigit = false, hasSpecial = false;
        for (char c : password) {
            if (std::isupper(c)) hasUpper = true;
            else if (std::islower(c)) hasLower = true;
            else if (std::isdigit(c)) hasDigit = true;
            else if (std::ispunct(c)) hasSpecial = true;
        }
        
        return hasUpper && hasLower && hasDigit && hasSpecial;
    }
    
    static bool isValidMessage(const std::string& message) {
        return !message.empty() && message.length() <= 1000;
    }
};

class UserDatabase {
private:
    std::mutex dbMutex;
    std::map<std::string, std::string> users;
    const std::string dbFile = "users.db";
    
    void loadUsers() {
        std::lock_guard<std::mutex> lock(dbMutex);
        std::ifstream file(dbFile);
        std::string line;
        
        while (std::getline(file, line)) {
            if (line.empty()) continue;
            
            size_t colonPos = line.find(':');
            if (colonPos != std::string::npos && colonPos > 0) {
                std::string username = line.substr(0, colonPos);
                std::string hash = line.substr(colonPos + 1);
                
                if (InputValidator::isValidUsername(username)) {
                    users[username] = hash;
                }
            }
        }
    }
    
    void saveUsers() {
        std::lock_guard<std::mutex> lock(dbMutex);
        std::ofstream file(dbFile);
        
        for (const auto& pair : users) {
            file << pair.first << ":" << pair.second << "\n";
        }
        file.flush();
    }
    
public:
    UserDatabase() {
        loadUsers();
    }
    
    bool registerUser(const std::string& username, const std::string& password) {
        if (!InputValidator::isValidUsername(username) || 
            !InputValidator::isValidPassword(password)) {
            return false;
        }
        
        std::lock_guard<std::mutex> lock(dbMutex);
        if (users.find(username) != users.end()) {
            return false; // User already exists
        }
        
        std::string hashedPassword = SecureHash::hashPassword(password);
        if (hashedPassword.empty()) {
            return false;
        }
        
        users[username] = hashedPassword;
        saveUsers();
        return true;
    }
    
    bool authenticateUser(const std::string& username, const std::string& password) {
        if (!InputValidator::isValidUsername(username) || password.empty()) {
            return false;
        }
        
        std::lock_guard<std::mutex> lock(dbMutex);
        auto it = users.find(username);
        if (it == users.end()) {
            return false;
        }
        
        return SecureHash::verifyPassword(password, it->second);
    }
};

class Message {
public:
    enum Type { LOGIN, LOGIN_RESPONSE, CHAT, REGISTER, REGISTER_RESPONSE };
    
    Type type;
    std::string username;
    std::string password;
    std::string content;
    bool success;
    
    Message(Type t = CHAT) : type(t), success(false) {}
    
    std::string serialize() const {
        std::ostringstream oss;
        oss << static_cast<int>(type) << "|" << username << "|" << password << "|" << content << "|" << success;
        return oss.str();
    }
    
    bool deserialize(const std::string& data) {
        if (data.empty() || data.length() > 2048) {
            return false;
        }
        
        std::vector<std::string> parts;
        std::istringstream iss(data);
        std::string part;
        
        while (std::getline(iss, part, '|')) {
            parts.push_back(part);
        }
        
        if (parts.size() != 5) {
            return false;
        }
        
        try {
            type = static_cast<Type>(std::stoi(parts[0]));
            username = parts[1];
            password = parts[2];
            content = parts[3];
            success = (parts[4] == "1");
            
            // Validate message components
            if (type < LOGIN || type > REGISTER_RESPONSE) {
                return false;
            }
            
            if (!username.empty() && !InputValidator::isValidUsername(username)) {
                return false;
            }
            
            if (!content.empty() && !InputValidator::isValidMessage(content)) {
                return false;
            }
            
            return true;
        } catch (...) {
            return false;
        }
    }
};

class ChatServer {
private:
    UserDatabase userDb;
    std::mutex clientsMutex;
    std::map<std::string, bool> connectedClients;
    
public:
    bool processMessage(const std::string& rawMessage, std::string& response) {
        Message msg;
        if (!msg.deserialize(rawMessage)) {
            Message errorMsg(Message::LOGIN_RESPONSE);
            errorMsg.success = false;
            errorMsg.content = "Invalid message format";
            response = errorMsg.serialize();
            return false;
        }
        
        Message responseMsg;
        
        switch (msg.type) {
            case Message::LOGIN:
                responseMsg.type = Message::LOGIN_RESPONSE;
                responseMsg.username = msg.username;
                responseMsg.success = userDb.authenticateUser(msg.username, msg.password);
                if (responseMsg.success) {
                    std::lock_guard<std::mutex> lock(clientsMutex);
                    connectedClients[msg.username] = true;
                    responseMsg.content = "Login successful";
                } else {
                    responseMsg.content = "Invalid credentials";
                }
                break;
                
            case Message::REGISTER:
                responseMsg.type = Message::REGISTER_RESPONSE;
                responseMsg.username = msg.username;
                responseMsg.success = userDb.registerUser(msg.username, msg.password);
                responseMsg.content = responseMsg.success ? "Registration successful" : "Registration failed";
                break;
                
            case Message::CHAT:
                // Broadcast message to all connected clients (simplified)
                responseMsg.type = Message::CHAT;
                responseMsg.username = msg.username;
                responseMsg.content = msg.content;
                responseMsg.success = true;
                break;
                
            default:
                responseMsg.success = false;
                responseMsg.content = "Unknown message type";
        }
        
        response = responseMsg.serialize();
        return responseMsg.success;
    }
    
    void disconnectClient(const std::string& username) {
        std::lock_guard<std::mutex> lock(clientsMutex);
        connectedClients.erase(username);
    }
};

class ChatClient {
private:
    std::string username;
    bool authenticated;
    
public:
    ChatClient() : authenticated(false) {}
    
    std::pair<bool, std::string> login(const std::string& user, const std::string& pass) {
        if (!InputValidator::isValidUsername(user) || pass.empty()) {
            return {false, "Invalid input format"};
        }
        
        Message loginMsg(Message::LOGIN);
        loginMsg.username = user;
        loginMsg.password = pass;
        
        std::string request = loginMsg.serialize();
        
        // Simulate network communication
        ChatServer server;
        std::string response;
        bool success = server.processMessage(request, response);
        
        Message responseMsg;
        if (responseMsg.deserialize(response) && success) {
            authenticated = true;
            username = user;
            return {true, responseMsg.content};
        }
        
        return {false, responseMsg.content};
    }
    
    std::pair<bool, std::string> registerUser(const std::string& user, const std::string& pass) {
        if (!InputValidator::isValidUsername(user) || !InputValidator::isValidPassword(pass)) {
            return {false, "Invalid username or password format"};
        }
        
        Message regMsg(Message::REGISTER);
        regMsg.username = user;
        regMsg.password = pass;
        
        std::string request = regMsg.serialize();
        
        // Simulate network communication
        ChatServer server;
        std::string response;
        bool success = server.processMessage(request, response);
        
        Message responseMsg;
        if (responseMsg.deserialize(response)) {
            return {success, responseMsg.content};
        }
        
        return {false, "Communication error"};
    }
    
    std::pair<bool, std::string> sendMessage(const std::string& message) {
        if (!authenticated || !InputValidator::isValidMessage(message)) {
            return {false, "Not authenticated or invalid message"};
        }
        
        Message chatMsg(Message::CHAT);
        chatMsg.username = username;
        chatMsg.content = message;
        
        std::string request = chatMsg.serialize();
        
        // Simulate network communication
        ChatServer server;
        std::string response;
        bool success = server.processMessage(request, response);
        
        return {success, success ? "Message sent" : "Failed to send message"};
    }
    
    bool isAuthenticated() const {
        return authenticated;
    }
    
    const std::string& getUsername() const {
        return username;
    }
};

int main() {
    std::cout << "=== Chat System Test Cases ===" << std::endl;
    
    // Test Case 1: User Registration
    std::cout << "\nTest Case 1: User Registration" << std::endl;
