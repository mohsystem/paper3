// Method to add two integers with overflow protection
static xmlrpc_value *
sample_add(xmlrpc_env * const envP,
           xmlrpc_value * const paramArrayP,
           void * const serverInfo,
           void * const channelInfo) {
    
    xmlrpc_int32 x, y, z;
    
    // Parse and validate parameters
    xmlrpc_decompose_value(envP, paramArrayP, "(ii)", &x, &y);
    if (envP->fault_occurred) {
        return NULL;
    }
    
    // Check for integer overflow
    if ((y > 0 && x > INT32_MAX - y) || (y < 0 && x < INT32_MIN - y)) {
        xmlrpc_env_set_fault_formatted(envP, XMLRPC_INTERNAL_ERROR,
                                       "Integer overflow in addition");
        return NULL;
    }
    
    z = x + y;
    return xmlrpc_build_value(envP, "i", z);
}

// Method to multiply two integers with overflow protection
static xmlrpc_value *
sample_multiply(xmlrpc_env * const envP,
                xmlrpc_value * const paramArrayP,
                void * const serverInfo,
                void * const channelInfo) {
    
    xmlrpc_int32 x, y, z;
    
    // Parse and validate parameters
    xmlrpc_decompose_value(envP, paramArrayP, "(ii)", &x, &y);
    if (envP->fault_occurred) {
        return NULL;
    }
    
    // Check for multiplication overflow
    if (x != 0 && ((y > 0 && x > INT32_MAX / y) || 
                   (y < 0 && x < INT32_MIN / y) ||
                   (y > 0 && x < INT32_MIN / y) ||
                   (y < 0 && x > INT32_MAX / y))) {
        xmlrpc_env_set_fault_formatted(envP, XMLRPC_INTERNAL_ERROR,
                                       "Integer overflow in multiplication");
        return NULL;
    }
    
    z = x * y;
    return xmlrpc_build_value(envP, "i", z);
}

// Method to safely concatenate strings with length validation
static xmlrpc_value *
sample_concat(xmlrpc_env * const envP,
              xmlrpc_value * const paramArrayP,
              void * const serverInfo,
              void * const channelInfo) {
    
    char *s1 = NULL, *s2 = NULL, *result = NULL;
    size_t len1, len2, total_len;
    xmlrpc_value *returnVal = NULL;
    
    // Parse parameters
    xmlrpc_decompose_value(envP, paramArrayP, "(ss)", &s1, &s2);
    if (envP->fault_occurred) {
        return NULL;
    }
    
    // Validate input strings exist
    if (!s1 || !s2) {
        xmlrpc_env_set_fault_formatted(envP, XMLRPC_INTERNAL_ERROR,
                                       "Invalid string parameters");
        goto cleanup;
    }
    
    // Validate string lengths to prevent buffer issues
    len1 = strnlen(s1, 1001);
    len2 = strnlen(s2, 1001);
    
    if (len1 > 1000 || len2 > 1000) {
        xmlrpc_env_set_fault_formatted(envP, XMLRPC_INTERNAL_ERROR,
                                       "String exceeds maximum length of 1000");
        goto cleanup;
    }
    
    // Check for overflow in total length calculation
    if (len1 > SIZE_MAX - len2 - 1) {
        xmlrpc_env_set_fault_formatted(envP, XMLRPC_INTERNAL_ERROR,
                                       "Combined string length overflow");
        goto cleanup;
    }
    
    total_len = len1 + len2 + 1;
    result = malloc(total_len);
    if (!result) {
        xmlrpc_env_set_fault_formatted(envP, XMLRPC_INTERNAL_ERROR,
                                       "Memory allocation failed");
        goto cleanup;
    }
    
    // Use secure string operations
    int ret = snprintf(result, total_len, "%.*s%.*s", 
                      (int)len1, s1, (int)len2, s2);
    if (ret < 0 || (size_t)ret >= total_len) {
        xmlrpc_env_set_fault_formatted(envP, XMLRPC_INTERNAL_ERROR,
                                       "String formatting failed");
        goto cleanup;
    }
    
    returnVal = xmlrpc_build_value(envP, "s", result);
    
cleanup:
    if (s1) free(s1);
    if (s2) free(s2);
    if (result) free(result);
    
    return returnVal;
}

// Test method implementations without network calls
static int test_methods(void) {
    xmlrpc_env env;
    xmlrpc_value *paramArray, *result;
    xmlrpc_int32 intResult;
