#include <iostream>
#include <string>
#include <unordered_map>
#include <random>
#include <regex>
#include <algorithm>

class CSRFProtectedApp {
private:
    std::unordered_map<std::string, std::string> sessions;
    std::unordered_map<std::string, std::pair<std::string, std::string>> users;
    std::random_device rd;
    std::mt19937 gen;
    
public:
    CSRFProtectedApp() : gen(rd()) {}
    
    std::string generateCSRFToken(const std::string& sessionId) {
        std::uniform_int_distribution<> dis(0, 61);
        const std::string chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
        std::string token;
        
        for (int i = 0; i < 32; ++i) {
            token += chars[dis(gen)];
        }
        
        sessions[sessionId] = token;
        return token;
    }
    
    bool validateCSRFToken(const std::string& sessionId, const std::string& submittedToken) {
        if (sessionId.empty() || submittedToken.empty()) {
            return false;
        }
        
        auto it = sessions.find(sessionId);
        if (it == sessions.end()) {
            return false;
        }
        
        const std::string& storedToken = it->second;
        if (storedToken.length() != submittedToken.length()) {
            return false;
        }
        
        int result = 0;
        for (size_t i = 0; i < storedToken.length(); ++i) {
            result |= storedToken[i] ^ submittedToken[i];
        }
        
        return result == 0;
    }
    
    std::string generateForm(const std::string& sessionId) {
        std::string csrfToken = generateCSRFToken(sessionId);
        return "<form method='post'>"
               "<input type='hidden' name='csrf_token' value='" + csrfToken + "'>"
               "<input type='email' name='email' required>"
               "<select name='theme'>"
               "<option value='light'>Light</option>"
               "<option value='dark'>Dark</option>"
               "</select>"
               "<button type='submit'>Update Settings</button>"
               "</form>";
    }
    
    std::string updateUserSettings(const std::string& sessionId, const std::string& csrfToken,
                                 const std::string& email, const std::string& theme) {
        if (!validateCSRFToken(sessionId, csrfToken)) {
            return "CSRF token validation failed";
        }
        
        std::regex emailPattern("^[\\w.-]+@[\\w.-]+\\.[a-zA-Z]{2,}$");
        if (email.empty() || !std::regex_match(email, emailPattern)) {
            return "Invalid email format";
        }
        
        if (theme != "light" && theme != "dark") {
            return "Invalid theme selection";
        }
        
        users[sessionId] = std::make_pair(email, theme);
        sessions.erase(sessionId);
        
        return "Settings updated successfully";
    }
};

int main() {
    CSRFProtectedApp app;
    
    // Test case 1: Valid form generation
    std::string form = app.generateForm("session1");
    std::cout << "Test 1: " << (form.find("csrf_token") != std::string::npos) << std::endl;
    
    // Test case 2: Valid settings update
    std::string token = app.generateCSRFToken("session2");
    std::string result = app.updateUserSettings("session2", token, "user@example.com", "dark");
    std::cout << "Test 2: " << (result == "Settings updated successfully") << std::endl;
    
    // Test case 3: Invalid CSRF token
    result = app.updateUserSettings("session3", "invalid_token", "user@example.com", "light");
    std::cout << "Test 3: " << (result.find("CSRF token validation failed") != std::string::npos) << std::endl;
    
    // Test case 4: Invalid email format
    std::string token4 = app.generateCSRFToken("session4");
    result = app.updateUserSettings("session4", token4, "invalid-email", "light");
    std::cout << "Test 4: " << (result.find("Invalid email format") != std::string::npos) << std::endl;
    
    // Test case 5: Invalid theme
    std::string token5 = app.generateCSRFToken("session5");
    result = app.updateUserSettings("session5", token5, "user@example.com", "invalid_theme");
    std::cout << "Test 5: " << (result.find("Invalid theme selection") != std::string::npos) << std::endl;
    
    return 0;
}
