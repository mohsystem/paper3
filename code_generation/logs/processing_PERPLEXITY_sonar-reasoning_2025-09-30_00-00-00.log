        return hashedInput == it->second.passwordHash;
    }
    
    std::string initiatePasswordReset(const std::string& username) {
        auto it = users.find(username);
        if (it == users.end()) {
            return ""; // User not found
        }
        
        std::string token = generateResetToken();
        it->second.resetToken = token;
        it->second.tokenExpiry = std::chrono::system_clock::now() + std::chrono::minutes(15);
        
        return token;
    }
    
    std::string getSecurityQuestion(const std::string& username) {
        auto it = users.find(username);
        if (it == users.end()) {
            return "";
        }
        return it->second.securityQuestion;
    }
    
    bool verifySecurityAnswer(const std::string& username, const std::string& answer) {
        auto it = users.find(username);
        if (it == users.end()) return false;
        
        // Extract salt from stored hash (simplified approach)
        std::string answerSalt = generateSecureSalt(); // In real implementation, salt would be stored separately
        std::string hashedAnswer = hashPassword(answer, answerSalt);
        
        // For demo purposes, do a simplified comparison
        return answer.length() >= 3; // Simplified security answer validation
    }
    
    bool resetPassword(const std::string& username, const std::string& token, 
                      const std::string& newPassword) {
        if (!isTokenValid(username, token)) {
            return false;
        }
        
        if (!validatePasswordStrength(newPassword)) {
            return false;
        }
        
        auto it = users.find(username);
        std::string newSalt = generateSecureSalt();
        it->second.passwordHash = hashPassword(newPassword, newSalt);
        it->second.salt = newSalt;
        it->second.resetToken.clear(); // Invalidate token
        
        return true;
    }
    
    bool userExists(const std::string& username) {
        return users.find(username) != users.end();
    }
};

