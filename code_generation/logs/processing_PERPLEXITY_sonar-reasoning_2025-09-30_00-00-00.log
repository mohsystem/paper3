```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <pthread.h>

#define MAX_BUFFER_SIZE 1024
#define MAX_USERNAME_LENGTH 50
#define MAX_PASSWORD_LENGTH 100
#define SERVER_PORT 8080
#define MAX_CLIENTS 10

typedef struct {
    int socket;
    char username[MAX_USERNAME_LENGTH + 1];
} client_info_t;

client_info_t clients[MAX_CLIENTS];
int client_count = 0;
pthread_mutex_t clients_mutex = PTHREAD_MUTEX_INITIALIZER;

int validate_input(const char* input, size_t max_length) {
    if (!input || strlen(input) == 0 || strlen(input) > max_length) {
        return 0;
    }
    
    for (size_t i = 0; i < strlen(input); i++) {
        if (input[i] == '\n' || input[i] == '\r') {
            return 0;
        }
    }
    return 1;
}

int authenticate_user(const char* username, const char* password) {
    if (!validate_input(username, MAX_USERNAME_LENGTH) || 
        !validate_input(password, MAX_PASSWORD_LENGTH)) {
        return 0;
    }
    
    FILE* file = fopen("credentials.txt", "r");
    if (!file) {
        return 0;
    }
    
    char line[256];
    char file_user[MAX_USERNAME_LENGTH + 1];
    char file_pass[MAX_PASSWORD_LENGTH + 1];
    
    while (fgets(line, sizeof(line), file)) {
        // Remove newline
        size_t len = strlen(line);
        if (len > 0 && line[len - 1] == '\n') {
            line[len - 1] = '\0';
        }
        
        char* colon = strchr(line, ':');
        if (colon) {
            *colon = '\0';
            strncpy(file_user, line, MAX_USERNAME_LENGTH);
            file_user[MAX_USERNAME_LENGTH] = '\0';
            
            strncpy(file_pass, colon + 1, MAX_PASSWORD_LENGTH);
            file_pass[MAX_PASSWORD_LENGTH] = '\0';
            
            if (strcmp(file_user, username) == 0 && strcmp(file_pass, password) == 0) {
                fclose(file);
                return 1;
            }
        }
    }
    
    fclose(file);
    return 0;
}

void* handle_client(void* arg) {
    int client_socket = *((int*)arg);
    free(arg);
    
    char buffer[MAX_BUFFER_SIZE];
    char username[MAX_USERNAME_LENGTH + 1];
    char password[MAX_PASSWORD_LENGTH + 1];
    
    memset(buffer, 0, sizeof(buffer));
    ssize_t bytes_received = recv(client_socket, buffer, sizeof(buffer) - 1, 0);
    
    if (bytes_received <= 0) {
        close(client_socket);
        return NULL;
    }
    
    buffer[bytes_received] = '\0';
    
    char* colon = strchr(buffer, ':');
    if (!colon) {
        const char* response = "INVALID_FORMAT";
        send(client_socket, response, strlen(response), 0);
        close(client_socket);
        return NULL;
    }
    
    *colon = '\0';
    strncpy(username, buffer, MAX_USERNAME_LENGTH);
    username[MAX_USERNAME_LENGTH] = '\0';
    
    strncpy(password, colon + 1, MAX_PASSWORD_LENGTH);
    password[MAX_PASSWORD_LENGTH] = '\0';
    
    if (authenticate_user(username, password)) {
        const char* response = "AUTH_SUCCESS";
        send(client_socket, response, strlen(response), 0);
        
        pthread_mutex_lock(&clients_mutex);
        if (client_count < MAX_CLIENTS) {
            clients[client_count].socket = client_socket;
            strncpy(clients[client_count].username, username, MAX_USERNAME_LENGTH);
            clients[client_count].username[MAX_USERNAME_LENGTH] = '\0';
            client_count++;
        }
        pthread_mutex_unlock(&clients_mutex);
        
        // Handle chat messages
        while (1) {
            memset(buffer, 0, sizeof(buffer));
            bytes_received = recv(client_socket, buffer, sizeof(buffer) - 1, 0);
            if (bytes_received <= 0) break;
            
            buffer[bytes_received] = '\0';
            
            char message[MAX_BUFFER_SIZE + MAX_USERNAME_LENGTH + 10];
            snprintf(message, sizeof(message), "%s: %s", username, buffer);
            
            pthread_mutex_lock(&clients_mutex);
            for (int i = 0; i < client_count; i++) {
                if (clients[i].socket != client_socket) {
                    send(clients[i].socket, message, strlen(message), 0);
                }
            }
            pthread_mutex_unlock(&clients_mutex);
        }
    } else {
        const char* response = "AUTH_FAILED";
        send(client_socket, response, strlen(response), 0);
    }
    
    pthread_mutex_lock(&clients_mutex);
    for (int i = 0; i < client_count; i++) {
        if (clients[i].socket == client_socket) {
            for (int j = i; j < client_count - 1; j++) {
                clients[j] = clients[j + 1];
            }
            client_count--;
            break;
        }
    }
    pthread_mutex_unlock(&clients_mutex);
    
    close(client_socket);
    return NULL;
}

int start_server() {
    int server_socket = socket(AF_INET, SOCK_STREAM, 0);
    if (server_socket < 0) {
        return -1;
    }
    
    int opt = 1;
    setsockopt(server_socket, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));
    
    struct sockaddr_in server_addr;
    memset(&server_addr, 0, sizeof(server_addr));
    server_addr.sin_family = AF_INET;
    server_addr.sin_addr.s_addr = INADDR_ANY;
    server_addr.sin_port = htons(SERVER_PORT);
    
    if (bind(server_socket, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {
        close(server_socket);
        return -1;
    }
    
    if (listen(server_socket, 5) < 0) {
        close(server_socket);
        return -1;
    }
    
    printf("Server started on port %d\n", SERVER_PORT);
    
    while (1) {
        struct sockaddr_in client_addr;
        socklen_t client_len = sizeof(client_addr);
        int client_socket = accept(server_socket, (struct sockaddr*)&client_addr, &client_len);
        
        if (client_socket >= 0) {
            int* client_sock_ptr = malloc(sizeof(int));
            if (client_sock_ptr) {
                *client_sock_ptr = client_socket;
                pthread_t thread;
                pthread_create(&thread, NULL, handle_client, client_sock_ptr);
                pthread_detach(thread);
            } else {
                close(client_socket);
            }
        }
    }
