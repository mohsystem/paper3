from cryptography.hazmat.primitives.ciphers.aead import AESGCM
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
import secrets
import os
from pathlib import Path
from typing import Optional

MAGIC = b"ENC1"
VERSION = 1
SALT_LENGTH = 16
IV_LENGTH = 12
TAG_LENGTH = 16
ITERATIONS = 210000

def derive_key(password: str, salt: bytes) -> bytes:
    kdf = PBKDF2HMAC(
        algorithm=hashes.SHA256(),
        length=32,
        salt=salt,
        iterations=ITERATIONS,
    )
    return kdf.derive(password.encode('utf-8'))

def encrypt_file(input_path: str, output_path: str, password: str) -> bool:
    if not input_path or not output_path or not password:
        return False
    
    try:
        input_file = Path(input_path)
        if not input_file.is_file():
            return False
            
        plaintext = input_file.read_bytes()
        salt = secrets.token_bytes(SALT_LENGTH)
        iv = secrets.token_bytes(IV_LENGTH)
        
        key = derive_key(password, salt)
        aesgcm = AESGCM(key)
        ciphertext = aesgcm.encrypt(iv, plaintext, None)
        
        temp_path = output_path + ".tmp"
        with open(temp_path, 'wb') as f:
            f.write(MAGIC)
            f.write(bytes([VERSION]))
            f.write(salt)
            f.write(iv)
            f.write(ciphertext)
            f.flush()
            os.fsync(f.fileno())
        
        Path(temp_path).rename(output_path)
        return True
    except Exception:
        return False

def decrypt_file(input_path: str, output_path: str, password: str) -> bool:
    if not input_path or not output_path or not password:
        return False
    
    try:
        input_file = Path(input_path)
        if not input_file.is_file():
            return False
            
        data = input_file.read_bytes()
        
        min_length = len(MAGIC) + 1 + SALT_LENGTH + IV_LENGTH + TAG_LENGTH
        if len(data) < min_length:
            return False
        
        offset = 0
        magic = data[offset:offset + len(MAGIC)]
        offset += len(MAGIC)
        
        if magic != MAGIC:
            return False
        
        version = data[offset]
        offset += 1
        
        if version != VERSION:
            return False
        
        salt = data[offset:offset + SALT_LENGTH]
        offset += SALT_LENGTH
        
        iv = data[offset:offset + IV_LENGTH]
        offset += IV_LENGTH
        
        ciphertext = data[offset:]
        
        key = derive_key(password, salt)
        aesgcm = AESGCM(key)
        plaintext = aesgcm.decrypt(iv, ciphertext, None)
        
        temp_path = output_path + ".tmp"
        with open(temp_path, 'wb') as f:
            f.write(plaintext)
            f.flush()
            os.fsync(f.fileno())
        
        Path(temp_path).rename(output_path)
        return True
    except Exception:
        return False

def main():
    Path("test1.txt").write_text("Hello World")
    Path("test2.txt").write_text("Secret Data")
    Path("test3.txt").write_text("")
    Path("test4.txt").write_text("A" * 1000)
    Path("test5.txt").write_text("Unicode: \u4f60\u597d")
    
    test1 = encrypt_file("test1.txt", "test1.enc", "password123") and decrypt_file("test1.enc", "test1.dec", "password123")
    test2 = encrypt_file("test2.txt", "test2.enc", "secret") and decrypt_file("test2.enc", "test2.dec", "secret")
    test3 = encrypt_file("test3.txt", "test3.enc", "empty") and decrypt_file("test3.enc", "test3.dec", "empty")
    test4 = encrypt_file("test4.txt", "test4.enc", "long") and decrypt_file("test4.enc", "test4.dec", "long")
    test5 = not decrypt_file("test5.enc", "test5.dec", "wrongpass")
    
    print(f"Test 1: {test1}")
    print(f"Test 2: {test2}")
    print(f"Test 3: {test3}")
    print(f"Test 4: {test4}")
    print(f"Test 5: {test5}")

if __name__ == "__main__":
    main()
