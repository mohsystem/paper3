#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <stdint.h>

#define MAX_USERNAME_LEN 64
#define MAX_PASSWORD_LEN 128
#define MAX_EMAIL_LEN 256
#define MAX_TOKEN_LEN 64
#define SALT_LEN 16
#define HASH_LEN 32
#define TOKEN_EXPIRY_SECONDS 3600

typedef struct {
    char username[MAX_USERNAME_LEN];
    char email[MAX_EMAIL_LEN];
    char password_hash[HASH_LEN * 2 + 1];
    char salt[SALT_LEN * 2 + 1];
    char reset_token[MAX_TOKEN_LEN];
    time_t token_expiry;
    int is_valid;
} User;

/* Simplified hash function for demo - in production use PBKDF2/scrypt/Argon2 */
static void simple_hash(const char* input, const char* salt, char* output) {
    if (!input || !salt || !output) return;
    
    uint32_t hash = 5381;
    size_t input_len = strnlen(input, MAX_PASSWORD_LEN);
    size_t salt_len = strnlen(salt, SALT_LEN * 2);
    
    for (size_t i = 0; i < input_len; i++) {
        hash = ((hash << 5) + hash) + (unsigned char)input[i];
    }
    for (size_t i = 0; i < salt_len; i++) {
        hash = ((hash << 5) + hash) + (unsigned char)salt[i];
    }
    
    snprintf(output, HASH_LEN * 2 + 1, "%08x%08x%08x%08x", 
             hash, hash ^ 0xAAAA, hash ^ 0x5555, hash ^ 0xFFFF);
}

static void generate_salt(char* salt) {
    if (!salt) return;
    
    srand((unsigned int)time(NULL) + clock());
    for (int i = 0; i < SALT_LEN * 2; i++) {
        int rand_val = rand() % 16;
        salt[i] = (rand_val < 10) ? ('0' + rand_val) : ('a' + rand_val - 10);
    }
    salt[SALT_LEN * 2] = '\0';
}

static void generate_reset_token(char* token) {
    if (!token) return;
    
    srand((unsigned int)time(NULL) + clock());
    const char charset[] = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
    
    for (int i = 0; i < MAX_TOKEN_LEN - 1; i++) {
        token[i] = charset[rand() % (sizeof(charset) - 1)];
    }
    token[MAX_TOKEN_LEN - 1] = '\0';
}

static int validate_password(const char* password) {
    if (!password) return 0;
    
    size_t len = strnlen(password, MAX_PASSWORD_LEN);
    if (len < 8 || len >= MAX_PASSWORD_LEN) return 0;
    
    int has_upper = 0, has_lower = 0, has_digit = 0, has_special = 0;
    
    for (size_t i = 0; i < len; i++) {
        char c = password[i];
        if (c >= 'A' && c <= 'Z') has_upper = 1;
        else if (c >= 'a' && c <= 'z') has_lower = 1;
        else if (c >= '0' && c <= '9') has_digit = 1;
        else if (c == '!' || c == '@' || c == '#' || c == '$' || c == '%' || c == '^' || c == '&' || c == '*') has_special = 1;
    }
    
    return has_upper && has_lower && has_digit && has_special;
}

static int validate_email(const char* email) {
    if (!email) return 0;
    
    size_t len = strnlen(email, MAX_EMAIL_LEN);
    if (len == 0 || len >= MAX_EMAIL_LEN) return 0;
    
    int at_count = 0;
    int has_dot_after_at = 0;
    int at_pos = -1;
    
    for (size_t i = 0; i < len; i++) {
        if (email[i] == '@') {
            at_count++;
            at_pos = (int)i;
        } else if (email[i] == '.' && at_pos != -1 && (int)i > at_pos) {
            has_dot_after_at = 1;
        }
    }
    
    return at_count == 1 && has_dot_after_at && at_pos > 0 && at_pos < (int)len - 1;
}

int create_user(User* user, const char* username, const char* email, const char* password) {
    if (!user || !username || !email || !password) return 0;
    
    if (strnlen(username, MAX_USERNAME_LEN) >= MAX_USERNAME_LEN) return 0;
    if (!validate_email(email)) return 0;
    if (!validate_password(password)) return 0;
    
    strncpy(user->username, username, MAX_USERNAME_LEN - 1);
    user->username[MAX_USERNAME_LEN - 1] = '\0';
    
    strncpy(user->email, email, MAX_EMAIL_LEN - 1);
    user->email[MAX_EMAIL_LEN - 1] = '\0';
    
    generate_salt(user->salt);
    simple_hash(password, user->salt, user->password_hash);
    
    user->reset_token[0] = '\0';
    user->token_expiry = 0;
    user->is_valid = 1;
    
    return 1;
}

int request_password_reset(User* user, const char* email) {
    if (!user || !email) return 0;
    if (!user->is_valid) return 0;
    
    size_t email_len = strnlen(email, MAX_EMAIL_LEN);
    size_t user_email_len = strnlen(user->email, MAX_EMAIL_LEN);
    
    if (email_len != user_email_len) return 0;
    
    int email_match = 1;
    for (size_t i = 0; i < email_len; i++) {
        if (email[i] != user->email[i]) {
            email_match = 0;
            break;
        }
    }
    
    if (!email_match) return 0;
    
    generate_reset_token(user->reset_token);
    user->token_expiry = time(NULL) + TOKEN_EXPIRY_SECONDS;
    
    return 1;
}

int reset_password_with_token(User* user, const char* token, const char* new_password) {
    if (!user || !token || !new_password) return 0;
    if (!user->is_valid) return 0;
    
    if (time(NULL) > user->token_expiry) return 0;
    
    size_t token_len = strnlen(token, MAX_TOKEN_LEN);
    size_t user_token_len = strnlen(user->reset_token, MAX_TOKEN_LEN);
    
    if (token_len != user_token_len) return 0;
    
    int token_match = 1;
    for (size_t i = 0; i < token_len; i++) {
        if (token[i] != user->reset_token[i]) {
            token_match = 0;
            break;
        }
    }
    
    if (!token_match) return 0;
    
    if (!validate_password(new_password)) return 0;
    
    generate_salt(user->salt);
    simple_hash(new_password, user->salt, user->password_hash);
    
    user->reset_token[0] = '\0';
    user->token_expiry = 0;
    
    return 1;
}

int verify_password(User* user, const char* password) {
    if (!user || !password) return 0;
    if (!user->is_valid) return 0;
    
    char computed_hash[HASH_LEN * 2 + 1];
    simple_hash(password, user->salt, computed_hash);
    
    size_t hash_len = strnlen(computed_hash, HASH_LEN * 2 + 1);
    size_t user_hash_len = strnlen(user->password_hash, HASH_LEN * 2 + 1);
    
    if (hash_len != user_hash_len) return 0;
    
    int hash_match = 1;
    for (size_t i = 0; i < hash_len; i++) {
        if (computed_hash[i] != user->password_hash[i]) {
            hash_match = 0;
            break;
        }
    }
    
    return hash_match;
}

int main() {
    User test_user;
    char token_buffer[MAX_TOKEN_LEN];
    
    printf("Password Reset Functionality Test\n");
    printf("=================================\n\n");
    
    /* Test Case 1: Create user with valid credentials */
    printf("Test 1: Creating user with valid credentials\n");
    int result1 = create_user(&test_user, "testuser", "test@example.com", "SecurePass123!");
    printf("Result: %s\n", result1 ? "SUCCESS" : "FAILED");
    printf("Username: %s, Email: %s\n\n", test_user.username, test_user.email);
    
    /* Test Case 2: Verify original password */
    printf("Test 2: Verifying original password\n");
    int result2 = verify_password(&test_user, "SecurePass123!");
    printf("Result: %s\n\n", result2 ? "SUCCESS" : "FAILED");
    
    /* Test Case 3: Request password reset with correct email */
    printf("Test 3: Requesting password reset with correct email\n");
    int result3 = request_password_reset(&test_user, "test@example.com");
    printf("Result: %s\n", result3 ? "SUCCESS" : "FAILED");
    if (result3) {
        strncpy(token_buffer, test_user.reset_token, MAX_TOKEN_LEN - 1);
        token_buffer[MAX_TOKEN_LEN - 1] = '\0';
        printf("Reset token generated: %.20s...\n", token_buffer);
    }
    printf("\n");
    
    /* Test Case 4: Reset password with valid token */
    printf("Test 4: Resetting password with valid token\n");
    int result4 = reset_password_with_token(&test_user, token_buffer, "NewSecure456#");
    printf("Result: %s\n", result4 ? "SUCCESS" : "FAILED");
    
    /* Verify new password works */
    int verify_new = verify_password(&test_user, "NewSecure456#");
    printf("New password verification: %s\n\n", verify_new ? "SUCCESS" : "FAILED");
    
    /* Test Case 5: Attempt password reset with invalid email */
    printf("Test 5: Attempting password reset with invalid email\n");
    int result5 = request_password_reset(&test_user, "wrong@example.com");
    printf("Result: %s (should be FAILED)\n\n", result5 ? "SUCCESS" : "FAILED");
    
    /* Additional security tests */
    printf("Additional Security Tests:\n");
    printf("=========================\n");
    
    /* Test weak password rejection */
    User weak_user;
    printf("Weak password test: ");
    int weak_result = create_user(&weak_user, "user", "user@test.com", "weak");
    printf("%s\n", weak_result ? "FAILED (should reject)" : "SUCCESS (rejected weak password)");
    
    /* Test invalid email rejection */
    User invalid_email_user;
    printf("Invalid email test: ");
    int email_result = create_user(&invalid_email_user, "user", "invalidemail", "SecurePass123!");
    printf("%s\n", email_result ? "FAILED (should reject)" : "SUCCESS (rejected invalid email)");
    
    printf("\nAll tests completed.\n");
    return 0;
}
