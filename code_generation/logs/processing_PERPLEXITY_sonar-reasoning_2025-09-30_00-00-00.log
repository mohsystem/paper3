#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/err.h>
#include <openssl/sha.h>
#include <sys/stat.h>
#include <unistd.h>

#define AES_KEY_SIZE 32
#define AES_IV_SIZE 12
#define AES_TAG_SIZE 16
#define SALT_SIZE 16
#define PBKDF2_ITERATIONS 210000
#define MAGIC "ENC1"
#define VERSION 1
#define MAX_PATH_LEN 4096
#define MAX_PASSWORD_LEN 1024
#define BUFFER_SIZE 4096

typedef struct {
    unsigned char magic[4];
    unsigned char version;
    unsigned char salt[SALT_SIZE];
    unsigned char iv[AES_IV_SIZE];
} FileHeader;

void secure_zero(void *ptr, size_t len) {
    volatile unsigned char *p = ptr;
    while (len--) *p++ = 0;
}

int derive_key(const char *password, const unsigned char *salt, unsigned char *key) {
    return PKCS5_PBKDF2_HMAC(password, strlen(password), salt, SALT_SIZE, 
                             PBKDF2_ITERATIONS, EVP_sha256(), AES_KEY_SIZE, key);
}

int validate_path(const char *path, const char *base_dir) {
    char resolved_path[MAX_PATH_LEN];
    char resolved_base[MAX_PATH_LEN];
    
    if (!path || !base_dir || strlen(path) >= MAX_PATH_LEN) return 0;
    
    if (!realpath(base_dir, resolved_base)) return 0;
    
    char parent_dir[MAX_PATH_LEN];
    snprintf(parent_dir, sizeof(parent_dir), "%s", path);
    char *last_slash = strrchr(parent_dir, '/');
    if (last_slash) {
        *last_slash = '\0';
        if (realpath(parent_dir, resolved_path)) {
            return strncmp(resolved_path, resolved_base, strlen(resolved_base)) == 0;
        }
    }
    return strncmp(path, base_dir, strlen(base_dir)) == 0;
}

int encrypt_file(const char *input_path, const char *output_path, const char *password) {
    FILE *input = NULL, *output = NULL, *temp = NULL;
    EVP_CIPHER_CTX *ctx = NULL;
    unsigned char salt[SALT_SIZE], iv[AES_IV_SIZE], key[AES_KEY_SIZE];
    unsigned char tag[AES_TAG_SIZE];
    unsigned char buffer[BUFFER_SIZE], out_buffer[BUFFER_SIZE + 16];
    char temp_path[MAX_PATH_LEN];
    FileHeader header;
    int len, out_len, ret = 0;
    
    if (!input_path || !output_path || !password) return 0;
    if (strlen(input_path) >= MAX_PATH_LEN || strlen(output_path) >= MAX_PATH_LEN) return 0;
    if (strlen(password) >= MAX_PASSWORD_LEN || strlen(password) == 0) return 0;

    if (RAND_bytes(salt, SALT_SIZE) != 1 || RAND_bytes(iv, AES_IV_SIZE) != 1) {
        goto cleanup;
    }

    if (!derive_key(password, salt, key)) goto cleanup;

    input = fopen(input_path, "rb");
    if (!input) goto cleanup;

    snprintf(temp_path, sizeof(temp_path), "%s.tmp", output_path);
    temp = fopen(temp_path, "wb");
    if (!temp) goto cleanup;

    memcpy(header.magic, MAGIC, 4);
    header.version = VERSION;
    memcpy(header.salt, salt, SALT_SIZE);
    memcpy(header.iv, iv, AES_IV_SIZE);
    
    if (fwrite(&header, sizeof(header), 1, temp) != 1) goto cleanup;

    ctx = EVP_CIPHER_CTX_new();
    if (!ctx) goto cleanup;

    if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), NULL, key, iv) != 1) goto cleanup;

    while ((len = fread(buffer, 1, BUFFER_SIZE, input)) > 0) {
        if (EVP_EncryptUpdate(ctx, out_buffer, &out_len, buffer, len) != 1) goto cleanup;
        if (fwrite(out_buffer, 1, out_len, temp) != (size_t)out_len) goto cleanup;
    }

    if (ferror(input)) goto cleanup;

    if (EVP_EncryptFinal_ex(ctx, out_buffer, &out_len) != 1) goto cleanup;
    if (out_len > 0 && fwrite(out_buffer, 1, out_len, temp) != (size_t)out_len) goto cleanup;

    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_AEAD_GET_TAG, AES_TAG_SIZE, tag) != 1) goto cleanup;
    if (fwrite(tag, 1, AES_TAG_SIZE, temp) != AES_TAG_SIZE) goto cleanup;

    if (fflush(temp) != 0 || fsync(fileno(temp)) != 0) goto cleanup;
    fclose(temp);
    temp = NULL;

    if (rename(temp_path, output_path) != 0) goto cleanup;

    ret = 1;

cleanup:
    secure_zero(key, sizeof(key));
    secure_zero(buffer, sizeof(buffer));
    if (input) fclose(input);
    if (temp) {
        fclose(temp);
        unlink(temp_path);
    }
    if (ctx) EVP_CIPHER_CTX_free(ctx);
    return ret;
}

int decrypt_file(const char *input_path, const char *output_path, const char *password) {
    FILE *input = NULL, *output = NULL, *temp = NULL;
    EVP_CIPHER_CTX *ctx = NULL;
    unsigned char key[AES_KEY_SIZE], tag[AES_TAG_SIZE];
