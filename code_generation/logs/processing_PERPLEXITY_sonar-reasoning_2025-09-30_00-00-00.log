    token[TOKEN_LENGTH] = '\0';
    
    strncpy(sessions[session_count].session_id, session_id, MAX_STRING_LENGTH - 1);
    sessions[session_count].session_id[MAX_STRING_LENGTH - 1] = '\0';
    strncpy(sessions[session_count].csrf_token, token, TOKEN_LENGTH);
    sessions[session_count].csrf_token[TOKEN_LENGTH] = '\0';
    session_count++;
    
    return token;
