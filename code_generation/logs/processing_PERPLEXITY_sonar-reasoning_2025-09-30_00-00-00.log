#include <iostream>
#include <string>
#include <unordered_map>
#include <random>
#include <sstream>
#include <iomanip>
#include <vector>
#include <memory>
#include <algorithm>
#include <chrono>

class SecureRandom {
private:
    std::random_device rd;
    std::mt19937 gen;
    
public:
    SecureRandom() : gen(rd()) {}
    
    std::string generateToken(size_t length = 32) {
        std::uniform_int_distribution<> dis(0, 15);
        std::stringstream ss;
        for (size_t i = 0; i < length; ++i) {
            ss << std::hex << dis(gen);
        }
        return ss.str();
    }
    
    uint64_t generateSecret() {
        std::uniform_int_distribution<uint64_t> dis;
        return dis(gen);
    }
};

struct UserSettings {
    std::string username;
    std::string email;
    std::string theme;
    bool notifications;
    
    UserSettings() : username(""), email(""), theme("default"), notifications(true) {}
    
    UserSettings(const std::string& user, const std::string& mail, 
                const std::string& th, bool notif) 
        : username(user), email(mail), theme(th), notifications(notif) {}
};

class CSRFToken {
private:
    std::string token;
    uint64_t secret;
    std::chrono::steady_clock::time_point created;
    static const int TOKEN_LIFETIME_MINUTES = 30;
    
public:
    CSRFToken(const std::string& tok, uint64_t sec) 
        : token(tok), secret(sec), created(std::chrono::steady_clock::now()) {}
    
    bool isValid(const std::string& providedToken) const {
        auto now = std::chrono::steady_clock::now();
        auto elapsed = std::chrono::duration_cast<std::chrono::minutes>(now - created);
        
        if (elapsed.count() > TOKEN_LIFETIME_MINUTES) {
            return false;
        }
        
        // Constant time comparison to prevent timing attacks
        if (token.length() != providedToken.length()) {
            return false;
        }
        
        int result = 0;
        for (size_t i = 0; i < token.length(); ++i) {
            result |= token[i] ^ providedToken[i];
        }
        
        return result == 0;
    }
    
    std::string getToken() const { return token; }
    uint64_t getSecret() const { return secret; }
};

class SessionManager {
private:
    std::unordered_map<std::string, std::unique_ptr<CSRFToken>> sessions;
    SecureRandom secureRandom;
    
public:
    std::string createSession() {
        std::string sessionId = secureRandom.generateToken(16);
        std::string csrfToken = secureRandom.generateToken(32);
        uint64_t secret = secureRandom.generateSecret();
        
        sessions[sessionId] = std::make_unique<CSRFToken>(csrfToken, secret);
        return sessionId;
    }
    
    std::string getCSRFToken(const std::string& sessionId) {
        auto it = sessions.find(sessionId);
        if (it != sessions.end() && it->second) {
            return it->second->getToken();
        }
        return "";
    }
    
    bool validateCSRFToken(const std::string& sessionId, const std::string& token) {
        auto it = sessions.find(sessionId);
        if (it != sessions.end() && it->second) {
            return it->second->isValid(token);
        }
        return false;
    }
    
    void invalidateSession(const std::string& sessionId) {
        sessions.erase(sessionId);
    }
};

class WebApplication {
private:
    SessionManager sessionManager;
    std::unordered_map<std::string, UserSettings> userDatabase;
    
    bool validateInput(const std::string& input, size_t maxLength) {
        if (input.empty() || input.length() > maxLength) {
            return false;
        }
        
        // Check for potentially dangerous characters
        for (char c : input) {
            if (c == '<' || c == '>' || c == '&' || c == '"' || c == '\'') {
                return false;
            }
        }
        return true;
    }
    
    std::string sanitizeInput(const std::string& input) {
        std::string sanitized = input;
        std::replace(sanitized.begin(), sanitized.end(), '<', ' ');
        std::replace(sanitized.begin(), sanitized.end(), '>', ' ');
        std::replace(sanitized.begin(), sanitized.end(), '&', ' ');
        std::replace(sanitized.begin(), sanitized.end(), '"', ' ');
        std::replace(sanitized.begin(), sanitized.end(), '\'', ' ');
        return sanitized;
    }
    
public:
    WebApplication() {
        // Initialize with default user
        userDatabase["user1"] = UserSettings("user1", "user1@example.com", "dark", true);
    }
    
    struct Response {
        int statusCode;
        std::string body;
        std::string error;
        
        Response(int code, const std::string& content, const std::string& err = "") 
            : statusCode(code), body(content), error(err) {}
    };
    
    std::string startSession() {
        return sessionManager.createSession();
    }
    
    Response renderSettingsForm(const std::string& sessionId, const std::string& username) {
        if (sessionId.empty() || username.empty()) {
            return Response(400, "", "Invalid session or username");
        }
        
        std::string csrfToken = sessionManager.getCSRFToken(sessionId);
        if (csrfToken.empty()) {
            return Response(403, "", "Invalid session");
        }
        
        auto userIt = userDatabase.find(username);
        if (userIt == userDatabase.end()) {
            return Response(404, "", "User not found");
        }
        
        std::stringstream form;
        form << "<form method='POST' action='/update-settings'>\n";
        form << "  <input type='hidden' name='csrf_token' value='" << csrfToken << "'>\n";
        form << "  <input type='hidden' name='session_id' value='" << sessionId << "'>\n";
        form << "  <label>Username: <input name='username' value='" << userIt->second.username << "'></label>\n";
        form << "  <label>Email: <input name='email' value='" << userIt->second.email << "'></label>\n";
        form << "  <label>Theme: <select name='theme'>\n";
        form << "    <option value='light'" << (userIt->second.theme == "light" ? " selected" : "") << ">Light</option>\n";
        form << "    <option value='dark'" << (userIt->second.theme == "dark" ? " selected" : "") << ">Dark</option>\n";
        form << "  </select></label>\n";
        form << "  <label>Notifications: <input type='checkbox' name='notifications'" 
             << (userIt->second.notifications ? " checked" : "") << "></label>\n";
        form << "  <button type='submit'>Update Settings</button>\n";
        form << "</form>";
        
        return Response(200, form.str());
    }
    
    Response updateSettings(const std::string& sessionId, const std::string& csrfToken,
                          const std::string& username, const std::string& email,
                          const std::string& theme, bool notifications) {
        
        // Validate session and CSRF token
        if (sessionId.empty() || csrfToken.empty()) {
            return Response(400, "", "Missing session or CSRF token");
        }
        
        if (!sessionManager.validateCSRFToken(sessionId, csrfToken)) {
            return Response(403, "", "Invalid CSRF token - potential attack detected");
        }
        
        // Validate and sanitize inputs
        if (!validateInput(username, 50) || !validateInput(email, 100) || !validateInput(theme, 20)) {
            return Response(400, "", "Invalid input parameters");
        }
        
        std::string cleanUsername = sanitizeInput(username);
        std::string cleanEmail = sanitizeInput(email);
        std::string cleanTheme = sanitizeInput(theme);
        
        // Additional email validation
        if (cleanEmail.find('@') == std::string::npos || cleanEmail.find('.') == std::string::npos) {
            return Response(400, "", "Invalid email format");
        }
        
        // Theme validation
        if (cleanTheme != "light" && cleanTheme != "dark" && cleanTheme != "default") {
            return Response(400, "", "Invalid theme selection");
        }
        
        // Update user settings
        auto userIt = userDatabase.find(cleanUsername);
        if (userIt != userDatabase.end()) {
            userIt->second.email = cleanEmail;
            userIt->second.theme = cleanTheme;
            userIt->second.notifications = notifications;
            
            return Response(200, "Settings updated successfully");
        } else {
            return Response(404, "", "User not found");
        }
    }
    
    Response getUser(const std::string& username) {
        auto userIt = userDatabase.find(username);
        if (userIt != userDatabase.end()) {
            std::stringstream ss;
            ss << "User: " << userIt->second.username 
               << ", Email: " << userIt->second.email
               << ", Theme: " << userIt->second.theme
               << ", Notifications: " << (userIt->second.notifications ? "enabled" : "disabled");
            return Response(200, ss.str());
        }
        return Response(404, "", "User not found");
    }
};

int main() {
    WebApplication app;
    
    std::cout << "=== CSRF-Protected Web Application Test Cases ===\n\n";
    
    // Test Case 1: Valid session and form rendering
    std::cout << "Test Case 1: Valid session and form rendering\n";
    std::string session1 = app.startSession();
    auto response1 = app.renderSettingsForm(session1, "user1");
    std::cout << "Status: " << response1.statusCode << "\n";
    std::cout << "Form contains CSRF token: " << (response1.body.find("csrf_token") != std::string::npos ? "Yes" : "No") << "\n";
    std::cout << "Success: " << (response1.statusCode == 200 ? "PASS" : "FAIL") << "\n\n";
    
    // Test Case 2: Valid settings update with correct CSRF token
    std::cout << "Test Case 2: Valid settings update with correct CSRF token\n";
    std::string csrfToken = app.sessionManager.getCSRFToken(session1);
    auto response2 = app.updateSettings(session1, csrfToken, "user1", "newemail@example.com", "light", false);
    std::cout << "Status: " << response2.statusCode << "\n";
    std::cout << "Message: " << response2.body << "\n";
    std::cout << "Success: " << (response2.statusCode == 200 ? "PASS" : "FAIL") << "\n\n";
    
    // Test Case 3: CSRF attack attempt with invalid token
    std::cout << "Test Case 3: CSRF attack attempt with invalid token\n";
    auto response3 = app.updateSettings(session1, "fake_csrf_token", "user1", "hacker@evil.com", "dark", true);
    std::cout << "Status: " << response3.statusCode << "\n";
    std::cout << "Error: " << response3.error << "\n";
    std::cout << "Attack blocked: " << (response3.statusCode == 403 ? "PASS" : "FAIL") << "\n\n";
    
    // Test Case 4: Input validation and sanitization
    std::cout << "Test Case 4: Input validation and sanitization\n";
    auto response4 = app.updateSettings(session1, csrfToken, "user1<script>", "malicious@<script>alert('xss')</script>", "invalid_theme", true);
    std::cout << "Status: " << response4.statusCode << "\n";
    std::cout << "Error: " << response4.error << "\n";
    std::cout << "Malicious input rejected: " << (response4.statusCode == 400 ? "PASS" : "FAIL") << "\n\n";
    
    // Test Case 5: Session validation
    std::cout << "Test Case 5: Session validation\n";
    auto response5 = app.updateSettings("invalid_session", "fake_token", "user1", "test@example.com", "light", true);
    std::cout << "Status: " << response5.statusCode << "\n";
    std::cout << "Error: " << response5.error << "\n";
    std::cout << "Invalid session rejected: " << (response5.statusCode == 403 ? "PASS" : "FAIL") << "\n\n";
    
    // Verify final user state
    std::cout << "Final user state:\n";
    auto userState = app.getUser("user1");
    std::cout << userState.body << "\n";
    
    return 0;
}
