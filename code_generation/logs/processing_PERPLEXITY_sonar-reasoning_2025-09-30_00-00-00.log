```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <stdint.h>

#define MAX_EMAIL_LEN 254
#define MAX_PASSWORD_LEN 128
#define MIN_PASSWORD_LEN 8
#define SALT_LEN 16
#define TOKEN_LEN 32
#define MAX_USERS 100
#define HASH_ITERATIONS 10000
#define TOKEN_EXPIRY_MINUTES 15

typedef struct {
    char email[MAX_EMAIL_LEN + 1];
    char passwordHash[65];
    char salt[SALT_LEN + 1];
    int active;
} UserRecord;

typedef struct {
    char token[TOKEN_LEN + 1];
    char email[MAX_EMAIL_LEN + 1];
    time_t expiry;
    int active;
} ResetToken;

typedef struct {
    UserRecord users[MAX_USERS];
    ResetToken tokens[MAX_USERS];
    int userCount;
    int tokenCount;
} PasswordResetSystem;

static void secure_clear(void* ptr, size_t len) {
    volatile unsigned char* p = ptr;
    while (len--) *p++ = 0;
}

static void generate_random_string(char* buffer, size_t length) {
    const char chars[] = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
    srand((unsigned int)time(NULL) + rand());
    
    for (size_t i = 0; i < length; ++i) {
        buffer[i] = chars[rand() % (sizeof(chars) - 1)];
    }
    buffer[length] = '\0';
}

static uint32_t simple_hash(const char* str) {
    uint32_t hash = 5381;
    int c;
    while ((c = *str++))
        hash = ((hash << 5) + hash) + c;
    return hash;
}

static void hash_password(const char* password, const char* salt, char* output) {
    char combined[MAX_PASSWORD_LEN + SALT_LEN + 1];
    uint32_t hash;
    
    if (snprintf(combined, sizeof(combined), "%s%s", password, salt) >= sizeof(combined)) {
        output[0] = '\0';
        return;
    }
    
    hash = simple_hash(combined);
    
    for (int i = 0; i < HASH_ITERATIONS; ++i) {
        if (snprintf(combined, sizeof(combined), "%u%s", hash, salt) >= sizeof(combined)) {
            output[0] = '\0';
            return;
        }
        hash = simple_hash(combined);
    }
    
    if (snprintf(output, 65, "%08x", hash) >= 65) {
        output[0] = '\0';
    }
}

static int constant_time_compare(const char* a, const char* b) {
    size_t len_a = strlen(a);
    size_t len_b = strlen(b);
    
    if (len_a != len_b) return 0;
    
    int result = 0;
    for (size_t i = 0; i < len_a; ++i) {
        result |= a[i] ^ b[i];
    }
    
    return result == 0;
}

static int is_valid_email(const char* email) {
    size_t len = strlen(email);
    if (len < 5 || len > MAX_EMAIL_LEN) return 0;
    
    const char* at_pos = strchr(email, '@');
    return at_pos != NULL && at_pos > email && at_pos < email + len - 1;
}

static int is_valid_password(const char* password) {
    size_t len = strlen(password);
    return len >= MIN_PASSWORD_LEN && len <= MAX_PASSWORD_LEN;
}

int register_user(PasswordResetSystem* system, const char* email, const char* password) {
    if (!system || !email || !password) return 0;
    if (!is_valid_email(email) || !is_valid_password(password)) return 0;
    if (system->userCount >= MAX_USERS) return 0;
    
    for (int i = 0; i < system->userCount; ++i) {
        if (system->users[i].active && strcmp(system->users[i].email, email) == 0) {
            return 0;
        }
    }
    
    UserRecord* user = &system->users[system->userCount];
    
    if (snprintf(user->email, sizeof(user->email), "%s", email) >= sizeof(user->email)) {
        return 0;
    }
    
    generate_random_string(user->salt, SALT_LEN);
    hash_password(password, user->salt, user->passwordHash);
    
    if (user->passwordHash[0] == '\0') return 0;
    
    user->active = 1;
    system->userCount++;
    
    return 1;
}

int generate_reset_token(PasswordResetSystem* system, const char* email, char* token_out) {
    if (!system || !email || !token_out) return 0;
    if (!is_valid_email(email)) return 0;
    if (system->tokenCount >= MAX_USERS) return 0;
    
    int user_found = 0;
    for (int i = 0; i < system->userCount; ++i) {
        if (system->users[i].active && strcmp(system->users[i].email, email) == 0) {
            user_found = 1;
            break;
        }
    }
    
    if (!user_found) return 0;
    
    ResetToken* reset_token = &system->tokens[system->tokenCount];
    
    generate_random_string(reset_token->token, TOKEN_LEN);
    
    if (snprintf(reset_token->email, sizeof(reset_token->email), "%s", email) >= sizeof(reset_token->email)) {
        return 0;
    }
    
    reset_token->expiry = time(NULL) + (TOKEN_EXPIRY_MINUTES * 60);
    reset_token->active = 1;
    
    if (snprintf(token_out, TOKEN_LEN + 1, "%s", reset_token->token) >= TOKEN_LEN + 1) {
        return 0;
    }
    
    system->tokenCount++;
    return 1;
}

int validate_reset_token(PasswordResetSystem* system, const char* token) {
    if (!system || !token) return 0;
    if (strlen(token) == 0 || strlen(token) > TOKEN_LEN) return 0;
    
    time_t current_time = time(NULL);
    
    for (int i = 0; i < system->tokenCount; ++i) {
        if (system->tokens[i].active && strcmp(system->tokens[i].token, token) == 0) {
            if (current_time > system->tokens[i].expiry) {
                system->tokens[i].active = 0;
                return 0;
            }
            return 1;
        }
    }
    
    return 0;
}

int reset_password(PasswordResetSystem* system, const char* token, const char* new_password) {
    if (!system || !token || !new_password) return 0;
    if (!validate_reset_token(system, token) || !is_valid_password(new_password)) return 0;
    
    ResetToken* reset_token = NULL;
    for (int i = 0; i < system->tokenCount; ++i) {
        if (system->tokens[i].active && strcmp(system->tokens[i].token, token) == 0) {
            reset_token = &system->tokens[i];
            break;
        }
    }
    
    if (!reset_token) return 0;
    
    UserRecord* user = NULL;
    for (int i = 0; i < system->userCount; ++i) {
        if (system->users[i].active && strcmp(system->users[i].email, reset_token->email) == 0) {
            user = &system->users[i];
            break;
        }
    }
    
    if (!user) return 0;
    
    generate_random_string(user->salt, SALT_LEN);
    hash_password(new_password, user->salt, user->passwordHash);
    
    if (user->passwordHash[0] == '\0') return 0;
    
    reset_token->active = 0;
    return 1;
}

int verify_password(PasswordResetSystem* system, const char* email, const char* password) {
    if (!system || !email || !password) return 0;
    if (!is_valid_email(email) || !is_valid_password(password)) return 0;
    
    UserRecord* user = NULL;
    for (int i = 0; i < system->userCount; ++i) {
        if (system->users[i].active && strcmp(system->users[i].email, email) == 0) {
            user = &system->users[i];
            break;
        }
    }
    
    if (!user) return 0;
    
    char computed_hash[65];
    hash_password(password, user->salt, computed_hash);
    
    if (computed_hash[0] == '\0') return 0;
    
    return constant_time_compare(computed_hash, user->passwordHash);
}

int main() {
    PasswordResetSystem system = {0};
    char token[TOKEN_LEN + 1];
    
    printf("Test 1 - Register user: %s\n", 
           register_user(&system, "user@example.com", "password123") ? "PASS" : "FAIL");
    
    printf("Test 2 - Generate token: %s\n", 
           generate_reset_token(&system, "user@example.com", token) ? "PASS" : "FAIL");
    
    printf("Test 3 - Validate token: %s\n", 
           validate_reset_token(&system, token) ? "PASS" : "FAIL");
    
    printf("Test 4 - Reset password: %s\n", 
           reset_password(&system, token, "newPassword456") ? "PASS" : "FAIL");
    
    printf("Test 5 - Verify new password: %s\n", 
           verify_password(&system, "user@example.com", "newPassword456") ? "PASS" : "FAIL");
    
    return 
