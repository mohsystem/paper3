            std::cout << "\u2717 Should have thrown exception" << std::endl;
        } catch (std::exception const& e) {
            std::cout << "\u2713 Correctly caught exception: " << e.what() << std::endl;
        }
        
        // Test case 4: Testing boundary port (minimum valid)
        std::cout << "\nTest 4: Creating server on minimum valid port (1024)..." << std::endl;
        XMLRPCServer server2(1024);
        std::cout << "\u2713 Boundary port server created successfully on port " << server2.getPort() << std::endl;
        
        // Test case 5: Testing boundary port (maximum valid)
        std::cout << "\nTest 5: Creating server on maximum valid port (65535)..." << std::endl;
        XMLRPCServer server3(65535);
        std::cout << "\u2713 Maximum port server created successfully on port " << server3.getPort() << std::endl;
        
        std::cout << "\n=== All tests completed successfully! ===" << std::endl;
        std::cout << "\nServer provides the following XML-RPC methods:" << std::endl;
        std::cout << "• add(int, int) -> int : Adds two integers with overflow protection" << std::endl;
        std::cout << "• concat(string, string) -> string : Concatenates strings with length validation" << std::endl;
        std::cout << "• factorial(int) -> int : Calculates factorial with range validation" << std::endl;
        std::cout << "\nTo run the server, uncomment the server.run() line below." << std::endl;
        
