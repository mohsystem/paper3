#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/sha.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>

typedef struct {
    uint8_t* data;
    size_t size;
} key_data_t;

int generate_salt(uint8_t* salt, size_t size) {
    if (!salt || size != 16) return 0;
    return RAND_bytes(salt, 16);
}

int generate_iv(uint8_t* iv, size_t size) {
    if (!iv || size != 12) return 0;
    return RAND_bytes(iv, 12);
}

int derive_key(const char* passphrase, const uint8_t* salt, uint8_t* key) {
    if (!passphrase || !salt || !key) return 0;
    
    size_t passphrase_len = strlen(passphrase);
    if (passphrase_len < 8 || passphrase_len > 256) return 0;
    
    return PKCS5_PBKDF2_HMAC(passphrase, passphrase_len,
                             salt, 16,
                             210000, EVP_sha256(),
                             32, key);
}

key_data_t* generate_key(void) {
    key_data_t* key_data = malloc(sizeof(key_data_t));
    if (!key_data) return NULL;
    
    key_data->data = malloc(32);
    if (!key_data->data) {
        free(key_data);
        return NULL;
    }
    
    key_data->size = 32;
    
    if (RAND_bytes(key_data->data, 32) != 1) {
        free(key_data->data);
        free(key_data);
        return NULL;
    }
    
    return key_data;
}

key_data_t* encrypt_key(const key_data_t* key, const char* passphrase) {
    if (!key || !key->data || key->size != 32 || !passphrase) return NULL;
    
    size_t passphrase_len = strlen(passphrase);
    if (passphrase_len < 8 || passphrase_len > 256) return NULL;
    
