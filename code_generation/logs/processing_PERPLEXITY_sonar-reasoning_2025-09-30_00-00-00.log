#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/crypto.h>

#define MAX_KEYS 100
#define MAX_KEY_ID_LEN 64
#define MAX_KEY_SIZE 32  // 256 bits
#define MIN_KEY_SIZE 16  // 128 bits

typedef struct {
    char id[MAX_KEY_ID_LEN];
    unsigned char key_data[MAX_KEY_SIZE];
    size_t key_size;
    int is_used;
} CryptoKey;

typedef struct {
    CryptoKey keys[MAX_KEYS];
    size_t count;
} KeyManager;

// Initialize key manager
int init_key_manager(KeyManager *km) {
    if (!km) return -1;
    
    memset(km, 0, sizeof(KeyManager));
    km->count = 0;
    return 0;
}

// Validate key ID
int validate_key_id(const char *key_id) {
    if (!key_id) return -1;
    
    size_t len = strlen(key_id);
    if (len == 0 || len >= MAX_KEY_ID_LEN) return -1;
    
    // Check for valid characters (alphanumeric and underscore)
    for (size_t i = 0; i < len; i++) {
        char c = key_id[i];
        if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || 
              (c >= '0' && c <= '9') || c == '_')) {
            return -1;
        }
    }
    return 0;
}

// Validate key size
int validate_key_size(size_t key_size) {
    return (key_size >= MIN_KEY_SIZE && key_size <= MAX_KEY_SIZE) ? 0 : -1;
}

// Find key by ID
int find_key_index(KeyManager *km, const char *key_id) {
    if (!km || !key_id) return -1;
    
    for (size_t i = 0; i < MAX_KEYS; i++) {
        if (km->keys[i].is_used && 
            strncmp(km->keys[i].id, key_id, MAX_KEY_ID_LEN) == 0) {
            return (int)i;
        }
    }
    return -1;
}

// Generate cryptographic key
int generate_key(KeyManager *km, const char *key_id, size_t key_size) {
    if (!km || validate_key_id(key_id) != 0 || validate_key_size(key_size) != 0) {
        return -1;
    }
    
    // Check if key already exists
    if (find_key_index(km, key_id) >= 0) {
        return -1; // Key already exists
    }
    
    // Find empty slot
    int slot = -1;
    for (size_t i = 0; i < MAX_KEYS; i++) {
        if (!km->keys[i].is_used) {
            slot = (int)i;
            break;
        }
    }
    
    if (slot == -1) {
        return -1; // No available slots
    }
    
    // Generate random key data
    unsigned char key_data[MAX_KEY_SIZE];
    if (RAND_bytes(key_data, (int)key_size) != 1) {
        return -1; // Random generation failed
    }
    
    // Store the key
    strncpy(km->keys[slot].id, key_id, MAX_KEY_ID_LEN - 1);
    km->keys[slot].id[MAX_KEY_ID_LEN - 1] = '\0';
    memcpy(km->keys[slot].key_data, key_data, key_size);
    km->keys[slot].key_size = key_size;
    km->keys[slot].is_used = 1;
    
    // Securely clear temporary key data
    OPENSSL_cleanse(key_data, sizeof(key_data));
    
    if (km->count < MAX_KEYS) {
        km->count++;
    }
    
    return 0;
}

// Store existing key
int store_key(KeyManager *km, const char *key_id, const unsigned char *key_data, size_t key_size) {
    if (!km || !key_data || validate_key_id(key_id) != 0 || validate_key_size(key_size) != 0) {
        return -1;
    }
    
    // Check if key already exists
    if (find_key_index(km, key_id) >= 0) {
        return -1; // Key already exists
    }
    
    // Find empty slot
    int slot = -1;
    for (size_t i = 0; i < MAX_KEYS; i++) {
        if (!km->keys[i].is_used) {
            slot = (int)i;
            break;
        }
    }
    
    if (slot == -1) {
        return -1; // No available slots
    }
    
    // Store the key
    strncpy(km->keys[slot].id, key_id, MAX_KEY_ID_LEN - 1);
    km->keys[slot].id[MAX_KEY_ID_LEN - 1] = '\0';
    memcpy(km->keys[slot].key_data, key_data, key_size);
    km->keys[slot].key_size = key_size;
    km->keys[slot].is_used = 1;
    
    if (km->count < MAX_KEYS) {
        km->count++;
    }
    
    return 0;
}

// Retrieve key
int retrieve_key(KeyManager *km, const char *key_id, unsigned char *key_data, size_t *key_size) {
    if (!km || !key_data || !key_size || validate_key_id(key_id) != 0) {
        return -1;
    }
    
    int index = find_key_index(km, key_id);
    if (index < 0) {
        return -1; // Key not found
    }
    
    // Check buffer size
    if (*key_size < km->keys[index].key_size) {
        return -1; // Buffer too small
    }
    
    memcpy(key_data, km->keys[index].key_data, km->keys[index].key_size);
    *key_size = km->keys[index].key_size;
    
    return 0;
}

// Destroy key
int destroy_key(KeyManager *km, const char *key_id) {
    if (!km || validate_key_id(key_id) != 0) {
        return -1;
    }
    
    int index = find_key_index(km, key_id);
    if (index < 0) {
        return -1; // Key not found
    }
    
    // Securely clear key data
    OPENSSL_cleanse(&km->keys[index], sizeof(CryptoKey));
    km->keys[index].is_used = 0;
    
    if (km->count > 0) {
        km->count--;
    }
    
    return 0;
}

// Cleanup key manager
void cleanup_key_manager(KeyManager *km) {
    if (!km) return;
    
    // Securely clear all keys
    for (size_t i = 0; i < MAX_KEYS; i++) {
        if (km->keys[i].is_used) {
            OPENSSL_cleanse(&km->keys[i], sizeof(CryptoKey));
        }
    }
    
    // Clear the entire structure
    OPENSSL_cleanse(km, sizeof(KeyManager));
}

int main() {
    KeyManager km;
    unsigned char retrieved_key[MAX_KEY_SIZE];
    size_t retrieved_size;
    
    // Test case 1: Initialize key manager
    printf("Test 1 - Initialize: ");
    if (init_key_manager(&km) == 0) {
        printf("PASS\n");
    } else {
        printf("FAIL\n");
    }
    
    // Test case 2: Generate a new key
    printf("Test 2 - Generate key: ");
    if (generate_key(&km, "test_key_1", 32) == 0) {
        printf("PASS\n");
    } else {
        printf("FAIL\n");
    }
    
    // Test case 3: Retrieve the generated key
    printf("Test 3 - Retrieve key: ");
    retrieved_size = MAX_KEY_SIZE;
    if (retrieve_key(&km, "test_key_1", retrieved_key, &retrieved_size) == 0 && retrieved_size == 32) {
        printf("PASS\n");
    } else {
        printf("FAIL\n");
    }
    
    // Test case 4: Store a custom key
    printf("Test 4 - Store custom key: ");
    unsigned char custom_key[16] = {0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08,
                                   0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F, 0x10};
    if (store_key(&km, "custom_key", custom_key, 16) == 0) {
        printf("PASS\n");
    } else {
        printf("FAIL\n");
    }
    
    // Test case 5: Destroy a key
    printf("Test 5 - Destroy key: ");
    if (destroy_key(&km, "test_key_1") == 0) {
        printf("PASS\n");
    } else {
        printf("FAIL\n");
    }
    
    // Cleanup
    cleanup_key_manager(&km);
    
    return 0;
}
