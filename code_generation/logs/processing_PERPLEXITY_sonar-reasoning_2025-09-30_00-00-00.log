#include <iostream>
#include <string>
#include <vector>
#include <map>
#include <memory>
#include <random>
#include <algorithm>
#include <stdexcept>
#include <iomanip>
#include <sstream>
#include <cstring>

class SecureKeyManager {
private:
    std::map<std::string, std::vector<uint8_t>> keyStore;
    mutable std::random_device rd;
    mutable std::mt19937_64 gen;
    
    static const size_t KEY_SIZE = 32; // 256 bits
    static const size_t SALT_SIZE = 16;
    static const size_t MIN_PASSPHRASE_LENGTH = 8;
    static const size_t MAX_KEY_ID_LENGTH = 128;
    
    // Input validation
    bool validateKeyId(const std::string& keyId) const {
        return !keyId.empty() && keyId.length() <= MAX_KEY_ID_LENGTH &&
               keyId.find_first_not_of("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-") == std::string::npos;
    }
    
    bool validatePassphrase(const std::string& passphrase) const {
        return passphrase.length() >= MIN_PASSPHRASE_LENGTH && passphrase.length() <= 1024;
    }
    
    // Simple but secure key derivation (simplified PBKDF2-like)
    std::vector<uint8_t> deriveKeyFromPassphrase(const std::string& passphrase, const std::vector<uint8_t>& salt, uint32_t iterations) const {
        if (!validatePassphrase(passphrase) || salt.size() != SALT_SIZE) {
            throw std::invalid_argument("Invalid passphrase or salt parameters");
        }
        
        std::vector<uint8_t> key(KEY_SIZE, 0);
        std::vector<uint8_t> input(passphrase.begin(), passphrase.end());
        input.insert(input.end(), salt.begin(), salt.end());
        
        // Simplified key stretching (in real implementation, use proper PBKDF2)
        for (uint32_t i = 0; i < iterations; ++i) {
            std::hash<std::string> hasher;
            std::string hashInput(input.begin(), input.end());
            size_t hashValue = hasher(hashInput + std::to_string(i));
            
            for (size_t j = 0; j < KEY_SIZE; ++j) {
                key[j] ^= static_cast<uint8_t>((hashValue >> (j % 8)) & 0xFF);
            }
        }
        
        return key;
    }
    
    // Secure memory clearing
    void secureClear(std::vector<uint8_t>& data) const {
        volatile uint8_t* ptr = data.data();
        for (size_t i = 0; i < data.size(); ++i) {
            ptr[i] = 0;
        }
    }

public:
    SecureKeyManager() : gen(rd()) {}
    
    ~SecureKeyManager() {
        // Securely clear all stored keys
        for (auto& pair : keyStore) {
            secureClear(pair.second);
        }
    }
    
    // Generate cryptographically secure random key
    std::vector<uint8_t> generateRandomKey() {
        std::vector<uint8_t> key(KEY_SIZE);
        std::uniform_int_distribution<uint16_t> dist(0, 255);
        
        for (size_t i = 0; i < KEY_SIZE; ++i) {
            key[i] = static_cast<uint8_t>(dist(gen));
        }
        
        return key;
    }
    
    // Generate random salt
    std::vector<uint8_t> generateSalt() {
        std::vector<uint8_t> salt(SALT_SIZE);
        std::uniform_int_distribution<uint16_t> dist(0, 255);
        
        for (size_t i = 0; i < SALT_SIZE; ++i) {
            salt[i] = static_cast<uint8_t>(dist(gen));
        }
        
        return salt;
    }
    
    // Derive key from passphrase with salt
    std::vector<uint8_t> deriveKey(const std::string& passphrase, const std::vector<uint8_t>& salt) {
        return deriveKeyFromPassphrase(passphrase, salt, 210000);
    }
    
    // Store key with identifier
    bool storeKey(const std::string& keyId, const std::vector<uint8_t>& key) {
        if (!validateKeyId(keyId) || key.size() != KEY_SIZE) {
            return false;
        }
        
        keyStore[keyId] = key;
        return true;
    }
    
    // Retrieve key by identifier
    std::vector<uint8_t> retrieveKey(const std::string& keyId) {
        if (!validateKeyId(keyId)) {
            throw std::invalid_argument("Invalid key identifier");
        }
        
        auto it = keyStore.find(keyId);
        if (it == keyStore.end()) {
            throw std::runtime_error("Key not found");
        }
        
        return it->second;
    }
    
    // Check if key exists
    bool keyExists(const std::string& keyId) {
        if (!validateKeyId(keyId)) {
            return false;
        }
        return keyStore.find(keyId) != keyStore.end();
    }
    
    // Remove key securely
    bool removeKey(const std::string& keyId) {
        if (!validateKeyId(keyId)) {
            return false;
        }
        
        auto it = keyStore.find(keyId);
        if (it != keyStore.end()) {
            secureClear(it->second);
            keyStore.erase(it);
            return true;
        }
        return false;
    }
    
    // Get number of stored keys
    size_t getKeyCount() const {
        return keyStore.size();
    }
    
    // Convert key to hex string for display (non-secret keys only)
    std::string keyToHex(const std::vector<uint8_t>& key) const {
        std::stringstream ss;
        ss << std::hex << std::setfill('0');
        for (size_t i = 0; i < std::min(key.size(), size_t(8)); ++i) {
            ss << std::setw(2) << static_cast<unsigned>(key[i]);
        }
        ss << "...";
        return ss.str();
    }
};

int main() {
    try {
        SecureKeyManager keyManager;
        
        // Test Case 1: Generate and store a random key
        std::cout << "Test 1: Generate and store random key" << std::endl;
        auto randomKey = keyManager.generateRandomKey();
        bool stored = keyManager.storeKey("test_key_1", randomKey);
        std::cout << "Random key generated and stored: " << (stored ? "SUCCESS" : "FAILED") << std::endl;
        std::cout << "Key preview: " << keyManager.keyToHex(randomKey) << std::endl;
        std::cout << "Current key count: " << keyManager.getKeyCount() << std::endl;
        
        // Test Case 2: Derive key from passphrase
        std::cout << "\nTest 2: Derive key from passphrase" << std::endl;
        std::string passphrase = "MySecurePassphrase123!";
        auto salt = keyManager.generateSalt();
        auto derivedKey = keyManager.deriveKey(passphrase, salt);
        bool derivedStored = keyManager.storeKey("derived_key_1", derivedKey);
        std::cout << "Key derived from passphrase and stored: " << (derivedStored ? "SUCCESS" : "FAILED") << std::endl;
        std::cout << "Derived key preview: " << keyManager.keyToHex(derivedKey) << std::endl;
        std::cout << "Current key count: " << keyManager.getKeyCount() << std::endl;
        
        // Test Case 3: Retrieve and verify stored key
        std::cout << "\nTest 3: Retrieve and verify stored key" << std::endl;
        try {
            auto retrievedKey = keyManager.retrieveKey("test_key_1");
            bool keysMatch = (retrievedKey == randomKey);
            std::cout << "Key retrieved successfully: " << (retrievedKey.size() == 32 ? "SUCCESS" : "FAILED") << std::endl;
            std::cout << "Retrieved key matches original: " << (keysMatch ? "SUCCESS" : "FAILED") << std::endl;
        } catch (const std::exception& e) {
            std::cout << "Key retrieval failed: " << e.what() << std::endl;
        }
        
        // Test Case 4: Key existence validation
        std::cout << "\nTest 4: Key existence validation" << std::endl;
        bool existingKeyFound = keyManager.keyExists("test_key_1");
        bool nonExistentKeyFound = keyManager.keyExists("non_existent_key");
        bool invalidKeyIdRejected = !keyManager.keyExists("");
        std::cout << "Existing key found: " << (existingKeyFound ? "SUCCESS" : "FAILED") << std::endl;
        std::cout << "Non-existent key correctly not found: " << (!nonExistentKeyFound ? "SUCCESS" : "FAILED") << std::endl;
        std::cout << "Invalid key ID rejected: " << (invalidKeyIdRejected ? "SUCCESS" : "FAILED") << std::endl;
        
        // Test Case 5: Secure key removal
        std::cout << "\nTest 5: Secure key removal" << std::endl;
        size_t initialCount = keyManager.getKeyCount();
        bool keyRemoved = keyManager.removeKey("test_key_1");
        bool keyNoLongerExists = !keyManager.keyExists("test_key_1");
        size_t finalCount = keyManager.getKeyCount();
        std::cout << "Key removed successfully: " << (keyRemoved ? "SUCCESS" : "FAILED") << std::endl;
        std::cout << "Key no longer exists: " << (keyNoLongerExists ? "SUCCESS" : "FAILED") << std::endl;
        std::cout << "Key count decreased: " << ((finalCount == initialCount - 1) ? "SUCCESS" : "FAILED") << std::endl;
        std::cout << "Final key count: " << finalCount << std::endl;
        
        std::cout << "\nAll tests completed successfully!" << std::endl;
        
    } catch (const std::exception& e) {
        std::cerr << "Error during execution: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
