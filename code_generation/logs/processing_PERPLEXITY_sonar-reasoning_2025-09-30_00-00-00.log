import socket
import hashlib
import secrets
import base64
import os
from typing import Optional
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
import hmac

class ChatClient:
    def send_login_request(self, username: str, password: str, server_host: str, port: int) -> str:
        if not username or not password or len(username) == 0 or len(username) > 50 or len(password) == 0 or len(password) > 100:
            return "INVALID_INPUT"
        
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.connect((server_host, port))
                sanitized_username = ''.join(c for c in username if c.isalnum() or c == '_')
                message = f"LOGIN {sanitized_username} {password}\n"
                s.sendall(message.encode('utf-8'))
                response = s.recv(1024).decode('utf-8').strip()
                return response
        except Exception:
            return "CONNECTION_ERROR"

class ChatServer:
    def __init__(self):
        self.users_file = "users.txt"
        self.salt_length = 16
        self.iterations = 210000
        
    def start_server(self, port: int) -> None:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as server_socket:
            server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            server_socket.bind(('localhost', port))
            server_socket.listen(1)
            
            while True:
                try:
                    client_socket, addr = server_socket.accept()
                    with client_socket:
                        data = client_socket.recv(1024).decode('utf-8').strip()
                        if data.startswith("LOGIN "):
                            parts = data.split(" ", 2)
                            if len(parts) == 3:
                                username = parts[1]
                                password = parts[2]
                                authenticated = self.authenticate_user(username, password)
                                response = "SUCCESS" if authenticated else "FAILURE"
                            else:
                                response = "FAILURE"
                            client_socket.sendall(response.encode('utf-8'))
                        else:
                            client_socket.sendall(b"FAILURE")
                except Exception:
                    continue
                    
    def authenticate_user(self, username: str, password: str) -> bool:
        if not username or not password or len(username) == 0 or len(username) > 50:
            return False
            
        try:
            with open(self.users_file, 'r', encoding='utf-8') as f:
                for line in f:
                    parts = line.strip().split(':', 2)
                    if len(parts) == 3 and self._constant_time_equals(parts[0], username):
                        salt = base64.b64decode(parts[1])
                        stored_hash = base64.b64decode(parts[2])
                        password_hash = self._hash_password(password, salt)
                        return self._constant_time_equals(stored_hash, password_hash)
        except (FileNotFoundError, Exception):
            return False
        return False
        
    def create_user(self, username: str, password: str) -> None:
        if not username or not password or len(username) == 0 or len(username) > 50 or len(password) < 8 or len(password) > 100:
            return
            
        salt = secrets.token_bytes(self.salt_length)
        password_hash = self._hash_password(password, salt)
        
        try:
            with open(self.users_file, 'a', encoding='utf-8') as f:
                salt_b64 = base64.b64encode(salt).decode('ascii')
                hash_b64 = base64.b64encode(password_hash).decode('ascii')
                f.write(f"{username}:{salt_b64}:{hash_b64}\n")
        except Exception:
            pass
            
    def _hash_password(self, password: str, salt: bytes) -> bytes:
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=self.iterations,
        )
        return kdf.derive(password.encode('utf-8'))
        
    def _constant_time_equals(self, a, b) -> bool:
        if isinstance(a, str) and isinstance(b, str):
            return hmac.compare_digest(a.encode('utf-8'), b.encode('utf-8'))
        elif isinstance(a, bytes) and isinstance(b, bytes):
            return hmac.compare_digest(a, b)
        return False

def main():
    server = ChatServer()
    client = ChatClient()
    
    # Test case 1: Create test users
    server.create_user("testuser1", "password123")
    server.create_user("admin", "securepass456")
    
    # Test case 2: Valid authentication
    auth1 = server.authenticate_user("testuser1", "password123")
    print(f"Test 1 - Valid auth: {auth1}")
    
    # Test case 3: Invalid password
    auth2 = server.authenticate_user("testuser1", "wrongpass")
    print(f"Test 2 - Invalid password: {not auth2}")
    
    # Test case 4: Non-existent user
    auth3 = server.authenticate_user("nonexistent", "anypass")
    print(f"Test 3 - Non-existent user: {not auth3}")
    
    # Test case 5: Input validation
    result = client.send_login_request("", "", "localhost", 8080)
    print(f"Test 4 - Empty input: {result == 'INVALID_INPUT'}")
    
    # Test case 6: Long input validation
    long_user = "a" * 60
    result2 = client.send_login_request(long_user, "pass", "localhost", 8080)
    print(f"Test 5 - Long username: {result2 == 'INVALID_INPUT'}")

if __name__ == "__main__":
    main()
