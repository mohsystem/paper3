            std::cout << "\u2717 Should have thrown exception" << std::endl;
        } catch (std::exception const& e) {
            std::cout << "\u2713 Correctly caught exception: " << e.what() << std::endl;
        }
        
        // Test case 3: Invalid port handling (too high)
