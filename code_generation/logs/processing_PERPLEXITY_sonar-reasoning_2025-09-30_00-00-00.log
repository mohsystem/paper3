#include <iostream>
#include <string>
#include <unordered_map>
#include <random>
#include <iomanip>
#include <sstream>
#include <cstring>
#include <memory>

class CSRFProtection {
private:
    std::unordered_map<std::string, std::string> sessions;
    std::random_device rd;
    std::mt19937 gen;
    
public:
    CSRFProtection() : gen(rd()) {}
    
    std::string generateToken(const std::string& sessionId) {
        if (sessionId.empty() || sessionId.length() > 64) {
            return "";
        }
        
        std::uniform_int_distribution<> dis(0, 15);
        std::stringstream ss;
        for (int i = 0; i < 32; ++i) {
            ss << std::hex << dis(gen);
        }
        
        std::string token = ss.str();
        sessions[sessionId] = token;
        return token;
    }
    
    bool validateToken(const std::string& sessionId, const std::string& token) {
        if (sessionId.empty() || token.empty() || sessionId.length() > 64 || token.length() != 32) {
            return false;
        }
        
        auto it = sessions.find(sessionId);
        if (it == sessions.end()) {
            return false;
        }
        
        return it->second == token;
    }
};

struct UserSettings {
    std::string email;
    std::string name;
    bool notifications;
    
    UserSettings() : notifications(false) {}
};

class WebApp {
private:
    std::unordered_map<std::string, UserSettings> users;
    CSRFProtection csrf;
    
public:
    std::string generateCSRFToken(const std::string& sessionId) {
        return csrf.generateToken(sessionId);
    }
    
    bool updateUserSettings(const std::string& sessionId, const std::string& csrfToken,
                           const std::string& email, const std::string& name, bool notifications) {
        if (!csrf.validateToken(sessionId, csrfToken)) {
            return false;
        }
        
        if (email.length() > 100 || name.length() > 50) {
            return false;
        }
        
        if (email.find('@') == std::string::npos) {
            return false;
        }
        
        UserSettings& settings = users[sessionId];
        settings.email = email;
        settings.name = name;
        settings.notifications = notifications;
        
        return true;
    }
    
    UserSettings getUserSettings(const std::string& sessionId) {
        auto it = users.find(sessionId);
        if (it != users.end()) {
            return it->second;
        }
        return UserSettings();
    }
};

int main() {
    WebApp app;
    
    // Test Case 1: Valid CSRF token and update
    std::string session1 = "user123";
    std::string token1 = app.generateCSRFToken(session1);
    bool result1 = app.updateUserSettings(session1, token1, "user@example.com", "John Doe", true);
    std::cout << "Test 1 (Valid CSRF): " << (result1 ? "PASS" : "FAIL") << std::endl;
    
    // Test Case 2: Invalid CSRF token
    std::string session2 = "user456";
    std::string token2 = app.generateCSRFToken(session2);
    bool result2 = app.updateUserSettings(session2, "invalid_token", "user2@example.com", "Jane Doe", false);
    std::cout << "Test 2 (Invalid CSRF): " << (!result2 ? "PASS" : "FAIL") << std::endl;
    
    // Test Case 3: Empty CSRF token
    std::string session3 = "user789";
    app.generateCSRFToken(session3);
    bool result3 = app.updateUserSettings(session3, "", "user3@example.com", "Bob Smith", true);
    std::cout << "Test 3 (Empty CSRF): " << (!result3 ? "PASS" : "FAIL") << std::endl;
    
    // Test Case 4: Invalid email format
    std::string session4 = "user101";
    std::string token4 = app.generateCSRFToken(session4);
    bool result4 = app.updateUserSettings(session4, token4, "invalid_email", "Alice Brown", false);
    std::cout << "Test 4 (Invalid email): " << (!result4 ? "PASS" : "FAIL") << std::endl;
    
    // Test Case 5: Valid update and verify settings
    std::string session5 = "user202";
    std::string token5 = app.generateCSRFToken(session5);
    bool result5 = app.updateUserSettings(session5, token5, "test@example.com", "Test User", true);
    UserSettings settings5 = app.getUserSettings(session5);
    bool verify5 = (settings5.email == "test@example.com" && settings5.name == "Test User" && settings5.notifications);
    std::cout << "Test 5 (Settings verify): " << (result5 && verify5 ? "PASS" : "FAIL") << std::endl;
    
    return 0;
}
