#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>
#include <stdbool.h>
#include <time.h>

#define MAX_NAME_LEN 64
#define MAX_ADDRESS_LEN 128
#define MAX_CC_NUM_LEN 20
#define SALT_SIZE 16
#define IV_SIZE 12
#define TAG_SIZE 16
#define MAGIC_SIZE 4

// Secure data structures
typedef struct {
    char name[MAX_NAME_LEN];
    char address[MAX_ADDRESS_LEN];
    char cc_number[MAX_CC_NUM_LEN];
    char cvv[4];
    uint32_t exp_month;
    uint32_t exp_year;
} SensitiveData;

typedef struct {
    char magic[MAGIC_SIZE];
    uint32_t version;
    uint8_t salt[SALT_SIZE];
    uint8_t iv[IV_SIZE];
    uint8_t* ciphertext;
    size_t ciphertext_len;
    uint8_t tag[TAG_SIZE];
} EncryptedData;

// Secure memory operations
void secure_memset(void* ptr, int value, size_t len) {
    if (ptr == NULL) return;
    volatile unsigned char* p = (volatile unsigned char*)ptr;
    while (len--) *p++ = value;
}

// Input validation functions
bool validate_name(const char* name) {
    if (name == NULL) return false;
    size_t len = strnlen(name, MAX_NAME_LEN);
    if (len == 0 || len >= MAX_NAME_LEN) return false;
    
    for (size_t i = 0; i < len; i++) {
        if (!((name[i] >= 'A' && name[i] <= 'Z') || 
              (name[i] >= 'a' && name[i] <= 'z') || 
              name[i] == ' ' || name[i] == '-' || name[i] == '\'')) {
            return false;
        }
    }
    return true;
}

bool validate_cc_number(const char* cc_num) {
    if (cc_num == NULL) return false;
    size_t len = strnlen(cc_num, MAX_CC_NUM_LEN);
    if (len < 13 || len >= MAX_CC_NUM_LEN) return false;
    
    for (size_t i = 0; i < len; i++) {
        if (cc_num[i] < '0' || cc_num[i] > '9') return false;
    }
    return true;
}

bool validate_cvv(const char* cvv) {
    if (cvv == NULL) return false;
    size_t len = strnlen(cvv, 4);
    if (len != 3) return false;
    
    for (size_t i = 0; i < 3; i++) {
        if (cvv[i] < '0' || cvv[i] > '9') return false;
    }
    return true;
}

bool validate_exp_date(uint32_t month, uint32_t year) {
    if (month < 1 || month > 12) return false;
    if (year < 2024 || year > 2040) return false;
    return true;
}

// Secure random number generation (placeholder - would use OS CSPRNG)
void generate_secure_random(uint8_t* buffer, size_t len) {
    // In production: use OS cryptographically secure RNG
    // For demo purposes only - NOT cryptographically secure
    srand((unsigned int)time(NULL));
    for (size_t i = 0; i < len; i++) {
        buffer[i] = (uint8_t)(rand() % 256);
    }
}

// Key derivation (placeholder - would use PBKDF2-HMAC-SHA-256)
bool derive_key(const char* passphrase, const uint8_t* salt, uint8_t* key) {
    if (passphrase == NULL || salt == NULL || key == NULL) return false;
    
    // Placeholder for PBKDF2-HMAC-SHA-256 with 210,000 iterations
    // In production: use proper KDF from crypto library
    for (int i = 0; i < 32; i++) {
        key[i] = (uint8_t)((passphrase[i % strlen(passphrase)] ^ salt[i % SALT_SIZE]) & 0xFF);
    }
    return true;
}

// AES-GCM encryption (placeholder - would use OpenSSL EVP or libsodium)
bool encrypt_data(const uint8_t* plaintext, size_t plaintext_len,
                  const uint8_t* key, const uint8_t* iv,
                  uint8_t* ciphertext, uint8_t* tag) {
    if (plaintext == NULL || key == NULL || iv == NULL || 
        ciphertext == NULL || tag == NULL) return false;
    
    // Placeholder for AES-256-GCM encryption
    // In production: use OpenSSL EVP_EncryptInit_ex with EVP_aes_256_gcm()
    for (size_t i = 0; i < plaintext_len; i++) {
        ciphertext[i] = plaintext[i] ^ key[i % 32] ^ iv[i % IV_SIZE];
    }
    
    // Generate authentication tag (placeholder)
    for (int i = 0; i < TAG_SIZE; i++) {
        tag[i] = key[i % 32] ^ iv[i % IV_SIZE];
    }
    
    return true;
}

// Store sensitive data securely
bool store_sensitive_data(const SensitiveData* data, const char* passphrase) {
    if (data == NULL || passphrase == NULL) return false;
    
    EncryptedData enc_data;
    uint8_t key; // AES-256 key
    
    // Set magic and version
    memcpy(enc_data.magic, "ENC1", MAGIC_SIZE);
    enc_data.version = 1;
    
    // Generate salt and IV
    generate_secure_random(enc_data.salt, SALT_SIZE);
    generate_secure_random(enc_data.iv, IV_SIZE);
    
    // Derive encryption key
    if (!derive_key(passphrase, enc_data.salt, key)) {
        secure_memset(key, 0, sizeof(key));
        return false;
    }
    
    // Allocate ciphertext buffer
    enc_data.ciphertext_len = sizeof(SensitiveData);
    enc_data.ciphertext = malloc(enc_data.ciphertext_len);
    if (enc_data.ciphertext == NULL) {
        secure_memset(key, 0, sizeof(key));
        return false;
    }
    
    // Encrypt data
    bool success = encrypt_data((const uint8_t*)data, sizeof(SensitiveData),
                               key, enc_data.iv, enc_data.ciphertext, enc_data.tag);
    
    // Clear sensitive key material
    secure_memset(key, 0, sizeof(key));
    
    if (success) {
        printf("Data encrypted successfully\n");
        printf("Magic: %.4s, Version: %u\n", enc_data.magic, enc_data.version);
        
        printf("Salt: ");
        for (int i = 0; i < SALT_SIZE; i++) {
            printf("%02x", enc_data.salt[i]);
        }
        printf("\n");
        
        printf("IV: ");
        for (int i = 0; i < IV_SIZE; i++) {
            printf("%02x", enc_data.iv[i]);
        }
        printf("\n");
        
        printf("Ciphertext length: %zu bytes\n", enc_data.ciphertext_len);
        printf("Authentication tag generated\n");
    }
    
    // Cleanup
    if (enc_data.ciphertext != NULL) {
        secure_memset(enc_data.ciphertext, 0, enc_data.ciphertext_len);
        free(enc_data.ciphertext);
        enc_data.ciphertext = NULL;
    }
    
    return success;
}

// Create sensitive data with validation
bool create_sensitive_data(SensitiveData* data, const char* name, const char* address,
                          const char* cc_number, const char* cvv,
                          uint32_t exp_month, uint32_t exp_year) {
    if (data == NULL) return false;
    
    // Initialize structure
    secure_memset(data, 0, sizeof(SensitiveData));
    
    // Validate and copy name
    if (!validate_name(name)) return false;
    strncpy(data->name, name, MAX_NAME_LEN - 1);
    data->name[MAX_NAME_LEN - 1] = '\0';
    
    // Validate and copy address
    if (address == NULL || strnlen(address, MAX_ADDRESS_LEN) >= MAX_ADDRESS_LEN) return false;
    strncpy(data->address, address, MAX_ADDRESS_LEN - 1);
    data->address[MAX_ADDRESS_LEN - 1] = '\0';
    
    // Validate and copy credit card number
    if (!validate_cc_number(cc_number)) return false;
    strncpy(data->cc_number, cc_number, MAX_CC_NUM_LEN - 1);
    data->cc_number[MAX_CC_NUM_LEN - 1] = '\0';
    
    // Validate and copy CVV
    if (!validate_cvv(cvv)) return false;
    strncpy(data->cvv, cvv, 3);
    data->cvv[3] = '\0';
    
    // Validate expiration date
    if (!validate_exp_date(exp_month, exp_year)) return false;
    data->exp_month = exp_month;
    data->exp_year = exp_year;
    
    return true;
}

int main() {
    printf("Secure Sensitive Data Storage System\n");
    printf("=====================================\n\n");
    
    // Test Case 1: Valid data
    printf("Test Case 1: Valid data\n");
    SensitiveData data1;
    if (create_sensitive_data(&data1, "John Doe", "123 Main St, City, State",
                             "4532123456789012", "123", 12, 2025)) {
        printf("\u2713 Data validation passed\n");
        if (store_sensitive_data(&data1, "SecurePassword123!")) {
            printf("\u2713 Data stored successfully\n");
        }
        secure_memset(&data1, 0, sizeof(data1));
    }
    printf("\n");
    
    // Test Case 2: Invalid credit card number
    printf("Test Case 2: Invalid credit card number\n");
    SensitiveData data2;
    if (!create_sensitive_data(&data2, "Jane Smith", "456 Oak Ave, Town, State",
                              "invalid_cc", "456", 6, 2026)) {
        printf("\u2713 Invalid credit card number rejected\n");
    }
    printf("\n");
    
    // Test Case 3: Invalid CVV
    printf("Test Case 3: Invalid CVV\n");
    SensitiveData data3;
    if (!create_sensitive_data(&data3, "Bob Johnson", "789 Pine Rd, Village, State",
                              "5555444433332222", "12", 3, 2027)) {
        printf("\u2713 Invalid CVV rejected\n");
    }
    printf("\n");
    
    // Test Case 4: Invalid expiration date
    printf("Test Case 4: Invalid expiration date\n");
    SensitiveData data4;
    if (!create_sensitive_data(&data4, "Alice Brown", "321 Elm St, City, State",
                              "4111111111111111", "789", 13, 2025)) {
        printf("\u2713 Invalid expiration month rejected\n");
    }
    printf("\n");
    
    // Test Case 5: Invalid name with special characters
    printf("Test Case 5: Invalid name with special characters\n");
    SensitiveData data5;
    if (!create_sensitive_data(&data5, "Test@User#123", "999 Test Ave, Test, State",
                              "4000000000000002", "321", 9, 2028)) {
        printf("\u2713 Invalid name with special characters rejected\n");
    }
    printf("\n");
    
    printf("All test cases completed.\n");
    printf("Note: This demonstration uses placeholder crypto functions.\n");
    printf("Production code must use vetted crypto libraries like OpenSSL.\n");
    
    return 0;
}
