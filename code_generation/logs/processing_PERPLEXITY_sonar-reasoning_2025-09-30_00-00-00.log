#include <openssl/kdf.h>
#include <fstream>
#include <vector>
#include <string>
#include <cstring>
#include <iostream>
#include <filesystem>

const std::string MAGIC = "ENC1";
const int VERSION = 1;
const int SALT_LENGTH = 16;
const int IV_LENGTH = 12;
const int TAG_LENGTH = 16;
const int ITERATIONS = 210000;

std::vector<uint8_t> derive_key(const std::string& password, const std::vector<uint8_t>& salt) {
    std::vector<uint8_t> key(32);
    EVP_KDF* kdf = EVP_KDF_fetch(nullptr, "PBKDF2", nullptr);
    EVP_KDF_CTX* kctx = EVP_KDF_CTX_new(kdf);
    
    OSSL_PARAM params[] = {
        OSSL_PARAM_construct_utf8_string("digest", const_cast<char*>("SHA256"), 0),
        OSSL_PARAM_construct_octet_string("password", const_cast<char*>(password.c_str()), password.length()),
        OSSL_PARAM_construct_octet_string("salt", const_cast<void*>(static_cast<const void*>(salt.data())), salt.size()),
        OSSL_PARAM_construct_int("iter", const_cast<int*>(&ITERATIONS)),
        OSSL_PARAM_construct_end()
    };
    
    EVP_KDF_derive(kctx, key.data(), key.size(), params);
    EVP_KDF_CTX_free(kctx);
    EVP_KDF_free(kdf);
    return key;
}

