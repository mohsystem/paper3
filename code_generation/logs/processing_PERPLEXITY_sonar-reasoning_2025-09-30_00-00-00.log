#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/kdf.h>
#include <openssl/err.h>
#include <iostream>
#include <fstream>
#include <vector>
#include <string>
#include <memory>
#include <cstring>

class SecureDataStorage {
private:
    static const size_t SALT_SIZE = 16;
    static const size_t IV_SIZE = 12;
    static const size_t TAG_SIZE = 16;
    static const size_t KEY_SIZE = 32;
    static const int PBKDF2_ITERATIONS = 210000;
    static const std::string MAGIC;
    static const uint32_t VERSION = 1;

    std::vector<uint8_t> deriveKey(const std::string& password, const std::vector<uint8_t>& salt) {
        std::vector<uint8_t> key(KEY_SIZE);
        
        EVP_KDF* kdf = EVP_KDF_fetch(nullptr, "PBKDF2", nullptr);
        if (!kdf) return {};
        
        EVP_KDF_CTX* ctx = EVP_KDF_CTX_new(kdf);
        EVP_KDF_free(kdf);
        if (!ctx) return {};
        
        OSSL_PARAM params[] = {
            OSSL_PARAM_construct_octet_string("pass", (void*)password.c_str(), password.length()),
            OSSL_PARAM_construct_octet_string("salt", (void*)salt.data(), salt.size()),
            OSSL_PARAM_construct_int("iter", (int*)&PBKDF2_ITERATIONS),
            OSSL_PARAM_construct_utf8_string("digest", (char*)"SHA256", 0),
            OSSL_PARAM_construct_end()
        };
        
        int result = EVP_KDF_derive(ctx, key.data(), key.size(), params);
        EVP_KDF_CTX_free(ctx);
        
        return (result == 1) ? key : std::vector<uint8_t>();
    }

    std::vector<uint8_t> generateRandom(size_t size) {
        std::vector<uint8_t> buffer(size);
        if (RAND_bytes(buffer.data(), static_cast<int>(size)) != 1) {
            return {};
        }
        return buffer;
    }

public:
    bool encryptAndStore(const std::string& data, const std::string& password, const std::string& filename) {
        if (data.empty() || password.empty() || filename.empty()) {
            return false;
        }

        auto salt = generateRandom(SALT_SIZE);
        auto iv = generateRandom(IV_SIZE);
        if (salt.empty() || iv.empty()) {
            return false;
        }

        auto key = deriveKey(password, salt);
        if (key.empty()) {
            return false;
        }

        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) {
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }

        if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, nullptr, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, IV_SIZE, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }

        if (EVP_EncryptInit_ex(ctx, nullptr, nullptr, key.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }

        std::vector<uint8_t> ciphertext(data.length());
        int len = 0;
        
        if (EVP_EncryptUpdate(ctx, ciphertext.data(), &len, 
                             reinterpret_cast<const uint8_t*>(data.c_str()), 
                             static_cast<int>(data.length())) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }

        int ciphertext_len = len;
        if (EVP_EncryptFinal_ex(ctx, ciphertext.data() + len, &len) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }
        ciphertext_len += len;
        ciphertext.resize(ciphertext_len);

        std::vector<uint8_t> tag(TAG_SIZE);
        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_SIZE, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return false;
        }

        EVP_CIPHER_CTX_free(ctx);
        OPENSSL_cleanse(key.data(), key.size());

        std::ofstream file(filename, std::ios::binary);
        if (!file) {
            return false;
        }

        file.write(MAGIC.c_str(), MAGIC.length());
        file.write(reinterpret_cast<const char*>(&VERSION), sizeof(VERSION));
        file.write(reinterpret_cast<const char*>(salt.data()), salt.size());
        file.write(reinterpret_cast<const char*>(iv.data()), iv.size());
        file.write(reinterpret_cast<const char*>(ciphertext.data()), ciphertext.size());
        file.write(reinterpret_cast<const char*>(tag.data()), tag.size());

        return file.good();
    }

    std::string decryptAndLoad(const std::string& password, const std::string& filename) {
        if (password.empty() || filename.empty()) {
            return "";
        }

        std::ifstream file(filename, std::ios::binary);
        if (!file) {
            return "";
        }

        char magic_buf[4];
        uint32_t version;
        file.read(magic_buf, 4);
        file.read(reinterpret_cast<char*>(&version), sizeof(version));

        if (std::string(magic_buf, 4) != MAGIC || version != VERSION) {
            return "";
        }

        std::vector<uint8_t> salt(SALT_SIZE);
        std::vector<uint8_t> iv(IV_SIZE);
        file.read(reinterpret_cast<char*>(salt.data()), salt.size());
        file.read(reinterpret_cast<char*>(iv.data()), iv.size());

        file.seekg(0, std::ios::end);
        size_t file_size = file.tellg();
        size_t ciphertext_size = file_size - MAGIC.length() - sizeof(VERSION) - SALT_SIZE - IV_SIZE - TAG_SIZE;
        
        if (ciphertext_size == 0) {
            return "";
        }

        file.seekg(MAGIC.length() + sizeof(VERSION) + SALT_SIZE + IV_SIZE);
        std::vector<uint8_t> ciphertext(ciphertext_size);
        file.read(reinterpret_cast<char*>(ciphertext.data()), ciphertext_size);

        std::vector<uint8_t> tag(TAG_SIZE);
        file.read(reinterpret_cast<char*>(tag.data()), tag.size());

        auto key = deriveKey(password, salt);
        if (key.empty()) {
            return "";
        }

        EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
        if (!ctx) {
            OPENSSL_cleanse(key.data(), key.size());
            return "";
        }

        if (EVP_DecryptInit_ex(ctx, EVP_aes_256_gcm(), nullptr, nullptr, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return "";
        }

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, IV_SIZE, nullptr) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return "";
        }

        if (EVP_DecryptInit_ex(ctx, nullptr, nullptr, key.data(), iv.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return "";
        }

        std::vector<uint8_t> plaintext(ciphertext.size());
        int len = 0;

        if (EVP_DecryptUpdate(ctx, plaintext.data(), &len, ciphertext.data(), 
                             static_cast<int>(ciphertext.size())) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return "";
        }

        int plaintext_len = len;

        if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_TAG, TAG_SIZE, tag.data()) != 1) {
            EVP_CIPHER_CTX_free(ctx);
            OPENSSL_cleanse(key.data(), key.size());
            return "";
        }

        int ret = EVP_DecryptFinal_ex(ctx, plaintext.data() + len, &len);
        EVP_CIPHER_CTX_free(ctx);
        OPENSSL_cleanse(key.data(), key.size());

        if (ret <= 0) {
            return "";
        }

        plaintext_len += len;
        return std::string(reinterpret_cast<char*>(plaintext.data()), plaintext_len);
    }
};

const std::string SecureDataStorage::MAGIC = "ENC1";

int main() {
    SecureDataStorage storage;

    // Test case 1: Basic credit card storage
    std::string cc1 = "4532-1234-5678-9012";
    std::string pass1 = "SecurePass123!";
    bool result1 = storage.encryptAndStore(cc1, pass1, "cc1.enc");
    std::string decrypted1 = storage.decryptAndLoad(pass1, "cc1.enc");
    std::cout << "Test 1: " << (result1 && decrypted1 == cc1 ? "PASS" : "FAIL") << std::endl;

    // Test case 2: Personal information storage
    std::string personal = "John Doe|SSN:123-45-6789|DOB:1990-01-01";
    std::string pass2 = "MyVerySecurePassword456@";
    bool result2 = storage.encryptAndStore(personal, pass2, "personal.enc");
    std::string decrypted2 = storage.decryptAndLoad(pass2, "personal.enc");
    std::cout << "Test 2: " << (result2 && decrypted2 == personal ? "PASS" : "FAIL") << std::endl;

    // Test case 3: Wrong password test
    std::string decrypted3 = storage.decryptAndLoad("WrongPassword", "cc1.enc");
    std::cout << "Test 3: " << (decrypted3.empty() ? "PASS" : "FAIL") << std::endl;

