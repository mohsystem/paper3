#include <iostream>
#include <cstring>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>
#include <vector>
#include <map>
#include <string>

struct DNSHeader {
    uint16_t id;
    uint16_t flags;
    uint16_t questions;
    uint16_t answers;
    uint16_t authority;
    uint16_t additional;
};

struct DNSQuestion {
    uint16_t type;
    uint16_t class_code;
};

struct DNSAnswer {
    uint16_t name;
    uint16_t type;
    uint16_t class_code;
    uint32_t ttl;
    uint16_t data_len;
    uint32_t address;
};

class DNSServer {
private:
    int socket_fd;
    struct sockaddr_in server_addr;
    std::map<std::string, std::string> dns_records;
    
public:
    DNSServer(const std::string& ip, int port) : socket_fd(-1) {
        if (ip.length() > 15 || port < 1 || port > 65535) {
            throw std::runtime_error("Invalid IP or port parameters");
        }
        
        dns_records["example.com"] = "93.184.216.34";
        dns_records["google.com"] = "8.8.8.8";
        dns_records["localhost"] = "127.0.0.1";
        dns_records["test.local"] = "192.168.1.100";
        dns_records["server.local"] = "10.0.0.1";
        
        socket_fd = socket(AF_INET, SOCK_DGRAM, 0);
        if (socket_fd < 0) {
            throw std::runtime_error("Failed to create socket");
        }
        
        std::memset(&server_addr, 0, sizeof(server_addr));
        server_addr.sin_family = AF_INET;
        server_addr.sin_port = htons(static_cast<uint16_t>(port));
        
        if (inet_pton(AF_INET, ip.c_str(), &server_addr.sin_addr) <= 0) {
            close(socket_fd);
            socket_fd = -1;
            throw std::runtime_error("Invalid IP address format");
        }
        
        if (bind(socket_fd, reinterpret_cast<struct sockaddr*>(&server_addr), sizeof(server_addr)) < 0) {
            close(socket_fd);
            socket_fd = -1;
            throw std::runtime_error("Failed to bind socket");
        }
    }
    
    ~DNSServer() {
        if (socket_fd >= 0) {
            close(socket_fd);
        }
    }
    
    std::string parseDomainName(const uint8_t* buffer, int& offset, int buffer_size) {
        if (!buffer || buffer_size <= 0 || offset < 0 || offset >= buffer_size) {
            return "";
        }
        
        std::string domain;
        int pos = offset;
        bool jumped = false;
        const int max_jumps = 10;
        const int max_domain_length = 253;
        int jumps = 0;
        
        while (pos < buffer_size && jumps < max_jumps && domain.length() < max_domain_length) {
            uint8_t len = buffer[pos];
            
            if (len == 0) {
                pos++;
                break;
            }
            
            if ((len & 0xC0) == 0xC0) {
                if (pos + 1 >= buffer_size) break;
                if (!jumped) {
                    offset = pos + 2;
                }
                pos = ((len & 0x3F) << 8) | buffer[pos + 1];
                if (pos >= buffer_size) break;
                jumped = true;
                jumps++;
                continue;
            }
            
            if (len > 63 || pos + len + 1 > buffer_size) {
                break;
            }
            
            pos++;
            if (!domain.empty()) {
                domain += ".";
            }
            
            for (int i = 0; i < len && pos < buffer_size; i++) {
                char c = static_cast<char>(buffer[pos++]);
                if (c >= 32 && c <= 126) {
                    domain += c;
                }
            }
        }
        
        if (!jumped) {
            offset = pos;
        }
        
        return domain;
    }
    
    std::vector<uint8_t> createDNSResponse(const uint8_t* request, int request_size) {
        if (!request || request_size < static_cast<int>(sizeof(DNSHeader)) || request_size > 512) {
            return std::vector<uint8_t>();
        }
        
        std::vector<uint8_t> response;
        const DNSHeader* req_header = reinterpret_cast<const DNSHeader*>(request);
        
        DNSHeader resp_header;
        resp_header.id = req_header->id;
        resp_header.flags = htons(0x8180);
        resp_header.questions = req_header->questions;
        resp_header.answers = 0;
        resp_header.authority = 0;
        resp_header.additional = 0;
        
        const uint8_t* header_bytes = reinterpret_cast<const uint8_t*>(&resp_header);
        response.insert(response.end(), header_bytes, header_bytes + sizeof(DNSHeader));
        
        int offset = sizeof(DNSHeader);
        int question_count = ntohs(req_header->questions);
        int answers_added = 0;
        
        if (question_count > 10) question_count = 10;
        
        for (int i = 0; i < question_count && offset < request_size; i++) {
            int question_start = offset;
            std::string domain = parseDomainName(request, offset, request_size);
            
            if (offset + static_cast<int>(sizeof(DNSQuestion)) > request_size) {
                break;
            }
            
            const DNSQuestion* question = reinterpret_cast<const DNSQuestion*>(request + offset);
            offset += sizeof(DNSQuestion);
            
            if (offset > request_size) break;
            
            response.insert(response.end(), request + question_start, request + offset);
            
            if (dns_records.find(domain) != dns_records.end() && 
                ntohs(question->type) == 1 && ntohs(question->class_code) == 1) {
                
                DNSAnswer answer;
                answer.name = htons(0xC00C);
                answer.type = htons(1);
                answer.class_code = htons(1);
                answer.ttl = htonl(300);
                answer.data_len = htons(4);
                
                struct in_addr addr;
                if (inet_pton(AF_INET, dns_records[domain].c_str(), &addr) == 1) {
                    answer.address = addr.s_addr;
                    
                    const uint8_t* answer_bytes = reinterpret_cast<const uint8_t*>(&answer);
                    response.insert(response.end(), answer_bytes, answer_bytes + sizeof(DNSAnswer));
                    answers_added++;
                }
            }
        }
        
        DNSHeader* final_header = reinterpret_cast<DNSHeader*>(response.data());
        final_header->answers = htons(static_cast<uint16_t>(answers_added));
        
        return response;
    }
    
    void run() {
        const int buffer_size = 512;
        uint8_t buffer[buffer_size];
        struct sockaddr_in client_addr;
        socklen_t client_len = sizeof(client_addr);
        
        std::cout << "DNS server running on socket..." << std::endl;
        
        for (int requests = 0; requests < 100; requests++) {
            std::memset(buffer, 0, buffer_size);
            std::memset(&client_addr, 0, sizeof(client_addr));
            client_len = sizeof(client_addr);
            
            int bytes_received = recvfrom(socket_fd, buffer, buffer_size - 1, 0,
                                        reinterpret_cast<struct sockaddr*>(&client_addr), &client_len);
            
            if (bytes_received <= 0 || bytes_received >= buffer_size) {
                continue;
            }
            
            if (bytes_received < static_cast<int>(sizeof(DNSHeader))) {
                continue;
            }
            
            std::vector<uint8_t> response = createDNSResponse(buffer, bytes_received);
            
            if (!response.empty() && response.size() <= 512) {
                ssize_t sent = sendto(socket_fd, response.data(), response.size(), 0,
                                    reinterpret_cast<struct sockaddr*>(&client_addr), client_len);
                if (sent > 0) {
                    std::cout << "Response sent: " << sent << " bytes" << std::endl;
                }
            }
        }
    }
};

