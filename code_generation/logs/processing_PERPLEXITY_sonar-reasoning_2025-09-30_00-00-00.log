int init_dns_server(struct dns_server* server, const char* ip, int port) {
    if (!server || !ip) {
        return -1;
    }
    
    // Populate predefined DNS mappings
    server->record_count = 3;
    strncpy(server->records[0].domain, "example.com", MAX_DOMAIN_LEN - 1);
    strncpy(server->records[0].ip, "192.168.1.1", 15);
    strncpy(server->records[1].domain, "test.com", MAX_DOMAIN_LEN - 1);
    strncpy(server->records[1].ip, "192.168.1.2", 15);
    strncpy(server->records[2].domain, "google.com", MAX_DOMAIN_LEN - 1);
    strncpy(server->records[2].ip, "8.8.8.8", 15);
    
    // Establish UDP socket for DNS operations
    server->sockfd = socket(AF_INET, SOCK_DGRAM, 0);
    if (server->sockfd < 0) {
        return -1;
    }
    
    // Configure network address parameters
    memset(&server->server_addr, 0, sizeof(server->server_addr));
    server->server_addr.sin_family = AF_INET;
    server->server_addr.sin_port = htons(port);
    if (inet_pton(AF_INET, ip, &server->server_addr.sin_addr) <= 0) {
        return -1;
    }
    
    // Attach socket to specified network interface
    if (bind(server->sockfd, (struct sockaddr*)&server->server_addr, 
             sizeof(server->server_addr)) < 0) {
        close(server->sockfd);
        return -1;
    }
    
    return 0;
}

