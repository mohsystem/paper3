```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>
#include <regex.h>

#define MAX_INPUT_LENGTH 1000
#define BUFFER_SIZE 4096
#define MAX_RESPONSE_SIZE 8192

typedef struct {
    regex_t valid_pattern;
} WebFormApp;

int init_app(WebFormApp* app) {
    return regcomp(&app->valid_pattern, "^[a-zA-Z0-9 .,!?-]*$", REG_EXTENDED);
}

void cleanup_app(WebFormApp* app) {
    regfree(&app->valid_pattern);
}

void html_escape(const char* input, char* output, size_t output_size) {
    size_t i = 0, j = 0;
    while (input[i] && j < output_size - 10) {
        switch (input[i]) {
            case '&':
                if (j + 5 < output_size) {
                    strcpy(output + j, "&amp;");
                    j += 5;
                }
                break;
            case '<':
                if (j + 4 < output_size) {
                    strcpy(output + j, "&lt;");
                    j += 4;
                }
                break;
            case '>':
                if (j + 4 < output_size) {
                    strcpy(output + j, "&gt;");
                    j += 4;
                }
                break;
            case '"':
                if (j + 6 < output_size) {
                    strcpy(output + j, "&quot;");
                    j += 6;
                }
                break;
            case '\'':
                if (j + 6 < output_size) {
                    strcpy(output + j, "&#x27;");
                    j += 6;
                }
                break;
            default:
                output[j++] = input[i];
                break;
        }
        i++;
    }
    output[j] = '\0';
}

int sanitize_input(WebFormApp* app, const char* input, char* output, size_t output_size) {
    if (!input || strlen(input) > MAX_INPUT_LENGTH) {
        output[0] = '\0';
        return 0;
    }
    
    if (regexec(&app->valid_pattern, input, 0, NULL, 0) != 0) {
        output[0] = '\0';
        return 0;
    }
    
    html_escape(input, output, output_size);
    return 1;
}

