#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/kdf.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>

#define SALT_SIZE 16
#define IV_SIZE 12
#define TAG_SIZE 16
#define KEY_SIZE 32
#define PBKDF2_ITERATIONS 210000
#define MAGIC "ENC1"
#define VERSION 1

typedef struct {
    unsigned char* data;
    size_t size;
} Buffer;

static void buffer_free(Buffer* buf) {
    if (buf && buf->data) {
        OPENSSL_cleanse(buf->data, buf->size);
        free(buf->data);
        buf->data = NULL;
        buf->size = 0;
    }
}

static int derive_key(const char* password, const unsigned char* salt, unsigned char* key) {
    if (!password || !salt || !key) return 0;
    
    EVP_KDF* kdf = EVP_KDF_fetch(NULL, "PBKDF2", NULL);
    if (!kdf) return 0;
    
    EVP_KDF_CTX* ctx = EVP_KDF_CTX_new(kdf);
    if (!ctx) {
        EVP_KDF_free(kdf);
        return 0;
    }

    size_t password_len = strlen(password);
    OSSL_PARAM params[] = {
        OSSL_PARAM_construct_utf8_string("pass", (char*)password, password_len),
        OSSL_PARAM_construct_octet_string("salt", (unsigned char*)salt, SALT_SIZE),
        OSSL_PARAM_construct_int("iter", (int*)&PBKDF2_ITERATIONS),
        OSSL_PARAM_construct_utf8_string("digest", "SHA256", 0),
        OSSL_PARAM_construct_end()
    };

    int ret = EVP_KDF_derive(ctx, key, KEY_SIZE, params);
    EVP_KDF_CTX_free(ctx);
    EVP_KDF_free(kdf);
    
    return ret == 1;
}

static Buffer read_file(const char* filename) {
    Buffer buf = {NULL, 0};
    if (!filename) return buf;
    
    FILE* file = fopen(filename, "rb");
    if (!file) return buf;
    
    if (fseek(file, 0, SEEK_END) != 0) {
        fclose(file);
        return buf;
    }
    
    long file_size = ftell(file);
    if (file_size < 0) {
        fclose(file);
        return buf;
    }
    
    if (fseek(file, 0, SEEK_SET) != 0) {
        fclose(file);
        return buf;
    }
    
    buf.data = malloc(file_size);
    if (!buf.data) {
        fclose(file);
        return buf;
    }
    
    size_t bytes_read = fread(buf.data, 1, file_size, file);
    fclose(file);
    
    if (bytes_read != (size_t)file_size) {
        free(buf.data);
        buf.data = NULL;
        return buf;
    }
    
    buf.size = bytes_read;
    return buf;
}

static int write_file(const char* filename, const unsigned char* data, size_t size) {
    if (!filename || !data) return 0;
    
    FILE* file = fopen(filename, "wb");
    if (!file) return 0;
    
    size_t written = fwrite(data, 1, size, file);
    int result = (written == size) && (fclose(file) == 0);
    
    return result;
}

int encrypt_file(const char* input_path, const char* output_path, const char* password) {
    if (!input_path || !output_path || !password || strlen(password) == 0) return 0;
    
    Buffer plaintext = read_file(input_path);
    if (!plaintext.data) return 0;
    
    unsigned char salt[SALT_SIZE];
    unsigned char iv[IV_SIZE];
    unsigned char key[KEY_SIZE];
    
    if (RAND_bytes(salt, SALT_SIZE) != 1 || RAND_bytes(iv, IV_SIZE) != 1) {
        buffer_free(&plaintext);
        return 0;
    }
    
    if (!derive_key(password, salt, key)) {
        buffer_free(&plaintext);
        OPENSSL_cleanse(key, KEY_SIZE);
        return 0;
    }
    
    EVP_CIPHER_CTX* ctx = EVP_CIPHER_CTX_new();
    if (!ctx) {
        buffer_free(&plaintext);
        OPENSSL_cleanse(key, KEY_SIZE);
        return 0;
    }
    
    if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), NULL, NULL, NULL) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        buffer_free(&plaintext);
        OPENSSL_cleanse(key, KEY_SIZE);
        return 0;
    }
    
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, IV_SIZE, NULL) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        buffer_free(&plaintext);
        OPENSSL_cleanse(key, KEY_SIZE);
        return 0;
    }
    
    if (EVP_EncryptInit_ex(ctx, NULL, NULL, key, iv) != 1) {
        EVP_CIPHER_CTX_free(ctx);
        buffer_free(&plaintext);
        OPENSSL_cleanse(key, KEY_SIZE);
        return 0;
    }
    
    unsigned char* ciphertext = malloc(plaintext.size);
    if (!ciphertext) {
        EVP_CIPHER_CTX_free(ctx);
        buffer_free(&plaintext);
        OPENSSL_cleanse(key, KEY_SIZE);
        return 0;
