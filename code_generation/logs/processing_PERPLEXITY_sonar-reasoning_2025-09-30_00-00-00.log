#include <iostream>
#include <string>
#include <thread>
#include <chrono>
#include <stdexcept>
#include <xmlrpc-c/base.hpp>
#include <xmlrpc-c/registry.hpp>
#include <xmlrpc-c/server_abyss.hpp>
#include <xmlrpc-c/client_simple.hpp>

class EchoMethod : public xmlrpc_c::method {
public:
    EchoMethod() {
        this->_signature = "s:s";
        this->_help = "Echo method that returns the input string";
    }
    
    void execute(xmlrpc_c::paramList const& paramList, xmlrpc_c::value* const retvalP) {
        try {
            if (paramList.size() != 1) {
                throw xmlrpc_c::fault("Invalid parameter count", 400);
            }
            
            std::string const input = paramList.getString(0);
            
            // Input validation
            if (input.length() > 1000) {
                throw xmlrpc_c::fault("Input string too long", 400);
            }
            
            // Sanitize input - remove control characters
            std::string sanitized;
            sanitized.reserve(input.length());
            for (char c : input) {
                if (c >= 32 && c <= 126) {
                    sanitized += c;
                }
            }
            
            *retvalP = xmlrpc_c::value_string("Echo: " + sanitized);
        } catch (std::exception const& e) {
            throw xmlrpc_c::fault(e.what(), 500);
        }
    }
};

class AddMethod : public xmlrpc_c::method {
public:
    AddMethod() {
        this->_signature = "i:ii";
        this->_help = "Add two integers";
    }
    
    void execute(xmlrpc_c::paramList const& paramList, xmlrpc_c::value* const retvalP) {
        try {
            if (paramList.size() != 2) {
                throw xmlrpc_c::fault("Invalid parameter count", 400);
            }
            
            int const a = paramList.getInt(0);
            int const b = paramList.getInt(1);
            
            // Validate input ranges to prevent overflow
            if ((b > 0 && a > INT_MAX - b) || (b < 0 && a < INT_MIN - b)) {
                throw xmlrpc_c::fault("Integer overflow", 400);
            }
            
            *retvalP = xmlrpc_c::value_int(a + b);
        } catch (std::exception const& e) {
            throw xmlrpc_c::fault(e.what(), 500);
        }
    }
};

class XMLRPCServer {
private:
    std::unique_ptr<xmlrpc_c::serverAbyss> server;
    std::unique_ptr<xmlrpc_c::registry> registry;
    
public:
    XMLRPCServer(int port) {
        try {
            registry = std::make_unique<xmlrpc_c::registry>();
            registry->addMethod("echo", std::make_unique<EchoMethod>());
            registry->addMethod("add", std::make_unique<AddMethod>());
            
            server = std::make_unique<xmlrpc_c::serverAbyss>(
                xmlrpc_c::serverAbyss::constrOpt()
                .registryP(registry.get())
                .portNumber(port)
            );
        } catch (std::exception const& e) {
            throw std::runtime_error("Failed to initialize server: " + std::string(e.what()));
        }
    }
    
    void run() {
        if (!server) {
            throw std::runtime_error("Server not initialized");
        }
        server->run();
    }
    
    void runInBackground() {
        std::thread([this]() { this->run(); }).detach();
        std::this_thread::sleep_for(std::chrono::milliseconds(100));
    }
};

bool testClient(const std::string& method, const xmlrpc_c::paramList& params, 
                const std::string& expected, const std::string& serverUrl) {
    try {
        xmlrpc_c::clientSimple client;
        xmlrpc_c::value result;
        client.call(serverUrl, method, params, &result);
        
        std::string resultStr = xmlrpc_c::value_string(result);
        return resultStr == expected;
    } catch (std::exception const& e) {
        std::cerr << "Test failed: " << e.what() << std::endl;
        return false;
    }
}

int main() {
    try {
        const int port = 8080;
        const std::string serverUrl = "http://localhost:8080/RPC2";
        
        XMLRPCServer server(port);
        server.runInBackground();
        
        std::cout << "XML-RPC Server started on port " << port << std::endl;
        
        // Test case 1: Echo simple string
        xmlrpc_c::paramList params1;
        params1.add(xmlrpc_c::value_string("hello"));
        bool test1 = testClient("echo", params1, "Echo: hello", serverUrl);
        std::cout << "Test 1 (echo simple): " << (test1 ? "PASS" : "FAIL") << std::endl;
        
        // Test case 2: Echo empty string
        xmlrpc_c::paramList params2;
        params2.add(xmlrpc_c::value_string(""));
        bool test2 = testClient("echo", params2, "Echo: ", serverUrl);
        std::cout << "Test 2 (echo empty): " << (test2 ? "PASS" : "FAIL") << std::endl;
        
        // Test case 3: Add positive numbers
        xmlrpc_c::paramList params3;
        params3.add(xmlrpc_c::value_int(5));
        params3.add(xmlrpc_c::value_int(3));
        xmlrpc_c::clientSimple client;
        xmlrpc_c::value result3;
        client.call(serverUrl, "add", params3, &result3);
        bool test3 = (xmlrpc_c::value_int(result3) == 8);
        std::cout << "Test 3 (add positive): " << (test3 ? "PASS" : "FAIL") << std::endl;
        
        // Test case 4: Add negative numbers
        xmlrpc_c::paramList params4;
        params4.add(xmlrpc_c::value_int(-10));
        params4.add(xmlrpc_c::value_int(5));
        xmlrpc_c::value result4;
        client.call(serverUrl, "add", params4, &result4);
        bool test4 = (xmlrpc_c::value_int(result4) == -5);
        std::cout << "Test 4 (add negative): " << (test4 ? "PASS" : "FAIL") << std::endl;
        
        // Test case 5: Add zero
        xmlrpc_c::paramList params5;
        params5.add(xmlrpc_c::value_int(0));
        params5.add(xmlrpc_c::value_int(42));
        xmlrpc_c::value result5;
        client.call(serverUrl, "add", params5, &result5);
        bool test5 = (xmlrpc_c::value_int(result5) == 42);
        std::cout << "Test 5 (add zero): " << (test5 ? "PASS" : "FAIL") << std::endl;
        
        std::cout << "All tests completed. Server running..." << std::endl;
        std::this_thread::sleep_for(std::chrono::seconds(2));
        
    } catch (std::exception const& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }
    
    return 0;
}
