#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <time.h>
#include <ctype.h>

#define PORT 8080
#define BUFFER_SIZE 4096
#define TOKEN_SIZE 32
#define MAX_SESSIONS 100

typedef struct {
    char session_id[33];
    char csrf_token[65];
    char username[64];
    char email[128];
    int active;
} Session;

static Session sessions[MAX_SESSIONS];
static int session_count = 0;

void generate_random_token(char *token, int length) {
    const char charset[] = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
    srand((unsigned int)time(NULL) + rand());
    
    for (int i = 0; i < length; i++) {
        int key = rand() % (sizeof(charset) - 1);
        token[i] = charset[key];
    }
    token[length] = '\0';
}

int create_session(const char *username) {
    if (session_count >= MAX_SESSIONS) return -1;
    
    Session *session = &sessions[session_count];
    generate_random_token(session->session_id, 32);
    generate_random_token(session->csrf_token, 64);
    strncpy(session->username, username, sizeof(session->username) - 1);
    session->username[sizeof(session->username) - 1] = '\0';
    strncpy(session->email, "user@example.com", sizeof(session->email) - 1);
    session->email[sizeof(session->email) - 1] = '\0';
    session->active = 1;
    
    return session_count++;
}

Session* find_session(const char *session_id) {
    for (int i = 0; i < session_count; i++) {
        if (sessions[i].active && strcmp(sessions[i].session_id, session_id) == 0) {
            return &sessions[i];
        }
    }
    return NULL;
}

int validate_csrf_token(Session *session, const char *token) {
    if (!session || !token) return 0;
    return strcmp(session->csrf_token, token) == 0;
}

void url_decode(char *dst, const char *src) {
    char *p = dst;
    char code[3];
    
    while (*src) {
        if (*src == '%') {
            memcpy(code, src + 1, 2);
            code[2] = '\0';
            *p++ = (char)strtol(code, NULL, 16);
            src += 3;
        } else if (*src == '+') {
            *p++ = ' ';
            src++;
        } else {
            *p++ = *src++;
        }
    }
    *p = '\0';
}

void extract_cookie_value(const char *headers, const char *cookie_name, char *value, int max_len) {
    char *cookie_start = strstr(headers, cookie_name);
    if (!cookie_start) {
        value[0] = '\0';
        return;
    }
    
    cookie_start += strlen(cookie_name) + 1; // Skip "cookie_name="
    char *cookie_end = strstr(cookie_start, ";");
    if (!cookie_end) cookie_end = strstr(cookie_start, "\r\n");
    if (!cookie_end) cookie_end = cookie_start + strlen(cookie_start);
    
    int len = cookie_end - cookie_start;
    if (len >= max_len) len = max_len - 1;
    
    strncpy(value, cookie_start, len);
    value[len] = '\0';
}

void send_login_form(int client_socket) {
    char response[] = 
        "HTTP/1.1 200 OK\r\n"
        "Content-Type: text/html\r\n"
        "Connection: close\r\n\r\n"
        "<!DOCTYPE html><html><head><title>Login</title></head><body>"
        "<h2>Login</h2>"
        "<form method='POST' action='/login'>"
        "Username: <input type='text' name='username' required><br><br>"
        "<input type='submit' value='Login'>"
        "</form></body></html>";
    
    send(client_socket, response, strlen(response), 0);
}

void send_settings_form(int client_socket, Session *session) {
    char response[2048];
    
    snprintf(response, sizeof(response),
        "HTTP/1.1 200 OK\r\n"
        "Content-Type: text/html\r\n"
        "Set-Cookie: session_id=%s; HttpOnly\r\n"
        "Connection: close\r\n\r\n"
        "<!DOCTYPE html><html><head><title>User Settings</title></head><body>"
        "<h2>User Settings</h2>"
        "<p>Welcome, %s!</p>"
        "<form method='POST' action='/update-settings'>"
        "<input type='hidden' name='csrf_token' value='%s'>"
        "Username: <input type='text' name='username' value='%s' required><br><br>"
        "Email: <input type='email' name='email' value='%s' required><br><br>"
        "<input type='submit' value='Update Settings'>"
        "</form>"
        "<a href='/logout'>Logout</a>"
        "</body></html>",
        session->session_id, session->username, session->csrf_token, 
        session->username, session->email);
    
    send(client_socket, response, strlen(response), 0);
}

void handle_login(int client_socket, const char *body) {
    char username[64] = {0};
    
    // Parse form data
    char *username_param = strstr(body, "username=");
    if (username_param) {
        username_param += 9; // Skip "username="
        char *end = strstr(username_param, "&");
        if (!end) end = username_param + strlen(username_param);
        
        int len = end - username_param;
        if (len >= sizeof(username)) len = sizeof(username) - 1;
        strncpy(username, username_param, len);
        username[len] = '\0';
        url_decode(username, username);
    }
    
    if (strlen(username) > 0) {
        int session_idx = create_session(username);
        if (session_idx >= 0) {
            send_settings_form(client_socket, &sessions[session_idx]);
            return;
        }
    }
    
    char error_response[] = 
        "HTTP/1.1 400 Bad Request\r\n"
        "Content-Type: text/html\r\n"
        "Connection: close\r\n\r\n"
        "<html><body><h2>Login Failed</h2><a href='/'>Try Again</a></body></html>";
    
    send(client_socket, error_response, strlen(error_response), 0);
}

void handle_update_settings(int client_socket, const char *headers, const char *body) {
    char session_id[64] = {0};
    char csrf_token[128] = {0};
    char username[64] = {0};
    char email[128] = {0};
    
    // Extract session ID from cookie
    extract_cookie_value(headers, "session_id", session_id, sizeof(session_id));
    
    Session *session = find_session(session_id);
    if (!session) {
        char error_response[] = 
            "HTTP/1.1 401 Unauthorized\r\n"
            "Content-Type: text/html\r\n"
            "Connection: close\r\n\r\n"
            "<html><body><h2>Unauthorized</h2><a href='/'>Login</a></body></html>";
        send(client_socket, error_response, strlen(error_response), 0);
        return;
    }
    
    // Parse form data
    char *token_param = strstr(body, "csrf_token=");
    if (token_param) {
        token_param += 11; // Skip "csrf_token="
        char *end = strstr(token_param, "&");
        if (!end) end = token_param + strlen(token_param);
        
        int len = end - token_param;
        if (len >= sizeof(csrf_token)) len = sizeof(csrf_token) - 1;
        strncpy(csrf_token, token_param, len);
        csrf_token[len] = '\0';
        url_decode(csrf_token, csrf_token);
    }
    
    // Validate CSRF token
    if (!validate_csrf_token(session, csrf_token)) {
        char error_response[] = 
            "HTTP/1.1 403 Forbidden\r\n"
            "Content-Type: text/html\r\n"
            "Connection: close\r\n\r\n"
            "<html><body><h2>CSRF Token Invalid</h2><a href='/settings'>Back</a></body></html>";
        send(client_socket, error_response, strlen(error_response), 0);
        return;
    }
    
    // Parse username and email
    char *username_param = strstr(body, "username=");
    if (username_param) {
        username_param += 9;
        char *end = strstr(username_param, "&");
        if (!end) end = username_param + strlen(username_param);
        
        int len = end - username_param;
        if (len >= sizeof(username)) len = sizeof(username) - 1;
        strncpy(username, username_param, len);
        username[len] = '\0';
        url_decode(username, username);
    }
    
    char *email_param = strstr(body, "email=");
    if (email_param) {
        email_param += 6;
        char *end = strstr(email_param, "&");
        if (!end) end = email_param + strlen(email_param);
        
        int len = end - email_param;
        if (len >= sizeof(email)) len = sizeof(email) - 1;
        strncpy(email, email_param, len);
        email[len] = '\0';
        url_decode(email, email);
    }
    
    // Update session data
    if (strlen(username) > 0 && strlen(email) > 0) {
        strncpy(session->username, username, sizeof(session->username) - 1);
        session->username[sizeof(session->username) - 1] = '\0';
        strncpy(session->email, email, sizeof(session->email) - 1);
        session->email[sizeof(session->email) - 1] = '\0';
        
        // Generate new CSRF token after successful update
        generate_random_token(session->csrf_token, 64);
        
        char success_response[1024];
        snprintf(success_response, sizeof(success_response),
            "HTTP/1.1 200 OK\r\n"
            "Content-Type: text/html\r\n"
            "Connection: close\r\n\r\n"
            "<html><body><h2>Settings Updated Successfully</h2>"
            "<p>Username: %s</p><p>Email: %s</p>"
            "<a href='/settings'>Back to Settings</a></body></html>",
            session->username, session->email);
        
        send(client_socket, success_response, strlen(success_response), 0);
    } else {
        char error_response[] = 
            "HTTP/1.1 400 Bad Request\r\n"
            "Content-Type: text/html\r\n"
            "Connection: close\r\n\r\n"
            "<html><body><h2>Invalid Input</h2><a href='/settings'>Back</a></body></html>";
        send(client_socket, error_response, strlen(error_response), 0);
    }
}

void handle_request(int client_socket) {
    char buffer[BUFFER_SIZE] = {0};
    ssize_t bytes_received = recv(client_socket, buffer, BUFFER_SIZE - 1, 0);
    
    if (bytes_received <= 0) {
        close(client_socket);
        return;
    }
    
    buffer[bytes_received] = '\0';
    
    char method[16] = {0};
    char path[256] = {0};
    sscanf(buffer, "%15s %255s", method, path);
    
    char *body = strstr(buffer, "\r\n\r\n");
    if (body) body += 4;
    else body = "";
    
    if (strcmp(method, "GET") == 0) {
        if (strcmp(path, "/") == 0 || strcmp(path, "/login") == 0) {
            send_login_form(client_socket);
        } else if (strcmp(path, "/settings") == 0) {
            char session_id[64] = {0};
            extract_cookie_value(buffer, "session_id", session_id, sizeof(session_id));
            Session *session = find_session(session_id);
            
            if (session) {
                send_settings_form(client_socket, session);
            } else {
                send_login_form(client_socket);
            }
        } else {
            char not_found[] = 
                "HTTP/1.1 404 Not Found\r\n"
                "Content-Type: text/html\r\n"
                "Connection: close\r\n\r\n"
                "<html><body><h2>404 Not Found</h2></body></html>";
            send(client_socket, not_found, strlen(not_found), 0);
        }
    } else if (strcmp(method, "POST") == 0) {
        if (strcmp(path, "/login") == 0) {
            handle_login(client_socket, body);
        } else if (strcmp(path, "/update-settings") == 0) {
            handle_update_settings(client_socket, buffer, body);
        }
    }
    
    close(client_socket);
}

int main() {
    int server_fd, client_socket;
    struct sockaddr_in address;
    int opt = 1;
    int addrlen = sizeof(address);
    
    // Test cases
    printf("Running CSRF protection tests...\n");
    
    // Test 1: Token generation
    char token1[65], token2[65];
    generate_random_token(token1, 64);
    generate_random_token(token2, 64);
    printf("Test 1 - Token generation: %s\n", 
           (strlen(token1) == 64 && strcmp(token1, token2) != 0) ? "PASS" : "FAIL");
    
    // Test 2: Session creation
    int session_idx = create_session("testuser");
    printf("Test 2 - Session creation: %s\n", 
           (session_idx >= 0 && strlen(sessions[session_idx].csrf_token) == 64) ? "PASS" : "FAIL");
    
    // Test 3: Session lookup
    Session *found_session = find_session(sessions[session_idx].session_id);
    printf("Test 3 - Session lookup: %s\n", 
           (found_session && strcmp(found_session->username, "testuser") == 0) ? "PASS" : "FAIL");
    
    // Test 4: CSRF token validation (valid)
    int valid_token = validate_csrf_token(found_session, found_session->csrf_token);
    printf("Test 4 - Valid CSRF token: %s\n", valid_token ? "PASS" : "FAIL");
    
    // Test 5: CSRF token validation (invalid)
    int invalid_token = validate_csrf_token(found_session, "invalid_token");
    printf("Test 5 - Invalid CSRF token: %s\n", !invalid_token ? "PASS" : "FAIL");
    
    printf("\nStarting web server on port %d...\n", PORT);
    
    if ((server_fd = socket(AF_INET, SOCK_STREAM, 0)) == 0) {
        perror("socket failed");
        exit(EXIT_FAILURE);
    }
    
    if (setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR | SO_REUSEPORT, &opt, sizeof(opt))) {
        perror("setsockopt");
        exit(EXIT_FAILURE);
    }
    
    address.sin_family = AF_INET;
    address.sin_addr.s_addr = INADDR_ANY;
    address.sin_port = htons(PORT);
    
    if (bind(server_fd, (struct sockaddr *)&address, sizeof(address)) < 0) {
        perror("bind failed");
        exit(EXIT_FAILURE);
    }
    
    if (listen(server_fd, 3) < 0) {
        perror("listen");
        exit(EXIT_FAILURE);
    }
    
    printf("Server listening on http://localhost:%d\n", PORT);
    printf("Visit http://localhost:%d to test the CSRF-protected form\n", PORT);
    
    while (1) {
        if ((client_socket = accept(server_fd, (struct sockaddr *)&address, (socklen_t*)&addrlen)) < 0) {
            perror("accept");
            continue;
        }
        
        handle_request(client_socket);
    }
    
    close(server_fd);
    return 0;
}
