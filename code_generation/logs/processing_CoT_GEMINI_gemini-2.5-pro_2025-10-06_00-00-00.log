        int k4 = 167;
        System.out.println("Test Case 4: " + solver.shortestSubarray(nums4, k4));

        // Test Case 5
        int[] nums5 = {-28, 81, -20, 28, -29};
        int k5 = 89;
        System.out.println("Test Case 5: " + solver.shortestSubarray(nums5, k5));
    }
}
