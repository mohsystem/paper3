    printf("\nTest Case 4: nums = [9, 9, 9, 9], k = 2\n");
    int* result4 = maxSlidingWindow(nums4, sizeof(nums4)/sizeof(int), k4, &returnSize4);
    printf("Output: ");
    printArray(result4, returnSize4);
