    runTest("Test Case 3", {'w'});
    runTest("Test Case 4", {'n','n','n','s','n','s','n','s','n','s'});
    runTest("Test Case 5", {'e','e','e','e','w','w','w','w','w','w'});
    
    return 0;
}
