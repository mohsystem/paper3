def find_nb(m):
    """
    Finds the number of cubes n such that the sum of the first n cubes equals m.
    """
    total_volume = 0
    n = 0
    while total_volume < m:
        n += 1
        total_volume += n**3
    
    return n if total_volume == m else -1

