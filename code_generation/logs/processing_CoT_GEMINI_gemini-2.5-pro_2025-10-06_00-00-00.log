    if length <= 0:
        return ""
    
    # string.ascii_letters contains 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ'
    alphabet = string.ascii_letters
    return ''.join(secrets.choice(alphabet) for _ in range(length))

