    mf2.addNum(-2)
    print(f"Median: {mf2.findMedian()}") # Output: -1.5
    mf2.addNum(-3)
    print(f"Median: {mf2.findMedian()}") # Output: -2.0
    print()

    # Test Case 3: Mixed numbers and duplicates
