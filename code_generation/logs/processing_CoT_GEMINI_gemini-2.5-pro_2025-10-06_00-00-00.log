    root = insert(root, 60)
    root = insert(root, 80)
    print("Inorder traversal:", end=" ")
    inorder(root)
    print()
    print("Search for 60:", "Found" if search(root, 60) else "Not Found")
    print("Search for 90:", "Found" if search(root, 90) else "Not Found")
