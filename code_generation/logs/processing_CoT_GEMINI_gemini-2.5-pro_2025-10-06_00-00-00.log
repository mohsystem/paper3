int merge(int* nums, int* temp, int low, int mid, int high);
int mergeSort(int* nums, int* temp, int low, int high);

int reversePairs(int* nums, int numsSize) {
    if (nums == NULL || numsSize < 2) {
        return 0;
    }
    int* temp = (int*)malloc(sizeof(int) * numsSize);
    if (temp == NULL) {
        return -1; // Memory allocation failed
    }
    int count = mergeSort(nums, temp, 0, numsSize - 1);
    free(temp);
    return count;
}

int mergeSort(int* nums, int* temp, int low, int high) {
    if (low >= high) {
        return 0;
    }
    int mid = low + (high - low) / 2;
    int count = mergeSort(nums, temp, low, mid);
    count += mergeSort(nums, temp, mid + 1, high);
    count += merge(nums, temp, low, mid, high);
    return count;
}

int merge(int* nums, int* temp, int low, int mid, int high) {
    int count = 0;
    int j = mid + 1;
    for (int i = low; i <= mid; i++) {
        while (j <= high && (long long)nums[i] > 2LL * nums[j]) {
            j++;
        }
        count += (j - (mid + 1));
    }

    int i = low;
    j = mid + 1;
    int k = low;
    
    while (i <= mid && j <= high) {
        if (nums[i] <= nums[j]) {
            temp[k++] = nums[i++];
        } else {
            temp[k++] = nums[j++];
        }
    }
    
    while (i <= mid) {
        temp[k++] = nums[i++];
    }
    
    while (j <= high) {
        temp[k++] = nums[j++];
    }
    
    for (int l = low; l <= high; l++) {
        nums[l] = temp[l];
    }
    
    return count;
}

int main() {
