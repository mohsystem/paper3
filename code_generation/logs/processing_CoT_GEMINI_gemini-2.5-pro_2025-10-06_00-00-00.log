            String plaintext = testCase[0];
            String key = testCase[1];
            String encrypted = encrypt(plaintext, key);
            System.out.println("Plaintext : \"" + plaintext + "\", Key: \"" + key + "\"");
            System.out.println("Encrypted : " + encrypted);
            System.out.println("--------------------");
        }
    }
}
