    stack.pop();
    stack.pop();
    stack.pop();

    // Test Case 3: Pop from an empty stack (underflow)
    std::cout << "\n--- Test Case 3: Pop from Empty Stack ---" << std::endl;
    std::cout << "Is stack empty? " << (stack.isEmpty() ? "Yes" : "No") << std::endl;
    stack.pop(); // This should cause an underflow error

