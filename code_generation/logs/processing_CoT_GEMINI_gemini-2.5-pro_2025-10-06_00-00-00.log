        // 1. Remove all non-digit characters.
        String cleaned = phoneNumber.replaceAll("[^\\d]", "");

        // 2. Handle country code if present.
        if (cleaned.length() == 11 && cleaned.startsWith("1")) {
            return cleaned.substring(1);
        }

