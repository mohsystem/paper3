    public MountainArrayImpl(int[] arr) {
        this.arr = arr;
    }

    @Override
    public int get(int index) {
        if (index < 0 || index >= arr.length) {
            // This behavior is not specified, but good practice for a mock
            throw new IndexOutOfBoundsException();
        }
        return arr[index];
    }

    @Override
    public int length() {
        return arr.length;
    }
