    snprintf(conn_str_buffer, sizeof(conn_str_buffer), "host=%s port=%s dbname=%s user=wrong_user password=%s", HOST, PORT, DBNAME, PASSWORD);
    PGconn* conn4 = connectToPostgres(conn_str_buffer);
    if (conn4 == NULL) {
