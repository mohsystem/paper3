  </book>
  <novel id="3">
    <title lang="en">The Great Gatsby</title>
    <author>F. Scott Fitzgerald</author>
  </novel>
</bookstore>
"""
    with open(xml_file_name, "w") as f:
        f.write(xml_content)

    # Simulating command line arguments: xpath, filename
    test_cases = [
