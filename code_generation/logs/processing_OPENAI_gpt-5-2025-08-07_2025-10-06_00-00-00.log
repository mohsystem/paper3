    }
    if (r->body[0] != '\0') {
        printf("Body: %s\n", r->body);
    }
}

int main(void) {
    Response r1 = handleRequest("OPTIONS", "https://example.com", "GET", "Content-Type, X-Requested-With", "/api/data", NULL);
