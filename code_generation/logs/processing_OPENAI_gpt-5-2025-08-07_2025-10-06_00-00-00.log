double cubeDiagonal(double volume) {
    if (!isfinite(volume) || volume < 0.0) {
        return NAN;
    }
    double diag = cbrt(volume) * sqrt(3.0);
    double rounded = round(diag * 100.0) / 100.0;
    return rounded;
}

int main(void) {
    double tests[5] = {8.0, 343.0, 1157.625, 0.0, -5.0};
