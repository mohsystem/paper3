def find_missing(arr, n):
    if not isinstance(n, int) or n < 1 or arr is None or len(arr) != n - 1:
        return -1
    seen = [False] * (n + 1)
    xor_val = 0
    for i in range(1, n + 1):
        xor_val ^= i
    for v in arr:
        if not isinstance(v, int) or v < 1 or v > n:
            return -1
        if seen[v]:
            return -1
        seen[v] = True
        xor_val ^= v
    if xor_val < 1 or xor_val > n or seen[xor_val]:
        return -1
    return xor_val


