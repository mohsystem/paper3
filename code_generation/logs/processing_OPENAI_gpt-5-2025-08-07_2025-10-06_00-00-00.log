    std::cout << "Test5 Peek Empty: " << (q2.peek().has_value() ? std::to_string(*q2.peek()) : "null") << "\n";
    q2.enqueue(99);
    auto d6 = q2.dequeue();
    std::cout << "Test5 Dequeue: " << (d6.has_value() ? std::to_string(*d6) : "null") << "\n";
    auto d7 = q2.dequeue();
    std::cout << "Test5 Dequeue Empty: " << (d7.has_value() ? std::to_string(*d7) : "null") << "\n";

    return 0;
}
