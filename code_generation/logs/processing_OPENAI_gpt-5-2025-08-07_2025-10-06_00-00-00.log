class IntStack {
private:
    std::vector<int> data;

public:
    IntStack() = default;

    void push(int value) {
        data.push_back(value);
    }

    int pop() {
        if (data.empty()) {
            throw std::out_of_range("Stack underflow");
        }
        int v = data.back();
        data.pop_back();
        return v;
    }

    int peek() const {
        if (data.empty()) {
            throw std::out_of_range("Stack underflow");
        }
        return data.back();
    }

    std::size_t size() const {
        return data.size();
    }
