    adj[2].append((3, 11))
    adj[2].append((5, 2))
    adj[3].append((4, 6))
    adj[4].append((5, 9))
    _print_result(dijkstra(n, adj, s))  # 0 7 9 20 26 11

if __name__ == "__main__":
    main()
