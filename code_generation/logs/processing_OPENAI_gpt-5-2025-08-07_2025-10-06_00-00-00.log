        [],
        [1],
        [5, 3, 8, 4, 2, 7, 1, 10],
        [1, 2, 3, 4, 5],
        [-3, -1, -7, 0, 2, 2, -3],
    ]
    for t in tests:
        print(Task155.heap_sort(t))
