def merge_sorted(a, b):
    a = [] if a is None else list(a)
    b = [] if b is None else list(b)
    i = j = 0
    la, lb = len(a), len(b)
    result = []

    while i < la and j < lb:
        if a[i] <= b[j]:
            result.append(a[i])
            i += 1
        else:
            result.append(b[j])
            j += 1

    if i < la:
        result.extend(a[i:])
    if j < lb:
        result.extend(b[j:])

    return result


