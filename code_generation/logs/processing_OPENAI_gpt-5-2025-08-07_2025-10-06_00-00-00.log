    free(r2);

    // Test case 3
    int* t3 = NULL;
    size_t n3 = 0;
    int* r3 = sort_ascending(t3, 0, &n3);
    print_array(r3 ? r3 : NULL, r3 ? n3 : 0);
    free(r3);

    // Test case 4
    int t4[] = {42};
    size_t n4 = 0;
    int* r4 = sort_ascending(t4, sizeof(t4)/sizeof(t4[0]), &n4);
    print_array(r4 ? r4 : NULL, r4 ? n4 : 0);
    free(r4);

    // Test case 5
