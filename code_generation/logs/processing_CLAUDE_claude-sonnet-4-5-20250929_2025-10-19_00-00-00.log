 {\n                    // Clear sensitive data before freeing\n                    size_t len = strlen(data->rows[i].fields[j]);\n                    if (len > 0) {\n                        memset(data->rows[i].fields[j], 0, len);\n                    }\n                    free(data->rows[i].fields[j]);\n                    data->rows[i].fields[j] = NULL;\n                }\n            }\n            free(data->rows[i].fields);\n            data->rows[i].fields = NULL;\n        }\n    }\n    \n    if (data->rows != NULL) {\n        free(data->rows);\n        data->rows = NULL;\n    }\n    data->row_count = 0;\n}\n\n// Validate filename to prevent path traversal attacks\nbool validate_filename(const char* filename) {\n    if (filename == NULL) {\n        return false;\n    }\n    \n    size_t len = strlen(filename);\n    \n    // Check length bounds\n    if (len == 0 || len > MAX_FILENAME) {\n        return false;\n    }\n    \n    // Check for path traversal patterns\n    if (strstr(filename, "..") != NULL || strstr(filename, "//") != NULL) {\n        return false;\n    }\n    \n    return true;\n}\n\n// Parse a single CSV field with proper quote handling\n// Returns number of characters consumed, 0 on error\nsize_t parse_field(const char* line, size_t pos, size_t line_len, char** field) {\n    if (line == NULL || field == NULL || pos >= line_len) {\n        return 0;\n    }\n    \n    *field = NULL;\n    \n    // Allocate buffer with bounds check\n    size_t buffer_capacity = 256;\n    char* buffer = (char*)calloc(buffer_capacity + 1, 1);\n    if (buffer == NULL) {\n        return 0;\n    }\n    \n    size_t buffer_len = 0;\n    size_t start_pos = pos;\n    bool in_quotes = false;\n    \n    // Check if field starts with quote\n    if (line[pos] == '"') {\n        in_quotes = true;\n        pos++;\n    }\n    \n    while (pos < line_len) {\n        // Prevent excessive field size (DoS protection)\n        if (buffer_len >= MAX_FIELD_SIZE) {\n            free(buffer);\n            return 0;\n        }\n        \n        // Grow buffer if needed\n        if (buffer_len >= buffer_capacity) {\n            size_t new_capacity = buffer_capacity * 2;\n            if (new_capacity > MAX_FIELD_SIZE) {\n                new_capacity = MAX_FIELD_SIZE;\n            }\n            \n            char* new_buffer = (char*)realloc(buffer, new_capacity + 1);\n            if (new_buffer == NULL) {\n                free(buffer);\n                return 0;\n            }\n            buffer = new_buffer;\n            buffer_capacity = new_capacity;\n        }\n        \n        char c = line[pos];\n        \n        if (in_quotes) {\n            if (c == '"') {\n                // Check for escaped quote\n                if (pos + 1 < line_len && line[pos + 1] == '"') {\n                    buffer[buffer_len++] = '"';\n                    buffer[buffer_len] = '\\0';\n                    pos += 2;\n                } else {\n                    // End of quoted field\n                    pos++;\n                    in_quotes = false;\n                    // Skip to comma or end\n                    if (pos < line_len && line[pos] == ',') {\n                        pos++;\n                    }\n                    break;\n                }\n            } else {\n                buffer[buffer_len++] = c;\n                buffer[buffer_len] = '\\0';\n                pos++;\n            }\n        } else {\n            if (c == ',') {\n                pos++;\n                break;\n            } else {\n                buffer[buffer_len++] = c;\n                buffer[buffer_len] = '\\0';\n                pos++;\n            }\n        }\n    }\n    \n    *field = buffer;\n    return pos - start_pos;\n}\n\n// Parse a CSV line into fields with security validation\nbool parse_line(const char* line, CSVRow* row) {\n    if (line == NULL || row == NULL) {\n        return false;\n    }\n    \n    row->fields = NULL;\n    row->field_count = 0;\n    \n    size_t line_len = strlen(line);\n    \n    // Validate line length\n    if (line_len > MAX_LINE_LENGTH) {\n        return false;\n    }\n    \n    // Allocate initial field array\n    size_t field_capacity = 16;\n    char** fields = (char**)calloc(field_capacity, sizeof(char*));\n    if (fields == NULL) {\n        return false;\n    }\n    \n    size_t pos = 0;\n    size_t field_count = 0;\n    \n    while (pos < line_len) {\n        // Prevent excessive field count (DoS protection)\n        if (field_count >= MAX_FIELDS) {\n            for (size_t i = 0; i < field_count; i++) {\n                if (fields[i] != NULL) {\n                    free(fields[i]);\n                }\n            }\n            free(fields);\n            return false;\n        }\n        \n        // Grow field array if needed\n        if (field_count >= field_capacity) {\n            size_t new_capacity = field_capacity * 2;\n            if (new_capacity > MAX_FIELDS) {\n                new_capacity = MAX_FIELDS;\n            }\n            \n            char** new_fields = (char**)realloc(fields, new_capacity * sizeof(char*));\n            if (new_fields == NULL) {\n                for (size_t i = 0; i < field_count; i++) {\n                    if (fields[i] != NULL) {\n                        free(fields[i]);\n                    }\n                }\n                free(fields);\n                return false;\n            }\n            fields = new_fields;\n            field_capacity = new_capacity;\n        }\n        \n        char* field = NULL;\n        size_t consumed = parse_field(line, pos, line_len, &field);\n        \n        if (consumed == 0 && field == NULL) {\n            for (size_t i = 0; i < field_count; i++) {\n                if (fields[i] != NULL) {\n                    free(fields[i]);\n                }\n            }\n            free(fields);\n            return false;\n        }\n        \n        fields[field_count++] = field;\n        pos += consumed;\n    }\n    \n    row->fields = fields;\n    row->field_count = field_count;\n    return true;\n}\n\n// Parse entire CSV file with security checks\nbool parse_csv_file(const char* filename, CSVData* data) {\n    if (filename == NULL || data == NULL) {\n        return false;\n    }\n    \n    csv_data_init(data);\n    \n    // Validate filename to prevent path traversal\n    if (!validate_filename(filename)) {\n        fprintf(stderr, "Invalid filename\\n");\n        return false;\n    }\n    \n    // Open file in binary mode and check size\n    FILE* file = fopen(filename, "rb");\n    if (file == NULL) {\n        fprintf(stderr, "Cannot open file: %s\\n", filename);\n        return false;\n    }\n    \n    // Check file size to prevent DoS\n    if (fseek(file, 0, SEEK_END) != 0) {\n        fclose(file);\n        return false;\n    }\n    \n    long file_size = ftell(file);\n    if (file_size < 0 || (size_t)file_size > MAX_FILE_SIZE) {\n        fprintf(stderr, "File size exceeds maximum allowed size\\n");\n        fclose(file);\n        return false;\n    }\n    \n    if (fseek(file, 0, SEEK_SET) != 0) {\n        fclose(file);\n        return false;\n    }\n    \n    // Allocate buffer for reading lines\n    char* line_buffer = (char*)calloc(MAX_LINE_LENGTH + 1, 1);\n    if (line_buffer == NULL) {\n        fclose(file);\n        return false;\n    }\n    \n    // Allocate initial row array\n    size_t row_capacity = 16;\n    CSVRow* rows = (CSVRow*)calloc(row_capacity, sizeof(CSVRow));\n    if (rows == NULL) {\n        free(line_buffer);\n        fclose(file);\n        return false;\n    }\n    \n    size_t row_count = 0;\n    \n    // Read and parse lines\n    while (fgets(line_buffer, MAX_LINE_LENGTH, file) != NULL) {\n        // Prevent excessive line count (DoS protection)\n        if (row_count >= MAX_LINES) {\n            fprintf(stderr, "File exceeds maximum line count\\n");\n            break;\n        }\n        \n        size_t len = strlen(line_buffer);\n        \n        // Remove trailing newline and carriage return\n        while (len > 0 && (line_buffer[len - 1] == '\\n' || line_buffer[len - 1] == '\\r')) {\n            line_buffer[--len] = '\\0';\n        }\n        \n        // Skip empty lines\n        if (len == 0) {\n            continue;\n        }\n        \n        // Grow row array if needed\n        if (row_count >= row_capacity) {\n            size_t new_capacity = row_capacity * 2;\n            if (new_capacity > MAX_LINES) {\n                new_capacity = MAX_LINES;\n            }\n            \n            CSVRow* new_rows = (CSVRow*)realloc(rows, new_capacity * sizeof(CSVRow));\n            if (new_rows == NULL) {\n                break;\n            }\n            rows = new_rows;\n            row_capacity = new_capacity;\n        }\n        \n        CSVRow row;\n        if (!parse_line(line_buffer, &row)) {\n            fprintf(stderr, "Failed to parse line %zu\\n", row_count + 1);\n            break;\n        }\n        \n        rows[row_count++] = row;\n    }\n    \n    // Clear line buffer before freeing\n    memset(line_buffer, 0, MAX_LINE_LENGTH + 1);\n    free(line_buffer);\n    fclose(file);\n    \n    data->rows = rows;\n    data->row_count = row_count;\n    \n    return row_count > 0;\n}\n\n// Display CSV data safely (no format string vulnerabilities)\nvoid display_csv_data(const CSVData* data) {\n    if (data == NULL) {\n        return;\n    }\n    \n    for (size_t i = 0; i < data->row_count; i++) {\n        printf("Row %zu: ", i);\n        for (size_t j = 0; j < data->rows[i].field_count; j++) {\n            printf("[%s]", data->rows[i].fields[j] != NULL ? data->rows[i].fields[j] : "");\n            if (j < data->rows[i].field_count - 1) {\n                printf(", ");\n            }\n        }\n        printf("\\n");\n    }\n}\n\nint main(void) {\n    // Test case 1: Simple CSV\n    {\n        FILE* out = fopen("test1.csv", "w");\n        if (out != NULL) {\n            fprintf(out, "name,age,city\\n");\n            fprintf(out, "John,30,NYC\\n");\n            fprintf(out, "Jane,25,LA\\n");\n            fclose(out);\n            \n            CSVData data;\n            if (parse_csv_file("test1.csv", &data)) {\n                printf("Test 1 - Simple CSV:\\n");\n                display_csv_data(&data);\n                csv_data_free(&data);\n            }\n        }\n    }\n    \n    // Test case 2: CSV with quoted fields\n    {\n        FILE* out = fopen("test2.csv", "w");\n        if (out != NULL) {\n            fprintf(out, "name,description\\n");\n            fprintf(out, "\\"Smith, John\\",\\"A \\"\\"great\\"\\" person\\"\\n");\n            fclose(out);\n            \n            CSVData data;\n            if (parse_csv_file("test2.csv", &data)) {\n                printf("\\nTest 2 - Quoted fields:\\n");\n                display_csv_data(&data);\n                csv_data_free(&data);\n            }\n        }\n    }\n    \n    // Test case 3: CSV with empty fields\n    {\n        FILE* out = fopen("test3.csv", "w");\n        if (out != NULL) {\n            fprintf(out, "a,b,c\\n");\n            fprintf(out, "1,,3\\n");\n            fprintf(out, ",2,\\n");\n            fclose(out);\n            \n            CSVData data;\n            if (parse_csv_file("test3.csv", &data)) {\n                printf("\\nTest 3 - Empty fields:\\n");\n                display_csv_data(&data);\n                csv_data_free(&data);\n            }\n        }\n    }\n    \n    // Test case 4: Invalid filename (path traversal attempt)\n    {\n        CSVData data;\n        printf("\\nTest 4 - Invalid path:\\n");\n        if (!parse_csv_file("../../../etc/passwd", &data)) {\n            printf("Correctly rejected invalid path\\n");\n        }\n    }\n    \n    // Test case 5: Non-existent file\n    {\n        CSVData data;\n        printf("\\nTest 5 - Non-existent file:\\n");\n        if (!parse_csv_file("nonexistent.csv", &data)) {\n            printf("Correctly han