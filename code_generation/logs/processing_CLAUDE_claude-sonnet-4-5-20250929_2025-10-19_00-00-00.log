hoSubstrings(test2));\n    \n    // Test case 3\n    const char* test3 = "aa";\n    printf("Test 3: %d (Expected: 1)\\n", distinctEchoSubstrings(test3));\n    \n    // Test case 4\n    const char* test4 = "aaaa";\n    printf("Test 4: %d (Expected: 2)\\n", distinctEchoSubstrings(test4));\n    \n    // Test case 5\n    const char* test5 = "abcd";\n    printf("Test 5: %d (Expected: 0)\\n", distinctEchoSubstrings(test5));\n    \n    return 0;\n}\n```', type='text')
