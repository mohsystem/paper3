2025-10-19 02:13:35,089 INFO TextBlock(citations=None, text='```cpp\n#include <string>\n#include <unordered_set>\n#include <cstring>\n#include <iostream>\n\n// Check if a substring can be written as concatenation of a string with itself\n// Security: Validates input bounds and uses safe string operations\nbool canBeSelfConcatenation(const std::string& text, int start, int len) {\n    // Input validation: ensure indices are within bounds\n    if (start < 0 || len <= 0 || start + len > static_cast<int>(text.length())) {\n        return false;\n    }\n    \n    // A string can be self-concatenation only if length is even\n    if (len % 2 != 0) {\n        return false;\n    }\n    \n    int halfLen = len / 2;\n    \n    // Compare first half with second half\n    // Security: Loop bounds are validated to prevent buffer overflow\n    for (int i = 0; i < halfLen; ++i) {\n        if (text[start + i] != text[start + halfLen + i]) {\n            return false;\n        }\n    }\n    \n    return true;\n}\n\nint distinctEchoSubstrings(const std::string& text) {\n    // Input validation: check constraints\n    if (text.empty() || text.length() > 2000) {\n        return 0;\n    }\n    \n    // Validate that text contains only lowercase English letters\n    for (char c : text) {\n        if (c < 'a' || c > 'z') {\n            return 0;\n        }\n    }\n    \n    std::unordered_set<std::string> distinctSubstrings;\n    int n = static_cast<int>(text.length());\n    \n    // Iterate through all possible substrings\n    // Security: Bounds are carefully validated to prevent out-of-bounds access\n    for (int start = 0; start < n; ++start) {\n        // Only consider even-length substrings (minimum length 2)\n        for (int len = 2; start + len <= n; len += 2) {\n            if (canBeSelfConcatenation(text, start, len)) {\n                // Extract substring safely\n                std::string sub = text.substr(start, len);\n                distinctSubstrings.insert(sub);\n            }\n        }\n    }\n    \n    return static_cast<int>(distinctSubstrings.size());\n}\n\nint main() {\n    // Test case 1\n    std::string test1 = "abcabcabc";\n    std::cout << "Test 1: " << distinctEchoSubstrings(test1) << " (Expected: 3)" << std::endl;\n    \n    // Test case 2\n    std::string test2 = "leetcodeleetcode";\n    std::cout << "Test 2: " << distinctEchoSubstrings(test2) << " (Expected: 2)" << std::endl;\n    \n    // Test case 3\n    std::string test3 = "aa";\n    std::cout << "Test 3: " << distinctEchoSubstrings(test3) << " (Expected: 1)" << std::endl;\n    \n    // Test case 4\n    std::string test4 = "aaaa";\n    std::cout << "Test 4: " << distinctEchoSubstrings(test4) << " (Expected: 2)" << std::endl;\n    \n    // Test case 5\n    std::string test5 = "abcd";\n    std::cout << "Test 5: " << distinctEchoSubstrings(test5) << " (Expected: 0)" << std::endl;\n    \n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <string.h>\n#include <stdbool.h>\n#include <stdlib.h>\n\n#define MAX_TEXT_LEN 2000\n#define MAX_SUBSTRINGS 4000000\n\n// Structure to store unique substrings using a simple hash set approach\ntypedef struct {\n    char** strings;\n    int count;\n    int capacity;\n} StringSet;\n\n// Initialize string set with bounds checking\n// Security: Validates allocation and initializes all pointers to NULL\nStringSet* createStringSet(int capacity) {\n    if (capacity <= 0 || capacity > MAX_SUBSTRINGS) {\n        return NULL;\n    }\n    \n    StringSet* set = (StringSet*)calloc(1, sizeof(StringSet));\n    if (set == NULL) {\n        return NULL;\n    }\n    \n    set->strings = (char**)calloc(capacity, sizeof(char*));\n    if (set->strings == NULL) {\n        free(set);\n        return NULL;\n    }\n    \n    set->count = 0;\n    set->capacity = capacity;\n    return set;\n}\n\n// Check if string exists in set\n// Security: Validates input pointers and uses safe string comparison\nbool containsString(StringSet* set, const char* str) {\n    if (set == NULL || str == NULL) {\n        return false;\n    }\n    \n    for (int i = 0; i < set->count; i++) {\n        if (set->strings[i] != NULL && strcmp(set->strings[i], str) == 0) {\n            return true;\n        }\n    }\n    return false;\n}\n\n// Add string to set if not already present\n// Security: Validates bounds, checks allocation, ensures null termination\nbool addString(StringSet* set, const char* str, int len) {\n    if (set == NULL || str == NULL || len <= 0 || len > MAX_TEXT_LEN) {\n        return false;\n    }\n    \n    if (set->count >= set->capacity) {\n        return false;\n    }\n    \n    if (containsString(set, str)) {\n        return true;\n    }\n    \n    // Allocate memory for string with null terminator\n    char* newStr = (char*)calloc(len + 1, sizeof(char));\n    if (newStr == NULL) {\n        return false;\n    }\n    \n    // Safe copy with bounds check\n    memcpy(newStr, str, len);\n    newStr[len] = '\\0';\n    \n    set->strings[set->count] = newStr;\n    set->count++;\n    return true;\n}\n\n// Free all memory allocated for string set\n// Security: Clears sensitive data and ensures proper cleanup\nvoid freeStringSet(StringSet* set) {\n    if (set == NULL) {\n        return;\n    }\n    \n    if (set->strings != NULL) {\n        for (int i = 0; i < set->count; i++) {\n            if (set->strings[i] != NULL) {\n                // Clear memory before freeing\n                memset(set->strings[i], 0, strlen(set->strings[i]));\n                free(set->strings[i]);\n                set->strings[i] = NULL;\n            }\n        }\n        free(set->strings);\n        set->strings = NULL;\n    }\n    \n    free(set);\n}\n\n// Check if substring can be self-concatenation\n// Security: Validates all bounds before array access\nbool canBeSelfConcatenation(const char* text, int textLen, int start, int len) {\n    if (text == NULL || textLen <= 0 || start < 0 || len <= 0) {\n        return false;\n    }\n    \n    if (