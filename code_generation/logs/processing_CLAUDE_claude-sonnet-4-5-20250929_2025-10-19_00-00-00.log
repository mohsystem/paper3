2025-10-19 02:39:48,990 INFO TextBlock(citations=None, text='```cpp\n#include <iostream>\n#include <vector>\n#include <algorithm>\n#include <limits>\n\n// Security: All inputs validated, boundary checks performed\n// Uses merge sort to count reverse pairs efficiently in O(n log n) time\n// Prevents integer overflow when computing 2 * nums[j]\n\nclass Solution {\nprivate:\n    // Merge two sorted subarrays and count reverse pairs\n    // Security: Validates all array bounds before access\n    int mergeAndCount(std::vector<int>& nums, int left, int mid, int right, std::vector<int>& temp) {\n        // Security: Validate input parameters to prevent out-of-bounds access\n        if (left < 0 || right >= static_cast<int>(nums.size()) || left > mid || mid >= right) {\n            return 0;\n        }\n        \n        int count = 0;\n        int j = mid + 1;\n        \n        // Count reverse pairs where i is in left half and j is in right half\n        // Security: Check bounds before array access\n        for (int i = left; i <= mid; i++) {\n            // Security: Prevent integer overflow when computing 2 * nums[j]\n            // Check if nums[j] would overflow when multiplied by 2\n            while (j <= right) {\n                // Security: Handle potential overflow in multiplication\n                // If nums[j] is negative and less than INT_MIN/2, 2*nums[j] would overflow\n                // If nums[j] is positive and greater than INT_MAX/2, 2*nums[j] would overflow\n                long long doubled = 2LL * nums[j];\n                if (nums[i] > doubled) {\n                    j++;\n                } else {\n                    break;\n                }\n            }\n            count += (j - (mid + 1));\n        }\n        \n        // Merge the two sorted halves\n        // Security: Bounds checked during merge operation\n        int i = left;\n        j = mid + 1;\n        int k = left;\n        \n        while (i <= mid && j <= right) {\n            // Security: Validate index before access\n            if (k >= static_cast<int>(temp.size())) {\n                break;\n            }\n            if (nums[i] <= nums[j]) {\n                temp[k++] = nums[i++];\n            } else {\n                temp[k++] = nums[j++];\n            }\n        }\n        \n        // Copy remaining elements\n        while (i <= mid && k < static_cast<int>(temp.size())) {\n            temp[k++] = nums[i++];\n        }\n        while (j <= right && k < static_cast<int>(temp.size())) {\n            temp[k++] = nums[j++];\n        }\n        \n        // Copy back to original array\n        // Security: Validate bounds during copy\n        for (int idx = left; idx <= right && idx < static_cast<int>(nums.size()); idx++) {\n            nums[idx] = temp[idx];\n        }\n        \n        return count;\n    }\n    \n    // Recursive merge sort with pair counting\n    // Security: Input validation and bounds checking\n    int mergeSortAndCount(std::vector<int>& nums, int left, int right, std::vector<int>& temp) {\n        // Security: Validate input bounds\n        if (left < 0 || right >= static_cast<int>(nums.size()) || left >= right) {\n            return 0;\n        }\n        \n        int mid = left + (right - left) / 2; // Security: Prevent overflow\n        int count = 0;\n        \n        // Recursively count in left and right halves\n        count += mergeSortAndCount(nums, left, mid, temp);\n        count += mergeSortAndCount(nums, mid + 1, right, temp);\n        \n        // Count reverse pairs across the two halves\n        count += mergeAndCount(nums, left, mid, right, temp);\n        \n        return count;\n    }\n    \npublic:\n    int reversePairs(std::vector<int>& nums) {\n        // Security: Validate input - check if array is empty or size within constraints\n        if (nums.empty() || nums.size() > 50000) {\n            return 0;\n        }\n        \n        // Security: Allocate temporary array with size validation\n        std::vector<int> temp(nums.size());\n        return mergeSortAndCount(nums, 0, static_cast<int>(nums.size()) - 1, temp);\n    }\n};\n\nint main() {\n    Solution solution;\n    \n    // Test case 1\n    std::vector<int> test1 = {1, 3, 2, 3, 1};\n    std::cout << "Test 1: " << solution.reversePairs(test1) << " (Expected: 2)" << std::endl;\n    \n    // Test case 2\n    std::vector<int> test2 = {2, 4, 3, 5, 1};\n    std::cout << "Test 2: " << solution.reversePairs(test2) << " (Expected: 3)" << std::endl;\n    \n    // Test case 3 - single element\n    std::vector<int> test3 = {5};\n    std::cout << "Test 3: " << solution.reversePairs(test3) << " (Expected: 0)" << std::endl;\n    \n    // Test case 4 - negative numbers\n    std::vector<int> test4 = {-5, -2, -1, -3, -4};\n    std::cout << "Test 4: " << solution.reversePairs(test4) << " (Expected: 0)" << std::endl;\n    \n    // Test case 5 - large numbers near INT_MAX\n    std::vector<int> test5 = {2147483647, 2147483647, 2147483647, 2147483647, 0};\n    std::cout << "Test 5: " << solution.reversePairs(test5) << " (Expected: 4)" << std::endl;\n    \n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <limits.h>\n#include <stdint.h>\n\n// Security: All pointers validated, memory bounds checked, proper cleanup\n// Uses merge sort to count reverse pairs efficiently\n\n// Helper function to merge and count reverse pairs\n// Security: Validates all array bounds and pointer validity before access\nint mergeAndCount(int* nums, int left, int mid, int right, int* temp, int numsSize) {\n    // Security: Validate input parameters\n    if (nums == NULL || temp == NULL || left < 0 || right >= numsSize || left > mid || mid >= right) {\n        return 0;\n    }\n    \n    int count = 0;\n    int j = mid + 1;\n    \n    // Count reverse pairs where i is in left half and j is in right half\n    for (int i = left; i <= mid; i++) {\n        // Security: Bounds check before array access\n        if (i >= numsSize) break;\n        \n        // Security: Prevent integer overflow when computing 2 * nums[j]\n        while (j <= right && j < numsSize) {\n            // Use long long to prevent overflow\n            long long doubled = 2LL * (long long)nums[j];\n            if ((long long)nums[i] > doubled) {\n                j++;\n            } else {\n                break;\n            }\n        }\n        count += (j - (mid + 1));\n    }\n    \n    // Merge the two sorted halves\n    int i = left;\n    j = mid + 1;\n    int k = left;\n    \n    // Security: Validate bounds during merge\n    while (i <= mid && j <= right && i < numsSize && j < numsSize && k < numsSize) {\n        if (nums[i] <= nums[j]) {\n            temp[k++] = nums[i++];\n        } else {\n            temp[k++] = nums[j++];\n        }\n    }\n    \n    // Copy remaining elements with bounds checking\n    while (i <= mid && i < numsSize && k < numsSize) {\n        temp[k++] = nums[i++];\n    }\n    while (j <= right && j < numsSize && k < numsSize) {\n        temp[k++] = nums[j++];\n    }\n    \n    // Copy back to original array with bounds validation\n    for (int idx = left; idx <= right && idx < numsSize; idx++) {\n        nums[idx] = temp[idx];\n    }\n    \n    return count;\n}\n\n// Recursive merge sort with pair counting\n// Security: Input validation and bounds checking throughout\nint mergeSortAndCount(int* nums, int left, int right, int* temp, int numsSize) {\n    // Security: Validate input parameters\n    if (nums == NULL || temp == NULL || left < 0 || right >= numsSize || left >= right) {\n        return 0;\n    }\n    \n    // Security: Prevent integer overflow in mid calculation\n    int mid = left + (right - left) / 2;\n    int count = 0;\n    \n    // Recursively count in left and right halves\n    count += mergeSortAndCount(nums, left, mid, temp, numsSize);\n    count += mergeSortAndCount(nums, mid + 1, right, temp, numsSize);\n    \n    // Count reverse pairs across the two halves\n    count += mergeAndCount(nums, left, mid, right, temp, numsSize);\n    \n    return count;\n}\n\n// Main function to count reverse pairs\n// Security: Full input validation and safe memory management\nint reversePairs(int* nums, int numsSize) {\n    // Security: Validate input pointer and size constraints\n    if (nums == NULL || numsSize <= 0 || numsSize > 50000) {\n        return 0;\n    }\n    \n    // Security: Allocate temporary array with size validation\n    // Check for integer overflow in allocation size\n    if (numsSize > SIZE_MAX / sizeof(int)) {\n        return 0;\n    }\n    \n    int* temp = (int*)calloc(numsSize, sizeof(int));\n    // Security: Check if memory allocation succeeded\n    if (temp == NULL) {\n        return 0;\n    }\n    \n    int result = mergeSortAndCount(nums, 0, numsSize - 1, temp, numsSize);\n    \n    // Security: Free allocated memory\n    free(temp);\n    temp = NULL;\n    \n    return result;\n}\n\nint main() {\n    // Test case 1\n    int test1[] = {1, 3, 2, 3, 1};\n    int size1 = sizeof(test1) / sizeof(test1[0]);\n    printf("Test 1: %d (Expected: 2)\\n", reversePairs(test1, size1));\n    \n    // Test case 2\n    int test2[] = {2, 4, 3, 5, 1};\n    int size2 = sizeof(test2) / sizeof(test2[0]);\n    printf("Test 2: %d (Expected: 3)\\n", reversePairs(test2, size2));\n    \n    // Test case 3 - single element\n    int test3[] = {5};\n    int size3 = sizeof(test3) / sizeof(test3[0]);\n    printf("Test 3: %d (Expected: 0)\\n", reversePairs(test3, size3));\n    \n    // Test case 4 - negative numbers\n    int test4[] = {-5, -2, -1, -3, -4};\n    int size4 = sizeof(test4) / sizeof(test4[0]);\n    printf("Test 4: %d (Expected: 0)\\n", reversePairs(test4, size4));\n    \n    // Test case 5 - large numbers near INT_MAX\n    int test5[] = {2147483647, 2147483647, 2147483647, 2147483647, 0};\n    int size5 = sizeof(test5) / sizeof(test5[0]);\n    printf("Test 5: %d (Expected: 4)\\n", reversePairs(test5, size5));\n    \n    return 0;\n}\n```', type='text')
