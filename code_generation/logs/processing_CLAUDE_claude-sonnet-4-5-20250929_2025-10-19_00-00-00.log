et callback */\n    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, writeCallback);\n    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &buffer);\n    \n    /* Security: Disable verbose mode */\n    curl_easy_setopt(curl, CURLOPT_VERBOSE, 0L);\n    \n    /* Security: Set user agent */\n    curl_easy_setopt(curl, CURLOPT_USERAGENT, "SecureClient/1.0");\n    \n    CURLcode res = curl_easy_perform(curl);\n    \n    if (res != CURLE_OK) {\n        char errorMsg[256];\n        snprintf(errorMsg, sizeof(errorMsg), "ERROR: %s", curl_easy_strerror(res));\n        *result = strdup(errorMsg);\n        freeResponseBuffer(&buffer);\n        curl_easy_cleanup(curl);\n        return 0;\n    }\n    \n    *result = buffer.data;\n    buffer.data = NULL;  /* Transfer ownership */\n    \n    freeResponseBuffer(&buffer);\n    curl_easy_cleanup(curl);\n    return 1;\n}\n\nint main(void) {\n    /* Security: Initialize CURL globally */\n    curl_global_init(CURL_GLOBAL_DEFAULT);\n    \n    /* Test cases */\n    const char* testUrls[] = {\n        "https://www.example.com",\n        "https://httpbin.org/get",\n        "http://www.example.com",   /* Should fail: not HTTPS */\n        "https://localhost/test",    /* Should fail: localhost blocked */\n        "https://192.168.1.1"        /* Should fail: private IP blocked */\n    };\n    \n    int i;\n    for (i = 0; i < 5; i++) {\n        printf("\\n=== Test Case %d ===\\n", i + 1);\n        printf("URL: %s\\n", testUrls[i]);\n        \n        /* Security: Validate URL before making request */\n        if (!validateUrl(testUrls[i])) {\n            printf("Result: REJECTED - Invalid or unsafe URL\\n");\n            continue;\n        }\n        \n        char* result = NULL;\n        if (makeHttpRequest(testUrls[i], &result)) {\n            /* Security: Truncate output to prevent excessive display */\n            if (result != NULL) {\n                if (strlen(result) > 500) {\n                    printf("Result: %.500s...\\n", result);\n        