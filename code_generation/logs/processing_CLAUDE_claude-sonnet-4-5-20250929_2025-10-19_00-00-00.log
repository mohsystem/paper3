    if (!is_path_safe(".", xml_filename, resolved_path, sizeof(resolved_path))) {\n        fprintf(stderr, "Error: Invalid or unsafe file path\\n");\n        xmlCleanupParser();\n        return 1;\n    }\n    \n    /* Read XML file securely */\n    xml_content = read_file_securely(resolved_path, &xml_size);\n    if (xml_content == NULL) {\n        xmlCleanupParser();\n        return 1;\n    }\n    \n    /* Execute XPath query */\n    result = execute_xpath_query(xml_content, xml_size, xpath_value);\n    \n    if (result != NULL && strlen(result) > 0) {\n        printf("XPath Result: %s\\n", result);\n        exit_code = 0;\n    } else {\n        printf("No results found\\n");\n        exit_code = 0;\n    }\n    \n    /* Security: Clear and free sensitive data */\n    if (xml_content != NULL) {\n        memset(xml_content, 0, xml_size);\n        free(xml_content);\n    }\n    \n    if (result != NULL) {\n        memset(result, 0, strlen(result));\n        free(result);\n    }\n    \n    /* Cleanup libxml2 */\n    xmlCleanupParser();\n    \n    return exit_code;\n}\n```', type='text')
