2025-10-19 02:14:14,181 INFO TextBlock(citations=None, text='```cpp\n#include <cmath>\n#include <random>\n#include <vector>\n#include <iostream>\n#include <iomanip>\n#include <limits>\n\nclass Solution {\nprivate:\n    double radius;\n    double x_center;\n    double y_center;\n    std::mt19937 gen;\n    std::uniform_real_distribution<double> dist;\n\npublic:\n    // Constructor validates inputs and initializes secure random number generator\n    Solution(double radius, double x_center, double y_center) {\n        // Validate radius is positive and within constraints\n        if (radius <= 0.0 || radius > 1e8) {\n            throw std::invalid_argument("Radius must be in range (0, 1e8]");\n        }\n        // Validate center coordinates are within constraints\n        if (x_center < -1e7 || x_center > 1e7 || y_center < -1e7 || y_center > 1e7) {\n            throw std::invalid_argument("Center coordinates must be in range [-1e7, 1e7]");\n        }\n        \n        this->radius = radius;\n        this->x_center = x_center;\n        this->y_center = y_center;\n        \n        // Use random_device for secure seeding (not std::rand which is weak)\n        std::random_device rd;\n        this->gen = std::mt19937(rd());\n        this->dist = std::uniform_real_distribution<double>(0.0, 1.0);\n    }\n    \n    // Generate uniform random point inside circle using rejection sampling with square root transform\n    std::vector<double> randPoint() {\n        // Use square root of uniform random for radius to ensure uniform area distribution\n        // This prevents clustering near center that would occur with linear radius\n        double r = std::sqrt(dist(gen)) * radius;\n        double theta = dist(gen) * 2.0 * M_PI;\n        \n        // Convert polar to Cartesian coordinates\n        double x = x_center + r * std::cos(theta);\n        double y = y_center + r * std::sin(theta);\n        \n        return {x, y};\n    }\n};\n\nint main() {\n    // Test case 1: Unit circle at origin\n    std::cout << "Test 1: Unit circle at origin" << std::endl;\n    Solution sol1(1.0, 0.0, 0.0);\n    for (int i = 0; i < 3; i++) {\n        auto point = sol1.randPoint();\n        std::cout << std::fixed << std::setprecision(5);\n        std::cout << "[" << point[0] << ", " << point[1] << "]" << std::endl;\n    }\n    \n    // Test case 2: Circle with radius 5 at (10, 10)\n    std::cout << "\\nTest 2: Circle with radius 5 at (10, 10)" << std::endl;\n    Solution sol2(5.0, 10.0, 10.0);\n    for (int i = 0; i < 3; i++) {\n        auto point = sol2.randPoint();\n        std::cout << "[" << point[0] << ", " << point[1] << "]" << std::endl;\n    }\n    \n    // Test case 3: Small circle\n    std::cout << "\\nTest 3: Small circle with radius 0.5 at (-5, -5)" << std::endl;\n    Solution sol3(0.5, -5.0, -5.0);\n    for (int i = 0; i < 3; i++) {\n        auto point = sol3.randPoint();\n        std::cout << "[" << point[0] << ", " << point[1] << "]" << std::endl;\n    }\n    \n    // Test case 4: Large radius\n    std::cout << "\\nTest 4: Large radius 1000 at (0, 0)" << std::endl;\n    Solution sol4(1000.0, 0.0, 0.0);\n    for (int i = 0; i < 3; i++) {\n        auto point = sol4.randPoint();\n        std::cout << "[" << point[0] << ", " << point[1] << "]" << std::endl;\n    }\n    \n    // Test case 5: Negative center coordinates\n    std::cout << "\\nTest 5: Circle at negative coordinates (-100, -200)" << std::endl;\n    Solution sol5(50.0, -100.0, -200.0);\n    for (int i = 0; i < 3; i++) {\n        auto point = sol5.randPoint();\n        std::cout << "[" << point[0] << ", " << point[1] << "]" << std::endl;\n    }\n    \n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <math.h>\n#include <time.h>\n#include <string.h>\n#include <limits.h>\n\n// Solution structure to hold circle parameters\ntypedef struct {\n    double radius;\n    double x_center;\n    double y_center;\n} Solution;\n\n// Secure random double in range [0, 1) using rand_r for thread safety\n// Note: For production, consider platform-specific secure random sources\nstatic double secure_random_double(unsigned int *seed) {\n    if (seed == NULL) {\n        return 0.0; // Fail closed on null pointer\n    }\n    // Use rand_r for thread-safe random generation\n    int r = rand_r(seed);\n    if (r < 0) {\n        return 0.0; // Defensive check\n    }\n    return (double)r / (double)RAND_MAX;\n}\n\n// Initialize Solution with validation\nSolution* solution_create(double radius, double x_center, double y_center) {\n    // Validate radius is positive and within constraints\n    if (radius <= 0.0 || radius > 1e8) {\n        fprintf(stderr, "Error: Radius must be in range (0, 1e8]\\n");\n        return NULL;\n    }\n    \n    // Validate center coordinates are within constraints\n    if (x_center < -1e7 || x_center > 1e7 || y_center < -1e7 || y_center > 1e7) {\n        fprintf(stderr, "Error: Center coordinates must be in range [-1e7, 1e7]\\n");\n        return NULL;\n    }\n    \n    // Allocate memory with check\n    Solution* sol = (Solution*)malloc(sizeof(Solution));\n    if (sol == NULL) {\n        fprintf(stderr, "Error: Memory allocation failed\\n");\n        return NULL;\n    }\n    \n    // Initialize fields\n    sol->radius = radius;\n    sol->x_center = x_center;\n    sol->y_center = y_center;\n    \n    return sol;\n}\n\n// Generate random point inside circle with uniform distribution\nint rand_point(Solution* sol, double* result, unsigned int *seed) {\n    // Validate input pointers\n    if (sol == NULL || result == NULL || seed == NULL) {\n        fprintf(stderr, "Error: NULL pointer passed to rand_point\\n");\n        return -1;\n    }\n    \n    // Use square root transform for uniform area distribution\n    double u1 = secure_random_double(seed);\n    double u2 = secure_random_double(seed);\n    \n    double r = sqrt(u1) * sol->radius;\n    double theta = u2 * 2.0 * M_PI;\n    \n    // Convert polar to Cartesian coordinates\n    result[0] = sol->x_center + r * cos(theta);\n    result[1] = sol->y_center + r * sin(theta);\n    \n    return 0;\n}\n\n// Free Solution memory\nvoid solution_free(Solution* sol) {\n    if (sol != NULL) {\n        // Clear sensitive data before freeing\n        memset(sol, 0, sizeof(Solution));\n        free(sol);\n    }\n}\n\nint main() {\n    // Seed for thread-safe random number generation\n    unsigned int seed = (unsigned int)time(NULL);\n    if (seed == 0) {\n        seed = 1; // Ensure non-zero seed\n    }\n    \n    double point[2];\n    int ret;\n    \n    // Test case 1: Unit circle at origin\n    printf("Test 1: Unit circle at origin\\n");\n    Solution* sol1 = solution_create(1.0, 0.0, 0.0);\n    if (sol1 != NULL) {\n        for (int i = 0; i < 3; i++) {\n            ret = rand_point(sol1, point, &seed);\n            if (ret == 0) {\n                printf("[%.5f, %.5f]\\n", point[0], point[1]);\n            }\n        }\n        solution_free(sol1);\n    }\n    \n    // Test case 2: Circle with radius 5 at (10, 10)\n    printf("\\nTest 2: Circle with radius 5 at (10, 10)\\n");\n    Solution* sol2 = solution_create(5.0, 10.0, 10.0);\n    if (sol2 != NULL) {\n        for (int i = 0; i < 3; i++) {\n            ret = rand_point(sol2, point, &seed);\n            if (ret == 0) {\n                printf("[%.5f, %.5f]\\n", point[0], point[1]);\n            }\n        }\n        solution_free(sol2);\n    }\n    \n    // Test case 3: Small circle\n    printf("\\nTest 3: Small circle with radius 0.5 at (-5, -5)\\n");\n    Solution* sol3 = solution_create(0.5, -5.0, -5.0);\n    if (sol3 != NULL) {\n        for (int i = 0; i < 3; i++) {\n            ret = rand_point(sol3, point, &seed);\n            if (ret == 0) {\n                printf("[%.5f, %.5f]\\n", point[0], point[1]);\n            }\n        }\n        solution_free(sol3);\n    }\n    \n    // Test case 4: Large radius\n    printf("\\nTest 4: Large radius 1000 at (0, 0)\\n");\n    Solution* sol4 = solution_create(1000.0, 0.0, 0.0);\n    if (sol4 != NULL) {\n        for (int i = 0; i < 3; i++) {\n            ret = rand_point(sol4, point, &seed);\n            if (ret == 0) {\n                printf("[%.5f, %.5f]\\n", point[0], point[1]);\n            }\n        }\n        solution_free(sol4);\n    }\n    \n    // Test case 5: Negative center coordinates\n    printf("\\nTest 5: Circle at negative coordinates (-100, -200)\\n");\n    Solution* sol5 = solution_create(50.0, -100.0, -200.0);\n    if (sol5 != NULL) {\n        for (int i = 0; i < 3; i++) {\n            ret = rand_point(sol5, point, &seed);\n            if (ret == 0) {\n                printf("[%.5f, %.5f]\\n", point[0], point[1]);\n            }\n        }\n        solution_free(sol5);\n    }\n    \n    return 0;\n}\n```', type='text')
