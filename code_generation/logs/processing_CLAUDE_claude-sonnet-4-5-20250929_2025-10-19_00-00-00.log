2025-10-19 02:35:38,227 INFO TextBlock(citations=None, text='```cpp\n#include <iostream>\n#include <string>\n#include <vector>\n#include <thread>\n#include <mutex>\n#include <atomic>\n#include <cstring>\n#include <cstdlib>\n#include <cstdint>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <unistd.h>\n#include <poll.h>\n#include <algorithm>\n\n// Maximum message size to prevent memory exhaustion\nconstexpr size_t MAX_MESSAGE_SIZE = 4096;\nconstexpr size_t MAX_CLIENTS = 100;\nconstexpr int BUFFER_SIZE = 4096;\n\nclass ChatServer {\nprivate:\n    int server_fd;\n    std::vector<int> client_fds;\n    std::mutex clients_mutex;\n    std::atomic<bool> running;\n    uint16_t port;\n\n    // Validates that message length is within bounds\n    bool validate_message_length(size_t len) {\n        return len > 0 && len <= MAX_MESSAGE_SIZE;\n    }\n\n    // Safely broadcasts message to all clients except sender\n    void broadcast_message(const std::string& message, int sender_fd) {\n        std::lock_guard<std::mutex> lock(clients_mutex);\n        \n        // Validate message size before broadcasting\n        if (!validate_message_length(message.size())) {\n            std::cerr << "Invalid message size: " << message.size() << std::endl;\n            return;\n        }\n\n        for (int client_fd : client_fds) {\n            if (client_fd != sender_fd && client_fd >= 0) {\n                // Send message length first for protocol safety\n                uint32_t msg_len = static_cast<uint32_t>(message.size());\n                ssize_t sent = send(client_fd, &msg_len, sizeof(msg_len), MSG_NOSIGNAL);\n                if (sent != sizeof(msg_len)) {\n                    continue; // Skip this client if send fails\n                }\n                \n                // Send actual message\n                sent = send(client_fd, message.c_str(), message.size(), MSG_NOSIGNAL);\n                if (sent < 0) {\n                    std::cerr << "Failed to send to client " << client_fd << std::endl;\n                }\n            }\n        }\n    }\n\n    // Handle individual client communication\n    void handle_client(int client_fd) {\n        char buffer[BUFFER_SIZE];\n        \n        while (running.load()) {\n            // Initialize buffer to prevent information leaks\n            std::memset(buffer, 0, BUFFER_SIZE);\n            \n            // Use poll for timeout to allow graceful shutdown\n            struct pollfd pfd;\n            pfd.fd = client_fd;\n            pfd.events = POLLIN;\n            \n            int poll_ret = poll(&pfd, 1, 1000); // 1 second timeout\n            \n            if (poll_ret < 0) {\n                break; // Error occurred\n            } else if (poll_ret == 0) {\n                continue; // Timeout, check running flag\n            }\n            \n            // Receive with bounds checking\n            ssize_t bytes_received = recv(client_fd, buffer, BUFFER_SIZE - 1, 0);\n            \n            if (bytes_received <= 0) {\n                break; // Client disconnected or error\n            }\n            \n            // Ensure null termination\n            buffer[bytes_received] = '\\0';\n            \n            // Validate received data length\n            if (!validate_message_length(static_cast<size_t>(bytes_received))) {\n                std::cerr << "Received invalid message size" << std::endl;\n                break;\n            }\n            \n            // Create message string safely\n            std::string message(buffer, static_cast<size_t>(bytes_received));\n            \n            // Broadcast to other clients\n            broadcast_message(message, client_fd);\n        }\n        \n        // Remove client from list\n        {\n            std::lock_guard<std::mutex> lock(clients_mutex);\n            client_fds.erase(\n                std::remove(client_fds.begin(), client_fds.end(), client_fd),\n                client_fds.end()\n            );\n        }\n        \n        // Clean up\n        close(client_fd);\n    }\n\npublic:\n    ChatServer(uint16_t p) : server_fd(-1), running(false), port(p) {}\n\n    ~ChatServer() {\n        stop();\n    }\n\n    // Initialize server socket with security checks\n    bool start() {\n        // Create socket with error checking\n        server_fd = socket(AF_INET, SOCK_STREAM, 0);\n        if (server_fd < 0) {\n            std::cerr << "Failed to create socket" << std::endl;\n            return false;\n        }\n\n        // Set socket options to reuse address\n        int opt = 1;\n        if (setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt)) < 0) {\n            close(server_fd);\n            server_fd = -1;\n            return false;\n        }\n\n        // Bind socket with validated port\n        struct sockaddr_in address;\n        std::memset(&address, 0, sizeof(address));\n        address.sin_family = AF_INET;\n        address.sin_addr.s_addr = INADDR_ANY;\n        address.sin_port = htons(port);\n\n        if (bind(server_fd, (struct sockaddr*)&address, sizeof(address)) < 0) {\n            close(server_fd);\n            server_fd = -1;\n            return false;\n        }\n\n        // Listen with bounded backlog\n        if (listen(server_fd, 10) < 0) {\n            close(server_fd);\n            server_fd = -1;\n            return false;\n        }\n\n        running.store(true);\n        return true;\n    }\n\n    // Accept clients with limits\n    void accept_clients() {\n        while (running.load()) {\n            struct pollfd pfd;\n            pfd.fd = server_fd;\n            pfd.events = POLLIN;\n            \n            int poll_ret = poll(&pfd, 1, 1000);\n            \n            if (poll_ret <= 0) {\n                continue;\n            }\n\n            struct sockaddr_in client_addr;\n            socklen_t client_len = sizeof(client_addr);\n            std::memset(&client_addr, 0, sizeof(client_addr));\n            \n            int client_fd = accept(server_fd, (struct sockaddr*)&client_addr, &client_len);\n            \n            if (client_fd < 0) {\n                continue;\n            }\n\n            // Enforce client limit to prevent resource exhaustion\n            {\n                std::lock_guard<std::mutex> lock(clients_mutex);\n                if (client_fds.size() >= MAX_CLIENTS) {\n                    close(client_fd);\n                    continue;\n                }\n                client_fds.push_back(client_fd);\n            }\n\n            // Spawn thread to handle client\n            std::thread(&ChatServer::handle_client, this, client_fd).detach();\n        }\n    }\n\n    void stop() {\n        running.store(false);\n        \n        if (server_fd >= 0) {\n            close(server_fd);\n            server_fd = -1;\n        }\n        \n        std::lock_guard<std::mutex> lock(clients_mutex);\n        for (int fd : client_fds) {\n            if (fd >= 0) {\n                close(fd);\n            }\n        }\n        client_fds.clear();\n    }\n};\n\nclass ChatClient {\nprivate:\n    int sock_fd;\n    std::string server_ip;\n    uint16_t port;\n    std::atomic<bool> running;\n\n    // Receive messages from server\n    void receive_messages() {\n        char buffer[BUFFER_SIZE];\n        \n        while (running.load()) {\n            std::memset(buffer, 0, BUFFER_SIZE);\n            \n            struct pollfd pfd;\n            pfd.fd = sock_fd;\n            pfd.events = POLLIN;\n            \n            int poll_ret = poll(&pfd, 1, 1000);\n            \n            if (poll_ret <= 0) {\n                continue;\n            }\n\n            // Receive message length\n            uint32_t msg_len = 0;\n            ssize_t received = recv(sock_fd, &msg_len, sizeof(msg_len), 0);\n            \n            if (received != sizeof(msg_len)) {\n                break;\n            }\n            \n            // Validate message length\n            if (msg_len == 0 || msg_len > MAX_MESSAGE_SIZE) {\n                std::cerr << "Invalid message length received" << std::endl;\n                break;\n            }\n            \n            // Receive message with bounds checking\n            size_t to_receive = std::min(static_cast<size_t>(msg_len), BUFFER_SIZE - 1);\n            received = recv(sock_fd, buffer, to_receive, 0);\n            \n            if (received <= 0) {\n                break;\n            }\n            \n            buffer[received] = '\\0';\n            std::cout << "Received: " << buffer << std::endl;\n        }\n    }\n\npublic:\n    ChatClient(const std::string& ip, uint16_t p) \n        : sock_fd(-1), server_ip(ip), port(p), running(false) {}\n\n    ~ChatClient() {\n        disconnect();\n    }\n\n    bool connect_to_server() {\n        sock_fd = socket(AF_INET, SOCK_STREAM, 0);\n        if (sock_fd < 0) {\n            return false;\n        }\n\n        struct sockaddr_in server_addr;\n        std::memset(&server_addr, 0, sizeof(server_addr));\n        server_addr.sin_family = AF_INET;\n        server_addr.sin_port = htons(port);\n\n        // Validate IP address format\n        if (inet_pton(AF_INET, server_ip.c_str(), &server_addr.sin_addr) <= 0) {\n            close(sock_fd);\n            sock_fd = -1;\n            return false;\n        }\n\n        if (connect(sock_fd, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {\n            close(sock_fd);\n            sock_fd = -1;\n            return false;\n        }\n\n        running.store(true);\n        std::thread(&ChatClient::receive_messages, this).detach();\n        return true;\n    }\n\n    bool send_message(const std::string& message) {\n        if (sock_fd < 0 || !running.load()) {\n            return false;\n        }\n\n        // Validate message length before sending\n        if (!message.empty() && message.size() <= MAX_MESSAGE_SIZE) {\n            ssize_t sent = send(sock_fd, message.c_str(), message.size(), MSG_NOSIGNAL);\n            return sent == static_cast<ssize_t>(message.size());\n        }\n        return false;\n    }\n\n    void disconnect() {\n        running.store(false);\n        if (sock_fd >= 0) {\n            close(sock_fd);\n            sock_fd = -1;\n        }\n    }\n};\n\nint main() {\n    // Test case 1: Start server on port 8080\n    std::cout << "Test 1: Starting server on port 8080" << std::endl;\n    ChatServer server(8080);\n    if (server.start()) {\n        std::cout << "Server started successfully" << std::endl;\n    }\n    \n    // Run server in separate thread\n    std::thread server_thread([&server]() {\n        server.accept_clients();\n    });\n\n    // Allow server to start\n    std::this_thread::sleep_for(std::chrono::milliseconds(500));\n\n    // Test case 2: Connect client 1\n    std::cout << "\\nTest 2: Connecting client 1" << std::endl;\n    ChatClient client1("127.0.0.1", 8080);\n    if (client1.connect_to_server()) {\n        std::cout << "Client 1 connected" << std::endl;\n    }\n\n    // Test case 3: Connect client 2\n    std::cout << "\\nTest 3: Connecting client 2" << std::endl;\n    ChatClient client2("127.0.0.1", 8080);\n    if (client2.connect_to_server()) {\n        std::cout << "Client 2 connected" << std::endl;\n    }\n\n    std::this_thread::sleep_for(std::chrono::milliseconds(200));\n\n    // Test case 4: Client 1 sends message\n    std::cout << "\\nTest 4: Client 1 sending message" << std::endl;\n    if (client1.send_message("Hello from client 1")) {\n        std::cout << "Message sent from client 1" << std::endl;\n    }\n\n    std::this_thread::sleep_for(std::chrono::milliseconds(200));\n\n    // Test case 5: Client 2 sends message\n    std::cout << "\\nTest 5: Client 2 sending message" << std::endl;\n    if (client2.send_message("Hello from client 2")) {\n        std::cout << "Message sent from client 2" << std::endl;\n    }\n\n    std::this_thread::sleep_for(std::chrono::milliseconds(500));\n\n    // Cleanup\n    client1.disconnect();\n    client2.disconnect();\n    server.stop();\n    server_thread.join();\n\n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdint.h>\n#include <unistd.h>\n#include <pthread.h>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <poll.h>\n#include <errno.h>\n\n#define MAX_MESSAGE_SIZE 4096\n#define MAX_CLIENTS 100\n#define BUFFER_SIZE 4096\n\n/* Thread-safe client list structure */\ntypedef struct {\n    int fds[MAX_CLIENTS];\n    size_t count;\n    pthread_mutex_t mutex;\n} ClientList;\n\n/* Server context structure */\ntypedef struct {\n    int server_fd;\n    uint16_t port;\n    ClientList clients;\n    volatile int running;\n    pthread_mutex_t running_mutex;\n} ChatServer;\n\n/* Client context structure */\ntypedef struct {\n    int sock_fd;\n    char server_ip[16];\n    uint16_t port;\n    volatile int running;\n    pthread_t recv_thread;\n} ChatClient;\n\n/* Thread argument for client handler */\ntypedef struct {\n    ChatServer* server;\n    int client_fd;\n} ClientHandlerArg;\n\n/* Initialize client list with NULL checks */\nint client_list_init(ClientList* list) {\n    if (list == NULL) {\n        return -1;\n    }\n    \n    /* Initialize all file descriptors to -1 */\n    for (size_t i = 0; i < MAX_CLIENTS; i++) {\n        list->fds[i] = -1;\n    }\n    list->count = 0;\n    \n    /* Initialize mutex with error checking */\n    if (pthread_mutex_init(&list->mutex, NULL) != 0) {\n        return -1;\n    }\n    \n    return 0;\n}\n\n/* Add client with bounds checking */\nint client_list_add(ClientList* list, int fd) {\n    if (list == NULL || fd < 0) {\n        return -1;\n    }\n    \n    pthread_mutex_lock(&list->mutex);\n    \n    if (list->count >= MAX_CLIENTS) {\n        pthread_mutex_unlock(&list->mutex);\n        return -1;\n    }\n    \n    /* Find first available slot */\n    for (size_t i = 0; i < MAX_CLIENTS; i++) {\n        if (list->fds[i] == -1) {\n            list->fds[i] = fd;\n            list->count++;\n            pthread_mutex_unlock(&list->mutex);\n            return 0;\n        }\n    }\n    \n    pthread_mutex_unlock(&list->mutex);\n    return -1;\n}\n\n/* Remove client with validation */\nint client_list_remove(ClientList* list, int fd) {\n    if (list == NULL || fd < 0) {\n        return -1;\n    }\n    \n    pthread_mutex_lock(&list->mutex);\n    \n    for (size_t i = 0; i < MAX_CLIENTS; i++) {\n        if (list->fds[i] == fd) {\n            list->fds[i] = -1;\n            if (list->count > 0) {\n                list->count--;\n            }\n            pthread_mutex_unlock(&list->mutex);\n            return 0;\n        }\n    }\n    \n    pthread_mutex_unlock(&list->mutex);\n    return -1;\n}\n\n/* Cleanup client list */\nvoid client_list_destroy(ClientList* list) {\n    if (list == NULL) {\n        return;\n    }\n    \n    pthread_mutex_lock(&list->mutex);\n    \n    /* Close all client connections */\n    for (size_t i = 0; i < MAX_CLIENTS; i++) {\n        if (list->fds[i] >= 0) {\n            close(list->fds[i]);\n            list->fds[i] = -1;\n        }\n    }\n    list->count = 0;\n    \n    pthread_mutex_unlock(&list->mutex);\n    pthread_mutex_destroy(&list->mutex);\n}\n\n/* Validate message length to prevent overflow */\nint validate_message_length(size_t len) {\n    return (len > 0 && len <= MAX_MESSAGE_SIZE);\n}\n\n/* Broadcast message to all clients except sender */\nvoid broadcast_message(ChatServer* server, const char* message, size_t msg_len, int sender_fd) {\n    if (server == NULL || message == NULL || !validate_message_length(msg_len)) {\n        return;\n    }\n    \n    pthread_mutex_lock(&server->clients.mutex);\n    \n    for (size_t i = 0; i < MAX_CLIENTS; i++) {\n        int client_fd = server->clients.fds[i];\n        \n        if (client_fd >= 0 && client_fd != sender_fd) {\n            /* Send message length first */\n            uint32_t network_len = (uint32_t)msg_len;\n            ssize_t sent = send(client_fd, &network_len, sizeof(network_len), MSG_NOSIGNAL);\n            \n            if (sent != sizeof(network_len)) {\n                continue;\n            }\n            \n            /* Send actual message with bounds checking */\n            sent = send(client_fd, message, msg_len, MSG_NOSIGNAL);\n            if (sent < 0) {\n                fprintf(stderr, "Failed to send to client %d\\n", client_fd);\n            }\n        }\n    }\n    \n    pthread_mutex_unlock(&server->clients.mutex);\n}\n\n/* Handle individual client communication */\nvoid* handle_client_thread(void* arg) {\n    if (arg == NULL) {\n        return NULL;\n    }\n    \n    ClientHandlerArg* handler_arg = (ClientHandlerArg*)arg;\n    ChatServer* server = handler_arg->server;\n    int client_fd = handler_arg->client_fd;\n    \n    /* Free argument structure after extracting values */\n    free(handler_arg);\n    handler_arg = NULL;\n    \n    if (server == NULL || client_fd < 0) {\n        return NULL;\n    }\n    \n    char* buffer = (char*)calloc(BUFFER_SIZE, sizeof(char));\n    if (buffer == NULL) {\n        close(client_fd);\n        client_list_remove(&server->clients, client_fd);\n        return NULL;\n    }\n    \n    int keep_running = 1;\n    \n    while (keep_running) {\n        pthread_mutex_lock(&server->running_mutex);\n        keep_running = server->running;\n        pthread_mutex_unlock(&server->running_mutex);\n        \n        if (!keep_running) {\n            break;\n        }\n        \n        /* Clear buffer to prevent information leaks */\n        memset(buffer, 0, BUFFER_SIZE);\n        \n        /* Use poll for timeout */\n        struct pollfd pfd;\n        pfd.fd = client_fd;\n        pfd.events = POLLIN;\n        \n        int poll_ret = poll(&pfd, 1, 1000);\n        \n        if (poll_ret < 0) {\n            break;\n        } else if (poll_ret == 0) {\n            continue;\n        }\n        \n        /* Receive with bounds checking */\n        ssize_t bytes_received = recv(client_fd, buffer, BUFFER_SIZE - 1, 0);\n        \n        if (bytes_received <= 0) {\n            break;\n        }\n        \n        /* Ensure null termination */\n        buffer[bytes_received] = '\\0';\n        \n        /* Validate received data length */\n        if (!validate_message_length((size_t)bytes_received)) {\n            fprintf(stderr, "Invalid message size received\\n");\n            break;\n        }\n        \n        /* Broadcast to other clients */\n        broadcast_message(server, buffer, (size_t)bytes_received, client_fd);\n    }\n    \n    /* Cleanup: clear sensitive data before freeing */\n    memset(buffer, 0, BUFFER_SIZE);\n    free(buffer);\n    buffer = NULL;\n    \n    /* Remove client and close connection */\n    client_list_remove(&server->clients, client_fd);\n    close(client_fd);\n    \n    return NULL;\n}\n\n/* Initialize server with validation */\nint chat_server_init(ChatServer* server, uint16_t port) {\n    if (server == NULL || port == 0) {\n        return -1;\n    }\n    \n    /* Initialize all fields */\n    server->server_fd = -1;\n    server->port = port;\n    server->running = 0;\n    \n    if (client_list_init(&server->clients) != 0) {\n        return -1;\n    }\n    \n    if (pthread_mutex_init(&server->running_mutex, NULL) != 0) {\n        client_list_destroy(&server->clients);\n        return -1;\n    }\n    \n    return 0;\n}\n\n/* Start server with security checks */\nint chat_server_start(ChatServer* server) {\n    if (server == NULL) {\n        return -1;\n    }\n    \n    /* Create socket with error checking */\n    server->server_fd = socket(AF_INET, SOCK_STREAM, 0);\n    if (server->server_fd < 0) {\n        fprintf(stderr, "Failed to create socket\\n");\n        return -1;\n    }\n    \n    /* Set socket options */\n    int opt = 1;\n    if (setsockopt(server->server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt)) < 0) {\n        close(server->server_fd);\n        server->server_fd = -1;\n        return -1;\n    }\n    \n    /* Bind socket with validated port */\n    struct sockaddr_in address;\n    memset(&address, 0, sizeof(address));\n    address.sin_family = AF_INET;\n    address.sin_addr.s_addr = INADDR_ANY;\n    address.sin_port = htons(server->port);\n    \n    if (bind(server->server_fd, (struct sockaddr*)&address, sizeof(address)) < 0) {\n        close(server->server_fd);\n        server->server_fd = -1;\n        return -1;\n    }\n    \n    /* Listen with bounded backlog */\n    if (listen(server->server_fd, 10) < 0) {\n        close(server->server_fd);\n        server->server_fd = -1;\n        return -1;\n    }\n    \n    pthread_mutex_lock(&server->running_mutex);\n    server->running = 1;\n    pthread_mutex_unlock(&server->running_mutex);\n    \n    return 0;\n}\n\n/* Accept clients with limits */\nvoid chat_server_accept_clients(ChatServer* server) {\n    if (server == NULL || server->server_fd < 0) {\n        return;\n    }\n    \n    int keep_running = 1;\n    \n    while (keep_running) {\n        pthread_mutex_lock(&server->running_mutex);\n        keep_running = server->running;\n        pthread_mutex_unlock(&server->running_mutex);\n        \n        if (!keep_running) {\n            break;\n        }\n        \n        struct pollfd pfd;\n        pfd.fd = server->server_fd;\n        pfd.events = POLLIN;\n        \n        int poll_ret = poll(&pfd, 1, 1000);\n        \n        if (poll_ret <= 0) {\n            continue;\n        }\n        \n        struct sockaddr_in client_addr;\n        socklen_t client_len = sizeof(client_addr);\n        memset(&client_addr, 0, sizeof(client_addr));\n        \n        int client_fd = accept(server->server_fd, (struct sockaddr*)&client_addr, &client_len);\n        \n        if (client_fd < 0) {\n            continue;\n        }\n        \n        /* Check client limit to prevent resource exhaustion */\n        if (client_list_add(&server->clients, client_fd) != 0) {\n            close(client_fd);\n            continue;\n        }\n        \n        /* Allocate thread argument with NULL check */\n        ClientHandlerArg* arg = (ClientHandlerArg*)malloc(sizeof(ClientHandlerArg));\n        if (arg == NULL) {\n            close(client_fd);\n            client_list_remove(&server->clients, client_fd);\n            continue;\n        }\n        \n        arg->server = server;\n        arg->client_fd = client_fd;\n        \n        /* Create thread to handle client */\n        pthread_t thread;\n        if (pthread_create(&thread, NULL, handle_client_thread, arg) != 0) {\n            free(arg);\n            close(client_fd);\n            client_list_remove(&server->clients, client_fd);\n            continue;\n        }\n        \n        pthread_detach(thread);\n    }\n}\n\n/* Stop server and cleanup */\nvoid chat_server_stop(ChatServer* server) {\n    if (server == NULL) {\n        return;\n    }\n    \n    pthread_mutex_lock(&server->running_mutex);\n    server->running = 0;\n    pthread_mutex_unlock(&server->running_mutex);\n    \n    if (server->server_fd >= 0) {\n        close(server->server_fd);\n        server->server_fd = -1;\n    }\n    \n    client_list_destroy(&server->clients);\n    pthread_mutex_destroy(&server->running_mutex);\n}\n\n/* Client receive messages thread */\nvoid* client_receive_thread(void* arg) {\n    if (arg == NULL) {\n        return NULL;\n    }\n    \n    ChatClient* client = (ChatClient*)arg;\n    \n    char* buffer = (char*)calloc(BUFFER_SIZE, sizeof(char));\n    if (buffer == NULL) {\n        return NULL;\n    }\n    \n    while (client->running) {\n        memset(buffer, 0, BUFFER_SIZE);\n        \n        struct pollfd pfd;\n        pfd.fd = client->sock_fd;\n        pfd.events = POLLIN;\n        \n        int poll_ret = poll(&pfd, 1, 1000);\n        \n        if (poll_ret <= 0) {\n            continue;\n        }\n        \n        /* Receive message length */\n        uint32_t msg_len = 0;\n        ssize_t received = recv(client->sock_fd, &msg_len, sizeof(msg_len), 0);\n        \n        if (received != sizeof(msg_len)) {\n            break;\n        }\n        \n        /* Validate message length */\n        if (msg_len == 0 || msg_len > MAX_MESSAGE_SIZE) {\n            fprintf(stderr, "Invalid message length received\\n");\n            break;\n        }\n        \n        /* Receive message with bounds checking */\n        size_t to_receive = (msg_len < BUFFER_SIZE - 1) ? msg_len : (BUFFER_SIZE - 1);\n        received = recv(client->sock_fd, buffer, to_receive, 0);\n        \n        if (received <= 0) {\n            break;\n        }\n        \n        buffer[received] = '\\0';\n        printf("Received: %s\\n", buffer);\n    }\n    \n    /* Clear sensitive data before freeing */\n    memset(buffer, 0, BUFFER_SIZE);\n    free(buffer);\n    buffer = NULL;\n    \n    return NULL;\n}\n\n/* Initialize client with validation */\nint chat_client_init(ChatClient* client, const char* server_ip, uint16_t port) {\n    if (client == NULL || server_ip == NULL || port == 0) {\n        return -1;\n    }\n    \n    /* Validate IP string length */\n    size_t ip_len = strnlen(server_ip, 16);\n    if (ip_len >= 16) {\n        return -1;\n    }\n    \n    client->sock_fd = -1;\n    client->port = port;\n    client->running = 0;\n    \n    /* Safe string copy with bounds checking */\n    strncpy(client->server_ip, server_ip, sizeof(client->server_ip) - 1);\n    client->server_ip[sizeof(client->server_ip) - 1] = '\\0';\n    \n    return 0;\n}\n\n/* Connect to server with validation */\nint chat_client_connect(ChatClient* client) {\n    if (client == NULL) {\n        return -1;\n    }\n    \n    client->sock_fd = socket(AF_INET, SOCK_STREAM, 0);\n    if (client->sock_fd < 0) {\n        return -1;\n    }\n    \n    struct sockaddr_in server_addr;\n    memset(&server_addr, 0, sizeof(server_addr));\n    server_addr.sin_family = AF_INET;\n    server_addr.sin_port = htons(client->port);\n    \n    /* Validate IP address format */\n    if (inet_pton(AF_INET, client->server_ip, &server_addr.sin_addr) <= 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n        return -1;\n    }\n    \n    if (connect(client->sock_fd, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n        return -1;\n    }\n    \n    client->running = 1;\n    \n    /* Start receive thread */\n    if (pthread_create(&client->recv_thread, NULL, client_receive_thread, client) != 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n        client->running = 0;\n        return -1;\n    }\n    \n    return 0;\n}\n\n/* Send message with validation */\nint chat_client_send(ChatClient* client, const char* message) {\n    if (client == NULL || message == NULL || client->sock_fd < 0 || !client->running) {\n        return -1;\n    }\n    \n    size_t msg_len = strnlen(message, MAX_MESSAGE_SIZE + 1);\n    \n    /* Validate message length */\n    if (!validate_message_length(msg_len)) {\n        return -1;\n    }\n    \n    ssize_t sent = send(client->sock_fd, message, msg_len, MSG_NOSIGNAL);\n    return (sent == (ssize_t)msg_len) ? 0 : -1;\n}\n\n/* Disconnect client and cleanup */\nvoid chat_client_disconnect(ChatClient* client) {\n    if (client == NULL) {\n        return;\n    }\n    \n    client->running = 0;\n    \n    if (client->sock_fd >= 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n    }\n    \n    pthread_join(client->recv_thread, NULL);\n}\n\nint main(void) {\n    /* Test case 1: Start server on port 8080 */\n    printf("Test 1: Starting server on port 8080\\n");\n    ChatServer server;\n    if (chat_server_init(&server, 8080) == 0 && chat_server_start(&server) == 0) {\n        printf("Server started successfully\\n");\n    } else {\n        fprintf(stderr, "Failed to start server\\n");\n        return 1;\n    }\n    \n    /* Run server in separate thread */\n    pthread_t server_thread;\n    if (pthread_create(&server_thread, NULL, (void*(*)(void*))chat_server_accept_clients, &server) != 0) {\n        fprintf(stderr, "Failed to create server thread\\n");\n        chat_server_stop(&server);\n        return 1;\n    }\n    \n    /* Allow server to start */\n    sleep(1);\n    \n    /* Test case 2: Connect client 1 */\n    printf("\\nTest 2: Connecting client 1\\n");\n    ChatClient client1;\n    if (chat_client_init(&client1, "127.0.0.1", 8080) == 0 && chat_client_connect(&client1) == 0) {\n        printf("Client 1 connected\\n");\n    } else {\n        fprintf(stderr, "Client 1 connection failed\\n");\n    }\n    \n    /* Test case 3: Connect client 2 */\n    printf("\\nTest 3: Connecting client 2\\n");\n    ChatClient client2;\n    if (chat_client_init(&client2, "127.0.0.1", 8080) == 0 && chat_client_connect(&client2) == 0) {\n        printf("Client 2 connected\\n");\n    } else {\n        fprintf(stderr, "Client 2 connection failed\\n");\n    }\n    \n    sleep(1);\n    \n    /* Test case 4: Client 1 sends message */\n    printf("\\nTest 4: Client 1 sending message\\n");\n    if (chat_client_send(&client1, "Hello from client 1") == 0) {\n        printf("Message sent from client 1\\n");\n    }\n    \n    sleep(1);\n    \n    /* Test case 5: Client 2 sends message */\n    printf("\\nTest 5: Client 2 sending message\\n");\n    if (chat_client_send(&client2, "Hello from client 2") == 0) {\n        printf("Message sent from client 2\\n");\n    }\n    \n    sleep(1);\n    \n    /* Cleanup */\n    chat_client_disconnect(&client1);\n    chat_client_disconnect(&client2);\n    chat_server_stop(&server);\n    pthread_join(server_thread, NULL);\n    \n    return 0;\n}\n```', type='text')
