se size to prevent memory exhaustion\n    if (mem->size + realsize + 1 > MAX_RESPONSE_SIZE) {\n        std::cerr << "Error: Response size exceeds maximum allowed (" \n                  << MAX_RESPONSE_SIZE << " bytes)" << std::endl;\n        return 0; // Fail safely\n    }\n    \n    // Security: Grow buffer if needed with bounds checking\n    if (mem->size + realsize + 1 > mem->capacity) {\n        size_t new_capacity = mem->capacity * 2;\n        if (new_capacity > MAX_RESPONSE_SIZE) {\n            new_capacity = MAX_RESPONSE_SIZE;\n        }\n        if (mem->size + realsize + 1 > new_capacity) {\n            return 0; // Cannot fit even with max capacity\n        }\n        \n        char* new_data = static_cast<char*>(realloc(mem->data, new_capacity));\n        if (new_data == nullptr) {\n            return 0; // Memory allocation failed\n        }\n        mem->data = new_data;\n        mem->capacity = new_capacity;\n    }\n    \n    // Security: Safe memory copy with bounds check\n    memcpy(&(mem->data[mem->size]), contents, realsize);\n    mem->size += realsize;\n    mem->data[mem->size] = '\\0'; // Security: Null-terminate\n    \n    return realsize;\n}\n\n// Security: Validate URL format (basic check for https://)\nbool validateUrl(const std::string& url) {\n    // Security: Reject empty URLs\n    if (url.empty() || url.length() > 2048) {\n        return false;\n    }\n    \n    // Security: Only allow HTTPS for secure transmission\n    if (url.substr(0, 8) != "https://") {\n        std::cerr << "Error: Only HTTPS URLs are allowed" << std::endl;\n        return false;\n    }\n    \n    return true;\n}\n\n// Security: Fetch JSON from URL with certificate validation\nJson::Value fetchJsonFromUrl(const std::string& url) {\n    Json::Value result;\n    \n    // Security: Validate URL before processing\n    if (!validateUrl(url)) {\n        std::cerr << "Error: Invalid URL format" << std::endl;\n        return result;\n    }\n    \n    CURL* curl = curl_easy_i