2025-10-19 02:55:06,094 INFO TextBlock(citations=None, text='```cpp\n#include <iostream>\n#include <string>\n#include <vector>\n#include <thread>\n#include <mutex>\n#include <atomic>\n#include <cstring>\n#include <unistd.h>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <poll.h>\n\n// Security: Max message size to prevent buffer overflow attacks\nconst size_t MAX_MESSAGE_SIZE = 4096;\n// Security: Max clients to prevent resource exhaustion\nconst size_t MAX_CLIENTS = 100;\n// Security: Port validation range\nconst int MIN_PORT = 1024;\nconst int MAX_PORT = 65535;\n\nclass ChatServer {\nprivate:\n    int server_fd;\n    std::vector<int> client_fds;\n    std::mutex clients_mutex;\n    std::atomic<bool> running;\n\n    // Security: Validate message content and size before broadcasting\n    bool validateMessage(const char* msg, size_t len) {\n        // Security: Check message length to prevent overflow\n        if (len == 0 || len > MAX_MESSAGE_SIZE) {\n            return false;\n        }\n        // Security: Ensure null-terminated string\n        if (msg[len - 1] != '\\0') {\n            return false;\n        }\n        return true;\n    }\n\n    void broadcastMessage(const std::string& message, int sender_fd) {\n        std::lock_guard<std::mutex> lock(clients_mutex);\n        \n        // Security: Validate message size before sending\n        if (message.size() > MAX_MESSAGE_SIZE - 1) {\n            return;\n        }\n\n        for (int client_fd : client_fds) {\n            if (client_fd != sender_fd && client_fd >= 0) {\n                // Security: Use send with MSG_NOSIGNAL to prevent SIGPIPE\n                ssize_t sent = send(client_fd, message.c_str(), message.size(), MSG_NOSIGNAL);\n                // Security: Check return value for errors\n                if (sent < 0) {\n                    std::cerr << "Failed to send to client" << std::endl;\n                }\n            }\n        }\n    }\n\n    void handleClient(int client_fd) {\n        char buffer[MAX_MESSAGE_SIZE];\n        \n        while (running.load()) {\n            // Security: Clear buffer before reading to prevent data leakage\n            std::memset(buffer, 0, sizeof(buffer));\n            \n            // Security: Use recv with size limit to prevent buffer overflow\n            ssize_t bytes_read = recv(client_fd, buffer, MAX_MESSAGE_SIZE - 1, 0);\n            \n            // Security: Check return value for errors or connection close\n            if (bytes_read <= 0) {\n                break;\n            }\n            \n            // Security: Ensure null-termination\n            buffer[bytes_read] = '\\0';\n            \n            // Security: Validate message before broadcasting\n            if (validateMessage(buffer, bytes_read + 1)) {\n                std::string message = "Client " + std::to_string(client_fd) + ": " + std::string(buffer);\n                broadcastMessage(message, client_fd);\n            }\n        }\n        \n        // Security: Remove client and close socket\n        {\n            std::lock_guard<std::mutex> lock(clients_mutex);\n            client_fds.erase(std::remove(client_fds.begin(), client_fds.end(), client_fd), client_fds.end());\n        }\n        close(client_fd);\n    }\n\npublic:\n    ChatServer() : server_fd(-1), running(false) {}\n\n    ~ChatServer() {\n        stop();\n    }\n\n    // Security: Validate port range\n    bool start(int port) {\n        if (port < MIN_PORT || port > MAX_PORT) {\n            std::cerr << "Invalid port range" << std::endl;\n            return false;\n        }\n\n        // Security: Create socket with error checking\n        server_fd = socket(AF_INET, SOCK_STREAM, 0);\n        if (server_fd < 0) {\n            std::cerr << "Socket creation failed" << std::endl;\n            return false;\n        }\n\n        // Security: Set socket options to reuse address\n        int opt = 1;\n        if (setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt)) < 0) {\n            close(server_fd);\n            return false;\n        }\n\n        struct sockaddr_in address;\n        std::memset(&address, 0, sizeof(address));\n        address.sin_family = AF_INET;\n        address.sin_addr.s_addr = INADDR_ANY;\n        address.sin_port = htons(port);\n\n        // Security: Check bind return value\n        if (bind(server_fd, (struct sockaddr*)&address, sizeof(address)) < 0) {\n            std::cerr << "Bind failed" << std::endl;\n            close(server_fd);\n            return false;\n        }\n\n        // Security: Check listen return value\n        if (listen(server_fd, 10) < 0) {\n            std::cerr << "Listen failed" << std::endl;\n            close(server_fd);\n            return false;\n        }\n\n        running.store(true);\n        std::cout << "Server started on port " << port << std::endl;\n\n        while (running.load()) {\n            struct pollfd pfd;\n            pfd.fd = server_fd;\n            pfd.events = POLLIN;\n            \n            // Security: Use poll with timeout to allow graceful shutdown\n            int ret = poll(&pfd, 1, 1000);\n            if (ret < 0) {\n                break;\n            }\n            if (ret == 0) {\n                continue;\n            }\n\n            struct sockaddr_in client_addr;\n            socklen_t client_len = sizeof(client_addr);\n            \n            // Security: Accept with error checking\n            int client_fd = accept(server_fd, (struct sockaddr*)&client_addr, &client_len);\n            if (client_fd < 0) {\n                continue;\n            }\n\n            // Security: Check max clients limit to prevent resource exhaustion\n            {\n                std::lock_guard<std::mutex> lock(clients_mutex);\n                if (client_fds.size() >= MAX_CLIENTS) {\n                    close(client_fd);\n                    continue;\n                }\n                client_fds.push_back(client_fd);\n            }\n\n            // Security: Launch thread to handle client\n            std::thread(&ChatServer::handleClient, this, client_fd).detach();\n        }\n\n        return true;\n    }\n\n    void stop() {\n        running.store(false);\n        \n        // Security: Close all client connections\n        {\n            std::lock_guard<std::mutex> lock(clients_mutex);\n            for (int fd : client_fds) {\n                if (fd >= 0) {\n                    close(fd);\n                }\n            }\n            client_fds.clear();\n        }\n        \n        // Security: Close server socket\n        if (server_fd >= 0) {\n            close(server_fd);\n            server_fd = -1;\n        }\n    }\n};\n\nclass ChatClient {\nprivate:\n    int sock_fd;\n    std::atomic<bool> running;\n\n    void receiveMessages() {\n        char buffer[MAX_MESSAGE_SIZE];\n        \n        while (running.load()) {\n            // Security: Clear buffer before reading\n            std::memset(buffer, 0, sizeof(buffer));\n            \n            // Security: Use recv with size limit\n            ssize_t bytes_read = recv(sock_fd, buffer, MAX_MESSAGE_SIZE - 1, 0);\n            \n            // Security: Check return value\n            if (bytes_read <= 0) {\n                break;\n            }\n            \n            // Security: Ensure null-termination\n            buffer[bytes_read] = '\\0';\n            std::cout << buffer << std::endl;\n        }\n    }\n\npublic:\n    ChatClient() : sock_fd(-1), running(false) {}\n\n    ~ChatClient() {\n        disconnect();\n    }\n\n    // Security: Validate IP address and port\n    bool connect(const std::string& ip, int port) {\n        if (port < MIN_PORT || port > MAX_PORT) {\n            return false;\n        }\n\n        // Security: Create socket with error checking\n        sock_fd = socket(AF_INET, SOCK_STREAM, 0);\n        if (sock_fd < 0) {\n            return false;\n        }\n\n        struct sockaddr_in serv_addr;\n        std::memset(&serv_addr, 0, sizeof(serv_addr));\n        serv_addr.sin_family = AF_INET;\n        serv_addr.sin_port = htons(port);\n\n        // Security: Validate IP address conversion\n        if (inet_pton(AF_INET, ip.c_str(), &serv_addr.sin_addr) <= 0) {\n            close(sock_fd);\n            return false;\n        }\n\n        // Security: Check connect return value\n        if (::connect(sock_fd, (struct sockaddr*)&serv_addr, sizeof(serv_addr)) < 0) {\n            close(sock_fd);\n            return false;\n        }\n\n        running.store(true);\n        std::thread(&ChatClient::receiveMessages, this).detach();\n        return true;\n    }\n\n    // Security: Validate message size before sending\n    bool sendMessage(const std::string& message) {\n        if (message.empty() || message.size() > MAX_MESSAGE_SIZE - 1) {\n            return false;\n        }\n\n        // Security: Use send with MSG_NOSIGNAL\n        ssize_t sent = send(sock_fd, message.c_str(), message.size(), MSG_NOSIGNAL);\n        return sent > 0;\n    }\n\n    void disconnect() {\n        running.store(false);\n        if (sock_fd >= 0) {\n            close(sock_fd);\n            sock_fd = -1;\n        }\n    }\n};\n\nint main() {\n    std::cout << "=== Test Case 1: Server Start ===" << std::endl;\n    ChatServer server;\n    std::thread server_thread([&server]() {\n        server.start(8080);\n    });\n    std::this_thread::sleep_for(std::chrono::milliseconds(500));\n\n    std::cout << "=== Test Case 2: Client Connection ===" << std::endl;\n    ChatClient client1;\n    if (client1.connect("127.0.0.1", 8080)) {\n        std::cout << "Client 1 connected" << std::endl;\n    }\n\n    std::cout << "=== Test Case 3: Send Message ===" << std::endl;\n    client1.sendMessage("Hello from client 1");\n    std::this_thread::sleep_for(std::chrono::milliseconds(200));\n\n    std::cout << "=== Test Case 4: Multiple Clients ===" << std::endl;\n    ChatClient client2;\n    if (client2.connect("127.0.0.1", 8080)) {\n        std::cout << "Client 2 connected" << std::endl;\n    }\n    client2.sendMessage("Hello from client 2");\n    std::this_thread::sleep_for(std::chrono::milliseconds(200));\n\n    std::cout << "=== Test Case 5: Cleanup ===" << std::endl;\n    client1.disconnect();\n    client2.disconnect();\n    server.stop();\n    \n    if (server_thread.joinable()) {\n        server_thread.join();\n    }\n    \n    std::cout << "All tests completed" << std::endl;\n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <unistd.h>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <pthread.h>\n#include <poll.h>\n#include <stdatomic.h>\n#include <errno.h>\n\n/* Security: Define maximum limits to prevent resource exhaustion */\n#define MAX_MESSAGE_SIZE 4096\n#define MAX_CLIENTS 100\n#define MIN_PORT 1024\n#define MAX_PORT 65535\n\n/* Server structure with thread-safe client list */\ntypedef struct {\n    int server_fd;\n    int client_fds[MAX_CLIENTS];\n    size_t client_count;\n    pthread_mutex_t clients_mutex;\n    atomic_int running;\n} ChatServer;\n\n/* Client thread argument structure */\ntypedef struct {\n    ChatServer* server;\n    int client_fd;\n} ClientThreadArg;\n\n/* Client structure */\ntypedef struct {\n    int sock_fd;\n    atomic_int running;\n    pthread_t recv_thread;\n} ChatClient;\n\n/* Security: Validate message content and size */\nint validate_message(const char* msg, size_t len) {\n    /* Security: Check message length to prevent overflow */\n    if (msg == NULL || len == 0 || len > MAX_MESSAGE_SIZE) {\n        return 0;\n    }\n    /* Security: Ensure null-terminated string */\n    if (msg[len - 1] != '\\0') {\n        return 0;\n    }\n    return 1;\n}\n\n/* Security: Broadcast message to all clients except sender */\nvoid broadcast_message(ChatServer* server, const char* message, int sender_fd) {\n    size_t i;\n    ssize_t sent;\n    size_t msg_len;\n    \n    if (server == NULL || message == NULL) {\n        return;\n    }\n    \n    /* Security: Validate message size before sending */\n    msg_len = strnlen(message, MAX_MESSAGE_SIZE);\n    if (msg_len == 0 || msg_len >= MAX_MESSAGE_SIZE) {\n        return;\n    }\n    \n    pthread_mutex_lock(&server->clients_mutex);\n    \n    for (i = 0; i < server->client_count; i++) {\n        if (server->client_fds[i] != sender_fd && server->client_fds[i] >= 0) {\n            /* Security: Use send with MSG_NOSIGNAL to prevent SIGPIPE */\n            sent = send(server->client_fds[i], message, msg_len, MSG_NOSIGNAL);\n            /* Security: Check return value for errors */\n            if (sent < 0) {\n                fprintf(stderr, "Failed to send to client\\n");\n            }\n        }\n    }\n    \n    pthread_mutex_unlock(&server->clients_mutex);\n}\n\n/* Security: Remove client from list */\nvoid remove_client(ChatServer* server, int client_fd) {\n    size_t i, j;\n    \n    if (server == NULL) {\n        return;\n    }\n    \n    pthread_mutex_lock(&server->clients_mutex);\n    \n    for (i = 0; i < server->client_count; i++) {\n        if (server->client_fds[i] == client_fd) {\n            /* Shift remaining clients */\n            for (j = i; j < server->client_count - 1; j++) {\n                server->client_fds[j] = server->client_fds[j + 1];\n            }\n            server->client_count--;\n            break;\n        }\n    }\n    \n    pthread_mutex_unlock(&server->clients_mutex);\n}\n\n/* Handle individual client communication */\nvoid* handle_client(void* arg) {\n    ClientThreadArg* thread_arg = NULL;\n    ChatServer* server = NULL;\n    int client_fd;\n    char buffer[MAX_MESSAGE_SIZE];\n    char message[MAX_MESSAGE_SIZE + 50];\n    ssize_t bytes_read;\n    int ret;\n    \n    /* Security: Validate argument pointer */\n    if (arg == NULL) {\n        return NULL;\n    }\n    \n    thread_arg = (ClientThreadArg*)arg;\n    server = thread_arg->server;\n    client_fd = thread_arg->client_fd;\n    \n    /* Security: Free allocated memory immediately after copying */\n    free(thread_arg);\n    thread_arg = NULL;\n    \n    while (atomic_load(&server->running)) {\n        /* Security: Clear buffer before reading to prevent data leakage */\n        memset(buffer, 0, sizeof(buffer));\n        \n        /* Security: Use recv with size limit to prevent buffer overflow */\n        bytes_read = recv(client_fd, buffer, MAX_MESSAGE_SIZE - 1, 0);\n        \n        /* Security: Check return value for errors or connection close */\n        if (bytes_read <= 0) {\n            break;\n        }\n        \n        /* Security: Ensure null-termination */\n        buffer[bytes_read] = '\\0';\n        \n        /* Security: Validate message before broadcasting */\n        if (validate_message(buffer, bytes_read + 1)) {\n            /* Security: Use snprintf to prevent buffer overflow */\n            ret = snprintf(message, sizeof(message), "Client %d: %s", client_fd, buffer);\n            if (ret > 0 && (size_t)ret < sizeof(message)) {\n                broadcast_message(server, message, client_fd);\n            }\n        }\n    }\n    \n    /* Security: Remove client and close socket */\n    remove_client(server, client_fd);\n    close(client_fd);\n    \n    return NULL;\n}\n\n/* Initialize server structure */\nint server_init(ChatServer* server) {\n    size_t i;\n    \n    /* Security: Validate pointer */\n    if (server == NULL) {\n        return 0;\n    }\n    \n    /* Security: Initialize all pointers to NULL or valid values */\n    server->server_fd = -1;\n    server->client_count = 0;\n    atomic_init(&server->running, 0);\n    \n    /* Security: Initialize all client fds to invalid value */\n    for (i = 0; i < MAX_CLIENTS; i++) {\n        server->client_fds[i] = -1;\n    }\n    \n    /* Security: Check mutex initialization return value */\n    if (pthread_mutex_init(&server->clients_mutex, NULL) != 0) {\n        return 0;\n    }\n    \n    return 1;\n}\n\n/* Start server on specified port */\nint server_start(ChatServer* server, int port) {\n    struct sockaddr_in address;\n    struct sockaddr_in client_addr;\n    socklen_t client_len;\n    int client_fd;\n    int opt = 1;\n    struct pollfd pfd;\n    int poll_ret;\n    pthread_t client_thread;\n    ClientThreadArg* thread_arg = NULL;\n    \n    /* Security: Validate pointer and port range */\n    if (server == NULL || port < MIN_PORT || port > MAX_PORT) {\n        fprintf(stderr, "Invalid server or port range\\n");\n        return 0;\n    }\n    \n    /* Security: Create socket with error checking */\n    server->server_fd = socket(AF_INET, SOCK_STREAM, 0);\n    if (server->server_fd < 0) {\n        fprintf(stderr, "Socket creation failed\\n");\n        return 0;\n    }\n    \n    /* Security: Set socket options to reuse address */\n    if (setsockopt(server->server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt)) < 0) {\n        close(server->server_fd);\n        server->server_fd = -1;\n        return 0;\n    }\n    \n    /* Security: Initialize address structure */\n    memset(&address, 0, sizeof(address));\n    address.sin_family = AF_INET;\n    address.sin_addr.s_addr = INADDR_ANY;\n    address.sin_port = htons((uint16_t)port);\n    \n    /* Security: Check bind return value */\n    if (bind(server->server_fd, (struct sockaddr*)&address, sizeof(address)) < 0) {\n        fprintf(stderr, "Bind failed\\n");\n        close(server->server_fd);\n        server->server_fd = -1;\n        return 0;\n    }\n    \n    /* Security: Check listen return value */\n    if (listen(server->server_fd, 10) < 0) {\n        fprintf(stderr, "Listen failed\\n");\n        close(server->server_fd);\n        server->server_fd = -1;\n        return 0;\n    }\n    \n    atomic_store(&server->running, 1);\n    printf("Server started on port %d\\n", port);\n    \n    while (atomic_load(&server->running)) {\n        pfd.fd = server->server_fd;\n        pfd.events = POLLIN;\n        \n        /* Security: Use poll with timeout to allow graceful shutdown */\n        poll_ret = poll(&pfd, 1, 1000);\n        if (poll_ret < 0) {\n            break;\n        }\n        if (poll_ret == 0) {\n            continue;\n        }\n        \n        client_len = sizeof(client_addr);\n        memset(&client_addr, 0, sizeof(client_addr));\n        \n        /* Security: Accept with error checking */\n        client_fd = accept(server->server_fd, (struct sockaddr*)&client_addr, &client_len);\n        if (client_fd < 0) {\n            continue;\n        }\n        \n        /* Security: Check max clients limit to prevent resource exhaustion */\n        pthread_mutex_lock(&server->clients_mutex);\n        if (server->client_count >= MAX_CLIENTS) {\n            pthread_mutex_unlock(&server->clients_mutex);\n            close(client_fd);\n            continue;\n        }\n        server->client_fds[server->client_count] = client_fd;\n        server->client_count++;\n        pthread_mutex_unlock(&server->clients_mutex);\n        \n        /* Security: Allocate memory for thread argument with NULL check */\n        thread_arg = (ClientThreadArg*)malloc(sizeof(ClientThreadArg));\n        if (thread_arg == NULL) {\n            remove_client(server, client_fd);\n            close(client_fd);\n            continue;\n        }\n        \n        thread_arg->server = server;\n        thread_arg->client_fd = client_fd;\n        \n        /* Security: Launch thread to handle client with error checking */\n        if (pthread_create(&client_thread, NULL, handle_client, thread_arg) != 0) {\n            free(thread_arg);\n            remove_client(server, client_fd);\n            close(client_fd);\n            continue;\n        }\n        \n        /* Detach thread to avoid resource leak */\n        pthread_detach(client_thread);\n    }\n    \n    return 1;\n}\n\n/* Stop server and cleanup resources */\nvoid server_stop(ChatServer* server) {\n    size_t i;\n    \n    if (server == NULL) {\n        return;\n    }\n    \n    atomic_store(&server->running, 0);\n    \n    /* Security: Close all client connections */\n    pthread_mutex_lock(&server->clients_mutex);\n    for (i = 0; i < server->client_count; i++) {\n        if (server->client_fds[i] >= 0) {\n            close(server->client_fds[i]);\n            server->client_fds[i] = -1;\n        }\n    }\n    server->client_count = 0;\n    pthread_mutex_unlock(&server->clients_mutex);\n    \n    /* Security: Close server socket */\n    if (server->server_fd >= 0) {\n        close(server->server_fd);\n        server->server_fd = -1;\n    }\n    \n    pthread_mutex_destroy(&server->clients_mutex);\n}\n\n/* Receive messages thread for client */\nvoid* client_receive_messages(void* arg) {\n    ChatClient* client = NULL;\n    char buffer[MAX_MESSAGE_SIZE];\n    ssize_t bytes_read;\n    \n    /* Security: Validate argument pointer */\n    if (arg == NULL) {\n        return NULL;\n    }\n    \n    client = (ChatClient*)arg;\n    \n    while (atomic_load(&client->running)) {\n        /* Security: Clear buffer before reading */\n        memset(buffer, 0, sizeof(buffer));\n        \n        /* Security: Use recv with size limit */\n        bytes_read = recv(client->sock_fd, buffer, MAX_MESSAGE_SIZE - 1, 0);\n        \n        /* Security: Check return value */\n        if (bytes_read <= 0) {\n            break;\n        }\n        \n        /* Security: Ensure null-termination */\n        buffer[bytes_read] = '\\0';\n        printf("%s\\n", buffer);\n    }\n    \n    return NULL;\n}\n\n/* Initialize client structure */\nint client_init(ChatClient* client) {\n    /* Security: Validate pointer */\n    if (client == NULL) {\n        return 0;\n    }\n    \n    /* Security: Initialize all members to safe values */\n    client->sock_fd = -1;\n    atomic_init(&client->running, 0);\n    client->recv_thread = 0;\n    \n    return 1;\n}\n\n/* Connect client to server */\nint client_connect(ChatClient* client, const char* ip, int port) {\n    struct sockaddr_in serv_addr;\n    \n    /* Security: Validate pointers and port range */\n    if (client == NULL || ip == NULL || port < MIN_PORT || port > MAX_PORT) {\n        return 0;\n    }\n    \n    /* Security: Create socket with error checking */\n    client->sock_fd = socket(AF_INET, SOCK_STREAM, 0);\n    if (client->sock_fd < 0) {\n        return 0;\n    }\n    \n    /* Security: Initialize address structure */\n    memset(&serv_addr, 0, sizeof(serv_addr));\n    serv_addr.sin_family = AF_INET;\n    serv_addr.sin_port = htons((uint16_t)port);\n    \n    /* Security: Validate IP address conversion */\n    if (inet_pton(AF_INET, ip, &serv_addr.sin_addr) <= 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n        return 0;\n    }\n    \n    /* Security: Check connect return value */\n    if (connect(client->sock_fd, (struct sockaddr*)&serv_addr, sizeof(serv_addr)) < 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n        return 0;\n    }\n    \n    atomic_store(&client->running, 1);\n    \n    /* Security: Create receive thread with error checking */\n    if (pthread_create(&client->recv_thread, NULL, client_receive_messages, client) != 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n        atomic_store(&client->running, 0);\n        return 0;\n    }\n    \n    pthread_detach(client->recv_thread);\n    return 1;\n}\n\n/* Send message from client */\nint client_send_message(ChatClient* client, const char* message) {\n    ssize_t sent;\n    size_t msg_len;\n    \n    /* Security: Validate pointers */\n    if (client == NULL || message == NULL) {\n        return 0;\n    }\n    \n    /* Security: Validate message size before sending */\n    msg_len = strnlen(message, MAX_MESSAGE_SIZE);\n    if (msg_len == 0 || msg_len >= MAX_MESSAGE_SIZE) {\n        return 0;\n    }\n    \n    /* Security: Use send with MSG_NOSIGNAL */\n    sent = send(client->sock_fd, message, msg_len, MSG_NOSIGNAL);\n    return sent > 0;\n}\n\n/* Disconnect client and cleanup */\nvoid client_disconnect(ChatClient* client) {\n    if (client == NULL) {\n        return;\n    }\n    \n    atomic_store(&client->running, 0);\n    \n    if (client->sock_fd >= 0) {\n        close(client->sock_fd);\n        client->sock_fd = -1;\n    }\n}\n\n/* Server thread function for testing */\nvoid* server_thread_func(void* arg) {\n    ChatServer* server = (ChatServer*)arg;\n    if (server != NULL) {\n        server_start(server, 8080);\n    }\n    return NULL;\n}\n\nint main(void) {\n    ChatServer server;\n    ChatClient client1;\n    ChatClient client2;\n    pthread_t server_thread;\n    \n    printf("=== Test Case 1: Server Initialization ===\\n");\n    /* Security: Check initialization return value */\n    if (!server_init(&server)) {\n        fprintf(stderr, "Server initialization failed\\n");\n        return 1;\n    }\n    \n    /* Security: Check thread creation return value */\n    if (pthread_create(&server_thread, NULL, server_thread_func, &server) != 0) {\n        fprintf(stderr, "Failed to create server thread\\n");\n        return 1;\n    }\n    \n    usleep(500000); /* Wait for server to start */\n    \n    printf("=== Test Case 2: Client 1 Connection ===\\n");\n    /* Security: Check initialization and connection */\n    if (!client_init(&client1)) {\n        fprintf(stderr, "Client 1 initialization failed\\n");\n        server_stop(&server);\n        pthread_join(server_thread, NULL);\n        return 1;\n    }\n    \n    if (client_connect(&client1, "127.0.0.1", 8080)) {\n        printf("Client 1 connected\\n");\n    } else {\n        fprintf(stderr, "Client 1 connection failed\\n");\n    }\n    \n    printf("=== Test Case 3: Send Message ===\\n");\n    client_send_message(&client1, "Hello from client 1");\n    usleep(200000);\n    \n    printf("=== Test Case 4: Multiple Clients ===\\n");\n    /* Security: Check initialization and connection */\n    if (!client_init(&client2)) {\n        fprintf(stderr, "Client 2 initialization failed\\n");\n        client_disconnect(&client1);\n        server_stop(&server);\n        pthread_join(server_thread, NULL);\n        return 1;\n    }\n    \n    if (client_connect(&client2, "127.0.0.1", 8080)) {\n        printf("Client 2 connected\\n");\n    } else {\n        fprintf(stderr, "Client 2 connection failed\\n");\n    }\n    \n    client_send_message(&client2, "Hello from client 2");\n    usleep(200000);\n    \n    printf("=== Test Case 5: Cleanup ===\\n");\n    client_disconnect(&client1);\n    client_disconnect(&client2);\n    server_stop(&server);\n    pthread_join(server_thread, NULL);\n    \n    printf("All tests completed\\n");\n    return 0;\n}\n```', type='text')
