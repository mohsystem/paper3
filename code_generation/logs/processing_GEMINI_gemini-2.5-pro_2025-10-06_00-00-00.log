    concatenatedStr = stringConcat(emptyStr, textStr);
    std::cout << "Concatenated: \"\" + \"" << textStr << "\" = \"" << concatenatedStr << "\"" << std::endl;

    reversedStr = stringReverse(emptyStr);
    std::cout << "Original: \"\", Reversed: \"" << reversedStr << "\"" << std::endl;
    std::cout << std::endl;

