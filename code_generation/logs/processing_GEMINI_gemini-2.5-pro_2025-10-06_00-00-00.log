        // Test Case 5: With null values in the array
        String[] input5 = {"Java", " is ", null, "awesome", null, "."};
        System.out.println("Test Case 5: " + concatenateStrings(input5));
        System.out.println("Expected: Java is awesome.");
        System.out.println("--------------------");
    }
}
