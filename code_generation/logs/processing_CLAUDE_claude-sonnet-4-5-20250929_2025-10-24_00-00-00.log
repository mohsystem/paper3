NULL && response->data != NULL) {\n        /* Security: Clear buffer before freeing (memset_s not available everywhere, using memset) */\n        memset(response->data, 0, response->capacity);\n        free(response->data);\n        response->data = NULL;\n        response->size = 0;\n        response->capacity = 0;\n    }\n}\n\n/**\n * Callback function for libcurl to write response data.\n * Security: Enforces size limit, validates buffer operations.\n */\nsize_t writeCallback(void* contents, size_t size, size_t nmemb, void* userp) {\n    size_t realsize;\n    ResponseData* response = (ResponseData*)userp;\n    \n    /* Security: Check for null pointer */\n    if (contents == NULL || userp == NULL) {\n        return 0;\n    }\n    \n    /* Security: Check for integer overflow before multiplication */\n    if (nmemb > 0 && size > SIZE_MAX / nmemb) {\n        return 0;\n    }\n    \n    realsize = size * nmemb;\n    \n    /* Security: Check size limit to prevent memory exhaustion */\n    if (realsize > MAX_RESPONSE_SIZE || response->size > MAX_RESPONSE_SIZE - realsize) {\n        return 0;\n    }\n    \n    /* Security: Check if buffer needs to grow */\n    if (response->size + realsize + 1 > response->capacity) {\n        size_t new_capacity = response->capacity * 2;\n        \n        /* Security: Cap growth at MAX_RESPONSE_SIZE */\n        if (new_capacity > MAX_RESPONSE_SIZE) {\n            new_capacity = MAX_RESPONSE_SIZE;\n        }\n        \n        /* Security: Check that new size will fit */\n        if (response->size + realsize + 1 > new_capacity) {\n            return 0;\n        }\n        \n        /* Security: Use realloc safely */\n        char* new_data = (char*)realloc(response->data, new_capacity);\n        if (new_data == NULL) {\n            return 0;\n        }\n        \n        response->data = new_data;\n        response->capacity = new_capacity;\n    }\n    \n    /* Security: Bounds-checked copy using memcpy */\n    memcpy(response->data +