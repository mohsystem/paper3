each character - prevent injection and traversal */\n    for (i = 0; i < len; i++) {\n        unsigned char c = (unsigned char)filename[i];\n        \n        /* Security: Reject null bytes (CWE-158) */\n        if (c == '\\0') {\n            fprintf(stderr, "Error: Null byte in filename\\n");\n            return 0;\n        }\n        \n        /* Security: Reject path separators and control characters */\n        if (c == '/' || c == '\\\\' || c < 32 || c == 127) {\n            fprintf(stderr, "Error: Invalid character in filename\\n");\n            return 0;\n        }\n        \n        /* Security: Check for path traversal sequences */\n        if (c == '.' && i > 0 && filename[i-1] == '.') {\n            fprintf(stderr, "Error: '..' sequence not allowed\\n");\n            return 0;\n        }\n    }\n    \n    /* Security: Additional check for dangerous names */\n    if (strcmp(filename, ".") == 0 || strcmp(filename, "..") == 0) {\n        fprintf(stderr, "Error: Invalid filename\\n");\n        return 0;\n    }\n    \n    return 1;\n}\n\n/* Security: Constructs safe file path within base directory\n * Prevents path traversal by validating and containing paths (CWE-22, CWE-73)\n */\nstatic int construct_safe_path(const char* filename, char* full_path, size_t path_size) {\n    int result;\n    size_t base_len;\n    size_t name_len;\n    \n    /* Security: Validate inputs */\n    if (filename == NULL || full_path == NULL || path_size == 0) {\n        return 0;\n    }\n    \n    /* Security: Validate filename before using it */\n    if (!validate_filename(filename)) {\n        return 0;\n    }\n    \n    base_len = strlen(BASE_UPLOAD_DIR);\n    name_len = strlen(filename);\n    \n    /* Security: Check for integer overflow before addition (CWE-190) */\n    if (base_len > SIZE_MAX - name_len - 2) {\n        fprintf(stderr, "Error: Path length calculation overflow\\n");\n        return 0;\n    }\n    \n    /* Security: Ensure buffer is large enough (CWE-120, CWE-131) */\n    if (base_len + 1 + name_len + 1 > path_size) {\n        fprintf(stderr, "Error: Path too long\\n");\n        return 0;\n    }\n    \n    /* Security: Use snprintf for safe string formatting (CWE-120) */\n    result = snprintf(full_path, path_size, "%s/%s", BASE_UPLOAD_DIR, filename);\n    \n    /* Security: Check snprintf result */\n    if (result < 0 || (size_t)result >= path_size) {\n        fprintf(stderr, "Error: Path construction failed\\n");\n        return 0;\n    }\n    \n    return 1;\n}\n\n/* Security: Creates upload directory with restrictive permissions (CWE-732)\n * Uses 0700 permissions to prevent unauthorized access\n */\nstatic int ensure_upload_directory(void) {\n    struct stat st;\n    \n    /* Security: Check if directory exists */\n    if (stat(BASE_UPLOAD_DIR, &st) == 0) {\n        /* Security: Verify it's a directory */\n        if (!S_ISDIR(st.st_mode)) {\n            fprintf(stderr, "Error: Upload path exists but is not a directory\\n");\n            return 0;\n        }\n        return 1;\n    }\n    \n    /* Security: Create with restrictive permissions (CWE-732) */\n    if (mkdir(BASE_UPLOAD_DIR, 0700) != 0) {\n        fprintf(stderr, "Error: Failed to create upload directory: %s\\n", strerror(errno));\n        return 0;\n    }\n    \n    return 1;\n}\n\n/* Security: Race-condition safe file upload using open-then-validate pattern (CWE-367, CWE-363)\n * Prevents TOCTOU by opening file first, then validating the file descriptor\n * Uses O_CREAT|O_EXCL to prevent overwriting existing files (CWE-59)\n */\nstatic int upload_file_safe(const char* filename, const unsigned char* data, size_t data_size) {\n    char full_path[MAX_PATH_LEN];\n    int fd = -1;\n    struct stat st;\n    ssize_t written;\n    size_t total_written = 0;\n    int fsync_result;\n    \n    /* Security: Input validation (CWE-20) */\n    if (filename == NULL || data == NULL) {\n        fprintf(stderr, "Error: Invalid input parameters\\n");\n        return 0;\n    }\n    \n    /* Security: Validate file size to prevent DoS (CWE-400) */\n    if (data_size == 0 || data_size > MAX_FILE_SIZE) {\n        fprintf(stderr, "Error: Invalid file size\\n");\n        return 0;\n    }\n    \n    /* Security: Ensure upload directory exists */\n    if (!ensure_upload_directory()) {\n        return 0;\n    }\n    \n    /* Security: Construct safe path within base directory (CWE-22) */\n    if (!construct_safe_path(filename, full_path, sizeof(full_path))) {\n        return 0;\n    }\n    \n    /* Security: Open file with restrictive flags and permissions (CWE-367, CWE-732)\n     * O_CREAT|O_EXCL: Fails if file exists, prevents race conditions (CWE-59)\n     * O_WRONLY: Write-only access\n     * O_CLOEXEC: Close on exec for security\n     * 0600: Owner read/write only (CWE-732)\n     */\n    fd = open(full_path, O_CREAT | O_EXCL | O_WRONLY | O_CLOEXEC, 0600);\n    if (fd < 0) {\n        if (errno == EEXIST) {\n            fprintf(stderr, "Error: File already exists\\n");\n        } else {\n            fprintf(stderr, "Error: Failed to create file: %s\\n", strerror(errno));\n        }\n        return 0;\n    }\n    \n    /* Security: Validate the opened file descriptor (CWE-367)\n     * This prevents TOCTOU by checking the already-opened file\n     */\n    if (fstat(fd, &st) != 0) {\n        fprintf(stderr, "Error: Failed to stat file: %s\\n", strerror(errno));\n        close(fd);\n        unlink(full_path); /* Clean up on error */\n        return 0;\n    }\n    \n    /* Security: Ensure it's a regular file, not a symlink or device (CWE-59) */\n    if (!S_ISREG(st.st_mode)) {\n        fprintf(stderr, "Error: Not a regular file\\n");\n        close(fd);\n        unlink(full_path);\n        return 0;\n    }\n    \n    /* Security: Write data in chunks with error checking (CWE-391, CWE-252)\n     * Check all write return values to prevent data corruption\n     */\n    while (total_written < data_size) {\n        size_t remaining = data_size - total_written;\n        size_t to_write = (remaining < BUFFER_SIZE) ? remaining : BUFFER_SIZE;\n        \n        written = write(fd, data + total_written, to_write);\n        \n        /* Security: Check write result (CWE-252) */\n        if (written < 0) {\n            fprintf(stderr, "Error: Write failed: %s\\n", strerror(errno));\n            close(fd);\n            unlink(full_path); /* Clean up on error */\n            return 0;\n        }\n        \n        /* Security: Check for integer overflow (CWE-190) */\n        if (total_written > SIZE_MAX - (size_t)written) {\n            fprintf(stderr, "Error: Write size overflow\\n");\n            close(fd);\n            unlink(full_path);\n            return 0;\n        }\n        \n        total_written += (size_t)written;\n    }\n    \n    /* Security: Ensure data is written to disk (CWE-662) */\n    fsync_result = fsync(fd);\n    if (fsync_result != 0) {\n        fprintf(stderr, "Warning: fsync failed: %s\\n", strerror(errno));\n    }\n    \n    /* Security: Close file and check result (CWE-252) */\n    if (close(fd) != 0) {\n        fprintf(stderr, "Error: Failed to close file: %s\\n", strerror(errno));\n        unlink(full_path); /* Clean up on error */\n        return 0;\n    }\n    \n    printf("Success: File '%s' uploaded successfully (%zu bytes)\\n", filename, data_size);\n    return 1;\n}\n\n/* Test function with 5 test cases */\nint main(void) {\n    unsigned char test_data1[] = "This is test file content for test case 1.";\n    unsigned char test_data2[] = "Test case 2: Different content with more data to test buffer handling.";\n    unsigned char test_data3[] = "Small";\n    unsigned char large_data[1024];\n    unsigned char test_data5[] = "Final test case with normal content.";\n    size_t i;\n    \n    printf("=== File Upload Server Test Cases ===\\n\\n");\n    \n    /* Test Case 1: Normal file upload */\n    printf("Test 1: Normal file upload\\n");\n    if (upload_file_safe("test1.txt", test_data1, sizeof(test_data1) - 1)) {\n        printf("Test 1: PASSED\\n\\n");\n    } else {\n        printf("Test 1: FAILED\\n\\n");\n    }\n    \n    /* Test Case 2: Another normal file with different content */\n    printf("Test 2: Different content file\\n");\n    if (upload_file_safe("test2.txt", test_data2, sizeof(test_data2) - 1)) {\n        printf("Test 2: PASSED\\n\\n");\n    } else {\n        printf("Test 2: FAILED\\n\\n");\n    }\n    \n    /* Test Case 3: Small file */\n    printf("Test 3: Small file upload\\n");\n    if (upload_file_safe("small_file.txt", test_data3, sizeof(test_data3) - 1)) {\n        printf("Test 3: PASSED\\n\\n");\n    } else {\n        printf("Test 3: FAILED\\n\\n");\n    }\n    \n    /* Test Case 4: Larger file to test buffering */\n    printf("Test 4: Larger file upload\\n");\n    for (i = 0; i < sizeof(large_data); i++) {\n        large_data[i] = (unsigned char)('A' + (i % 26));\n    }\n    if (upload_file_safe("large_test.txt", large_data, sizeof(large_data))) {\n        printf("Test 4: PASSED\\n\\n");\n    } else {\n        printf("Test 4: FAILED\\n\\n");\n    }\n    \n    /* Test Case 5: Security test - attempt path traversal (should fail) */\n    printf("Test 5: Security test - path traversal attempt (should fail)\\n");\n    if (!upload_file_safe("../etc/passwd", test_data5, sizeof(test_data5) - 1)) {\n        printf("Test 5: PASSED (correctly rejected malicious filename)\\n\\n");\n    } else {\n        printf("Test 5: FAILED (security vulnerability detected!)\\n\\n");\n    }\n    \n    /* Security: Clear sensitive data before exit */\n    explicit_zero(test_data1, sizeof(test_data1));\n    explicit_zero(test_data2, sizeof(test_data2));\n    explicit_zero(test_data3, sizeof(test_data3));\n    explicit_zero(large_data, sizeof(large_data));\n    explicit_zero(test_data5, sizeof(test_data5));\n    \n    printf("=== All tests completed ===\\n");\n    return 0;\n}\n```\n\n```Python\nimport os\nimport sys\nimport secrets\nfrom pathlib import Path\nfrom typing import Optional\n\n# Security: Maximum file size to prevent DoS and memory exhaustion (CWE-400)\nMAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB\n# Security: Maximum filename length to prevent buffer issues (CWE-120)\nMAX_FILENAME_LEN = 255\n# Security: Base directory for uploads - prevents path traversal (CWE-22)\nBASE_UPLOAD_DIR = "./uploads"\n\n\ndef validate_filename(filename: str) -> bool:\n    """\n    Security: Validates filename to prevent path traversal attacks (CWE-22, CWE-73)\n    Rejects: "..", "/", "\\\\", null bytes, and control characters\n    Only allows: safe alphanumeric and basic punctuation\n    """\n    # Security: Type and null check (CWE-20)\n    if not filename or not isinstance(filename, str):\n        print("Error: Invalid filename type", file=sys.stderr)\n        return False\n    \n    # Security: Length validation (CWE-120, CWE-131)\n    if len(filename) == 0 or len(filename) > MAX_FILENAME_LEN:\n        print("Error: Invalid filename length", file=sys.stderr)\n        return False\n    \n    # Security: Reject hidden files and files starting with path separators (CWE-22)\n    if filename[0] in ('.', '/', '\\\\'):\n        print("Error: Filename cannot start with '.', '/', or '\\\\'", file=sys.stderr)\n        return False\n    \n    # Security: Check for null bytes (CWE-158)\n    if '\\0' in filename:\n        print("Error: Null byte in filename", file=sys.stderr)\n        return False\n    \n    # Security: Check for path traversal sequences (CWE-22)\n    if '..' in filename or '/' in filename or '\\\\' in filename:\n        print("Error: Path traversal characters not allowed", file=sys.stderr)\n        return False\n    \n    # Security: Reject control characters (CWE-20)\n    for char in filename:\n        if ord(char) < 32 or ord(char) == 127:\n            print("Error: Control characters not allowed", file=sys.stderr)\n            return False\n    \n    # Security: Additional dangerous filename checks\n    if filename in ('.', '..'):\n        print("Error: Invalid filename", file=sys.stderr)\n        return False\n    \n    return True\n\n\ndef construct_safe_path(filename: str) -> Optional[Path]:\n    """\n    Security: Constructs and validates safe file path within base directory (CWE-22, CWE-73)\n    Returns None if path would escape base directory\n    """\n    # Security: Validate filename first (CWE-20)\n    if not validate_filename(filename):\n        return None\n    \n    try:\n        # Security: Construct path and resolve it to absolute path\n        base_path = Path(BASE_UPLOAD_DIR).resolve()\n        target_path = (base_path / filename).resolve()\n        \n        # Security: Ensure target path is within base directory (CWE-22)\n        # This prevents path traversal even with symlinks\n        if not str(target_path).startswith(str(base_path) + os.sep):\n            print("Error: Path traversal detected", file=sys.stderr)\n            return None\n        \n        # Security: Additional check using relative_to\n        try:\n            target_path.relative_to(base_path)\n        except ValueError:\n            print("Error: Path outside base directory", file=sys.stderr)\n            return None\n        \n        return target_path\n        \n    except (OSError, ValueError) as e:\n        print(f"Error: Path construction failed: {e}", file=sys.stderr)\n        return None\n\n\ndef ensure_upload_directory() -> bool:\n    """\n    Security: Creates upload directory with restrictive permissions (CWE-732)\n    Directory mode 0o700 allows only owner access\n    """\n    try:\n        upload_dir = Path(BASE_UPLOAD_DIR)\n        \n        if upload_dir.exists():\n            # Security: Verify it's actually a directory (CWE-22)\n            if not upload_dir.is_dir():\n                print("Error: Upload path exists but is not a directory", file=sys.stderr)\n                return False\n            return True\n        \n        # Security: Create directory with restrictive permissions (CWE-732)\n        upload_dir.mkdir(mode=0o700, parents=False, exist_ok=False)\n        return True\n        \n    except OSError as e:\n        print(f"Error: Failed to create upload directory: {e}", file=sys.stderr)\n        return False\n\n\ndef upload_file_safe(filename: str, data: bytes) -> bool:\n    """\n    Security: Race-condition safe file upload using open-then-validate pattern (CWE-367, CWE-363)\n    Uses O_CREAT|O_EXCL flags to prevent overwriting and TOCTOU issues (CWE-59)\n    """\n    # Security: Input validation (CWE-20)\n    if not filename or not isinstance(filename, str):\n        print("Error: Invalid filename", file=sys.stderr)\n        return False\n    \n    if not isinstance(data, bytes):\n        print("Error: Data must be bytes", file=sys.stderr)\n        return False\n    \n    # Security: Validate file size to prevent DoS (CWE-400)\n    if len(data) == 0 or len(data) > MAX_FILE_SIZE:\n        print("Error: Invalid file size", file=sys.stderr)\n        return False\n    \n    # Security: Ensure upload directory exists with proper permissions\n    if not ensure_upload_directory():\n        return False\n    \n    # Security: Construct and validate safe path (CWE-22)\n    target_path = construct_safe_path(filename)\n    if target_path is None:\n        return False\n    \n    fd = None\n    try:\n        # Security: Open file with exclusive creation (CWE-367, CWE-59, CWE-732)\n        # os.O_CREAT | os.O_EXCL: Fails if file exists (prevents race conditions)\n        # os.O_WRONLY: Write-only access\n        # os.O_CLOEXEC: Close on exec for security\n        # Mode 0o600: Owner read/write only (restrictive permissions)\n        fd = os.open(\n            target_path,\n            os.O_CREAT | os.O_EXCL | os.O_WRONLY | os.O_CLOEXEC,\n            mode=0o600\n        )\n        \n        # Security: Validate the opened file descriptor (CWE-367)\n        # This prevents TOCTOU by checking the already-opened file\n        stat_info = os.fstat(fd)\n        \n        # Security: Ensure it's a regular file (CWE-59)\n        import stat\n        if not stat.S_ISREG(stat_info.st_mode):\n            print("Error: Not a regular file", file=sys.stderr)\n            os.close(fd)\n            os.unlink(target_path)\n            return False\n        \n        # Security: Write data and check result (CWE-252)\n        bytes_written = os.write(fd, data)\n        \n        if bytes_written != len(data):\n            print("Error: Incomplete write", file=sys.stderr)\n            os.close(fd)\n            os.unlink(target_path)\n            return False\n        \n        # Security: Ensure data is written to disk (CWE-662)\n        os.fsync(fd)\n        \n        # Security: Close file descriptor (CWE-404)\n        os.close(fd)\n        fd = None\n        \n        print(f"Success: File '{filename}' uploaded successfully ({len(data)} bytes)")\n        return True\n        \n    except FileExistsError:\n        print("Error: File already exists", file=sys.stderr)\n        if fd is not None:\n            os.close(fd)\n        return False\n        \n    except OSError as e:\n        print(f"Error: File operation failed: {e}", file=sys.stderr)\n        if fd is not None:\n            os.close(fd)\n        # Security: Clean up on error\n        try:\n            if target_path and target_path.exists():\n                os.unlink(target_path)\n        except OSError:\n            pass\n        return False\n        \n    except Exception as e:\n        print(f"Error: Unexpected error: {e}", file=sys.stderr)\n        if fd is not None:\n            os.close(fd)\n        # Security: Clean up on error\n        try:\n            if target_path and target_path.exists():\n                os.unlink(target_path)\n        except OSError:\n            pass\n        return False\n\n\ndef main():\n    """Test function with 5 test cases"""\n    print("=== File Upload Server Test Cases ===\\n")\n    \n    # Test Case 1: Normal file upload\n    print("Test 1: Normal file upload")\n    test_data1 = b"This is test file content for test case 1."\n    if upload_file_safe("test1.txt", test_data1):\n        print("Test 1: PASSED\\n")\n    else:\n        print("Test 1: FAILED\\n")\n    \n    # Test Case 2: Different content file\n    print("Test 2: Different content file")\n    test_data2 = b"Test case 2: Different content with more data to test handling."\n    if upload_file_safe("test2.txt", test_data2):\n        print("Test 2: PASSED\\n")\n    else:\n        print("Test 2: FAILED\\n")\n    \n    # Test Case 3: Small file\n    print("Test 3: Small file upload")\n    test_data3 = b"Small"\n    if upload_file_safe("small_file.txt", test_data3):\n        print("Test 3: PASSED\\n")\n    else:\n        print("Test 3: FAILED\\n")\n    \n    # Test Case 4: Larger file\n    print("Test 4: Larger file upload")\n    # Security: Use secrets module for generating random test data\n    large_data = bytes([(65 + (i % 26)) for i in range(1024)])\n    if upload_file_safe("large_test.txt", large_data):\n        print("Test 4: PASSED\\n")\n    else:\n        print("Test 4: FAILED\\n")\n    \n    # Test Case 5: Security test - path traversal attempt (should fail)\n    print("Test 5: Security test - path traversal attempt (should fail)")\n    test_data5 = b"Malicious content"\n    if not upload_file_safe("../etc/passwd", test_data5):\n        print("Test 5: PASSED (correctly rejected malicious filename)\\n")\n    else:\n        print("Test 5: FAILED (security vulnerability detected!)\\n")\n    \n    print("=== All tests completed ===")\n\n\nif __name__ == "__main__":\n    main()\n```\n\n```Java\nimport java.io.*;\nimport java.nio.file.*;\nimport java.nio.file.attribute.PosixFilePermission;\nimport java.nio.file.attribute.PosixFilePermissions;\nimport java.security.SecureRandom;\nimport java.util.*;\n\npublic class Task50 {\n    // Security: Maximum file size to prevent DoS and memory exhaustion (CWE-400)\n    private static final long MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB\n    // Security: Maximum filename length to prevent buffer issues (CWE-120)\n    private static final int MAX_FILENAME_LEN = 255;\n    // Security: Base directory for uploads - prevents path traversal (CWE-22)\n    private static final String BASE_UPLOAD_DIR = "./uploads";\n    // Security: Buffer size for safe file operations\n    private static final int BUFFER_SIZE = 8192;\n\n    /**\n     * Security: Validates filename to prevent path traversal attacks (CWE-22, CWE-73)\n     * Rejects: "..", "/", "\\\\", null bytes, and control characters\n     * Only allows: safe characters for filenames\n     */\n    private static boolean validateFilename(String filename) {\n        // Security: Null and empty check (CWE-20)\n        if (filename == null || filename.isEmpty()) {\n            System.err.println("Error: Invalid filename");\n            return false;\n        }\n\n        // Security: Length validation (CWE-120, CWE-131)\n        if (filename.length() > MAX_FILENAME_LEN) {\n            System.err.println("Error: Filename too long");\n            return false;\n        }\n\n        // Security: Reject files starting with dangerous characters (CWE-22)\n        char firstChar = filename.charAt(0);\n        if (firstChar == '.' || firstChar == '/' || firstChar == '\\\\') {\n            System.err.println("Error: Filename cannot start with '.', '/', or '\\\\'");\n            return false;\n        }\n\n        // Security: Check for null bytes and path traversal (CWE-158, CWE-22)\n        if (filename.contains("\\0") || filename.contains("..") || \n            filename.contains("/") || filename.contains("\\\\")) {\n            System.err.println("Error: Invalid characters in filename");\n            return false;\n        }\n\n        // Security: Reject control characters (CWE-20)\n        for (char c : filename.toCharArray()) {\n            if (c < 32 || c == 127) {\n                System.err.println("Error: Control characters not allowed");\n                return false;\n            }\n        }\n\n        // Security: Reject dangerous filenames\n        if (filename.equals(".") || filename.equals("..")) {\n            System.err.println("Error: Invalid filename");\n            return false;\n        }\n\n        return true;\n    }\n\n    /**\n     * Security: Constructs and validates safe file path within base directory (CWE-22, CWE-73)\n     * Returns null if path would escape base directory\n     */\n    private static Path constructSafePath(String filename) {\n        // Security: Validate filename first (CWE-20)\n        if (!validateFilename(filename)) {\n            return null;\n        }\n\n        try {\n            // Security: Construct path and normalize it (CWE-22)\n            Path basePath = Paths.get(BASE_UPLOAD_DIR).toRealPath(LinkOption.NOFOLLOW_LINKS);\n            Path targetPath = basePath.resolve(filename).normalize();\n\n            // Security: Ensure target path is within base directory (CWE-22)\n            // This prevents path traversal attacks\n            if (!targetPath.startsWith(basePath)) {\n                System.err.println("Error: Path traversal detected");\n                return null;\n            }\n\n            // Security: Additional check to prevent symlink attacks (CWE-59)\n            if (Files.exists(targetPath, LinkOption.NOFOLLOW_LINKS)) {\n                if (Files.isSymbolicLink(targetPath)) {\n                    System.err.println("Error: Symbolic links not allowed");\n                    return null;\n                }\n            }\n\n            return targetPath;\n\n        } catch (IOException e) {\n            System.err.println("Error: Path construction failed: " + e.getMessage());\n            return null;\n        }\n    }\n\n    /**\n     * Security: Creates upload directory with restrictive permissions (CWE-732)\n     * Uses permissions that allow only owner access\n     */\n    private static boolean ensureUploadDirectory() {\n        try {\n            Path uploadDir = Paths.get(BASE_UPLOAD_DIR);\n\n            if (Files.exists(uploadDir)) {\n                // Security: Verify it's a directory (CWE-22)\n                if (!Files.isDirectory(uploadDir)) {\n                    System.err.println("Error: Upload path exists but is not a directory");\n                    return false;\n                }\n                return true;\n            }\n\n            // Security: Create directory with restrictive permissions (CWE-732)\n            // On POSIX systems, set owner-only permissions\n            try {\n                Set<PosixFilePermission> perms = PosixFilePermissions.fromString("rwx------");\n                Files.createDirectory(uploadDir, PosixFilePermissions.asFileAttribute(perms));\n            } catch (UnsupportedOperationException e) {\n                // On non-POSIX systems (Windows), create directory normally\n                Files.createDirectory(uploadDir);\n            }\n\n            return true;\n\n        } catch (IOException e) {\n            System.err.println("Error: Failed to create upload directory: " + e.getMessage());\n            return false;\n        }\n    }\n\n    /**\n     * Security: Race-condition safe file upload using atomic operations (CWE-367, CWE-363)\n     * Uses StandardOpenOption.CREATE_NEW to prevent overwriting (CWE-59)\n     */\n    public static boolean uploadFileSafe(String filename, byte[] data) {\n        // Security: Input validation (CWE-20)\n        if (filename == null || data == null) {\n            System.err.println("Error: Invalid input parameters");\n            return false;\n        }\n\n        // Security: Validate file size to prevent DoS (CWE-400)\n        if (data.length == 0 || data.length > MAX_FILE_SIZE) {\n            System.err.println("Error: Invalid file size");\n            return false;\n        }\n\n        // Security: Ensure upload directory exists with proper permissions\n        if (!ensureUploadDirectory()) {\n            return false;\n        }\n\n        // Security: Construct and validate safe path (CWE-22)\n        Path targetPath = constructSafePath(filename);\n        if (targetPath == null) {\n            return false;\n        }\n\n        // Security: Use try-with-resources for automatic resource management (CWE-404, CWE-772)\n        try (OutputStream out = Files.newOutputStream(targetPath,\n                StandardOpenOption.CREATE_NEW,    // Fails if file exists (CWE-59, CWE-367)\n                StandardOpenOption.WRITE,          // Write mode\n                StandardOpenOption.SYNC)) {        // Synchronous writes (CWE-662)\n\n            // Security: Write data in a single operation (CWE-252)\n            out.write(data);\n\n            // Security: Explicit flush to ensure data is written (CWE-662)\n            out.flush();\n\n            System.out.println("Success: File '" + filename + "' uploaded successfully (" + \n                             data.length + " bytes)");\n            return true;\n\n        } catch (FileAlreadyExistsException e) {\n            System.err.println("Error: File already exists");\n            return false;\n\n        } catch (IOException e) {\n            System.err.println("Error: File operation failed: " + e.getMessage());\n            // Security: Clean up on error (CWE-459)\n            try {\n                Files.deleteIfExists(targetPath);\n            } catch (IOException cleanupEx) {\n                // Log but don't fail on cleanup error\n                System.err.println("Warning: Cleanup failed: " + cleanupEx.getMessage());\n            }\n            return false;\n\n        } catch (Exception e) {\n            System.err.println("Error: Unexpected error: " + e.getMessage());\n            // Security: Clean up on error\n            try {\n                Files.deleteIfExists(targetPath);\n            } catch (IOException cleanupEx) {\n                System.err.println("Warning: Cleanup failed: " + cleanupEx.getMessage());\n            }\n            return false;\n        }\n    }\n\n    /**\n     * Main method with 5 test cases\n     */\n    public static void main(String[] args) {\n        System.out.println("=== File Upload Server Test Cases ===\\n");\n\n        // Test Case 1: Normal file upload\n        System.out.println("Test 1: Normal file upload");\n        byte[] testData1 = "This is test file content for test case 1.".getBytes(java.nio.charset.StandardCharsets.UTF_8);\n        if (uploadFileSafe("test1.txt", testData1)) {\n            System.out.println("Test 1: PASSED\\n");\n        } else {\n            System.out.println("Test 1: FAILED\\n");\n        }\n\n        // Test Case 2: Different content file\n        System.out.println("Test 2: Different content file");\n        byte[] testData2 = "Test case 2: Different content with more data to test handling.".getBytes(java.nio.charset.StandardCharsets.UTF_8);\n        if (uploadFileSafe("test2.txt", testData2)) {\n            System.out.println("Test 2: PASSED\\n");\n        } else {\n            System.out.println("Test 2: FAILED\\n");\n        }\n\n        // Test Case 3: Small file\n        System.out.println("Test 3: Small file upload");\n        byte[] testData3 = "Small".getBytes(java.nio.charset.StandardCharsets.UTF_8);\n        if (uploadFileSafe("small_file.txt", testData3)) {\n            System.out.println("Test 3: PASSED\\n");\n        } else {\n            System.out.println("Test 3: FAILED\\n");\n        }\n\n        // Test Case 4: Larger file\n        System.out.println("Test 4: Larger file upload");\n        byte[] largeData = new byte[1024];\n        // Security: Initialize with predictable test data (not for crypto use)\n        for (int i = 0; i < largeData.length; i++) {\n            largeData[i] = (byte) ('A' + (i % 26));\n        }\n        if (uploadFileSafe("large_test.txt", largeData)) {\n            System.out.println("Test 4: PASSED\\n");\n        } else {\n            System.out.println("Test 4: FAILED\\n");\n        }\n\n        // Test Case 5: Security test - path traversal attempt (should fail)\n        System.out.println("Test 5: Security test - path traversal attempt (should fail)");\n        byte[] testData5 = "Malicious content".getBytes(java.nio.charset.StandardCharsets.UTF_8);\n        if (!uploadFileSafe("../etc/passwd", testData5)) {\n            System.out.println("Test 5: PASSED (correctly rejected malicious filename)\\n");\n        } else {\n            System.out.println("Test 5: FAILED (security vulnerability detected!)\\n");\n        }\n\n        // Security: Clear sensitive data arrays (best effort)\n        Arrays.fill(testData1, (byte) 0);\n        Arrays.fill(testData2, (byte) 0);\n        Arrays.fill(testData3, (byte) 0);\n        Arrays.fill(largeData, (byte) 0);\n        Arrays.fill(testData5, (byte) 0);\n\n        System.out.println("=== All tests completed ===");\n    }\n}\n```\n\n```Go\npackage main\n\nimport (\n\t"errors"\n\t"fmt"\n\t"io"\n\t"os"\n\t"path/filepath"\n\t"strings"\n)\n\n// Security: Maximum file size to prevent DoS and memory exhaustion (CWE-400)\nconst maxFileSize = 10 * 1024 * 1024 // 10 MB\n\n// Security: Maximum filename length to prevent buffer issues (CWE-120)\nconst maxFilenameLen = 255\n\n// Security: Base directory for uploads - prevents path traversal (CWE-22)\nconst baseUploadDir = "./uploads"\n\n// Security: Validates filename to prevent path traversal attacks (CWE-22, CWE-73)\n// Rejects: "..", "/", "\\\\", null bytes, and control characters\nfunc validateFilename(filename string) error {\n\t// Security: Empty check (CWE-20)\n\tif filename == "" {\n\t\treturn errors.New("filename is empty")\n\t}\n\n\t// Security: Length validation (CWE-120, CWE-131)\n\tif len(filename) > maxFilenameLen {\n\t\treturn errors.New("filename too long")\n\t}\n\n\t// Security: Reject files starting with dangerous characters (CWE-22)\n\tif filename[0] == '.' || filename[0] == '/' || filename[0] == '\\\\' {\n\t\treturn errors.New("filename cannot start with '.', '/', or '\\\\'")\n\t}\n\n\t// Security: Check for null bytes and path separators (CWE-158, CWE-22)\n\tif strings.Contains(filename, "\\x00") {\n\t\treturn errors.New("null byte in filename")\n\t}\n\n\tif strings.Contains(filename, "..") || strings.Contains(filename, "/") || strings.Contains(filename, "\\\\") {\n\t\treturn errors.New("invalid characters in filename")\n\t}\n\n\t// Security: Reject control characters (CWE-20)\n\tfor _, c := range filename {\n\t\tif c < 32 || c == 127 {\n\t\t\treturn errors.New("control characters not allowed")\n\t\t}\n\t}\n\n\t// Security: Reject dangerous filenames\n\tif filename == "." || filename == ".." {\n\t\treturn errors.New("invalid filename")\n\t}\n\n\treturn nil\n}\n\n// Security: Constructs and validates safe file path within base directory (CWE-22, CWE-73)\nfunc constructSafePath(filename string) (string, error) {\n\t// Security: Validate filename first (CWE-20)\n\tif err := validateFilename(filename); err != nil {\n\t\treturn "", err\n\t}\n\n\t// Security: Get absolute path of base directory (CWE-22)\n\tbaseAbs, err := filepath.Abs(baseUploadDir)\n\tif err != nil {\n\t\treturn "", fmt.Errorf("failed to resolve base directory: %w", err)\n\t}\n\n\t// Security: Join and clean the path (CWE-22)\n\ttargetPath := filepath.Join(baseAbs, filename)\n\ttargetAbs, err := filepath.Abs(targetPath)\n\tif err != nil {\n\t\treturn "", fmt.Errorf("failed to resolve target path: %w", err)\n\t}\n\n\t// Security: Ensure target path is within base directory (CWE-22)\n\t// This prevents path traversal attacks\n\tif !strings.HasPrefix(targetAbs, baseAbs+string(os.PathSeparator)) && targetAbs != baseAbs {\n\t\treturn "", errors.New("path traversal detected")\n\t}\n\n\treturn targetAbs, nil\n}\n\n// Security: Creates upload directory with restrictive permissions (CWE-732)\nfunc ensureUploadDirectory() error {\n\tinfo, err := os.Stat(baseUploadDir)\n\tif err == nil {\n\t\t// Security: Verify it's a directory (CWE-22)\n\t\tif !info.IsDir() {\n\t\t\treturn errors.New("upload path exists but is not a directory")\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Security: Create directory with restrictive permissions (CWE-732)\n\t// 0700 allows only owner access\n\tif err := os.Mkdir(baseUploadDir, 0700); err != nil {\n\t\treturn fmt.Errorf("failed to create upload directory: %w", err)\n\t}\n\n\treturn nil\n}\n\n// Security: Race-condition safe file upload (CWE-367, CWE-363)\n// Uses O_CREATE|O_EXCL to prevent overwriting and TOCTOU issues (CWE-59)\nfunc uploadFileSafe(filename string, data []byte) error {\n\t// Security: Input validation (CWE-20)\n\tif filename == "" {\n\t\treturn errors.New("invalid filename")\n\t}\n\n\tif data == nil {\n\t\treturn errors.New("data is nil")\n\t}\n\n\t// Security: Validate file size to prevent DoS (CWE-400)\n\tif len(data) == 0 || len(data) > maxFileSize {\n\t\treturn errors.New("invalid file size")\n\t}\n\n\t// Security: Ensure upload directory exists with proper permissions\n\tif err := ensureUploadDirectory(); err != nil {\n\t\treturn err\n\t}\n\n\t// Security: Construct and validate safe path (CWE-22)\n\ttargetPath, err := constructSafePath(filename)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// Security: Open file with exclusive creation (CWE-367, CWE-59, CWE-732)\n\t// O_CREATE|O_EXCL: Fails if file exists (prevents race conditions)\n\t// O_WRONLY: Write-only access\n\t// 0600: Owner read/write only (restrictive permissions)\n\tfile, err := os.OpenFile(targetPath, os.O_WRONLY|os.O_CREATE|os.O_EXCL, 0600)\n\tif err != nil {\n\t\tif os.IsExist(err) {\n\t\t\treturn errors.New("file already exists")\n\t\t}\n\t\treturn fmt.Errorf("failed to create file: %w", err)\n\t}\n\t\n\t// Security: Use defer to ensure file is closed (CWE-404, CWE-772)\n\tdefer func() {\n\t\tif closeErr := file.Close(); closeErr != nil && err == nil {\n\t\t\terr = fmt.Errorf("failed to close file: %w", closeErr)\n\t\t}\n\t}()\n\n\t// Security: Validate the opened file (CWE-367)\n\tinfo, err := file.Stat()\n\tif err != nil {\n\t\t// Clean up on error\n\t\tos.Remove(targetPath)\n\t\treturn fmt.Errorf("failed to stat file: %w", err)\n\t}\n\n\t// Security: Ensure it's a regular file (CWE-59)\n\tif !info.Mode().IsRegular() {\n\t\tos.Remove(targetPath)\n\t\treturn errors.New("not a regular file")\n\t}\n\n\t// Security: Write data and check result (CWE-252)\n\twritten, err := file.Write(data)\n\tif err != nil {\n\t\tos.Remove(targetPath)\n\t\treturn fmt.Errorf("write failed: %w", err)\n\t}\n\n\tif written != len(data) {\n\t\tos.Remove(targetPath)\n\t\treturn errors.New("incomplete write")\n\t}\n\n\t// Security: Ensure data is written to disk (CWE-662)\n\tif err := file.Sync(); err != nil {\n\t\tos.Remove(targetPath)\n\t\treturn fmt.Errorf("sync failed: %w", err)\n\t}\n\n\tfmt.Printf("Success: File '%s' uploaded successfully (%d bytes)\\n", filename, len(data))\n\treturn nil\n}\n\n// Security: Clears sensitive data from memory\nfunc clearBytes(data []byte) {\n\tfor i := range data {\n\t\tdata[i] = 0\n\t}\n}\n\nfunc main() {\n\tfmt.Println("=== File Upload Server Test Cases ===\\n")\n\n\t// Test Case 1: Normal file upload\n\tfmt.Println("Test 1: Normal file upload")\n\ttestData1 := []byte("This is test file content for test case 1.")\n\tif err := uploadFileSafe("test1.txt", testData1); err == nil {\n\t\tfmt.Println("Test 1: PASSED\\n")\n\t} else {\n\t\tfmt.Printf("Test 1: FAILED - %v\\n\\n", err)\n\t}\n\n\t// Test Case 2: Different content file\n\tfmt.Println("Test 2: Different content file")\n\ttestData2 := []byte("Test case 2: Different content with more data to test handling.")\n\tif err := uploadFileSafe("test2.txt", testData2); err == nil {\n\t\tfmt.Println("Test 2: PASSED\\n")\n\t} else {\n\t\tfmt.Printf("Test 2: FAILED - %v\\n\\n", err)\n\t}\n\n\t// Test Case 3: Small file\n\tfmt.Println("Test 3: Small file upload")\n\ttestData3 := []byte("Small")\n\tif err := uploadFileSafe("small_file.txt", testData3); err == nil {\n\t\tfmt.Println("Test 3: PASSED\\n")\n\t} else {\n\t\tfmt.Printf("Test 3: FAILED - %v\\n\\n", err)\n\t}\n\n\t// Test Case 4: Larger file\n\tfmt.Println("Test 4: Larger file upload")\n\tlargeData := make([]byte, 1024)\n\tfor i := range largeData {\n\t\tlargeData[i] = byte('A' + (i % 26))\n\t}\n\tif err := uploadFileSafe("large_test.txt", largeData); err == nil {\n\t\tfmt.Println("Test 4: PASSED\\n")\n\t} else {\n\t\tfmt.Printf("Test 4: FAILED - %v\\n\\n", err)\n\t}\n\n\t// Test Case 5: Security test - path traversal attempt (should fail)\n\tfmt.Println("Test 5: Security test - path traversal attempt (should fail)")\n\ttestData5 := []byte("Malicious content")\n\tif err := uploadFileSafe("../etc/passwd", testData5); err != nil {\n\t\tfmt.Println("Test 5: PASSED (correctly rejected malicious filename)\\n")\n\t} else {\n\t\tfmt.Println("Test 5: FAILED (security vulnerability detected!)\\n")\n\t}\n\n\t// Security: Clear sensitive data before exit\n\tclearBytes(testData1)\n\tclearBytes(testData2)\n\tclearBytes(testData3)\n\tclearBytes(largeData)\n\tclearBytes(testData5)\n\n\tfmt.Println("=== All tests completed ===")\n}\n```', type='text')
