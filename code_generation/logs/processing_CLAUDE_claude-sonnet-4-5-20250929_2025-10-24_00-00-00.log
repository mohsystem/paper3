t(nums, temp, mid + 1, right);\n        count += mergeAndCount(nums, temp, left, mid, right);\n        \n        return count;\n    }\n    \npublic:\n    int reversePairs(vector<int>& nums) {\n        /* Input validation */\n        if (nums.empty() || nums.size() > 50000) {\n            return 0;\n        }\n        \n        /* Create temporary vector for merging */\n        vector<int> temp(nums.size(), 0);\n        \n        /* Count reverse pairs using merge sort */\n        return mergeSortAndCount(nums, temp, 0, static_cast<int>(nums.size()) - 1);\n    }\n};\n\n/* Test driver with 5 test cases */\nint main() {\n    Solution solution;\n    \n    /* Test case 1: Example 1 from problem */\n    vector<int> test1 = {1, 3, 2, 3, 1};\n    cout << "Test 1: [1,3,2,3,1] -> " << solution.reversePairs(test1) << endl;\n    \n    /* Test case 2: Example 2 from problem */\n    vector<int> test2 = {2, 4, 3, 5, 1};\n    cout << "Test 2: [2,4,3,5,1] -> " << solution.reversePairs(test2) << endl;\n    \n    /* Test case 3: Single element */\n    vector<int> test3 = {1};\n    cout << "Test 3: [1] -> " << solution.reversePairs(test3) << endl;\n    \n    /* Test case 4: Already sorted */\n    vector<int> test4 = {1, 2, 3, 4, 5};\n    cout << "Test 4: [1,2,3,4,5] -> " << solution.reversePairs(test4) << endl;\n    \n    /* Test case 5: With negative numbers and edge values */\n    vector<int> test5 = {2147483647, -2147483648, 0, 1};\n    cout << "Test 5: [2147483647,-2147483648,0,1] -> " << solution.reversePairs(test5) << endl;\n    \n    return 0;\n}\n```\n\n```Python\nfrom typing import List\n\nclass Solution:\n    def reversePairs(self, nums: List[int]) -> int:\n        """\n        Count reverse pairs using merge sort\n        Security: Input validation, bounds checking, no overflow issues in Python\n        """\n        # Input validation\n        if not nums or len(nums) == 0:\n            return 0\n        \n        if len(nums) > 50000:\n            return 0\n        \n        # Create temporary array for merging\n        temp = [0] * len(nums)\n        \n        return self._merge_sort_and_count(nums, temp, 0, len(nums) - 1)\n    \n    def _merge_sort_and_count(self, nums: List[int], temp: List[int], left: int, right: int) -> int:\n        """\n        Recursive merge sort that counts reverse pairs\n        Security: Validates bounds at each step\n        """\n        # Boundary check\n        if left >= right:\n            return 0\n        \n        # Calculate mid point (no overflow in Python)\n        mid = left + (right - left) // 2\n        \n        count = 0\n        count += self._merge_sort_and_count(nums, temp, left, mid)\n        count += self._merge_sort_and_count(nums, temp, mid + 1, right)\n        count += self._merge_and_count(nums, temp, left, mid, right)\n        \n        return count\n    \n    def _merge_and_count(self, nums: List[int], temp: List[int], left: int, mid: int, right: int) -> int:\n        """\n        Merge helper that counts cross-boundary reverse pairs\n        Security: All array accesses are bounds-checked by Python\n        """\n        # Input validation\n        if left < 0 or mid < left or right < mid or right >= len(nums):\n            return 0\n        \n        count = 0\n        \n        # Count reverse pairs where i is in left half and j is in right half\n        # Python handles large integers natively, no overflow\n        j = mid + 1\n        for i in range(left, mid + 1):\n            while j <= right and nums[i] > 2 * nums[j]:\n                j += 1\n            count += (j - (mid + 1))\n        \n        # Merge the two sorted halves\n        i = left\n        j = mid + 1\n        k = left\n        \n        while i <= mid and j <= right:\n            if nums[i] <= nums[j]:\n                temp[k] = nums[i]\n                i += 1\n            else:\n                temp[k] = nums[j]\n                j += 1\n            k += 1\n        \n        # Copy remaining elements\n      