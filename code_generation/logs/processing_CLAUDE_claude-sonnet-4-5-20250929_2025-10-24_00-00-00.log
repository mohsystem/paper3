2025-10-24 01:08:03,640 INFO TextBlock(citations=None, text='```python\n#!/usr/bin/env python3\n"""\nSecure JSON fetcher from URL with comprehensive input validation.\nImplements all security requirements including input validation, secure network access,\nand proper error handling.\n"""\n\nimport sys\nimport json\nimport urllib.request\nimport urllib.error\nimport ssl\nfrom typing import Any, Dict, Optional\nfrom urllib.parse import urlparse\n\n\n# Constants for security limits\nMAX_URL_LENGTH = 2048  # Prevent excessive URL lengths\nMAX_RESPONSE_SIZE = 10 * 1024 * 1024  # 10MB limit to prevent memory exhaustion\nALLOWED_SCHEMES = {'https'}  # Only allow HTTPS for security\nTIMEOUT_SECONDS = 30  # Prevent indefinite hangs\n\n\ndef validate_url(url: str) -> bool:\n    """\n    Validate URL input against security requirements.\n    \n    Args:\n        url: The URL string to validate\n        \n    Returns:\n        True if valid, False otherwise\n        \n    Security: Treats input as untrusted, validates length, scheme, and format\n    """\n    # Check URL length to prevent buffer issues\n    if not url or len(url) > MAX_URL_LENGTH:\n        return False\n    \n    # Parse and validate URL structure\n    try:\n        parsed = urlparse(url)\n        \n        # Only allow HTTPS scheme for secure transmission\n        if parsed.scheme not in ALLOWED_SCHEMES:\n            return False\n        \n        # Ensure hostname exists and is not empty\n        if not parsed.netloc:\n            return False\n        \n        # Basic validation that hostname doesn't contain suspicious characters\n        if any(char in parsed.netloc for char in [' ', '\\n', '\\r', '\\t']):\n            return False\n            \n        return True\n        \n    except (ValueError, AttributeError):\n        # urlparse failed - invalid URL format\n        return False\n\n\ndef create_secure_ssl_context() -> ssl.SSLContext:\n    """\n    Create a secure SSL context with proper certificate verification.\n    \n    Returns:\n        Configured SSL context\n        \n    Security: Implements certificate validation, hostname verification,\n    and uses secure protocol versions\n    """\n    # Create SSL context with secure defaults\n    context = ssl.create_default_context()\n    \n    # Ensure certificate verification is enabled (Rules#3)\n    context.check_hostname = True\n    context.verify_mode = ssl.CERT_REQUIRED\n    \n    # Use only secure protocol versions (TLSv1.2+)\n    context.minimum_version = ssl.TLSVersion.TLSv1_2\n    \n    return context\n\n\ndef fetch_json_from_url(url: str) -> Optional[Dict[str, Any]]:\n    """\n    Fetch and parse JSON from a URL with comprehensive security measures.\n    \n    Args:\n        url: The HTTPS URL to fetch JSON from\n        \n    Returns:\n        Parsed JSON object as dictionary, or None on error\n        \n    Security: Validates all inputs, uses secure SSL/TLS, prevents resource exhaustion,\n    handles all exceptions, and validates JSON parsing\n    """\n    # Rule#5: Validate input before processing\n    if not validate_url(url):\n        print("Error: Invalid URL format or insecure scheme. Only HTTPS URLs are allowed.", \n              file=sys.stderr)\n        return None\n    \n    try:\n        # Rule#3 & #4: Create secure SSL context with certificate and hostname verification\n        ssl_context = create_secure_ssl_context()\n        \n        # Create request with security headers\n        request = urllib.request.Request(\n            url,\n            headers={\n                'User-Agent': 'SecureJSONFetcher/1.0',\n                'Accept': 'application/json'\n            }\n        )\n        \n        # Rule#6: Open connection with timeout to prevent indefinite hangs\n        # Use context manager for automatic resource cleanup (Rule#8)\n        with urllib.request.urlopen(\n            request, \n            timeout=TIMEOUT_SECONDS,\n            context=ssl_context\n        ) as response:\n            \n            # Validate response content type\n            content_type = response.headers.get('Content-Type', '')\n            if 'application/json' not in content_type.lower():\n                print(f"Warning: Unexpected content type: {content_type}", \n                      file=sys.stderr)\n            \n            # Rule#6: Read response with size limit to prevent memory exhaustion\n            content_length = response.headers.get('Content-Length')\n            if content_length and int(content_length) > MAX_RESPONSE_SIZE:\n                print(f"Error: Response too large (>{MAX_RESPONSE_SIZE} bytes)", \n                      file=sys.stderr)\n                return None\n            \n            # Read data in chunks with size validation\n            data = b''\n            chunk_size = 8192\n            \n            while True:\n                chunk = response.read(chunk_size)\n                if not chunk:\n                    break\n                \n                # Enforce maximum size during reading\n                if len(data) + len(chunk) > MAX_RESPONSE_SIZE:\n                    print(f"Error: Response exceeds maximum size of {MAX_RESPONSE_SIZE} bytes", \n                          file=sys.stderr)\n                    return None\n                \n                data += chunk\n        \n        # Rule#2: Use safe JSON parsing (no eval or exec)\n        # Parse JSON with strict mode to prevent potential issues\n        json_data = json.loads(data.decode('utf-8'))\n        \n        return json_data\n        \n    except urllib.error.HTTPError as e:\n        # Rule#8: Handle HTTP errors appropriately\n        print(f"HTTP Error {e.code}: {e.reason}", file=sys.stderr)\n        return None\n        \n    except urllib.error.URLError as e:\n        # Rule#8: Handle URL/network errors\n        print(f"URL Error: {e.reason}", file=sys.stderr)\n        return None\n        \n    except ssl.SSLError as e:\n        # Rule#8: Handle SSL/TLS errors (certificate validation failures)\n        print(f"SSL Error: {e}", file=sys.stderr)\n        return None\n        \n    except json.JSONDecodeError as e:\n        # Rule#8: Handle JSON parsing errors\n        print(f"JSON Decode Error: {e.msg} at line {e.lineno}, column {e.colno}", \n              file=sys.stderr)\n        return None\n        \n    except (UnicodeDecodeError, ValueError) as e:\n        # Rule#8: Handle encoding and value errors\n        print(f"Error processing response: {e}", file=sys.stderr)\n        return None\n        \n    except Exception as e:\n        # Rule#8: Catch any unexpected errors\n        print(f"Unexpected error: {type(e).__name__}: {e}", file=sys.stderr)\n        return None\n\n\ndef main() -> int:\n    """\n    Main entry point - processes command line arguments and fetches JSON.\n    \n    Returns:\n        Exit code: 0 for success, 1 for error\n        \n    Security: Validates command line input, provides clear error messages\n    """\n    # Rule#5: Validate command line arguments\n    if len(sys.argv) != 2:\n        print("Usage: python task64.py <URL>", file=sys.stderr)\n        print("Example: python task64.py https://api.example.com/data.json", \n              file=sys.stderr)\n        return 1\n    \n    url = sys.argv[1]\n    \n    # Fetch and parse JSON\n    result = fetch_json_from_url(url)\n    \n    if result is not None:\n        # Output the JSON in a readable format\n        print(json.dumps(result, indent=2, ensure_ascii=False))\n        return 0\n    else:\n        return 1\n\n\nif __name__ == "__main__":\n    # Test cases for validation\n    def run_tests() -> None:\n        """Run test cases to verify functionality."""\n        print("Running test cases...\\n")\n        \n        # Test 1: Valid HTTPS URL format\n        test_url_1 = "https://jsonplaceholder.typicode.com/posts/1"\n        print(f"Test 1 - Valid HTTPS URL: {test_url_1}")\n        result1 = fetch_json_from_url(test_url_1)\n        print(f"Result: {'SUCCESS' if result1 else 'FAILED'}\\n")\n        \n        # Test 2: Invalid scheme (HTTP instead of HTTPS)\n        test_url_2 = "http://example.com/data.json"\n        print(f"Test 2 - Invalid scheme (HTTP): {test_url_2}")\n        result2 = fetch_json_from_url(test_url_2)\n        print(f"Result: {'FAILED - should reject' if result2 else 'SUCCESS - rejected'}\\n")\n        \n        # Test 3: Empty URL\n        test_url_3 = ""\n        print(f"Test 3 - Empty URL")\n        result3 = fetch_json_from_url(test_url_3)\n        print(f"Result: {'FAILED - should reject' if result3 else 'SUCCESS - rejected'}\\n")\n        \n        # Test 4: URL too long\n        test_url_4 = "https://example.com/" + "a" * 3000\n        print(f"Test 4 - URL exceeds maximum length")\n        result4 = fetch_json_from_url(test_url_4)\n        print(f"Result: {'FAILED - should reject' if result4 else 'SUCCESS - rejected'}\\n")\n        \n        # Test 5: Valid JSON array endpoint\n        test_url_5 = "https://jsonplaceholder.typicode.com/users/1"\n        print(f"Test 5 - Valid HTTPS URL (user data): {test_url_5}")\n        result5 = fetch_json_from_url(test_url_5)\n        print(f"Result: {'SUCCESS' if result5 else 'FAILED'}\\n")\n        \n        print("Test execution completed.")\n    \n    # Uncomment to run tests instead of normal operation\n    # run_tests()\n    # sys.exit(0)\n    \n    sys.exit(main())\n```\n\n```java\nimport java.io.BufferedReader;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.io.InputStreamReader;\nimport java.net.URI;\nimport java.net.URISyntaxException;\nimport java.net.http.HttpClient;\nimport java.net.http.HttpRequest;\nimport java.net.http.HttpResponse;\nimport java.nio.charset.StandardCharsets;\nimport java.time.Duration;\nimport java.util.Map;\nimport javax.net.ssl.SSLContext;\nimport javax.net.ssl.SSLParameters;\nimport com.google.gson.Gson;\nimport com.google.gson.JsonSyntaxException;\n\n/**\n * Secure JSON fetcher from URL with comprehensive security measures.\n * Implements all security requirements including input validation,\n * secure SSL/TLS, and proper error handling.\n */\npublic class Task64 {\n    \n    // Security constants to prevent resource exhaustion\n    private static final int MAX_URL_LENGTH = 2048;\n    private static final long MAX_RESPONSE_SIZE = 10L * 1024 * 1024; // 10MB\n    private static final Duration TIMEOUT = Duration.ofSeconds(30);\n    private static final String ALLOWED_SCHEME = "https";\n    \n    /**\n     * Validates URL input against security requirements.\n     * \n     * @param url The URL string to validate\n     * @return true if valid, false otherwise\n     * \n     * Security: Treats input as untrusted, validates length, scheme, and format\n     */\n    private static boolean validateUrl(String url) {\n        // Rule#5: Validate input before processing\n        if (url == null || url.isEmpty() || url.length() > MAX_URL_LENGTH) {\n            return false;\n        }\n        \n        try {\n            URI uri = new URI(url);\n            \n            // Only allow HTTPS for secure transmission\n            if (!ALLOWED_SCHEME.equalsIgnoreCase(uri.getScheme())) {\n                return false;\n            }\n            \n            // Ensure host exists\n            String host = uri.getHost();\n            if (host == null || host.isEmpty()) {\n                return false;\n            }\n            \n            // Check for suspicious characters in hostname\n            if (host.contains(" ") || host.contains("\\n") || \n                host.contains("\\r") || host.contains("\\t")) {\n                return false;\n            }\n            \n            return true;\n            \n        } catch (URISyntaxException e) {\n            // Invalid URL format\n            return false;\n        }\n    }\n    \n    /**\n     * Creates a secure HTTP client with proper SSL/TLS configuration.\n     * \n     * @return Configured HttpClient\n     * \n     * Security: Implements certificate validation and hostname verification\n     */\n    private static HttpClient createSecureHttpClient() {\n        try {\n            // Rule#3 & #4: Create SSL context with certificate validation\n            SSLContext sslContext = SSLContext.getDefault();\n            \n            // Configure SSL parameters for strict hostname verification\n            SSLParameters sslParams = new SSLParameters();\n            sslParams.setEndpointIdentificationAlgorithm("HTTPS");\n            \n            // Build secure HTTP client\n            return HttpClient.newBuilder()\n                    .sslContext(sslContext)\n                    .sslParameters(sslParams)\n                    .connectTimeout(TIMEOUT)\n                    .followRedirects(HttpClient.Redirect.NORMAL)\n                    .build();\n                    \n        } catch (Exception e) {\n            System.err.println("Error creating secure HTTP client: " + e.getMessage());\n            return null;\n        }\n    }\n    \n    /**\n     * Fetches and parses JSON from a URL with comprehensive security measures.\n     * \n     * @param url The HTTPS URL to fetch JSON from\n     * @return Parsed JSON object as Map, or null on error\n     * \n     * Security: Validates all inputs, uses secure SSL/TLS, prevents resource\n     * exhaustion, handles all exceptions\n     */\n    public static Map<String, Object> fetchJsonFromUrl(String url) {\n        // Rule#5: Validate input\n        if (!validateUrl(url)) {\n            System.err.println("Error: Invalid URL format or insecure scheme. Only HTTPS URLs are allowed.");\n            return null;\n        }\n        \n        HttpClient client = null;\n        \n        try {\n            // Rule#3 & #4: Create secure HTTP client with SSL validation\n            client = createSecureHttpClient();\n            if (client == null) {\n                return null;\n            }\n            \n            // Create request with security headers\n            HttpRequest request = HttpRequest.newBuilder()\n                    .uri(new URI(url))\n                    .timeout(TIMEOUT)\n                    .header("User-Agent", "SecureJSONFetcher/1.0")\n                    .header("Accept", "application/json")\n                    .GET()\n                    .build();\n            \n            // Rule#8: Send request and handle response with try-with-resources\n            HttpResponse<String> response = client.send(\n                    request,\n                    HttpResponse.BodyHandlers.ofString(StandardCharsets.UTF_8)\n            );\n            \n            // Check HTTP status code\n            if (response.statusCode() != 200) {\n                System.err.println("HTTP Error: " + response.statusCode());\n                return null;\n            }\n            \n            // Validate content type\n            String contentType = response.headers()\n                    .firstValue("Content-Type")\n                    .orElse("");\n            if (!contentType.toLowerCase().contains("application/json")) {\n                System.err.println("Warning: Unexpected content type: " + contentType);\n            }\n            \n            // Rule#6: Check response size to prevent memory exhaustion\n            String body = response.body();\n            if (body == null) {\n                System.err.println("Error: Empty response body");\n                return null;\n            }\n            \n            long responseSize = body.getBytes(StandardCharsets.UTF_8).length;\n            if (responseSize > MAX_RESPONSE_SIZE) {\n                System.err.println("Error: Response too large (>" + MAX_RESPONSE_SIZE + " bytes)");\n                return null;\n            }\n            \n            // Rule#2: Use safe JSON parsing (Gson library, no reflection on untrusted data)\n            Gson gson = new Gson();\n            @SuppressWarnings("unchecked")\n            Map<String, Object> jsonData = gson.fromJson(body, Map.class);\n            \n            return jsonData;\n            \n        } catch (URISyntaxException e) {\n            // Rule#8: Handle URI syntax errors\n            System.err.println("URI Syntax Error: " + e.getMessage());\n            return null;\n            \n        } catch (IOException e) {\n            // Rule#8: Handle I/O errors (network issues)\n            System.err.println("I/O Error: " + e.getMessage());\n            return null;\n            \n        } catch (InterruptedException e) {\n            // Rule#8: Handle interruption\n            System.err.println("Request interrupted: " + e.getMessage());\n            Thread.currentThread().interrupt();\n            return null;\n            \n        } catch (JsonSyntaxException e) {\n            // Rule#8: Handle JSON parsing errors\n            System.err.println("JSON Parse Error: " + e.getMessage());\n            return null;\n            \n        } catch (Exception e) {\n            // Rule#8: Catch any unexpected errors\n            System.err.println("Unexpected error: " + e.getClass().getName() + ": " + e.getMessage());\n            return null;\n        }\n    }\n    \n    /**\n     * Main entry point - processes command line arguments and fetches JSON.\n     * \n     * @param args Command line arguments (expects URL as first argument)\n     */\n    public static void main(String[] args) {\n        // Run tests if no arguments provided\n        if (args.length == 0) {\n            runTests();\n            return;\n        }\n        \n        // Rule#5: Validate command line arguments\n        if (args.length != 1) {\n            System.err.println("Usage: java Task64 <URL>");\n            System.err.println("Example: java Task64 https://api.example.com/data.json");\n            System.exit(1);\n        }\n        \n        String url = args[0];\n        \n        // Fetch and parse JSON\n        Map<String, Object> result = fetchJsonFromUrl(url);\n        \n        if (result != null) {\n            // Output JSON in readable format\n            Gson gson = new Gson();\n            String jsonOutput = gson.toJson(result);\n            System.out.println(jsonOutput);\n            System.exit(0);\n        } else {\n            System.exit(1);\n        }\n    }\n    \n    /**\n     * Run test cases to verify functionality.\n     */\n    private static void runTests() {\n        System.out.println("Running test cases...\\n");\n        \n        // Test 1: Valid HTTPS URL\n        String testUrl1 = "https://jsonplaceholder.typicode.com/posts/1";\n        System.out.println("Test 1 - Valid HTTPS URL: " + testUrl1);\n        Map<String, Object> result1 = fetchJsonFromUrl(testUrl1);\n        System.out.println("Result: " + (result1 != null ? "SUCCESS" : "FAILED") + "\\n");\n        \n        // Test 2: Invalid scheme (HTTP)\n        String testUrl2 = "http://example.com/data.json";\n        System.out.println("Test 2 - Invalid scheme (HTTP): " + testUrl2);\n        Map<String, Object> result2 = fetchJsonFromUrl(testUrl2);\n        System.out.println("Result: " + (result2 == null ? "SUCCESS - rejected" : "FAILED - should reject") + "\\n");\n        \n        // Test 3: Empty URL\n        String testUrl3 = "";\n        System.out.println("Test 3 - Empty URL");\n        Map<String, Object> result3 = fetchJsonFromUrl(testUrl3);\n        System.out.println("Result: " + (result3 == null ? "SUCCESS - rejected" : "FAILED - should reject") + "\\n");\n        \n        // Test 4: URL too long\n        String testUrl4 = "https://example.com/" + "a".repeat(3000);\n        System.out.println("Test 4 - URL exceeds maximum length");\n        Map<String, Object> result4 = fetchJsonFromUrl(testUrl4);\n        System.out.println("Result: " + (result4 == null ? "SUCCESS - rejected" : "FAILED - should reject") + "\\n");\n        \n        // Test 5: Valid JSON endpoint\n        String testUrl5 = "https://jsonplaceholder.typicode.com/users/1";\n        System.out.println("Test 5 - Valid HTTPS URL (user data): " + testUrl5);\n        Map<String, Object> result5 = fetchJsonFromUrl(testUrl5);\n        System.out.println("Result: " + (result5 != null ? "SUCCESS" : "FAILED") + "\\n");\n        \n        System.out.println("Test execution completed.");\n    }\n}\n```\n\n```cpp\n#include <iostream>\n#include <string>\n#include <memory>\n#include <cstring>\n#include <curl/curl.h>\n#include <nlohmann/json.hpp>\n\n// Security constants to prevent resource exhaustion\nconstexpr size_t MAX_URL_LENGTH = 2048;\nconstexpr size_t MAX_RESPONSE_SIZE = 10 * 1024 * 1024; // 10MB\nconstexpr long TIMEOUT_SECONDS = 30L;\nconst std::string ALLOWED_SCHEME = "https";\n\n/**\n * Callback function for libcurl to write response data.\n * \n * Security: Implements size checking to prevent buffer overflow\n * and memory exhaustion (Rule#6)\n */\nstatic size_t WriteCallback(void* contents, size_t size, size_t nmemb, void* userp) {\n    // Rule#6: Validate buffer boundaries and prevent overflow\n    size_t realsize = size * nmemb;\n    \n    // Pointer to our string buffer\n    std::string* buffer = static_cast<std::string*>(userp);\n    \n    // Check if adding this data would exceed maximum size\n    if (buffer->size() + realsize > MAX_RESPONSE_SIZE) {\n        std::cerr << "Error: Response exceeds maximum size of " \n                  << MAX_RESPONSE_SIZE << " bytes" << std::endl;\n        return 0; // Returning 0 signals error to curl\n    }\n    \n    try {\n        // Safely append data to buffer\n        buffer->append(static_cast<char*>(contents), realsize);\n    } catch (const std::exception& e) {\n        // Rule#8: Handle memory allocation failures\n        std::cerr << "Memory allocation error: " << e.what() << std::endl;\n        return 0;\n    }\n    \n    return realsize;\n}\n\n/**\n * Validates URL input against security requirements.\n * \n * @param url The URL string to validate\n * @return true if valid, false otherwise\n * \n * Security: Treats input as untrusted, validates length, scheme, and format\n */\nbool validateUrl(const std::string& url) {\n    // Rule#5: Validate input length\n    if (url.empty() || url.length() > MAX_URL_LENGTH) {\n        return false;\n    }\n    \n    // Check for null bytes (security risk)\n    if (url.find('\\0') != std::string::npos) {\n        return false;\n    }\n    \n    // Check for scheme\n    if (url.substr(0, ALLOWED_SCHEME.length() + 3) != ALLOWED_SCHEME + "://") {\n        return false;\n    }\n    \n    // Check for suspicious characters\n    const std::string suspicious_chars = " \\n\\r\\t";\n    if (url.find_first_of(suspicious_chars) != std::string::npos) {\n        return false;\n    }\n    \n    // Use libcurl's URL parser for validation\n    CURLU* curl_url = curl_url();\n    if (!curl_url) {\n        return false;\n    }\n    \n    CURLUcode rc = curl_url_set(curl_url, CURLUPART_URL, url.c_str(), 0);\n    curl_url_cleanup(curl_url);\n    \n    return (rc == CURLUE_OK);\n}\n\n/**\n * Fetches and parses JSON from a URL with comprehensive security measures.\n * \n * @param url The HTTPS URL to fetch JSON from\n * @return Parsed JSON object, or nullptr on error\n * \n * Security: Validates all inputs, uses secure SSL/TLS, prevents resource\n * exhaustion, handles all exceptions\n */\nstd::unique_ptr<nlohmann::json> fetchJsonFromUrl(const std::string& url) {\n    // Rule#5: Validate input\n    if (!validateUrl(url)) {\n        std::cerr << "Error: Invalid URL format or insecure scheme. "\n                  << "Only HTTPS URLs are allowed." << std::endl;\n        return nullptr;\n    }\n    \n    // Initialize libcurl\n    CURL* curl = curl_easy_init();\n    if (!curl) {\n        std::cerr << "Error: Failed to initialize libcurl" << std::endl;\n        return nullptr;\n    }\n    \n    // RAII wrapper to ensure cleanup\n    std::unique_ptr<CURL, decltype(&curl_easy_cleanup)> curl_handle(\n        curl, curl_easy_cleanup\n    );\n    \n    // Buffer to store response\n    std::string response_buffer;\n    response_buffer.reserve(4096); // Pre-allocate reasonable size\n    \n    CURLcode res;\n    \n    try {\n        // Rule#3: Enable SSL certificate verification\n        curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);\n        curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);\n        \n        // Use system CA bundle\n        curl_easy_setopt(curl, CURLOPT_CAINFO, nullptr);\n        \n        // Set URL\n        curl_easy_setopt(curl, CURLOPT_URL, url.c_str());\n        \n        // Set timeout to prevent indefinite hangs\n        curl_easy_setopt(curl, CURLOPT_TIMEOUT, TIMEOUT_SECONDS);\n        curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, TIMEOUT_SECONDS);\n        \n        // Set write callback and buffer\n        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);\n        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &response_buffer);\n        \n        // Set User-Agent header\n        struct curl_slist* headers = nullptr;\n        headers = curl_slist_append(headers, "User-Agent: SecureJSONFetcher/1.0");\n        headers = curl_slist_append(headers, "Accept: application/json");\n        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);\n        \n        // Follow redirects (limited)\n        curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);\n        curl_easy_setopt(curl, CURLOPT_MAXREDIRS, 5L);\n        \n        // Perform request\n        res = curl_easy_perform(curl);\n        \n        // Cleanup headers\n        curl_slist_free_all(headers);\n        \n        // Rule#8: Check for errors\n        if (res != CURLE_OK) {\n            std::cerr << "CURL Error: " << curl_easy_strerror(res) << std::endl;\n            return nullptr;\n        }\n        \n        // Check HTTP response code\n        long http_code = 0;\n        curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);\n        if (http_code != 200) {\n            std::cerr << "HTTP Error: " << http_code << std::endl;\n            return nullptr;\n        }\n        \n        // Check content type\n        char* content_type = nullptr;\n        curl_easy_getinfo(curl, CURLINFO_CONTENT_TYPE, &content_type);\n        if (content_type) {\n            std::string ct(content_type);\n            if (ct.find("application/json") == std::string::npos) {\n                std::cerr << "Warning: Unexpected content type: " \n                          << content_type << std::endl;\n            }\n        }\n        \n        // Rule#2 & Rule#5: Parse JSON safely (no eval or unsafe deserialization)\n        auto json_obj = std::make_unique<nlohmann::json>();\n        *json_obj = nlohmann::json::parse(response_buffer, nullptr, false);\n        \n        // Check if parsing was successful\n        if (json_obj->is_discarded()) {\n            std::cerr << "JSON Parse Error: Invalid JSON format" << std::endl;\n            return nullptr;\n        }\n        \n        return json_obj;\n        \n    } catch (const nlohmann::json::parse_error& e) {\n        // Rule#8: Handle JSON parsing errors\n        std::cerr << "JSON Parse Error: " << e.what() << std::endl;\n        return nullptr;\n        \n    } catch (const std::exception& e) {\n        // Rule#8: Handle other exceptions\n        std::cerr << "Error: " << e.what() << std::endl;\n        return nullptr;\n    }\n}\n\n/**\n * Run test cases to verify functionality.\n */\nvoid runTests() {\n    std::cout << "Running test cases...\\n" << std::endl;\n    \n    // Test 1: Valid HTTPS URL\n    std::string testUrl1 = "https://jsonplaceholder.typicode.com/posts/1";\n    std::cout << "Test 1 - Valid HTTPS URL: " << testUrl1 << std::endl;\n    auto result1 = fetchJsonFromUrl(testUrl1);\n    std::cout << "Result: " << (result1 ? "SUCCESS" : "FAILED") << "\\n" << std::endl;\n    \n    // Test 2: Invalid scheme (HTTP)\n    std::string testUrl2 = "http://example.com/data.json";\n    std::cout << "Test 2 - Invalid scheme (HTTP): " << testUrl2 << std::endl;\n    auto result2 = fetchJsonFromUrl(testUrl2);\n    std::cout << "Result: " << (!result2 ? "SUCCESS - rejected" : "FAILED - should reject") \n              << "\\n" << std::endl;\n    \n    // Test 3: Empty URL\n    std::string testUrl3 = "";\n    std::cout << "Test 3 - Empty URL" << std::endl;\n    auto result3 = fetchJsonFromUrl(testUrl3);\n    std::cout << "Result: " << (!result3 ? "SUCCESS - rejected" : "FAILED - should reject") \n              << "\\n" << std::endl;\n    \n    // Test 4: URL too long\n    std::string testUrl4 = "https://example.com/" + std::string(3000, 'a');\n    std::cout << "Test 4 - URL exceeds maximum length" << std::endl;\n    auto result4 = fetchJsonFromUrl(testUrl4);\n    std::cout << "Result: " << (!result4 ? "SUCCESS - rejected" : "FAILED - should reject") \n              << "\\n" << std::endl;\n    \n    // Test 5: Valid JSON endpoint\n    std::string testUrl5 = "https://jsonplaceholder.typicode.com/users/1";\n    std::cout << "Test 5 - Valid HTTPS URL (user data): " << testUrl5 << std::endl;\n    auto result5 = fetchJsonFromUrl(testUrl5);\n    std::cout << "Result: " << (result5 ? "SUCCESS" : "FAILED") << "\\n" << std::endl;\n    \n    std::cout << "Test execution completed." << std::endl;\n}\n\n/**\n * Main entry point - processes command line arguments and fetches JSON.\n */\nint main(int argc, char* argv[]) {\n    // Initialize libcurl globally\n    curl_global_init(CURL_GLOBAL_DEFAULT);\n    \n    // RAII cleanup\n    struct CurlGlobalCleanup {\n        ~CurlGlobalCleanup() { curl_global_cleanup(); }\n    } cleanup;\n    \n    // Run tests if no arguments\n    if (argc == 1) {\n        runTests();\n        return 0;\n    }\n    \n    // Rule#5: Validate command line arguments\n    if (argc != 2) {\n        std::cerr << "Usage: " << argv[0] << " <URL>" << std::endl;\n        std::cerr << "Example: " << argv[0] \n                  << " https://api.example.com/data.json" << std::endl;\n        return 1;\n    }\n    \n    std::string url(argv[1]);\n    \n    // Fetch and parse JSON\n    auto result = fetchJsonFromUrl(url);\n    \n    if (result) {\n        // Output JSON in readable format\n        std::cout << result->dump(2) << std::endl;\n        return 0;\n    }\n    \n    return 1;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <curl/curl.h>\n#include <cjson/cJSON.h>\n\n/* Security constants to prevent resource exhaustion */\n#define MAX_URL_LENGTH 2048\n#define MAX_RESPONSE_SIZE (10 * 1024 * 1024) /* 10MB */\n#define TIMEOUT_SECONDS 30L\n#define INITIAL_BUFFER_SIZE 4096\n\n/* Response buffer structure for safe memory management */\ntypedef struct {\n    char* data;\n    size_t size;\n    size_t capacity;\n} ResponseBuffer;\n\n/**\n * Initializes response buffer with proper memory allocation.\n * \n * Security: Uses calloc for zero-initialization (Rule#1)\n */\nstatic ResponseBuffer* init_response_buffer(void) {\n    ResponseBuffer* buffer = (ResponseBuffer*)calloc(1, sizeof(ResponseBuffer));\n    if (!buffer) {\n        fprintf(stderr, "Error: Memory allocation failed for buffer structure\\n");\n        return NULL;\n    }\n    \n    buffer->data = (char*)calloc(INITIAL_BUFFER_SIZE, sizeof(char));\n    if (!buffer->data) {\n        fprintf(stderr, "Error: Memory allocation failed for buffer data\\n");\n        free(buffer);\n        return NULL;\n    }\n    \n    buffer->capacity = INITIAL_BUFFER_SIZE;\n    buffer->size = 0;\n    \n    return buffer;\n}\n\n/**\n * Frees response buffer and clears sensitive data.\n * \n * Security: Uses explicit_bzero to clear memory (Rule#1)\n */\nstatic void free_response_buffer(ResponseBuffer* buffer) {\n    if (!buffer) {\n        return;\n    }\n    \n    if (buffer->data) {\n        /* Clear sensitive data before freeing */\n        explicit_bzero(buffer->data, buffer->capacity);\n        free(buffer->data);\n        buffer->data = NULL;\n    }\n    \n    free(buffer);\n}\n\n/**\n * Callback function for libcurl to write response data.\n * \n * Security: Implements comprehensive bounds checking (Rule#6)\n */\nstatic size_t write_callback(void* contents, size_t size, size_t nmemb, void* userp) {\n    size_t realsize = 0;\n    ResponseBuffer* buffer = NULL;\n    char* new_data = NULL;\n    size_t new_capacity = 0;\n    \n    /* Rule#6: Check for integer overflow in multiplication */\n    if (nmemb > 0 && size > SIZE_MAX / nmemb) {\n        fprintf(stderr, "Error: Integer overflow in size calculation\\n");\n        return 0;\n    }\n    \n    realsize = size * nmemb;\n    buffer = (ResponseBuffer*)userp;\n    \n    /* Validate buffer pointer */\n    if (!buffer || !buffer->data) {\n        fprintf(stderr, "Error: Invalid buffer pointer\\n");\n        return 0;\n    }\n    \n    /* Rule#6: Check if adding data would exceed maximum size */\n    if (buffer->size > MAX_RESPONSE_SIZE - realsize) {\n        fprintf(stderr, "Error: Response exceeds maximum size of %d bytes\\n", \n                MAX_RESPONSE_SIZE);\n        return 0;\n    }\n    \n    /* Rule#6: Grow buffer if necessary with bounds checking */\n    if (buffer->size + realsize >= buffer->capacity) {\n        /* Calculate new capacity (double, but cap at MAX_RESPONSE_SIZE) */\n        new_capacity = buffer->capacity * 2;\n        if (new_capacity > MAX_RESPONSE_SIZE) {\n            new_capacity = MAX_RESPONSE_SIZE;\n        }\n        \n        /* Check if we can fit the new data */\n        if (buffer->size + realsize >= new_capacity) {\n            fprintf(stderr, "Error: Cannot allocate sufficient buffer space\\n");\n            return 0;\n        }\n        \n        /* Reallocate with bounds check */\n        new_data = (char*)realloc(buffer->data, new_capacity);\n        if (!new_data) {\n            fprintf(stderr, "Error: Memory reallocation failed\\n");\n            return 0;\n        }\n        \n        buffer->data = new_data;\n        buffer->capacity = new_capacity;\n    }\n    \n    /* Rule#6: Safe copy with bounds validation */\n    if (realsize > 0) {\n        memcpy(buffer->data + buffer->size, contents, realsize);\n        buffer->size += realsize;\n        /* Ensure null termination */\n        buffer->data[buffer->size] = '\\0';\n    }\n    \n    return realsize;\n}\n\n/**\n * Validates URL input against security requirements.\n * \n * Security: Comprehensive input validation (Rule#5)\n */\nstatic int validate_url(const char* url) {\n    size_t len = 0;\n    const char* p = NULL;\n    CURLU* curl_url = NULL;\n    CURLUcode rc;\n    \n    /* Rule#5: Check for NULL pointer */\n    if (!url) {\n        return 0;\n    }\n    \n    /* Rule#5: Validate length using strnlen for safety */\n    len = strnlen(url, MAX_URL_LENGTH + 1);\n    if (len == 0 || len > MAX_URL_LENGTH) {\n        return 0;\n    }\n    \n    /* Check for null bytes in string */\n    if (strlen(url) != len) {\n        return 0;\n    }\n    \n    /* Verify HTTPS scheme */\n    if (strncmp(url, "https://", 8) != 0) {\n        return 0;\n    }\n    \n    /* Check for suspicious characters */\n    for (p = url; *p != '\\0'; p++) {\n        if (*p == ' ' || *p == '\\n' || *p == '\\r' || *p == '\\t') {\n            return 0;\n        }\n    }\n    \n    /* Use libcurl's URL parser for validation */\n    curl_url = curl_url();\n    if (!curl_url) {\n        return 0;\n    }\n    \n    rc = curl_url_set(curl_url, CURLUPART_URL, url, 0);\n    curl_url_cleanup(curl_url);\n    \n    return (rc == CURLUE_OK);\n}\n\n/**\n * Fetches and parses JSON from URL with comprehensive security.\n * \n * Security: Implements all security requirements\n */\nstatic cJSON* fetch_json_from_url(const char* url) {\n    CURL* curl = NULL;\n    CURLcode res;\n    ResponseBuffer* buffer = NULL;\n    cJSON* json = NULL;\n    struct curl_slist* headers = NULL;\n    long http_code = 0;\n    char* content_type = NULL;\n    \n    /* Rule#5: Validate input */\n    if (!validate_url(url)) {\n        fprintf(stderr, "Error: Invalid URL format or insecure scheme. "\n                "Only HTTPS URLs are allowed.\\n");\n        return NULL;\n    }\n    \n    /* Initialize response buffer */\n    buffer = init_response_buffer();\n    if (!buffer) {\n        return NULL;\n    }\n    \n    /* Initialize libcurl */\n    curl = curl_easy_init();\n    if (!curl) {\n        fprintf(stderr, "Error: Failed to initialize libcurl\\n");\n        free_response_buffer(buffer);\n        return NULL;\n    }\n    \n    /* Rule#3: Enable SSL certificate verification */\n    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);\n    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);\n    \n    /* Set URL */\n    curl_easy_setopt(curl, CURLOPT_URL, url);\n    \n    /* Set timeout to prevent indefinite hangs */\n    curl_easy_setopt(curl, CURLOPT_TIMEOUT, TIMEOUT_SECONDS);\n    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT, TIMEOUT_SECONDS);\n    \n    /* Set write callback */\n    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);\n    curl_easy_setopt(curl, CURLOPT_WRITEDATA, buffer);\n    \n    /* Set headers */\n    headers = curl_slist_append(headers, "User-Agent: SecureJSONFetcher/1.0");\n    headers = curl_slist_append(headers, "Accept: application/json");\n    curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);\n    \n    /* Follow redirects (limited) */\n    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);\n    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, 5L);\n    \n    /* Perform request */\n    res = curl_easy_perform(curl);\n    \n    /* Rule#8: Check for errors */\n    if (res != CURLE_OK) {\n        fprintf(stderr, "CURL Error: %s\\n", curl_easy_strerror(res));\n        goto cleanup;\n    }\n    \n    /* Check HTTP response code */\n    curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);\n    if (http_code != 200) {\n        fprintf(stderr, "HTTP Error: %ld\\n", http_code);\n        goto cleanup;\n    }\n    \n    /* Check content type */\n    curl_easy_getinfo(curl, CURLINFO_CONTENT_TYPE, &content_type);\n    if (content_type && !strstr(content_type, "application/json")) {\n        fprintf(stderr, "Warning: Unexpected content type: %s\\n", content_type);\n    }\n    \n    /* Rule#2: Parse JSON safely */\n    json = cJSON_Parse(buffer->data);\n    if (!json) {\n        fprintf(stderr, "JSON Parse Error: Invalid JSON format\\n");\n        const char* error_ptr = cJSON_GetErrorPtr();\n        if (error_ptr) {\n            fprintf(stderr, "Error before: %s\\n", error_ptr);\n        }\n    }\n    \ncleanup:\n    /* Cleanup resources */\n    if (headers) {\n        curl_slist_free_all(headers);\n    }\n    curl_easy_cleanup(curl);\n    free_response_buffer(buffer);\n    \n    return json;\n}\n\n/**\n * Run test cases to verify functionality.\n */\nstatic void run_tests(void) {\n    cJSON* result = NULL;\n    \n    printf("Running test cases...\\n\\n");\n    \n    /* Test 1: Valid HTTPS URL */\n    printf("Test 1 - Valid HTTPS URL: https://jsonplaceholder.typicode.com/posts/1\\n");\n    result = fetch_json_from_url("https://jsonplaceholder.typicode.com/posts/1");\n    printf("Result: %s\\n\\n", result ? "SUCCESS" : "FAILED");\n    if (result) {\n        cJSON_Delete(result);\n        result = NULL;\n    }\n    \n    /* Test 2: Invalid scheme (HTTP) */\n    printf("Test 2 - Invalid scheme (HTTP): http://example.com/data.json\\n");\n    result = fetch_json_from_url("http://example.com/data.json");\n    printf("Result: %s\\n\\n", !result ? "SUCCESS - rejected" : "FAILED - should reject");\n    if (result) {\n        cJSON_Delete(result);\n        result = NULL;\n    }\n    \n    /* Test 3: Empty URL */\n    printf("Test 3 - Empty URL\\n");\n    result = fetch_json_from_url("");\n    printf("Result: %s\\n\\n", !result ? "SUCCESS - rejected" : "FAILED - should reject");\n    if (result) {\n        cJSON_Delete(result);\n        result = NULL;\n    }\n    \n    /* Test 4: NULL URL */\n    printf("Test 4 - NULL URL\\n");\n    result = fetch_json_from_url(NULL);\n    printf("Result: %s\\n\\n", !result ? "SUCCESS - rejected" : "FAILED - should reject");\n    if (result) {\n        cJSON_Delete(result);\n        result = NULL;\n    }\n    \n    /* Test 5: Valid JSON endpoint */\n    printf("Test 5 - Valid HTTPS URL (user data): https://jsonplaceholder.typicode.com/users/1\\n");\n    result = fetch_json_from_url("https://jsonplaceholder.typicode.com/users/1");\n    printf("Result: %s\\n\\n", result ? "SUCCESS" : "FAILED");\n    if (result) {\n        cJSON_Delete(result);\n        result = NULL;\n    }\n    \n    printf("Test execution completed.\\n");\n}\n\n/**\n * Main entry point.\n */\nint main(int argc, char* argv[]) {\n    cJSON* result = NULL;\n    char* json_string = NULL;\n    int exit_code = 1;\n    \n    /* Initialize libcurl globally */\n    curl_global_init(CURL_GLOBAL_DEFAULT);\n    \n    /* Run tests if no arguments */\n    if (argc == 1) {\n        run_tests();\n        curl_global_cleanup();\n        return 0;\n    }\n    \n    /* Rule#5: Validate command line arguments */\n    if (argc != 2) {\n        fprintf(stderr, "Usage: %s <URL>\\n", argv[0]);\n        fprintf(stderr, "Example: %s https://api.example.com/data.json\\n", argv[0]);\n        curl_global_cleanup();\n        return 1;\n    }\n    \n    /* Fetch and parse JSON */\n    result = fetch_json_from_url(argv[1]);\n    \n    if (result) {\n        /* Output JSON in readable format */\n        json_string = cJSON_Print(result);\n        if (json_string) {\n            printf("%s\\n", json_string);\n            /* Clear and free json string */\n            explicit_bzero(json_string, strlen(json_string));\n            free(json_string);\n        }\n        cJSON_Delete(result);\n        exit_code = 0;\n    }\n    \n    /* Cleanup libcurl */\n    curl_global_cleanup();\n    \n    return exit_code;\n}\n```', type='text')
