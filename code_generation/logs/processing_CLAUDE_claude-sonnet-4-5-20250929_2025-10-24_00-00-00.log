2025-10-24 01:20:41,115 INFO TextBlock(citations=None, text='```python\nimport ssl\nimport socket\nimport sys\nfrom typing import Optional, Tuple\nfrom urllib.parse import urlparse\n\n\ndef create_secure_context() -> ssl.SSLContext:\n    """\n    Create a secure SSL/TLS context with strict security settings.\n    \n    Returns:\n        ssl.SSLContext: Configured SSL context with TLS 1.2+ enforced\n    \n    Security: Enforces TLS 1.2+ to prevent downgrade attacks (CWE-327).\n    Certificate validation is enabled by default to prevent MITM (CWE-295, CWE-297).\n    """\n    # Create default context with certificate validation enabled\n    ctx = ssl.create_default_context()\n    \n    # Enforce hostname verification to prevent MITM attacks (CWE-297)\n    ctx.check_hostname = True\n    ctx.verify_mode = ssl.CERT_REQUIRED\n    \n    # Force TLS 1.2 or higher to prevent protocol downgrade attacks (CWE-327)\n    if hasattr(ssl, "TLSVersion"):  # Python 3.10+\n        ctx.minimum_version = ssl.TLSVersion.TLSv1_2\n        ctx.maximum_version = ssl.TLSVersion.TLSv1_3\n    else:  # Python 3.7-3.9\n        # Disable insecure protocols\n        ctx.options |= getattr(ssl, "OP_NO_SSLv2", 0)\n        ctx.options |= getattr(ssl, "OP_NO_SSLv3", 0)\n        ctx.options |= getattr(ssl, "OP_NO_TLSv1", 0)\n        ctx.options |= getattr(ssl, "OP_NO_TLSv1_1", 0)\n    \n    return ctx\n\n\ndef parse_server_url(url: str) -> Tuple[str, int, str]:\n    """\n    Parse and validate server URL.\n    \n    Args:\n        url: URL string to parse (e.g., "https://example.com:443")\n    \n    Returns:\n        Tuple of (hostname, port, scheme)\n    \n    Raises:\n        ValueError: If URL is invalid or not HTTPS\n    \n    Security: Validates URL format and enforces HTTPS to prevent insecure connections.\n    """\n    if not url or not isinstance(url, str):\n        raise ValueError("URL must be a non-empty string")\n    \n    # Limit URL length to prevent resource exhaustion\n    if len(url) > 2048:\n        raise ValueError("URL exceeds maximum length of 2048 characters")\n    \n    parsed = urlparse(url)\n    \n    # Only allow HTTPS to ensure encrypted connections\n    if parsed.scheme != "https":\n        raise ValueError("Only HTTPS URLs are supported")\n    \n    hostname = parsed.hostname\n    if not hostname:\n        raise ValueError("Invalid hostname in URL")\n    \n    # Validate hostname length (max 255 per RFC 1035)\n    if len(hostname) > 255:\n        raise ValueError("Hostname exceeds maximum length")\n    \n    # Get port or default to 443 for HTTPS\n    port = parsed.port if parsed.port else 443\n    \n    # Validate port range\n    if not isinstance(port, int) or port < 1 or port > 65535:\n        raise ValueError("Port must be between 1 and 65535")\n    \n    return hostname, port, parsed.scheme\n\n\ndef establish_secure_connection(\n    hostname: str, \n    port: int, \n    timeout: float = 10.0\n) -> Tuple[ssl.SSLSocket, dict]:\n    """\n    Establish a secure SSL/TLS connection to a remote server.\n    \n    Args:\n        hostname: Server hostname to connect to\n        port: Server port number\n        timeout: Connection timeout in seconds (default: 10.0)\n    \n    Returns:\n        Tuple of (ssl_socket, certificate_info)\n    \n    Raises:\n        ssl.SSLError: If SSL/TLS connection fails\n        socket.error: If network connection fails\n        ValueError: If certificate validation fails\n    \n    Security: \n    - Validates SSL certificates including hostname verification (CWE-295, CWE-297)\n    - Enforces TLS 1.2+ (CWE-327)\n    - Implements connection timeout to prevent resource exhaustion\n    """\n    # Validate inputs\n    if not hostname or not isinstance(hostname, str):\n        raise ValueError("Hostname must be a non-empty string")\n    \n    if not isinstance(port, int) or port < 1 or port > 65535:\n        raise ValueError("Port must be between 1 and 65535")\n    \n    if not isinstance(timeout, (int, float)) or timeout <= 0 or timeout > 300:\n        raise ValueError("Timeout must be between 0 and 300 seconds")\n    \n    # Create secure SSL context\n    context = create_secure_context()\n    \n    # Create raw socket with timeout\n    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n    sock.settimeout(timeout)\n    \n    ssl_sock = None\n    try:\n        # Connect to server\n        sock.connect((hostname, port))\n        \n        # Wrap socket with SSL/TLS - hostname verification is automatic (CWE-297)\n        ssl_sock = context.wrap_socket(sock, server_hostname=hostname)\n        \n        # Get and validate peer certificate (CWE-295)\n        cert = ssl_sock.getpeercert()\n        if not cert:\n            raise ValueError("Server did not provide a certificate")\n        \n        # Verify certificate subject matches hostname\n        ssl.match_hostname(cert, hostname)\n        \n        # Extract certificate information for logging (no sensitive data)\n        cert_info = {\n            "subject": dict(x[0] for x in cert.get("subject", [])),\n            "issuer": dict(x[0] for x in cert.get("issuer", [])),\n            "version": cert.get("version"),\n            "serialNumber": cert.get("serialNumber"),\n            "notBefore": cert.get("notBefore"),\n            "notAfter": cert.get("notAfter"),\n            "protocol": ssl_sock.version(),\n            "cipher": ssl_sock.cipher()\n        }\n        \n        return ssl_sock, cert_info\n        \n    except (ssl.SSLError, socket.error, ValueError) as e:\n        # Clean up on error\n        if ssl_sock:\n            try:\n                ssl_sock.close()\n            except Exception:\n                pass\n        else:\n            try:\n                sock.close()\n            except Exception:\n                pass\n        raise\n\n\ndef send_https_request(\n    url: str, \n    request_path: str = "/"\n) -> Tuple[int, str]:\n    """\n    Send an HTTPS GET request and return response.\n    \n    Args:\n        url: Server URL (e.g., "https://example.com")\n        request_path: Path to request (default: "/")\n    \n    Returns:\n        Tuple of (status_code, response_body)\n    \n    Security: Uses secure connection establishment with full certificate validation.\n    """\n    # Parse and validate URL\n    hostname, port, _ = parse_server_url(url)\n    \n    # Validate request path to prevent injection\n    if not request_path or not isinstance(request_path, str):\n        request_path = "/"\n    \n    if len(request_path) > 2048:\n        raise ValueError("Request path exceeds maximum length")\n    \n    # Establish secure connection\n    ssl_sock, cert_info = establish_secure_connection(hostname, port)\n    \n    try:\n        # Construct HTTP request with explicit headers\n        request = (\n            f"GET {request_path} HTTP/1.1\\r\\n"\n            f"Host: {hostname}\\r\\n"\n            f"User-Agent: SecureClient/1.0\\r\\n"\n            f"Connection: close\\r\\n"\n            f"\\r\\n"\n        )\n        \n        # Send request\n        ssl_sock.sendall(request.encode("utf-8"))\n        \n        # Receive response with size limit to prevent memory exhaustion\n        response_parts = []\n        total_size = 0\n        max_size = 10 * 1024 * 1024  # 10 MB limit\n        \n        while True:\n            chunk = ssl_sock.recv(4096)\n            if not chunk:\n                break\n            \n            total_size += len(chunk)\n            if total_size > max_size:\n                raise ValueError("Response exceeds maximum size limit")\n            \n            response_parts.append(chunk)\n        \n        response = b"".join(response_parts).decode("utf-8", errors="replace")\n        \n        # Parse status code\n        status_code = 0\n        if response:\n            first_line = response.split("\\r\\n")[0]\n            parts = first_line.split()\n            if len(parts) >= 2:\n                try:\n                    status_code = int(parts[1])\n                except (ValueError, IndexError):\n                    status_code = 0\n        \n        return status_code, response\n        \n    finally:\n        # Always close the connection\n        try:\n            ssl_sock.close()\n        except Exception:\n            pass\n\n\ndef main() -> int:\n    """\n    Main function with test cases demonstrating secure SSL/TLS connections.\n    \n    Returns:\n        Exit code (0 for success)\n    """\n    print("Secure SSL/TLS Connection Test Cases")\n    print("=" * 60)\n    \n    # Test case 1: Connect to a well-known HTTPS server\n    print("\\nTest 1: Connecting to https://www.example.com")\n    try:\n        hostname, port, _ = parse_server_url("https://www.example.com")\n        ssl_sock, cert_info = establish_secure_connection(hostname, port)\n        print(f"\u2713 Connected successfully")\n        print(f"  Protocol: {cert_info['protocol']}")\n        print(f"  Cipher: {cert_info['cipher'][0]}")\n        print(f"  Certificate Subject: {cert_info['subject'].get('commonName', 'N/A')}")\n        ssl_sock.close()\n    except Exception as e:\n        print(f"\u2717 Failed: {type(e).__name__}: {e}")\n    \n    # Test case 2: Full HTTPS GET request\n    print("\\nTest 2: HTTPS GET request to https://www.example.com")\n    try:\n        status_code, response = send_https_request("https://www.example.com", "/")\n        print(f"\u2713 Request completed")\n        print(f"  Status Code: {status_code}")\n        print(f"  Response Length: {len(response)} bytes")\n    except Exception as e:\n        print(f"\u2717 Failed: {type(e).__name__}: {e}")\n    \n    # Test case 3: Invalid URL (should fail)\n    print("\\nTest 3: Invalid URL (http instead of https)")\n    try:\n        hostname, port, _ = parse_server_url("http://www.example.com")\n        print(f"\u2717 Should have failed but didn't")\n    except ValueError as e:\n        print(f"\u2713 Correctly rejected: {e}")\n    \n    # Test case 4: Invalid hostname (should fail)\n    print("\\nTest 4: Invalid hostname")\n    try:\n        ssl_sock, cert_info = establish_secure_connection("", 443)\n        print(f"\u2717 Should have failed but didn't")\n    except ValueError as e:\n        print(f"\u2713 Correctly rejected: {e}")\n    \n    # Test case 5: Invalid port (should fail)\n    print("\\nTest 5: Invalid port number")\n    try:\n        ssl_sock, cert_info = establish_secure_connection("www.example.com", 99999)\n        print(f"\u2717 Should have failed but didn't")\n    except ValueError as e:\n        print(f"\u2713 Correctly rejected: {e}")\n    \n    print("\\n" + "=" * 60)\n    print("All test cases completed")\n    \n    return 0\n\n\nif __name__ == "__main__":\n    sys.exit(main())\n```\n\n```java\nimport javax.net.ssl.*;\nimport java.io.*;\nimport java.net.URL;\nimport java.security.cert.Certificate;\nimport java.security.cert.X509Certificate;\nimport java.util.HashMap;\nimport java.util.Map;\n\npublic class Task105 {\n    \n    /**\n     * Creates a secure SSL context with strict security settings.\n     * \n     * Security: Enforces TLS 1.2+ to prevent downgrade attacks (CWE-327).\n     * Certificate validation is enabled by default (CWE-295, CWE-297).\n     */\n    private static SSLContext createSecureContext() throws Exception {\n        // Create SSL context with TLS protocol\n        SSLContext sslContext = SSLContext.getInstance("TLS");\n        \n        // Initialize with default trust manager (validates certificates)\n        sslContext.init(null, null, new java.security.SecureRandom());\n        \n        return sslContext;\n    }\n    \n    /**\n     * Establishes a secure SSL/TLS connection to a remote server.\n     * \n     * Security:\n     * - Validates SSL certificates including hostname verification (CWE-295, CWE-297)\n     * - Enforces TLS 1.2+ (CWE-327)\n     * - Implements connection timeout to prevent resource exhaustion\n     */\n    public static Map<String, Object> establishSecureConnection(\n            String hostname, \n            int port, \n            int timeoutMs\n    ) throws Exception {\n        // Validate inputs\n        if (hostname == null || hostname.trim().isEmpty()) {\n            throw new IllegalArgumentException("Hostname must not be null or empty");\n        }\n        \n        if (hostname.length() > 255) {\n            throw new IllegalArgumentException("Hostname exceeds maximum length of 255 characters");\n        }\n        \n        if (port < 1 || port > 65535) {\n            throw new IllegalArgumentException("Port must be between 1 and 65535");\n        }\n        \n        if (timeoutMs <= 0 || timeoutMs > 300000) {\n            throw new IllegalArgumentException("Timeout must be between 0 and 300000 milliseconds");\n        }\n        \n        // Create secure SSL context\n        SSLContext sslContext = createSecureContext();\n        SSLSocketFactory factory = sslContext.getSocketFactory();\n        \n        SSLSocket sslSocket = null;\n        try {\n            // Create SSL socket with timeout\n            sslSocket = (SSLSocket) factory.createSocket();\n            sslSocket.setSoTimeout(timeoutMs);\n            \n            // Configure enabled protocols to enforce TLS 1.2+ (CWE-327)\n            String[] protocols = sslSocket.getSupportedProtocols();\n            java.util.List<String> enabledProtocols = new java.util.ArrayList<>();\n            for (String protocol : protocols) {\n                if (protocol.equals("TLSv1.2") || protocol.equals("TLSv1.3")) {\n                    enabledProtocols.add(protocol);\n                }\n            }\n            sslSocket.setEnabledProtocols(enabledProtocols.toArray(new String[0]));\n            \n            // Connect to server\n            sslSocket.connect(new java.net.InetSocketAddress(hostname, port), timeoutMs);\n            \n            // Start SSL handshake\n            sslSocket.startHandshake();\n            \n            // Get and validate peer certificates (CWE-295)\n            Certificate[] peerCerts = sslSocket.getSession().getPeerCertificates();\n            if (peerCerts == null || peerCerts.length == 0) {\n                throw new SSLException("Server did not provide a certificate");\n            }\n            \n            // Verify hostname matches certificate (CWE-297)\n            HostnameVerifier hostnameVerifier = HttpsURLConnection.getDefaultHostnameVerifier();\n            if (!hostnameVerifier.verify(hostname, sslSocket.getSession())) {\n                throw new SSLException("Hostname verification failed for: " + hostname);\n            }\n            \n            // Extract certificate information (no sensitive data)\n            Map<String, Object> result = new HashMap<>();\n            result.put("socket", sslSocket);\n            \n            Map<String, String> certInfo = new HashMap<>();\n            if (peerCerts[0] instanceof X509Certificate) {\n                X509Certificate x509 = (X509Certificate) peerCerts[0];\n                certInfo.put("subject", x509.getSubjectX500Principal().getName());\n                certInfo.put("issuer", x509.getIssuerX500Principal().getName());\n                certInfo.put("serialNumber", x509.getSerialNumber().toString());\n                certInfo.put("notBefore", x509.getNotBefore().toString());\n                certInfo.put("notAfter", x509.getNotAfter().toString());\n            }\n            certInfo.put("protocol", sslSocket.getSession().getProtocol());\n            certInfo.put("cipherSuite", sslSocket.getSession().getCipherSuite());\n            \n            result.put("certificateInfo", certInfo);\n            \n            return result;\n            \n        } catch (Exception e) {\n            // Clean up on error\n            if (sslSocket != null) {\n                try {\n                    sslSocket.close();\n                } catch (Exception ignored) {\n                }\n            }\n            throw e;\n        }\n    }\n    \n    /**\n     * Sends an HTTPS GET request and returns the response.\n     * \n     * Security: Uses secure connection establishment with full certificate validation.\n     */\n    public static String sendHttpsRequest(String urlString, String requestPath) throws Exception {\n        // Validate inputs\n        if (urlString == null || urlString.trim().isEmpty()) {\n            throw new IllegalArgumentException("URL must not be null or empty");\n        }\n        \n        if (urlString.length() > 2048) {\n            throw new IllegalArgumentException("URL exceeds maximum length of 2048 characters");\n        }\n        \n        if (!urlString.startsWith("https://")) {\n            throw new IllegalArgumentException("Only HTTPS URLs are supported");\n        }\n        \n        if (requestPath == null || requestPath.isEmpty()) {\n            requestPath = "/";\n        }\n        \n        if (requestPath.length() > 2048) {\n            throw new IllegalArgumentException("Request path exceeds maximum length");\n        }\n        \n        // Parse URL\n        URL url = new URL(urlString);\n        String hostname = url.getHost();\n        int port = url.getPort() == -1 ? 443 : url.getPort();\n        \n        // Establish secure connection\n        Map<String, Object> connResult = establishSecureConnection(hostname, port, 10000);\n        SSLSocket sslSocket = (SSLSocket) connResult.get("socket");\n        \n        try (\n            BufferedWriter writer = new BufferedWriter(\n                new OutputStreamWriter(sslSocket.getOutputStream(), java.nio.charset.StandardCharsets.UTF_8)\n            );\n            BufferedReader reader = new BufferedReader(\n                new InputStreamReader(sslSocket.getInputStream(), java.nio.charset.StandardCharsets.UTF_8)\n            )\n        ) {\n            // Construct HTTP request\n            writer.write("GET " + requestPath + " HTTP/1.1\\r\\n");\n            writer.write("Host: " + hostname + "\\r\\n");\n            writer.write("User-Agent: SecureClient/1.0\\r\\n");\n            writer.write("Connection: close\\r\\n");\n            writer.write("\\r\\n");\n            writer.flush();\n            \n            // Read response with size limit to prevent memory exhaustion\n            StringBuilder response = new StringBuilder();\n            String line;\n            int totalSize = 0;\n            int maxSize = 10 * 1024 * 1024; // 10 MB limit\n            \n            while ((line = reader.readLine()) != null) {\n                totalSize += line.length() + 2; // +2 for line terminators\n                if (totalSize > maxSize) {\n                    throw new IOException("Response exceeds maximum size limit");\n                }\n                response.append(line).append("\\r\\n");\n            }\n            \n            return response.toString();\n            \n        } finally {\n            // Always close the socket\n            try {\n                sslSocket.close();\n            } catch (Exception ignored) {\n            }\n        }\n    }\n    \n    /**\n     * Main method with test cases demonstrating secure SSL/TLS connections.\n     */\n    public static void main(String[] args) {\n        System.out.println("Secure SSL/TLS Connection Test Cases");\n        System.out.println("=".repeat(60));\n        \n        // Test case 1: Connect to a well-known HTTPS server\n        System.out.println("\\nTest 1: Connecting to https://www.example.com");\n        try {\n            Map<String, Object> result = establishSecureConnection("www.example.com", 443, 10000);\n            @SuppressWarnings("unchecked")\n            Map<String, String> certInfo = (Map<String, String>) result.get("certificateInfo");\n            System.out.println("\u2713 Connected successfully");\n            System.out.println("  Protocol: " + certInfo.get("protocol"));\n            System.out.println("  Cipher Suite: " + certInfo.get("cipherSuite"));\n            \n            SSLSocket socket = (SSLSocket) result.get("socket");\n            socket.close();\n        } catch (Exception e) {\n            System.out.println("\u2717 Failed: " + e.getClass().getSimpleName() + ": " + e.getMessage());\n        }\n        \n        // Test case 2: Full HTTPS GET request\n        System.out.println("\\nTest 2: HTTPS GET request to https://www.example.com");\n        try {\n            String response = sendHttpsRequest("https://www.example.com", "/");\n            System.out.println("\u2713 Request completed");\n            System.out.println("  Response Length: " + response.length() + " bytes");\n            \n            // Parse status code\n            String[] lines = response.split("\\r\\n");\n            if (lines.length > 0) {\n                String[] parts = lines[0].split(" ");\n                if (parts.length >= 2) {\n                    System.out.println("  Status Code: " + parts[1]);\n                }\n            }\n        } catch (Exception e) {\n            System.out.println("\u2717 Failed: " + e.getClass().getSimpleName() + ": " + e.getMessage());\n        }\n        \n        // Test case 3: Invalid URL (should fail)\n        System.out.println("\\nTest 3: Invalid URL (http instead of https)");\n        try {\n            sendHttpsRequest("http://www.example.com", "/");\n            System.out.println("\u2717 Should have failed but didn't");\n        } catch (IllegalArgumentException e) {\n            System.out.println("\u2713 Correctly rejected: " + e.getMessage());\n        } catch (Exception e) {\n            System.out.println("\u2717 Wrong exception: " + e.getMessage());\n        }\n        \n        // Test case 4: Invalid hostname (should fail)\n        System.out.println("\\nTest 4: Invalid hostname");\n        try {\n            establishSecureConnection("", 443, 10000);\n            System.out.println("\u2717 Should have failed but didn't");\n        } catch (IllegalArgumentException e) {\n            System.out.println("\u2713 Correctly rejected: " + e.getMessage());\n        } catch (Exception e) {\n            System.out.println("\u2717 Wrong exception: " + e.getMessage());\n        }\n        \n        // Test case 5: Invalid port (should fail)\n        System.out.println("\\nTest 5: Invalid port number");\n        try {\n            establishSecureConnection("www.example.com", 99999, 10000);\n            System.out.println("\u2717 Should have failed but didn't");\n        } catch (IllegalArgumentException e) {\n            System.out.println("\u2713 Correctly rejected: " + e.getMessage());\n        } catch (Exception e) {\n            System.out.println("\u2717 Wrong exception: " + e.getMessage());\n        }\n        \n        System.out.println("\\n" + "=".repeat(60));\n        System.out.println("All test cases completed");\n    }\n}\n```\n\n```cpp\n#include <iostream>\n#include <string>\n#include <memory>\n#include <vector>\n#include <cstring>\n#include <openssl/ssl.h>\n#include <openssl/err.h>\n#include <openssl/x509v3.h>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <netdb.h>\n#include <unistd.h>\n\n// RAII wrapper for SSL context\nclass SSLContextRAII {\nprivate:\n    SSL_CTX* ctx;\n    \npublic:\n    SSLContextRAII() : ctx(nullptr) {\n        // Initialize OpenSSL\n        SSL_library_init();\n        SSL_load_error_strings();\n        OpenSSL_add_all_algorithms();\n        \n        // Create SSL context with TLS method (supports TLS 1.2 and 1.3)\n        ctx = SSL_CTX_new(TLS_client_method());\n        if (!ctx) {\n            throw std::runtime_error("Failed to create SSL context");\n        }\n        \n        // Set minimum protocol version to TLS 1.2 (CWE-327)\n        if (!SSL_CTX_set_min_proto_version(ctx, TLS1_2_VERSION)) {\n            SSL_CTX_free(ctx);\n            throw std::runtime_error("Failed to set minimum TLS version");\n        }\n        \n        // Load default certificate store for validation (CWE-295)\n        if (!SSL_CTX_set_default_verify_paths(ctx)) {\n            SSL_CTX_free(ctx);\n            throw std::runtime_error("Failed to load certificate store");\n        }\n        \n        // Enable certificate verification (CWE-295, CWE-297)\n        SSL_CTX_set_verify(ctx, SSL_VERIFY_PEER, nullptr);\n    }\n    \n    ~SSLContextRAII() {\n        if (ctx) {\n            SSL_CTX_free(ctx);\n        }\n    }\n    \n    // Disable copy\n    SSLContextRAII(const SSLContextRAII&) = delete;\n    SSLContextRAII& operator=(const SSLContextRAII&) = delete;\n    \n    SSL_CTX* get() const { return ctx; }\n};\n\n// RAII wrapper for SSL connection\nclass SSLConnectionRAII {\nprivate:\n    SSL* ssl;\n    int socket_fd;\n    \npublic:\n    SSLConnectionRAII(SSL_CTX* ctx, int sock) : ssl(nullptr), socket_fd(sock) {\n        ssl = SSL_new(ctx);\n        if (!ssl) {\n            throw std::runtime_error("Failed to create SSL object");\n        }\n        \n        if (!SSL_set_fd(ssl, socket_fd)) {\n            SSL_free(ssl);\n            throw std::runtime_error("Failed to set socket file descriptor");\n        }\n    }\n    \n    ~SSLConnectionRAII() {\n        if (ssl) {\n            SSL_shutdown(ssl);\n            SSL_free(ssl);\n        }\n        if (socket_fd >= 0) {\n            close(socket_fd);\n        }\n    }\n    \n    // Disable copy\n    SSLConnectionRAII(const SSLConnectionRAII&) = delete;\n    SSLConnectionRAII& operator=(const SSLConnectionRAII&) = delete;\n    \n    SSL* get() const { return ssl; }\n    int get_socket() const { return socket_fd; }\n};\n\n// Validate hostname length and format\nbool validate_hostname(const std::string& hostname) {\n    if (hostname.empty() || hostname.length() > 255) {\n        return false;\n    }\n    // Basic validation - no null bytes\n    if (hostname.find('\\0') != std::string::npos) {\n        return false;\n    }\n    return true;\n}\n\n// Validate port range\nbool validate_port(int port) {\n    return port >= 1 && port <= 65535;\n}\n\n// Verify hostname matches certificate (CWE-297)\nbool verify_hostname(SSL* ssl, const std::string& hostname) {\n    if (!ssl || hostname.empty()) {\n        return false;\n    }\n    \n    // Get peer certificate\n    X509* cert = SSL_get_peer_certificate(ssl);\n    if (!cert) {\n        std::cerr << "Server did not provide a certificate" << std::endl;\n        return false;\n    }\n    \n    // Verify certificate\n    long verify_result = SSL_get_verify_result(ssl);\n    if (verify_result != X509_V_OK) {\n        std::cerr << "Certificate verification failed: " \n                  << X509_verify_cert_error_string(verify_result) << std::endl;\n        X509_free(cert);\n        return false;\n    }\n    \n    // Check hostname in certificate\n    int result = X509_check_host(cert, hostname.c_str(), hostname.length(), 0, nullptr);\n    X509_free(cert);\n    \n    return result == 1;\n}\n\n// Establish secure SSL/TLS connection\nstd::unique_ptr<SSLConnectionRAII> establish_secure_connection(\n    const std::string& hostname, \n    int port, \n    int timeout_sec\n) {\n    // Validate inputs\n    if (!validate_hostname(hostname)) {\n        throw std::invalid_argument("Invalid hostname");\n    }\n    \n    if (!validate_port(port)) {\n        throw std::invalid_argument("Port must be between 1 and 65535");\n    }\n    \n    if (timeout_sec <= 0 || timeout_sec > 300) {\n        throw std::invalid_argument("Timeout must be between 0 and 300 seconds");\n    }\n    \n    // Resolve hostname\n    struct addrinfo hints, *result = nullptr;\n    std::memset(&hints, 0, sizeof(hints));\n    hints.ai_family = AF_INET;\n    hints.ai_socktype = SOCK_STREAM;\n    \n    std::string port_str = std::to_string(port);\n    int ret = getaddrinfo(hostname.c_str(), port_str.c_str(), &hints, &result);\n    if (ret != 0) {\n        throw std::runtime_error(std::string("Failed to resolve hostname: ") + gai_strerror(ret));\n    }\n    \n    // Create socket\n    int sock = socket(result->ai_family, result->ai_socktype, result->ai_protocol);\n    if (sock < 0) {\n        freeaddrinfo(result);\n        throw std::runtime_error("Failed to create socket");\n    }\n    \n    // Set socket timeout\n    struct timeval tv;\n    tv.tv_sec = timeout_sec;\n    tv.tv_usec = 0;\n    setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));\n    setsockopt(sock, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof(tv));\n    \n    // Connect to server\n    if (connect(sock, result->ai_addr, result->ai_addrlen) < 0) {\n        close(sock);\n        freeaddrinfo(result);\n        throw std::runtime_error("Failed to connect to server");\n    }\n    \n    freeaddrinfo(result);\n    \n    // Create SSL context\n    SSLContextRAII ctx;\n    \n    // Create SSL connection\n    auto ssl_conn = std::make_unique<SSLConnectionRAII>(ctx.get(), sock);\n    SSL* ssl = ssl_conn->get();\n    \n    // Set hostname for SNI and verification (CWE-297)\n    if (!SSL_set_tlsext_host_name(ssl, hostname.c_str())) {\n        throw std::runtime_error("Failed to set SNI hostname");\n    }\n    \n    // Perform SSL handshake\n    if (SSL_connect(ssl) != 1) {\n        unsigned long err = ERR_get_error();\n        char err_buf[256];\n        ERR_error_string_n(err, err_buf, sizeof(err_buf));\n        throw std::runtime_error(std::string("SSL handshake failed: ") + err_buf);\n    }\n    \n    // Verify hostname matches certificate (CWE-297)\n    if (!verify_hostname(ssl, hostname)) {\n        throw std::runtime_error("Hostname verification failed");\n    }\n    \n    return ssl_conn;\n}\n\n// Send HTTPS GET request\nstd::string send_https_request(\n    const std::string& hostname, \n    int port, \n    const std::string& path\n) {\n    // Validate inputs\n    if (path.length() > 2048) {\n        throw std::invalid_argument("Request path exceeds maximum length");\n    }\n    \n    // Establish secure connection\n    auto ssl_conn = establish_secure_connection(hostname, port, 10);\n    SSL* ssl = ssl_conn->get();\n    \n    // Construct HTTP request\n    std::string request = \n        "GET " + path + " HTTP/1.1\\r\\n" +\n        "Host: " + hostname + "\\r\\n" +\n        "User-Agent: SecureClient/1.0\\r\\n" +\n        "Connection: close\\r\\n" +\n        "\\r\\n";\n    \n    // Send request\n    int bytes_sent = SSL_write(ssl, request.c_str(), request.length());\n    if (bytes_sent <= 0) {\n        throw std::runtime_error("Failed to send request");\n    }\n    \n    // Read response with size limit\n    std::string response;\n    const size_t max_size = 10 * 1024 * 1024; // 10 MB limit\n    std::vector<char> buffer(4096);\n    \n    while (true) {\n        int bytes_read = SSL_read(ssl, buffer.data(), buffer.size());\n        if (bytes_read <= 0) {\n            break;\n        }\n        \n        if (response.size() + bytes_read > max_size) {\n            throw std::runtime_error("Response exceeds maximum size limit");\n        }\n        \n        response.append(buffer.data(), bytes_read);\n    }\n    \n    return response;\n}\n\nint main() {\n    std::cout << "Secure SSL/TLS Connection Test Cases" << std::endl;\n    std::cout << std::string(60, '=') << std::endl;\n    \n    // Test case 1: Connect to a well-known HTTPS server\n    std::cout << "\\nTest 1: Connecting to www.example.com:443" << std::endl;\n    try {\n        auto conn = establish_secure_connection("www.example.com", 443, 10);\n        SSL* ssl = conn->get();\n        std::cout << "\u2713 Connected successfully" << std::endl;\n        std::cout << "  Protocol: " << SSL_get_version(ssl) << std::endl;\n        \n        const SSL_CIPHER* cipher = SSL_get_current_cipher(ssl);\n        if (cipher) {\n            std::cout << "  Cipher: " << SSL_CIPHER_get_name(cipher) << std::endl;\n        }\n    } catch (const std::exception& e) {\n        std::cout << "\u2717 Failed: " << e.what() << std::endl;\n    }\n    \n    // Test case 2: Full HTTPS GET request\n    std::cout << "\\nTest 2: HTTPS GET request to www.example.com" << std::endl;\n    try {\n        std::string response = send_https_request("www.example.com", 443, "/");\n        std::cout << "\u2713 Request completed" << std::endl;\n        std::cout << "  Response Length: " << response.length() << " bytes" << std::endl;\n        \n        // Parse status code\n        size_t pos = response.find(' ');\n        if (pos != std::string::npos) {\n            size_t end = response.find(' ', pos + 1);\n            if (end != std::string::npos) {\n                std::cout << "  Status Code: " << response.substr(pos + 1, end - pos - 1) << std::endl;\n            }\n        }\n    } catch (const std::exception& e) {\n        std::cout << "\u2717 Failed: " << e.what() << std::endl;\n    }\n    \n    // Test case 3: Invalid hostname (should fail)\n    std::cout << "\\nTest 3: Invalid hostname (empty)" << std::endl;\n    try {\n        auto conn = establish_secure_connection("", 443, 10);\n        std::cout << "\u2717 Should have failed but didn't" << std::endl;\n    } catch (const std::invalid_argument& e) {\n        std::cout << "\u2713 Correctly rejected: " << e.what() << std::endl;\n    } catch (const std::exception& e) {\n        std::cout << "\u2717 Wrong exception: " << e.what() << std::endl;\n    }\n    \n    // Test case 4: Invalid port (should fail)\n    std::cout << "\\nTest 4: Invalid port number" << std::endl;\n    try {\n        auto conn = establish_secure_connection("www.example.com", 99999, 10);\n        std::cout << "\u2717 Should have failed but didn't" << std::endl;\n    } catch (const std::invalid_argument& e) {\n        std::cout << "\u2713 Correctly rejected: " << e.what() << std::endl;\n    } catch (const std::exception& e) {\n        std::cout << "\u2717 Wrong exception: " << e.what() << std::endl;\n    }\n    \n    // Test case 5: Invalid timeout (should fail)\n    std::cout << "\\nTest 5: Invalid timeout" << std::endl;\n    try {\n        auto conn = establish_secure_connection("www.example.com", 443, 500);\n        std::cout << "\u2717 Should have failed but didn't" << std::endl;\n    } catch (const std::invalid_argument& e) {\n        std::cout << "\u2713 Correctly rejected: " << e.what() << std::endl;\n    } catch (const std::exception& e) {\n        std::cout << "\u2717 Wrong exception: " << e.what() << std::endl;\n    }\n    \n    std::cout << "\\n" << std::string(60, '=') << std::endl;\n    std::cout << "All test cases completed" << std::endl;\n    \n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <openssl/ssl.h>\n#include <openssl/err.h>\n#include <openssl/x509v3.h>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <netdb.h>\n#include <unistd.h>\n\n#define MAX_HOSTNAME_LEN 255\n#define MAX_PATH_LEN 2048\n#define MAX_RESPONSE_SIZE (10 * 1024 * 1024)\n#define BUFFER_SIZE 4096\n\n/* Structure to hold SSL connection */\ntypedef struct {\n    SSL_CTX* ctx;\n    SSL* ssl;\n    int socket_fd;\n} SecureConnection;\n\n/* Initialize SecureConnection structure to NULL/invalid values */\nvoid init_connection(SecureConnection* conn) {\n    if (conn == NULL) {\n        return;\n    }\n    conn->ctx = NULL;\n    conn->ssl = NULL;\n    conn->socket_fd = -1;\n}\n\n/* Clean up and free SecureConnection resources */\nvoid cleanup_connection(SecureConnection* conn) {\n    if (conn == NULL) {\n        return;\n    }\n    \n    if (conn->ssl != NULL) {\n        SSL_shutdown(conn->ssl);\n        SSL_free(conn->ssl);\n        conn->ssl = NULL;\n    }\n    \n    if (conn->ctx != NULL) {\n        SSL_CTX_free(conn->ctx);\n        conn->ctx = NULL;\n    }\n    \n    if (conn->socket_fd >= 0) {\n        close(conn->socket_fd);\n        conn->socket_fd = -1;\n    }\n}\n\n/* Validate hostname - length and no null bytes */\nint validate_hostname(const char* hostname) {\n    size_t len;\n    size_t i;\n    \n    if (hostname == NULL) {\n        return 0;\n    }\n    \n    len = strlen(hostname);\n    if (len == 0 || len > MAX_HOSTNAME_LEN) {\n        return 0;\n    }\n    \n    /* Check for null bytes in hostname */\n    for (i = 0; i < len; i++) {\n        if (hostname[i] == '\\0') {\n            return 0;\n        }\n    }\n    \n    return 1;\n}\n\n/* Validate port range */\nint validate_port(int port) {\n    return (port >= 1 && port <= 65535);\n}\n\n/* Verify hostname matches certificate (CWE-297) */\nint verify_hostname(SSL* ssl, const char* hostname) {\n    X509* cert = NULL;\n    long verify_result;\n    int result;\n    \n    if (ssl == NULL || hostname == NULL) {\n        return 0;\n    }\n    \n    /* Get peer certificate */\n    cert = SSL_get_peer_certificate(ssl);\n    if (cert == NULL) {\n        fprintf(stderr, "Server did not provide a certificate\\n");\n        return 0;\n    }\n    \n    /* Verify certificate */\n    verify_result = SSL_get_verify_result(ssl);\n    if (verify_result != X509_V_OK) {\n        fprintf(stderr, "Certificate verification failed: %s\\n",\n                X509_verify_cert_error_string(verify_result));\n        X509_free(cert);\n        return 0;\n    }\n    \n    /* Check hostname in certificate */\n    result = X509_check_host(cert, hostname, strlen(hostname), 0, NULL);\n    X509_free(cert);\n    \n    return (result == 1);\n}\n\n/* Create secure SSL context with TLS 1.2+ enforcement (CWE-327) */\nSSL_CTX* create_secure_context(void) {\n    SSL_CTX* ctx = NULL;\n    \n    /* Initialize OpenSSL */\n    SSL_library_init();\n    SSL_load_error_strings();\n    OpenSSL_add_all_algorithms();\n    \n    /* Create SSL context with TLS method */\n    ctx = SSL_CTX_new(TLS_client_method());\n    if (ctx == NULL) {\n        fprintf(stderr, "Failed to create SSL context\\n");\n        return NULL;\n    }\n    \n    /* Set minimum protocol version to TLS 1.2 (CWE-327) */\n    if (!SSL_CTX_set_min_proto_version(ctx, TLS1_2_VERSION)) {\n        fprintf(stderr, "Failed to set minimum TLS version\\n");\n        SSL_CTX_free(ctx);\n        return NULL;\n    }\n    \n    /* Load default certificate store for validation (CWE-295) */\n    if (!SSL_CTX_set_default_verify_paths(ctx)) {\n        fprintf(stderr, "Failed to load certificate store\\n");\n        SSL_CTX_free(ctx);\n        return NULL;\n    }\n    \n    /* Enable certificate verification (CWE-295, CWE-297) */\n    SSL_CTX_set_verify(ctx, SSL_VERIFY_PEER, NULL);\n    \n    return ctx;\n}\n\n/* Establish secure SSL/TLS connection to remote server */\nint establish_secure_connection(\n    const char* hostname,\n    int port,\n    int timeout_sec,\n    SecureConnection* conn\n) {\n    struct addrinfo hints;\n    struct addrinfo* result = NULL;\n    char port_str[16];\n    int ret;\n    struct timeval tv;\n    \n    /* Validate inputs */\n    if (hostname == NULL || conn == NULL) {\n        fprintf(stderr, "Invalid NULL parameter\\n");\n        return 0;\n    }\n    \n    init_connection(conn);\n    \n    if (!validate_hostname(hostname)) {\n        fprintf(stderr, "Invalid hostname\\n");\n        return 0;\n    }\n    \n    if (!validate_port(port)) {\n        fprintf(stderr, "Port must be between 1 and 65535\\n");\n        return 0;\n    }\n    \n    if (timeout_sec <= 0 || timeout_sec > 300) {\n        fprintf(stderr, "Timeout must be between 0 and 300 seconds\\n");\n        return 0;\n    }\n    \n    /* Resolve hostname */\n    memset(&hints, 0, sizeof(hints));\n    hints.ai_family = AF_INET;\n    hints.ai_socktype = SOCK_STREAM;\n    \n    ret = snprintf(port_str, sizeof(port_str), "%d", port);\n    if (ret < 0 || ret >= (int)sizeof(port_str)) {\n        fprintf(stderr, "Failed to format port string\\n");\n        return 0;\n    }\n    \n    ret = getaddrinfo(hostname, port_str, &hints, &result);\n    if (ret != 0) {\n        fprintf(stderr, "Failed to resolve hostname: %s\\n", gai_strerror(ret));\n        return 0;\n    }\n    \n    /* Create socket */\n    conn->socket_fd = socket(result->ai_family, result->ai_socktype, result->ai_protocol);\n    if (conn->socket_fd < 0) {\n        fprintf(stderr, "Failed to create socket\\n");\n        freeaddrinfo(result);\n        return 0;\n    }\n    \n    /* Set socket timeout */\n    tv.tv_sec = timeout_sec;\n    tv.tv_usec = 0;\n    setsockopt(conn->socket_fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));\n    setsockopt(conn->socket_fd, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof(tv));\n    \n    /* Connect to server */\n    if (connect(conn->socket_fd, result->ai_addr, result->ai_addrlen) < 0) {\n        fprintf(stderr, "Failed to connect to server\\n");\n        freeaddrinfo(result);\n        cleanup_connection(conn);\n        return 0;\n    }\n    \n    freeaddrinfo(result);\n    \n    /* Create SSL context */\n    conn->ctx = create_secure_context();\n    if (conn->ctx == NULL) {\n        cleanup_connection(conn);\n        return 0;\n    }\n    \n    /* Create SSL connection */\n    conn->ssl = SSL_new(conn->ctx);\n    if (conn->ssl == NULL) {\n        fprintf(stderr, "Failed to create SSL object\\n");\n        cleanup_connection(conn);\n        return 0;\n    }\n    \n    if (!SSL_set_fd(conn->ssl, conn->socket_fd)) {\n        fprintf(stderr, "Failed to set socket file descriptor\\n");\n        cleanup_connection(conn);\n        return 0;\n    }\n    \n    /* Set hostname for SNI and verification (CWE-297) */\n    if (!SSL_set_tlsext_host_name(conn->ssl, hostname)) {\n        fprintf(stderr, "Failed to set SNI hostname\\n");\n        cleanup_connection(conn);\n        return 0;\n    }\n    \n    /* Perform SSL handshake */\n    if (SSL_connect(conn->ssl) != 1) {\n        unsigned long err = ERR_get_error();\n        char err_buf[256];\n        ERR_error_string_n(err, err_buf, sizeof(err_buf));\n        fprintf(stderr, "SSL handshake failed: %s\\n", err_buf);\n        cleanup_connection(conn);\n        return 0;\n    }\n    \n    /* Verify hostname matches certificate (CWE-297) */\n    if (!verify_hostname(conn->ssl, hostname)) {\n        fprintf(stderr, "Hostname verification failed\\n");\n        cleanup_connection(conn);\n        return 0;\n    }\n    \n    return 1;\n}\n\n/* Send HTTPS GET request and return response */\nchar* send_https_request(\n    const char* hostname,\n    int port,\n    const char* path,\n    size_t* response_len\n) {\n    SecureConnection conn;\n    char* request = NULL;\n    char* response = NULL;\n    size_t request_len;\n    size_t total_size = 0;\n    size_t current_capacity = BUFFER_SIZE;\n    int bytes_sent;\n    int bytes_read;\n    char buffer[BUFFER_SIZE];\n    char* new_response = NULL;\n    \n    /* Validate inputs */\n    if (hostname == NULL || path == NULL || response_len == NULL) {\n        fprintf(stderr, "Invalid NULL parameter\\n");\n        return NULL;\n    }\n    \n    *response_len = 0;\n    \n    if (strlen(path) > MAX_PATH_LEN) {\n        fprintf(stderr, "Request path exceeds maximum length\\n");\n        return NULL;\n    }\n    \n    /* Establish secure connection */\n    if (!establish_secure_connection(hostname, port, 10, &conn)) {\n        return NULL;\n    }\n    \n    /* Construct HTTP request */\n    request_len = strlen("GET ") + strlen(path) + strlen(" HTTP/1.1\\r\\nHost: ") +\n                  strlen(hostname) + strlen("\\r\\nUser-Agent: SecureClient/1.0\\r\\n"\n                  "Connection: close\\r\\n\\r\\n") + 1;\n    \n    request = (char*)malloc(request_len);\n    if (request == NULL) {\n        fprintf(stderr, "Failed to allocate memory for request\\n");\n        cleanup_connection(&conn);\n        return NULL;\n    }\n    \n    ret = snprintf(request, request_len,\n                   "GET %s HTTP/1.1\\r\\n"\n                   "Host: %s\\r\\n"\n                   "User-Agent: SecureClient/1.0\\r\\n"\n                   "Connection: close\\r\\n"\n                   "\\r\\n",\n                   path, hostname);\n    \n    if (ret < 0 || ret >= (int)request_len) {\n        fprintf(stderr, "Failed to format request\\n");\n        free(request);\n        cleanup_connection(&conn);\n        return NULL;\n    }\n    \n    /* Send request */\n    bytes_sent = SSL_write(conn.ssl, request, strlen(request));\n    free(request);\n    request = NULL;\n    \n    if (bytes_sent <= 0) {\n        fprintf(stderr, "Failed to send request\\n");\n        cleanup_connection(&conn);\n        return NULL;\n    }\n    \n    /* Allocate initial response buffer */\n    response = (char*)malloc(current_capacity);\n    if (response == NULL) {\n        fprintf(stderr, "Failed to allocate memory for response\\n");\n        cleanup_connection(&conn);\n        return NULL;\n    }\n    \n    /* Read response with size limit */\n    while (1) {\n        bytes_read = SSL_read(conn.ssl, buffer, sizeof(buffer));\n        if (bytes_read <= 0) {\n            break;\n        }\n        \n        /* Check size limit */\n        if (total_size + bytes_read > MAX_RESPONSE_SIZE) {\n            fprintf(stderr, "Response exceeds maximum size limit\\n");\n            free(response);\n            cleanup_connection(&conn);\n            return NULL;\n        }\n        \n        /* Expand buffer if needed */\n        if (total_size + bytes_read >= current_capacity) {\n            current_capacity *= 2;\n            if (current_capacity > MAX_RESPONSE_SIZE) {\n                current_capacity = MAX_RESPONSE_SIZE;\n            }\n            \n            new_response = (char*)realloc(response, current_capacity);\n            if (new_response == NULL) {\n                fprintf(stderr, "Failed to reallocate response buffer\\n");\n                free(response);\n                cleanup_connection(&conn);\n                return NULL;\n            }\n            response = new_response;\n        }\n        \n        /* Copy data to response buffer */\n        memcpy(response + total_size, buffer, bytes_read);\n        total_size += bytes_read;\n    }\n    \n    cleanup_connection(&conn);\n    \n    /* Null-terminate response */\n    if (total_size < current_capacity) {\n        response[total_size] = '\\0';\n    } else {\n        new_response = (char*)realloc(response, total_size + 1);\n        if (new_response == NULL) {\n            fprintf(stderr, "Failed to null-terminate response\\n");\n            free(response);\n            return NULL;\n        }\n        response = new_response;\n        response[total_size] = '\\0';\n    }\n    \n    *response_len = total_size;\n    return response;\n}\n\nint main(void) {\n    SecureConnection conn;\n    char* response = NULL;\n    size_t response_len;\n    char* status_start = NULL;\n    char* status_end = NULL;\n    \n    printf("Secure SSL/TLS Connection Test Cases\\n");\n    printf("============================================================\\n");\n    \n    /* Test case 1: Connect to a well-known HTTPS server */\n    printf("\\nTest 1: Connecting to www.example.com:443\\n");\n    if (establish_secure_connection("www.example.com", 443, 10, &conn)) {\n        printf("\u2713 Connected successfully\\n");\n        printf("  Protocol: %s\\n", SSL_get_version(conn.ssl));\n        \n        if (SSL_get_current_cipher(conn.ssl) != NULL) {\n            printf("  Cipher: %s\\n", SSL_CIPHER_get_name(SSL_get_current_cipher(conn.ssl)));\n        }\n        \n        cleanup_connection(&conn);\n    } else {\n        printf("\u2717 Failed to connect\\n");\n    }\n    \n    /* Test case 2: Full HTTPS GET request */\n    printf("\\nTest 2: HTTPS GET request to www.example.com\\n");\n    response = send_https_request("www.example.com", 443, "/", &response_len);\n    if (response != NULL) {\n        printf("\u2713 Request completed\\n");\n        printf("  Response Length: %zu bytes\\n", response_len);\n        \n        /* Parse status code */\n        status_start = strchr(response, ' ');\n        if (status_start != NULL) {\n            status_start++;\n            status_end = strchr(status_start, ' ');\n            if (status_end != NULL) {\n                *status_end = '\\0';\n                printf("  Status Code: %s\\n", status_start);\n            }\n        }\n        \n        free(response);\n        response = NULL;\n    } else {\n        printf("\u2717 Failed to send request\\n");\n    }\n    \n    /* Test case 3: Invalid hostname (should fail) */\n    printf("\\nTest 3: Invalid hostname (empty)\\n");\n    if (!establish_secure_connection("", 443, 10, &conn)) {\n        printf("\u2713 Correctly rejected invalid hostname\\n");\n    } else {\n        printf("\u2717 Should have failed but didn't\\n");\n        cleanup_connection(&conn);\n    }\n    \n    /* Test case 4: Invalid port (should fail) */\n    printf("\\nTest 4: Invalid port number\\n");\n    if (!establish_secure_connection("www.example.com", 99999, 10, &conn)) {\n        printf("\u2713 Correctly rejected invalid port\\n");\n    } else {\n        printf("\u2717 Should have failed but didn't\\n");\n        cleanup_connection(&conn);\n    }\n    \n    /* Test case 5: Invalid timeout (should fail) */\n    printf("\\nTest 5: Invalid timeout\\n");\n    if (!establish_secure_connection("www.example.com", 443, 500, &conn)) {\n        printf("\u2713 Correctly rejected invalid timeout\\n");\n    } else {\n        printf("\u2717 Should have failed but didn't\\n");\n        cleanup_connection(&conn);\n    }\n    \n    printf("\\n============================================================\\n");\n    printf("All test cases completed\\n");\n    \n    return 0;\n}\n```', type='text')
