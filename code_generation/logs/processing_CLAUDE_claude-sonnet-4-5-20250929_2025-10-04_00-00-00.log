                throw new IllegalArgumentException("Invalid password");\n            }\n            \n            try (Socket socket = new Socket(serverHost, serverPort);\n                 PrintWriter out = new PrintWriter(\n                     new OutputStreamWriter(socket.getOutputStream(), StandardCharsets.UTF_8), true);\n                 BufferedReader in = new BufferedReader(\n                     new InputStreamReader(socket.getInputStream(), StandardCharsets.UTF_8))) {\n                \n                String request = String.format("LOGIN:%s:%s", username, password);\n                out.println(request);\n                \n                String response = in.readLine();\n                if (response == null || response.length() > 1024) {\n                    return "ERROR:Invalid response";\n                }\n                return response;\n            }\n        }\n    }\n    \n    public static void main(String[] args) throws Exception {\n        int port = 9999;\n        AuthServer server = new AuthServer("./test_users", port);\n        \n        server.addUser("alice", "Password123!");\n        server.addUser("bob", "SecurePass456@");\n        server.addUser("charlie", "MyP@ssw0rd");\n        server.addUser("dave", "TestUser789#");\n        server.addUser("eve", "ComplexP@ss1");\n        \n        Thread serverThread = new Thread(() -> {\n            try {\n                server.start();\n            } catch (Exception e) {\n                System.err.println("Server error");\n            }\n        });\n        serverThread.setDaemon(true);\n        serverThread.start();\n        \n        Thread.sleep(1000);\n        \n        AuthClient client = new AuthClient("localhost", port);\n        \n        System.out.println("Test 1 - Valid login (alice): " + client.login("alice", "Password123!"));\n        System.out.println("Test 2 - Invalid password: " + client.login("bob", "WrongPassword"));\n        System.out.println("Test 3 - Valid login (charlie): " + client.login("charlie", "MyP@ssw0rd"));\n        System.out.println("Test 4 - Non-existent user: " + client.login("frank", "SomePassword1"));\n        System.out.println("Test 5 - Valid login (eve): " + client.login("eve", "ComplexP@ss1"));\n        \n        server.stop();\n    }\n}\n```\n\n```python\nimport socket\nimport secrets\nimport hashlib\nimport os\nfrom pathlib import Path\nfrom typing import Dict, Optional\nfrom cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC\nfrom cryptography.hazmat.primitives import hashes\nfrom cryptography.hazmat.backends import default_backend\n\nPBKDF2_ITERATIONS = 210000\nSALT_LENGTH = 16\nMAX_USERNAME_LENGTH = 64\nMAX_PASSWORD_LENGTH = 128\nMAX_REQUEST_LENGTH = 1024\n\n\nclass AuthServer:\n    def __init__(self, base_directory: str, port: int):\n        self.base_dir = Path(base_directory).resolve()\n        self.base_dir.mkdir(parents=True, exist_ok=True)\n        self.user_database: Dict[str, bytes] = {}\n        self.port = port\n        self.server_socket: Optional[socket.socket] = None\n        self._load_users()\n\n    def _resolve_secure_path(self, filename: str) -> Path:\n        if not filename or len(filename) > 255:\n            raise ValueError("Invalid filename")\n        if ".." in filename or "/" in filename or "\\\\" in filename:\n            raise ValueError("Invalid filename")\n        \n        resolved = (self.base_dir / filename).resolve()\n        if not str(resolved).startswith(str(self.base_dir)):\n            raise ValueError("Path traversal detected")\n        return resolved\n\n    def _load_users(self) -> None:\n        users_file = self._resolve_secure_path("users.dat")\n        if not users_file.exists():\n            return\n        \n        with open(users_file, "r", encoding="utf-8") as f:\n            for line in f:\n                line = line.strip()\n                if not line or len(line) > MAX_REQUEST_LENGTH:\n                    continue\n                parts = line.split(":", 1)\n                if len(parts) == 2:\n                    username, hash_data = parts\n                    if 0 < len(username) <= MAX_USERNAME_LENGTH and 0 < len(hash_data) <= 512:\n                        self.user_database[username] = bytes.fromhex(hash_data)\n\n    def add_user(self, username: str, password: str) -> None:\n        if not username or len(username) > MAX_USERNAME_LENGTH:\n            raise ValueError("Invalid username")\n        if not password or len(password) < 8 or len(password) > MAX_PASSWORD_LENGTH:\n            raise ValueError("Invalid password length")\n        \n        salt = secrets.token_bytes(SALT_LENGTH)\n        password_hash = self._hash_password(password, salt)\n        combined = salt + password_hash\n        \n        self.user_database[username] = combined\n        self._save_users()\n\n    def _save_users(self) -> None:\n        users_file = self._resolve_secure_path("users.dat")\n        temp_file = self._resolve_secure_path("users.dat.tmp")\n        \n        with open(temp_file, "w", encoding="utf-8") as f:\n            for username, data in self.user_database.items():\n                f.write(f"{username}:{data.hex()}\\n")\n        \n        temp_file.replace(users_file)\n\n    def _hash_password(self, password: str, salt: bytes) -> bytes:\n        kdf = PBKDF2HMAC(\n            algorithm=hashes.SHA256(),\n            length=32,\n            salt=salt,\n            iterations=PBKDF2_ITERATIONS,\n            backend=default_backend()\n        )\n        return kdf.derive(password.encode("utf-8"))\n\n    def _verify_password(self, username: str, password: str) -> bool:\n        stored = self.user_database.get(username)\n        if not stored or len(stored) != SALT_LENGTH + 32:\n            return False\n        \n        salt = stored[:SALT_LENGTH]\n        expected_hash = stored[SALT_LENGTH:]\n        actual_hash = self._hash_password(password, salt)\n        \n        return secrets.compare_digest(expected_hash, actual_hash)\n\n    def start(self) -> None:\n        self.server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n        self.server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)\n        self.server_socket.bind(("127.0.0.1", self.port))\n        self.server_socket.listen(5)\n        print(f"Server started on port {self.port}")\n        \n        while True:\n            try:\n                client_', type='text')
