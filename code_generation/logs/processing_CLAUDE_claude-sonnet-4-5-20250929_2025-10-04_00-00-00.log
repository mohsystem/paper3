_EMAIL_LENGTH:\n        return False\n    \n    if not validate_email(email):\n        return False\n    \n    user_settings[session_id] = {\n        'username': username.strip(),\n        'email': email.strip(),\n        'notifications': notifications\n    }\n    return True\n\n\nclass RequestHandler(BaseHTTPRequestHandler):\n    def do_GET(self) -> None:\n        if self.path == '/':\n            session_id = 'session123'\n            csrf_token = generate_csrf_token(session_id)\n            \n            response = f'''<!DOCTYPE html>\n<html>\n<head>\n    <meta charset="UTF-8">\n    <title>User Settings</title>\n</head>\n<body>\n    <h1>Update User Settings</h1>\n    <form method="POST" action="/update">\n        <input type="hidden" name="csrf_token" value="{csrf_token}">\n        <input type="hidden" name="session_id" value="{session_id}">\n        <label>Username: <input type="text" name="username" maxlength="50" required></label><br>\n        <label>Email: <input type="email" name="email" maxlength="100" required></label><br>\n        <label><input type="checkbox" name="notifications"> Enable Notifications</label><br>\n        <button type="submit">Update Settings</button>\n    </form>\n</body>\n</html>'''\n            \n            self.send_response(200)\n            self.send_header('Content-Type', 'text/html; charset=utf-8')\n            self.end_headers()\n            self.wfile.write(response.encode('utf-8'))\n        else:\n            self.send_response(404)\n            self.end_headers()\n    \n    def do_POST(self) -> None:\n        if self.path == '/update':\n            content_length = int(self.headers.get('Content-Length', 0))\n            if content_length > 4096:\n                self.send_response(413)\n                self.end_headers()\n                return\n            \n            body = self.rfile.read(content_length).decode('utf-8')\n            params = parse_qs(body)\n            \n            session_id = params.get('session_id', [''])[0]\n            csrf_token = params.get('csrf_token', [''])[0]\n            username = params.get('username', [''])[0]\n            email = params.get('email', [''])[0]\n            notifications = 'notifications' in params\n            \n            success = update_user_settings(session_id, csrf_token, username, email, notifications)\n            \n            response = 'Settings updated successfully!' if success else 'Invalid request or CSRF token!'\n            status_code = 200 if success else 403\n            \n            self.send_response(status_code)\n            self.send_header('Content-Type', 'text/plain; charset=utf-8')\n            self.end_headers()\n            self.wfile.write(response.encode('utf-8'))\n        else:\n            self.send_response(404)\n            self.end_headers()\n\n\ndef main() -> None:\n    print("Test 1: Generate CSRF token")\n    token1 = generate_csrf_token("session1")\n    print(f"Token generated: {token1 is not None and len(token1) > 0}")\n    \n    print("\\nTest 2: Validate correct CSRF token")\n    valid1 = validate_csrf_token("session1", token1)\n    print(f"Valid token: {valid1}")\n    \n    print("\\nTest 3: Reject invalid CSRF token")\n    valid2 = validate_csrf_token("session1", "invalid_token")\n    print(f"Invalid token rejected: {not valid2}")\n    \n    print("\\nTest 4: Update settings with valid token")\n    token2 = generate_csrf_token("session2")\n    update1 = update_user_settings("session2", token2, "john_doe", "john@example.com", True)\n    print(f"Settings updated: {update1}")\n    \n    print("\\nTest 5: Reject update with invalid token")\n    update2 = update_user_settings("session3", "wrong_token", "jane_doe", "jane@example.com", False)\n    print(f"Invalid update rejected: {not update2}")\n    \n    server = HTTPServer(('localhost', 8080), RequestHandler)\n    print("\\nServer started on port 8080")\n    server.serve_forever()\n\n\nif __name__ == '__main__':\n    main()\n```\n\n```cpp\n#i