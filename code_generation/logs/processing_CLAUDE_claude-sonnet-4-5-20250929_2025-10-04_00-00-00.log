2025-10-04 01:55:54,414 INFO TextBlock(citations=None, text='```java\nimport javax.crypto.Cipher;\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.GCMParameterSpec;\nimport javax.crypto.spec.PBEKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\nimport java.io.*;\nimport java.net.*;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.*;\nimport java.security.MessageDigest;\nimport java.security.SecureRandom;\nimport java.security.spec.KeySpec;\nimport java.util.*;\nimport java.util.concurrent.*;\n\npublic class Task7 {\n    private static final int PBKDF2_ITERATIONS = 210000;\n    private static final int SALT_LENGTH = 16;\n    private static final int GCM_IV_LENGTH = 12;\n    private static final int GCM_TAG_LENGTH = 128;\n    private static final String CIPHER_ALGORITHM = "AES/GCM/NoPadding";\n    private static final int MAX_USERNAME_LENGTH = 64;\n    private static final int MAX_PASSWORD_LENGTH = 128;\n    private static final int SERVER_PORT = 8443;\n\n    public static class ChatServer {\n        private final Path credentialsDir;\n        private final SecureRandom secureRandom;\n        private final ExecutorService executor;\n\n        public ChatServer(Path credentialsDir) throws IOException {\n            this.credentialsDir = credentialsDir;\n            this.secureRandom = new SecureRandom();\n            this.executor = Executors.newFixedThreadPool(10);\n            Files.createDirectories(credentialsDir);\n        }\n\n        public void start(int port) {\n            try (ServerSocket serverSocket = new ServerSocket(port)) {\n                System.out.println("Server started on port " + port);\n                while (true) {\n                    Socket clientSocket = serverSocket.accept();\n                    executor.submit(() -> handleClient(clientSocket));\n                }\n            } catch (IOException e) {\n                System.err.println("Server error: " + e.getMessage());\n            }\n        }\n\n        private void handleClient(Socket clientSocket) {\n            try (clientSocket;\n                 BufferedReader in = new BufferedReader(new InputStreamReader(\n                         clientSocket.getInputStream(), StandardCharsets.UTF_8));\n                 PrintWriter out = new PrintWriter(new OutputStreamWriter(\n                         clientSocket.getOutputStream(), StandardCharsets.UTF_8), true)) {\n\n                String request = in.readLine();\n                if (request == null || request.isEmpty()) {\n                    out.println("ERROR:Invalid request");\n                    return;\n                }\n\n                String[] parts = request.split(":", 3);\n                if (parts.length != 3) {\n                    out.println("ERROR:Invalid request format");\n                    return;\n                }\n\n                String command = parts[0];\n                String username = parts[1];\n                String password = parts[2];\n\n                if (!validateInput(username, MAX_USERNAME_LENGTH) || \n                    !validateInput(password, MAX_PASSWORD_LENGTH)) {\n                    out.println("ERROR:Invalid credentials format");\n                    return;\n                }\n\n                if ("REGISTER".equals(command)) {\n                    String response = registerUser(username, password);\n                    out.println(response);\n                } else if ("LOGIN".equals(command)) {\n                    String response = authenticateUser(username, password);\n                    out.println(response);\n                } else {\n                    out.println("ERROR:Unknown command");\n                }\n            } catch (IOException e) {\n                System.err.println("Client handler error: " + e.getMessage());\n            }\n        }\n\n        private boolean validateInput(String input, int maxLength) {\n            if (input == null || input.isEmpty() || input.length() > maxLength) {\n                return false;\n            }\n            return input.matches("^[a-zA-Z0-9_-]+$");\n        }\n\n        private String registerUser(String username, String password) {\n            try {\n                Path userFile = credentialsDir.resolve(username + ".dat");\n                if (Files.exists(userFile)) {\n                    return "ERROR:User already exists";\n                }\n\n                byte[] salt = new byte[SALT_LENGTH];\n                secureRandom.nextBytes(salt);\n\n                byte[] passwordHash = hashPassword(password, salt);\n\n                Path tempFile = Files.createTempFile(credentialsDir, "temp", ".dat");\n                try (OutputStream os = Files.newOutputStream(tempFile, \n                        StandardOpenOption.WRITE, StandardOpenOption.TRUNCATE_EXISTING)) {\n                    os.write(salt);\n                    os.write(passwordHash);\n                }\n\n                Files.move(tempFile, userFile, StandardCopyOption.ATOMIC_MOVE);\n                return "SUCCESS:User registered";\n            } catch (Exception e) {\n                return "ERROR:Registration failed";\n            }\n        }\n\n        private String authenticateUser(String username, String password) {\n            try {\n                Path userFile = credentialsDir.resolve(username + ".dat");\n                if (!Files.exists(userFile) || !Files.isRegularFile(userFile)) {\n                    return "ERROR:Invalid credentials";\n                }\n\n                byte[] fileData = Files.readAllBytes(userFile);\n                if (fileData.length < SALT_LENGTH + 32) {\n                    return "ERROR:Invalid credentials";\n                }\n\n                byte[] salt = Arrays.copyOfRange(fileData, 0, SALT_LENGTH);\n                byte[] storedHash = Arrays.copyOfRange(fileData, SALT_LENGTH, fileData.length);\n\n                byte[] computedHash = hashPassword(password, salt);\n\n                if (MessageDigest.isEqual(storedHash, computedHash)) {\n                    return "SUCCESS:Login successful";\n                } else {\n                    return "ERROR:Invalid credentials";\n                }\n            } catch (Exception e) {\n                return "ERROR:Authentication failed";\n            }\n        }\n\n        private byte[] hashPassword(String password, byte[] salt) throws Exception {\n            KeySpec spec = new PBEKeySpec(password.toCharArray(), salt, \n                    PBKDF2_ITERATIONS, 256);\n            SecretKeyFactory factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256");\n            return factory.generateSecret(spec).getEncoded();\n        }\n\n        public void shutdown() {\n            executor.shutdown();\n        }\n    }\n\n    public static class ChatClient {\n        private final SecureRandom secureRandom;\n\n        public ChatClient() {\n            this.secureRandom = new SecureRandom();\n        }\n\n        public String sendRequest(String host, int port, String command, \n                                 String username, String password) {\n            if (!validateInput(username, MAX_USERNAME_LENGTH) || \n                !validateInput(password, MAX_PASSWORD_LENGTH)) {\n                return "ERROR:Invalid input format";\n            }\n\n            try (Socket socket = new Socket(host, port);\n                 PrintWriter out = new PrintWriter(new OutputStreamWriter(\n                         socket.getOutputStream(), StandardCharsets.UTF_8), true);\n                 BufferedReader in = new BufferedReader(new InputStreamReader(\n                         socket.getInputStream(), StandardCharsets.UTF_8))) {\n\n                String request = command + ":" + username + ":" + password;\n                out.println(request);\n\n                String response = in.readLine();\n                return response != null ? response : "ERROR:No response";\n            } catch (IOException e) {\n                return "ERROR:Connection failed - " + e.getMessage();\n            }\n        }\n\n        private boolean validateInput(String input, int maxLength) {\n            if (input == null || input.isEmpty() || input.length() > maxLength) {\n                return false;\n            }\n            return input.matches("^[a-zA-Z0-9_-]+$");\n        }\n    }\n\n    public static void main(String[] args) {\n        try {\n            Path credentialsDir = Paths.get(System.getProperty("java.io.tmpdir"), "chat_credentials");\n            \n            ChatServer server = new ChatServer(credentialsDir);\n            Thread serverThread = new Thread(() -> server.start(SERVER_PORT));\n            serverThread.setDaemon(true);\n            serverThread.start();\n\n            Thread.sleep(1000);\n\n            ChatClient client = new ChatClient();\n\n            System.out.println("Test 1: Register user1");\n            String response1 = client.sendRequest("localhost", SERVER_PORT, "REGISTER", "user1", "Pass123");\n            System.out.println(response1);\n\n            System.out.println("\\nTest 2: Login user1");\n            String response2 = client.sendRequest("localhost", SERVER_PORT, "LOGIN", "user1", "Pass123");\n            System.out.println(response2);\n\n            System.out.println("\\nTest 3: Login user1 with wrong password");\n            String response3 = client.sendRequest("localhost", SERVER_PORT, "LOGIN", "user1", "WrongPass");\n            System.out.println(response3);\n\n            System.out.println("\\nTest 4: Register duplicate user");\n            String response4 = client.sendRequest("localhost", SERVER_PORT, "REGISTER", "user1", "Pass456");\n            System.out.println(response4);\n\n            System.out.println("\\nTest 5: Invalid username format");\n            String response5 = client.sendRequest("localhost", SERVER_PORT, "REGISTER", "user@invalid", "Pass789");\n            System.out.println(response5);\n\n            server.shutdown();\n        } catch (Exception e) {\n            System.err.println("Error: " + e.getMessage());\n        }\n    }\n\n    private static boolean validateInput(String input, int maxLength) {\n        if (input == null || input.isEmpty() || input.length() > maxLength) {\n            return false;\n        }\n        return input.matches("^[a-zA-Z0-9_-]+$");\n    }\n}\n```\n\n```python\nimport socket\nimport hashlib\nimport secrets\nimport os\nimport threading\nimport time\nfrom pathlib import Path\nfrom typing import Optional, Tuple\nfrom cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC\nfrom cryptography.hazmat.primitives import hashes\nfrom cryptography.hazmat.backends import default_backend\n\nPBKDF2_ITERATIONS = 210000\nSALT_LENGTH = 16\nMAX_USERNAME_LENGTH = 64\nMAX_PASSWORD_LENGTH = 128\nSERVER_PORT = 8443\n\n\nclass ChatServer:\n    def __init__(self, credentials_dir: Path):\n        self.credentials_dir = Path(credentials_dir)\n        self.credentials_dir.mkdir(parents=True, exist_ok=True)\n        self.running = True\n\n    def start(self, port: int) -> None:\n        try:\n            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as server_socket:\n                server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)\n                server_socket.bind(('localhost', port))\n                server_socket.listen(5)\n                server_socket.settimeout(1.0)\n                print(f"Server started on port {port}")\n\n                while self.running:\n                    try:\n                        client_socket, _ = server_socket.accept()\n                        thread = threading.Thread(target=self._handle_client, args=(client_socket,))\n                        thread.daemon = True\n                        thread.start()\n                    except socket.timeout:\n                        continue\n        except Exception as e:\n            print(f"Server error: {e}")\n\n    def _handle_client(self, client_socket: socket.socket) -> None:\n        try:\n            with client_socket:\n                request = client_socket.recv(1024).decode('utf-8').strip()\n                \n                if not request:\n                    self._send_response(client_socket, "ERROR:Invalid request")\n                    return\n\n                parts = request.split(':', 2)\n                if len(parts) != 3:\n                    self._send_response(client_socket, "ERROR:Invalid request format")\n                    return\n\n                command, username, password = parts\n\n                if not self._validate_input(username, MAX_USERNAME_LENGTH) or \\\n                   not self._validate_input(password, MAX_PASSWORD_LENGTH):\n                    self._send_response(client_socket, "ERROR:Invalid credentials format")\n                    return\n\n                if command == "REGISTER":\n                    response = self._register_user(username, password)\n                elif command == "LOGIN":\n                    response = self._authenticate_user(username, password)\n                else:\n                    response = "ERROR:Unknown command"\n\n                self._send_response(client_socket, response)\n        except Exception as e:\n            print(f"Client handler error: {e}")\n\n    def _send_response(self, client_socket: socket.socket, response: str) -> None:\n        try:\n            client_socket.sendall((response + '\\n').encode('utf-8'))\n        except Exception:\n            pass\n\n    def _validate_input(self, input_str: str, max_length: int) -> bool:\n        if not input_str or len(input_str) > max_length:\n            return False\n        return all(c.isalnum() or c in ('_', '-') for c in input_str)\n\n    def _register_user(self, username: str, password: str) -> str:\n        try:\n            user_file = self.credentials_dir / f"{username}.dat"\n            \n            if user_file.exists():\n                return "ERROR:User already exists"\n\n            salt = secrets.token_bytes(SALT_LENGTH)\n            password_hash = self._hash_password(password, salt)\n\n            temp_file = self.credentials_dir / f"temp_{secrets.token_hex(8)}.dat"\n            with open(temp_file, 'wb') as f:\n                f.write(salt)\n                f.write(password_hash)\n                f.flush()\n                os.fsync(f.fileno())\n\n            temp_file.replace(user_file)\n            user_file.chmod(0o600)\n            \n            return "SUCCESS:User registered"\n        except Exception as e:\n            return "ERROR:Registration failed"\n\n    def _authenticate_user(self, username: str, password: str) -> str:\n        try:\n            user_file = self.credentials_dir / f"{username}.dat"\n            \n            if not user_file.exists() or not user_file.is_file():\n                return "ERROR:Invalid credentials"\n\n            with open(user_file, 'rb') as f:\n                file_data = f.read()\n\n            if len(file_data) < SALT_LENGTH + 32:\n                return "ERROR:Invalid credentials"\n\n            salt = file_data[:SALT_LENGTH]\n            stored_hash = file_data[SALT_LENGTH:]\n\n            computed_hash = self._hash_password(password, salt)\n\n            if secrets.compare_digest(stored_hash, computed_hash):\n                return "SUCCESS:Login successful"\n            else:\n                return "ERROR:Invalid credentials"\n        except Exception as e:\n            return "ERROR:Authentication failed"\n\n    def _hash_password(self, password: str, salt: bytes) -> bytes:\n        kdf = PBKDF2HMAC(\n            algorithm=hashes.SHA256(),\n            length=32,\n            salt=salt,\n            iterations=PBKDF2_ITERATIONS,\n            backend=default_backend()\n        )\n        return kdf.derive(password.encode('utf-8'))\n\n    def shutdown(self) -> None:\n        self.running = False\n\n\nclass ChatClient:\n    def _validate_input(self, input_str: str, max_length: int) -> bool:\n        if not input_str or len(input_str) > max_length:\n            return False\n        return all(c.isalnum() or c in ('_', '-') for c in input_str)\n\n    def send_request(self, host: str, port: int, command: str, \n                    username: str, password: str) -> str:\n        if not self._validate_input(username, MAX_USERNAME_LENGTH) or \\\n           not self._validate_input(password, MAX_PASSWORD_LENGTH):\n            return "ERROR:Invalid input format"\n\n        try:\n            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:\n                sock.connect((host, port))\n                \n                request = f"{command}:{username}:{password}\\n"\n                sock.sendall(request.encode('utf-8'))\n\n                response = sock.recv(1024).decode('utf-8').strip()\n                return response if response else "ERROR:No response"\n        except Exception as e:\n            return f"ERROR:Connection failed - {e}"\n\n\ndef main() -> None:\n    credentials_dir = Path("/tmp/chat_credentials")\n    \n    server = ChatServer(credentials_dir)\n    server_thread = threading.Thread(target=server.start, args=(SERVER_PORT,))\n    server_thread.daemon = True\n    server_thread.start()\n\n    time.sleep(1)\n\n    client = ChatClient()\n\n    print("Test 1: Register user1")\n    response1 = client.send_request("localhost", SERVER_PORT, "REGISTER", "user1", "Pass123")\n    print(response1)\n\n    print("\\nTest 2: Login user1")\n    response2 = client.send_request("localhost", SERVER_PORT, "LOGIN", "user1", "Pass123")\n    print(response2)\n\n    print("\\nTest 3: Login user1 with wrong password")\n    response3 = client.send_request("localhost", SERVER_PORT, "LOGIN", "user1", "WrongPass")\n    print(response3)\n\n    print("\\nTest 4: Register duplicate user")\n    response4 = client.send_request("localhost", SERVER_PORT, "REGISTER", "user1", "Pass456")\n    print(response4)\n\n    print("\\nTest 5: Invalid username format")\n    response5 = client.send_request("localhost", SERVER_PORT, "REGISTER", "user@invalid", "Pass789")\n    print(response5)\n\n    server.shutdown()\n\n\nif __name__ == "__main__":\n    main()\n```\n\n```cpp\n#include <iostream>\n#include <string>\n#include <fstream>\n#include <vector>\n#include <cstring>\n#include <thread>\n#include <chrono>\n#include <memory>\n#include <algorithm>\n#include <stdexcept>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <unistd.h>\n#include <sys/stat.h>\n#include <openssl/evp.h>\n#include <openssl/rand.h>\n#include <openssl/sha.h>\n\nconst int PBKDF2_ITERATIONS = 210000;\nconst int SALT_LENGTH = 16;\nconst int HASH_LENGTH = 32;\nconst int MAX_USERNAME_LENGTH = 64;\nconst int MAX_PASSWORD_LENGTH = 128;\nconst int SERVER_PORT = 8443;\n\nclass SecureString {\nprivate:\n    std::vector<char> data;\npublic:\n    SecureString(const std::string& str) : data(str.begin(), str.end()) {}\n    ~SecureString() {\n        if (!data.empty()) {\n            OPENSSL_cleanse(data.data(), data.size());\n        }\n    }\n    const char* c_str() const { return data.data(); }\n    size_t size() const { return data.size(); }\n};\n\nbool validateInput(const std::string& input, size_t maxLength) {\n    if (input.empty() || input.length() > maxLength) {\n        return false;\n    }\n    return std::all_of(input.begin(), input.end(), [](char c) {\n        return std::isalnum(c) || c == '_' || c == '-';\n    });\n}\n\nstd::vector<unsigned char> hashPassword(const std::string& password, \n                                       const std::vector<unsigned char>& salt) {\n    std::vector<unsigned char> hash(HASH_LENGTH);\n    \n    if (PKCS5_PBKDF2_HMAC(password.c_str(), password.length(),\n                          salt.data(), salt.size(),\n                          PBKDF2_ITERATIONS,\n                          EVP_sha256(),\n                          HASH_LENGTH, hash.data()) != 1) {\n        throw std::runtime_error("PBKDF2 failed");\n    }\n    \n    return hash;\n}\n\nbool constantTimeCompare(const std::vector<unsigned char>& a, \n                        const std::vector<unsigned char>& b) {\n    if (a.size() != b.size()) {\n        return false;\n    }\n    return CRYPTO_memcmp(a.data(), b.data(), a.size()) == 0;\n}\n\nclass ChatServer {\nprivate:\n    std::string credentialsDir;\n    bool running;\n\n    void handleClient(int clientSocket) {\n        char buffer[2048];\n        ssize_t bytesRead = recv(clientSocket, buffer, sizeof(buffer) - 1, 0);\n        \n        if (bytesRead <= 0) {\n            std::string error = "ERROR:Invalid request\\n";\n            send(clientSocket, error.c_str(), error.length(), 0);\n            close(clientSocket);\n            return;\n        }\n        \n        buffer[bytesRead] = '\\0';\n        std::string request(buffer);\n        \n        size_t pos1 = request.find(':');\n        size_t pos2 = request.find(':', pos1 + 1);\n        \n        if (pos1 == std::string::npos || pos2 == std::string::npos) {\n            std::string error = "ERROR:Invalid request format\\n";\n            send(clientSocket, error.c_str(), error.length(), 0);\n            close(clientSocket);\n            return;\n        }\n        \n        std::string command = request.substr(0, pos1);\n        std::string username = request.substr(pos1 + 1, pos2 - pos1 - 1);\n        std::string password = request.substr(pos2 + 1);\n        \n        if (password.back() == '\\n') {\n            password.pop_back();\n        }\n        \n        if (!validateInput(username, MAX_USERNAME_LENGTH) || \n            !validateInput(password, MAX_PASSWORD_LENGTH)) {\n            std::string error = "ERROR:Invalid credentials format\\n";\n            send(clientSocket, error.c_str(), error.length(), 0);\n            close(clientSocket);\n            return;\n        }\n        \n        std::string response;\n        if (command == "REGISTER") {\n            response = registerUser(username, password);\n        } else if (command == "LOGIN") {\n            response = authenticateUser(username, password);\n        } else {\n            response = "ERROR:Unknown command";\n        }\n        \n        response += "\\n";\n        send(clientSocket, response.c_str(), response.length(), 0);\n        close(clientSocket);\n    }\n\n    std::string registerUser(const std::string& username, const std::string& password) {\n        try {\n            std::string userFile = credentialsDir + "/" + username + ".dat";\n            \n            std::ifstream checkFile(userFile);\n            if (checkFile.good()) {\n                return "ERROR:User already exists";\n            }\n            \n            std::vector<unsigned char> salt(SALT_LENGTH);\n            if (RAND_bytes(salt.data(), SALT_LENGTH) != 1) {\n                return "ERROR:Registration failed";\n            }\n            \n            std::vector<unsigned char> passwordHash = hashPassword(password, salt);\n            \n            std::string tempFile = credentialsDir + "/temp_" + \n                                  std::to_string(std::chrono::system_clock::now().time_since_epoch().count()) + ".dat";\n            \n            std::ofstream file(tempFile, std::ios::binary);\n            if (!file) {\n                return "ERROR:Registration failed";\n            }\n            \n            file.write(reinterpret_cast<const char*>(salt.data()), salt.size());\n            file.write(reinterpret_cast<const char*>(passwordHash.data()), passwordHash.size());\n            file.flush();\n            file.close();\n            \n            if (rename(tempFile.c_str(), userFile.c_str()) != 0) {\n                unlink(tempFile.c_str());\n                return "ERROR:Registration failed";\n            }\n            \n            chmod(userFile.c_str(), 0600);\n            \n            return "SUCCESS:User registered";\n        } catch (...) {\n            return "ERROR:Registration failed";\n        }\n    }\n\n    std::string authenticateUser(const std::string& username, const std::string& password) {\n        try {\n            std::string userFile = credentialsDir + "/" + username + ".dat";\n            \n            std::ifstream file(userFile, std::ios::binary);\n            if (!file) {\n                return "ERROR:Invalid credentials";\n            }\n            \n            std::vector<unsigned char> salt(SALT_LENGTH);\n            file.read(reinterpret_cast<char*>(salt.data()), SALT_LENGTH);\n            \n            std::vector<unsigned char> storedHash(HASH_LENGTH);\n            file.read(reinterpret_cast<char*>(storedHash.data()), HASH_LENGTH);\n            \n            if (file.gcount() != HASH_LENGTH) {\n                return "ERROR:Invalid credentials";\n            }\n            \n            std::vector<unsigned char> computedHash = hashPassword(password, salt);\n            \n            if (constantTimeCompare(storedHash, computedHash)) {\n                return "SUCCESS:Login successful";\n            } else {\n                return "ERROR:Invalid credentials";\n            }\n        } catch (...) {\n            return "ERROR:Authentication failed";\n        }\n    }\n\npublic:\n    ChatServer(const std::string& dir) : credentialsDir(dir), running(true) {\n        mkdir(credentialsDir.c_str(), 0700);\n    }\n\n    void start(int port) {\n        int serverSocket = socket(AF_INET, SOCK_STREAM, 0);\n        if (serverSocket < 0) {\n            std::cerr << "Failed to create socket" << std::endl;\n            return;\n        }\n\n        int opt = 1;\n        setsockopt(serverSocket, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));\n\n        struct sockaddr_in serverAddr;\n        std::memset(&serverAddr, 0, sizeof(serverAddr));\n        serverAddr.sin_family = AF_INET;\n        serverAddr.sin_addr.s_addr = INADDR_ANY;\n        serverAddr.sin_port = htons(port);\n\n        if (bind(serverSocket, (struct sockaddr*)&serverAddr, sizeof(serverAddr)) < 0) {\n            std::cerr << "Bind failed" << std::endl;\n            close(serverSocket);\n            return;\n        }\n\n        if (listen(serverSocket, 5) < 0) {\n            std::cerr << "Listen failed" << std::endl;\n            close(serverSocket);\n            return;\n        }\n\n        std::cout << "Server started on port " << port << std::endl;\n\n        while (running) {\n            struct sockaddr_in clientAddr;\n            socklen_t clientLen = sizeof(clientAddr);\n            int clientSocket = accept(serverSocket, (struct sockaddr*)&clientAddr, &clientLen);\n\n            if (clientSocket >= 0) {\n                std::thread(&ChatServer::handleClient, this, clientSocket).detach();\n            }\n        }\n\n        close(serverSocket);\n    }\n\n    void shutdown() {\n        running = false;\n    }\n};\n\nclass ChatClient {\npublic:\n    std::string sendRequest(const std::string& host, int port, const std::string& command,\n                           const std::string& username, const std::string& password) {\n        if (!validateInput(username, MAX_USERNAME_LENGTH) || \n            !validateInput(password, MAX_PASSWORD_LENGTH)) {\n            return "ERROR:Invalid input format";\n        }\n\n        int sock = socket(AF_INET, SOCK_STREAM, 0);\n        if (sock < 0) {\n            return "ERROR:Connection failed";\n        }\n\n        struct sockaddr_in serverAddr;\n        std::memset(&serverAddr, 0, sizeof(serverAddr));\n        serverAddr.sin_family = AF_INET;\n        serverAddr.sin_port = htons(port);\n        \n        if (inet_pton(AF_INET, host.c_str(), &serverAddr.sin_addr) <= 0) {\n            close(sock);\n            return "ERROR:Invalid address";\n        }\n\n        if (connect(sock, (struct sockaddr*)&serverAddr, sizeof(serverAddr)) < 0) {\n            close(sock);\n            return "ERROR:Connection failed";\n        }\n\n        std::string request = command + ":" + username + ":" + password + "\\n";\n        send(sock, request.c_str(), request.length(), 0);\n\n        char buffer[1024];\n        ssize_t bytesRead = recv(sock, buffer, sizeof(buffer) - 1, 0);\n        close(sock);\n\n        if (bytesRead > 0) {\n            buffer[bytesRead] = '\\0';\n            std::string response(buffer);\n            if (!response.empty() && response.back() == '\\n') {\n                response.pop_back();\n            }\n            return response;\n        }\n\n        return "ERROR:No response";\n    }\n};\n\nint main() {\n    std::string credentialsDir = "/tmp/chat_credentials_cpp";\n    \n    ChatServer server(credentialsDir);\n    std::thread serverThread(&ChatServer::start, &server, SERVER_PORT);\n    serverThread.detach();\n\n    std::this_thread::sleep_for(std::chrono::seconds(1));\n\n    ChatClient client;\n\n    std::cout << "Test 1: Register user1" << std::endl;\n    std::string response1 = client.sendRequest("127.0.0.1", SERVER_PORT, "REGISTER", "user1", "Pass123");\n    std::cout << response1 << std::endl;\n\n    std::cout << "\\nTest 2: Login user1" << std::endl;\n    std::string response2 = client.sendRequest("127.0.0.1", SERVER_PORT, "LOGIN", "user1", "Pass123");\n    std::cout << response2 << std::endl;\n\n    std::cout << "\\nTest 3: Login user1 with wrong password" << std::endl;\n    std::string response3 = client.sendRequest("127.0.0.1", SERVER_PORT, "LOGIN", "user1", "WrongPass");\n    std::cout << response3 << std::endl;\n\n    std::cout << "\\nTest 4: Register duplicate user" << std::endl;\n    std::string response4 = client.sendRequest("127.0.0.1", SERVER_PORT, "REGISTER", "user1", "Pass456");\n    std::cout << response4 << std::endl;\n\n    std::cout << "\\nTest 5: Invalid username format" << std::endl;\n    std::string response5 = client.sendRequest("127.0.0.1", SERVER_PORT, "REGISTER", "user@invalid", "Pass789");\n    std::cout << response5 << std::endl;\n\n    server.shutdown();\n    std::this_thread::sleep_for(std::chrono::seconds(1));\n\n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <unistd.h>\n#include <sys/socket.h>\n#include <netinet/in.h>\n#include <arpa/inet.h>\n#include <sys/stat.h>\n#include <fcntl.h>\n#include <pthread.h>\n#include <ctype.h>\n#include <openssl/evp.h>\n#include <openssl/rand.h>\n#include <openssl/sha.h>\n\n#define PBKDF2_ITERATIONS 210000\n#define SALT_LENGTH 16\n#define HASH_LENGTH 32\n#define MAX_USERNAME_LENGTH 64\n#define MAX_PASSWORD_LENGTH 128\n#define SERVER_PORT 8443\n#define BUFFER_SIZE 2048\n\ntypedef struct {\n    int socket;\n    char credentials_dir[256];\n} ClientHandler;\n\nint validate_input(const char* input, size_t max_length) {\n    if (input == NULL || strlen(input) == 0 || strlen(input) > max_length) {\n        return 0;\n    }\n    \n    for (size_t i = 0; i < strlen(input); i++) {\n        if (!isalnum(input[i]) && input[i] != '_' && input[i] != '-') {\n            return 0;\n        }\n    }\n    return 1;\n}\n\nint hash_password(const char* password, const unsigned char* salt, \n                  unsigned char* hash) {\n    return PKCS5_PBKDF2_HMAC(password, strlen(password),\n                             salt, SALT_LENGTH,\n                             PBKDF2_ITERATIONS,\n                             EVP_sha256(),\n                             HASH_LENGTH, hash) == 1;\n}\n\nint constant_time_compare(const unsigned char* a, const unsigned char* b, size_t len) {\n    return CRYPTO_memcmp(a, b, len) == 0;\n}\n\nchar* register_user(const char* credentials_dir, const char* username, \n                   const char* password) {\n    static char response[256];\n    char user_file[512];\n    char temp_file[512];\n    unsigned char salt[SALT_LENGTH];\n    unsigned char password_hash[HASH_LENGTH];\n    \n    snprintf(user_file, sizeof(user_file), "%s/%s.dat", credentials_dir, username);\n    \n    if (access(user_file, F_OK) == 0) {\n        snprintf(response, sizeof(response), "ERROR:User already exists");\n        return response;\n    }\n    \n    if (RAND_bytes(salt, SALT_LENGTH) != 1) {\n        snprintf(response, sizeof(response), "ERROR:Registration failed");\n        return response;\n    }\n    \n    if (!hash_password(password, salt, password_hash)) {\n        snprintf(response, sizeof(response), "ERROR:Registration failed");\n        return response;\n    }\n    \n    snprintf(temp_file, sizeof(temp_file), "%s/temp_%ld.dat", \n             credentials_dir, (long)time(NULL));\n    \n    int fd = open(temp_file, O_WRONLY | O_CREAT | O_EXCL, 0600);\n    if (fd < 0) {\n        snprintf(response, sizeof(response), "ERROR:Registration failed");\n        return response;\n    }\n    \n    if (write(fd, salt, SALT_LENGTH) != SALT_LENGTH ||\n        write(fd, password_hash, HASH_LENGTH) != HASH_LENGTH) {\n        close(fd);\n        unlink(temp_file);\n        snprintf(response, sizeof(response), "ERROR:Registration failed");\n        return response;\n    }\n    \n    fsync(fd);\n    close(fd);\n    \n    if (rename(temp_file, user_file) != 0) {\n        unlink(temp_file);\n        snprintf(response, sizeof(response), "ERROR:Registration failed");\n        return response;\n    }\n    \n    chmod(user_file, 0600);\n    snprintf(response, sizeof(response), "SUCCESS:User registered");\n    return response;\n}\n\nchar* authenticate_user(const char* credentials_dir, const char* username, \n                       const char* password) {\n    static char response[256];\n    char user_file[512];\n    unsigned char salt[SALT_LENGTH];\n    unsigned char stored_hash[HASH_LENGTH];\n    unsigned char computed_hash[HASH_LENGTH];\n    \n    snprintf(user_file, sizeof(user_file), "%s/%s.dat", credentials_dir, username);\n    \n    int fd = open(user_file, O_RDONLY);\n    if (fd < 0) {\n        snprintf(response, sizeof(response), "ERROR:Invalid credentials");\n        return response;\n    }\n    \n    if (read(fd, salt, SALT_LENGTH) != SALT_LENGTH ||\n        read(fd, stored_hash, HASH_LENGTH) != HASH_LENGTH) {\n        close(fd);\n        snprintf(response, sizeof(response), "ERROR:Invalid credentials");\n        return response;\n    }\n    close(fd);\n    \n    if (!hash_password(password, salt, computed_hash)) {\n        snprintf(response, sizeof(response), "ERROR:Authentication failed");\n        return response;\n    }\n    \n    if (constant_time_compare(stored_hash, computed_hash, HASH_LENGTH)) {\n        snprintf(response, sizeof(response), "SUCCESS:Login successful");\n    } else {\n        snprintf(response, sizeof(response), "ERROR:Invalid credentials");\n    }\n    \n    return response;\n}\n\nvoid* handle_client(void* arg) {\n    ClientHandler* handler = (ClientHandler*)arg;\n    char buffer[BUFFER_SIZE];\n    char command[32], username[MAX_USERNAME_LENGTH + 1], password[MAX_PASSWORD_LENGTH + 1];\n    char* response;\n    \n    ssize_t bytes_read = recv(handler->socket, buffer, sizeof(buffer) - 1, 0);\n    if (bytes_read <= 0) {\n        const char* error = "ERROR:Invalid request\\n";\n        send(handler->socket, error, strlen(error), 0);\n        close(handler->socket);\n        free(handler);\n        return NULL;\n    }\n    \n    buffer[bytes_read] = '\\0';\n    \n    if (buffer[bytes_read - 1] == '\\n') {\n        buffer[bytes_read - 1] = '\\0';\n    }\n    \n    char* token1 = strchr(buffer, ':');\n    char* token2 = token1 ? strchr(token1 + 1, ':') : NULL;\n    \n    if (!token1 || !token2) {\n        const char* error = "ERROR:Invalid request format\\n";\n        send(handler->socket, error, strlen(error), 0);\n        close(handler->socket);\n        free(handler);\n        return NULL;\n    }\n    \n    *token1 = '\\0';\n    *token2 = '\\0';\n    \n    strncpy(command, buffer, sizeof(command) - 1);\n    command[sizeof(command) - 1] = '\\0';\n    \n    strncpy(username, token1 + 1, sizeof(username) - 1);\n    username[sizeof(username) - 1] = '\\0';\n    \n    strncpy(password, token2 + 1, sizeof(password) - 1);\n    password[sizeof(password) - 1] = '\\0';\n    \n    if (!validate_input(username, MAX_USERNAME_LENGTH) || \n        !validate_input(password, MAX_PASSWORD_LENGTH)) {\n        const char* error = "ERROR:Invalid credentials format\\n";\n        send(handler->socket, error, strlen(error), 0);\n        close(handler->socket);\n        free(handler);\n        return NULL;\n    }\n    \n    if (strcmp(command, "REGISTER") == 0) {\n        response = register_user(handler->credentials_dir, username, password);\n    } else if (strcmp(command, "LOGIN") == 0) {\n        response = authenticate_user(handler->credentials_dir, username, password);\n    } else {\n        response = "ERROR:Unknown command";\n    }\n    \n    char full_response[512];\n    snprintf(full_response, sizeof(full_response), "%s\\n", response);\n    send(handler->socket, full_response, strlen(full_response), 0);\n    \n    close(handler->socket);\n    free(handler);\n    return NULL;\n}\n\nvoid start_server(const char* credentials_dir, int port) {\n    int server_socket;\n    struct sockaddr_in server_addr, client_addr;\n    socklen_t client_len;\n    \n    mkdir(credentials_dir, 0700);\n    \n    server_socket = socket(AF_INET, SOCK_STREAM, 0);\n    if (server_socket < 0) {\n        perror("Socket creation failed");\n        return;\n    }\n    \n    int opt = 1;\n    setsockopt(server_socket, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));\n    \n    memset(&server_addr, 0, sizeof(server_addr));\n    server_addr.sin_family = AF_INET;\n    server_addr.sin_addr.s_addr = INADDR_ANY;\n    server_addr.sin_port = htons(port);\n    \n    if (bind(server_socket, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {\n        perror("Bind failed");\n        close(server_socket);\n        return;\n    }\n    \n    if (listen(server_socket, 5) < 0) {\n        perror("Listen failed");\n        close(server_socket);\n        return;\n    }\n    \n    printf("Server started on port %d\\n", port);\n    \n    while (1) {\n        client_len = sizeof(client_addr);\n        int client_socket = accept(server_socket, (struct sockaddr*)&client_addr, &client_len);\n        \n        if (client_socket >= 0) {\n            ClientHandler* handler = malloc(sizeof(ClientHandler));\n            if (handler) {\n                handler->socket = client_socket;\n                strncpy(handler->credentials_dir, credentials_dir, \n                       sizeof(handler->credentials_dir) - 1);\n                handler->credentials_dir[sizeof(handler->credentials_dir) - 1] = '\\0';\n                \n                pthread_t thread;\n                pthread_create(&thread, NULL, handle_client, handler);\n                pthread_detach(thread);\n            } else {\n                close(client_socket);\n            }\n        }\n    }\n    \n    close(server_socket);\n}\n\nchar* send_request(const char* host, int port, const char* command,\n                  const char* username, const char* password) {\n    static char response[512];\n    \n    if (!validate_input(username, MAX_USERNAME_LENGTH) || \n        !validate_input(password, MAX_PASSWORD_LENGTH)) {\n        snprintf(response, sizeof(response), "ERROR:Invalid input format");\n        return response;\n    }\n    \n    int sock = socket(AF_INET, SOCK_STREAM, 0);\n    if (sock < 0) {\n        snprintf(response, sizeof(response), "ERROR:Connection failed");\n        return response;\n    }\n    \n    struct sockaddr_in server_addr;\n    memset(&server_addr, 0, sizeof(server_addr));\n    server_addr.sin_family = AF_INET;\n    server_addr.sin_port = htons(port);\n    \n    if (inet_pton(AF_INET, host, &server_addr.sin_addr) <= 0) {\n        close(sock);\n        snprintf(response, sizeof(response), "ERROR:Invalid address");\n        return response;\n    }\n    \n    if (connect(sock, (struct sockaddr*)&server_addr, sizeof(server_addr)) < 0) {\n        close(sock);\n        snprintf(response, sizeof(response), "ERROR:Connection failed");\n        return response;\n    }\n    \n    char request[BUFFER_SIZE];\n    snprintf(request, sizeof(request), "%s:%s:%s\\n", command, username, password);\n    send(sock, request, strlen(request), 0);\n    \n    ssize_t bytes_read = recv(sock, response, sizeof(response) - 1, 0);\n    close(sock);\n    \n    if (bytes_read > 0) {\n        response[bytes_read] = '\\0';\n        if (response[bytes_read - 1] == '\\n') {\n            response[bytes_read - 1] = '\\0';\n        }\n        return response;\n    }\n    \n    snprintf(response, sizeof(response), "ERROR:No response");\n    return response;\n}\n\nvoid* server_thread_func(void* arg) {\n    start_server((const char*)arg, SERVER_PORT);\n    return NULL;\n}\n\nint main(void) {\n    const char* credentials_dir = "/tmp/chat_credentials_c";\n    \n    pthread_t server_thread;\n    pthread_create(&server_thread, NULL, server_thread_func, (void*)credentials_dir);\n    pthread_detach(server_thread);\n    \n    sleep(1);\n    \n    printf("Test 1: Register user1\\n");\n    char* response1 = send_request("127.0.0.1", SERVER_PORT, "REGISTER", "user1", "Pass123");\n    printf("%s\\n", response1);\n    \n    printf("\\nTest 2: Login user1\\n");\n    char* response2 = send_request("127.0.0.1", SERVER_PORT, "LOGIN", "user1", "Pass123");\n    printf("%s\\n", response2);\n    \n    printf("\\nTest 3: Login user1 with wrong password\\n");\n    char* response3 = send_request("127.0.0.1", SERVER_PORT, "LOGIN", "user1", "WrongPass");\n    printf("%s\\n", response3);\n    \n    printf("\\nTest 4: Register duplicate user\\n");\n    char* response4 = send_request("127.0.0.1", SERVER_PORT, "REGISTER", "user1", "Pass456");\n    printf("%s\\n", response4);\n    \n    printf("\\nTest 5: Invalid username format\\n");\n    char* response5 = send_request("127.0.0.1", SERVER_PORT, "REGISTER", "user@invalid", "Pass789");\n    printf("%s\\n", response5);\n    \n    sleep(1);\n    \n    return 0;\n}\n```', type='text')
