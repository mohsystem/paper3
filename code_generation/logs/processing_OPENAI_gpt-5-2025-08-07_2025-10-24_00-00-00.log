    int nums3[] = {5, 4, 3, 2, 1};
    long long res3 = reversePairs_count(nums3, (int)(sizeof(nums3) / sizeof(nums3[0])));
    printf("Input: "); print_array(nums3, (int)(sizeof(nums3) / sizeof(nums3[0]))); printf("\n");
    printf("Reverse pairs: %lld\n\n", res3);

    // Test case 4: negatives
