    printf("Test 3: radius=0.1, center=(1e7,-1e7)\n");
    Solution s3 = Solution_create(0.1, 1e7, -1e7);
    for (int i = 0; i < 3; ++i) {
        Point p = Solution_randPoint(&s3);
        printf("  randPoint -> [%.5f, %.5f]\n", p.x, p.y);
