    if (res != CURLE_OK || rb.overflowed) {
        ret = -6;
    } else {
        /* HTTP status check (optional but good practice) */
        long http_code = 0;
        if (curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code) == CURLE_OK) {
            if (http_code < 200 || http_code >= 300) {
                ret = -7;
            }
        }
    }

    if (ret == 0) {
        *out_buf = rb.data;
        *out_len = rb.size;
        /* Caller must free */
    } else {
        rb_free(&rb);
    }

    curl_easy_cleanup(curl);
    curl_global_cleanup();
    return ret;
}

/* Fetch URL and extract title; returns 0 on success */
int fetch_title_from_https_url(const char *url, char *out_title, size_t out_title_sz) {
    if (!url || !out_title || out_title_sz == 0) return -1;

    char *buf = NULL;
    size_t len = 0;
    int rc = fetch_url_https(url, &buf, &len);
    if (rc != 0) {
        return -2;
    }

    int trc = extract_title(buf, out_title, out_title_sz);
    free(buf);
    if (trc != 0) return -3;
    return 0;
}

/* -------------------- Test Harness -------------------- */

static void run_parser_test(const char *name, const char *html, const char *expected) {
    char title[TITLE_MAX_OUT];
    int rc = extract_title(html, title, sizeof(title));
    if (rc == 0) {
        printf("[Parser Test] %s => \"%s\"%s\n", name, title,
               (expected && strcmp(expected, title) == 0) ? " (OK)" : (expected ? " (Mismatch)" : ""));
    } else {
        printf("[Parser Test] %s => Error rc=%d%s\n", name, rc, (expected == NULL ? " (Expected)" : ""));
    }
}

int main(int argc, char **argv) {
    if (argc > 1) {
        /* Process each provided HTTPS URL */
        for (int i = 1; i < argc; i++) {
            const char *url = argv[i];
            char title[TITLE_MAX_OUT];
            int rc = fetch_title_from_https_url(url, title, sizeof(title));
            if (rc == 0) {
                printf("URL: %s\nTitle: %s\n", url, title);
            } else {
                printf("URL: %s\nError: Failed to fetch/extract title (rc=%d)\n", url, rc);
            }
        }
        return 0;
    }

    /* No args: run 5 local parser test cases */
    const char *html1 = "<!doctype html><html><head><title>Example Domain</title></head><body>...</body></html>";
    const char *html2 = "<HTML><HEAD><TITLE data-x='1'>  Hello World  </TITLE></HEAD><BODY></BODY></HTML>";
    const char *html3 = "<html><head></head><body>No title here</body></html>";
    const char *html4 = "<html><head><title>\n  My Page\t</title></head></html>";
    const char *html5 = "<html><head><title>My <b>Bold</b> Page</title></head><body></body></html>";

    run_parser_test("Basic Title", html1, "Example Domain");
    run_parser_test("Case/Attr/Trim", html2, "Hello World");
    run_parser_test("Missing Title", html3, NULL);
    run_parser_test("Whitespace Trim", html4, "My Page");
    run_parser_test("Nested Tags In Title", html5, "My <b>Bold</b> Page");

    return 0;
}
