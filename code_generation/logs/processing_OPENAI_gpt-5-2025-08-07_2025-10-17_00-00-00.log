/*
Secure FTPS downloader in C using libcurl.
Build: cc -Wall -Wextra -O2 -o ftps_dl main.c -lcurl
Usage: ./ftps_dl <hostname> <username> <password> <remote_file_path>
Notes:
- Uses FTPS with strict certificate and hostname verification.
- Downloads to current directory using a sanitized basename.
- Writes to a secure temp file, fsyncs, then atomically commits without overwriting existing files.
*/

#define _POSIX_C_SOURCE 200809L
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <errno.h>
#include <ctype.h>
#include <stdbool.h>
#include <sys/stat.h>
#include <unistd.h>
#include <fcntl.h>
#include <limits.h>

#include <curl/curl.h>

/* -------------- Utility: safe string length checks -------------- */
static int safe_strlen_bound(const char *s, size_t max, size_t *out_len) {
    if (!s || !out_len) return -1;
    size_t n = 0;
    while (n <= max) {
        if (s[n] == '\0') { *out_len = n; return 0; }
        n++;
    }
    return -1; /* exceeded max */
}

/* -------------- Input validation -------------- */
static bool is_valid_hostname_char(char c) {
    return (isalnum((unsigned char)c) || c == '-' || c == '.');
}

static int validate_hostname(const char *host) {
    if (!host) return -1;
    size_t len = 0;
    if (safe_strlen_bound(host, 253, &len) != 0 || len == 0) return -1;
    /* Disallow schemes if provided */
    if (strncasecmp(host, "ftp://", 6) == 0 || strncasecmp(host, "ftps://", 7) == 0) return -1;
    for (size_t i = 0; i < len; i++) {
        if (!is_valid_hostname_char(host[i])) return -1;
    }
    /* Basic check: no leading/trailing dot or hyphen in labels */
    const char *p = host;
    while (*p) {
        /* label begins */
        if (*p == '.' || *p == '-') return -1;
        const char *label_start = p;
        while (*p && *p != '.') p++;
        const char *label_end = p - 1;
        if (*label_end == '-' || *label_end == '.') return -1;
        if (*p == '.') p++;
        if (p == label_start) return -1;
    }
    return 0;
}

/* Extract and validate a safe local filename (basename of remote path) */
static int sanitize_basename(const char *remote_path, char *out, size_t out_sz) {
    if (!remote_path || !out || out_sz == 0) return -1;
    size_t len = 0;
    if (safe_strlen_bound(remote_path, 4096, &len) != 0 || len == 0) return -1;

    /* Find last '/' */
    const char *base = remote_path;
    for (const char *p = remote_path; *p; ++p) {
        if (*p == '/') base = p + 1;
    }
    if (*base == '\0') return -1;
    if ((strcmp(base, ".") == 0) || (strcmp(base, "..") == 0)) return -1;

    /* Allow only [A-Za-z0-9._-], length 1..255 */
    size_t blen = strnlen(base, 256);
    if (blen == 0 || blen > 255) return -1;
    for (size_t i = 0; i < blen; i++) {
        unsigned char c = (unsigned char)base[i];
        if (!(isalnum(c) || c == '.' || c == '_' || c == '-')) {
            return -1;
        }
    }
    if (blen + 1 > out_sz) return -1;
    memcpy(out, base, blen);
    out[blen] = '\0';
    return 0;
}

/* -------------- URL builder with escaping of path segments -------------- */
static char *build_ftps_url(CURL *curl, const char *host, const char *remote_path) {
    if (!curl || !host || !remote_path) return NULL;

    /* Split remote_path on '/', escape each segment, re-join */
    size_t rlen = strnlen(remote_path, 4096);
    if (rlen == 0 || rlen >= 4096) return NULL;

    /* Allocate buffer for escaped path */
    /* Worst-case: every byte becomes %XX => ~3x + slashes + prefix */
    size_t cap = 16 + strlen("ftps://") + strlen(host) + 1 + rlen * 3 + 16;
    char *url = (char *)calloc(1, cap);
    if (!url) return NULL;

    int written = snprintf(url, cap, "ftps://%s", host);
    if (written <= 0 || (size_t)written >= cap) { free(url); return NULL; }
    size_t pos = (size_t)written;

    /* Ensure leading slash */
    if (remote_path[0] != '/') {
        if (pos + 1 >= cap) { free(url); return NULL; }
        url[pos++] = '/';
        url[pos] = '\0';
    }

    const char *start = remote_path;
    const char *p = remote_path;
    bool first = true;
    while (1) {
        if (*p == '/' || *p == '\0') {
            size_t seglen = (size_t)(p - start);
            if (!first) {
                if (pos + 1 >= cap) { free(url); return NULL; }
                url[pos++] = '/';
                url[pos] = '\0';
            } else {
                first = false;
            }

            if (seglen == 0) {
                /* Skip empty segments to avoid '//' */
            } else {
                char *segment = (char *)malloc(seglen + 1);
                if (!segment) { free(url); return NULL; }
                memcpy(segment, start, seglen);
                segment[seglen] = '\0';
                char *esc = curl_easy_escape(curl, segment, (int)seglen);
                free(segment);
                if (!esc) { free(url); return NULL; }
                size_t esclen = strlen(esc);
                if (pos + esclen >= cap) {
                    /* grow buffer */
                    size_t ncap = cap + esclen + 128;
                    char *nurl = (char *)realloc(url, ncap);
                    if (!nurl) { curl_free(esc); free(url); return NULL; }
                    url = nurl;
                    cap = ncap;
                }
                memcpy(url + pos, esc, esclen);
                pos += esclen;
                url[pos] = '\0';
                curl_free(esc);
            }

            if (*p == '\0') break;
            start = p + 1;
        }
        if (*p == '\0') break;
        p++;
    }
    return url;
}

/* -------------- Write callback -------------- */
typedef struct {
    FILE *fp;
    size_t max_bytes;   /* 0 for unlimited */
    size_t written;
} write_ctx_t;

static size_t write_cb(void *ptr, size_t size, size_t nmemb, void *userdata) {
    write_ctx_t *ctx = (write_ctx_t *)userdata;
    if (!ctx || !ctx->fp) return 0;

    size_t total = size * nmemb;
    if (ctx->max_bytes > 0 && ctx->written + total > ctx->max_bytes) {
        /* Enforce size limit */
        size_t allowed = ctx->max_bytes - ctx->written;
        if (allowed == 0) return 0; /* signal error */
        size_t w = fwrite(ptr, 1, allowed, ctx->fp);
        ctx->written += w;
        return (w == allowed) ? allowed : 0;
    } else {
        size_t w = fwrite(ptr, 1, total, ctx->fp);
        ctx->written += w;
        return w;
    }
}

/* -------------- Atomic commit: link() then unlink temp (no overwrite) -------------- */
static int atomic_commit_no_overwrite(const char *temp_path, const char *target_path) {
    if (!temp_path || !target_path) return -1;
    /* Attempt hard link (atomic "install") */
    if (link(temp_path, target_path) == 0) {
        /* Remove temp, leaving target */
        if (unlink(temp_path) != 0) {
            /* Best effort cleanup; if unlink fails, still succeed but warn */
            return 0;
        }
        return 0;
    } else {
        if (errno == EEXIST) {
            /* Target exists; do not overwrite */
            return 1; /* special code: exists */
        }
#ifdef __linux__
        /* Fallback: try renameat2 with RENAME_NOREPLACE if same directory */
        #ifndef RENAME_NOREPLACE
        #define RENAME_NOREPLACE (1 << 0)
        #endif
        if (renameat2(AT_FDCWD, temp_path, AT_FDCWD, target_path, RENAME_NOREPLACE) == 0) {
            return 0;
        } else if (errno == EEXIST) {
            return 1;
        }
#endif
        /* Last resort: check existence then rename (race possible) */
        struct stat st;
        if (stat(target_path, &st) == 0) {
            return 1;
        }
        if (rename(temp_path, target_path) == 0) {
            return 0;
        }
        return -1;
    }
}

/* Create a secure temp file path in current directory based on target name; returns FILE* and temp path string */
static FILE *create_secure_temp(const char *target_name, char **out_temp_path, int *out_fd) {
    if (!target_name || !out_temp_path || !out_fd) return NULL;
    char tmpl[PATH_MAX];
    int n = snprintf(tmpl, sizeof(tmpl), "./.%s.part.XXXXXX", target_name);
    if (n <= 0 || (size_t)n >= sizeof(tmpl)) return NULL;

    char *path = strdup(tmpl);
    if (!path) return NULL;

    int fd = mkstemp(path);
    if (fd < 0) {
        free(path);
        return NULL;
    }
    /* Restrict permissions to 0600 */
    (void)fchmod(fd, S_IRUSR | S_IWUSR);

    FILE *fp = fdopen(fd, "wb");
    if (!fp) {
        close(fd);
        unlink(path);
        free(path);
        return NULL;
    }
    *out_temp_path = path;
    *out_fd = fd; /* still valid within fp; keep for fsync */
    return fp;
}

/* -------------- Core download function -------------- */
static int download_ftps_file(const char *hostname,
                              const char *username,
                              const char *password,
                              const char *remote_path,
                              char *saved_path_out,
                              size_t saved_path_out_sz) {
    if (!hostname || !username || !password || !remote_path || !saved_path_out) return -1;

    if (validate_hostname(hostname) != 0) {
        fprintf(stderr, "Error: invalid hostname.\n");
        return -1;
    }

    char local_name[256];
    if (sanitize_basename(remote_path, local_name, sizeof local_name) != 0) {
        fprintf(stderr, "Error: invalid remote path/basename.\n");
        return -1;
    }

    CURLcode cc;
    CURL *curl = NULL;
    int ret = -1;
    char *url = NULL;
    char *temp_path = NULL;
    int tmp_fd = -1;
    FILE *fp = NULL;

    if ((cc = curl_global_init(CURL_GLOBAL_DEFAULT)) != CURLE_OK) {
        fprintf(stderr, "cURL init failed: %s\n", curl_easy_strerror(cc));
        return -1;
    }
    curl = curl_easy_init();
    if (!curl) {
        fprintf(stderr, "cURL easy init failed.\n");
        goto cleanup;
    }

    url = build_ftps_url(curl, hostname, remote_path);
    if (!url) {
        fprintf(stderr, "Error: failed to build URL.\n");
        goto cleanup;
    }

    fp = create_secure_temp(local_name, &temp_path, &tmp_fd);
    if (!fp) {
        fprintf(stderr, "Error: cannot create temp file.\n");
        goto cleanup;
    }

    write_ctx_t wctx;
    wctx.fp = fp;
    wctx.max_bytes = 0; /* unlimited; adjust if needed */
    wctx.written = 0;

    /* Configure cURL */
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS, CURLPROTO_FTPS);
    curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS, CURLPROTO_FTPS);
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 0L);
    curl_easy_setopt(curl, CURLOPT_USERNAME, username);
    curl_easy_setopt(curl, CURLOPT_PASSWORD, password);
    curl_easy_setopt(curl, CURLOPT_NOPROGRESS, 1L);
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &wctx);
    curl_easy_setopt(curl, CURLOPT_FAILONERROR, 1L);

    /* TLS security: verify peer and hostname strictly */
    curl_easy_setopt(curl, CURLOPT_USE_SSL, CURLUSESSL_ALL);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);

    /* Timeouts and keepalive */
    curl_easy_setopt(curl, CURLOPT_CONNECTTIMEOUT_L, 30L);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT_L, 600L);
    curl_easy_setopt(curl, CURLOPT_TCP_KEEPALIVE, 1L);
    curl_easy_setopt(curl, CURLOPT_TCP_KEEPIDLE, 30L);
    curl_easy_setopt(curl, CURLOPT_TCP_KEEPINTVL, 30L);

    /* Passive mode is default; ensure path method doesn't change directories dangerously */
    curl_easy_setopt(curl, CURLOPT_FTP_FILEMETHOD, (long)CURLFTPMETHOD_SINGLECWD);

    /* Perform transfer */
    cc = curl_easy_perform(curl);
    if (cc != CURLE_OK) {
        fprintf(stderr, "Download failed: %s\n", curl_easy_strerror(cc));
        goto cleanup;
    }

    /* Flush and fsync to ensure durability before commit */
    if (fflush(fp) != 0) {
        fprintf(stderr, "Error: flush failed.\n");
        goto cleanup;
    }
#if defined(_WIN32)
    /* fsync equivalent on Windows would be _commit(tmp_fd); omitted for POSIX build focus */
#else
    if (fsync(tmp_fd) != 0) {
        fprintf(stderr, "Error: fsync failed.\n");
        goto cleanup;
    }
#endif

    /* Commit atomically without overwriting existing files */
    int ac = atomic_commit_no_overwrite(temp_path, local_name);
    if (ac == 1) {
        fprintf(stderr, "Error: target file '%s' already exists; not overwriting.\n", local_name);
        goto cleanup;
    } else if (ac != 0) {
        fprintf(stderr, "Error: atomic commit failed.\n");
        goto cleanup;
    }

    /* Success */
    if (saved_path_out_sz > 0) {
        size_t l = strnlen(local_name, sizeof local_name);
        if (l + 1 > saved_path_out_sz) {
            fprintf(stderr, "Internal error: output buffer too small.\n");
            ret = -1;
            goto cleanup;
        }
        memcpy(saved_path_out, local_name, l + 1);
    }
    ret = 0;

cleanup:
    if (fp) { fclose(fp); fp = NULL; }
    else if (tmp_fd >= 0) { close(tmp_fd); }

    if (ret != 0 && temp_path) {
        /* Best-effort cleanup of temp */
        (void)unlink(temp_path);
    }
    free(temp_path);
    free(url);
    if (curl) curl_easy_cleanup(curl);
    curl_global_cleanup();
    return ret;
}

/* -------------- Test harness -------------- */
static void run_tests(void) {
    /* Five basic tests focused on input validation and filename sanitization */
    const char *paths[] = {
        "/etc/passwd",
        "folder/file.txt",
        "../../secret?.txt",
        "safe-Name_1.2.3",
        "/deep/path/to/.hidden_config"
    };
    for (int i = 0; i < 5; i++) {
        char out[256];
        int rc = sanitize_basename(paths[i], out, sizeof out);
        if (rc == 0) {
            printf("[TEST %d] OK: '%s' -> '%s'\n", i + 1, paths[i], out);
        } else {
            printf("[TEST %d] REJECTED: '%s'\n", i + 1, paths[i]);
        }
    }
    /* Note: Network download not attempted in tests to keep execution environment self-contained. */
}

/* -------------- Main -------------- */
int main(int argc, char **argv) {
    if (argc == 5) {
        const char *hostname = argv[1];
        const char *username = argv[2];
        const char *password = argv[3];
        const char *remote_path = argv[4];

        char saved[512];
        int rc = download_ftps_file(hostname, username, password, remote_path, saved, sizeof saved);
        if (rc == 0) {
            printf("Downloaded securely to: %s\n", saved);
            return 0;
        } else {
            fprintf(stderr, "Download failed.\n");
            return 1;
        }
    } else {
        fprintf(stderr, "Usage: %s <hostname> <username> <password> <remote_file_path>\n", argv[0]);
        printf("Running 5 self-tests (no network):\n");
        run_tests();
        return 0;
    }
}
