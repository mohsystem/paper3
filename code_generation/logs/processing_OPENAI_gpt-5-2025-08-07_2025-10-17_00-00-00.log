/*
Secure HTTP client in C using libcurl.
- Validates input URL (length, characters, scheme, and host).
- Enforces TLS certificate validation and strict hostname verification.
- Limits protocols to HTTP/HTTPS and caps response size.
- Includes five test cases and an interactive prompt.

Build (example):
  cc -Wall -Wextra -O2 task160.c -o task160 -lcurl
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <errno.h>
#include <curl/curl.h>

#define MAX_URL_LEN        2048
#define MAX_RESPONSE_BYTES (1024 * 1024) /* 1 MiB cap */
#define TIMEOUT_MS         10000L        /* 10 seconds */
#define MAX_REDIRECTS      5L

typedef struct {
    char *data;
    size_t size;
    size_t capacity;
    size_t max_bytes;
    int limit_hit;
} MemoryBuffer;

static void mbuf_init(MemoryBuffer *b, size_t initial_capacity, size_t max_bytes) {
    if (!b) return;
    b->data = NULL;
    b->size = 0;
    b->capacity = 0;
    b->max_bytes = max_bytes;
    b->limit_hit = 0;

    if (initial_capacity > 0) {
        if (initial_capacity > max_bytes) initial_capacity = max_bytes;
        b->data = (char *)malloc(initial_capacity);
        if (b->data) {
            b->data[0] = '\0';
            b->capacity = initial_capacity;
        }
    }
}

static void mbuf_free(MemoryBuffer *b) {
    if (!b) return;
    if (b->data) {
        /* No sensitive data, but zeroing is harmless */
        /* memset(b->data, 0, b->capacity); */
        free(b->data);
    }
    b->data = NULL;
    b->size = 0;
    b->capacity = 0;
    b->max_bytes = 0;
    b->limit_hit = 0;
}

static int mbuf_reserve(MemoryBuffer *b, size_t needed) {
    if (!b) return 0;
    if (needed > b->max_bytes) {
        needed = b->max_bytes;
    }
    if (needed <= b->capacity) return 1;

    size_t newcap = b->capacity ? b->capacity : 16384; /* 16 KiB start */
    while (newcap < needed) {
        if (newcap > b->max_bytes / 2) { /* prevent overflow */
            newcap = b->max_bytes;
            break;
        }
        newcap *= 2;
        if (newcap > b->max_bytes) {
            newcap = b->max_bytes;
            break;
        }
    }

    char *p = (char *)realloc(b->data, newcap);
    if (!p) return 0;

    b->data = p;
    b->capacity = newcap;
    return 1;
}

static size_t write_callback(void *contents, size_t size, size_t nmemb, void *userp) {
    MemoryBuffer *b = (MemoryBuffer *)userp;
    if (!b || !contents) return 0;

    size_t total = size * nmemb;
    if (total == 0) return 0;

    if (b->size >= b->max_bytes) {
        b->limit_hit = 1;
        return 0; /* abort transfer */
    }

    size_t newsize_target = b->size + total + 1; /* +1 for null terminator */
    if (newsize_target > b->max_bytes + 1) {
        /* Would exceed max; abort */
        b->limit_hit = 1;
        return 0;
    }

    if (!mbuf_reserve(b, newsize_target)) {
        /* allocation failed */
        return 0;
    }

    memcpy(b->data + b->size, contents, total);
    b->size += total;
    b->data[b->size] = '\0';
    return total;
}

static int is_printable_url_char(int c) {
    /* Allow visible ASCII except spaces and control chars */
    if (c <= 0x1F || c == 0x7F) return 0;
    if (isspace((unsigned char)c)) return 0;
    return 1;
}

/* Basic URL validation using libcurl URL API plus character/length checks */
static int validate_url_basic(const char *url, char *err, size_t errlen) {
    if (!url) {
        if (err && errlen) snprintf(err, errlen, "URL is NULL");
        return 0;
    }

    size_t len = strnlen(url, MAX_URL_LEN + 1);
    if (len == 0 || len > MAX_URL_LEN) {
        if (err && errlen) snprintf(err, errlen, "URL length invalid (1..%d)", MAX_URL_LEN);
        return 0;
    }

    for (size_t i = 0; i < len; ++i) {
        unsigned char ch = (unsigned char)url[i];
        if (!is_printable_url_char(ch)) {
            if (err && errlen) snprintf(err, errlen, "URL contains invalid character");
            return 0;
        }
    }

#if LIBCURL_VERSION_NUM >= 0x073E00 /* 7.62.0 for curl_url */
    CURLU *h = curl_url();
    if (!h) {
        if (err && errlen) snprintf(err, errlen, "Failed to create URL parser");
        return 0;
    }

    CURLUcode uc = curl_url_set(h, CURLUPART_URL, url, 0);
    if (uc != CURLUE_OK) {
        if (err && errlen) snprintf(err, errlen, "Malformed URL");
        curl_url_cleanup(h);
        return 0;
    }

    char *scheme = NULL;
    uc = curl_url_get(h, CURLUPART_SCHEME, &scheme, 0);
    if (uc != CURLUE_OK || !scheme) {
        if (err && errlen) snprintf(err, errlen, "Missing URL scheme");
        if (scheme) curl_free(scheme);
        curl_url_cleanup(h);
        return 0;
    }
    int ok_scheme = (strcmp(scheme, "http") == 0 || strcmp(scheme, "https") == 0);
    curl_free(scheme);
    if (!ok_scheme) {
        if (err && errlen) snprintf(err, errlen, "Only http and https schemes are allowed");
        curl_url_cleanup(h);
        return 0;
    }

    char *host = NULL;
    uc = curl_url_get(h, CURLUPART_HOST, &host, 0);
    if (uc != CURLUE_OK || !host || host[0] == '\0') {
        if (err && errlen) snprintf(err, errlen, "URL must include a host");
        if (host) curl_free(host);
        curl_url_cleanup(h);
        return 0;
    }
    curl_free(host);

    /* Disallow userinfo (username:password@host) */
    char *user = NULL;
    uc = curl_url_get(h, CURLUPART_USER, &user, 0);
    if (uc == CURLUE_OK && user && user[0] != '\0') {
        if (err && errlen) snprintf(err, errlen, "Userinfo in URL is not allowed");
        curl_free(user);
        curl_url_cleanup(h);
        return 0;
    }
    if (user) curl_free(user);

    curl_url_cleanup(h);
#else
    /* Fallback validation: ensure scheme starts with http:// or https:// and has a host part */
    const char *p = NULL;
    if (strncmp(url, "http://", 7) == 0) {
        p = url + 7;
    } else if (strncmp(url, "https://", 8) == 0) {
        p = url + 8;
    } else {
        if (err && errlen) snprintf(err, errlen, "Only http and https schemes are allowed");
        return 0;
    }
    if (!p || *p == '\0') {
        if (err && errlen) snprintf(err, errlen, "URL must include a host");
        return 0;
    }
    /* Quick host presence check (until slash or end) */
    const char *slash = strchr(p, '/');
    size_t hostlen = slash ? (size_t)(slash - p) : strlen(p);
    if (hostlen == 0) {
        if (err && errlen) snprintf(err, errlen, "URL must include a host");
        return 0;
    }
    /* Disallow credentials */
    if (memchr(p, '@', hostlen) != NULL) {
        if (err && errlen) snprintf(err, errlen, "Userinfo in URL is not allowed");
        return 0;
    }
#endif

    if (err && errlen) err[0] = '\0';
    return 1;
}

/* Performs an HTTP(S) GET request. Returns 1 on success, 0 on failure.
   On success, *out_body points to a malloc'd buffer that caller must free.
   On both success and failure, *out_code contains HTTP response code if available (else 0).
   err buffer contains a human-readable message on failure (or empty on success). */
static int http_get_request(const char *url,
                            long timeout_ms,
                            size_t max_bytes,
                            long max_redirects,
                            char **out_body,
                            long *out_code,
                            char *err,
                            size_t errlen) {
    if (out_body) *out_body = NULL;
    if (out_code) *out_code = 0;
    if (err && errlen) err[0] = '\0';

    if (!url || !out_body || !out_code) {
        if (err && errlen) snprintf(err, errlen, "Invalid parameters");
        return 0;
    }

    char vmsg[128];
    if (!validate_url_basic(url, vmsg, sizeof(vmsg))) {
        if (err && errlen) snprintf(err, errlen, "URL validation failed: %s", vmsg);
        return 0;
    }

    CURL *curl = curl_easy_init();
    if (!curl) {
        if (err && errlen) snprintf(err, errlen, "Failed to initialize CURL");
        return 0;
    }

    MemoryBuffer buf;
    mbuf_init(&buf, 16384, max_bytes);

    CURLcode res;
    long httpcode = 0;

    /* Enforce secure defaults and restrictions */
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_PROTOCOLS, CURLPROTO_HTTP | CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_REDIR_PROTOCOLS, CURLPROTO_HTTP | CURLPROTO_HTTPS);
    curl_easy_setopt(curl, CURLOPT_FOLLOWLOCATION, 1L);
    curl_easy_setopt(curl, CURLOPT_MAXREDIRS, max_redirects);
    curl_easy_setopt(curl, CURLOPT_USERAGENT, "SecureHTTPClient/1.0");
    curl_easy_setopt(curl, CURLOPT_NOSIGNAL, 1L);
    curl_easy_setopt(curl, CURLOPT_TIMEOUT_MS, timeout_ms);
    curl_easy_setopt(curl, CURLOPT_ACCEPT_ENCODING, "");
    curl_easy_setopt(curl, CURLOPT_HTTPGET, 1L);

    /* TLS/SSL verification */
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);
#if LIBCURL_VERSION_NUM >= 0x072E00 /* 7.46.0 */
    curl_easy_setopt(curl, CURLOPT_SSL_VERIFYSTATUS, 1L); /* OCSP stapling if available */
#endif

    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, &buf);

    res = curl_easy_perform(curl);

    if (res == CURLE_OK) {
        curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &httpcode);
        if (out_code) *out_code = httpcode;

        /* Ensure NUL-termination even if empty */
        if (!buf.data) {
            buf.data = (char *)malloc(1);
            if (!buf.data) {
                curl_easy_cleanup(curl);
                if (err && errlen) snprintf(err, errlen, "Out of memory");
                return 0;
            }
            buf.data[0] = '\0';
        }

        *out_body = buf.data;
        /* Do not free buf.data here as ownership transfers to caller */
        curl_easy_cleanup(curl);
        return 1;
    } else {
        const char *emsg = curl_easy_strerror(res);
        curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &httpcode);
        if (out_code) *out_code = httpcode;

        if (buf.limit_hit) {
            if (err && errlen) snprintf(err, errlen, "Response exceeded limit of %zu bytes", buf.max_bytes);
        } else {
            if (err && errlen) snprintf(err, errlen, "CURL error: %s", emsg ? emsg : "Unknown error");
        }

        mbuf_free(&buf);
        curl_easy_cleanup(curl);
        return 0;
    }
}

/* Utility to print a summary of response content safely */
static void print_response_summary(const char *label, int ok, long code, const char *body, const char *err) {
    printf("== %s ==\n", label);
    if (ok) {
        printf("Success. HTTP status: %ld\n", code);
        size_t to_show = 200;
        size_t len = body ? strlen(body) : 0;
        if (len < to_show) to_show = len;
        printf("Body (first %zu bytes):\n", to_show);
        if (to_show > 0) {
            /* Print safely: escape non-printables */
            for (size_t i = 0; i < to_show; ++i) {
                unsigned char c = (unsigned char)body[i];
                if (c == '\n' || c == '\r' || (c >= 32 && c < 127)) {
                    putchar(c);
                } else {
                    printf("\\x%02X", c);
                }
            }
            putchar('\n');
        } else {
            printf("<empty>\n");
        }
    } else {
        printf("Failed. HTTP status (if any): %ld\n", code);
        printf("Error: %s\n", err ? err : "Unknown error");
    }
    printf("\n");
}

int main(void) {
    if (curl_global_init(CURL_GLOBAL_DEFAULT) != 0) {
        fprintf(stderr, "Failed to initialize libcurl\n");
        return 1;
    }

    const char *tests[5] = {
        "https://example.com/",
        "http://example.com/",
        "https://www.google.com/robots.txt",
        "ftp://example.com/",                  /* invalid scheme, should fail validation */
        "https://expired.badssl.com/"          /* TLS should fail due to expired cert */
    };

    for (int i = 0; i < 5; ++i) {
        char *body = NULL;
        long code = 0;
        char err[256];
        int ok = http_get_request(tests[i], TIMEOUT_MS, MAX_RESPONSE_BYTES, MAX_REDIRECTS, &body, &code, err, sizeof(err));
        char label[128];
        snprintf(label, sizeof(label), "Test case %d: %s", i + 1, tests[i]);
        print_response_summary(label, ok, code, body, ok ? NULL : err);
        free(body);
    }

    /* Interactive part: accept a URL from the user and fetch it */
    printf("Enter a URL (http or https): ");
    fflush(stdout);

    char input_buf[MAX_URL_LEN + 2]; /* +2 for newline and NUL */
    if (fgets(input_buf, sizeof(input_buf), stdin) != NULL) {
        size_t n = strlen(input_buf);
        if (n > 0 && (input_buf[n - 1] == '\n' || input_buf[n - 1] == '\r')) {
            input_buf[n - 1] = '\0';
            n--;
            if (n > 0 && input_buf[n - 1] == '\r') {
                input_buf[n - 1] = '\0';
                n--;
            }
        }

        char *body = NULL;
        long code = 0;
        char err[256];
        int ok = http_get_request(input_buf, TIMEOUT_MS, MAX_RESPONSE_BYTES, MAX_REDIRECTS, &body, &code, err, sizeof(err));
        print_response_summary("User-provided URL", ok, code, body, ok ? NULL : err);
        free(body);
    } else {
        fprintf(stderr, "Failed to read input: %s\n", strerror(errno));
        curl_global_cleanup();
        return 1;
    }

    curl_global_cleanup();
    return 0;
}
