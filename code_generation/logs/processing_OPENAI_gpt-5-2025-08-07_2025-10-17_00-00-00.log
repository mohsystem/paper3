/*
 * Program: HTTPS Page Title Extractor (C with libcurl)
 * Description:
 *   - Fetches a webpage over HTTPS from a command-line URL parameter
 *   - Extracts and returns the HTML <title> content
 *   - Enforces TLS certificate and hostname verification, and checks OCSP stapled status
 *
 * Build (example):
 *   cc -Wall -Wextra -pedantic -O2 task76.c -o task76 -lcurl
 *
 * Usage:
 *   ./task76 https://example.com [https://another.example]
 *
 * If no arguments are provided, runs 5 local parser test cases.
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <curl/curl.h>

#ifndef SIZE_MAX
#include <limits.h>
#endif

#define TITLE_MAX_OUT 512
#define URL_MAX_LEN 2048
#define MAX_DOWNLOAD_SIZE (10 * 1024 * 1024) /* 10 MiB */
#define INITIAL_BUF_CAP 8192

typedef struct {
    char *data;
    size_t size;
    size_t cap;
    size_t max;
    int overflowed;
} ResponseBuffer;

/* Safe multiplication check to avoid overflow: returns 0 on success, -1 on overflow */
static int safe_mul_size(size_t a, size_t b, size_t *out) {
    if (a == 0 || b == 0) { *out = 0; return 0; }
    if (a > SIZE_MAX / b) return -1;
    *out = a * b;
    return 0;
}

/* Initialize response buffer */
static int rb_init(ResponseBuffer *rb, size_t initial_cap, size_t max_cap) {
    if (!rb) return -1;
    rb->data = NULL;
    rb->size = 0;
    rb->cap = 0;
    rb->max = max_cap;
    rb->overflowed = 0;

    if (initial_cap > max_cap) initial_cap = max_cap;
    rb->data = (char *)malloc(initial_cap);
    if (!rb->data) return -1;
    rb->cap = initial_cap;
    rb->data[0] = '\0';
    return 0;
}

/* Ensure capacity, growing as needed without exceeding rb->max */
static int rb_ensure_capacity(ResponseBuffer *rb, size_t needed) {
    if (!rb) return -1;
    if (needed <= rb->cap) return 0;

    size_t new_cap = rb->cap ? rb->cap : INITIAL_BUF_CAP;
    while (new_cap < needed) {
        if (new_cap > rb->max / 2) { new_cap = rb->max; break; }
        new_cap *= 2;
    }
    if (new_cap < needed || new_cap > rb->max) {
        rb->overflowed = 1;
        return -1;
    }
    char *tmp = (char *)realloc(rb->data, new_cap);
    if (!tmp) return -1;
    rb->data = tmp;
    rb->cap = new_cap;
    return 0;
}

/* Free response buffer */
static void rb_free(ResponseBuffer *rb) {
    if (rb && rb->data) {
        free(rb->data);
        rb->data = NULL;
        rb->size = 0;
        rb->cap = 0;
        rb->max = 0;
        rb->overflowed = 0;
    }
}

/* libcurl write callback */
static size_t write_cb(void *contents, size_t size, size_t nmemb, void *userp) {
    ResponseBuffer *rb = (ResponseBuffer *)userp;
    if (!rb || !contents) return 0;

    size_t chunk_size;
    if (safe_mul_size(size, nmemb, &chunk_size) != 0) return 0;

    /* Enforce maximum size */
    if (rb->size >= rb->max || chunk_size > rb->max - rb->size) {
        rb->overflowed = 1;
        return 0; /* Abort transfer - too large */
    }

    size_t needed = rb->size + chunk_size + 1; /* +1 for null terminator */
    if (rb_ensure_capacity(rb, needed) != 0) {
        return 0; /* Abort transfer on allocation failure */
    }

    memcpy(rb->data + rb->size, contents, chunk_size);
    rb->size += chunk_size;
    rb->data[rb->size] = '\0';
    return chunk_size;
}

/* Validate that a URL is HTTPS and within length constraints */
static int is_https_url(const char *url) {
    if (!url) return 0;
    size_t len = strnlen(url, URL_MAX_LEN + 1);
    if (len == 0 || len > URL_MAX_LEN) return 0;
    const char *prefix = "https://";
    size_t pfx_len = 8;
    if (len < pfx_len) return 0;
    if (strncmp(url, prefix, pfx_len) != 0) return 0;

    /* Basic host validation: ensure at least one dot in host portion */
    const char *host_start = url + pfx_len;
    const char *slash = strchr(host_start, '/');
    size_t host_len = slash ? (size_t)(slash - host_start) : strnlen(host_start, URL_MAX_LEN - pfx_len);
    if (host_len == 0) return 0;
    int has_dot = 0;
    for (size_t i = 0; i < host_len; i++) {
        if (host_start[i] == '.') { has_dot = 1; break; }
    }
    if (!has_dot) return 0;

    return 1;
}

/* Case-insensitive comparison of two chars (ASCII) */
static int ci_equal(char a, char b) {
    return tolower((unsigned char)a) == tolower((unsigned char)b);
}

/* Find case-insensitive substring; returns pointer or NULL */
static const char* find_ci_substr(const char *hay, size_t hay_len, const char *needle) {
    size_t nlen = strlen(needle);
    if (nlen == 0 || hay_len < nlen) return NULL;
    for (size_t i = 0; i + nlen <= hay_len; i++) {
        size_t j = 0;
        for (; j < nlen; j++) {
            if (!ci_equal(hay[i + j], needle[j])) break;
        }
        if (j == nlen) return hay + i;
    }
    return NULL;
}

/* Trim leading/trailing whitespace and copy to out (null-terminated), returns 0 on success */
static int trim_copy(const char *in, size_t in_len, char *out, size_t outsz) {
    if (!in || !out || outsz == 0) return -1;
    size_t start = 0;
    while (start < in_len && isspace((unsigned char)in[start])) start++;
    size_t end = in_len;
    while (end > start && isspace((unsigned char)in[end - 1])) end--;
    size_t len = end > start ? (end - start) : 0;
    if (len + 1 > outsz) {
        /* Truncate safely */
        len = outsz - 1;
    }
    if (len > 0) memcpy(out, in + start, len);
    out[len] = '\0';
    return 0;
}

/* Extract <title> content, case-insensitive, returns 0 on success */
int extract_title(const char *html, char *out_title, size_t out_title_sz) {
    if (!html || !out_title || out_title_sz == 0) return -1;

    size_t len = strlen(html);
    if (len == 0) return -2;

    /* Find opening <title ...> */
    const char *open = find_ci_substr(html, len, "<title");
    if (!open) return -3;

    const char *gt = strchr(open, '>');
    if (!gt) return -4;

    const char *content_start = gt + 1;
    if (content_start >= html + len) return -5;

    /* Find closing </title */
    const char *close = find_ci_substr(content_start, (size_t)((html + len) - content_start), "</title");
    if (!close) return -6;

    size_t content_len = (size_t)(close - content_start);

    /* Trim and copy to output */
    if (trim_copy(content_start, content_len, out_title, out_title_sz) != 0) return -7;

    return out_title[0] != '\0' ? 0 : -8;
}

/* Fetch the full content of a URL over HTTPS into a newly allocated buffer (must be freed by caller) */
int fetch_url_https(const char *url, char **out_buf, size_t *out_len) {
    if (!url || !out_buf || !out_len) return -1;
    if (!is_https_url(url)) return -2;

    CURLcode gcode = curl_global_init(CURL_GLOBAL_DEFAULT);
    if (gcode != CURLE_OK) return -3;

    int ret = 0;
    CURL *curl = curl_easy_init();
    if (!curl) {
        curl_global_cleanup();
        return -4;
    }

    ResponseBuffer rb;
    if (rb_init(&rb, INITIAL_BUF_CAP, MAX_DOWNLOAD_SIZE) != 0) {
        curl_easy_cleanup(curl);
        curl_global_cleanup();
        return -5;
    }

    char errbuf[CURL_ERROR_SIZE];
    errbuf[0] = '\0';

    curl_easy_setopt(curl, CURLOPT_URL, url);
