#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>
#include <openssl/evp.h>
#include <openssl/rand.h>
#include <openssl/crypto.h>

#define MAGIC "ENC1"
#define MAGIC_LEN 4
#define VERSION 1
#define SALT_LEN 16
#define IV_LEN 12
#define TAG_LEN 16
#define DERIVED_KEY_LEN 32
#define PBKDF2_ITERATIONS 210000
#define MAX_INPUT_KEY_LEN 4096

typedef struct {
    unsigned char *data;
    size_t len;
} ByteArray;

static void bytearray_free(ByteArray *arr) {
    if (arr && arr->data) {
        OPENSSL_cleanse(arr->data, arr->len);
        free(arr->data);
        arr->data = NULL;
        arr->len = 0;
    }
}

static int generate_random(unsigned char *buf, size_t len) {
    if (buf == NULL || len == 0 || len > 1<<20) return 0;
    return RAND_bytes(buf, (int)len) == 1 ? 1 : 0;
}

static int derive_key_pbkdf2(const char *passphrase, const unsigned char *salt, size_t salt_len, unsigned char *out_key, size_t out_len) {
    if (!passphrase || !salt || salt_len != SALT_LEN || !out_key || out_len != DERIVED_KEY_LEN) return 0;
    return PKCS5_PBKDF2_HMAC(passphrase, (int)strlen(passphrase), salt, (int)salt_len, PBKDF2_ITERATIONS, EVP_sha256(), (int)out_len, out_key) == 1 ? 1 : 0;
}

static ByteArray encrypt_key_secure(const char *passphrase, const unsigned char *key_plain, size_t key_len) {
    ByteArray out = { NULL, 0 };
    EVP_CIPHER_CTX *ctx = NULL;
    unsigned char salt[SALT_LEN];
    unsigned char iv[IV_LEN];
    unsigned char dkey[DERIVED_KEY_LEN];
    unsigned char *ciphertext = NULL;
    int outl = 0, tmplen = 0;
    size_t header_len = MAGIC_LEN + 1 + SALT_LEN + IV_LEN;
    size_t total_len = 0;

    if (!passphrase || !key_plain || key_len == 0 || key_len > MAX_INPUT_KEY_LEN) {
        return out;
    }

    if (!generate_random(salt, sizeof(salt))) goto cleanup;
    if (!generate_random(iv, sizeof(iv))) goto cleanup;
    if (!derive_key_pbkdf2(passphrase, salt, sizeof(salt), dkey, sizeof(dkey))) goto cleanup;

    ctx = EVP_CIPHER_CTX_new();
    if (!ctx) goto cleanup;
    if (EVP_EncryptInit_ex(ctx, EVP_aes_256_gcm(), NULL, NULL, NULL) != 1) goto cleanup;
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, (int)sizeof(iv), NULL) != 1) goto cleanup;
    if (EVP_EncryptInit_ex(ctx, NULL, NULL, dkey, iv) != 1) goto cleanup;

    ciphertext = (unsigned char *)malloc(key_len);
    if (!ciphertext) goto cleanup;
    if (EVP_EncryptUpdate(ctx, ciphertext, &outl, key_plain, (int)key_len) != 1) goto cleanup;

    // GCM does not output data at finalization for encryption, but call for completeness.
    if (EVP_EncryptFinal_ex(ctx, ciphertext + outl, &tmplen) != 1) goto cleanup;
    outl += tmplen;

    unsigned char tag[TAG_LEN];
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_GET_TAG, TAG_LEN, tag) != 1) goto cleanup;

    total_len = header_len + (size_t)outl + TAG_LEN;
    out.data = (unsigned char *)malloc(total_len);
    if (!out.data) goto cleanup;
    out.len = total_len;

    size_t off = 0;
    memcpy(out.data + off, MAGIC, MAGIC_LEN); off += MAGIC_LEN;
    out.data[off++] = VERSION;
    memcpy(out.data + off, salt, SALT_LEN); off += SALT_LEN;
    memcpy(out.data + off, iv, IV_LEN); off += IV_LEN;
    memcpy(out.data + off, ciphertext, (size_t)outl); off += (size_t)outl;
    memcpy(out.data + off, tag, TAG_LEN); off += TAG_LEN;

    goto done;

cleanup:
    bytearray_free(&out);
done:
    if (ctx) EVP_CIPHER_CTX_free(ctx);
    if (ciphertext) { OPENSSL_cleanse(ciphertext, key_len); free(ciphertext); }
    OPENSSL_cleanse(dkey, sizeof(dkey));
    OPENSSL_cleanse(salt, sizeof(salt));
    OPENSSL_cleanse(iv, sizeof(iv));
    return out;
}

static ByteArray decrypt_blob_secure(const char *passphrase, const unsigned char *blob, size_t blob_len) {
    ByteArray out = { NULL, 0 };
    EVP_CIPHER_CTX *ctx = NULL;
    unsigned char dkey[DERIVED_KEY_LEN];
    const unsigned char *p = blob;
    size_t min_len = MAGIC_LEN + 1 + SALT_LEN + IV_LEN + TAG_LEN;

    if (!passphrase || !blob || blob_len < min_len) return out;
    if (CRYPTO_memcmp(p, MAGIC, MAGIC_LEN) != 0) return out;
    p += MAGIC_LEN;

    if (*p != VERSION) return out;
    p += 1;

    const unsigned char *salt = p; p += SALT_LEN;
    const unsigned char *iv = p; p += IV_LEN;

    size_t ct_len = blob + blob_len - p - TAG_LEN;
    if (ct_len > MAX_INPUT_KEY_LEN || ct_len == 0) return out;

    const unsigned char *ct = p; p += ct_len;
    const unsigned char *tag = p;

    if (!derive_key_pbkdf2(passphrase, salt, SALT_LEN, dkey, sizeof(dkey))) goto cleanup;

    ctx = EVP_CIPHER_CTX_new();
    if (!ctx) goto cleanup;
    if (EVP_DecryptInit_ex(ctx, EVP_aes_256_gcm(), NULL, NULL, NULL) != 1) goto cleanup;
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_IVLEN, (int)IV_LEN, NULL) != 1) goto cleanup;
    if (EVP_DecryptInit_ex(ctx, NULL, NULL, dkey, iv) != 1) goto cleanup;

    out.data = (unsigned char *)malloc(ct_len);
    if (!out.data) goto cleanup;

    int outl = 0, tmplen = 0;
    if (EVP_DecryptUpdate(ctx, out.data, &outl, ct, (int)ct_len) != 1) goto cleanup;
    if (EVP_CIPHER_CTX_ctrl(ctx, EVP_CTRL_GCM_SET_TAG, TAG_LEN, (void *)tag) != 1) goto cleanup;

    if (EVP_DecryptFinal_ex(ctx, out.data + outl, &tmplen) != 1) goto cleanup;
    outl += tmplen;
    out.len = (size_t)outl;
    goto done;

cleanup:
    bytearray_free(&out);
done:
    if (ctx) EVP_CIPHER_CTX_free(ctx);
    OPENSSL_cleanse(dkey, sizeof(dkey));
    return out;
}

static int constant_time_equal(const unsigned char *a, const unsigned char *b, size_t len) {
    if (!a || !b) return 0;
    return CRYPTO_memcmp(a, b, len) == 0 ? 1 : 0;
}

int main(void) {
    // Five test cases: each with a passphrase and a "key" to encrypt (as bytes).
    const char *passphrases[5] = {
        "correct horse battery staple",
        "p@ssw0rd-2",
        "another-longer-passphrase",
        "ShortPass!",
        "Una_clave_segura_#2025"
    };

    unsigned char key1[16]  = { 0x00,0x01,0x02,0x03,0x21,0x22,0x23,0x24,0xAA,0xBB,0xCC,0xDD,0x10,0x20,0x30,0x40 };
    unsigned char key2[24]  = { 0x10,0x11,0x12,0x13,0x31,0x32,0x33,0x34,0xA1,0xB2,0xC3,0xD4,0x50,0x60,0x70,0x80,0x90,0x91,0x92,0x93,0x94,0x95,0x96,0x97 };
    unsigned char key3[32]  = { 0x20,0x21,0x22,0x23,0x41,0x42,0x43,0x44,0xAF,0xBF,0xCF,0xDF,0x01,0x03,0x05,0x07,0x09,0x0B,0x0D,0x0F,0xEE,0xDD,0xCC,0xBB,0xAA,0x99,0x88,0x77,0x66,0x55,0x44,0x33 };
    unsigned char key4[48]  = { 0 };
    unsigned char key5[64]  = { 0 };

    // Initialize some data for key4 and key5 deterministically.
    for (size_t i = 0; i < sizeof(key4); i++) key4[i] = (unsigned char)((i * 3 + 7) & 0xFF);
    for (size_t i = 0; i < sizeof(key5); i++) key5[i] = (unsigned char)((i * 5 + 11) & 0xFF);

    const unsigned char *keys[5] = { key1, key2, key3, key4, key5 };
    size_t key_lens[5] = { sizeof(key1), sizeof(key2), sizeof(key3), sizeof(key4), sizeof(key5) };

    for (int i = 0; i < 5; i++) {
        ByteArray enc = encrypt_key_secure(passphrases[i], keys[i], key_lens[i]);
        ByteArray dec = { NULL, 0 };
        int verified = 0;

        if (enc.data && enc.len > 0) {
            dec = decrypt_blob_secure(passphrases[i], enc.data, enc.len);
            if (dec.data && dec.len == key_lens[i]) {
                verified = constant_time_equal(dec.data, keys[i], key_lens[i]);
            }
        }

        // Only print non-sensitive metadata.
        printf("Test %d: encrypted_len=%zu, verified=%s\n", i + 1, enc.len, verified ? "OK" : "FAIL");

        bytearray_free(&enc);
        bytearray_free(&dec);
    }

