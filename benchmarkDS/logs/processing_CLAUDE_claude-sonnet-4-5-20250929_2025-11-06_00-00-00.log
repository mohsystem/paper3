2025-11-06 23:57:41,401 INFO TextBlock(citations=None, text='```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <sys/stat.h>\n#include <sys/types.h>\n#include <errno.h>\n#include <limits.h>\n#include <unistd.h>\n#include <fcntl.h>\n\n// Maximum filename length and upload directory path\n#define MAX_FILENAME_LEN 255\n#define UPLOAD_DIR "uploads"\n#define MAX_PATH_LEN 4096\n#define MAX_FILE_SIZE (10 * 1024 * 1024) // 10MB limit\n\n// Secure function to validate filename - Rules#2: Input validation\nint validate_filename(const char *filename) {\n    if (filename == NULL || strlen(filename) == 0) {\n        return 0;\n    }\n    \n    size_t len = strlen(filename);\n    if (len > MAX_FILENAME_LEN) {\n        return 0; // Filename too long\n    }\n    \n    // Rules#2: Block path traversal - reject ../ .\\ and absolute paths\n    if (strstr(filename, "..") != NULL || \n        strstr(filename, "/") != NULL || \n        strstr(filename, "\\\\") != NULL ||\n        filename[0] == '.' ||\n        (len > 1 && filename[1] == ':')) { // Windows drive letter\n        return 0;\n    }\n    \n    // Allow only alphanumeric, underscore, hyphen, and dot\n    for (size_t i = 0; i < len; i++) {\n        char c = filename[i];\n        if (!((c >= 'a' && c <= 'z') || \n              (c >= 'A' && c <= 'Z') || \n              (c >= '0' && c <= '9') || \n              c == '_' || c == '-' || c == '.')) {\n            return 0;\n        }\n    }\n    \n    return 1;\n}\n\n// Rules#7: Create upload directory with restrictive permissions\nint create_upload_directory(void) {\n    struct stat st = {0};\n    \n    // Check if directory exists using stat\n    if (stat(UPLOAD_DIR, &st) == -1) {\n        // Rules#7: Set restrictive permissions 0700 (owner only)\n        if (mkdir(UPLOAD_DIR, 0700) == -1) {\n            perror("Failed to create upload directory");\n            return 0;\n        }\n    } else {\n        // Verify it's a directory\n        if (!S_ISDIR(st.st_mode)) {\n            fprintf(stderr, "Upload path exists but is not a directory\\n");\n            return 0;\n        }\n    }\n    \n    return 1;\n}\n\n// Rules#7: Safe file write with atomic operations and TOCTOU prevention\nint save_file_securely(const char *filename, const unsigned char *data, size_t data_len) {\n    // Rules#2: Validate filename to prevent path traversal\n    if (!validate_filename(filename)) {\n        fprintf(stderr, "Invalid filename\\n");\n        return 0;\n    }\n    \n    // Rules#8: Check for integer overflow before allocation\n    if (data_len > MAX_FILE_SIZE) {\n        fprintf(stderr, "File size exceeds maximum allowed\\n");\n        return 0;\n    }\n    \n    // Rules#7: Create upload directory if it doesn't exist\n    if (!create_upload_directory()) {\n        return 0;\n    }\n    \n    // Build safe path - Rules#2: Path construction with validation\n    char filepath[MAX_PATH_LEN];\n    int ret = snprintf(filepath, sizeof(filepath), "%s/%s", UPLOAD_DIR, filename);\n    if (ret < 0 || ret >= (int)sizeof(filepath)) {\n        fprintf(stderr, "Path construction failed\\n");\n        return 0;\n    }\n    \n    // Rules#7: Create temporary file for atomic write\n    char temp_path[MAX_PATH_LEN];\n    ret = snprintf(temp_path, sizeof(temp_path), "%s/.tmp_%s_XXXXXX", UPLOAD_DIR, filename);\n    if (ret < 0 || ret >= (int)sizeof(temp_path)) {\n        fprintf(stderr, "Temp path construction failed\\n");\n        return 0;\n    }\n    \n    // Rules#7: Open with O_CREAT|O_EXCL|O_NOFOLLOW to prevent TOCTOU and symlink attacks\n    // Use mkstemp for secure temp file creation\n    int fd = mkstemp(temp_path);\n    if (fd == -1) {\n        perror("Failed to create temporary file");\n        return 0;\n    }\n    \n    // Rules#7: Validate the opened file descriptor with fstat\n    struct stat file_stat;\n    if (fstat(fd, &file_stat) == -1) {\n        perror("fstat failed");\n        close(fd);\n        unlink(temp_path);\n        return 0;\n    }\n    \n    // Verify it's a regular file\n    if (!S_ISREG(file_stat.st_mode)) {\n        fprintf(stderr, "Not a regular file\\n");\n        close(fd);\n        unlink(temp_path);\n        return 0;\n    }\n    \n    // Rules#8: Write data with bounds checking\n    size_t total_written = 0;\n    while (total_written < data_len) {\n        ssize_t written = write(fd, data + total_written, data_len - total_written);\n        if (written == -1) {\n            if (errno == EINTR) {\n                continue; // Retry on interrupt\n            }\n            perror("Write failed");\n            close(fd);\n            unlink(temp_path);\n            return 0;\n        }\n        total_written += written;\n    }\n    \n    // Rules#7: Flush and sync to ensure data is written to disk\n    if (fsync(fd) == -1) {\n        perror("fsync failed");\n        close(fd);\n        unlink(temp_path);\n        return 0;\n    }\n    \n    close(fd);\n    \n    // Rules#7: Atomic rename to final destination\n    if (rename(temp_path, filepath) == -1) {\n        perror("rename failed");\n        unlink(temp_path);\n        return 0;\n    }\n    \n    // Sync directory to ensure rename is durable\n    int dirfd = open(UPLOAD_DIR, O_RDONLY | O_DIRECTORY);\n    if (dirfd != -1) {\n        fsync(dirfd);\n        close(dirfd);\n    }\n    \n    return 1;\n}\n\n// Main upload function\nint upload_file(const char *filename, const unsigned char *file_data, size_t file_size) {\n    // Rules#2: Validate all inputs\n    if (filename == NULL || file_data == NULL || file_size == 0) {\n        fprintf(stderr, "Invalid input parameters\\n");\n        return 0;\n    }\n    \n    // Rules#10: Log upload attempt without sensitive data\n    printf("Processing file upload request\\n");\n    \n    // Save file securely\n    if (!save_file_securely(filename, file_data, file_size)) {\n        // Rules#11: Return generic error message\n        fprintf(stderr, "File upload failed\\n");\n        return 0;\n    }\n    \n    printf("File uploaded successfully\\n");\n    return 1;\n}\n\n// Test cases\nint main(void) {\n    printf("=== File Upload Security Test Cases ===\\n\\n");\n    \n    // Test case 1: Valid upload\n    printf("Test 1: Valid file upload\\n");\n    const unsigned char data1[] = "This is test file content";\n    if (upload_file("test1.txt", data1, sizeof(data1) - 1)) {\n        printf("PASS: Valid file uploaded\\n\\n");\n    } else {\n        printf("FAIL: Valid file rejected\\n\\n");\n    }\n    \n    // Test case 2: Path traversal attempt\n    printf("Test 2: Path traversal attempt (../etc/passwd)\\n");\n    const unsigned char data2[] = "malicious content";\n    if (!upload_file("../etc/passwd", data2, sizeof(data2) - 1)) {\n        printf("PASS: Path traversal blocked\\n\\n");\n    } else {\n        printf("FAIL: Path traversal allowed\\n\\n");\n    }\n    \n    // Test case 3: Absolute path attempt\n    printf("Test 3: Absolute path attempt (/tmp/evil.txt)\\n");\n    const unsigned char data3[] = "evil content";\n    if (!upload_file("/tmp/evil.txt", data3, sizeof(data3) - 1)) {\n        printf("PASS: Absolute path blocked\\n\\n");\n    } else {\n        printf("FAIL: Absolute path allowed\\n\\n");\n    }\n    \n    // Test case 4: Null input\n    printf("Test 4: NULL filename\\n");\n    const unsigned char data4[] = "test data";\n    if (!upload_file(NULL, data4, sizeof(data4) - 1)) {\n        printf("PASS: NULL filename rejected\\n\\n");\n    } else {\n        printf("FAIL: NULL filename accepted\\n\\n");\n    }\n    \n    // Test case 5: Valid filename with allowed characters\n    printf("Test 5: Valid filename with underscores and hyphens\\n");\n    const unsigned char data5[] = "Valid test content";\n    if (upload_file("test_file-2.txt", data5, sizeof(data5) - 1)) {\n        printf("PASS: Valid filename accepted\\n\\n");\n    } else {\n        printf("FAIL: Valid filename rejected\\n\\n");\n    }\n    \n    return 0;\n}\n```', type='t