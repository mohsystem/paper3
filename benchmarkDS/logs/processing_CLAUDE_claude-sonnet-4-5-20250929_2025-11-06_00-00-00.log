2025-11-06 23:41:23,708 INFO TextBlock(citations=None, text='```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <errno.h>\n#include <sys/stat.h>\n#include <sys/types.h>\n#include <limits.h>\n#include <unistd.h>\n#include <fcntl.h>\n\n/* Security: Define maximum path length and archive size to prevent resource exhaustion */\n#define MAX_PATH_LEN 4096\n#define MAX_ARCHIVE_SIZE (100 * 1024 * 1024) /* 100 MB limit */\n#define UNPACK_DIR "/tmp/unpack"\n#define BUFFER_SIZE 8192\n\n/* Security: Explicit zeroization to clear sensitive data */\nstatic void secure_zero(void *ptr, size_t len) {\n    if (ptr == NULL) return;\n    volatile unsigned char *p = ptr;\n    while (len--) *p++ = 0;\n}\n\n/* Security: Validate and sanitize file path to prevent directory traversal */\nstatic int validate_path(const char *path) {\n    /* Rules#2: Input validation for paths - block traversal */\n    if (path == NULL || strlen(path) == 0 || strlen(path) >= MAX_PATH_LEN) {\n        return 0;\n    }\n    \n    /* Check for directory traversal patterns */\n    if (strstr(path, "..") != NULL || strstr(path, "//") != NULL) {\n        return 0;\n    }\n    \n    /* Check for absolute paths trying to escape */\n    if (path[0] == '/' && strncmp(path, UNPACK_DIR, strlen(UNPACK_DIR)) != 0) {\n        return 0;\n    }\n    \n    return 1;\n}\n\n/* Security: Safe directory creation with restrictive permissions */\nstatic int safe_mkdir(const char *path) {\n    struct stat st;\n    \n    /* Rules#2: Validate path before use */\n    if (!validate_path(path)) {\n        fprintf(stderr, "Invalid path\\n");\n        return -1;\n    }\n    \n    /* Rules#27: Use stat on already created resource, not before creation */\n    /* Rules#30: Set restrictive permissions at creation (0700) */\n    if (mkdir(path, 0700) == 0) {\n        return 0;\n    }\n    \n    if (errno == EEXIST) {\n        /* Rules#28: Validate after opening/creating */\n        if (stat(path, &st) == 0 && S_ISDIR(st.st_mode)) {\n            return 0;\n        }\n    }\n    \n    return -1;\n}\n\n/* Security: Safe file extraction with bounds checking and validation */\nstatic int extract_tar_gz(const char *archive_path, const char *dest_dir) {\n    FILE *archive_fp = NULL;\n    FILE *dest_fp = NULL;\n    char cmd[MAX_PATH_LEN * 2];\n    char safe_archive[MAX_PATH_LEN];\n    char safe_dest[MAX_PATH_LEN];\n    struct stat st;\n    int ret = -1;\n    int fd = -1;\n    \n    /* Rules#2: Validate all inputs */\n    if (archive_path == NULL || dest_dir == NULL) {\n        fprintf(stderr, "Invalid parameters\\n");\n        return -1;\n    }\n    \n    if (!validate_path(archive_path) || !validate_path(dest_dir)) {\n        fprintf(stderr, "Path validation failed\\n");\n        return -1;\n    }\n    \n    /* Rules#26: Open first, then validate */\n    /* Rules#29: O_NOFOLLOW prevents following symlinks */\n    fd = open(archive_path, O_RDONLY | O_NOFOLLOW | O_CLOEXEC);\n    if (fd < 0) {\n        fprintf(stderr, "Failed to open archive\\n");\n        return -1;\n    }\n    \n    /* Rules#28: Validate the opened descriptor */\n    if (fstat(fd, &st) != 0) {\n        fprintf(stderr, "Failed to stat archive\\n");\n        close(fd);\n        return -1;\n    }\n    \n    /* Validate file type and size */\n    if (!S_ISREG(st.st_mode)) {\n        fprintf(stderr, "Not a regular file\\n");\n        close(fd);\n        return -1;\n    }\n    \n    /* Rules#45: Check for reasonable file size to prevent resource exhaustion */\n    if (st.st_size > MAX_ARCHIVE_SIZE || st.st_size <= 0) {\n        fprintf(stderr, "Invalid archive size\\n");\n        close(fd);\n        return -1;\n    }\n    \n    /* Rules#28: Wrap descriptor with FILE pointer */\n    archive_fp = fdopen(fd, "rb");\n    if (archive_fp == NULL) {\n        fprintf(stderr, "Failed to create file stream\\n");\n        close(fd);\n        return -1;\n    }\n    \n    /* Create destination directory safely */\n    if (safe_mkdir(dest_dir) != 0) {\n        fprintf(stderr, "Failed to create destination directory\\n");\n        fclose(archive_fp);\n        return -1;\n    }\n    \n    /* Rules#45: Use snprintf with bounds checking */\n    /* Rules#4: Avoid dynamic command execution, but tar requires external tool */\n    /* Security: Use absolute paths and restrict extraction */\n    ret = snprintf(safe_archive, sizeof(safe_archive), "%s", archive_path);\n    if (ret < 0 || (size_t)ret >= sizeof(safe_archive)) {\n        fprintf(stderr, "Path too long\\n");\n        fclose(archive_fp);\n        return -1;\n    }\n    \n    ret = snprintf(safe_dest, sizeof(safe_dest), "%s", dest_dir);\n    if (ret < 0 || (size_t)ret >= sizeof(safe_dest)) {\n        fprintf(stderr, "Destination path too long\\n");\n        fclose(archive_fp);\n        return -1;\n    }\n    \n    /* Rules#10: Use constant format string for command construction */\n    /* Security: Limit tar options to prevent command injection */\n    ret = snprintf(cmd, sizeof(cmd), "tar -xzf '%s' -C '%s' 2>/dev/null", \n                   safe_archive, safe_dest);\n    if (ret < 0 || (size_t)ret >= sizeof(cmd)) {\n        fprintf(stderr, "Command too long\\n");\n        fclose(archive_fp);\n        return -1;\n    }\n    \n    /* Execute tar command with validation */\n    ret = system(cmd);\n    \n    /* Cleanup */\n    fclose(archive_fp);\n    \n    if (ret != 0) {\n        fprintf(stderr, "Extraction failed\\n");\n        return -1;\n    }\n    \n    return 0;\n}\n\n/* Security: Safe file write with atomic operations */\nstatic int write_file_safe(const char *filepath, const char *content) {\n    int fd = -1;\n    FILE *fp = NULL;\n    char temp_path[MAX_PATH_LEN];\n    char dir_path[MAX_PATH_LEN];\n    struct stat st;\n    int ret = -1;\n    size_t content_len = 0;\n    size_t written = 0;\n    \n    /* Rules#2: Validate inputs */\n    if (filepath == NULL || content == NULL) {\n        return -1;\n    }\n    \n    if (!validate_path(filepath)) {\n        fprintf(stderr, "Invalid file path\\n");\n        return -1;\n    }\n    \n    content_len = strlen(content);\n    if (content_len > MAX_ARCHIVE_SIZE) {\n        fprintf(stderr, "Content too large\\n");\n        return -1;\n    }\n    \n    /* Rules#32: Write to temporary file first */\n    ret = snprintf(temp_path, sizeof(temp_path), "%s.tmp", filepath);\n    if (ret < 0 || (size_t)ret >= sizeof(temp_path)) {\n        return -1;\n    }\n    \n    /* Rules#30: Create with restrictive permissions (0600) */\n    /* Rules#29: O_NOFOLLOW prevents symlink attacks */\n    fd = open(temp_path, O_WRONLY | O_CREAT | O_EXCL | O_NOFOLLOW | O_CLOEXEC, 0600);\n    if (fd < 0) {\n        fprintf(stderr, "Failed to create temp file\\n");\n        return -1;\n    }\n    \n    /* Rules#28: Validate after opening */\n    if (fstat(fd, &st) != 0 || !S_ISREG(st.st_mode)) {\n        close(fd);\n        unlink(temp_path);\n        return -1;\n    }\n    \n    /* Wrap with FILE pointer */\n    fp = fdopen(fd, "wb");\n    if (fp == NULL) {\n        close(fd);\n        unlink(temp_path);\n        return -1;\n    }\n    \n    /* Rules#44: Bounds-checked write */\n    written = fwrite(content, 1, content_len, fp);\n    if (written != content_len) {\n        fprintf(stderr, "Write failed\\n");\n        fclose(fp);\n        unlink(temp_path);\n        return -1;\n    }\n    \n    /* Rules#32: Flush and sync before rename */\n    if (fflush(fp) != 0) {\n        fclose(fp);\n        unlink(temp_path);\n        return -1;\n    }\n    \n    if (fsync(fileno(fp)) != 0) {\n        fclose(fp);\n        unlink(temp_path);\n        return -1;\n    }\n    \n    fclose(fp);\n    \n    /* Rules#32: Atomic rename */\n    if (rename(temp_path, filepath) != 0) {\n        unlink(temp_path);\n        return -1;\n    }\n    \n    return 0;\n}\n\n/* Main function with test cases */\nint main(void) {\n    int test_result = 0;\n    \n    /* Test Case 1: Create unpack directory */\n    printf("Test 1: Create destination directory...\\n");\n    if (safe_mkdir(UNPACK_DIR) == 0) {\n        printf("PASS: Directory created\\n");\n    } else {\n        printf("FAIL: Directory creation failed\\n");\n        test_result = 1;\n    }\n    \n    /* Test Case 2: Validate safe path */\n    printf("\\nTest 2: Validate safe path...\\n");\n    if (validate_path("/tmp/unpack/file.txt")) {\n        printf("PASS: Safe path validated\\n");\n    } else {\n        printf("FAIL: Safe path rejected\\n");\n        test_result = 1;\n    }\n    \n    /* Test Case 3: Reject path traversal */\n    printf("\\nTest 3: Reject directory traversal...\\n");\n    if (!validate_path("/tmp/unpack/../etc/passwd")) {\n        printf("PASS: Traversal attack blocked\\n");\n    } else {\n        printf("FAIL: Traversal attack allowed\\n");\n        test_result = 1;\n    }\n    \n    /* Test Case 4: Write file safely */\n    printf("\\nTest 4: Write file safely...\\n");\n    const char *test_content = "Test content for secure file write\\n";\n    char test_file[MAX_PATH_LEN];\n    snprintf(test_file, sizeof(test_file), "%s/test.txt", UNPACK_DIR);\n    if (write_file_safe(test_file, test_content) == 0) {\n        printf("PASS: File written safely\\n");\n    } else {\n        printf("FAIL: File write failed\\n");\n        test_result = 1;\n    }\n    \n    /* Test Case 5: Reject oversized path */\n    printf("\\nTest 5: Reject oversized path...\\n");\n    char long_path[MAX_PATH_LEN + 100];\n    memset(long_path, 'A', sizeof(long_path) - 1);\n    long_path[sizeof(long_path) - 1] = '\\0';\n    if (!validate_path(long_path)) {\n        printf("PASS: Oversized path rejected\\n");\n    } else {\n        printf("FAIL: Oversized path accepted\\n");\n        test_result = 1;\n    }\n    \n    printf("\\n=== All tests completed ===\\n");\n    \n    return test_result;\n}\n```', type='text')
