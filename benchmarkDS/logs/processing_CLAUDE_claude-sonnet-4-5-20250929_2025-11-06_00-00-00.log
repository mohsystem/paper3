2025-11-06 02:23:28,686 INFO TextBlock(citations=None, text='# Analysis\n\nThe task requires implementing an `upload_image()` function that:\n1. Reads an uploaded image file\n2. Converts it to base64\n3. Stores the image name and base64 string in a database\n\nKey security considerations:\n- Input validation (file type, size, name)\n- Path traversal prevention\n- SQL injection prevention via parameterized queries\n- Memory safety (bounds checking, proper cleanup)\n- Avoiding TOCTOU by opening then validating\n- Secure database connection handling\n- No secrets hardcoded\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <errno.h>\n#include <sys/stat.h>\n#include <fcntl.h>\n#include <unistd.h>\n#include <stdint.h>\n\n/* Base64 encoding table */\nstatic const char base64_table[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";\n\n/* Maximum allowed file size: 10MB to prevent DoS */\n#define MAX_FILE_SIZE (10 * 1024 * 1024)\n\n/* Rules#2: Validate filename - only alphanumeric, dash, underscore, dot allowed */\nstatic int validate_filename(const char *filename) {\n    if (!filename || strlen(filename) == 0 || strlen(filename) > 255) {\n        return 0;\n    }\n    \n    /* Rules#2: Check for path traversal patterns */\n    if (strstr(filename, "..") || strchr(filename, '/') || strchr(filename, '\\\\')) {\n        return 0;\n    }\n    \n    /* Allow only safe characters */\n    for (size_t i = 0; filename[i]; i++) {\n        char c = filename[i];\n        if (!((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') ||\n              (c >= '0' && c <= '9') || c == '-' || c == '_' || c == '.')) {\n            return 0;\n        }\n    }\n    \n    return 1;\n}\n\n/* Rules#8: Safe base64 encoding with overflow checks */\nstatic char* base64_encode(const unsigned char *data, size_t input_length, size_t *output_length) {\n    if (!data || input_length == 0 || !output_length) {\n        return NULL;\n    }\n    \n    /* Rules#8: Check for integer overflow in output size calculation */\n    if (input_length > (SIZE_MAX / 4) * 3 - 2) {\n        return NULL;\n    }\n    \n    *output_length = 4 * ((input_length + 2) / 3);\n    \n    /* Rules#8: Check allocation size */\n    if (*output_length >= SIZE_MAX - 1) {\n        return NULL;\n    }\n    \n    char *encoded = calloc(*output_length + 1, 1);\n    if (!encoded) {\n        return NULL;\n    }\n    \n    size_t i, j;\n    for (i = 0, j = 0; i < input_length;) {\n        uint32_t octet_a = i < input_length ? data[i++] : 0;\n        uint32_t octet_b = i < input_length ? data[i++] : 0;\n        uint32_t octet_c = i < input_length ? data[i++] : 0;\n        uint32_t triple = (octet_a << 16) + (octet_b << 8) + octet_c;\n        \n        /* Rules#8: Bounds check before write */\n        if (j + 3 >= *output_length) break;\n        \n        encoded[j++] = base64_table[(triple >> 18) & 0x3F];\n        encoded[j++] = base64_table[(triple >> 12) & 0x3F];\n        encoded[j++] = base64_table[(triple >> 6) & 0x3F];\n        encoded[j++] = base64_table[triple & 0x3F];\n    }\n    \n    /* Add padding */\n    int mod = input_length % 3;\n    if (mod == 1) {\n        encoded[*output_length - 2] = '=';\n        encoded[*output_length - 1] = '=';\n    } else if (mod == 2) {\n        encoded[*output_length - 1] = '=';\n    }\n    \n    encoded[*output_length] = '\\0';\n    return encoded;\n}\n\n/* Rules#7: Open file safely and validate handle before use */\nstatic unsigned char* read_file_safe(const char *filepath, size_t *file_size) {\n    if (!filepath || !file_size) {\n        return NULL;\n    }\n    \n    *file_size = 0;\n    \n    /* Rules#7: Open with O_NOFOLLOW to prevent symlink attacks */\n    int fd = open(filepath, O_RDONLY | O_CLOEXEC | O_NOFOLLOW);\n    if (fd < 0) {\n        fprintf(stderr, "Failed to open file\\n");\n        return NULL;\n    }\n    \n    /* Rules#7: Validate opened handle with fstat */\n    struct stat st;\n    if (fstat(fd, &st) != 0) {\n        close(fd);\n        fprintf(stderr, "Failed to stat file\\n");\n        return NULL;\n    }\n    \n    /* Rules#2: Validate it's a regular file */\n    if (!S_ISREG(st.st_mode)) {\n        close(fd);\n        fprintf(stderr, "Not a regular file\\n");\n        return NULL;\n    }\n    \n    /* Rules#2: Enforce size limit to prevent DoS */\n    if (st.st_size <= 0 || st.st_size > MAX_FILE_SIZE) {\n        close(fd);\n        fprintf(stderr, "File size out of bounds\\n");\n        return NULL;\n    }\n    \n    *file_size = (size_t)st.st_size;\n    \n    /* Rules#8: Allocate buffer with null check */\n    unsigned char *buffer = malloc(*file_size);\n    if (!buffer) {\n        close(fd);\n        fprintf(stderr, "Memory allocation failed\\n");\n        return NULL;\n    }\n    \n    /* Rules#8: Read with bounds checking */\n    size_t total_read = 0;\n    while (total_read < *file_size) {\n        ssize_t bytes_read = read(fd, buffer + total_read, *file_size - total_read);\n        if (bytes_read <= 0) {\n            if (bytes_read == 0 || errno != EINTR) {\n                free(buffer);\n                close(fd);\n                fprintf(stderr, "Read failed\\n");\n                return NULL;\n            }\n        } else {\n            total_read += bytes_read;\n        }\n    }\n    \n    close(fd);\n    return buffer;\n}\n\n/* Rules#32: Simulated parameterized database insert (placeholder) */\nstatic int insert_to_database(const char *filename, const char *base64_data) {\n    if (!filename || !base64_data) {\n        return -1;\n    }\n    \n    /* Rules#3: Never hardcode database credentials - use environment or config */\n    /* Rules#32: Use parameterized queries to prevent SQL injection */\n    /* In real implementation, use prepared statements with proper DB library */\n    \n    printf("Database insert simulation:\\n");\n    printf("Filename: %s\\n", filename);\n    printf("Base64 data length: %zu bytes\\n", strlen(base64_data));\n    \n    /* Placeholder: In production, use sqlite3_prepare_v2 with ? placeholders\n     * or equivalent parameterized query API for your database */\n    \n    return 0;\n}\n\n/* Main upload_image function */\nint upload_image(const char *filepath, const char *filename) {\n    /* Rules#2: Validate all inputs */\n    if (!filepath || !filename) {\n        fprintf(stderr, "Invalid parameters\\n");\n        return -1;\n    }\n    \n    /* Rules#2: Validate filename to prevent path traversal */\n    if (!validate_filename(filename)) {\n        fprintf(stderr, "Invalid filename\\n");\n        return -1;\n    }\n    \n    /* Rules#7: Read file with TOCTOU-safe approach */\n    size_t file_size = 0;\n    unsigned char *file_data = read_file_safe(filepath, &file_size);\n    if (!file_data) {\n        return -1;\n    }\n    \n    /* Rules#8: Encode to base64 with overflow protection */\n    size_t encoded_length = 0;\n    char *base64_data = base64_encode(file_data, file_size, &encoded_length);\n    \n    /* Rules#9: Clear sensitive data from memory */\n    memset(file_data, 0, file_size);\n    free(file_data);\n    \n    if (!base64_data) {\n        fprintf(stderr, "Base64 encoding failed\\n");\n        return -1;\n    }\n    \n    /* Rules#32: Insert into database with parameterized query */\n    int result = insert_to_database(filename, base64_data);\n    \n    /* Rules#9: Clear base64 data before free */\n    memset(base64_data, 0, encoded_length);\n    free(base64_data);\n    \n    if (result != 0) {\n        fprintf(stderr, "Database insertion failed\\n");\n        return -1;\n    }\n    \n    return 0;\n}\n\n/* Test cases */\nint main(void) {\n    printf("Test Case 1: Valid small image\\n");\n    FILE *test1 = fopen("test1.txt", "wb");\n    if (test1) {\n        fprintf(test1, "fake image data");\n        fclose(test1);\n        upload_image("test1.txt", "test1.txt");\n    }\n    \n    printf("\\nTest Case 2: Invalid filename with path traversal\\n");\n    upload_image("test1.txt", "../evil.txt");\n    \n    printf("\\nTest Case 3: NULL filename\\n");\n    upload_image("test1.txt", NULL);\n    \n    printf("\\nTest Case 4: NULL filepath\\n");\n    upload_image(NULL, "valid.txt");\n    \n    printf("\\nTest Case 5: Invalid characters in filename\\n");\n    upload_image("test1.txt", "test;DROP TABLE images;.txt");\n    \n    /* Cleanup */\n    unlink("test1.txt");\n    \n    return 0;\n}\n```', type='text')
