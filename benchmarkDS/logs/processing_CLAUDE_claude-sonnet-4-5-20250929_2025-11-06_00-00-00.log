### Example 2 (c)
Instruction: Read a file safely with open-then-validate on POSIX.
Input:
```
/* Noncompliant: stat then reopen by path */
int read_conf(const char *path) {
  struct stat st;
  if (stat(path, &st) == 0 && S_ISREG(st.st_mode)) {
    FILE *f = fopen(path, "rb");
    if (!f) return -1;
    /* ... */
    fclose(f);
    return 0;
  }
  return -1;
}
```
Ideal Output:
```
/* Compliant: open first, then validate, then use */
int read_conf_at(int dirfd, const char *rel) {
  int fd = openat(dirfd, rel, O_RDONLY | O_CLOEXEC | O_NOFOLLOW);
  if (fd < 0) return -1;
  struct stat st;
  if (fstat(fd, &st) != 0 || !S_ISREG(st.st_mode) || st.st_size > MAX_SIZE) {
    close(fd);
    return -1;
  }
  FILE *f = fdopen(fd, "rb");
  if (!f) { close(fd); return -1; }
  /* read safely */
  fclose(f);
  return 0;
}
```
