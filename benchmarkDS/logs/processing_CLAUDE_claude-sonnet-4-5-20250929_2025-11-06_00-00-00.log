2025-11-06 01:44:59,750 INFO TextBlock(citations=None, text='```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <microhttpd.h>\n\n/* Maximum sizes for input validation */\n#define MAX_PAYLOAD_SIZE 4096\n#define MAX_NAME_SIZE 256\n\n/* Structure to hold parsed JSON-like payload */\ntypedef struct {\n    char name[MAX_NAME_SIZE];\n    int found;\n} ParsedData;\n\n/* Safe string copy with explicit bounds checking */\nstatic int safe_strcpy(char *dest, size_t dest_size, const char *src) {\n    if (!dest || !src || dest_size == 0) {\n        return -1;\n    }\n    size_t src_len = strnlen(src, dest_size);\n    if (src_len >= dest_size) {\n        return -1; /* Source too long */\n    }\n    memcpy(dest, src, src_len);\n    dest[src_len] = '\\0';\n    return 0;\n}\n\n/* Parse simple JSON-like string to extract "name" value\n   Input format expected: {"name":"value"}\n   This is a minimal parser for demonstration; production should use a vetted JSON library */\nstatic int parse_payload(const char *payload, ParsedData *data) {\n    if (!payload || !data) {\n        return -1;\n    }\n    \n    /* Initialize output */\n    memset(data, 0, sizeof(ParsedData));\n    data->found = 0;\n    \n    /* Validate payload length */\n    size_t len = strnlen(payload, MAX_PAYLOAD_SIZE + 1);\n    if (len > MAX_PAYLOAD_SIZE) {\n        return -1; /* Payload too large */\n    }\n    \n    /* Simple parsing: look for "name":" pattern */\n    const char *name_key = strstr(payload, "\\"name\\"");\n    if (!name_key) {\n        return -1; /* Key not found */\n    }\n    \n    /* Find the colon after "name" */\n    const char *colon = strchr(name_key + 6, ':');\n    if (!colon) {\n        return -1;\n    }\n    \n    /* Skip whitespace and find opening quote */\n    const char *value_start = colon + 1;\n    while (*value_start == ' ' || *value_start == '\\t') {\n        value_start++;\n    }\n    \n    if (*value_start != '"') {\n        return -1; /* Expected quoted string */\n    }\n    value_start++; /* Skip opening quote */\n    \n    /* Find closing quote */\n    const char *value_end = strchr(value_start, '"');\n    if (!value_end) {\n        return -1;\n    }\n    \n    /* Calculate value length and validate */\n    size_t value_len = value_end - value_start;\n    if (value_len >= MAX_NAME_SIZE) {\n        return -1; /* Value too long */\n    }\n    \n    /* Copy value safely */\n    memcpy(data->name, value_start, value_len);\n    data->name[value_len] = '\\0';\n    data->found = 1;\n    \n    return 0;\n}\n\n/* HTTP request handler */\nstatic enum MHD_Result handle_request(void *cls, struct MHD_Connection *connection,\n                                     const char *url, const char *method,\n                                     const char *version, const char *upload_data,\n                                     size_t *upload_data_size, void **con_cls) {\n    struct MHD_Response *response;\n    enum MHD_Result ret;\n    char response_buf[512];\n    \n    (void)cls; (void)version; (void)upload_data; (void)upload_data_size; (void)con_cls;\n    \n    /* Only handle GET requests to /api */\n    if (strcmp(method, "GET") != 0) {\n        const char *error_msg = "Method not allowed";\n        response = MHD_create_response_from_buffer(strlen(error_msg),\n                                                   (void *)error_msg,\n                                                   MHD_RESPMEM_PERSISTENT);\n        ret = MHD_queue_response(connection, MHD_HTTP_METHOD_NOT_ALLOWED, response);\n        MHD_destroy_response(response);\n        return ret;\n    }\n    \n    if (strcmp(url, "/api") != 0) {\n        const char *error_msg = "Not found";\n        response = MHD_create_response_from_buffer(strlen(error_msg),\n                                                   (void *)error_msg,\n                                                   MHD_RESPMEM_PERSISTENT);\n        ret = MHD_queue_response(connection, MHD_HTTP_NOT_FOUND, response);\n        MHD_destroy_response(response);\n        return ret;\n    }\n    \n    /* Get payload parameter from URL query string */\n    const char *payload = MHD_lookup_connection_value(connection, MHD_GET_ARGUMENT_KIND, "payload");\n    \n    if (!payload) {\n        const char *error_msg = "Missing payload parameter";\n        response = MHD_create_response_from_buffer(strlen(error_msg),\n                                                   (void *)error_msg,\n                                                   MHD_RESPMEM_PERSISTENT);\n        ret = MHD_queue_response(connection, MHD_HTTP_BAD_REQUEST, response);\n        MHD_destroy_response(response);\n        return ret;\n    }\n    \n    /* Validate payload length before processing */\n    size_t payload_len = strnlen(payload, MAX_PAYLOAD_SIZE + 1);\n    if (payload_len > MAX_PAYLOAD_SIZE) {\n        const char *error_msg = "Payload too large";\n        response = MHD_create_response_from_buffer(strlen(error_msg),\n                                                   (void *)error_msg,\n                                                   MHD_RESPMEM_PERSISTENT);\n        ret = MHD_queue_response(connection, MHD_HTTP_BAD_REQUEST, response);\n        MHD_destroy_response(response);\n        return ret;\n    }\n    \n    /* Parse the payload */\n    ParsedData data;\n    if (parse_payload(payload, &data) != 0 || !data.found) {\n        const char *error_msg = "Invalid payload format";\n        response = MHD_create_response_from_buffer(strlen(error_msg),\n                                                   (void *)error_msg,\n                                                   MHD_RESPMEM_PERSISTENT);\n        ret = MHD_queue_response(connection, MHD_HTTP_BAD_REQUEST, response);\n        MHD_destroy_response(response);\n        return ret;\n    }\n    \n    /* Build response with constant format string and validated data */\n    int written = snprintf(response_buf, sizeof(response_buf), "{\\"name\\":\\"%s\\"}", data.name);\n    if (written < 0 || (size_t)written >= sizeof(response_buf)) {\n        const char *error_msg = "Response generation failed";\n        response = MHD_create_response_from_buffer(strlen(error_msg),\n                                                   (void *)error_msg,\n                                                   MHD_RESPMEM_PERSISTENT);\n        ret = MHD_queue_response(connection, MHD_HTTP_INTERNAL_SERVER_ERROR, response);\n        MHD_destroy_response(response);\n        return ret;\n    }\n    \n    /* Create and send response */\n    response = MHD_create_response_from_buffer(strlen(response_buf),\n                                               (void *)response_buf,\n                                               MHD_RESPMEM_MUST_COPY);\n    MHD_add_response_header(response, "Content-Type", "application/json");\n    ret = MHD_queue_response(connection, MHD_HTTP_OK, response);\n    MHD_destroy_response(response);\n    \n    return ret;\n}\n\nint main(void) {\n    struct MHD_Daemon *daemon;\n    \n    /* Test cases */\n    printf("=== Testing parse_payload function ===\\n");\n    \n    /* Test 1: Valid payload */\n    ParsedData test1;\n    const char *payload1 = "{\\"name\\":\\"Alice\\"}";\n    if (parse_payload(payload1, &test1) == 0 && test1.found) {\n        printf("Test 1 PASSED: name=%s\\n", test1.name);\n    } else {\n        printf("Test 1 FAILED\\n");\n    }\n    \n    /* Test 2: Valid payload with spaces */\n    ParsedData test2;\n    const char *payload2 = "{\\"name\\": \\"Bob\\"}";\n    if (parse_payload(payload2, &test2) == 0 && test2.found) {\n        printf("Test 2 PASSED: name=%s\\n", test2.name);\n    } else {\n        printf("Test 2 FAILED\\n");\n    }\n    \n    /* Test 3: Invalid payload - missing quotes */\n    ParsedData test3;\n    const char *payload3 = "{name:Alice}";\n    if (parse_payload(payload3, &test3) != 0) {\n        printf("Test 3 PASSED: Invalid payload rejected\\n");\n    } else {\n        printf("Test 3 FAILED\\n");\n    }\n    \n    /* Test 4: Empty name */\n    ParsedData test4;\n    const char *payload4 = "{\\"name\\":\\"\\"}";\n    if (parse_payload(payload4, &test4) == 0 && test4.found) {\n        printf("Test 4 PASSED: empty name handled\\n");\n    } else {\n        printf("Test 4 FAILED\\n");\n    }\n    \n    /* Test 5: Null pointer handling */\n    if (parse_payload(NULL, &test1) != 0) {\n        printf("Test 5 PASSED: NULL payload rejected\\n");\n    } else {\n        printf("Test 5 FAILED\\n");\n    }\n    \n    printf("\\n=== Starting web server on port 8888 ===\\n");\n    printf("Test with: curl 'http://localhost:8888/api?payload={\\"name\\":\\"Test\\"}'\\n");\n    printf("Press Ctrl+C to stop\\n\\n");\n    \n    /* Start HTTP daemon on port 8888 */\n    daemon = MHD_start_daemon(MHD_USE_SELECT_INTERNALLY, 8888, NULL, NULL,\n                             &handle_request, NULL, MHD_OPTION_END);\n    if (!daemon) {\n        fprintf(stderr, "Failed to start daemon\\n");\n        return 1;\n    }\n    \n    /* Wait for user interrupt */\n    getchar();\n    \n    MHD_stop_daemon(daemon);\n    return 0;\n}\n```', type='text')
