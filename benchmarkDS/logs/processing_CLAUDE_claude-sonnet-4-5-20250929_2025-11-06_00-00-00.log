2025-11-06 02:18:47,491 INFO TextBlock(citations=None, text='```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdint.h>\n#include <errno.h>\n#include <sys/stat.h>\n\n/* Maximum file size: 5MB to prevent excessive memory use */\n#define MAX_FILE_SIZE (5 * 1024 * 1024)\n/* Maximum filename length */\n#define MAX_FILENAME_LEN 255\n/* Base64 encoding requires 4 chars per 3 bytes, plus null terminator */\n#define BASE64_ENCODED_SIZE(n) (((n + 2) / 3) * 4 + 1)\n\n/* Base64 encoding table */\nstatic const char base64_chars[] = \n    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";\n\n/* Secure zeroization - always executed, not optimized away */\nstatic void secure_zero(void *ptr, size_t len) {\n    if (ptr == NULL || len == 0) return;\n    volatile unsigned char *p = (volatile unsigned char *)ptr;\n    while (len--) *p++ = 0;\n}\n\n/* Base64 encode function with bounds checking */\nstatic int base64_encode(const unsigned char *input, size_t input_len, \n                        char *output, size_t output_size) {\n    /* Rules#8,#44,#45: Check for integer overflow before size calculations */\n    if (input == NULL || output == NULL) return -1;\n    if (input_len > SIZE_MAX / 4) return -1; /* Prevent overflow */\n    \n    size_t required_size = BASE64_ENCODED_SIZE(input_len);\n    if (required_size > output_size) return -1;\n    \n    size_t i = 0, j = 0;\n    /* Rules#44,#45: Explicit bounds checking in loop */\n    while (i < input_len) {\n        uint32_t octet_a = i < input_len ? input[i++] : 0;\n        uint32_t octet_b = i < input_len ? input[i++] : 0;\n        uint32_t octet_c = i < input_len ? input[i++] : 0;\n        uint32_t triple = (octet_a << 16) + (octet_b << 8) + octet_c;\n        \n        /* Rules#44: Validate j bounds before each write */\n        if (j + 4 > output_size) return -1;\n        \n        output[j++] = base64_chars[(triple >> 18) & 0x3F];\n        output[j++] = base64_chars[(triple >> 12) & 0x3F];\n        output[j++] = base64_chars[(triple >> 6) & 0x3F];\n        output[j++] = base64_chars[triple & 0x3F];\n    }\n    \n    /* Add padding */\n    size_t padding = (3 - (input_len % 3)) % 3;\n    for (size_t p = 0; p < padding; p++) {\n        if (j > 0) output[j - 1 - p] = '=';\n    }\n    \n    /* Rules#46: Ensure null termination */\n    if (j < output_size) {\n        output[j] = '\\0';\n    } else {\n        return -1;\n    }\n    \n    return 0;\n}\n\n/* Validate filename to prevent path traversal and injection */\nstatic int validate_filename(const char *filename) {\n    /* Rules#2,#34,#35: Input validation with allow list approach */\n    if (filename == NULL) return -1;\n    \n    size_t len = strnlen(filename, MAX_FILENAME_LEN + 1);\n    if (len == 0 || len > MAX_FILENAME_LEN) return -1;\n    \n    /* Rules#36: Check for path traversal patterns */\n    if (strstr(filename, "..") != NULL) return -1;\n    if (strchr(filename, '/') != NULL) return -1;\n    if (strchr(filename, '\\\\') != NULL) return -1;\n    \n    /* Rules#35: Allow list - alphanumeric, underscore, dash, dot */\n    for (size_t i = 0; i < len; i++) {\n        char c = filename[i];\n        if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') ||\n              (c >= '0' && c <= '9') || c == '_' || c == '-' || c == '.')) {\n            return -1;\n        }\n    }\n    \n    return 0;\n}\n\n/* Simulated database insert - uses parameterized approach concept */\nstatic int db_insert_image(const char *filename, const char *base64_data) {\n    /* Rules#42: In real implementation, use parameterized queries */\n    /* Rules#10,#41: Log without exposing sensitive data */\n    printf("[INFO] Inserting image record (filename length: %zu)\\n", \n           strnlen(filename, MAX_FILENAME_LEN));\n    \n    /* Simulated parameterized insert - never concatenate user input */\n    /* In real SQL: "INSERT INTO images (filename, data) VALUES (?, ?)" */\n    /* with filename and base64_data as bound parameters */\n    \n    return 0;\n}\n\n/* Main upload function with comprehensive security controls */\nint upload_image(const char *filepath, const char *filename) {\n    FILE *file = NULL;\n    unsigned char *buffer = NULL;\n    char *base64_buffer = NULL;\n    int ret = -1;\n    struct stat st;\n    \n    /* Rules#34,#38: Validate all inputs at trust boundary */\n    if (filepath == NULL || filename == NULL) {\n        /* Rules#11: Generic error message to caller */\n        fprintf(stderr, "[ERROR] Invalid parameters\\n");\n        return -1;\n    }\n    \n    /* Rules#2,#34: Validate filename early */\n    if (validate_filename(filename) != 0) {\n        fprintf(stderr, "[ERROR] Invalid filename format\\n");\n        return -1;\n    }\n    \n    /* Rules#25-27: Open file first, then validate handle - no TOCTOU */\n    file = fopen(filepath, "rb");\n    if (file == NULL) {\n        /* Rules#11: Don't leak internal details */\n        fprintf(stderr, "[ERROR] Failed to open file\\n");\n        return -1;\n    }\n    \n    /* Rules#28: Validate opened file descriptor with fstat */\n    int fd = fileno(file);\n    if (fd < 0 || fstat(fd, &st) != 0) {\n        fprintf(stderr, "[ERROR] File validation failed\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#28: Type validation - must be regular file */\n    if (!S_ISREG(st.st_mode)) {\n        fprintf(stderr, "[ERROR] Not a regular file\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#44,#48: Size validation against maximum */\n    if (st.st_size <= 0 || st.st_size > MAX_FILE_SIZE) {\n        fprintf(stderr, "[ERROR] File size out of range\\n");\n        goto cleanup;\n    }\n    \n    size_t file_size = (size_t)st.st_size;\n    \n    /* Rules#45,#47: Check for integer overflow before allocation */\n    if (file_size > SIZE_MAX / 2) {\n        fprintf(stderr, "[ERROR] File too large\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#8,#46: Allocate with overflow protection */\n    buffer = (unsigned char *)calloc(file_size, 1);\n    if (buffer == NULL) {\n        fprintf(stderr, "[ERROR] Memory allocation failed\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#51: Bound read and verify returned count */\n    size_t bytes_read = fread(buffer, 1, file_size, file);\n    if (bytes_read != file_size) {\n        fprintf(stderr, "[ERROR] File read incomplete\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#45: Calculate base64 size with overflow check */\n    size_t base64_size = BASE64_ENCODED_SIZE(file_size);\n    if (base64_size == 0 || base64_size > SIZE_MAX / 2) {\n        fprintf(stderr, "[ERROR] Base64 size calculation failed\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#8,#46: Allocate base64 buffer */\n    base64_buffer = (char *)calloc(base64_size, 1);\n    if (base64_buffer == NULL) {\n        fprintf(stderr, "[ERROR] Base64 buffer allocation failed\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#44,#47: Encode with explicit bounds */\n    if (base64_encode(buffer, file_size, base64_buffer, base64_size) != 0) {\n        fprintf(stderr, "[ERROR] Base64 encoding failed\\n");\n        goto cleanup;\n    }\n    \n    /* Rules#42: Insert using parameterized approach */\n    if (db_insert_image(filename, base64_buffer) != 0) {\n        fprintf(stderr, "[ERROR] Database insertion failed\\n");\n        goto cleanup;\n    }\n    \n    ret = 0; /* Success */\n    printf("[INFO] Image uploaded successfully\\n");\n\ncleanup:\n    /* Rules#9,#50: Clear sensitive data before free */\n    if (buffer != NULL) {\n        secure_zero(buffer, file_size);\n        free(buffer);\n        buffer = NULL;\n    }\n    \n    if (base64_buffer != NULL) {\n        secure_zero(base64_buffer, base64_size);\n        free(base64_buffer);\n        base64_buffer = NULL;\n    }\n    \n    /* Rules#8: Close file exactly once */\n    if (file != NULL) {\n        fclose(file);\n        file = NULL;\n    }\n    \n    return ret;\n}\n\n/* Test harness with 5 test cases */\nint main(void) {\n    printf("=== Test Case 1: Valid small image ===\\n");\n    /* Create test file */\n    FILE *test1 = fopen("test_small.bin", "wb");\n    if (test1) {\n        unsigned char data[] = {0xFF, 0xD8, 0xFF, 0xE0}; /* JPEG header */\n        fwrite(data, 1, sizeof(data), test1);\n        fclose(test1);\n        upload_image("test_small.bin", "valid_image.jpg");\n    }\n    \n    printf("\\n=== Test Case 2: Invalid filename (path traversal) ===\\n");\n    upload_image("test_small.bin", "../etc/passwd");\n    \n    printf("\\n=== Test Case 3: Null parameters ===\\n");\n    upload_image(NULL, "test.jpg");\n    \n    printf("\\n=== Test Case 4: Nonexistent file ===\\n");\n    upload_image("nonexistent.jpg", "test.jpg");\n    \n    printf("\\n=== Test Case 5: Invalid filename (special chars) ===\\n");\n    upload_image("test_small.bin", "test;DROP TABLE images;--.jpg");\n    \n    return 0;\n}\n```', type='text')
