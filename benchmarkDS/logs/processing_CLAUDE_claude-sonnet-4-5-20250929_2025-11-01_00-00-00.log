2025-11-01 03:31:30,339 INFO TextBlock(citations=None, text='```java\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.SQLException;\nimport java.util.Properties;\nimport java.io.InputStream;\nimport java.io.IOException;\n\n/**\n * Lse141: Secure database configuration management\n * Demonstrates proper secret handling and configuration management\n */\npublic class Lse141 {\n    private static Properties config = new Properties();\n    \n    static {\n        // Load configuration from external properties file\n        // Secrets must never be hard-coded (Rule #3)\n        try (InputStream input = Lse141.class.getClassLoader()\n                .getResourceAsStream("db.properties")) {\n            if (input == null) {\n                throw new IOException("Unable to find db.properties");\n            }\n            config.load(input);\n        } catch (IOException ex) {\n            // Fail closed with minimal error message (Rule #1)\n            System.err.println("Configuration error");\n            System.exit(1);\n        }\n    }\n    \n    /**\n     * Returns database connection with secure settings\n     * @return Connection object with SSL/TLS enforced\n     */\n    public static Connection getDatabaseConnection() throws SQLException {\n        // Input validation: verify all required properties exist (Rule #2)\n        String server = getServerName();\n        String database = getDatabaseName();\n        String user = getDatabaseUser();\n        String password = getDatabasePassword();\n        \n        if (server == null || database == null || user == null || password == null) {\n            throw new SQLException("Missing required configuration");\n        }\n        \n        // Enforce TLS for database connection (Rule #6)\n        String url = String.format(\n            "jdbc:mysql://%s/%s?useSSL=true&requireSSL=true&verifyServerCertificate=true",\n            server, database\n        );\n        \n        Properties props = new Properties();\n        props.setProperty("user", user);\n        props.setProperty("password", password);\n        \n        return DriverManager.getConnection(url, props);\n    }\n    \n    /**\n     * Returns server name from secure configuration\n     * @return Server name, validated for safety\n     */\n    public static String getServerName() {\n        String server = config.getProperty("db.server");\n        // Validate server format to prevent injection (Rule #2)\n        if (server != null && server.matches("^[a-zA-Z0-9.-]+$")) {\n            return server;\n        }\n        return null;\n    }\n    \n    /**\n     * Returns database name from secure configuration\n     * @return Database name, validated for safety\n     */\n    public static String getDatabaseName() {\n        String dbName = config.getProperty("db.name");\n        // Validate database name format (Rule #2)\n        if (dbName != null && dbName.matches("^[a-zA-Z0-9_]+$")) {\n            return dbName;\n        }\n        return null;\n    }\n    \n    /**\n     * Returns database user from secure configuration\n     * @return Database user, validated for safety\n     */\n    public static String getDatabaseUser() {\n        String user = config.getProperty("db.user");\n        // Validate username format (Rule #2)\n        if (user != null && user.matches("^[a-zA-Z0-9_]+$")) {\n            return user;\n        }\n        return null;\n    }\n    \n    /**\n     * Returns database password from secure configuration\n     * Never logs or exposes password (Rule #10)\n     * @return Database password from external config\n     */\n    public static String getDatabasePassword() {\n        // Read from secure external source only (Rule #3)\n        return config.getProperty("db.password");\n    }\n    \n    /**\n     * Main method with test cases\n     * Note: In production, db.properties should be externalized\n     */\n    public static void main(String[] args) {\n        System.out.println("Test Case 1: Get Server Name");\n        String server = getServerName();\n        System.out.println("Server: " + (server != null ? server : "Not configured"));\n        \n        System.out.println("\\nTest Case 2: Get Database Name");\n        String dbName = getDatabaseName();\n        System.out.println("Database: " + (dbName != null ? dbName : "Not configured"));\n        \n        System.out.println("\\nTest Case 3: Get Database User");\n        String user = getDatabaseUser();\n        System.out.println("User: " + (user != null ? user : "Not configured"));\n        \n        System.out.println("\\nTest Case 4: Get Database Password Status");\n        String password = getDatabasePassword();\n        // Never log actual password (Rule #10)\n        System.out.println("Password configured: " + (password != null && !password.isEmpty()));\n        \n        System.out.println("\\nTest Case 5: Database Connection Test");\n        try {\n            Connection conn = getDatabaseConnection();\n            System.out.println("Connection successful: " + !conn.isClosed());\n            conn.close();\n        } catch (SQLException e) {\n            // Generic error message to caller (Rule #11)\n            System.out.println("Connection failed: Configuration error");\n        }\n    }\n}\n```\n\n```python\nimport os\nimport sys\nfrom typing import Optional\nimport mysql.connector\nfrom mysql.connector import Error\nimport ssl\n\n# Secrets loaded from environment variables only (Rule #3)\n# Never hard-code credentials\n\ndef get_database_connection():\n    """\n    Returns secure database connection with TLS enforcement\n    \n    Returns:\n        Connection object or None on failure\n    """\n    try:\n        server = get_server_name()\n        database = get_database_name()\n        user = get_database_user()\n        password = get_database_password()\n        \n        # Input validation: ensure all required fields present (Rule #2)\n        if not all([server, database, user, password]):\n            print("Configuration error", file=sys.stderr)\n            return None\n        \n        # Enforce TLS 1.2+ for database connection (Rule #6)\n        ssl_context = ssl.create_default_context()\n        ssl_context.minimum_version = ssl.TLSVersion.TLSv1_2\n        \n        # Connect with secure settings\n        connection = mysql.connector.connect(\n            host=server,\n            database=database,\n            user=user,\n            password=password,\n            ssl_disabled=False,\n            tls_versions=['TLSv1.2', 'TLSv1.3']\n        )\n        \n        return connection\n        \n    except Error as e:\n        # Generic error to caller, no internal details (Rule #11)\n        print("Connection error", file=sys.stderr)\n        return None\n\ndef get_server_name() -> Optional[str]:\n    """\n    Returns database server name from environment variable\n    \n    Returns:\n        Validated server name or None\n    """\n    server = os.getenv('DB_SERVER')\n    \n    # Input validation: check format to prevent injection (Rule #2)\n    if server and all(c.isalnum() or c in '.-' for c in server):\n        return server\n    return None\n\ndef get_database_name() -> Optional[str]:\n    """\n    Returns database name from environment variable\n    \n    Returns:\n        Validated database name or None\n    """\n    db_name = os.getenv('DB_NAME')\n    \n    # Input validation: alphanumeric and underscore only (Rule #2)\n    if db_name and all(c.isalnum() or c == '_' for c in db_name):\n        return db_name\n    return None\n\ndef get_database_user() -> Optional[str]:\n    """\n    Returns database user from environment variable\n    \n    Returns:\n        Validated username or None\n    """\n    user = os.getenv('DB_USER')\n    \n    # Input validation: alphanumeric and underscore only (Rule #2)\n    if user and all(c.isalnum() or c == '_' for c in user):\n        return user\n    return None\n\ndef get_database_password() -> Optional[str]:\n    """\n    Returns database password from environment variable\n    Never logs or exposes password (Rule #10)\n    \n    Returns:\n        Password string or None\n    """\n    # Read from environment only, never hard-code (Rule #3)\n    return os.getenv('DB_PASSWORD')\n\ndef main():\n    """Main function with test cases"""\n    \n    print("Test Case 1: Get Server Name")\n    server = get_server_name()\n    print(f"Server: {server if server else 'Not configured'}")\n    \n    print("\\nTest Case 2: Get Database Name")\n    db_name = get_database_name()\n    print(f"Database: {db_name if db_name else 'Not configured'}")\n    \n    print("\\nTest Case 3: Get Database User")\n    user = get_database_user()\n    print(f"User: {user if user else 'Not configured'}")\n    \n    print("\\nTest Case 4: Get Database Password Status")\n    password = get_database_password()\n    # Never log actual password (Rule #10)\n    print(f"Password configured: {bool(password)}")\n    \n    print("\\nTest Case 5: Database Connection Test")\n    conn = get_database_connection()\n    if conn and conn.is_connected():\n        print("Connection successful")\n        conn.close()\n    else:\n        print("Connection failed: Configuration error")\n\nif __name__ == "__main__":\n    main()\n```\n\n```cpp\n#include <iostream>\n#include <string>\n#include <cstdlib>\n#include <mysql/mysql.h>\n#include <algorithm>\n#include <cctype>\n\n// Secure database configuration manager\n// All secrets loaded from environment variables (Rule #3)\n\n/**\n * Returns database connection with TLS enforcement\n * \n * @return MYSQL* connection pointer or nullptr on failure\n */\nMYSQL* get_database_connection() {\n    MYSQL* conn = mysql_init(nullptr);\n    if (conn == nullptr) {\n        std::cerr << "MySQL init failed" << std::endl;\n        return nullptr;\n    }\n    \n    // Get configuration from secure sources\n    std::string server = get_server_name();\n    std::string database = get_database_name();\n    std::string user = get_database_user();\n    std::string password = get_database_password();\n    \n    // Input validation: ensure all required fields present (Rule #2)\n    if (server.empty() || database.empty() || user.empty() || password.empty()) {\n        std::cerr << "Configuration error" << std::endl;\n        mysql_close(conn);\n        return nullptr;\n    }\n    \n    // Enforce SSL/TLS for connection (Rule #6)\n    mysql_ssl_mode ssl_mode = SSL_MODE_REQUIRED;\n    mysql_options(conn, MYSQL_OPT_SSL_MODE, &ssl_mode);\n    \n    // Attempt secure connection\n    if (mysql_real_connect(conn, server.c_str(), user.c_str(), \n                          password.c_str(), database.c_str(), \n                          3306, nullptr, 0) == nullptr) {\n        // Generic error message, no internal details (Rule #11)\n        std::cerr << "Connection error" << std::endl;\n        mysql_close(conn);\n        return nullptr;\n    }\n    \n    return conn;\n}\n\n/**\n * Returns validated server name from environment\n * \n * @return Server name string\n */\nstd::string get_server_name() {\n    const char* server = std::getenv("DB_SERVER");\n    if (server == nullptr) {\n        return "";\n    }\n    \n    std::string server_str(server);\n    \n    // Input validation: alphanumeric, dot, dash only (Rule #2)\n    auto is_valid = [](char c) {\n        return std::isalnum(c) || c == '.' || c == '-';\n    };\n    \n    if (std::all_of(server_str.begin(), server_str.end(), is_valid)) {\n        return server_str;\n    }\n    \n    return "";\n}\n\n/**\n * Returns validated database name from environment\n * \n * @return Database name string\n */\nstd::string get_database_name() {\n    const char* db_name = std::getenv("DB_NAME");\n    if (db_name == nullptr) {\n        return "";\n    }\n    \n    std::string db_str(db_name);\n    \n    // Input validation: alphanumeric and underscore only (Rule #2)\n    auto is_valid = [](char c) {\n        return std::isalnum(c) || c == '_';\n    };\n    \n    if (std::all_of(db_str.begin(), db_str.end(), is_valid)) {\n        return db_str;\n    }\n    \n    return "";\n}\n\n/**\n * Returns validated database user from environment\n * \n * @return Database user string\n */\nstd::string get_database_user() {\n    const char* user = std::getenv("DB_USER");\n    if (user == nullptr) {\n        return "";\n    }\n    \n    std::string user_str(user);\n    \n    // Input validation: alphanumeric and underscore only (Rule #2)\n    auto is_valid = [](char c) {\n        return std::isalnum(c) || c == '_';\n    };\n    \n    if (std::all_of(user_str.begin(), user_str.end(), is_valid)) {\n        return user_str;\n    }\n    \n    return "";\n}\n\n/**\n * Returns database password from environment\n * Never logs or exposes password (Rule #10)\n * \n * @return Password string\n */\nstd::string get_database_password() {\n    // Read from environment only, never hard-code (Rule #3)\n    const char* password = std::getenv("DB_PASSWORD");\n    return password ? std::string(password) : "";\n}\n\nint main() {\n    std::cout << "Test Case 1: Get Server Name" << std::endl;\n    std::string server = get_server_name();\n    std::cout << "Server: " << (server.empty() ? "Not configured" : server) << std::endl;\n    \n    std::cout << "\\nTest Case 2: Get Database Name" << std::endl;\n    std::string db_name = get_database_name();\n    std::cout << "Database: " << (db_name.empty() ? "Not configured" : db_name) << std::endl;\n    \n    std::cout << "\\nTest Case 3: Get Database User" << std::endl;\n    std::string user = get_database_user();\n    std::cout << "User: " << (user.empty() ? "Not configured" : user) << std::endl;\n    \n    std::cout << "\\nTest Case 4: Get Database Password Status" << std::endl;\n    std::string password = get_database_password();\n    // Never log actual password (Rule #10)\n    std::cout << "Password configured: " << (!password.empty() ? "true" : "false") << std::endl;\n    \n    std::cout << "\\nTest Case 5: Database Connection Test" << std::endl;\n    MYSQL* conn = get_database_connection();\n    if (conn != nullptr) {\n        std::cout << "Connection successful" << std::endl;\n        mysql_close(conn);\n    } else {\n        std::cout << "Connection failed: Configuration error" << std::endl;\n    }\n    \n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <ctype.h>\n#include <mysql/mysql.h>\n\n/* Maximum length for configuration strings */\n#define MAX_CONFIG_LEN 256\n\n/**\n * Validates string contains only safe characters\n * \n * @param str String to validate\n * @param allow_dot Allow dot character\n * @param allow_dash Allow dash character\n * @return 1 if valid, 0 otherwise\n */\nstatic int validate_string(const char* str, int allow_dot, int allow_dash) {\n    if (str == NULL) {\n        return 0;\n    }\n    \n    /* Input validation: check each character (Rule #2) */\n    for (size_t i = 0; i < strlen(str) && i < MAX_CONFIG_LEN; i++) {\n        char c = str[i];\n        if (!isalnum(c) && c != '_') {\n            if (allow_dot && c == '.') continue;\n            if (allow_dash && c == '-') continue;\n            return 0;\n        }\n    }\n    \n    return 1;\n}\n\n/**\n * Returns database connection with TLS enforcement\n * Caller must call mysql_close() on returned pointer\n * \n * @return MYSQL* connection pointer or NULL on failure\n */\nMYSQL* get_database_connection(void) {\n    MYSQL* conn = NULL;\n    const char* server = NULL;\n    const char* database = NULL;\n    const char* user = NULL;\n    const char* password = NULL;\n    \n    /* Initialize connection (Rule #8) */\n    conn = mysql_init(NULL);\n    if (conn == NULL) {\n        fprintf(stderr, "MySQL init failed\\n");\n        return NULL;\n    }\n    \n    /* Get configuration from environment */\n    server = getenv("DB_SERVER");\n    database = getenv("DB_NAME");\n    user = getenv("DB_USER");\n    password = getenv("DB_PASSWORD");\n    \n    /* Input validation: ensure all required fields present (Rule #2) */\n    if (server == NULL || database == NULL || user == NULL || password == NULL) {\n        fprintf(stderr, "Configuration error\\n");\n        mysql_close(conn);\n        return NULL;\n    }\n    \n    /* Validate configuration values */\n    if (!validate_string(server, 1, 1) || !validate_string(database, 0, 0) || \n        !validate_string(user, 0, 0)) {\n        fprintf(stderr, "Invalid configuration format\\n");\n        mysql_close(conn);\n        return NULL;\n    }\n    \n    /* Enforce SSL/TLS for connection (Rule #6) */\n    unsigned int ssl_mode = SSL_MODE_REQUIRED;\n    if (mysql_options(conn, MYSQL_OPT_SSL_MODE, &ssl_mode) != 0) {\n        fprintf(stderr, "SSL configuration failed\\n");\n        mysql_close(conn);\n        return NULL;\n    }\n    \n    /* Attempt secure connection */\n    if (mysql_real_connect(conn, server, user, password, database, \n                          3306, NULL, 0) == NULL) {\n        /* Generic error message, no internal details (Rule #11) */\n        fprintf(stderr, "Connection error\\n");\n        mysql_close(conn);\n        return NULL;\n    }\n    \n    return conn;\n}\n\n/**\n * Returns validated server name from environment\n * \n * @param buffer Buffer to store server name\n * @param bufsize Size of buffer\n * @return Pointer to buffer or NULL on error\n */\nconst char* get_server_name(char* buffer, size_t bufsize) {\n    const char* server = NULL;\n    \n    /* Initialize buffer (Rule #8) */\n    if (buffer == NULL || bufsize == 0) {\n        return NULL;\n    }\n    memset(buffer, 0, bufsize);\n    \n    /* Read from environment only (Rule #3) */\n    server = getenv("DB_SERVER");\n    if (server == NULL) {\n        return NULL;\n    }\n    \n    /* Bounds check before copy (Rule #8) */\n    size_t len = strlen(server);\n    if (len >= bufsize) {\n        return NULL;\n    }\n    \n    /* Validate and copy (Rule #2) */\n    if (validate_string(server, 1, 1)) {\n        strncpy(buffer, server, bufsize - 1);\n        buffer[bufsize - 1] = '\\0';\n        return buffer;\n    }\n    \n    return NULL;\n}\n\n/**\n * Returns validated database name from environment\n * \n * @param buffer Buffer to store database name\n * @param bufsize Size of buffer\n * @return Pointer to buffer or NULL on error\n */\nconst char* get_database_name(char* buffer, size_t bufsize) {\n    const char* db_name = NULL;\n    \n    /* Initialize buffer (Rule #8) */\n    if (buffer == NULL || bufsize == 0) {\n        return NULL;\n    }\n    memset(buffer, 0, bufsize);\n    \n    /* Read from environment only (Rule #3) */\n    db_name = getenv("DB_NAME");\n    if (db_name == NULL) {\n        return NULL;\n    }\n    \n    /* Bounds check before copy (Rule #8) */\n    size_t len = strlen(db_name);\n    if (len >= bufsize) {\n        return NULL;\n    }\n    \n    /* Validate and copy (Rule #2) */\n    if (validate_string(db_name, 0, 0)) {\n        strncpy(buffer, db_name, bufsize - 1);\n        buffer[bufsize - 1] = '\\0';\n        return buffer;\n    }\n    \n    return NULL;\n}\n\n/**\n * Returns validated database user from environment\n * \n * @param buffer Buffer to store user name\n * @param bufsize Size of buffer\n * @return Pointer to buffer or NULL on error\n */\nconst char* get_database_user(char* buffer, size_t bufsize) {\n    const char* user = NULL;\n    \n    /* Initialize buffer (Rule #8) */\n    if (buffer == NULL || bufsize == 0) {\n        return NULL;\n    }\n    memset(buffer, 0, bufsize);\n    \n    /* Read from environment only (Rule #3) */\n    user = getenv("DB_USER");\n    if (user == NULL) {\n        return NULL;\n    }\n    \n    /* Bounds check before copy (Rule #8) */\n    size_t len = strlen(user);\n    if (len >= bufsize) {\n        return NULL;\n    }\n    \n    /* Validate and copy (Rule #2) */\n    if (validate_string(user, 0, 0)) {\n        strncpy(buffer, user, bufsize - 1);\n        buffer[bufsize - 1] = '\\0';\n        return buffer;\n    }\n    \n    return NULL;\n}\n\n/**\n * Returns database password from environment\n * Never logs or exposes password (Rule #10)\n * \n * @param buffer Buffer to store password\n * @param bufsize Size of buffer\n * @return Pointer to buffer or NULL on error\n */\nconst char* get_database_password(char* buffer, size_t bufsize) {\n    const char* password = NULL;\n    \n    /* Initialize buffer (Rule #8) */\n    if (buffer == NULL || bufsize == 0) {\n        return NULL;\n    }\n    memset(buffer, 0, bufsize);\n    \n    /* Read from environment only, never hard-code (Rule #3) */\n    password = getenv("DB_PASSWORD");\n    if (password == NULL) {\n        return NULL;\n    }\n    \n    /* Bounds check before copy (Rule #8) */\n    size_t len = strlen(password);\n    if (len >= bufsize) {\n        return NULL;\n    }\n    \n    strncpy(buffer, password, bufsize - 1);\n    buffer[bufsize - 1] = '\\0';\n    return buffer;\n}\n\nint main(void) {\n    char buffer[MAX_CONFIG_LEN];\n    \n    printf("Test Case 1: Get Server Name\\n");\n    if (get_server_name(buffer, sizeof(buffer)) != NULL) {\n        printf("Server: %s\\n", buffer);\n    } else {\n        printf("Server: Not configured\\n");\n    }\n    \n    printf("\\nTest Case 2: Get Database Name\\n");\n    if (get_database_name(buffer, sizeof(buffer)) != NULL) {\n        printf("Database: %s\\n", buffer);\n    } else {\n        printf("Database: Not configured\\n");\n    }\n    \n    printf("\\nTest Case 3: Get Database User\\n");\n    if (get_database_user(buffer, sizeof(buffer)) != NULL) {\n        printf("User: %s\\n", buffer);\n    } else {\n        printf("User: Not configured\\n");\n    }\n    \n    printf("\\nTest Case 4: Get Database Password Status\\n");\n    /* Never log actual password (Rule #10) */\n    if (get_database_password(buffer, sizeof(buffer)) != NULL) {\n        printf("Password configured: true\\n");\n        /* Clear password from memory (Rule #9) */\n        memset(buffer, 0, sizeof(buffer));\n    } else {\n        printf("Password configured: false\\n");\n    }\n    \n    printf("\\nTest Case 5: Database Connection Test\\n");\n    MYSQL* conn = get_database_connection();\n    if (conn != NULL) {\n        printf("Connection successful\\n");\n        mysql_close(conn);\n    } else {\n        printf("Connection failed: Configuration error\\n");\n    }\n    \n    return 0;\n}\n```', type='text')
