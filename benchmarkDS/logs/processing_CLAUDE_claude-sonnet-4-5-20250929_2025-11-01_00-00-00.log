2025-11-01 03:30:16,723 INFO TextBlock(citations=None, text='```java\nimport java.sql.*;\nimport java.util.Properties;\nimport java.io.FileInputStream;\nimport java.io.IOException;\n\npublic class Lse140 {\n    \n    /**\n     * Checks if a username exists in the database.\n     * \n     * @param username The username to check (validated before use)\n     * @return true if username exists, false otherwise\n     * @throws SQLException if database error occurs\n     * @throws IOException if config file cannot be read\n     */\n    public static boolean checkUsernameExists(String username) throws SQLException, IOException {\n        // Rules#2: Input validation - check type, length, and reject null/empty\n        if (username == null || username.trim().isEmpty()) {\n            throw new IllegalArgumentException("Username cannot be null or empty");\n        }\n        \n        // Rules#2: Validate length to prevent excessive input\n        if (username.length() > 255) {\n            throw new IllegalArgumentException("Username exceeds maximum length");\n        }\n        \n        // Rules#2: Validate format - alphanumeric and basic safe characters only\n        if (!username.matches("^[a-zA-Z0-9_.-]+$")) {\n            throw new IllegalArgumentException("Username contains invalid characters");\n        }\n        \n        // Rules#3: Load database credentials from external configuration, not hard-coded\n        Properties config = new Properties();\n        try (FileInputStream fis = new FileInputStream("db.properties")) {\n            config.load(fis);\n        }\n        \n        String dbUrl = config.getProperty("db.url");\n        String dbUser = config.getProperty("db.user");\n        String dbPassword = config.getProperty("db.password");\n        \n        // Validate configuration was loaded\n        if (dbUrl == null || dbUser == null || dbPassword == null) {\n            throw new IllegalStateException("Database configuration incomplete");\n        }\n        \n        Connection conn = null;\n        PreparedStatement pstmt = null;\n        ResultSet rs = null;\n        \n        try {\n            // Rules#6: Ensure TLS connection if using SSL\n            Properties connProps = new Properties();\n            connProps.setProperty("user", dbUser);\n            connProps.setProperty("password", dbPassword);\n            connProps.setProperty("useSSL", "true");\n            connProps.setProperty("requireSSL", "true");\n            connProps.setProperty("verifyServerCertificate", "true");\n            \n            // Connect to database\n            conn = DriverManager.getConnection(dbUrl, connProps);\n            \n            // Rules#32: Use parameterized query to prevent SQL injection\n            // Never concatenate user input into SQL queries\n            String sql = "SELECT 1 FROM users WHERE username = ? LIMIT 1";\n            pstmt = conn.prepareStatement(sql);\n            \n            // Set parameter safely\n            pstmt.setString(1, username);\n            \n            // Execute query\n            rs = pstmt.executeQuery();\n            \n            // Return true if username exists, false otherwise\n            return rs.next();\n            \n        } finally {\n            // Rules#1: Fail closed - ensure resources are cleaned up\n            if (rs != null) {\n                try { rs.close(); } catch (SQLException e) { /* logged elsewhere */ }\n            }\n            if (pstmt != null) {\n                try { pstmt.close(); } catch (SQLException e) { /* logged elsewhere */ }\n            }\n            if (conn != null) {\n                try { conn.close(); } catch (SQLException e) { /* logged elsewhere */ }\n            }\n        }\n    }\n    \n    public static void main(String[] args) {\n        // Test cases\n        String[] testUsernames = {\n            "john_doe",\n            "alice123",\n            "bob.smith",\n            "user-name",\n            "test_user"\n        };\n        \n        for (String username : testUsernames) {\n            try {\n                boolean exists = checkUsernameExists(username);\n                // Rules#10: Do not log sensitive data\n                System.out.println("Username check completed: " + (exists ? "found" : "not found"));\n            } catch (SQLException e) {\n                // Rules#11: Return generic error message, log details securely\n                System.err.println("Database error occurred");\n                // In production: secure logging with full details\n            } catch (IOException e) {\n                System.err.println("Configuration error occurred");\n            } catch (IllegalArgumentException e) {\n                System.err.println("Invalid input: " + e.getMessage());\n            }\n        }\n    }\n}\n```\n\n```python\nimport re\nimport os\nimport pymysql\nfrom typing import Optional\n\ndef check_username_exists(username: str) -> bool:\n    """\n    Checks if a username exists in the database.\n    \n    Args:\n        username: The username to check (validated before use)\n        \n    Returns:\n        True if username exists, False otherwise\n        \n    Raises:\n        ValueError: If username validation fails\n        RuntimeError: If database configuration is invalid\n    """\n    # Rules#2: Input validation - check type, length, and reject null/empty\n    if not username or not isinstance(username, str):\n        raise ValueError("Username must be a non-empty string")\n    \n    username = username.strip()\n    if not username:\n        raise ValueError("Username cannot be empty")\n    \n    # Rules#2: Validate length to prevent excessive input\n    if len(username) > 255:\n        raise ValueError("Username exceeds maximum length")\n    \n    # Rules#2: Validate format - alphanumeric and basic safe characters only\n    if not re.match(r'^[a-zA-Z0-9_.-]+$', username):\n        raise ValueError("Username contains invalid characters")\n    \n    # Rules#3: Load database credentials from environment, not hard-coded\n    db_host = os.environ.get('DB_HOST')\n    db_user = os.environ.get('DB_USER')\n    db_password = os.environ.get('DB_PASSWORD')\n    db_name = os.environ.get('DB_NAME')\n    \n    # Validate configuration was loaded\n    if not all([db_host, db_user, db_password, db_name]):\n        raise RuntimeError("Database configuration incomplete")\n    \n    connection = None\n    cursor = None\n    \n    try:\n        # Rules#6: Use TLS for database connection\n        # PyMySQL supports SSL with ssl parameter\n        connection = pymysql.connect(\n            host=db_host,\n            user=db_user,\n            password=db_password,\n            database=db_name,\n            charset='utf8mb4',\n            cursorclass=pymysql.cursors.DictCursor,\n            ssl={'ssl': True},  # Enable SSL/TLS\n            connect_timeout=10  # Timeout for connection\n        )\n        \n        cursor = connection.cursor()\n        \n        # Rules#32: Use parameterized query to prevent SQL injection\n        # Never concatenate user input into SQL queries\n        sql = "SELECT 1 FROM users WHERE username = %s LIMIT 1"\n        \n        # Execute with parameter binding\n        cursor.execute(sql, (username,))\n        \n        # Fetch result\n        result = cursor.fetchone()\n        \n        # Return true if username exists, false otherwise\n        return result is not None\n        \n    finally:\n        # Rules#1: Fail closed - ensure resources are cleaned up\n        if cursor:\n            cursor.close()\n        if connection:\n            connection.close()\n\n\ndef main():\n    """Test cases for username existence check"""\n    # Set environment variables for testing (in production, set these externally)\n    os.environ.setdefault('DB_HOST', 'localhost')\n    os.environ.setdefault('DB_USER', 'dbuser')\n    os.environ.setdefault('DB_PASSWORD', 'secure_password')\n    os.environ.setdefault('DB_NAME', 'testdb')\n    \n    test_usernames = [\n        "john_doe",\n        "alice123",\n        "bob.smith",\n        "user-name",\n        "test_user"\n    ]\n    \n    for username in test_usernames:\n        try:\n            exists = check_username_exists(username)\n            # Rules#10: Do not log sensitive data\n            print(f"Username check completed: {'found' if exists else 'not found'}")\n        except ValueError as e:\n            print(f"Invalid input: {e}")\n        except RuntimeError as e:\n            # Rules#11: Return generic error message\n            print("Configuration error occurred")\n        except Exception as e:\n            # Rules#11: Return generic error message\n            print("Database error occurred")\n            # In production: secure logging with full details\n\n\nif __name__ == "__main__":\n    main()\n```\n\n```cpp\n#include <iostream>\n#include <string>\n#include <regex>\n#include <cstdlib>\n#include <mysql/mysql.h>\n#include <stdexcept>\n#include <cstring>\n\n// Rules#8: Initialize pointers to NULL\nstatic MYSQL* conn = NULL;\nstatic MYSQL_STMT* stmt = NULL;\nstatic MYSQL_RES* result = NULL;\n\n/**\n * Checks if a username exists in the database.\n * \n * @param username The username to check (validated before use)\n * @return true if username exists, false otherwise\n * @throws std::invalid_argument if validation fails\n * @throws std::runtime_error if database error occurs\n */\nbool checkUsernameExists(const std::string& username) {\n    // Rules#2: Input validation - check length and reject empty\n    if (username.empty()) {\n        throw std::invalid_argument("Username cannot be empty");\n    }\n    \n    // Rules#2: Validate length to prevent excessive input\n    if (username.length() > 255) {\n        throw std::invalid_argument("Username exceeds maximum length");\n    }\n    \n    // Rules#2: Validate format - alphanumeric and basic safe characters only\n    std::regex pattern("^[a-zA-Z0-9_.-]+$");\n    if (!std::regex_match(username, pattern)) {\n        throw std::invalid_argument("Username contains invalid characters");\n    }\n    \n    // Rules#3: Load database credentials from environment, not hard-coded\n    const char* db_host = std::getenv("DB_HOST");\n    const char* db_user = std::getenv("DB_USER");\n    const char* db_password = std::getenv("DB_PASSWORD");\n    const char* db_name = std::getenv("DB_NAME");\n    \n    // Validate configuration was loaded\n    if (!db_host || !db_user || !db_password || !db_name) {\n        throw std::runtime_error("Database configuration incomplete");\n    }\n    \n    bool username_exists = false;\n    \n    // Rules#8: Initialize connection handle\n    conn = mysql_init(NULL);\n    if (conn == NULL) {\n        throw std::runtime_error("MySQL initialization failed");\n    }\n    \n    // Rules#6: Enable SSL/TLS for MySQL connection\n    mysql_ssl_set(conn, NULL, NULL, NULL, NULL, NULL);\n    \n    // Connect to database\n    if (mysql_real_connect(conn, db_host, db_user, db_password, \n                          db_name, 0, NULL, CLIENT_SSL) == NULL) {\n        std::string error = mysql_error(conn);\n        mysql_close(conn);\n        conn = NULL;\n        throw std::runtime_error("Database connection failed");\n    }\n    \n    // Rules#32: Use prepared statement to prevent SQL injection\n    const char* query = "SELECT 1 FROM users WHERE username = ? LIMIT 1";\n    \n    stmt = mysql_stmt_init(conn);\n    if (stmt == NULL) {\n        mysql_close(conn);\n        conn = NULL;\n        throw std::runtime_error("Statement initialization failed");\n    }\n    \n    if (mysql_stmt_prepare(stmt, query, std::strlen(query)) != 0) {\n        mysql_stmt_close(stmt);\n        mysql_close(conn);\n        stmt = NULL;\n        conn = NULL;\n        throw std::runtime_error("Statement preparation failed");\n    }\n    \n    // Bind parameter\n    MYSQL_BIND bind[1];\n    std::memset(bind, 0, sizeof(bind));\n    \n    unsigned long username_length = username.length();\n    \n    bind[0].buffer_type = MYSQL_TYPE_STRING;\n    bind[0].buffer = (char*)username.c_str();\n    bind[0].buffer_length = username.length();\n    bind[0].length = &username_length;\n    bind[0].is_null = 0;\n    \n    if (mysql_stmt_bind_param(stmt, bind) != 0) {\n        mysql_stmt_close(stmt);\n        mysql_close(conn);\n        stmt = NULL;\n        conn = NULL;\n        throw std::runtime_error("Parameter binding failed");\n    }\n    \n    // Execute query\n    if (mysql_stmt_execute(stmt) != 0) {\n        mysql_stmt_close(stmt);\n        mysql_close(conn);\n        stmt = NULL;\n        conn = NULL;\n        throw std::runtime_error("Query execution failed");\n    }\n    \n    // Store result\n    if (mysql_stmt_store_result(stmt) != 0) {\n        mysql_stmt_close(stmt);\n        mysql_close(conn);\n        stmt = NULL;\n        conn = NULL;\n        throw std::runtime_error("Result storage failed");\n    }\n    \n    // Check if row exists\n    username_exists = (mysql_stmt_num_rows(stmt) > 0);\n    \n    // Rules#1: Clean up resources\n    mysql_stmt_close(stmt);\n    mysql_close(conn);\n    stmt = NULL;\n    conn = NULL;\n    \n    return username_exists;\n}\n\nint main() {\n    // Test cases\n    std::string test_usernames[] = {\n        "john_doe",\n        "alice123",\n        "bob.smith",\n        "user-name",\n        "test_user"\n    };\n    \n    for (const auto& username : test_usernames) {\n        try {\n            bool exists = checkUsernameExists(username);\n            // Rules#10: Do not log sensitive data\n            std::cout << "Username check completed: " \n                     << (exists ? "found" : "not found") << std::endl;\n        } catch (const std::invalid_argument& e) {\n            std::cerr << "Invalid input: " << e.what() << std::endl;\n        } catch (const std::runtime_error& e) {\n            // Rules#11: Return generic error message\n            std::cerr << "Database error occurred" << std::endl;\n        }\n    }\n    \n    return 0;\n}\n```\n\n```c\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdbool.h>\n#include <ctype.h>\n#include <mysql/mysql.h>\n\n/* Rules#8: Initialize pointers to NULL */\nstatic MYSQL* conn = NULL;\nstatic MYSQL_STMT* stmt = NULL;\n\n/**\n * Validates username format and length\n * \n * @param username The username to validate\n * @return true if valid, false otherwise\n */\nstatic bool validate_username(const char* username) {\n    size_t len;\n    size_t i;\n    \n    /* Rules#2: Input validation - check for NULL and empty */\n    if (username == NULL) {\n        return false;\n    }\n    \n    len = strnlen(username, 256);\n    \n    if (len == 0 || len > 255) {\n        return false;\n    }\n    \n    /* Rules#2: Validate format - alphanumeric and basic safe characters only */\n    for (i = 0; i < len; i++) {\n        if (!isalnum((unsigned char)username[i]) && \n            username[i] != '_' && \n            username[i] != '.' && \n            username[i] != '-') {\n            return false;\n        }\n    }\n    \n    return true;\n}\n\n/**\n * Checks if a username exists in the database.\n * \n * @param username The username to check (validated before use)\n * @return true if username exists, false otherwise, -1 on error\n */\nint check_username_exists(const char* username) {\n    const char* db_host;\n    const char* db_user;\n    const char* db_password;\n    const char* db_name;\n    const char* query = "SELECT 1 FROM users WHERE username = ? LIMIT 1";\n    MYSQL_BIND bind[1];\n    unsigned long username_length;\n    int result_value = -1;\n    \n    /* Rules#2: Input validation */\n    if (!validate_username(username)) {\n        fprintf(stderr, "Invalid username format\\n");\n        return -1;\n    }\n    \n    /* Rules#3: Load database credentials from environment, not hard-coded */\n    db_host = getenv("DB_HOST");\n    db_user = getenv("DB_USER");\n    db_password = getenv("DB_PASSWORD");\n    db_name = getenv("DB_NAME");\n    \n    /* Validate configuration was loaded */\n    if (db_host == NULL || db_user == NULL || \n        db_password == NULL || db_name == NULL) {\n        fprintf(stderr, "Database configuration incomplete\\n");\n        return -1;\n    }\n    \n    /* Rules#8: Initialize connection handle */\n    conn = mysql_init(NULL);\n    if (conn == NULL) {\n        fprintf(stderr, "MySQL initialization failed\\n");\n        return -1;\n    }\n    \n    /* Rules#6: Enable SSL/TLS for MySQL connection */\n    mysql_ssl_set(conn, NULL, NULL, NULL, NULL, NULL);\n    \n    /* Connect to database */\n    if (mysql_real_connect(conn, db_host, db_user, db_password,\n                          db_name, 0, NULL, CLIENT_SSL) == NULL) {\n        fprintf(stderr, "Database connection failed\\n");\n        mysql_close(conn);\n        conn = NULL;\n        return -1;\n    }\n    \n    /* Rules#32: Use prepared statement to prevent SQL injection */\n    stmt = mysql_stmt_init(conn);\n    if (stmt == NULL) {\n        fprintf(stderr, "Statement initialization failed\\n");\n        goto cleanup;\n    }\n    \n    if (mysql_stmt_prepare(stmt, query, strlen(query)) != 0) {\n        fprintf(stderr, "Statement preparation failed\\n");\n        goto cleanup;\n    }\n    \n    /* Bind parameter - Rules#8: Initialize bind structure */\n    memset(bind, 0, sizeof(bind));\n    \n    username_length = strnlen(username, 256);\n    \n    bind[0].buffer_type = MYSQL_TYPE_STRING;\n    bind[0].buffer = (char*)username;\n    bind[0].buffer_length = username_length;\n    bind[0].length = &username_length;\n    bind[0].is_null = 0;\n    \n    if (mysql_stmt_bind_param(stmt, bind) != 0) {\n        fprintf(stderr, "Parameter binding failed\\n");\n        goto cleanup;\n    }\n    \n    /* Execute query */\n    if (mysql_stmt_execute(stmt) != 0) {\n        fprintf(stderr, "Query execution failed\\n");\n        goto cleanup;\n    }\n    \n    /* Store result */\n    if (mysql_stmt_store_result(stmt) != 0) {\n        fprintf(stderr, "Result storage failed\\n");\n        goto cleanup;\n    }\n    \n    /* Check if row exists */\n    result_value = (mysql_stmt_num_rows(stmt) > 0) ? 1 : 0;\n    \ncleanup:\n    /* Rules#1: Clean up resources using single failure label */\n    if (stmt != NULL) {\n        mysql_stmt_close(stmt);\n        stmt = NULL;\n    }\n    if (conn != NULL) {\n        mysql_close(conn);\n        conn = NULL;\n    }\n    \n    return result_value;\n}\n\nint main(void) {\n    const char* test_usernames[] = {\n        "john_doe",\n        "alice123",\n        "bob.smith",\n        "user-name",\n        "test_user"\n    };\n    size_t i;\n    int result;\n    \n    for (i = 0; i < 5; i++) {\n        result = check_username_exists(test_usernames[i]);\n        \n        if (result == 1) {\n            /* Rules#10: Do not log sensitive data */\n            printf("Username check completed: found\\n");\n        } else if (result == 0) {\n            printf("Username check completed: not found\\n");\n        } else {\n            /* Rules#11: Return generic error message */\n            fprintf(stderr, "Database error occurred\\n");\n        }\n    }\n    \n    return 0;\n}\n```', type='text')
