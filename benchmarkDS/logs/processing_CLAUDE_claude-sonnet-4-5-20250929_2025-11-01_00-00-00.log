sage);\n    \n    /* Test case 5: Invalid email format */\n    RegistrationResult r5 = register_user("charlie_b", "ValidPass999!", "Charlie", "Brown", "invalid-email");\n    printf("Test 5 - Invalid email: %s\\n", r5.message);\n    \n    return 0;\n}\n```', type='text')
