    return 0;\n        }\n    }\n    \n    return 1;\n}\n\n/* Securely uploads a file to the uploads directory */\nint upload_file(const char *filename, const unsigned char *data, size_t data_len) {\n    int result = 0;\n    int fd = -1;\n    int dir_fd = -1;\n    char safe_path[MAX_PATH_LEN];\n    char temp_filename[MAX_FILENAME_LEN + 16];\n    struct stat file_stat;\n    ssize_t written = 0;\n    \n    /* Rules#28: Treat all input as untrusted - validate filename first */\n    if (!validate_filename(filename)) {\n        fprintf(stderr, "Invalid filename\\n"); /* Rules#11: Generic error message */\n        return 0;\n    }\n    \n    /* Rules#34: Validate size before processing */\n    if (data == NULL || data_len == 0 || data_len > MAX_FILE_SIZE) {\n        fprintf(stderr, "Invalid file data or size\\n");\n        return 0;\n    }\n    \n    /* Create upload directory if it doesn't exist */\n    if (!create_upload_directory()) {\n        fprintf(stderr, "Failed to create upload directory\\n");\n        return 0;\n    }\n    \n    /* Rules#47: Open directory first to anchor operations */\n    dir_fd = open(UPLOAD_DIR, O_RDONLY | O_DIRECTORY | O_CLOEXEC);\n    if (dir_fd == -1) {\n        fprintf(stderr, "Failed to open upload directory\\n");\n        return 0;\n    }\n    \n    /* Rules#52: Write to temporary file first for atomic operation */\n    /* Rules#35: Check for overflow in snprintf */\n    int len = snprintf(temp_filename, sizeof(temp_filename), ".tmp_%s", filename);\n    if (len < 0 || (size_t)len >= sizeof(temp_filename)) {\n        fprintf(stderr, "Filename too long\\n");\n        close(dir_fd);\n        return 0;\n    }\n    \n    /* Rules#46, #49: Open with O_CREAT|O_EXCL|O_NOFOLLOW to prevent races and symlink attacks */\n    /* Rules#50: Restrictive permissions 0600 (owner read/write only) */\n    fd = openat(dir_fd, temp_filename, O_WRONLY | O_CREAT | O_EXCL | O_NOFOLLOW | O_CLOEXEC, 0600);\n    if (fd == -1) {\n        fprintf(stderr, "Failed to