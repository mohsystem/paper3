/*
Build:
  cc -Wall -Wextra -O2 -std=c11 -D_XOPEN_SOURCE=700 lse51.c -o lse51 -larchive

This program demonstrates:
- A "with-like" context manager pattern for file descriptors via a macro.
- Secure extraction of .tar/.tar.gz/.tar.bz2 archives into /tmp/unpack using libarchive with secure flags.
- Safe open()/read()/write() patterns, atomic file writes, and input/path validation.

Note:
- Requires libarchive (e.g., on Debian/Ubuntu: sudo apt-get install libarchive-dev).
*/

#include <archive.h>
#include <archive_entry.h>
#include <errno.h>
#include <fcntl.h>
#include <inttypes.h>
#include <stdbool.h>
#include <stdarg.h>
#include <stddef.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <sys/time.h>
#include <sys/uio.h>
#include <time.h>
#include <unistd.h>

#ifndef O_NOFOLLOW
#define O_NOFOLLOW 0
#endif

#ifndef __USE_MISC
#define __USE_MISC
#endif

#define UNUSED(x) (void)(x)

/* "with-like" context manager for file descriptors: ensures fd is closed at block exit */
#define WITH_FD(fd_name, open_expr) for (int fd_name = (open_expr), _with_once_##fd_name = 0; !_with_once_##fd_name; _with_once_##fd_name = 1, (void)((fd_name) >= 0 ? close(fd_name) : 0))

/* Bounds and limits */
enum {
    MAX_PATH_LEN = 4096,
    MAX_FILE_READ = 16 * 1024 * 1024, /* 16 MiB */
    TMP_NAME_RETRIES = 32
};

static size_t cstrnlen(const char *s, size_t maxlen) {
    if (!s) return 0;
    size_t i = 0;
    for (; i < maxlen; ++i) {
        if (s[i] == '\0') break;
    }
    return i;
}

static bool is_path_separator(char c) {
    return c == '/';
}

static bool is_empty_str(const char *s) {
    return !s || s[0] == '\0';
}

static bool path_is_relative_and_safe(const char *p) {
    /* reject: empty, absolute, starting with "./" or "../", contains "/../" or "/./", or trailing "/.." */
    if (is_empty_str(p)) return false;
    size_t n = cstrnlen(p, MAX_PATH_LEN + 1);
    if (n == 0 || n > MAX_PATH_LEN) return false;
    if (p[0] == '/') return false;
    if (p[0] == '.' && (p[1] == '/' || (p[1] == '.' && (p[2] == '/' || p[2] == '\0')))) return false;

    /* No backslashes; no control chars */
    for (size_t i = 0; i < n; ++i) {
        unsigned char ch = (unsigned char)p[i];
        if (ch == '\\' || ch < 0x20) return false;
    }

    /* Normalize and check for traversal sequences */
    if (strstr(p, "/../") != NULL) return false;
    if (strstr(p, "/./") != NULL) return false;
    /* Edge components */
    size_t len = n;
    if (len >= 3 && strcmp(p + len - 3, "/..") == 0) return false;
    if (strcmp(p, "..") == 0) return false;
    return true;
}

static int ensure_dir_exists_mode(const char *path, mode_t mode) {
    if (is_empty_str(path)) return -1;
    size_t n = cstrnlen(path, MAX_PATH_LEN + 1);
    if (n == 0 || n > MAX_PATH_LEN) return -1;

    struct stat st;
    if (stat(path, &st) == 0) {
        if (S_ISDIR(st.st_mode)) return 0;
        return -1;
    }
    if (errno != ENOENT) return -1;

    if (mkdir(path, mode) == 0) return 0;
    if (errno == EEXIST) {
        if (stat(path, &st) == 0 && S_ISDIR(st.st_mode)) return 0;
    }
    return -1;
}

static int path_join(char *out, size_t out_sz, const char *a, const char *b) {
    if (!out || out_sz == 0) return -1;
    out[0] = '\0';
    if (is_empty_str(a) || is_empty_str(b)) return -1;
    size_t la = cstrnlen(a, MAX_PATH_LEN + 1);
    size_t lb = cstrnlen(b, MAX_PATH_LEN + 1);
    if (la == 0 || lb == 0 || la > MAX_PATH_LEN || lb > MAX_PATH_LEN) return -1;

    bool need_slash = !is_path_separator(a[la - 1]);
    size_t need = la + (need_slash ? 1 : 0) + lb + 1;
    if (need > out_sz) return -1;

    memcpy(out, a, la);
    size_t pos = la;
    if (need_slash) out[pos++] = '/';
    memcpy(out + pos, b, lb);
    pos += lb;
    out[pos] = '\0';
    return 0;
}

static int fsync_dirfd(int dirfd) {
    if (dirfd < 0) return -1;
    return fsync(dirfd);
}

static int safe_renameat(int olddirfd, const char *oldpath, int newdirfd, const char *newpath) {
    if (!oldpath || !newpath) return -1;
    if (renameat(olddirfd, oldpath, newdirfd, newpath) == 0) return 0;
    return -1;
}

static int write_all(int fd, const void *buf, size_t len) {
    const unsigned char *p = (const unsigned char *)buf;
    size_t off = 0;
    while (off < len) {
        ssize_t w = write(fd, p + off, len - off);
        if (w < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        if (w == 0) return -1;
        off += (size_t)w;
    }
    return 0;
}

/* Generate a cryptographically strong random hex string suffix for temp files */
static int random_hex(char *out, size_t out_len) {
    if (!out || out_len < 17) return -1; /* need at least 16 hex + NUL */
    unsigned char r[8];
    int fd = open("/dev/urandom", O_RDONLY | O_CLOEXEC);
    if (fd < 0) return -1;
    ssize_t got = read(fd, r, sizeof(r));
    int saved = errno;
    close(fd);
    errno = saved;
    if (got != (ssize_t)sizeof(r)) return -1;

    static const char hex[] = "0123456789abcdef";
    for (size_t i = 0; i < sizeof(r); ++i) {
        out[2 * i]     = hex[(r[i] >> 4) & 0xF];
        out[2 * i + 1] = hex[r[i] & 0xF];
    }
    out[16] = '\0';
    return 0;
}

/* Atomic text file write into base_dir/relpath. Securely creates file with 0600. */
static int write_text_file_atomic(const char *base_dir, const char *relpath, const char *content) {
    if (is_empty_str(base_dir) || is_empty_str(relpath) || !content) return -1;
    if (!path_is_relative_and_safe(relpath)) return -1;

    if (ensure_dir_exists_mode(base_dir, 0700) != 0) return -1;

    /* Open base directory securely */
    int dirfd = open(base_dir, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
    if (dirfd < 0) return -1;

    /* Build a random temp name */
    char tmpname[64];
    int tmpfd = -1;
    int rc = -1;
    for (int i = 0; i < TMP_NAME_RETRIES; ++i) {
        if (random_hex(tmpname, sizeof(tmpname)) != 0) continue;
        char candidate[80];
        if (snprintf(candidate, sizeof(candidate), ".tmp.%s", tmpname) >= (int)sizeof(candidate)) continue;
        tmpfd = openat(dirfd, candidate, O_CREAT | O_EXCL | O_WRONLY | O_CLOEXEC | O_NOFOLLOW, 0600);
        if (tmpfd >= 0) {
            /* we have a temp file */
            /* Write content */
            size_t len = cstrnlen(content, (size_t)MAX_FILE_READ + 1);
            if (len > (size_t)MAX_FILE_READ) {
                close(tmpfd);
                unlinkat(dirfd, candidate, 0);
                close(dirfd);
                return -1;
            }
            if (write_all(tmpfd, content, len) != 0) {
                int saved = errno;
                close(tmpfd);
                unlinkat(dirfd, candidate, 0);
                close(dirfd);
                errno = saved;
                return -1;
            }
            if (fsync(tmpfd) != 0) {
                int saved = errno;
                close(tmpfd);
                unlinkat(dirfd, candidate, 0);
                close(dirfd);
                errno = saved;
                return -1;
            }
            if (close(tmpfd) != 0) {
                int saved = errno;
                unlinkat(dirfd, candidate, 0);
                close(dirfd);
                errno = saved;
                return -1;
            }
            /* Move into place atomically */
            if (renameat(dirfd, candidate, dirfd, relpath) != 0) {
                int saved = errno;
                unlinkat(dirfd, candidate, 0);
                close(dirfd);
                errno = saved;
                return -1;
            }
            /* Sync directory */
            if (fsync_dirfd(dirfd) != 0) {
                /* Not fatal for all use cases, but we treat as error */
                close(dirfd);
                return -1;
            }
            rc = 0;
            break;
        } else {
            if (errno == EEXIST) continue;
        }
    }
    close(dirfd);
    return rc;
}

/* Read a file fully into a heap buffer (NUL-terminated). Caller must free(). max_size caps the read. */
static char *read_file_to_string(const char *path, size_t max_size) {
    if (is_empty_str(path)) return NULL;
    if (max_size == 0 || max_size > (size_t)MAX_FILE_READ) max_size = (size_t)MAX_FILE_READ;

    int fd = open(path, O_RDONLY | O_CLOEXEC | O_NOFOLLOW);
    if (fd < 0) return NULL;

    char *buf = (char *)malloc(max_size + 1);
    if (!buf) {
        close(fd);
        return NULL;
    }

    size_t off = 0;
    for (;;) {
        if (off >= max_size) break;
        ssize_t r = read(fd, buf + off, max_size - off);
        if (r < 0) {
            if (errno == EINTR) continue;
            free(buf);
            close(fd);
            return NULL;
        }
        if (r == 0) break;
        off += (size_t)r;
    }
    buf[off] = '\0';
    close(fd);
    return buf;
}

/* Create a minimal ustar tar archive containing a single regular file with provided content. */
#pragma pack(push, 1)
struct ustar_header {
    char name[100];
    char mode[8];
    char uid[8];
    char gid[8];
    char size[12];
    char mtime[12];
    char chksum[8];
    char typeflag;
    char linkname[100];
    char magic[6];
    char version[2];
    char uname[32];
    char gname[32];
    char devmajor[8];
    char devminor[8];
    char prefix[155];
    char padding[12];
};
#pragma pack(pop)

static void octal_fill(char *dst, size_t len, unsigned long long val) {
    /* Writes val as octal, right-aligned, null-terminated or space-terminated as tar expects. */
    /* Ensure space for NUL */
    if (len == 0) return;
    memset(dst, '0', len);
    /* Tar size and numeric fields expect NUL at end for POSIX ustar */
    size_t i = len - 1;
    dst[i--] = '\0';
    do {
        if (i >= len) break;
        dst[i] = (char)('0' + (val & 7));
        val >>= 3U;
    } while (i-- > 0 && val != 0);
    /* Ensure there's at least a space */
    if (dst[len - 1] != '\0') dst[len - 1] = '\0';
}

static int create_simple_tar(const char *tar_path, const char *filename_in_tar, const char *content) {
    if (is_empty_str(tar_path) || is_empty_str(filename_in_tar) || !content) return -1;
    if (!path_is_relative_and_safe(filename_in_tar)) return -1;

    int fd = open(tar_path, O_CREAT | O_EXCL | O_WRONLY | O_CLOEXEC | O_NOFOLLOW, 0600);
    if (fd < 0) return -1;

    struct ustar_header hdr;
    memset(&hdr, 0, sizeof(hdr));

    size_t name_len = cstrnlen(filename_in_tar, sizeof(hdr.name));
    if (name_len == 0 || name_len >= sizeof(hdr.name)) {
        close(fd);
        unlink(tar_path);
        return -1;
    }
    memcpy(hdr.name, filename_in_tar, name_len);

    /* Mode, uid, gid, size, mtime */
    octal_fill(hdr.mode, sizeof(hdr.mode), 0644);
    octal_fill(hdr.uid, sizeof(hdr.uid), 0);
    octal_fill(hdr.gid, sizeof(hdr.gid), 0);

    size_t content_len = cstrnlen(content, (size_t)MAX_FILE_READ);
    octal_fill(hdr.size, sizeof(hdr.size), (unsigned long long)content_len);

    unsigned long mtime = (unsigned long)time(NULL);
    octal_fill(hdr.mtime, sizeof(hdr.mtime), mtime);

    hdr.typeflag = '0'; /* regular file */
    memcpy(hdr.magic, "ustar", 5);
    hdr.magic[5] = '\0';
    memcpy(hdr.version, "00", 2);

    /* Checksum: treat chksum field as spaces for computation */
    memset(hdr.chksum, ' ', sizeof(hdr.chksum));
    unsigned int sum = 0;
    const unsigned char *p = (const unsigned char *)&hdr;
    for (size_t i = 0; i < sizeof(hdr); ++i) sum += p[i];
    /* Write checksum as octal followed by NUL and space */
    /* Classic tar uses 6 digits, a NUL and a space */
    {
        char chk[8];
        memset(chk, 0, sizeof(chk));
        /* Format sum in octal */
        char tmp[32];
        memset(tmp, 0, sizeof(tmp));
        /* Ensure bounded snprintf */
        int n = snprintf(tmp, sizeof(tmp), "%06o", sum & 0xFFFFFFFFU);
        if (n < 0 || (size_t)n >= sizeof(tmp)) {
            close(fd);
            unlink(tar_path);
            return -1;
        }
        memcpy(hdr.chksum, tmp, 6);
        hdr.chksum[6] = '\0';
        hdr.chksum[7] = ' ';
    }

    /* Write header */
    if (write_all(fd, &hdr, sizeof(hdr)) != 0) {
        int saved = errno;
        close(fd);
        unlink(tar_path);
        errno = saved;
        return -1;
    }

    /* Write content and pad to 512 */
    if (content_len > 0) {
        if (write_all(fd, content, content_len) != 0) {
            int saved = errno;
            close(fd);
            unlink(tar_path);
            errno = saved;
            return -1;
        }
        size_t pad = 512 - (content_len % 512);
        if (pad != 512) {
            char zeros[512];
            memset(zeros, 0, sizeof(zeros));
            if (write_all(fd, zeros, pad) != 0) {
                int saved = errno;
                close(fd);
                unlink(tar_path);
                errno = saved;
                return -1;
            }
        }
    }

    /* Two 512-byte blocks of zeros to end archive */
    {
        char zeros[1024];
        memset(zeros, 0, sizeof(zeros));
        if (write_all(fd, zeros, sizeof(zeros)) != 0) {
            int saved = errno;
            close(fd);
            unlink(tar_path);
            errno = saved;
            return -1;
        }
    }

    if (fsync(fd) != 0) {
        int saved = errno;
        close(fd);
        unlink(tar_path);
        errno = saved;
        return -1;
    }
    if (close(fd) != 0) {
        int saved = errno;
        unlink(tar_path);
        errno = saved;
        return -1;
    }
    return 0;
}

/* Securely extract a tar archive (supports gzip/bzip2/others via libarchive) into dest_base directory. */
static int safe_extract_tar(const char *archive_path, const char *dest_base) {
    if (is_empty_str(archive_path)) return -1;
    if (is_empty_str(dest_base)) dest_base = "/tmp/unpack";

    size_t ap_len = cstrnlen(archive_path, MAX_PATH_LEN + 1);
    size_t db_len = cstrnlen(dest_base, MAX_PATH_LEN + 1);
    if (ap_len == 0 || ap_len > MAX_PATH_LEN || db_len == 0 || db_len > MAX_PATH_LEN) return -1;

    if (ensure_dir_exists_mode(dest_base, 0700) != 0) return -1;

    /* Open destination directory and save current working directory */
    int destfd = open(dest_base, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
    if (destfd < 0) return -1;

    int oldcwd = open(".", O_RDONLY | O_DIRECTORY | O_CLOEXEC);
    if (oldcwd < 0) {
        close(destfd);
        return -1;
    }

    if (fchdir(destfd) != 0) {
        int saved = errno;
        close(oldcwd);
        close(destfd);
        errno = saved;
        return -1;
    }

    struct archive *a = archive_read_new();
    if (!a) {
        fchdir(oldcwd);
        close(oldcwd);
        close(destfd);
        return -1;
    }

    /* Enable all filters and tar format */
    archive_read_support_format_tar(a);
    archive_read_support_filter_gzip(a);
    archive_read_support_filter_bzip2(a);
    archive_read_support_filter_xz(a);
    archive_read_support_filter_lz4(a);
    archive_read_support_filter_zstd(a);

    int r = archive_read_open_filename(a, archive_path, 10240);
    if (r != ARCHIVE_OK) {
        archive_read_free(a);
        fchdir(oldcwd);
        close(oldcwd);
        close(destfd);
        return -1;
    }

    struct archive_entry *entry = NULL;
    int extract_flags = ARCHIVE_EXTRACT_SECURE_NODOTDOT |
                        ARCHIVE_EXTRACT_SECURE_NOABSOLUTEPATHS |
                        ARCHIVE_EXTRACT_NO_OVERWRITE |
                        ARCHIVE_EXTRACT_SECURE_SYMLINKS |
                        ARCHIVE_EXTRACT_PERM |
                        ARCHIVE_EXTRACT_TIME;

    int rc = 0;
    while ((r = archive_read_next_header(a, &entry)) == ARCHIVE_OK) {
        /* Skip symlinks and hardlinks for stricter security posture */
        mode_t type = archive_entry_filetype(entry);
        if (type == AE_IFLNK || type == AE_IFBLK || type == AE_IFCHR || type == AE_IFIFO) {
            /* Skip these entries */
            archive_read_data_skip(a);
            continue;
        }
        const char *pathname = archive_entry_pathname(entry);
        if (!pathname || !path_is_relative_and_safe(pathname)) {
            rc = -1;
            break;
        }

        r = archive_read_extract(a, entry, extract_flags);
        if (r != ARCHIVE_OK) {
            rc = -1;
            break;
        }
    }

    archive_read_close(a);
    archive_read_free(a);

    /* Restore working directory */
    int saved = errno;
    fchdir(oldcwd);
    close(oldcwd);

    /* Sync destination directory to persist metadata */
    if (rc == 0) {
        if (fsync_dirfd(destfd) != 0) {
            rc = -1;
        }
    }
    close(destfd);
    errno = saved;
    return rc;
}

/* Demonstrate use of open() with a with-like macro to ensure cleanup. */
static int demo_open_read_write(const char *base_dir) {
    if (is_empty_str(base_dir)) base_dir = "/tmp/unpack";
    if (ensure_dir_exists_mode(base_dir, 0700) != 0) return -1;

    char path[MAX_PATH_LEN + 1];
    if (path_join(path, sizeof(path), base_dir, "demo_open_io.txt") != 0) return -1;

    /* write */
    WITH_FD(fd_w, open(path, O_CREAT | O_EXCL | O_WRONLY | O_CLOEXEC | O_NOFOLLOW, 0600)) {
        if (fd_w < 0) return -1;
        const char *msg = "open() demo: safe write via POSIX APIs.\n";
        if (write_all(fd_w, msg, cstrnlen(msg, 1024)) != 0) return -1;
        if (fsync(fd_w) != 0) return -1;
    }

    /* read */
    WITH_FD(fd_r, open(path, O_RDONLY | O_CLOEXEC | O_NOFOLLOW)) {
        if (fd_r < 0) return -1;
        char buf[128];
        ssize_t r = read(fd_r, buf, sizeof(buf) - 1);
        if (r < 0) return -1;
        buf[r] = '\0';
        /* Print using constant format string */
        printf("%s", buf);
    }
    return 0;
}

/* Test cases in main (5 tests) */
int main(void) {
    const char *base = "/tmp/unpack";
    umask(0077); /* Restrictive default permissions */

    /* Test 1: Atomic write and read back */
    if (write_text_file_atomic(base, "test1.txt", "Sample content 1\n") == 0) {
        char full[MAX_PATH_LEN + 1];
        if (path_join(full, sizeof(full), base, "test1.txt") == 0) {
            char *s = read_file_to_string(full, 4096);
            if (s) {
                printf("%s", s);
                free(s);
            } else {
                printf("%s", "Failed to read test1.txt\n");
            }
        } else {
            printf("%s", "Path join failed\n");
        }
    } else {
        printf("%s", "Atomic write failed\n");
    }

    /* Test 2: demo_open_read_write using open() and with-like macro */
    if (demo_open_read_write(base) != 0) {
        printf("%s", "demo_open_read_write failed\n");
    }

    /* Test 3: Attempt to extract a non-existent archive (expected failure) */
    int rc = safe_extract_tar("/tmp/unpack/no_such.tar.gz", "/tmp/unpack/extract_fail");
    printf("Extract non-existent archive rc=%d (expected -1)\n", rc);

    /* Test 4: Create a simple tar archive and extract it */
    char tar_path[MAX_PATH_LEN + 1];
    if (path_join(tar_path, sizeof(tar_path), base, "sample.tar") == 0) {
        if (create_simple_tar(tar_path, "greeting.txt", "Hello Tar from C!\n") == 0) {
            const char *dest_ok = "/tmp/unpack/extract_ok";
            if (ensure_dir_exists_mode(dest_ok, 0700) == 0) {
                int erc = safe_extract_tar(tar_path, dest_ok);
                printf("Extract created tar rc=%d (expected 0)\n", erc);
            } else {
                printf("%s", "Failed to create extract_ok dir\n");
            }
        } else {
            printf("%s", "Failed to create simple tar\n");
        }
    } else {
        printf("%s", "Failed to build tar path\n");
    }

    /* Test 5: Validate path traversal rejection in writer and extractor */
    int rc_trav1 = write_text_file_atomic(base, "../evil.txt", "nope");
    printf("Traversal write rejected rc=%d (expected -1)\n", rc_trav1);
    int rc_trav2 = safe_extract_tar("/tmp/unpack/../evil.tar", "/tmp/unpack/extract_trav");
    printf("Traversal archive path rc=%d (expected -1)\n", rc_trav2);

    return 0;
}
