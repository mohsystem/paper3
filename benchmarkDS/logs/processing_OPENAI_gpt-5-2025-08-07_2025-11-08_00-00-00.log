#ifndef O_NOFOLLOW
#define O_NOFOLLOW 0
#endif

#ifndef O_CLOEXEC
#define O_CLOEXEC 0
#endif

#ifndef SOCK_CLOEXEC
#define SOCK_CLOEXEC 0
#endif

#ifndef TCP_NODELAY
#define TCP_NODELAY 1
#endif

#define SERVER_PORT 18080
#define MAX_HEADER (16 * 1024)
#define RECV_BUF   (8 * 1024)
#define MAX_UPLOAD (5 * 1024 * 1024) // 5 MiB
#define MAX_NAME_LEN 64
#define UPLOAD_DIR "uploads"

typedef struct {
    int fd;
    int dirfd;
    size_t max_upload;
} server_ctx_t;

static void safe_perror(const char *msg) {
    // Minimal, constant format, no user-controlled format strings.
    fprintf(stderr, "ERR: %s: %s\n", msg, strerror(errno));
}

static int set_timeouts(int fd, int seconds) {
    struct timeval tv;
    tv.tv_sec = seconds;
    tv.tv_usec = 0;
    if (setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv)) != 0) return -1;
    if (setsockopt(fd, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof(tv)) != 0) return -1;
    return 0;
}

static int set_nodelay(int fd) {
    int flag = 1;
    if (setsockopt(fd, IPPROTO_TCP, TCP_NODELAY, &flag, sizeof(flag)) != 0) return -1;
    return 0;
}

static int create_listen_socket(uint16_t port) {
    int fd = socket(AF_INET, SOCK_STREAM | SOCK_CLOEXEC, 0);
    if (fd < 0) { safe_perror("socket"); return -1; }
    int one = 1;
    (void)setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &one, sizeof(one));

    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    if (inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr) != 1) {
        safe_perror("inet_pton");
        close(fd);
        return -1;
    }
    if (bind(fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {
        safe_perror("bind");
        close(fd);
        return -1;
    }
    if (listen(fd, 16) != 0) {
        safe_perror("listen");
        close(fd);
        return -1;
    }
    return fd;
}

static bool is_allowed_filename_char(char c) {
    // Allow alphanumerics, dot, underscore, dash only.
    if (c >= 'a' && c <= 'z') return true;
    if (c >= 'A' && c <= 'Z') return true;
    if (c >= '0' && c <= '9') return true;
    if (c == '.' || c == '_' || c == '-') return true;
    return false;
}

static bool validate_filename(const char *name) {
    if (!name) return false;
    size_t n = strnlen(name, MAX_NAME_LEN + 1);
    if (n == 0 || n > MAX_NAME_LEN) return false;
    // Disallow starting with dot (hidden) and require only allowed chars.
    if (name[0] == '.') return false;
    for (size_t i = 0; i < n; i++) {
        if (!is_allowed_filename_char(name[i])) return false;
    }
    return true;
}

static int open_upload_dir(void) {
    // Create directory if needed (0700), then open securely without following symlinks.
    if (mkdir(UPLOAD_DIR, 0700) != 0) {
        if (errno != EEXIST) {
            safe_perror("mkdir uploads");
            return -1;
        }
    }
    int dfd = open(UPLOAD_DIR, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
    if (dfd < 0) { safe_perror("open uploads dir"); return -1; }
    struct stat st;
    if (fstat(dfd, &st) != 0) { safe_perror("fstat uploads dir"); close(dfd); return -1; }
    if (!S_ISDIR(st.st_mode)) { fprintf(stderr, "ERR: uploads is not a directory\n"); close(dfd); return -1; }
    return dfd;
}

static uint64_t get_nonce64(void) {
    uint64_t x = 0;
    ssize_t r = getrandom(&x, sizeof(x), 0);
    if (r != (ssize_t)sizeof(x)) {
        struct timespec ts;
        clock_gettime(CLOCK_REALTIME, &ts);
        x = ((uint64_t)ts.tv_sec << 32) ^ (uint64_t)ts.tv_nsec ^ (uint64_t)getpid() ^ (uint64_t)rand();
    }
    return x;
}

static int safe_write_all(int fd, const void *buf, size_t len) {
    const unsigned char *p = (const unsigned char *)buf;
    size_t off = 0;
    while (off < len) {
        ssize_t w = write(fd, p + off, len - off);
        if (w < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        if (w == 0) return -1;
        off += (size_t)w;
    }
    return 0;
}

static int safe_read_all(int fd, void *buf, size_t len) {
    unsigned char *p = (unsigned char *)buf;
    size_t off = 0;
    while (off < len) {
        ssize_t r = read(fd, p + off, len - off);
        if (r < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        if (r == 0) return -2; // EOF before expected
        off += (size_t)r;
    }
    return 0;
}

typedef struct {
    char method[8];
    char path[256];
    char version[16];
    int64_t content_length;
    bool has_content_length;
    bool chunked;
} http_request_t;

static void init_request(http_request_t *req) {
    memset(req, 0, sizeof(*req));
    req->content_length = 0;
    req->has_content_length = false;
    req->chunked = false;
}

static int parse_start_line(const char *line, http_request_t *req) {
    // Expect: METHOD SP PATH SP HTTP/1.1
    // Enforce bounds and allowed characters.
    const char *sp1 = strchr(line, ' ');
    if (!sp1) return -1;
    size_t mlen = (size_t)(sp1 - line);
    if (mlen == 0 || mlen >= sizeof(req->method)) return -1;

    const char *sp2 = strchr(sp1 + 1, ' ');
    if (!sp2) return -1;
    size_t plen = (size_t)(sp2 - (sp1 + 1));
    if (plen == 0 || plen >= sizeof(req->path)) return -1;

    size_t vlen = strnlen(sp2 + 1, sizeof(req->version));
    if (vlen == 0 || vlen >= sizeof(req->version)) return -1;

    memcpy(req->method, line, mlen);
    req->method[mlen] = '\0';
    memcpy(req->path, sp1 + 1, plen);
    req->path[plen] = '\0';
    memcpy(req->version, sp2 + 1, vlen);
    req->version[vlen] = '\0';
    return 0;
}

static bool ieq(const char *a, const char *b) {
    // case-insensitive equality
    while (*a && *b) {
        char ca = *a, cb = *b;
        if (ca >= 'A' && ca <= 'Z') ca = (char)(ca - 'A' + 'a');
        if (cb >= 'A' && cb <= 'Z') cb = (char)(cb - 'A' + 'a');
        if (ca != cb) return false;
        a++; b++;
    }
    return *a == '\0' && *b == '\0';
}

static int64_t parse_int64(const char *s) {
    if (!s || *s == '\0') return -1;
    errno = 0;
    char *end = NULL;
    long long v = strtoll(s, &end, 10);
    if (errno != 0 || end == s || *end != '\0' || v < 0) return -1;
    return (int64_t)v;
}

static int recv_until_headers(int fd, char *buf, size_t cap, size_t *hdr_len, size_t *total_len) {
    size_t used = 0;
    const char *needle = "\r\n\r\n";
    while (used < cap) {
        ssize_t r = recv(fd, buf + used, (int)(cap - used), 0);
        if (r < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        if (r == 0) break; // EOF
        used += (size_t)r;
        // search for header end
        if (used >= 4) {
            for (size_t i = 0; i + 3 < used; i++) {
                if (buf[i] == '\r' && buf[i+1] == '\n' && buf[i+2] == '\r' && buf[i+3] == '\n') {
                    *hdr_len = i + 4;
                    *total_len = used;
                    return 0;
                }
            }
        }
        if (used == cap) return -2; // headers too large
    }
    return -3; // incomplete
}

static void send_simple_response(int fd, int code, const char *status, const char *ctype, const char *body) {
    char hdr[512];
    size_t blen = body ? strnlen(body, 4096) : 0;
    int n = snprintf(hdr, sizeof(hdr),
                     "HTTP/1.1 %d %s\r\n"
                     "Content-Type: %s\r\n"
                     "Content-Length: %zu\r\n"
                     "Connection: close\r\n"
                     "X-Content-Type-Options: nosniff\r\n"
                     "Content-Security-Policy: default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; base-uri 'none'\r\n"
                     "Referrer-Policy: no-referrer\r\n"
                     "\r\n",
                     code, status, ctype ? ctype : "text/plain; charset=utf-8", blen);
    if (n < 0) return;
    (void)safe_write_all(fd, hdr, (size_t)n);
    if (body && blen > 0) (void)safe_write_all(fd, body, blen);
}

static void send_405(int fd) {
    send_simple_response(fd, 405, "Method Not Allowed", "text/plain; charset=utf-8", "Method Not Allowed");
}

static void send_400(int fd) {
    send_simple_response(fd, 400, "Bad Request", "text/plain; charset=utf-8", "Bad Request");
}

static void send_404(int fd) {
    send_simple_response(fd, 404, "Not Found", "text/plain; charset=utf-8", "Not Found");
}

static void send_409(int fd) {
    send_simple_response(fd, 409, "Conflict", "text/plain; charset=utf-8", "File Already Exists");
}

static void send_413(int fd) {
    send_simple_response(fd, 413, "Payload Too Large", "text/plain; charset=utf-8", "Payload Too Large");
}

static void send_201(int fd, const char *msg) {
    send_simple_response(fd, 201, "Created", "text/plain; charset=utf-8", msg ? msg : "Created");
}

static void send_index_html(int fd) {
    const char *html =
        "<!doctype html>\n"
        "<html lang=\"en\"><head><meta charset=\"utf-8\">\n"
        "<title>Secure Upload</title>\n"
        "<meta http-equiv=\"X-Content-Type-Options\" content=\"nosniff\">\n"
        "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
        "</head><body>\n"
        "<h1>Secure File Upload</h1>\n"
        "<p>This demo uploads the file via POST /upload/&lt;name&gt; with the raw file as the request body.</p>\n"
        "<input id=\"f\" type=\"file\" /> <button id=\"b\">Upload</button>\n"
        "<pre id=\"o\"></pre>\n"
        "<script>\n"
        "function sanitizeName(n){return n.replace(/[^A-Za-z0-9._-]/g,'').replace(/^\\./,'');}\n"
        "document.getElementById('b').onclick=async()=>{\n"
        " const f=document.getElementById('f').files[0];\n"
        " if(!f){document.getElementById('o').textContent='Pick a file';return;}\n"
        " const name=sanitizeName(f.name).slice(0,64); if(!name){document.getElementById('o').textContent='Invalid name';return;}\n"
        " const r=await fetch('/upload/'+name,{method:'POST',body:f});\n"
        " document.getElementById('o').textContent='Status: '+r.status+' '+r.statusText+'\\n'+await r.text();\n"
        "};\n"
        "</script>\n"
        "</body></html>\n";
    send_simple_response(fd, 200, "OK", "text/html; charset=utf-8", html);
}

static int write_upload_file(int dirfd, const char *final_name, int client_fd, const unsigned char *prefetch, size_t prefetch_len, int64_t total_len) {
    if (!validate_filename(final_name)) return -1;

    // Build a unique temporary name in the same directory.
    char tmpname[96];
    uint64_t nonce = get_nonce64();
    int tmpfd = -1;
    for (int tries = 0; tries < 8; tries++) {
        int n = snprintf(tmpname, sizeof(tmpname), "tmp.%ld.%llu.%d",
                         (long)getpid(), (unsigned long long)(nonce + (uint64_t)tries), rand());
        if (n <= 0 || (size_t)n >= sizeof(tmpname)) return -2;

        tmpfd = openat(dirfd, tmpname, O_WRONLY | O_CREAT | O_EXCL | O_CLOEXEC | O_NOFOLLOW, 0600);
        if (tmpfd >= 0) break;
        if (errno == EEXIST) continue;
        safe_perror("openat tmp");
        return -3;
    }
    if (tmpfd < 0) return -3;

    // Write body: first any prefetch, then the remainder from the socket.
    int rc = 0;
    int64_t remaining = total_len;
    if (prefetch_len > 0) {
        size_t w = prefetch_len;
        if ((int64_t)w > remaining) w = (size_t)remaining;
        if (safe_write_all(tmpfd, prefetch, w) != 0) { rc = -4; goto done; }
        remaining -= (int64_t)w;
    }
    unsigned char buf[RECV_BUF];
    while (remaining > 0) {
        size_t to_read = (size_t)((remaining > (int64_t)sizeof(buf)) ? sizeof(buf) : remaining);
        ssize_t r = recv(client_fd, buf, (int)to_read, 0);
        if (r < 0) {
            if (errno == EINTR) continue;
            rc = -5; goto done;
        }
        if (r == 0) { rc = -6; goto done; }
        if (safe_write_all(tmpfd, buf, (size_t)r) != 0) { rc = -7; goto done; }
        remaining -= (int64_t)r;
    }

    // Ensure regular file and sync content
    struct stat st;
    if (fstat(tmpfd, &st) != 0) { rc = -8; goto done; }
    if (!S_ISREG(st.st_mode)) { rc = -9; goto done; }
    if (fsync(tmpfd) != 0) { rc = -10; goto done; }

    // Atomically create final name without overwrite using linkat
    if (linkat(dirfd, tmpname, dirfd, final_name, 0) != 0) {
        if (errno == EEXIST) { rc = -11; goto done; }
        rc = -12; goto done;
    }

    // Sync directory metadata and unlink temp
    {
        int dfd_dup = dup(dirfd);
        if (dfd_dup >= 0) {
            (void)fsync(dfd_dup);
            close(dfd_dup);
        }
    }
    (void)unlinkat(dirfd, tmpname, 0);
    rc = 0;

done:
    if (tmpfd >= 0) close(tmpfd);
    if (rc != 0) {
        // Cleanup temp on failure
        (void)unlinkat(dirfd, tmpname, 0);
    }
    return rc;
}

static int handle_post_upload(int client_fd, int dirfd, http_request_t *req, const unsigned char *body0, size_t body0_len) {
    // Path expected: /upload/<name>
    const char *p = req->path;
    // Strip query component if any
    char pathbuf[sizeof(req->path)];
    {
        size_t plen = strnlen(p, sizeof(pathbuf)-1);
        size_t i;
        for (i = 0; i < plen; i++) {
            if (p[i] == '?') break;
            pathbuf[i] = p[i];
        }
        pathbuf[i] = '\0';
    }
    if (strncmp(pathbuf, "/upload/", 8) != 0) {
        send_404(client_fd);
        return 0;
    }
    const char *name = pathbuf + 8;
    if (!validate_filename(name)) {
        send_400(client_fd);
        return 0;
    }
    if (!req->has_content_length || req->chunked) {
        // Only support explicit Content-Length, not chunked.
        send_400(client_fd);
        return 0;
    }
    if (req->content_length > (int64_t)MAX_UPLOAD) {
        send_413(client_fd);
        return 0;
    }

    int rc = write_upload_file(dirfd, name, client_fd, body0, body0_len, req->content_length);
    if (rc == 0) {
        send_201(client_fd, "Uploaded");
    } else if (rc == -11) {
        send_409(client_fd);
    } else if (rc == -6) {
        send_400(client_fd); // premature EOF
    } else if (rc == -4 || rc == -5 || rc == -7) {
        send_simple_response(client_fd, 500, "Internal Server Error", "text/plain; charset=utf-8", "Upload failed");
    } else {
        send_simple_response(client_fd, 500, "Internal Server Error", "text/plain; charset=utf-8", "Server error");
    }
    return 0;
}

static int handle_client(server_ctx_t *srv, int cfd) {
    (void)set_timeouts(cfd, 5);
    (void)set_nodelay(cfd);

    char *hdr = (char *)malloc(MAX_HEADER);
    if (!hdr) { send_simple_response(cfd, 500, "Internal Server Error", "text/plain; charset=utf-8", "OOM"); return -1; }
    size_t hdr_len = 0, total_len = 0;
    int rcv = recv_until_headers(cfd, hdr, MAX_HEADER, &hdr_len, &total_len);
    if (rcv != 0) {
        free(hdr);
        send_400(cfd);
        return -1;
    }
    // Parse start line
    char *start = hdr;
    char *end_start = (char *)memmem(hdr, hdr_len, "\r\n", 2);
    if (!end_start) { free(hdr); send_400(cfd); return -1; }
    size_t start_len = (size_t)(end_start - start);
    char start_line[512];
    if (start_len >= sizeof(start_line)) { free(hdr); send_400(cfd); return -1; }
    memcpy(start_line, start, start_len);
    start_line[start_len] = '\0';

    http_request_t req;
    init_request(&req);
    if (parse_start_line(start_line, &req) != 0) { free(hdr); send_400(cfd); return -1; }

    // Parse headers
    char *p = end_start + 2;
    while (p < hdr + hdr_len - 2) {
        char *eol = (char *)memmem(p, (hdr + hdr_len) - p, "\r\n", 2);
        if (!eol) break;
        if (eol == p) { // blank line
            break;
        }
        size_t linelen = (size_t)(eol - p);
        if (linelen > 0) {
            // Split at colon
            char *colon = memchr(p, ':', linelen);
            if (colon && colon > p) {
                size_t klen = (size_t)(colon - p);
                size_t vlen = linelen - klen - 1; // skip ':'
                while (vlen > 0 && (p[klen + 1] == ' ' || p[klen + 1] == '\t')) { klen++; vlen--; }
                // Extract key lowercase-ish compare safely
                char key[64]; char val[256];
                size_t cpy = klen < sizeof(key) - 1 ? klen : sizeof(key) - 1;
                memcpy(key, p, cpy); key[cpy] = '\0';
                // trim value
                size_t vstart = (size_t)(colon - p + 1);
                while (vstart < linelen && (p[vstart] == ' ' || p[vstart] == '\t')) vstart++;
                size_t vcopy = linelen - vstart;
                if (vcopy >= sizeof(val)) vcopy = sizeof(val) - 1;
                memcpy(val, p + vstart, vcopy); val[vcopy] = '\0';

                // Lower-case key for compare
                for (size_t i = 0; key[i]; i++) if (key[i] >= 'A' && key[i] <= 'Z') key[i] = (char)(key[i] - 'A' + 'a');

                if (strcmp(key, "content-length") == 0) {
                    int64_t cl = parse_int64(val);
                    if (cl < 0) { free(hdr); send_400(cfd); return -1; }
                    req.content_length = cl;
                    req.has_content_length = true;
                } else if (strcmp(key, "transfer-encoding") == 0) {
                    // if chunked appears, we reject
                    char low[256];
                    size_t L = strnlen(val, sizeof(low)-1);
                    for (size_t i = 0; i < L; i++) {
                        char ch = val[i];
                        if (ch >= 'A' && ch <= 'Z') ch = (char)(ch - 'A' + 'a');
                        low[i] = ch;
                    }
                    low[L] = '\0';
                    if (strstr(low, "chunked") != NULL) {
                        req.chunked = true;
                    }
                }
            }
        }
        p = eol + 2;
    }

    size_t body0_len = total_len - hdr_len;
    unsigned char *body0 = (unsigned char *)(hdr + hdr_len);

    // Dispatch
    int rc = 0;
    if (ieq(req.method, "GET")) {
        if (strcmp(req.path, "/") == 0) {
            send_index_html(cfd);
        } else {
            send_404(cfd);
        }
    } else if (ieq(req.method, "POST")) {
        rc = handle_post_upload(cfd, srv->dirfd, &req, body0, body0_len);
    } else {
        send_405(cfd);
    }

    free(hdr);
    return rc;
}

typedef struct {
    server_ctx_t srv;
    int max_requests;
} server_thread_arg_t;

static int server_thread(void *arg) {
    server_thread_arg_t *a = (server_thread_arg_t *)arg;

    int handled = 0;
    while (handled < a->max_requests) {
        struct sockaddr_in cli;
        socklen_t sl = sizeof(cli);
        int cfd = accept(a->srv.fd, (struct sockaddr *)&cli, &sl);
        if (cfd < 0) {
            if (errno == EINTR) continue;
            safe_perror("accept");
            break;
        }
        (void)set_timeouts(cfd, 5);
        (void)set_nodelay(cfd);
        (void)handle_client(&a->srv, cfd);
        close(cfd);
        handled++;
    }
    return 0;
}

// -----------------------------
// Simple test HTTP client suite
// -----------------------------

static int connect_to_server(uint16_t port) {
    int fd = socket(AF_INET, SOCK_STREAM | SOCK_CLOEXEC, 0);
    if (fd < 0) return -1;
    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr);
    if (connect(fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {
        safe_perror("connect");
        close(fd);
        return -1;
    }
    (void)set_timeouts(fd, 5);
    (void)set_nodelay(fd);
    return fd;
}

static int read_response_status(int fd, int *status_out, char *buf, size_t bufsz) {
    // Read up to headers end or buffer size, parse status code.
    size_t used = 0;
    while (used < bufsz) {
        ssize_t r = recv(fd, buf + used, (int)(bufsz - used), 0);
        if (r < 0) { if (errno == EINTR) continue; return -1; }
        if (r == 0) break;
        used += (size_t)r;
        if (used >= 4) {
            for (size_t i = 0; i + 3 < used; i++) {
                if (buf[i] == '\r' && buf[i+1] == '\n' && buf[i+2] == '\r' && buf[i+3] == '\n') {
                    // Found end of headers
                    goto parse;
                }
            }
        }
        if (used == bufsz) break;
    }
parse:
    buf[used < bufsz ? used : bufsz - 1] = '\0';
    // Parse first line
    char *eol = strstr(buf, "\r\n");
    if (!eol) return -1;
    *eol = '\0';
    // Expect "HTTP/1.1 XXX"
    if (strncmp(buf, "HTTP/", 5) != 0) return -1;
    char *sp = strchr(buf, ' ');
    if (!sp) return -1;
    int code = atoi(sp + 1);
    if (code < 100 || code > 999) return -1;
    *status_out = code;
    return 0;
}

static void test_get_index(uint16_t port) {
    int fd = connect_to_server(port);
    if (fd < 0) { fprintf(stderr, "Test1: connect fail\n"); return; }
    const char *req =
        "GET / HTTP/1.1\r\n"
        "Host: localhost\r\n"
        "Connection: close\r\n"
        "\r\n";
    (void)safe_write_all(fd, req, strlen(req));
    char buf[4096];
    int status = 0;
    if (read_response_status(fd, &status, buf, sizeof(buf)) == 0) {
        printf("Test1 GET / -> %d\n", status);
    } else {
        printf("Test1 GET / -> parse error\n");
    }
    close(fd);
}

static void test_post_small_file(uint16_t port) {
    int fd = connect_to_server(port);
    if (fd < 0) { fprintf(stderr, "Test2: connect fail\n"); return; }
    const char *body = "Hello, upload!";
    char hdr[256];
    int n = snprintf(hdr, sizeof(hdr),
        "POST /upload/good.txt HTTP/1.1\r\n"
        "Host: localhost\r\n"
        "Content-Length: %zu\r\n"
        "Connection: close\r\n"
        "\r\n", strlen(body));
    (void)safe_write_all(fd, hdr, (size_t)n);
    (void)safe_write_all(fd, body, strlen(body));
    char buf[4096];
    int status = 0;
    if (read_response_status(fd, &status, buf, sizeof(buf)) == 0) {
        printf("Test2 POST small -> %d\n", status);
    } else {
        printf("Test2 POST small -> parse error\n");
    }
    close(fd);
}

static void test_post_bad_name(uint16_t port) {
    int fd = connect_to_server(port);
    if (fd < 0) { fprintf(stderr, "Test3: connect fail\n"); return; }
    const char *body = "evil";
    const char *req1 =
        "POST /upload/../evil.txt HTTP/1.1\r\n"
        "Host: localhost\r\n"
        "Content-Length: 4\r\n"
        "Connection: close\r\n"
        "\r\n"
        "evil";
    (void)safe_write_all(fd, req1, strlen(req1));
    char buf[4096];
    int status = 0;
    if (read_response_status(fd, &status, buf, sizeof(buf)) == 0) {
        printf("Test3 POST bad name -> %d\n", status);
    } else {
        printf("Test3 POST bad name -> parse error\n");
    }
    close(fd);
}

static void test_post_too_large(uint16_t port) {
    int fd = connect_to_server(port);
    if (fd < 0) { fprintf(stderr, "Test4: connect fail\n"); return; }
    size_t big = MAX_UPLOAD + 1;
    char *body = (char *)malloc(big);
    if (!body) { fprintf(stderr, "Test4: OOM\n"); close(fd); return; }
    memset(body, 'A', big);
    char hdr[256];
    int n = snprintf(hdr, sizeof(hdr),
        "POST /upload/large.bin HTTP/1.1\r\n"
        "Host: localhost\r\n"
        "Content-Length: %zu\r\n"
        "Connection: close\r\n"
        "\r\n", big);
    (void)safe_write_all(fd, hdr, (size_t)n);
    // Send only headers; server should reject based on Content-Length before reading body
    char buf[4096];
    int status = 0;
    if (read_response_status(fd, &status, buf, sizeof(buf)) == 0) {
        printf("Test4 POST too large -> %d\n", status);
    } else {
        printf("Test4 POST too large -> parse error\n");
    }
    free(body);
    close(fd);
}

static void test_put_method(uint16_t port) {
    int fd = connect_to_server(port);
    if (fd < 0) { fprintf(stderr, "Test5: connect fail\n"); return; }
    const char *body = "data";
    char hdr[256];
    int n = snprintf(hdr, sizeof(hdr),
        "PUT /upload/name.txt HTTP/1.1\r\n"
        "Host: localhost\r\n"
        "Content-Length: %zu\r\n"
        "Connection: close\r\n"
        "\r\n", strlen(body));
    (void)safe_write_all(fd, hdr, (size_t)n);
    (void)safe_write_all(fd, body, strlen(body));
    char buf[4096];
    int status = 0;
    if (read_response_status(fd, &status, buf, sizeof(buf)) == 0) {
        printf("Test5 PUT method -> %d\n", status);
    } else {
        printf("Test5 PUT method -> parse error\n");
    }
    close(fd);
}

int main(void) {
    // Ignore SIGPIPE to avoid crashes on client disconnect
    signal(SIGPIPE, SIG_IGN);

    int dirfd = open_upload_dir();
    if (dirfd < 0) {
        fprintf(stderr, "Failed to prepare upload directory\n");
        return 1;
    }

    int lfd = create_listen_socket(SERVER_PORT);
    if (lfd < 0) {
        close(dirfd);
        return 1;
    }

    server_thread_arg_t arg;
    memset(&arg, 0, sizeof(arg));
    arg.srv.fd = lfd;
    arg.srv.dirfd = dirfd;
    arg.srv.max_upload = MAX_UPLOAD;
    arg.max_requests = 5; // we'll run 5 test cases

    thrd_t thr;
    if (thrd_create(&thr, server_thread, &arg) != thrd_success) {
        fprintf(stderr, "Failed to start server thread\n");
        close(lfd);
        close(dirfd);
        return 1;
    }

    // Tiny delay to ensure the server is listening
    struct timespec ts = { .tv_sec = 0, .tv_nsec = 200 * 1000 * 1000 };
    nanosleep(&ts, NULL);

    // Run 5 test cases:
    test_get_index(SERVER_PORT);
    test_post_small_file(SERVER_PORT);
    test_post_bad_name(SERVER_PORT);
    test_post_too_large(SERVER_PORT);
    test_put_method(SERVER_PORT);

    // Join server thread
    thrd_join(thr, NULL);

    close(lfd);
    close(dirfd);
    return 0;
}
