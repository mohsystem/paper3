// Secure image uploader in C: reads an image from a trusted input directory,
// Base64-encodes it, and writes the encoded content to a file in a trusted output directory.
// Demonstrates safe path handling, input validation, atomic write via temp file + rename,
// and size bounds checks.
//
// Build: cc -std=c11 -Wall -Wextra -O2 upload_image.c -o upload_image
// Run:   ./upload_image

#define _POSIX_C_SOURCE 200809L
#include <errno.h>
#include <fcntl.h>
#include <limits.h>
#include <stdbool.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <unistd.h>
#include <time.h>
#include <sys/time.h>

#ifndef O_NOFOLLOW
#define O_NOFOLLOW 0
#endif

// Policy limits
#define MAX_INPUT_BYTES (10U * 1024U * 1024U)     // 10 MiB max upload
#define MAX_FILENAME_LEN 255

// ---------- Utility: constant-time min ----------
static size_t ct_min_size(size_t a, size_t b) {
    return (a < b) ? a : b;
}

// ---------- Filename validation ----------
// Allow list: A-Z, a-z, 0-9, '-', '_', '.', must be 1..255 chars, not "." or "..".
static bool is_sane_filename(const char *name) {
    if (name == NULL) return false;
    size_t len = strnlen(name, MAX_FILENAME_LEN + 1);
    if (len == 0 || len > MAX_FILENAME_LEN) return false;
    if ((len == 1 && name[0] == '.') || (len == 2 && name[0] == '.' && name[1] == '.')) return false;

    for (size_t i = 0; i < len; i++) {
        unsigned char c = (unsigned char)name[i];
        bool ok =
            (c >= 'A' && c <= 'Z') ||
            (c >= 'a' && c <= 'z') ||
            (c >= '0' && c <= '9') ||
            c == '-' || c == '_' || c == '.';
        if (!ok) return false;
    }
    return true;
}

// ---------- Open directory without following symlinks ----------
static int open_dir_nofollow(const char *path) {
    if (path == NULL) return -1;
    int dfd = open(path, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
    if (dfd < 0) return -1;

    struct stat st;
    if (fstat(dfd, &st) != 0) {
        int e = errno;
        close(dfd);
        errno = e;
        return -1;
    }
    if (!S_ISDIR(st.st_mode)) {
        close(dfd);
        errno = ENOTDIR;
        return -1;
    }
    return dfd;
}

// ---------- Open regular file for reading from a directory fd ----------
static int open_reg_read_at(int dirfd, const char *name, off_t *size_out) {
    if (!is_sane_filename(name)) {
        errno = EINVAL;
        return -1;
    }
    int fd = openat(dirfd, name, O_RDONLY | O_CLOEXEC | O_NOFOLLOW);
    if (fd < 0) return -1;

    struct stat st;
    if (fstat(fd, &st) != 0) {
        int e = errno;
        close(fd);
        errno = e;
        return -1;
    }
    if (!S_ISREG(st.st_mode)) {
        close(fd);
        errno = EINVAL;
        return -1;
    }
    if (st.st_size < 0 || (uint64_t)st.st_size > (uint64_t)MAX_INPUT_BYTES) {
        close(fd);
        errno = EFBIG;
        return -1;
    }
    if (size_out) *size_out = st.st_size;
    return fd;
}

// ---------- Read entire file into memory ----------
static int read_file_fd(int fd, off_t size, unsigned char **buf_out, size_t *len_out) {
    if (!buf_out || !len_out) {
        errno = EINVAL;
        return -1;
    }
    *buf_out = NULL;
    *len_out = 0;

    size_t n = (size_t)size;
    if (n > MAX_INPUT_BYTES) {
        errno = EFBIG;
        return -1;
    }
    unsigned char *buf = (unsigned char *)malloc(n ? n : 1);
    if (!buf && n != 0) {
        errno = ENOMEM;
        return -1;
    }

    size_t off = 0;
    while (off < n) {
        ssize_t r = read(fd, buf + off, n - off);
        if (r < 0) {
            int e = errno;
            free(buf);
            errno = e;
            return -1;
        }
        if (r == 0) break;
        off += (size_t)r;
    }
    if (off != n) {
        free(buf);
        errno = EIO;
        return -1;
    }
    *buf_out = buf;
    *len_out = n;
    return 0;
}

// ---------- Base64 encoding ----------
static int b64_encode_buf(const unsigned char *in, size_t inlen, char **out, size_t *outlen) {
    if (!out || !outlen) {
        errno = EINVAL;
        return -1;
    }
    *out = NULL;
    *outlen = 0;
    if (inlen > (SIZE_MAX / 4u) * 3u) { // conservative overflow check
        errno = EOVERFLOW;
        return -1;
    }
    size_t full_chunks = inlen / 3u;
    size_t rem = inlen % 3u;
    size_t enc_len = full_chunks * 4u + (rem ? 4u : 0u);

    if (enc_len > SIZE_MAX - 1u) {
        errno = EOVERFLOW;
        return -1;
    }
    char *outbuf = (char *)malloc(enc_len + 1u);
    if (!outbuf) {
        errno = ENOMEM;
        return -1;
    }

    static const char tbl[] =
        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

    size_t i = 0, j = 0;
    while (i + 3u <= inlen) {
        uint32_t v = ((uint32_t)in[i] << 16) | ((uint32_t)in[i + 1] << 8) | (uint32_t)in[i + 2];
        outbuf[j++] = tbl[(v >> 18) & 0x3F];
        outbuf[j++] = tbl[(v >> 12) & 0x3F];
        outbuf[j++] = tbl[(v >> 6) & 0x3F];
        outbuf[j++] = tbl[v & 0x3F];
        i += 3u;
    }
    if (rem == 1u) {
        uint32_t v = ((uint32_t)in[i]) << 16;
        outbuf[j++] = tbl[(v >> 18) & 0x3F];
        outbuf[j++] = tbl[(v >> 12) & 0x3F];
        outbuf[j++] = '=';
        outbuf[j++] = '=';
    } else if (rem == 2u) {
        uint32_t v = (((uint32_t)in[i]) << 16) | (((uint32_t)in[i + 1]) << 8);
        outbuf[j++] = tbl[(v >> 18) & 0x3F];
        outbuf[j++] = tbl[(v >> 12) & 0x3F];
        outbuf[j++] = tbl[(v >> 6) & 0x3F];
        outbuf[j++] = '=';
    }

    outbuf[enc_len] = '\0';
    *out = outbuf;
    *outlen = enc_len;
    return 0;
}

// ---------- Safe write (loop until all bytes written) ----------
static int write_all(int fd, const void *buf, size_t len) {
    const unsigned char *p = (const unsigned char *)buf;
    size_t off = 0;
    while (off < len) {
        ssize_t w = write(fd, p + off, len - off);
        if (w < 0) {
            if (errno == EINTR) continue;
            return -1;
        }
        if (w == 0) {
            errno = EIO;
            return -1;
        }
        off += (size_t)w;
    }
    return 0;
}

// ---------- Random bytes from /dev/urandom ----------
static int get_random_bytes(unsigned char *out, size_t len) {
    if (!out && len != 0) {
        errno = EINVAL;
        return -1;
    }
    int ur = open("/dev/urandom", O_RDONLY | O_CLOEXEC);
    if (ur < 0) return -1;
    size_t off = 0;
    while (off < len) {
        ssize_t r = read(ur, out + off, len - off);
        if (r < 0) {
            if (errno == EINTR) continue;
            int e = errno;
            close(ur);
            errno = e;
            return -1;
        }
        if (r == 0) {
            close(ur);
            errno = EIO;
            return -1;
        }
        off += (size_t)r;
    }
    close(ur);
    return 0;
}

// ---------- Create a temporary file name and open it ----------
static int create_temp_out(int dirfd, char *tmpname, size_t tmpname_size) {
    if (!tmpname || tmpname_size < 32) {
        errno = EINVAL;
        return -1;
    }

    // Template: ".tmp_upload_<16 hex>"
    for (int attempt = 0; attempt < 32; attempt++) {
        unsigned char rnd[8];
        if (get_random_bytes(rnd, sizeof(rnd)) != 0) return -1;

        static const char hex[] = "0123456789abcdef";
        char suffix[17];
        for (size_t i = 0; i < sizeof(rnd); i++) {
            suffix[i * 2] = hex[(rnd[i] >> 4) & 0xF];
            suffix[i * 2 + 1] = hex[rnd[i] & 0xF];
        }
        suffix[16] = '\0';

        int n = snprintf(tmpname, tmpname_size, ".tmp_upload_%s", suffix);
        if (n < 0 || (size_t)n >= tmpname_size) {
            errno = ENAMETOOLONG;
            return -1;
        }

        int fd = openat(dirfd, tmpname, O_WRONLY | O_CREAT | O_EXCL | O_CLOEXEC | O_NOFOLLOW, 0600);
        if (fd >= 0) {
            // Validate it's a regular file
            struct stat st;
            if (fstat(fd, &st) != 0) {
                int e = errno;
                close(fd);
                unlinkat(dirfd, tmpname, 0);
                errno = e;
                return -1;
            }
            if (!S_ISREG(st.st_mode)) {
                close(fd);
                unlinkat(dirfd, tmpname, 0);
                errno = EINVAL;
                return -1;
            }
            return fd;
        }
        if (errno != EEXIST) {
            return -1;
        }
    }
    errno = EEXIST;
    return -1;
}

static int fsync_dirfd(int dirfd) {
    int dfd = dup(dirfd);
    if (dfd < 0) return -1;
    int r1 = fsync(dfd);
    int e = errno;
    close(dfd);
    if (r1 != 0) {
        errno = e;
        return -1;
    }
    return 0;
}

// ---------- Public API: upload_image from input file to output base64 file ----------
int upload_image(const char *input_base_dir, const char *input_name,
                 const char *output_base_dir, const char *output_name) {
    if (!input_base_dir || !input_name || !output_base_dir || !output_name) {
        errno = EINVAL;
        return -1;
    }
    if (!is_sane_filename(input_name) || !is_sane_filename(output_name)) {
        errno = EINVAL;
        return -1;
    }

    int in_dfd = -1, out_dfd = -1, in_fd = -1, tmp_fd = -1;
    unsigned char *img = NULL;
    size_t img_len = 0;
    char *b64 = NULL;
    size_t b64_len = 0;
    char tmpname[64];
    int rc = -1;

    in_dfd = open_dir_nofollow(input_base_dir);
    if (in_dfd < 0) goto cleanup;

    out_dfd = open_dir_nofollow(output_base_dir);
    if (out_dfd < 0) goto cleanup;

    off_t fsize = 0;
    in_fd = open_reg_read_at(in_dfd, input_name, &fsize);
    if (in_fd < 0) goto cleanup;

    if (read_file_fd(in_fd, fsize, &img, &img_len) != 0) goto cleanup;

    if (b64_encode_buf(img, img_len, &b64, &b64_len) != 0) goto cleanup;

    tmp_fd = create_temp_out(out_dfd, tmpname, sizeof(tmpname));
    if (tmp_fd < 0) goto cleanup;

    if (write_all(tmp_fd, b64, b64_len) != 0) goto cleanup;
    if (fsync(tmp_fd) != 0) goto cleanup;
    if (close(tmp_fd) != 0) {
        tmp_fd = -1;
        goto cleanup;
    }
    tmp_fd = -1;

    // Atomic rename to final name
    if (renameat(out_dfd, tmpname, out_dfd, output_name) != 0) goto cleanup;
    if (fsync_dirfd(out_dfd) != 0) goto cleanup;

    rc = 0;

cleanup:
    if (tmp_fd >= 0) {
        // Best-effort cleanup
        close(tmp_fd);
    }
    if (rc != 0 && out_dfd >= 0) {
        // Remove temp file if it exists
        unlinkat(out_dfd, tmpname, 0);
    }
    if (in_fd >= 0) close(in_fd);
    if (in_dfd >= 0) close(in_dfd);
    if (out_dfd >= 0) close(out_dfd);
    if (img) {
        // zeroize not strictly required; image data is not sensitive, but we clear to be tidy.
        memset(img, 0, img_len);
        free(img);
    }
    if (b64) {
        memset(b64, 0, b64_len);
        free(b64);
    }
    if (rc != 0) {
        // Generic failure; errno already set by failing operation.
        return -1;
    }
    return 0;
}

// ---------- Public API: upload from in-memory buffer to output base64 file ----------
int upload_image_from_buffer(const unsigned char *buffer, size_t buffer_len,
                             const char *output_base_dir, const char *output_name) {
    if (!buffer && buffer_len != 0) { errno = EINVAL; return -1; }
    if (!output_base_dir || !output_name) { errno = EINVAL; return -1; }
    if (!is_sane_filename(output_name)) { errno = EINVAL; return -1; }
    if (buffer_len > MAX_INPUT_BYTES) { errno = EFBIG; return -1; }

    int out_dfd = -1, tmp_fd = -1;
    char *b64 = NULL;
    size_t b64_len = 0;
    char tmpname[64];
    int rc = -1;

    out_dfd = open_dir_nofollow(output_base_dir);
    if (out_dfd < 0) goto cleanup;

    if (b64_encode_buf(buffer, buffer_len, &b64, &b64_len) != 0) goto cleanup;

    tmp_fd = create_temp_out(out_dfd, tmpname, sizeof(tmpname));
    if (tmp_fd < 0) goto cleanup;

    if (write_all(tmp_fd, b64, b64_len) != 0) goto cleanup;
    if (fsync(tmp_fd) != 0) goto cleanup;
    if (close(tmp_fd) != 0) {
        tmp_fd = -1;
        goto cleanup;
    }
    tmp_fd = -1;

    if (renameat(out_dfd, tmpname, out_dfd, output_name) != 0) goto cleanup;
    if (fsync_dirfd(out_dfd) != 0) goto cleanup;

    rc = 0;

cleanup:
    if (tmp_fd >= 0) close(tmp_fd);
    if (rc != 0 && out_dfd >= 0) unlinkat(out_dfd, tmpname, 0);
    if (out_dfd >= 0) close(out_dfd);
    if (b64) {
        memset(b64, 0, b64_len);
        free(b64);
    }
    if (rc != 0) return -1;
    return 0;
}

// ---------- Helpers for tests ----------
static int ensure_dir(const char *path) {
    if (mkdir(path, 0700) == 0) return 0;
    if (errno == EEXIST) {
        struct stat st;
        if (stat(path, &st) == 0 && S_ISDIR(st.st_mode)) return 0;
    }
    return -1;
}

static int create_file_in_dir(const char *dir, const char *name, const unsigned char *data, size_t len) {
    if (!is_sane_filename(name)) { errno = EINVAL; return -1; }
    int dfd = open_dir_nofollow(dir);
    if (dfd < 0) return -1;
    int fd = openat(dfd, name, O_WRONLY | O_CREAT | O_TRUNC | O_CLOEXEC | O_NOFOLLOW, 0600);
    if (fd < 0) {
        int e = errno;
        close(dfd);
        errno = e;
        return -1;
    }
    int rc = 0;
    if (write_all(fd, data, len) != 0) rc = -1;
    int e = errno;
    close(fd);
    close(dfd);
    errno = e;
    return rc;
}

static int create_large_file_in_dir(const char *dir, const char *name, size_t total_bytes) {
    if (!is_sane_filename(name)) { errno = EINVAL; return -1; }
    int dfd = open_dir_nofollow(dir);
    if (dfd < 0) return -1;
    int fd = openat(dfd, name, O_WRONLY | O_CREAT | O_TRUNC | O_CLOEXEC | O_NOFOLLOW, 0600);
    if (fd < 0) {
        int e = errno;
        close(dfd);
        errno = e;
        return -1;
    }
    unsigned char buf[4096];
    for (size_t i = 0; i < sizeof(buf); i++) buf[i] = (unsigned char)(i & 0xFF);
    size_t remaining = total_bytes;
    int rc = 0;
    while (remaining > 0) {
        size_t chunk = ct_min_size(remaining, sizeof(buf));
        if (write_all(fd, buf, chunk) != 0) { rc = -1; break; }
        remaining -= chunk;
    }
    int e = errno;
    close(fd);
    close(dfd);
    errno = e;
    return rc;
}

static void print_result(const char *label, int rc) {
    const char *status = (rc == 0) ? "OK" : "FAIL";
    // Use constant format string; do not treat user data as format string.
    printf("[%s] %s\n", status, label);
}

int main(void) {
    // Prepare temporary input and output directories
    char in_tmpl[] = "./inXXXXXX";
    char out_tmpl[] = "./outXXXXXX";
    if (!mkdtemp(in_tmpl) || !mkdtemp(out_tmpl)) {
        printf("[FAIL] Could not create temporary directories\n");
        return 1;
    }

    // Create sample input files
    const unsigned char img1[] = { 0x89, 0x50, 0x4E, 0x47, 0x00, 0x01, 0x02, 0x03 }; // fake PNG header + bytes
    const unsigned char img2[] = { 0xFF, 0xD8, 0xFF, 0xEE, 0x12, 0x34 }; // fake JPEG header + bytes

    if (create_file_in_dir(in_tmpl, "small1.bin", img1, sizeof(img1)) != 0) {
        printf("[FAIL] Setup small1.bin\n");
        return 1;
    }
    if (create_file_in_dir(in_tmpl, "small2.bin", img2, sizeof(img2)) != 0) {
        printf("[FAIL] Setup small2.bin\n");
        return 1;
    }
    // Large file: 11 MiB > MAX_INPUT_BYTES (10 MiB) to trigger rejection
    if (create_large_file_in_dir(in_tmpl, "too_large.bin", 11U * 1024U * 1024U) != 0) {
        printf("[FAIL] Setup too_large.bin\n");
        return 1;
    }

    // Test 1: Valid upload
    int rc1 = upload_image(in_tmpl, "small1.bin", out_tmpl, "image1.b64");
    print_result("upload small1.bin -> image1.b64", rc1);

    // Test 2: Valid upload with allowed filename chars
    int rc2 = upload_image(in_tmpl, "small2.bin", out_tmpl, "img-02_Test.b64");
    print_result("upload small2.bin -> img-02_Test.b64", rc2);

    // Test 3: Invalid output filename (traversal attempt)
    int rc3 = upload_image(in_tmpl, "small1.bin", out_tmpl, "..");
    print_result("reject invalid output name '..'", rc3);

    // Test 4: Oversize input file should be rejected
    int rc4 = upload_image(in_tmpl, "too_large.bin", out_tmpl, "large.b64");
