from werkzeug.exceptions import RequestEntityTooLarge

# Configuration
# It's recommended to read these from environment variables or a config file
# For this example, they are defined as constants.
UPLOAD_FOLDER = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'uploads')
ALLOWED_EXTENSIONS = {'txt', 'pdf', 'png', 'jpg', 'jpeg', 'gif'}
# Set a reasonable file size limit (e.g., 16 MB)
MAX_FILE_SIZE = 16 * 1024 * 1024 

app = Flask(__name__)
# It's crucial to set a secret key for flashing messages.
# In a real application, this should be a long, random, and secret value.
# Never hardcode secrets in source code.
app.config['SECRET_KEY'] = os.environ.get('FLASK_SECRET_KEY', os.urandom(24))
app.config['UPLOAD_FOLDER'] = UPLOAD_FOLDER
# Use Flask's built-in mechanism to limit request size.
app.config['MAX_CONTENT_LENGTH'] = MAX_FILE_SIZE

# Ensure the upload directory exists.
os.makedirs(app.config['UPLOAD_FOLDER'], exist_ok=True)

def is_allowed_file(filename):
    """
    Checks if the file's extension is in the allowed list.
    """
    return '.' in filename and \
           filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS

@app.route('/', methods=['GET', 'POST'])
def upload_file():
    """
    Handles file uploads. It displays an upload form on GET requests and
    processes the uploaded file on POST requests.
    """
    if request.method == 'POST':
        # 1. Check if the post request has the file part
        if 'file' not in request.files:
            flash('No file part in the request.')
            return redirect(request.url)
        
        file = request.files['file']

        # 2. Check if a file was selected
        if file.filename == '':
            flash('No file selected.')
            return redirect(request.url)

        # 3. Validate file type and sanitize filename
        if file and is_allowed_file(file.filename):
            # Sanitize the filename to prevent security risks like directory traversal.
            # Rules: 5, 7, 9, 43
            original_filename = secure_filename(file.filename)
            file_ext = original_filename.rsplit('.', 1)[1] if '.' in original_filename else ''

            # Generate a new unique filename to prevent overwrites and filename-based attacks.
            # Using UUID is a robust way to ensure filename uniqueness.
            unique_filename = f"{uuid.uuid4()}.{file_ext}"

            # 4. Construct a safe and absolute path for the file.
            # Rules: 44, 45
            destination_folder = os.path.abspath(app.config['UPLOAD_FOLDER'])
            destination_path = os.path.join(destination_folder, unique_filename)

            # 5. Final security check: ensure the resolved path is within the UPLOAD_FOLDER.
            # This is a defense-in-depth measure against sophisticated path traversal attacks.
            if os.path.commonprefix([destination_path, destination_folder]) != destination_folder:
                # This should theoretically never be reached if secure_filename works correctly.
                flash('Invalid path detected.')
                return redirect(request.url)

            try:
                # 6. Save the file securely.
                # The file is saved directly to its final destination. No TOCTOU vulnerability.
                # Rules: 49, 50, 51, 63
                file.save(destination_path)
                flash(f'File "{original_filename}" uploaded successfully as "{unique_filename}".')
                return redirect(url_for('upload_file'))
            except Exception as e:
