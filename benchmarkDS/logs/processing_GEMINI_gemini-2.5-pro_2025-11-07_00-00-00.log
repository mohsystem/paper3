            flash('Invalid file path.')
            return redirect(url_for('upload_form'))

        try:
            # Rule #59: Handle exceptions during file operations.
            file.save(save_path)
            # Rule #71: Return generic success message.
            flash(f'File "{original_filename}" uploaded successfully.')
