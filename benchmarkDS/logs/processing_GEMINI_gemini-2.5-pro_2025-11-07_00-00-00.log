from werkzeug.utils import secure_filename
from werkzeug.exceptions import RequestEntityTooLarge
from flask_wtf.csrf import CSRFProtect

# --- Configuration ---

# In a real application, load this from a config file or environment variables
# Generate a key with: python -c 'import secrets; print(secrets.token_hex(16))'
# RULE #7, #59: Never hard code secrets.
SECRET_KEY = os.environ.get('SECRET_KEY', secrets.token_hex(16))

# Define the upload folder. Use Path for OS-independent path handling.
UPLOAD_FOLDER = Path(__file__).parent / 'uploads'

# RULE #2: Use allow lists over block lists.
# Define allowed file extensions.
ALLOWED_EXTENSIONS = {'txt', 'pdf', 'png', 'jpg', 'jpeg', 'gif'}

# Define a reasonable maximum file size (e.g., 16 MB)
# RULE #12, #22: Enforce maximum sizes before processing.
MAX_CONTENT_LENGTH = 16 * 1024 * 1024  # 16 MB

# --- Application Setup ---

app = Flask(__name__)
app.config['UPLOAD_FOLDER'] = str(UPLOAD_FOLDER)
app.config['MAX_CONTENT_LENGTH'] = MAX_CONTENT_LENGTH
app.config['SECRET_KEY'] = SECRET_KEY

# Enable CSRF protection for all POST requests
csrf = CSRFProtect(app)

# Configure logging
# RULE #8, #66: Use constant format strings for logging.
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')


def is_allowed_file(filename: str) -> bool:
    """
    Checks if a filename has an allowed extension.
    RULE #1: Validate every external input.
    """
    # An empty filename is not allowed.
    if not filename:
        return False
    # Check if the file has an extension and if it's in the allowed list.
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS


@app.route('/', methods=['GET', 'POST'])
def upload_file():
    """
    Handles file uploads via a web form.
    """
    if request.method == 'POST':
        # --- Input Validation ---
        # RULE #5: Treat all input as untrusted.
        # Check if the post request has the file part
        if 'file' not in request.files:
            flash('No file part in the request.')
            return redirect(request.url)

        file = request.files['file']

        # If the user does not select a file, the browser submits an
        # empty part without a filename.
        if file.filename == '':
            flash('No selected file.')
            return redirect(request.url)

        # --- Security Checks ---
        if file and is_allowed_file(file.filename):
            # RULE #3, #39: Sanitize input used in path construction.
            # Use secure_filename to prevent path traversal attacks.
            # Example: '../.ssh/id_rsa' becomes '..ssh_id_rsa'
            filename = secure_filename(file.filename)
            
            # Construct the full path
            # RULE #40: Accept a base directory and normalize user paths.
            upload_folder_abs = os.path.abspath(app.config['UPLOAD_FOLDER'])
            filepath = os.path.join(upload_folder_abs, filename)
            
            # RULE #41: Reject any path that resolves outside the base directory.
            # Defense-in-depth: Ensure the final path is within the UPLOAD_FOLDER
            if not os.path.abspath(filepath).startswith(upload_folder_abs):
                app.logger.error("Path traversal attempt detected for filename: %s", file.filename)
                # RULE #67: Return generic messages.
                abort(HTTPStatus.BAD_REQUEST, "Invalid filename provided.")

            try:
                # Save the file. The framework handles temporary storage and moving.
                file.save(filepath)
                # Jinja2's auto-escaping handles XSS when rendering filename
                flash(f'File "{filename}" uploaded successfully!')
                app.logger.info("File '%s' saved to '%s'", filename, filepath)
                return redirect(url_for('upload_file'))
            except Exception as e:
                app.logger.error("Failed to save file '%s'. Error: %s", filename, e)
                flash('An error occurred while saving the file.')
                return redirect(request.url)
        else:
            flash('File type not allowed.')
            return redirect(request.url)

    # For GET requests, render the upload form.
    # Jinja2 auto-escapes content, preventing XSS.
    return render_template_string('''
    <!doctype html>
    <title>File Upload</title>
    <h1>Upload a New File</h1>
    {% with messages = get_flashed_messages() %}
      {% if messages %}
        <ul class=flashes>
        {% for message in messages %}
          <li>{{ message }}</li>
        {% endfor %}
        </ul>
      {% endif %}
    {% endwith %}
    <form method=post enctype=multipart/form-data>
      <!-- CSRF token is essential for security -->
      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}"/>
      <input type=file name=file>
      <input type=submit value=Upload>
    </form>
    ''')

@app.errorhandler(413)
@app.errorhandler(RequestEntityTooLarge)
def handle_file_too_large(e):
    """
    Custom error handler for files that exceed the size limit.
    """
    # RULE #67: Do not leak internal details in error messages.
    flash(f'File is too large. The maximum allowed size is {MAX_CONTENT_LENGTH // 1024 // 1024} MB.')
    return redirect(request.url)


def main():
    """
    Main function to run the application and perform initial setup.
    """
    # Create the upload directory if it doesn't exist
    try:
        UPLOAD_FOLDER.mkdir(parents=True, exist_ok=True)
    except OSError as e:
        app.logger.error("Could not create upload directory '%s'. Error: %s", UPLOAD_FOLDER, e)
        # Exit if we can't create the essential upload directory
        return

    # In a production environment, use a proper WSGI server like Gunicorn or uWSGI.
    # The debug flag should be False in production.
    # RULE #69: Use production-ready configurations.
    print("Starting Flask server. To test, open http://127.0.0.1:5000 in your browser.")
    print("---")
    print("Test Cases:")
    print("1. Upload a valid file (e.g., test.txt, image.jpg). Expected: Success.")
    print("2. Upload a disallowed file (e.g., script.js, program.exe). Expected: 'File type not allowed' error.")
    print("3. Submit the form with no file selected. Expected: 'No selected file' error.")
    print("4. Upload a file with a path traversal name (e.g., create a file named '../../test.txt'). Expected: Uploads as 'test.txt' safely.")
    print("5. Upload a file larger than 16MB. Expected: 'File is too large' error.")
    print("---")

    app.run(host='0.0.0.0', port=5000, debug=False)

if __name__ == '__main__':
    main()
