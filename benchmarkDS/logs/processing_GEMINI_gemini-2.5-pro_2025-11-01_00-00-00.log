import java.io.IOException;
import java.io.InputStream;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.nio.file.StandardCopyOption;
import java.security.SecureRandom;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.UUID;
import java.util.regex.Pattern;
import java.util.stream.Stream;

public class Lse64 {

    // Define a secure base directory for uploads.
    // In a real application, this should be a configuration parameter.
    private static final String UPLOAD_DIR_NAME = "uploads";
    private static final Path UPLOAD_DIRECTORY = Paths.get(System.getProperty("user.dir"), UPLOAD_DIR_NAME).toAbsolutePath();

    // Define a maximum file size to prevent denial-of-service attacks (e.g., 10MB).
    private static final long MAX_FILE_SIZE = 10 * 1024 * 1024;

    // Pattern to validate filenames, allowing alphanumeric characters, dots, hyphens, and underscores.
    private static final Pattern FILENAME_PATTERN = Pattern.compile("^[a-zA-Z0-9._-]+$");

    /**
     * Saves an uploaded PDF file to a secure location and records its path in a MySQL database.
     *
     * @param fileInputStream  The InputStream of the uploaded file content.
     * @param originalFilename The original filename provided by the user.
     * @param conn             The database connection.
     * @return The relative path of the saved file, or null on failure.
     */
    public static String upload_pdf(InputStream fileInputStream, String originalFilename, Connection conn) {
        // Rule #1: Validate and sanitize all input.
        if (originalFilename == null || originalFilename.trim().isEmpty()) {
            System.err.println("Error: Original filename is null or empty.");
            return null;
        }

        // Sanitize the filename to remove any path components.
        String sanitizedFilename = Paths.get(originalFilename).getFileName().toString();

        // Validate filename characters and extension.
        if (!FILENAME_PATTERN.matcher(sanitizedFilename).matches() || !sanitizedFilename.toLowerCase().endsWith(".pdf")) {
            System.err.println("Error: Invalid filename or file type. Only .pdf files are allowed.");
            return null;
        }

        try {
            // Ensure the upload directory exists.
            if (!Files.exists(UPLOAD_DIRECTORY)) {
                Files.createDirectories(UPLOAD_DIRECTORY);
            }

            // Generate a unique filename to prevent overwrites and hide internal file structure.
            String uniqueFilename = UUID.randomUUID().toString() + ".pdf";
            Path destinationPath = UPLOAD_DIRECTORY.resolve(uniqueFilename);

            // Rule #5: Ensure the final path is within the intended directory.
            if (!destinationPath.toAbsolutePath().normalize().startsWith(UPLOAD_DIRECTORY.toAbsolutePath().normalize())) {
                System.err.println("Error: Directory traversal attempt detected.");
                return null;
            }

            // Rule #3 & #7: Limit file size by reading into a temporary location and checking size
            // We use a temporary file to avoid partial writes of large files.
            Path tempFile = Files.createTempFile(UPLOAD_DIRECTORY, "upload-", ".tmp");
            long bytesCopied = 0;
            try (InputStream is = fileInputStream) {
                bytesCopied = Files.copy(is, tempFile, StandardCopyOption.REPLACE_EXISTING);
            }

            if (bytesCopied > MAX_FILE_SIZE) {
                Files.delete(tempFile);
                System.err.println("Error: File size exceeds the maximum limit of " + MAX_FILE_SIZE + " bytes.");
                return null;
            }

            // Rule #6: Atomically move the file to its final destination.
            Files.move(tempFile, destinationPath, StandardCopyOption.ATOMIC_MOVE);

            // The path stored in the database should be relative for portability.
            String relativePath = Paths.get(UPLOAD_DIR_NAME).resolve(uniqueFilename).toString().replace('\\', '/');

            // Rule #2: Use PreparedStatement to prevent SQL injection.
            String sql = "INSERT INTO files (filepath, original_filename) VALUES (?, ?)";
            try (PreparedStatement pstmt = conn.prepareStatement(sql)) {
                pstmt.setString(1, relativePath);
                pstmt.setString(2, sanitizedFilename);
                pstmt.executeUpdate();
            }

            System.out.println("Successfully uploaded " + sanitizedFilename + " to " + relativePath);
            return relativePath;

        } catch (IOException e) {
            System.err.println("File I/O error: " + e.getMessage());
            return null;
        } catch (SQLException e) {
            System.err.println("Database error: " + e.getMessage());
            // In a real application, you might need to clean up the saved file if the DB operation fails.
            return null;
        }
    }

    // --- Mock Database and Test Cases ---
