    // Test Case 4: Malicious filename
    printf("\n--- Test Case 4: Malicious filename ---\n");
    char* path4 = upload_pdf(valid_pdf, sizeof(valid_pdf) - 1, "../../etc/passwd.pdf");
    if (path4) {
        printf("Success! File stored at: %s (original malicious name was handled).\n", path4);
        free(path4);
    } else {
        printf("Failure as expected or something went wrong.\n");
    }

    // Test Case 5: Empty file content
    printf("\n--- Test Case 5: Empty file content ---\n");
    char* path5 = upload_pdf("", 0, "empty.pdf");
    if (!path5) {
