    std::cout << "Result: " << (!savedPath2.empty() ? "SUCCESS, path: " + savedPath2 : "FAILURE (Expected, sanitized name used)") << std::endl;
    std::cout << "---" << std::endl;

    // Test Case 3: File too large
    std::cout << "Test 3: Uploading a file that is too large..." << std::endl;
    std::string savedPath3 = uploadPdf("large_file.pdf", largePdfContent);
    std::cout << "Result: " << (savedPath3.empty() ? "FAILURE (Expected)" : "SUCCESS") << std::endl;
