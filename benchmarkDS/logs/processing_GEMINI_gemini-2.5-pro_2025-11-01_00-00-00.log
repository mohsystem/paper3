// --- Database Configuration ---
const std::string DB_HOST = std::getenv("DB_HOST") ? std::getenv("DB_HOST") : "tcp://127.0.0.1:3306";
const std::string DB_USER = std::getenv("DB_USER") ? std::getenv("DB_USER") : "user";
const std::string DB_PASS = std::getenv("DB_PASS") ? std::getenv("DB_PASS") : "password";
const std::string DB_NAME = std::getenv("DB_NAME") ? std::getenv("DB_NAME") : "filedb";

// --- File Upload Configuration ---
const std::string UPLOADS_DIR_NAME = "uploads";
const size_t MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB
const size_t MAX_FILENAME_LENGTH = 100;
const std::regex VALID_FILENAME_PATTERN("^[a-zA-Z0-9._-]+$");

// Generates a simple UUID-like string. Not cryptographically secure, but fine for unique filenames.
std::string generate_uuid() {
    static const char alphanum[] = "0123456789abcdef";
    std::string s(36, ' ');
    for (int i = 0; i < 36; ++i) {
        if (i == 8 || i == 13 || i == 18 || i == 23) {
            s[i] = '-';
        } else {
            s[i] = alphanum[rand() % (sizeof(alphanum) - 1)];
        }
    }
    return s;
}

/**
 * Uploads a PDF file by saving its content and recording its path in a database.
 * @param fileName The original name of the uploaded file.
 * @param fileContent The byte content of the file.
 * @return The absolute path of the saved file, or an empty string on failure.
 */
std::string uploadPdf(const std::string& fileName, const std::vector<char>& fileContent) {
    // 1. Input Validation
    if (fileName.empty()) {
        std::cerr << "Error: File name cannot be empty." << std::endl;
        return "";
    }
    if (fileContent.empty()) {
        std::cerr << "Error: File content cannot be empty." << std::endl;
        return "";
    }
    if (fileContent.size() > MAX_FILE_SIZE) {
        std::cerr << "Error: File size " << fileContent.size() << " exceeds limit of " << MAX_FILE_SIZE << " bytes." << std::endl;
        return "";
    }

    // 2. Sanitize filename
    std::string sanitizedFileName = std::filesystem::path(fileName).filename().string();
    if (sanitizedFileName.length() > MAX_FILENAME_LENGTH) {
        std::cerr << "Error: Filename length exceeds limit." << std::endl;
        return "";
    }
    std::string lowerCaseFileName = sanitizedFileName;
    std::transform(lowerCaseFileName.begin(), lowerCaseFileName.end(), lowerCaseFileName.begin(), ::tolower);
    if (!std::regex_match(sanitizedFileName, VALID_FILENAME_PATTERN) || lowerCaseFileName.rfind(".pdf") == std::string::npos) {
        std::cerr << "Error: Invalid filename. Must be a .pdf and contain only safe characters." << std::endl;
        return "";
    }
    
    // Use a unique name to avoid conflicts
    std::string uniqueFileName = generate_uuid() + ".pdf";
    
    std::filesystem::path uploadsDir = std::filesystem::current_path() / UPLOADS_DIR_NAME;
    std::filesystem::path filePath = uploadsDir / uniqueFileName;

    // Security check: ensure the final path is within the intended directory
    auto canonicalUploadsDir = std::filesystem::weakly_canonical(uploadsDir);
    auto canonicalFilePath = std::filesystem::weakly_canonical(filePath);
    if (canonicalFilePath.string().rfind(canonicalUploadsDir.string(), 0) != 0) {
        std::cerr << "Error: Path traversal attempt detected and blocked." << std::endl;
        return "";
    }

    // 3. Save the file to the filesystem securely (POSIX-specific)
    int fd = -1;
    try {
        std::filesystem::create_directories(uploadsDir);
        // Use O_CREAT | O_EXCL for atomic, secure file creation. Permissions are 0600.
        fd = open(filePath.c_str(), O_WRONLY | O_CREAT | O_EXCL, S_IRUSR | S_IWUSR);
        if (fd == -1) {
            perror("Error opening file for writing");
            return "";
        }
        
        ssize_t bytes_written = write(fd, fileContent.data(), fileContent.size());
        if (bytes_written < 0 || (size_t)bytes_written != fileContent.size()) {
             perror("Error writing to file");
             close(fd);
             std::filesystem::remove(filePath); // Cleanup
             return "";
        }
        close(fd);
    } catch (const std::filesystem::filesystem_error& e) {
        std::cerr << "Filesystem error: " << e.what() << std::endl;
        if(fd != -1) close(fd);
        return "";
    }

    // 4. Save the filepath to the database
    try {
        sql::Driver *driver = get_driver_instance();
        std::unique_ptr<sql::Connection> con(driver->connect(DB_HOST, DB_USER, DB_PASS));
        con->setSchema(DB_NAME);

        std::unique_ptr<sql::PreparedStatement> pstmt(con->prepareStatement("INSERT INTO files (filepath) VALUES (?)"));
        pstmt->setString(1, filePath.string());
        pstmt->executeUpdate();

        std::cout << "Successfully saved file to " << filePath.string() << " and recorded in DB." << std::endl;
        return filePath.string();
    } catch (sql::SQLException &e) {
        std::cerr << "Database error: " << e.what() << std::endl;
        // Cleanup: delete the orphaned file
        std::filesystem::remove(filePath);
        return "";
    }
}

int main() {
    srand(time(0)); // Seed for UUID generation
    std::cout << "Starting PDF upload tests..." << std::endl;
    std::cout << "NOTE: Ensure MySQL server is running and the database/table are set up." << std::endl;
