from pathlib import Path
from typing import Optional, Any

# Define a secure base directory for uploads.
# In a real application, this should be a configuration parameter.
UPLOAD_DIR_NAME = "uploads"
UPLOAD_DIRECTORY = Path(__file__).resolve().parent / UPLOAD_DIR_NAME

# Define a maximum file size to prevent denial-of-service attacks (e.g., 10MB).
MAX_FILE_SIZE = 10 * 1024 * 1024

# A strict regex for validating filenames. Allows alphanumeric, underscore, hyphen, and dot.
# It explicitly disallows path separators.
FILENAME_REGEX = re.compile(r"^[a-zA-Z0-9._-]+$")

def upload_pdf(file_content: bytes, original_filename: str, db_connection: Any) -> Optional[str]:
    """
    Saves an uploaded PDF file to a secure location and records its path in a MySQL database.

    Args:
        file_content: The binary content of the file.
        original_filename: The original filename from the user.
        db_connection: A connected database cursor provider (e.g., mysql.connector connection).

    Returns:
        The relative path of the saved file, or None on failure.
    """
    # Rule #1: Validate and sanitize all input.
    if not original_filename or not isinstance(original_filename, str):
        print("Error: Original filename is invalid.")
        return None

    if len(file_content) > MAX_FILE_SIZE:
        print(f"Error: File size exceeds the maximum limit of {MAX_FILE_SIZE} bytes.")
        return None

    # Sanitize the filename to remove any path components.
    sanitized_filename = Path(original_filename).name

    if not sanitized_filename.lower().endswith(".pdf") or not FILENAME_REGEX.match(sanitized_filename):
        print("Error: Invalid filename or file type. Only .pdf files with safe characters are allowed.")
        return None

    try:
        # Ensure the upload directory exists with appropriate permissions.
        UPLOAD_DIRECTORY.mkdir(mode=0o750, exist_ok=True)

        # Generate a unique filename to prevent overwrites.
        unique_filename = f"{uuid.uuid4()}.pdf"
        destination_path = UPLOAD_DIRECTORY.joinpath(unique_filename).resolve()

        # Rule #5: Double-check that the resolved path is within the UPLOAD_DIRECTORY.
        if UPLOAD_DIRECTORY.resolve() not in destination_path.parents:
            print("Error: Directory traversal attempt detected.")
            return None

        # Rule #6: Write to a temporary file first for atomicity.
        # Use a temporary file in the same directory to ensure atomic move works.
        fd, temp_path_str = tempfile.mkstemp(dir=UPLOAD_DIRECTORY)
        with os.fdopen(fd, 'wb') as temp_file:
            temp_file.write(file_content)
        
        # Atomically move the temporary file to the final destination.
        shutil.move(temp_path_str, destination_path)

        # The path stored in the database should be relative for portability.
        relative_path = Path(UPLOAD_DIR_NAME).joinpath(unique_filename).as_posix()

        # Rule #2: Use parameterized queries to prevent SQL injection.
        query = "INSERT INTO files (filepath, original_filename) VALUES (%s, %s)"
        cursor = db_connection.cursor(prepared=True)
        cursor.execute(query, (relative_path, sanitized_filename))
        db_connection.commit()
        cursor.close()

        print(f"Successfully uploaded {sanitized_filename} to {relative_path}")
        return relative_path

    except (IOError, OSError) as e:
        print(f"File I/O error: {e}")
        return None
    except mysql.connector.Error as e:
        print(f"Database error: {e}")
        # Consider cleaning up the created file if DB write fails.
        if 'destination_path' in locals() and destination_path.exists():
             destination_path.unlink()
        return None
    finally:
        if 'temp_path_str' in locals() and os.path.exists(temp_path_str):
            os.remove(temp_path_str)


