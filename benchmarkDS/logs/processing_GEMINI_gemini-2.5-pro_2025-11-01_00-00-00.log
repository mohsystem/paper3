#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>
#include <time.h>
#include <sys/stat.h>
#include <errno.h>

/*
 * NOTE: This code requires the MySQL C API client library (libmysqlclient).
 * You must have the library installed and link against it.
 * E.g., gcc your_file.c -o your_app `mysql_config --cflags --libs`
 *
 * The database interaction part is included for completeness but will fail
 * to compile/run without the library properly set up.
 */
#include <mysql/mysql.h>

// --- Configuration ---
// In a real application, these would be in a configuration file or environment variables.
#define UPLOADS_DIR "uploads"
#define MAX_FILE_SIZE (10 * 1024 * 1024) // 10 MB
#define MAX_PATH_LEN 256
#define MAX_FILENAME_LEN 128

// --- Database Configuration ---
// IMPORTANT: Never hardcode credentials in production code.
#define DB_HOST "localhost"
#define DB_USER "dbuser"
#define DB_PASSWORD "dbpassword" // Placeholder
#define DB_NAME "filedb"


/**
 * Generates a safe, unique filename.
 *
 * @param buffer The buffer to write the filename into.
 * @param len The size of the buffer.
 */
void generate_safe_filename(char* buffer, size_t len) {
    long current_time = time(NULL);
    int random_num = rand();
    snprintf(buffer, len, "%ld-%d.pdf", current_time, random_num);
}

/**
 * Uploads a PDF file from a memory buffer.
 * The file is saved to a configured directory with a unique name,
 * and its path is stored in a MySQL database.
 *
 * @param file_content Pointer to the file content buffer.
 * @param content_len Length of the file content.
 * @param original_filename The original filename from the user.
 * @param saved_filepath A buffer to store the final path of the saved file.
 * @param saved_filepath_len The size of the saved_filepath buffer.
 * @return true on success, false on failure.
 */
bool upload_pdf(const char* file_content, size_t content_len, const char* original_filename, 
                char* saved_filepath, size_t saved_filepath_len) {
    
    FILE *fp = NULL;
    MYSQL *con = NULL;
    MYSQL_STMT *stmt = NULL;
    bool success = false;

    if (file_content == NULL || original_filename == NULL || saved_filepath == NULL || *original_filename == '\0') {
        fprintf(stderr, "Error: Invalid input parameters.\n");
        return false;
    }

    // 1. Validate file size
    if (content_len > MAX_FILE_SIZE) {
        fprintf(stderr, "Error: File size exceeds the %d MB limit.\n", (int)(MAX_FILE_SIZE / (1024 * 1024)));
        return false;
    }

    // 2. Validate filename extension
    const char *dot = strrchr(original_filename, '.');
    if (!dot || strcasecmp(dot, ".pdf") != 0) {
        fprintf(stderr, "Error: Invalid file type. Only PDF files are allowed.\n");
        return false;
    }
    // Note: For better security, also validate the file's magic number (e.g., starts with %PDF-).

    // 3. Create uploads directory if it doesn't exist
    struct stat st = {0};
    if (stat(UPLOADS_DIR, &st) == -1) {
        if (mkdir(UPLOADS_DIR, 0700) != 0 && errno != EEXIST) {
            perror("Error creating uploads directory");
            return false;
        }
    }

    // 4. Generate a safe filename and construct the full path
    char new_filename[MAX_FILENAME_LEN];
    generate_safe_filename(new_filename, sizeof(new_filename));
    
    int written = snprintf(saved_filepath, saved_filepath_len, "%s/%s", UPLOADS_DIR, new_filename);
    if (written < 0 || (size_t)written >= saved_filepath_len) {
        fprintf(stderr, "Error: Destination path is too long.\n");
        return false;
    }

    // 5. Save the file
    fp = fopen(saved_filepath, "wb");
    if (fp == NULL) {
        perror("Error opening file for writing");
        goto cleanup;
    }

    if (fwrite(file_content, 1, content_len, fp) != content_len) {
        fprintf(stderr, "Error writing to file.\n");
        goto cleanup;
    }
    fclose(fp);
    fp = NULL; // Prevent double-close

    // 6. Save filepath to database
    con = mysql_init(NULL);
    if (con == NULL) {
        fprintf(stderr, "mysql_init() failed\n");
        goto cleanup;
    }

    if (mysql_real_connect(con, DB_HOST, DB_USER, DB_PASSWORD, DB_NAME, 0, NULL, 0) == NULL) {
        fprintf(stderr, "mysql_real_connect() failed: %s\n", mysql_error(con));
        goto cleanup;
    }

    const char* query = "INSERT INTO files (filepath) VALUES (?)";
    stmt = mysql_stmt_init(con);
    if (!stmt) {
        fprintf(stderr, "mysql_stmt_init() failed\n");
        goto cleanup;
    }

    if (mysql_stmt_prepare(stmt, query, strlen(query))) {
        fprintf(stderr, "mysql_stmt_prepare() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup;
    }

    MYSQL_BIND bind[1];
    memset(bind, 0, sizeof(bind));
    bind[0].buffer_type = MYSQL_TYPE_STRING;
    bind[0].buffer = (char*)saved_filepath;
    bind[0].buffer_length = strlen(saved_filepath);

    if (mysql_stmt_bind_param(stmt, bind)) {
        fprintf(stderr, "mysql_stmt_bind_param() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup;
    }

    if (mysql_stmt_execute(stmt)) {
        fprintf(stderr, "mysql_stmt_execute() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup;
    }

    printf("File uploaded successfully to: %s\n", saved_filepath);
    success = true;

cleanup:
    if (!success) {
        // If anything failed after file creation, delete the orphaned file.
        if (saved_filepath[0] != '\0') {
             remove(saved_filepath);
        }
    }
    if (fp) fclose(fp);
    if (stmt) mysql_stmt_close(stmt);
    if (con) mysql_close(con);
    return success;
}

int main() {
    // Seed the random number generator
    srand(time(NULL));
    char final_path[MAX_PATH_LEN] = {0};

    printf("Running test cases...\n");
    printf("--- NOTE: Database operations will fail without a configured MySQL server and client library. ---\n");
    
    // Test Case 1: Valid PDF upload
    printf("\n[Test Case 1: Valid PDF upload]\n");
    const char* valid_content = "%PDF-1.4...";
    upload_pdf(valid_content, strlen(valid_content), "document.pdf", final_path, sizeof(final_path));

    // Test Case 2: File too large
    printf("\n[Test Case 2: File too large]\n");
    char* large_content = malloc(MAX_FILE_SIZE + 1);
    if(large_content) {
        memset(large_content, 'a', MAX_FILE_SIZE + 1);
        upload_pdf(large_content, MAX_FILE_SIZE + 1, "large.pdf", final_path, sizeof(final_path));
        free(large_content);
    }

    // Test Case 3: Invalid file type
    printf("\n[Test Case 3: Invalid file type]\n");
    upload_pdf("text content", 12, "document.txt", final_path, sizeof(final_path));

    // Test Case 4: Filename with path traversal characters (only extension is checked)
    printf("\n[Test Case 4: Path traversal attempt]\n");
    upload_pdf(valid_content, strlen(valid_content), "../../bad.pdf", final_path, sizeof(final_path));

    // Test Case 5: Empty input
    printf("\n[Test Case 5: Empty input]\n");
    upload_pdf("", 0, "", final_path, sizeof(final_path));

    return 0;
}
