    print(f"Result: {'SUCCESS' if saved_path_3 else 'FAILURE (Expected)'}")
    print("---")

    # Test Case 4: Invalid filename
    print("Test 4: Uploading a file with an invalid name 'report<script>.pdf'...")
    saved_path_4 = upload_pdf("report<script>.pdf", small_pdf_content)
    print(f"Result: {'SUCCESS' if saved_path_4 else 'FAILURE (Expected)'}")
    print("---")
    
    # Test Case 5: Duplicate file (re-run test 1 to see failure)
    print("Test 5: Re-uploading 'report.pdf' to test duplicate prevention...")
    # We will try to upload a file with a name that is now guaranteed to exist if test 1 succeeded.
