    print(f"Result: {'SUCCESS, path: ' + saved_path_2 if saved_path_2 else 'FAILURE (Expected, sanitized name used)'}")
    print("---")
    
    # Test Case 3: File too large
    print("Test 3: Uploading a file that is too large...")
