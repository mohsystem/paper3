import java.io.IOException;
import java.io.InputStream;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.nio.file.StandardCopyOption;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.UUID;
import java.util.regex.Pattern;
import java.util.stream.Stream;

public class Lse64 {

    // In a real application, these would be in a configuration file or environment variables
    private static final String UPLOADS_DIR_STR = "uploads";
    private static final Path UPLOADS_DIR = Paths.get(UPLOADS_DIR_STR).toAbsolutePath();
    private static final long MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB

    // --- Database Configuration ---
    // IMPORTANT: Never hardcode credentials in production code.
    // Use a secure method like environment variables or a secrets management system.
    private static final String DB_URL = "jdbc:mysql://localhost:3306/filedb";
    private static final String DB_USER = "dbuser";
    private static final String DB_PASSWORD = "dbpassword"; // Placeholder

    // A whitelist of allowed file extensions
    private static final Pattern ALLOWED_EXTENSION_PATTERN = Pattern.compile("^\\.pdf$", Pattern.CASE_INSENSITIVE);
    
    /**
     * Uploads a PDF file represented by an InputStream.
     * The file is saved to a configured directory with a unique name,
     * and its path is stored in a MySQL database.
     *
     * @param fileStream The InputStream of the file content.
     * @param originalFilename The original filename provided by the user.
     * @return The path where the file was saved, or null on failure.
     */
    public static String upload_pdf(InputStream fileStream, String originalFilename) {
        if (fileStream == null || originalFilename == null || originalFilename.trim().isEmpty()) {
            System.err.println("Error: File stream or original filename is null/empty.");
            return null;
        }

        // 1. Validate and Sanitize Filename
        // Extract the extension and validate it against a whitelist.
        String extension = "";
        int dotIndex = originalFilename.lastIndexOf('.');
        if (dotIndex > 0 && dotIndex < originalFilename.length() - 1) {
            extension = originalFilename.substring(dotIndex);
        }

        if (!ALLOWED_EXTENSION_PATTERN.matcher(extension).matches()) {
            System.err.println("Error: Invalid file type. Only PDF files are allowed.");
            return null;
        }

        // For security, generate a new unique filename. Do not use the original filename.
        String newFilename = UUID.randomUUID().toString() + extension;
        Path destinationPath = UPLOADS_DIR.resolve(newFilename).normalize();

        // 2. Security Check: Path Traversal
        // Ensure the final path is within the intended upload directory.
        if (!destinationPath.startsWith(UPLOADS_DIR)) {
            System.err.println("Error: Invalid path detected (path traversal attempt).");
            return null;
        }
        
        try {
            // Ensure upload directory exists
            Files.createDirectories(UPLOADS_DIR);
            
            // 3. Save the file with size limit
            // Use a temporary file and atomic move for safer writes, but for simplicity, we write directly here.
            // A more robust implementation would read the stream in chunks to enforce the size limit before writing all data.
            long bytesCopied = Files.copy(fileStream, destinationPath, StandardCopyOption.REPLACE_EXISTING);

            if (bytesCopied > MAX_FILE_SIZE) {
                Files.delete(destinationPath); // Clean up the oversized file
                System.err.println("Error: File size exceeds the " + (MAX_FILE_SIZE / (1024 * 1024)) + " MB limit.");
                return null;
            }

            // 4. Save filepath to database
            // NOTE: The database connection part will fail if the DB is not set up.
            // This is for demonstration purposes.
            String sql = "INSERT INTO files (filepath) VALUES (?)";
            try (Connection conn = DriverManager.getConnection(DB_URL, DB_USER, DB_PASSWORD);
                 PreparedStatement pstmt = conn.prepareStatement(sql)) {

                pstmt.setString(1, destinationPath.toString());
                pstmt.executeUpdate();

            } catch (SQLException e) {
                System.err.println("Database Error: Failed to save file path. Cleaning up saved file.");
                e.printStackTrace();
                // If DB write fails, delete the orphaned file from the filesystem.
                Files.deleteIfExists(destinationPath);
                return null;
            }

            System.out.println("File uploaded successfully to: " + destinationPath);
            return destinationPath.toString();

        } catch (IOException e) {
            System.err.println("File I/O Error: Could not save the uploaded file.");
            e.printStackTrace();
            // Attempt to clean up partially written file
            try {
                Files.deleteIfExists(destinationPath);
            } catch (IOException cleanupEx) {
                // Ignore cleanup error
            }
            return null;
        }
    }

    public static void main(String[] args) {
        // --- Test Cases ---
        System.out.println("Running test cases...");

        // Setup: Create dummy files for testing
        try {
            Files.createDirectories(Paths.get("test_data"));
            Files.write(Paths.get("test_data/valid.pdf"), "This is a dummy PDF.".getBytes());
            Files.write(Paths.get("test_data/large_file.pdf"), new byte[(int) (MAX_FILE_SIZE + 1)]);
            Files.write(Paths.get("test_data/invalid_type.txt"), "This is a text file.".getBytes());
        } catch (IOException e) {
            System.err.println("Failed to set up test files.");
            e.printStackTrace();
            return;
        }
        
        System.out.println("\n--- NOTE: Database operations will likely fail without a configured MySQL server. ---");

        // Test Case 1: Valid PDF upload
        System.out.println("\n[Test Case 1: Valid PDF upload]");
        try (InputStream is = Files.newInputStream(Paths.get("test_data/valid.pdf"))) {
            upload_pdf(is, "valid.pdf");
        } catch (IOException e) {
            System.err.println("Test 1 failed: " + e.getMessage());
        }

        // Test Case 2: File too large
        System.out.println("\n[Test Case 2: File too large]");
        try (InputStream is = Files.newInputStream(Paths.get("test_data/large_file.pdf"))) {
             // We can't use Files.copy directly for size check before write,
             // but our current implementation checks after write.
             // A real implementation would check during streaming.
             upload_pdf(is, "large_file.pdf");
        } catch (IOException e) {
            System.err.println("Test 2 failed: " + e.getMessage());
        }

        // Test Case 3: Invalid file type
        System.out.println("\n[Test Case 3: Invalid file type]");
        try (InputStream is = Files.newInputStream(Paths.get("test_data/invalid_type.txt"))) {
            upload_pdf(is, "invalid_type.txt");
        } catch (IOException e) {
            System.err.println("Test 3 failed: " + e.getMessage());
        }

        // Test Case 4: Path traversal attempt in filename
        System.out.println("\n[Test Case 4: Path traversal attempt]");
        try (InputStream is = Files.newInputStream(Paths.get("test_data/valid.pdf"))) {
            upload_pdf(is, "../../etc/passwd.pdf");
        } catch (IOException e) {
            System.err.println("Test 4 failed: " + e.getMessage());
        }

        // Test Case 5: Null input
        System.out.println("\n[Test Case 5: Null input]");
        upload_pdf(null, null);

        // Cleanup test files and directories
        try {
            Files.deleteIfExists(Paths.get("test_data/valid.pdf"));
            Files.deleteIfExists(Paths.get("test_data/large_file.pdf"));
            Files.deleteIfExists(Paths.get("test_data/invalid_type.txt"));
            Files.deleteIfExists(Paths.get("test_data"));
            // Also cleanup uploads directory if it contains files
            if (Files.exists(UPLOADS_DIR)) {
                 try (Stream<Path> walk = Files.walk(UPLOADS_DIR)) {
                    walk.sorted(java.util.Comparator.reverseOrder())
                        .forEach(path -> {
                            try {
                                Files.delete(path);
                            } catch (IOException e) {
                                //
                            }
                        });
                }
            }
        } catch(IOException e) {
            System.err.println("Cleanup failed.");
        }
    }
}
