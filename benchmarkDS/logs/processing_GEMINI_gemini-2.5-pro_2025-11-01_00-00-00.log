// Helper to check if filename has only safe characters
bool is_safe_filename(const char* filename) {
    if (!filename) return false;
    for (size_t i = 0; filename[i] != '\0'; i++) {
        if (!isalnum((unsigned char)filename[i]) && filename[i] != '.' && filename[i] != '_' && filename[i] != '-') {
            return false;
        }
    }
    return true;
}

char* upload_pdf(FILE* file_content, const char* original_filename) {
    if (!file_content || !original_filename || strlen(original_filename) == 0) {
        fprintf(stderr, "Error: File content or original filename is null or empty.\n");
        return NULL;
    }

    // 1. Sanitize and validate filename
    char* original_filename_copy = strdup(original_filename);
    if (!original_filename_copy) {
        perror("Failed to duplicate filename string");
        return NULL;
    }
    char* base_name = basename(original_filename_copy);

    if (!is_safe_filename(base_name)) {
        fprintf(stderr, "Error: Original filename contains invalid characters.\n");
        free(original_filename_copy);
        return NULL;
    }

    const char* ext = strrchr(base_name, '.');
    if (!ext || strcasecmp(ext, ".pdf") != 0) {
        fprintf(stderr, "Error: Invalid file type. Only PDF files are allowed.\n");
        free(original_filename_copy);
        return NULL;
    }

    // Create upload directory if it doesn't exist
    if (mkdir(UPLOAD_DIR, 0750) != 0 && errno != EEXIST) {
        perror("Error creating upload directory");
        free(original_filename_copy);
        return NULL;
    }
    
    // 2. Generate a unique filename
    uuid_t binuuid;
    uuid_generate_random(binuuid);
    char unique_name[37];
    uuid_unparse_lower(binuuid, unique_name);
    
    char final_filename[256];
    snprintf(final_filename, sizeof(final_filename), "%s.pdf", unique_name);

    char temp_path[512];
    snprintf(temp_path, sizeof(temp_path), "%s/%s.tmp", UPLOAD_DIR, unique_name);
    
    char final_path[512];
    snprintf(final_path, sizeof(final_path), "%s/%s", UPLOAD_DIR, final_filename);
    
    // 3. Save file securely (write to temp, then rename)
    int fd = open(temp_path, O_WRONLY | O_CREAT | O_EXCL, S_IRUSR | S_IWUSR);
    if (fd == -1) {
        perror("Error opening temporary file");
        free(original_filename_copy);
        return NULL;
    }

    char buffer[4096];
    size_t bytes_read;
    long long bytes_written = 0;
    bool size_ok = true;

    while ((bytes_read = fread(buffer, 1, sizeof(buffer), file_content)) > 0) {
        bytes_written += bytes_read;
        if (bytes_written > MAX_FILE_SIZE) {
            fprintf(stderr, "Error: File size exceeds the maximum limit of %d bytes.\n", MAX_FILE_SIZE);
            size_ok = false;
            break;
        }
        if (write(fd, buffer, bytes_read) != (ssize_t)bytes_read) {
            perror("Error writing to temporary file");
            size_ok = false;
            break;
        }
    }
    close(fd);
    
    if (!size_ok) {
        remove(temp_path);
        free(original_filename_copy);
        return NULL;
    }

    if (rename(temp_path, final_path) != 0) {
        perror("Error renaming temporary file");
        remove(temp_path);
        free(original_filename_copy);
        return NULL;
    }

    char* result_path = strdup(final_path);
    printf("File saved successfully to: %s\n", result_path);
    
    // 4. Save file path to database
    save_filepath_to_db(result_path);
    
    free(original_filename_copy);
    return result_path;
}

int main() {
    printf("--- Running PDF Upload Test Cases ---\n");

    char* saved_path = NULL;

    // Test Case 1: Valid PDF upload
    printf("\n--- Test Case 1: Valid PDF ---\n");
    const char* content1 = "%PDF-1.4\ncontent";
    FILE* stream1 = fmemopen((void*)content1, strlen(content1), "r");
    if (stream1) {
        saved_path = upload_pdf(stream1, "document.pdf");
        if (saved_path) free(saved_path);
        fclose(stream1);
    }

    // Test Case 2: File too large
    printf("\n--- Test Case 2: File Too Large ---\n");
    char* large_content = malloc(MAX_FILE_SIZE + 1);
    if (large_content) {
        memset(large_content, 'a', MAX_FILE_SIZE + 1);
        FILE* stream2 = fmemopen(large_content, MAX_FILE_SIZE + 1, "r");
        if (stream2) {
            saved_path = upload_pdf(stream2, "large_file.pdf");
            if (saved_path) free(saved_path);
            fclose(stream2);
        }
        free(large_content);
    }

    // Test Case 3: Invalid filename (path traversal attempt)
    printf("\n--- Test Case 3: Path Traversal Filename ---\n");
    const char* content3 = "%PDF-1.4\ncontent";
    FILE* stream3 = fmemopen((void*)content3, strlen(content3), "r");
    if (stream3) {
        saved_path = upload_pdf(stream3, "../../etc/passwd.pdf");
        if (saved_path) free(saved_path);
        fclose(stream3);
    }
    
    // Test Case 4: Invalid file type
    printf("\n--- Test Case 4: Invalid File Type ---\n");
    const char* content4 = "This is a text file.";
    FILE* stream4 = fmemopen((void*)content4, strlen(content4), "r");
    if (stream4) {
        saved_path = upload_pdf(stream4, "document.txt");
        if (saved_path) free(saved_path);
        fclose(stream4);
    }

    // Test Case 5: Malicious filename with valid extension
