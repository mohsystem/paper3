import mysql.connector
from mysql.connector import Error

# --- Configuration ---
# In a real application, these would be in a configuration file or environment variables.
UPLOADS_DIR = pathlib.Path("uploads").resolve()
MAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB

# --- Database Configuration ---
# IMPORTANT: Never hardcode credentials in production code.
# Use a secure method like environment variables or a secrets management system.
DB_CONFIG = {
    'host': 'localhost',
    'database': 'filedb',
    'user': 'dbuser',
    'password': 'dbpassword' # Placeholder
}


def upload_pdf(file_content: bytes, original_filename: str) -> str | None:
    """
    Uploads a PDF file from its content bytes.
    The file is saved to a configured directory with a unique name,
    and its path is stored in a MySQL database.

    :param file_content: The byte content of the file.
    :param original_filename: The original filename provided by the user.
    :return: The path where the file was saved, or None on failure.
    """
    if not file_content or not original_filename:
        print("Error: File content or original filename is empty.")
        return None

    # 1. Validate file size
    if len(file_content) > MAX_FILE_SIZE:
        print(f"Error: File size exceeds the {MAX_FILE_SIZE // (1024 * 1024)} MB limit.")
        return None
        
    # 2. Validate and Sanitize Filename
    # Check for a valid PDF extension.
    # Note: For better security, also validate the file's magic number (e.g., starts with %PDF-).
    if not original_filename.lower().endswith('.pdf'):
        print("Error: Invalid file type. Only PDF files are allowed.")
        return None

    # Generate a new, secure filename to prevent path traversal and other attacks.
    safe_filename = f"{uuid.uuid4()}.pdf"
    
    # Construct the destination path and ensure it's within the upload directory.
    destination_path = UPLOADS_DIR / safe_filename
    
    # Redundant check, as Pathlib handles this well, but good for defense-in-depth.
    if UPLOADS_DIR not in destination_path.resolve().parents:
        print("Error: Invalid path detected (path traversal attempt).")
        return None

    connection = None
    try:
        # Ensure the uploads directory exists.
        UPLOADS_DIR.mkdir(exist_ok=True)
        
        # 3. Save the file to the filesystem.
        destination_path.write_bytes(file_content)

        # 4. Save the filepath to the database.
        # This part will fail if the DB is not configured correctly.
        try:
            connection = mysql.connector.connect(**DB_CONFIG)
            cursor = connection.cursor()
            
            sql = "INSERT INTO files (filepath) VALUES (%s)"
            # Use a tuple for the parameters to prevent SQL injection.
            cursor.execute(sql, (str(destination_path),))
            
            connection.commit()
            
            print(f"File uploaded successfully to: {destination_path}")
            return str(destination_path)
            
        except Error as e:
            print(f"Database Error: {e}. Cleaning up saved file.")
            # If the database operation fails, remove the orphaned file.
            if destination_path.exists():
                destination_path.unlink()
            return None
            
    except IOError as e:
        print(f"File I/O Error: Could not save the file. {e}")
        return None
    finally:
        if connection and connection.is_connected():
            connection.close()


if __name__ == '__main__':
