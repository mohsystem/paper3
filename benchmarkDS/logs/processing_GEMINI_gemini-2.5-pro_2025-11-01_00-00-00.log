    std::transform(ext.begin(), ext.end(), ext.begin(), ::tolower);

    if (ext != ALLOWED_EXTENSION) {
        throw std::runtime_error("Error: Invalid file type. Only " + ALLOWED_EXTENSION + " files allowed.");
