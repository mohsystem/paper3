                 return null;
            }

            // Create a temporary file in the same directory to ensure atomic move
            Path tempFile = Files.createTempFile(uploadsPath, "upload-", ".tmp");
            try (OutputStream os = Files.newOutputStream(tempFile)) {
                os.write(fileContent);
            }

            // Atomically move the temporary file to its final destination
            finalPath = uploadsPath.resolve(uniqueFileName).toAbsolutePath().normalize();

            // Final check to ensure the path doesn't escape the uploads directory
            if (!finalPath.startsWith(uploadsPath.toAbsolutePath().normalize())) {
                Files.delete(tempFile); // Clean up temp file
                System.err.println("Error: Path resolution resulted in directory traversal attempt.");
                return null;
            }
            
            Files.move(tempFile, finalPath, StandardCopyOption.ATOMIC_MOVE);

        } catch (IOException e) {
            System.err.println("Error saving file: " + e.getMessage());
            return null;
        }

        // 3. Database Interaction
        String relativePath = Paths.get(UPLOADS_DIR).relativize(finalPath).toString().replace('\\', '/');
        
        // Ensure environment variables are set
        if (DB_URL == null || DB_USER == null || DB_PASSWORD == null) {
            System.err.println("Database environment variables (DB_URL, DB_USER, DB_PASSWORD) are not set.");
            // Clean up the created file if DB connection fails
             try { Files.delete(finalPath); } catch (IOException ignored) {}
            return null;
