    print("USE filedb;")
    print("CREATE TABLE IF NOT EXISTS files (id INT AUTO_INCREMENT PRIMARY KEY, filepath VARCHAR(512) NOT NULL UNIQUE);")
    print("---")
    
    small_pdf_content = b"Dummy PDF content."
    large_pdf_content = b'\0' * (MAX_FILE_SIZE + 1)
    
    # Test Case 1: Successful upload
    print("Test 1: Uploading a valid file 'report.pdf'...")
