#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <mysql/mysql.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <unistd.h>
#include <time.h>
#include <errno.h>
#include <limits.h>

#define UPLOADS_DIR "uploads"
#define MAX_FILE_SIZE (10 * 1024 * 1024) // 10 MB
#define PDF_MAGIC_BYTES_LEN 5

// --- Database Configuration ---
// Read from environment variables for security.
const char *db_host = NULL;
const char *db_user = NULL;
const char *db_pass = NULL;
const char *db_name = NULL;

// Helper function to check if a string starts with a prefix
int starts_with(const char *str, size_t str_len, const char *prefix, size_t prefix_len) {
    if (str_len < prefix_len) return 0;
    return memcmp(str, prefix, prefix_len) == 0;
}

// Generates a unique filename.
// Note: Using rand() is not cryptographically secure for uniqueness.
// For production, consider using a library like libuuid or reading from /dev/urandom.
char *generate_unique_filename() {
    char *filename = (char*)malloc(256);
    if (!filename) return NULL;
    time_t t = time(NULL);
    snprintf(filename, 256, "%ld-%d.pdf", t, rand() % 10000);
    return filename;
}


/**
 * Uploads a PDF file by saving it and recording its path in a database.
 *
 * @param fileContent The byte content of the PDF file.
 * @param contentLength The length of the file content.
 * @param originalFileName The original name of the uploaded file.
 * @return A dynamically allocated string with the stored path, or NULL on failure. The caller must free this string.
 */
char* upload_pdf(const char* fileContent, size_t contentLength, const char* originalFileName) {
    // 1. Input Validation
    if (!fileContent || contentLength == 0) {
        fprintf(stderr, "Error: File content is empty.\n");
        return NULL;
    }
    if (contentLength > MAX_FILE_SIZE) {
        fprintf(stderr, "Error: File size exceeds the %d byte limit.\n", MAX_FILE_SIZE);
        return NULL;
    }
    const char pdf_magic[] = "%PDF-";
    if (!starts_with(fileContent, contentLength, pdf_magic, PDF_MAGIC_BYTES_LEN)) {
        fprintf(stderr, "Error: File is not a valid PDF (invalid magic bytes).\n");
        return NULL;
    }
    if (!originalFileName || strlen(originalFileName) == 0) {
        fprintf(stderr, "Error: Original filename is missing.\n");
        return NULL;
    }
    // Basic check for traversal characters in filename.
    if (strchr(originalFileName, '/') || strchr(originalFileName, '\\')) {
        fprintf(stderr, "Warning: Original filename contains path separators.\n");
    }

    // 2. Secure File Saving
    char *unique_filename = NULL;
    char temp_path_template[256];
    char final_path[PATH_MAX];
    char *return_path = NULL;
    int temp_fd = -1;

    // Create uploads directory if it doesn't exist
    struct stat st = {0};
    if (stat(UPLOADS_DIR, &st) == -1) {
        if (mkdir(UPLOADS_DIR, 0755) != 0) {
            perror("Error creating uploads directory");
            return NULL;
        }
    } else if (!S_ISDIR(st.st_mode)) {
        fprintf(stderr, "Error: %s exists but is not a directory.\n", UPLOADS_DIR);
        return NULL;
    }

    // Generate a unique filename and paths
    unique_filename = generate_unique_filename();
    if (!unique_filename) {
        fprintf(stderr, "Error: could not generate unique filename.\n");
        return NULL;
    }
    snprintf(temp_path_template, sizeof(temp_path_template), "%s/tmpfile-XXXXXX", UPLOADS_DIR);
    snprintf(final_path, sizeof(final_path), "%s/%s", UPLOADS_DIR, unique_filename);

    // Create and open a temporary file securely
    temp_fd = mkstemp(temp_path_template);
    if (temp_fd == -1) {
        perror("Error creating temporary file");
        free(unique_filename);
        return NULL;
    }

    // Write content to temp file
    if (write(temp_fd, fileContent, contentLength) != (ssize_t)contentLength) {
        perror("Error writing to temporary file");
        close(temp_fd);
        unlink(temp_path_template);
        free(unique_filename);
        return NULL;
    }
    // Ensure data is written to disk
    if (fsync(temp_fd) == -1) {
        perror("Error fsyncing temporary file");
    }
    close(temp_fd);

    // Atomically move the temporary file to its final destination
    if (rename(temp_path_template, final_path) != 0) {
        perror("Error renaming temporary file");
        unlink(temp_path_template);
        free(unique_filename);
        return NULL;
    }
    
    // Sync the directory to ensure the rename operation is persisted
    int dir_fd = open(UPLOADS_DIR, O_RDONLY);
    if (dir_fd != -1) {
        fsync(dir_fd);
        close(dir_fd);
    }

    // 3. Database Interaction
    MYSQL *conn = NULL;
    MYSQL_STMT *stmt = NULL;
    int success = 0;

    conn = mysql_init(NULL);
    if (!conn) {
        fprintf(stderr, "mysql_init() failed\n");
        goto db_cleanup;
    }

    if (mysql_real_connect(conn, db_host, db_user, db_pass, db_name, 0, NULL, 0) == NULL) {
        fprintf(stderr, "mysql_real_connect() failed: %s\n", mysql_error(conn));
        goto db_cleanup;
    }
    
    const char* query = "INSERT INTO pdf_files (original_name, stored_path) VALUES (?, ?)";
    stmt = mysql_stmt_init(conn);
    if (!stmt) {
        fprintf(stderr, "mysql_stmt_init() failed\n");
        goto db_cleanup;
    }

    if (mysql_stmt_prepare(stmt, query, strlen(query))) {
        fprintf(stderr, "mysql_stmt_prepare() failed: %s\n", mysql_stmt_error(stmt));
        goto db_cleanup;
    }
    
    MYSQL_BIND bind[2];
    memset(bind, 0, sizeof(bind));

    // Bind original_name
    unsigned long original_name_len = strlen(originalFileName);
    bind[0].buffer_type = MYSQL_TYPE_STRING;
    bind[0].buffer = (char *)originalFileName;
    bind[0].buffer_length = original_name_len;

    // Bind stored_path
    unsigned long stored_path_len = strlen(final_path);
    bind[1].buffer_type = MYSQL_TYPE_STRING;
    bind[1].buffer = final_path;
    bind[1].buffer_length = stored_path_len;
    
    if (mysql_stmt_bind_param(stmt, bind)) {
        fprintf(stderr, "mysql_stmt_bind_param() failed: %s\n", mysql_stmt_error(stmt));
        goto db_cleanup;
    }
    
    if (mysql_stmt_execute(stmt)) {
        fprintf(stderr, "mysql_stmt_execute() failed: %s\n", mysql_stmt_error(stmt));
        goto db_cleanup;
    }

    return_path = strdup(final_path);
    success = 1;

db_cleanup:
    if (stmt) mysql_stmt_close(stmt);
    if (conn) mysql_close(conn);
    free(unique_filename);
    
    if (!success) {
        unlink(final_path); // Clean up orphaned file on DB error
    }

    return return_path;
}

int main() {
