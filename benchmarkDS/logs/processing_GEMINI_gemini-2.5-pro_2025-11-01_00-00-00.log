std::optional<std::string> uploadPdf(std::istream& fileContent, const std::string& originalFileName) {
    if (!fileContent || originalFileName.empty()) {
        std::cerr << "Error: File content or original filename is null or empty." << std::endl;
        return std::nullopt;
    }

    // 1. Sanitize and validate the filename
    std::filesystem::path originalPath(originalFileName);
    std::string baseName = originalPath.filename().string();

    if (!std::regex_match(baseName, SAFE_FILENAME_REGEX)) {
        std::cerr << "Error: Original filename contains invalid characters." << std::endl;
        return std::nullopt;
    }

    std::string lowerBaseName = baseName;
    std::transform(lowerBaseName.begin(), lowerBaseName.end(), lowerBaseName.begin(), ::tolower);
    if (lowerBaseName.rfind(".pdf") != lowerBaseName.length() - 4) {
        std::cerr << "Error: Invalid file type. Only PDF files are allowed." << std::endl;
        return std::nullopt;
    }

    try {
        std::filesystem::path uploadDirPath = std::filesystem::absolute(UPLOAD_DIR);
        std::filesystem::create_directories(uploadDirPath);

        // 2. Generate a unique filename
        auto now = std::chrono::system_clock::now();
        auto epoch = now.time_since_epoch();
        auto value = std::chrono::duration_cast<std::chrono::milliseconds>(epoch);
        std::string uniqueFileName = std::to_string(value.count()) + "_" + std::to_string(rand()) + ".pdf";
        
        std::filesystem::path finalPath = uploadDirPath / uniqueFileName;
        std::filesystem::path tempPath = uploadDirPath / (uniqueFileName + ".tmp");

        // 3. Save the file securely (write to temp file and move)
        // Open with low-level I/O to set permissions atomically on creation
        int fd = open(tempPath.c_str(), O_WRONLY | O_CREAT | O_EXCL, S_IRUSR | S_IWUSR);
        if (fd == -1) {
            perror("Error opening temporary file");
            return std::nullopt;
        }

        char buffer[4096];
        long long bytesWritten = 0;
        bool size_ok = true;
        while (fileContent.read(buffer, sizeof(buffer)) || fileContent.gcount() > 0) {
            ssize_t bytesReadCount = fileContent.gcount();
            bytesWritten += bytesReadCount;
            if (bytesWritten > MAX_FILE_SIZE) {
                std::cerr << "Error: File size exceeds the maximum limit of " << MAX_FILE_SIZE << " bytes." << std::endl;
                size_ok = false;
                break;
            }
            if (write(fd, buffer, bytesReadCount) != bytesReadCount) {
                perror("Error writing to temporary file");
                size_ok = false;
                break;
            }
        }
        close(fd);

        if (!size_ok) {
            std::filesystem::remove(tempPath);
            return std::nullopt;
        }

        // Atomically move the temporary file to its final destination
        std::filesystem::rename(tempPath, finalPath);

        std::string savedFilePath = finalPath.string();
        std::cout << "File saved successfully to: " << savedFilePath << std::endl;

        // 4. Save the file path to the database
        saveFilePathToDb(savedFilePath);

        return savedFilePath;

    } catch (const std::filesystem::filesystem_error& e) {
        std::cerr << "Filesystem Error: " << e.what() << std::endl;
        return std::nullopt;
    }
}


int main() {
    srand(time(0)); // Seed random number generator
    std::cout << "--- Running PDF Upload Test Cases ---" << std::endl;

    // Test Case 1: Valid PDF upload
    std::cout << "\n--- Test Case 1: Valid PDF ---" << std::endl;
    std::stringstream stream1("%PDF-1.4\ncontent");
    uploadPdf(stream1, "document.pdf");

    // Test Case 2: File too large
    std::cout << "\n--- Test Case 2: File Too Large ---" << std::endl;
    std::vector<char> largeContent(MAX_FILE_SIZE + 1, 'a');
    std::string largeContentStr(largeContent.begin(), largeContent.end());
    std::stringstream stream2(largeContentStr);
    uploadPdf(stream2, "large_file.pdf");

    // Test Case 3: Invalid filename (path traversal attempt)
    std::cout << "\n--- Test Case 3: Path Traversal Filename ---" << std::endl;
    std::stringstream stream3("%PDF-1.4\ncontent");
    uploadPdf(stream3, "../../etc/passwd");

    // Test Case 4: Invalid file type
    std::cout << "\n--- Test Case 4: Invalid File Type ---" << std::endl;
    std::stringstream stream4("This is a text file.");
    uploadPdf(stream4, "document.txt");

    // Test Case 5: Malicious filename with valid extension
    std::cout << "\n--- Test Case 5: Malicious Filename with valid extension ---" << std::endl;
    std::stringstream stream5("%PDF-1.4\ncontent");
    uploadPdf(stream5, "file<script>.pdf");

    return 0;
}
