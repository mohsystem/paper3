import os
import uuid
import mysql.connector
import tempfile
import shutil
import re

UPLOADS_DIR = "uploads"
MAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB
PDF_MAGIC_BYTES = b'%PDF-'

# --- Database Configuration ---
# In production, use a proper configuration management system.
# Read from environment variables for better security.
DB_CONFIG = {
    'host': os.getenv('DB_HOST', 'localhost'),
    'user': os.getenv('DB_USER', 'dbuser'),
    'password': os.getenv('DB_PASSWORD', 'dbpassword'),
    'database': os.getenv('DB_NAME', 'filedb')
}

def upload_pdf(file_content: bytes, original_file_name: str) -> str or None:
    """
    Uploads a PDF file by saving it and recording its path in a database.

    :param file_content: The byte content of the PDF file.
    :param original_file_name: The original name of the uploaded file.
    :return: The unique path where the file was stored, or None on failure.
    """
    # 1. Input Validation
    if not file_content:
        print("Error: File content is empty.")
        return None

    if len(file_content) > MAX_FILE_SIZE:
        print(f"Error: File size exceeds the {MAX_FILE_SIZE} byte limit.")
        return None

    if not file_content.startswith(PDF_MAGIC_BYTES):
        print("Error: File is not a valid PDF (invalid magic bytes).")
        return None

    if not original_file_name:
        print("Error: Original filename is missing.")
        return None

    # This pattern is a basic whitelist for filenames.
    safe_filename_pattern = re.compile(r"^[a-zA-Z0-9._-]+$")
    if "/" in original_file_name or "\\" in original_file_name or not safe_filename_pattern.match(original_file_name):
        print("Warning: Original filename contains potentially unsafe characters. It will not be used for path construction.")
    
    # 2. Secure File Saving
    final_path = None
    try:
        # Ensure the upload directory exists with secure permissions
        os.makedirs(UPLOADS_DIR, mode=0o755, exist_ok=True)
        if not os.path.isdir(UPLOADS_DIR):
            print("Error: Upload path exists but is not a directory.")
            return None

        unique_file_name = f"{uuid.uuid4()}.pdf"
        
        # Atomically create and write to a temporary file in the same directory
        # This prevents partial file access and race conditions
        with tempfile.NamedTemporaryFile(mode='wb', dir=UPLOADS_DIR, delete=False) as temp_file:
            temp_file_path = temp_file.name
            temp_file.write(file_content)
        
        # Atomically move the file to its final destination
        final_path_str = os.path.join(UPLOADS_DIR, unique_file_name)
        
        # Normalize paths and check for traversal
        base_dir_abs = os.path.abspath(UPLOADS_DIR)
        final_path_abs = os.path.abspath(final_path_str)

        if os.path.commonpath([base_dir_abs]) != os.path.commonpath([base_dir_abs, final_path_abs]):
             os.remove(temp_file_path)
             print("Error: Path resolution resulted in directory traversal attempt.")
             return None

        shutil.move(temp_file_path, final_path_abs)
        final_path = final_path_abs

    except (IOError, OSError) as e:
        print(f"Error saving file: {e}")
        # Clean up temp file if it exists and move failed
        if 'temp_file_path' in locals() and os.path.exists(temp_file_path):
            os.remove(temp_file_path)
        return None
    except Exception as e:
        print(f"An unexpected error occurred during file saving: {e}")
        return None


    # 3. Database Interaction
    db_connection = None
    try:
        if not all(DB_CONFIG.values()):
            print("Database configuration is incomplete. Check environment variables.")
            # Clean up created file
            if final_path and os.path.exists(final_path):
                os.remove(final_path)
            return None

        db_connection = mysql.connector.connect(**DB_CONFIG)
        cursor = db_connection.cursor()
        
        relative_path = os.path.relpath(final_path, os.getcwd()).replace('\\', '/')
        
        sql = "INSERT INTO pdf_files (original_name, stored_path) VALUES (%s, %s)"
        params = (original_file_name, relative_path)
        
        cursor.execute(sql, params)
        db_connection.commit()
        
        cursor.close()
        return relative_path

    except mysql.connector.Error as err:
        print(f"Database error: {err}")
        # If DB insertion fails, delete the orphaned file
        if final_path and os.path.exists(final_path):
            os.remove(final_path)
        return None
    finally:
        if db_connection and db_connection.is_connected():
            db_connection.close()


def main():
    print("Starting tests... (Ensure MySQL is running and configured)")
    print("This script requires a database 'filedb' and table:")
    print("CREATE TABLE pdf_files (id INT AUTO_INCREMENT PRIMARY KEY, original_name VARCHAR(255), stored_path VARCHAR(255) NOT NULL UNIQUE, uploaded_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);")
    print("And environment variables: DB_HOST, DB_USER, DB_PASSWORD, DB_NAME")
    print("---------------------------------------------------------")
    
    # Test Case 1: Valid PDF
    valid_pdf = b'%PDF-1.4\n%\r\n'
    print("\n--- Test Case 1: Valid PDF ---")
    path1 = upload_pdf(valid_pdf, "report.pdf")
    if path1:
        print(f"Success! File stored at: {path1}")
    else:
        print("Failure as expected or something went wrong.")
    
    # Test Case 2: File too large
    large_file = valid_pdf + b'a' * (MAX_FILE_SIZE + 1)
    print("\n--- Test Case 2: File too large ---")
    path2 = upload_pdf(large_file, "large_document.pdf")
    if not path2:
        print("Success! Function correctly rejected oversized file.")
    else:
        print("Failure! Oversized file was accepted.")
    
    # Test Case 3: Invalid file type (not a PDF)
    not_a_pdf = b"This is not a PDF"
    print("\n--- Test Case 3: Not a PDF ---")
    path3 = upload_pdf(not_a_pdf, "document.txt")
    if not path3:
        print("Success! Function correctly rejected non-PDF file.")
    else:
        print("Failure! Non-PDF file was accepted.")
        
    # Test Case 4: Path traversal in filename
    print("\n--- Test Case 4: Malicious filename ---")
    path4 = upload_pdf(valid_pdf, "../../etc/passwd.pdf")
    if path4:
        print(f"Success! File stored at: {path4} (original malicious name was handled).")
    else:
        print("Failure as expected or something went wrong.")
    
    # Test Case 5: Empty file content
    print("\n--- Test Case 5: Empty file content ---")
    empty_file = b""
    path5 = upload_pdf(empty_file, "empty.pdf")
    if not path5:
        print("Success! Function correctly rejected empty file.")
    else:
        print("Failure! Empty file was accepted.")

if __name__ == "__main__":
    main()
