#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <mysql.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <unistd.h>
#include <libgen.h>
#include <time.h>
#include <errno.h>

// To compile: gcc -o Lse64 Lse64.c $(mysql_config --cflags --libs)
// Ensure you have libmysqlclient-dev (or equivalent) installed.

// --- Database Configuration ---
#define DB_HOST "127.0.0.1"
#define DB_USER "user"
#define DB_PASS "password"
#define DB_NAME "filedb"

// --- File Upload Configuration ---
#define UPLOADS_DIR_NAME "uploads"
#define MAX_FILE_SIZE (10 * 1024 * 1024) // 10 MB
#define MAX_FILENAME_LENGTH 100
#define MAX_PATH_LENGTH 512

// A simple function to check if a filename is safe
int is_filename_safe(const char* filename) {
    if (strstr(filename, "..")) return 0; // Contains ".."
    const char *p = filename;
    while (*p) {
        if (!((*p >= 'a' && *p <= 'z') || (*p >= 'A' && *p <= 'Z') || (*p >= '0' && *p <= '9') || *p == '.' || *p == '_' || *p == '-')) {
            return 0; // Contains invalid characters
        }
        p++;
    }
    const char* dot = strrchr(filename, '.');
    if (!dot || strcmp(dot, ".pdf") != 0) return 0; // Must be .pdf
    
    return 1;
}

char* generate_uuid_string() {
    char* uuid_str = malloc(37);
    if (!uuid_str) return NULL;
    sprintf(uuid_str, "%08x-%04x-%04x-%04x-%012x",
            (unsigned int)rand(), (unsigned int)(rand() & 0xFFFF),
            (unsigned int)(rand() & 0xFFFF), (unsigned int)(rand() & 0xFFFF),
            (unsigned int)rand());
    return uuid_str;
}

/**
 * Uploads a PDF file.
 * @return 0 on success, -1 on failure.
 */
int upload_pdf(const char* fileName, const char* fileContent, size_t contentLength) {
    // 1. Input Validation
    if (!fileName || fileName[0] == '\0') {
        fprintf(stderr, "Error: File name cannot be empty.\n");
        return -1;
    }
    if (!fileContent || contentLength == 0) {
        fprintf(stderr, "Error: File content cannot be empty.\n");
        return -1;
    }
    if (contentLength > MAX_FILE_SIZE) {
        fprintf(stderr, "Error: File size exceeds limit.\n");
        return -1;
    }

    // 2. Sanitize filename
    char fileNameCopy[MAX_FILENAME_LENGTH + 1];
    strncpy(fileNameCopy, fileName, MAX_FILENAME_LENGTH);
    fileNameCopy[MAX_FILENAME_LENGTH] = '\0';
    
    char* sanitizedFileName = basename(fileNameCopy);
    if (strlen(sanitizedFileName) > MAX_FILENAME_LENGTH) {
        fprintf(stderr, "Error: Filename length exceeds limit.\n");
        return -1;
    }
    if (!is_filename_safe(sanitizedFileName)) {
        fprintf(stderr, "Error: Invalid filename.\n");
        return -1;
    }

    char* uuid = generate_uuid_string();
    if (!uuid) {
        fprintf(stderr, "Error: Failed to generate UUID.\n");
        return -1;
    }

    char uniqueFileName[MAX_PATH_LENGTH];
    snprintf(uniqueFileName, sizeof(uniqueFileName), "%s.pdf", uuid);
    free(uuid);

    char filePath[MAX_PATH_LENGTH];
    snprintf(filePath, sizeof(filePath), "%s/%s", UPLOADS_DIR_NAME, uniqueFileName);

    // 3. Save the file securely
    mkdir(UPLOADS_DIR_NAME, 0755);
    // Use O_CREAT | O_EXCL for atomic, secure file creation (permissions 0600)
    int fd = open(filePath, O_WRONLY | O_CREAT | O_EXCL, S_IRUSR | S_IWUSR);
    if (fd == -1) {
        perror("Error opening file for writing");
        return -1;
    }
    
    ssize_t bytes_written = write(fd, fileContent, contentLength);
    close(fd);
    if (bytes_written < 0 || (size_t)bytes_written != contentLength) {
        perror("Error writing to file");
        remove(filePath); // Cleanup
        return -1;
    }

    // 4. Save to database
    MYSQL *conn = NULL;
    MYSQL_STMT *stmt = NULL;
    int result = -1; // Assume failure

    conn = mysql_init(NULL);
    if (!conn) {
        fprintf(stderr, "mysql_init() failed\n");
        goto cleanup_db;
    }

    if (!mysql_real_connect(conn, DB_HOST, DB_USER, DB_PASS, DB_NAME, 0, NULL, 0)) {
        fprintf(stderr, "mysql_real_connect() failed: %s\n", mysql_error(conn));
        goto cleanup_db;
    }

    const char* query = "INSERT INTO files (filepath) VALUES (?)";
    stmt = mysql_stmt_init(conn);
    if (!stmt) {
        fprintf(stderr, "mysql_stmt_init() failed\n");
        goto cleanup_db;
    }
    
    if (mysql_stmt_prepare(stmt, query, strlen(query))) {
        fprintf(stderr, "mysql_stmt_prepare() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup_db;
    }

    MYSQL_BIND bind[1];
    memset(bind, 0, sizeof(bind));
    bind[0].buffer_type = MYSQL_TYPE_STRING;
    bind[0].buffer = (char*)filePath;
    bind[0].buffer_length = strlen(filePath);

    if (mysql_stmt_bind_param(stmt, bind)) {
        fprintf(stderr, "mysql_stmt_bind_param() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup_db;
    }
    
    if (mysql_stmt_execute(stmt)) {
        fprintf(stderr, "mysql_stmt_execute() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup_db;
    }

    if (mysql_stmt_affected_rows(stmt) > 0) {
        printf("Successfully saved file to %s and recorded in DB.\n", filePath);
        result = 0; // Success
    } else {
        fprintf(stderr, "Failed to insert record into database.\n");
    }

cleanup_db:
    if (stmt) mysql_stmt_close(stmt);
    if (conn) mysql_close(conn);
    if (result != 0) {
        remove(filePath); // Cleanup orphaned file
    }
    return result;
}

int main() {
    srand(time(NULL)); // Seed for UUID
    printf("Starting PDF upload tests...\n");
    printf("NOTE: Ensure MySQL server is running and the database/table are set up.\n");
    printf("CREATE DATABASE IF NOT EXISTS filedb;\n");
    printf("USE filedb;\n");
    printf("CREATE TABLE IF NOT EXISTS files (id INT AUTO_INCREMENT PRIMARY KEY, filepath VARCHAR(512) NOT NULL UNIQUE);\n");
    printf("---\n");

    const char* small_pdf_content = "Dummy PDF content.";
    char* large_pdf_content = malloc(MAX_FILE_SIZE + 1);
    if(large_pdf_content) memset(large_pdf_content, 'A', MAX_FILE_SIZE + 1);

    // Test Case 1: Successful upload
    printf("Test 1: Uploading a valid file 'report.pdf'...\n");
    int res1 = upload_pdf("report.pdf", small_pdf_content, strlen(small_pdf_content));
    printf("Result: %s\n---\n", res1 == 0 ? "SUCCESS" : "FAILURE");

    // Test Case 2: Path traversal attempt
    printf("Test 2: Attempting path traversal with '../../etc/passwd.pdf'...\n");
    int res2 = upload_pdf("../../etc/passwd.pdf", small_pdf_content, strlen(small_pdf_content));
    printf("Result: %s (Expected, sanitized name used)\n---\n", res2 == 0 ? "SUCCESS" : "FAILURE");

    // Test Case 3: File too large
    if(large_pdf_content) {
        printf("Test 3: Uploading a file that is too large...\n");
        int res3 = upload_pdf("large_file.pdf", large_pdf_content, MAX_FILE_SIZE + 1);
        printf("Result: %s\n---\n", res3 != 0 ? "FAILURE (Expected)" : "SUCCESS");
    }

    // Test Case 4: Invalid filename
    printf("Test 4: Uploading a file with an invalid name 'report<script>.pdf'...\n");
    int res4 = upload_pdf("report<script>.pdf", small_pdf_content, strlen(small_pdf_content));
    printf("Result: %s\n---\n", res4 != 0 ? "FAILURE (Expected)" : "SUCCESS");

    // Test Case 5: Empty filename
    printf("Test 5: Uploading with an empty filename...\n");
    int res5 = upload_pdf("", small_pdf_content, strlen(small_pdf_content));
    printf("Result: %s\n---\n", res5 != 0 ? "FAILURE (Expected)" : "SUCCESS");

    free(large_pdf_content);
    return 0;
}
