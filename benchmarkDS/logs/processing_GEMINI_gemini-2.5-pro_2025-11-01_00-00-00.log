#include <iostream>
#include <fstream>
#include <string>
#include <vector>
#include <filesystem>
#include <random>
#include <sstream>
#include <iomanip>
#include <memory>
#include <algorithm>
#include <cstdlib>

// MySQL Connector/C++ headers
#include <mysql_driver.h>
#include <mysql_connection.h>
#include <cppconn/prepared_statement.h>
#include <cppconn/exception.h>

namespace fs = std::filesystem;

const std::string UPLOADS_DIR = "uploads";
const size_t MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB
const std::string ALLOWED_EXTENSION = ".pdf";

// --- Database Configuration ---
// Read from environment variables for security.
std::string get_env_var(const char* key, const std::string& default_val) {
    const char* val = std::getenv(key);
    return val == nullptr ? default_val : std::string(val);
}

const std::string DB_HOST = get_env_var("DB_HOST", "tcp://127.0.0.1:3306");
const std::string DB_USER = get_env_var("DB_USER", "user");
const std::string DB_PASS = get_env_var("DB_PASSWORD", "password");
const std::string DB_NAME = get_env_var("DB_NAME", "file_db");

// Function to generate a random hex string to use as a filename
std::string generate_random_hex_string(size_t len) {
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> distrib(0, 255);
    std::stringstream ss;
    ss << std::hex;
    for (size_t i = 0; i < len; ++i) {
        ss << std::setw(2) << std::setfill('0') << distrib(gen);
    }
    return ss.str();
}

bool uploadPdf(const std::string& originalFilename, const std::vector<char>& fileContent) {
    if (fileContent.empty() || fileContent.size() > MAX_FILE_SIZE) {
        std::cerr << "Error: File content is invalid or exceeds max size." << std::endl;
        return false;
    }

    if (originalFilename.empty()) {
        std::cerr << "Error: Original filename is empty." << std::endl;
        return false;
    }

    fs::path originalPath(originalFilename);
    std::string ext = originalPath.extension().string();
    std::transform(ext.begin(), ext.end(), ext.begin(), 
        [](unsigned char c){ return std::tolower(c); });

    if (ext != ALLOWED_EXTENSION) {
        std::cerr << "Error: Invalid file extension: " << originalPath.extension().string() << std::endl;
        return false;
    }

    // Generate a secure, unique filename
    std::string secureFilename = generate_random_hex_string(16) + ext;
    fs::path destinationPath = fs::path(UPLOADS_DIR) / secureFilename;

    try {
        fs::create_directories(UPLOADS_DIR);
        std::ofstream outFile(destinationPath, std::ios::binary);
        if (!outFile) {
            std::cerr << "Error: Could not open file for writing: " << destinationPath << std::endl;
            return false;
        }
        outFile.write(fileContent.data(), fileContent.size());
        outFile.close();
    } catch (const fs::filesystem_error& e) {
        std::cerr << "Filesystem error: " << e.what() << std::endl;
        return false;
    }

    // --- Database Insertion ---
    try {
        sql::mysql::MySQL_Driver *driver = sql::mysql::get_mysql_driver_instance();
        std::unique_ptr<sql::Connection> con(driver->connect(DB_HOST, DB_USER, DB_PASS));
        con->setSchema(DB_NAME);

        std::unique_ptr<sql::PreparedStatement> pstmt(con->prepareStatement("INSERT INTO pdf_files (filepath) VALUES (?)"));
        pstmt->setString(1, secureFilename);
        
        int updateCount = pstmt->executeUpdate();

        if (updateCount > 0) {
            std::cout << "Successfully uploaded " << originalFilename << " as " << secureFilename << std::endl;
            return true;
        } else {
             std::cerr << "Database insert failed, no rows affected." << std::endl;
             fs::remove(destinationPath); // Clean up orphaned file
             return false;
        }

    } catch (sql::SQLException &e) {
        std::cerr << "Database error: " << e.what() << std::endl;
        fs::remove(destinationPath); // Clean up orphaned file
        return false;
    }

    return false;
}


