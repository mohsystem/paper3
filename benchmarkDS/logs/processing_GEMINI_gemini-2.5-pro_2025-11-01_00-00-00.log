```python
import os
import uuid
import mysql.connector
from mysql.connector import Error

UPLOADS_DIR = "uploads"
MAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB
ALLOWED_EXTENSIONS = {".pdf"}

# --- Database Configuration ---
# Read credentials from environment variables for security.
# Provide fallbacks for a simple, runnable example.
DB_CONFIG = {
    'host': os.getenv('DB_HOST', 'localhost'),
    'user': os.getenv('DB_USER', 'user'),
    'password': os.getenv('DB_PASSWORD', 'password'),
    'database': os.getenv('DB_NAME', 'file_db')
}

def upload_pdf(original_filename, file_content):
    """
    Uploads a PDF file, saves it to a secure location, and records its path in the database.
    
    Args:
        original_filename (str): The original filename from the user.
        file_content (bytes): The content of the file.
        
    Returns:
        bool: True on success, False on failure.
    """
    if not file_content or len(file_content) > MAX_FILE_SIZE:
        print("Error: File content is empty or exceeds max size.")
        return False

    if not original_filename:
        print("Error: Filename cannot be empty.")
        return False

    # Validate file extension
    _root, ext = os.path.splitext(original_filename)
    if ext.lower() not in ALLOWED_EXTENSIONS:
        print(f"Error: File type '{ext}' is not allowed.")
        return False

    # Generate a secure, unique filename to prevent path traversal and collisions
    secure_filename = str(uuid.uuid4()) + ext
    
    # Construct a safe destination path
    # os.path.join is safe against path traversal with a clean second argument
    destination_path = os.path.join(UPLOADS_DIR, secure_filename)
    
    try:
        # Ensure the uploads directory exists
        os.makedirs(UPLOADS_DIR, exist_ok=True)
        
        # Save the file
        with open(destination_path, "wb") as f:
            f.write(file_content)
    except IOError as e:
        print(f"Error saving file: {e}")
        return False
        
    # --- Database Insertion ---
    conn = None
    cursor = None
    try:
        conn = mysql.connector.connect(**DB_CONFIG)
        cursor = conn.cursor()
        
        # Use a parameterized query to prevent SQL injection
        query = "INSERT INTO pdf_files (filepath) VALUES (%s)"
        cursor.execute(query, (secure_filename,))
        
        conn.commit()
        
        print(f"Successfully uploaded {original_filename} as {secure_filename}")
        return True
        
    except Error as e:
        print(f"Database error: {e}")
        # Rollback in case of error
        if conn:
            conn.rollback()
        # Clean up the saved file if DB insert fails
        if os.path.exists(destination_path):
            os.remove(destination_path)
        return False
        
    finally:
        if cursor:
            cursor.close()
        if conn and conn.is_connected():
            conn.close()

def main():
    """Main function with test cases."""
    # NOTE: This main function requires a running MySQL server with the specified
    # database and table.
    # CREATE DATABASE IF NOT EXISTS file_db;
    # USE file_db;
    # CREATE TABLE IF NOT EXISTS pdf_files (
    #     id INT AUTO_INCREMENT PRIMARY KEY,
    #     filepath VARCHAR(255) NOT NULL UNIQUE,
    #     uploaded_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    # );
    # Also, set environment variables DB_HOST, DB_USER, DB_PASSWORD, DB_NAME
    # or update the defaults.
    # And run: pip install mysql-connector-python
    
    print("Running test cases...")

    # Test Case 1: Valid PDF upload
    print("\n--- Test Case 1: Valid Upload ---")
    valid_content = b"This is a dummy PDF content."
    result1 = upload_pdf("mydocument.pdf", valid_content)
    print(f"Test 1 Result: {'SUCCESS' if result1 else 'FAILURE'}")

    # Test Case 2: Path traversal attempt (will be sanitized by only using the extension)
    print("\n--- Test Case 2: Path Traversal ---")
    result2 = upload_pdf("../../etc/passwd.pdf", valid_content)
    print(f"Test 2 Result: {'SUCCESS' if result2 else 'FAILURE'}")

    # Test Case 3: Invalid file extension
    print("\n--- Test Case 3: Invalid Extension ---")
    result3 = upload_pdf("image.jpg", valid_content)
    print(f"Test 3 Result: {'SUCCESS' if result3 else 'FAILURE'}")

    # Test Case 4: File too large
    print("\n--- Test Case 4: File Too Large ---")
    large_content = b'\0' * (MAX_FILE_SIZE + 1)
    result4 = upload_pdf("largefile.pdf", large_content)
    print(f"Test 4 Result: {'SUCCESS' if result4 else 'FAILURE'}")

    # Test Case 5: Empty file content
    print("\n--- Test Case 5: Empty Content ---")
    result5 = upload_pdf("empty.pdf", b"")
    print(f"Test 5 Result: {'SUCCESS' if result5 else 'FAILURE'}")

if __name__ == "__main__":
    main()
