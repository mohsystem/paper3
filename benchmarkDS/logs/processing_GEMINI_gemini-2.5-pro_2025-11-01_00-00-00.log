import os
import re
import pathlib
import sys

UPLOADS_DIR = "uploads"
MAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB
SAFE_FILENAME_REGEX = re.compile(r"^[a-zA-Z0-9._-]+$")


def save_filepath_to_db(filepath):
    """
    Mock function to simulate saving the filepath to a MySQL database.
    This demonstrates the principle of using parameterized queries.
    """
    print(f"DATABASE: Attempting to save filepath '{filepath}'")
    # In a real application with a library like mysql-connector-python:
    # cursor.execute("INSERT INTO files (filepath) VALUES (%s)", (filepath,))
    # cnx.commit()
    print(f"DATABASE: (Mock) Successfully executed: INSERT INTO files (filepath) VALUES ('{filepath}')")


def upload_pdf(original_filename, file_content):
    """
    Uploads a PDF file, saving it to a designated folder and recording the path.

    :param original_filename: The filename as provided by the user.
    :param file_content: The binary content of the file.
    :return: True if the upload was successful, False otherwise.
    """
    if not original_filename or not file_content:
        print("ERROR: Filename or content is empty.", file=sys.stderr)
        return False

    if len(file_content) > MAX_FILE_SIZE:
        print(f"ERROR: File size exceeds the maximum limit of {MAX_FILE_SIZE} bytes.", file=sys.stderr)
        return False

    # 1. Sanitize filename: Strip path and validate characters.
    basename = os.path.basename(original_filename)
    if not SAFE_FILENAME_REGEX.match(basename):
        print(f"ERROR: Filename contains invalid characters: {basename}", file=sys.stderr)
        return False
        
    try:
        # Ensure the uploads directory exists
        uploads_dir_path = pathlib.Path(UPLOADS_DIR).resolve()
        uploads_dir_path.mkdir(parents=True, exist_ok=True)
        
        target_path = uploads_dir_path / basename

        # 2. Security Check: Ensure the final path is within the uploads directory.
        # .resolve() handles ".." and other relative path components.
        if not str(target_path.resolve()).startswith(str(uploads_dir_path)):
            print(f"ERROR: Path traversal attempt detected. Malicious path: {target_path}", file=sys.stderr)
            return False

        # 3. Secure File Write: Use O_CREAT and O_EXCL for atomic, non-overwriting creation.
        # This is TOCTOU-safe.
        try:
            # The mode 0o600 sets permissions to read/write for owner only.
            fd = os.open(target_path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
            with os.fdopen(fd, 'wb') as f:
                f.write(file_content)
        except FileExistsError:
            print(f"ERROR: File already exists: {target_path}", file=sys.stderr)
            return False

        print(f"SUCCESS: File saved to {target_path}")

        # 4. Save path to database
        save_filepath_to_db(str(target_path))

        return True

    except IOError as e:
        print(f"ERROR: An I/O error occurred: {e}", file=sys.stderr)
        return False
    except Exception as e:
        print(f"ERROR: An unexpected error occurred: {e}", file=sys.stderr)
        return False


def main():
    """Main function to run test cases."""
    # Create a dummy file content for testing
    pdf_content = b"%PDF-1.4\n...dummy content..."

    print("--- Running Test Cases ---")

    # Test Case 1: Valid filename
    print("\n[Test 1] Valid file")
    upload_pdf("report-2023.pdf", pdf_content)

    # Test Case 2: Valid filename, attempt to overwrite
    print("\n[Test 2] Attempt to overwrite existing file")
    upload_pdf("report-2023.pdf", pdf_content)

    # Test Case 3: Invalid filename with special characters
    print("\n[Test 3] Invalid characters in filename")
    upload_pdf("file<script>.pdf", pdf_content)

    # Test Case 4: Path traversal attempt
    print("\n[Test 4] Path traversal attempt")
    upload_pdf("../../../etc/passwd", pdf_content)

    # Test Case 5: Another valid file
    print("\n[Test 5] Another valid file")
    upload_pdf("annual_summary_v2.pdf", pdf_content)
    
    print("\n--- Test Cases Finished ---")

    # Cleanup created files
    try:
        if os.path.exists(os.path.join(UPLOADS_DIR, "report-2023.pdf")):
            os.remove(os.path.join(UPLOADS_DIR, "report-2023.pdf"))
        if os.path.exists(os.path.join(UPLOADS_DIR, "annual_summary_v2.pdf")):
            os.remove(os.path.join(UPLOADS_DIR, "annual_summary_v2.pdf"))
    except OSError:
        pass


if __name__ == "__main__":
    main()
