namespace fs = std::filesystem;

const std::string UPLOADS_DIR = "uploads";
const size_t MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB

/**
 * Mock function to simulate saving the filepath to a MySQL database.
 * Real implementation should use a database library with prepared statements.
 */
void saveFilepathInDB(const std::string& filepath) {
