#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>
#include <time.h>
#include <errno.h>

#ifdef _WIN32
#include <direct.h>
#define MKDIR(path) _mkdir(path)
#else
#include <sys/stat.h>
#define MKDIR(path) mkdir(path, 0755)
#endif

#include <mysql/mysql.h>

#define UPLOADS_DIR "uploads"
#define MAX_FILE_SIZE (10 * 1024 * 1024) // 10 MB
#define ALLOWED_EXTENSION ".pdf"
#define SECURE_FILENAME_LEN 32 // 16 bytes * 2 hex chars
#define MAX_PATH_LEN 256

// --- Database Configuration ---
const char* get_env_var(const char* key, const char* default_val) {
    const char* val = getenv(key);
    return val ? val : default_val;
}

// Function to safely extract file extension
const char* get_filename_ext(const char* filename) {
    if (!filename) return "";
    const char* dot = strrchr(filename, '.');
    if (!dot || dot == filename) return "";
    // A simple case-insensitive comparison for ".pdf"
    if (strcasecmp(dot, ALLOWED_EXTENSION) == 0) {
        return ALLOWED_EXTENSION;
    }
    return "";
}

// Function to generate a random hex string
void generate_random_hex_string(char* buffer, size_t len) {
    const char* hex_chars = "0123456789abcdef";
    for (size_t i = 0; i < len; ++i) {
        buffer[i] = hex_chars[rand() % 16];
    }
    buffer[len] = '\0';
}

bool upload_pdf(const char* original_filename, const char* file_content, size_t content_length) {
    if (file_content == NULL || content_length == 0 || content_length > MAX_FILE_SIZE) {
        fprintf(stderr, "Error: File content is invalid or exceeds max size.\n");
        return false;
    }

    if (original_filename == NULL || strlen(original_filename) == 0) {
        fprintf(stderr, "Error: Original filename is empty.\n");
        return false;
    }

    // Validate extension
    const char* ext = get_filename_ext(original_filename);
    if (strcmp(ext, ALLOWED_EXTENSION) != 0) {
        fprintf(stderr, "Error: Invalid file extension.\n");
        return false;
    }

    // Create uploads directory if it doesn't exist
    if (MKDIR(UPLOADS_DIR) != 0 && errno != EEXIST) {
        perror("Error creating uploads directory");
        return false;
    }
    
    // Generate a secure filename
    char secure_basename[SECURE_FILENAME_LEN + 1];
    generate_random_hex_string(secure_basename, SECURE_FILENAME_LEN);

    char secure_filename[SECURE_FILENAME_LEN + sizeof(ALLOWED_EXTENSION) + 1];
    snprintf(secure_filename, sizeof(secure_filename), "%s%s", secure_basename, ext);
    
    char destination_path[MAX_PATH_LEN];
    int path_len = snprintf(destination_path, sizeof(destination_path), "%s/%s", UPLOADS_DIR, secure_filename);
    if (path_len < 0 || (size_t)path_len >= sizeof(destination_path)) {
        fprintf(stderr, "Error: Destination path is too long.\n");
        return false;
    }

    // Save the file
    FILE* fp = fopen(destination_path, "wb");
    if (!fp) {
        perror("Error opening file for writing");
        return false;
    }
    size_t written = fwrite(file_content, 1, content_length, fp);
    fclose(fp);
    if (written != content_length) {
        fprintf(stderr, "Error: Failed to write complete file.\n");
        remove(destination_path); // Attempt to clean up partial file
        return false;
    }
    
    // --- Database Insertion ---
    MYSQL* conn = NULL;
    MYSQL_STMT* stmt = NULL;
    bool success = false;

    conn = mysql_init(NULL);
    if (conn == NULL) {
        fprintf(stderr, "mysql_init() failed\n");
        goto cleanup;
    }
    
    const char* db_host = get_env_var("DB_HOST", "localhost");
    const char* db_user = get_env_var("DB_USER", "user");
    const char* db_pass = get_env_var("DB_PASSWORD", "password");
    const char* db_name = get_env_var("DB_NAME", "file_db");

    if (mysql_real_connect(conn, db_host, db_user, db_pass, db_name, 0, NULL, 0) == NULL) {
        fprintf(stderr, "mysql_real_connect() failed: %s\n", mysql_error(conn));
        goto cleanup;
    }

    const char* query = "INSERT INTO pdf_files (filepath) VALUES (?)";
    stmt = mysql_stmt_init(conn);
    if (!stmt) {
        fprintf(stderr, "mysql_stmt_init() failed\n");
        goto cleanup;
    }

    if (mysql_stmt_prepare(stmt, query, strlen(query))) {
        fprintf(stderr, "mysql_stmt_prepare() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup;
    }

    MYSQL_BIND bind[1];
    memset(bind, 0, sizeof(bind));
    bind[0].buffer_type = MYSQL_TYPE_STRING;
    bind[0].buffer = (char*)secure_filename;
    bind[0].buffer_length = strlen(secure_filename);

    if (mysql_stmt_bind_param(stmt, bind)) {
        fprintf(stderr, "mysql_stmt_bind_param() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup;
    }

    if (mysql_stmt_execute(stmt)) {
        fprintf(stderr, "mysql_stmt_execute() failed: %s\n", mysql_stmt_error(stmt));
        goto cleanup;
    }

    if (mysql_stmt_affected_rows(stmt) == 1) {
        printf("Successfully uploaded %s as %s\n", original_filename, secure_filename);
        success = true;
    } else {
        fprintf(stderr, "Database insert failed, no rows affected.\n");
    }

cleanup:
    if (stmt) mysql_stmt_close(stmt);
    if (conn) mysql_close(conn);

    if (!success) {
        remove(destination_path); // Clean up orphaned file
    }
    
    return success;
}

int main() {
    // NOTE: This requires libmysqlclient to be installed and linked.
    // e.g., gcc -o Lse64 Lse64.c -lmysqlclient
    // The database and table must exist. See other examples for schema.
    // Set environment variables or update defaults.
    srand(time(NULL)); // Seed random number generator

    printf("Running test cases...\n");
    const char* valid_content = "This is a dummy PDF content.";
    size_t valid_content_len = strlen(valid_content);

    // Test Case 1: Valid PDF upload
    printf("\n--- Test Case 1: Valid Upload ---\n");
    bool r1 = upload_pdf("mydocument.pdf", valid_content, valid_content_len);
    printf("Test 1 Result: %s\n", r1 ? "SUCCESS" : "FAILURE");

    // Test Case 2: Path traversal attempt
    printf("\n--- Test Case 2: Path Traversal ---\n");
    bool r2 = upload_pdf("../../etc/passwd.pdf", valid_content, valid_content_len);
    printf("Test 2 Result: %s\n", r2 ? "SUCCESS" : "FAILURE");
    
    // Test Case 3: Invalid file extension
    printf("\n--- Test Case 3: Invalid Extension ---\n");
    bool r3 = upload_pdf("image.jpg", valid_content, valid_content_len);
    printf("Test 3 Result: %s\n", r3 ? "SUCCESS" : "FAILURE");

    // Test Case 4: File too large
    printf("\n--- Test Case 4: File Too Large ---\n");
    char* large_content = (char*)malloc(MAX_FILE_SIZE + 1);
    if (large_content) {
        memset(large_content, 'A', MAX_FILE_SIZE + 1);
        bool r4 = upload_pdf("largefile.pdf", large_content, MAX_FILE_SIZE + 1);
        printf("Test 4 Result: %s\n", r4 ? "SUCCESS" : "FAILURE");
        free(large_content);
    } else {
        printf("Test 4 Result: SKIPPED (malloc failed)\n");
    }

    // Test Case 5: Empty file content
    printf("\n--- Test Case 5: Empty Content ---\n");
    bool r5 = upload_pdf("empty.pdf", "", 0);
    printf("Test 5 Result: %s\n", r5 ? "SUCCESS" : "FAILURE");
    
    return 0;
}
