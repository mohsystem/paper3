     * @param fileContent The byte content of the PDF file.
     * @param originalFileName The original name of the uploaded file.
     * @return The unique path where the file was stored, or null on failure.
     */
    public static String upload_pdf(byte[] fileContent, String originalFileName) {
        // 1. Input Validation
        if (fileContent == null || fileContent.length == 0) {
            System.err.println("Error: File content is empty.");
            return null;
        }

        if (fileContent.length > MAX_FILE_SIZE) {
            System.err.println("Error: File size exceeds the " + MAX_FILE_SIZE + " byte limit.");
            return null;
        }

        if (fileContent.length < PDF_MAGIC_BYTES.length || !startsWith(fileContent, PDF_MAGIC_BYTES)) {
            System.err.println("Error: File is not a valid PDF (invalid magic bytes).");
            return null;
        }

        if (originalFileName == null || originalFileName.trim().isEmpty()) {
            System.err.println("Error: Original filename is missing.");
            return null;
        }

        // Sanitize original filename to prevent path traversal, though we generate a new name.
        // This pattern allows basic alphanumeric characters, dots, hyphens, and underscores.
        Pattern safeFilenamePattern = Pattern.compile("^[a-zA-Z0-9._-]+$");
        if (originalFileName.contains("/") || originalFileName.contains("\\") || !safeFilenamePattern.matcher(originalFileName).matches()) {
             System.err.println("Warning: Original filename contains potentially unsafe characters. It will not be used for path construction.");
        }


        // 2. Secure File Saving
        Path uploadsPath = Paths.get(UPLOADS_DIR);
        Path finalPath = null;
