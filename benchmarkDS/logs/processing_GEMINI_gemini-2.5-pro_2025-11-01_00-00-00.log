    // ... bind parameters and execute ...
    std::cout << "DATABASE: (Mock) Successfully executed: INSERT INTO files (filepath) VALUES ('" << filepath << "')" << std::endl;
}

/**
 * Validates a filename against a safe character whitelist.
 */
bool isValidFilename(const std::string& filename) {
    // Allows letters, numbers, dot, underscore, hyphen.
    static const std::regex safe_pattern("^[a-zA-Z0-9._-]+$");
    return std::regex_match(filename, safe_pattern);
}

/**
 * Uploads a PDF file, saving it to a designated folder and recording the path.
 *
 * @param originalFilename The filename as provided by the user.
 * @param fileContent      The binary content of the file.
 * @return true if the upload was successful, false otherwise.
 */
bool uploadPdf(const std::string& originalFilename, const std::vector<char>& fileContent) {
    if (originalFilename.empty() || fileContent.empty()) {
        std::cerr << "ERROR: Filename or content is empty." << std::endl;
        return false;
    }

    if (fileContent.size() > MAX_FILE_SIZE) {
        std::cerr << "ERROR: File size exceeds the maximum limit of " << MAX_FILE_SIZE << " bytes." << std::endl;
        return false;
    }
    
    // 1. Sanitize filename: Strip path and validate characters.
    fs::path originalPath(originalFilename);
    std::string basename = originalPath.filename().string();

    if (!isValidFilename(basename)) {
        std::cerr << "ERROR: Filename contains invalid characters: " << basename << std::endl;
        return false;
    }

    try {
        fs::path uploadsDirPath = fs::absolute(UPLOADS_DIR);
        fs::create_directories(uploadsDirPath);

        fs::path targetPath = (uploadsDirPath / basename).lexically_normal();
        
        // 2. Security Check: Ensure the final path is within the uploads directory.
        if (targetPath.string().rfind(uploadsDirPath.string(), 0) != 0) {
            std::cerr << "ERROR: Path traversal attempt detected. Malicious path: " << targetPath << std::endl;
            return false;
        }

        // 3. Secure File Write (using POSIX open for TOCTOU-safe creation)
        // O_CREAT | O_EXCL ensures atomic creation; fails if file exists.
        // Mode 0600 gives read/write permissions to owner only.
        int fd = open(targetPath.c_str(), O_WRONLY | O_CREAT | O_EXCL, 0600);
        if (fd == -1) {
            if (errno == EEXIST) {
                std::cerr << "ERROR: File already exists: " << targetPath << std::endl;
            } else {
                std::cerr << "ERROR: Could not create file: " << strerror(errno) << std::endl;
            }
            return false;
        }
        
        ssize_t bytesWritten = write(fd, fileContent.data(), fileContent.size());
        if (bytesWritten < 0 || static_cast<size_t>(bytesWritten) != fileContent.size()) {
            std::cerr << "ERROR: Failed to write all content to file." << std::endl;
            close(fd);
            unlink(targetPath.c_str());
            return false;
        }
        
        close(fd);

        std::cout << "SUCCESS: File saved to " << targetPath << std::endl;

        // 4. Save path to database
        saveFilepathInDB(targetPath.string());

        return true;

    } catch (const fs::filesystem_error& e) {
        std::cerr << "ERROR: A filesystem error occurred: " << e.what() << std::endl;
        return false;
    } catch (const std::exception& e) {
        std::cerr << "ERROR: An unexpected error occurred: " << e.what() << std::endl;
        return false;
    }
}

int main() {
    std::string content_str = "%PDF-1.4\n...dummy content...";
    std::vector<char> pdfContent(content_str.begin(), content_str.end());

    std::cout << "--- Running Test Cases ---" << std::endl;

    // Test Case 1: Valid filename
    std::cout << "\n[Test 1] Valid file" << std::endl;
    uploadPdf("report-2023.pdf", pdfContent);

    // Test Case 2: Valid filename, attempt to overwrite
    std::cout << "\n[Test 2] Attempt to overwrite existing file" << std::endl;
    uploadPdf("report-2023.pdf", pdfContent);

    // Test Case 3: Invalid filename with special characters
    std::cout << "\n[Test 3] Invalid characters in filename" << std::endl;
    uploadPdf("file<script>.pdf", pdfContent);

    // Test Case 4: Path traversal attempt
    std::cout << "\n[Test 4] Path traversal attempt" << std::endl;
    uploadPdf("../../../etc/passwd", pdfContent);

    // Test Case 5: Another valid file
    std::cout << "\n[Test 5] Another valid file" << std::endl;
    uploadPdf("annual_summary_v2.pdf", pdfContent);

    std::cout << "\n--- Test Cases Finished ---" << std::endl;

    try {
       fs::remove(fs::path(UPLOADS_DIR) / "report-2023.pdf");
       fs::remove(fs::path(UPLOADS_DIR) / "annual_summary_v2.pdf");
    } catch(const fs::filesystem_error& e) {
        // Ignore errors during cleanup
    }

    return 0;
}
