// Define a secure base directory for uploads.
#define UPLOAD_DIR_NAME "uploads"
// Define a maximum file size (e.g., 10MB).
#define MAX_FILE_SIZE (10 * 1024 * 1024)
#define MAX_FILENAME_LEN 255
#define MAX_PATH_LEN 4096

/**
 * Checks if a filename has only safe characters (alphanumeric, dot, underscore, hyphen).
 */
bool is_safe_filename(const char* filename) {
    for (size_t i = 0; i < strlen(filename); ++i) {
        char c = filename[i];
        if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '.' || c == '_' || c == '-')) {
            return false;
        }
    }
    return true;
}

/**
 * Saves an uploaded PDF file and records its path in a MySQL database.
 *
 * @param file_content The binary content of the file.
 * @param content_length The length of the file content.
 * @param original_filename The original filename from the user.
 * @param conn A pointer to the active database connection.
 * @return A dynamically allocated string with the relative path of the saved file, or NULL on failure. The caller must free this string.
 */
char* upload_pdf(const char* file_content, size_t content_length, const char* original_filename, MYSQL* conn) {
    // Rule #1: Validate inputs
    if (original_filename == NULL || original_filename[0] == '\0') {
        fprintf(stderr, "Error: Original filename is empty.\n");
        return NULL;
    }
    
    if (content_length > MAX_FILE_SIZE) {
        fprintf(stderr, "Error: File size exceeds the maximum limit.\n");
        return NULL;
    }

    // Sanitize filename: extract basename
    const char *basename = strrchr(original_filename, '/');
    const char *basename_bs = strrchr(original_filename, '\\');
    if (basename == NULL) {
        basename = (basename_bs == NULL) ? original_filename : basename_bs + 1;
    } else {
        basename = (basename_bs != NULL && basename_bs > basename) ? basename_bs + 1 : basename + 1;
    }
    
    if (strlen(basename) > MAX_FILENAME_LEN) {
        fprintf(stderr, "Error: Filename is too long.\n");
        return NULL;
    }

    // Further validation
    char lower_basename[MAX_FILENAME_LEN + 1];
    strncpy(lower_basename, basename, MAX_FILENAME_LEN);
    lower_basename[MAX_FILENAME_LEN] = '\0';
    for(int i = 0; lower_basename[i]; i++){
        lower_basename[i] = tolower(lower_basename[i]);
    }
    
    if (strstr(lower_basename, ".pdf") == NULL || !is_safe_filename(basename)) {
        fprintf(stderr, "Error: Invalid filename or file type. Only .pdf files with safe characters are allowed.\n");
        return NULL;
    }
    
    // Create upload directory if it doesn't exist
    MKDIR(UPLOAD_DIR_NAME, 0750);

    // Generate unique filename
    char unique_filename[MAX_FILENAME_LEN + 1];
    snprintf(unique_filename, sizeof(unique_filename), "%ld-%d.pdf", (long)time(NULL), rand());
    
    // Rule #5: Construct path safely
    char destination_path[MAX_PATH_LEN];
    int len = snprintf(destination_path, sizeof(destination_path), "%s/%s", UPLOAD_DIR_NAME, unique_filename);
    if (len < 0 || (size_t)len >= sizeof(destination_path)) {
        fprintf(stderr, "Error: Could not construct destination path.\n");
        return NULL;
    }
    
    // Rule #6: Write file
    FILE *outfile = fopen(destination_path, "wb");
    if (!outfile) {
        perror("Error opening file for writing");
        return NULL;
    }
    
    if (fwrite(file_content, 1, content_length, outfile) != content_length) {
        fprintf(stderr, "Error writing to file.\n");
        fclose(outfile);
        remove(destination_path);
        return NULL;
    }
    fclose(outfile);

    // Rule #2: Use prepared statements
    MYSQL_STMT *stmt = mysql_stmt_init(conn);
    if (!stmt) {
        fprintf(stderr, "DB Error: mysql_stmt_init() out of memory\n");
        remove(destination_path);
        return NULL;
    }

    const char *query = "INSERT INTO files (filepath, original_filename) VALUES (?, ?)";
    if (mysql_stmt_prepare(stmt, query, strlen(query))) {
        fprintf(stderr, "DB Error: mysql_stmt_prepare() failed\n");
        mysql_stmt_close(stmt);
        remove(destination_path);
        return NULL;
    }

    // Mock database logic for runnable example
#ifndef USE_MYSQL_CLIENT
    printf("DB PREPARE: %s\n", query);
    printf("DB BIND: %s\n", destination_path);
    printf("DB BIND: %s\n", basename);
    printf("DB EXECUTE\n");
#else
    MYSQL_BIND bind[2];
    memset(bind, 0, sizeof(bind));
    
    bind[0].buffer_type = MYSQL_TYPE_STRING;
    bind[0].buffer = destination_path;
    bind[0].buffer_length = strlen(destination_path);

    bind[1].buffer_type = MYSQL_TYPE_STRING;
    bind[1].buffer = (char*)basename;
    bind[1].buffer_length = strlen(basename);

    if (mysql_stmt_bind_param(stmt, bind)) {
        fprintf(stderr, "DB Error: mysql_stmt_bind_param() failed\n");
        mysql_stmt_close(stmt);
        remove(destination_path);
        return NULL;
    }
    if (mysql_stmt_execute(stmt)) {
        fprintf(stderr, "DB Error: mysql_stmt_execute() failed\n");
        mysql_stmt_close(stmt);
        remove(destination_path);
        return NULL;
    }
#endif
    mysql_stmt_close(stmt);
    
    char* result_path = strdup(destination_path);
    printf("Successfully uploaded %s to %s\n", basename, result_path);
    return result_path;
}

// --- Test Cases ---
int main() {
    srand((unsigned int)time(NULL));
    printf("Running test cases...\n");
    
    // Test Case 1: Valid PDF upload
    printf("\n--- Test Case 1: Valid PDF ---\n");
    char valid_content[] = "%PDF-1.4...";
    char* path1 = upload_pdf(valid_content, sizeof(valid_content) - 1, "report-final.pdf", NULL);
    if (path1) free(path1);

    // Test Case 2: Invalid file type
    printf("\n--- Test Case 2: Invalid File Type ---\n");
    char* path2 = upload_pdf(valid_content, sizeof(valid_content) - 1, "archive.zip", NULL);
    if (path2) free(path2);

    // Test Case 3: File size too large
    printf("\n--- Test Case 3: File Too Large ---\n");
    char* large_content = (char*)malloc(MAX_FILE_SIZE + 1);
    if (large_content) {
        memset(large_content, 'a', MAX_FILE_SIZE + 1);
        char* path3 = upload_pdf(large_content, MAX_FILE_SIZE + 1, "large-file.pdf", NULL);
        if (path3) free(path3);
        free(large_content);
    }
    
    // Test Case 4: Directory traversal attempt
    printf("\n--- Test Case 4: Directory Traversal ---\n");
    char* path4 = upload_pdf(valid_content, sizeof(valid_content) - 1, "../../etc/passwd.pdf", NULL);
    if (path4) free(path4);
    
    // Test Case 5: Malicious filename
    printf("\n--- Test Case 5: Malicious Filename ---\n");
    char* path5 = upload_pdf(valid_content, sizeof(valid_content) - 1, "file<script>.pdf", NULL);
    if (path5) free(path5);

    // Cleanup: In a real scenario, you would remove the created files.
    // For this example, we leave them in the 'uploads' directory.
    
    return 0;
}
