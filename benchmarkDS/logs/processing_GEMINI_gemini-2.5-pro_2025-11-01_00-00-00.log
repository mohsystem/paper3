        // And ensure the MySQL JDBC driver is in the classpath.
        
        System.out.println("Running test cases...");

        // Test Case 1: Valid PDF upload
        System.out.println("\n--- Test Case 1: Valid Upload ---");
        byte[] validContent = "This is a dummy PDF content.".getBytes();
        boolean result1 = uploadPdf("mydocument.pdf", validContent);
        System.out.println("Test 1 Result: " + (result1 ? "SUCCESS" : "FAILURE"));

        // Test Case 2: Path traversal attempt
        System.out.println("\n--- Test Case 2: Path Traversal ---");
        boolean result2 = uploadPdf("../../etc/passwd.pdf", validContent);
        System.out.println("Test 2 Result: " + (result2 ? "SUCCESS" : "FAILURE"));

        // Test Case 3: Invalid file extension
        System.out.println("\n--- Test Case 3: Invalid Extension ---");
        boolean result3 = uploadPdf("image.jpg", validContent);
        System.out.println("Test 3 Result: " + (result3 ? "SUCCESS" : "FAILURE"));

        // Test Case 4: File too large
        System.out.println("\n--- Test Case 4: File Too Large ---");
        byte[] largeContent = new byte[(int) MAX_FILE_SIZE + 1];
