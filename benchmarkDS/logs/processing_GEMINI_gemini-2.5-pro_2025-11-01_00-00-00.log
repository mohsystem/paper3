namespace fs = std::filesystem;

// Define a secure base directory for uploads.
const std::string UPLOAD_DIR_NAME = "uploads";
const fs::path UPLOAD_DIRECTORY = fs::current_path() / UPLOAD_DIR_NAME;

// Define a maximum file size (e.g., 10MB).
const size_t MAX_FILE_SIZE = 10 * 1024 * 1024;

// Regex for validating filenames.
const std::regex FILENAME_REGEX("^[a-zA-Z0-9._-]+$");

std::string generate_uuid() {
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> dis(0, 15);
    std::uniform_int_distribution<> dis2(8, 11);
    
    std::stringstream ss;
    ss << std::hex;
    for (int i = 0; i < 8; i++) ss << dis(gen);
    ss << "-";
    for (int i = 0; i < 4; i++) ss << dis(gen);
    ss << "-4";
    for (int i = 0; i < 3; i++) ss << dis(gen);
    ss << "-";
    ss << dis2(gen);
    for (int i = 0; i < 3; i++) ss << dis(gen);
    ss << "-";
    for (int i = 0; i < 12; i++) ss << dis(gen);
    return ss.str();
}

/**
 * Saves an uploaded PDF file and records its path in a MySQL database.
 *
 * @param file_content The binary content of the file.
 * @param original_filename The original filename from the user.
 * @param conn A pointer to the active database connection.
 * @return The relative path of the saved file, or an empty string on failure.
 */
std::string upload_pdf(const std::vector<char>& file_content, const std::string& original_filename, sql::Connection* conn) {
    // Rule #1: Validate inputs
    if (original_filename.empty()) {
        std::cerr << "Error: Original filename is empty." << std::endl;
        return "";
    }
    
    if (file_content.size() > MAX_FILE_SIZE) {
        std::cerr << "Error: File size exceeds the maximum limit." << std::endl;
        return "";
    }

    fs::path original_path(original_filename);
    std::string sanitized_filename = original_path.filename().string();
    
    std::string lower_filename = sanitized_filename;
    std::transform(lower_filename.begin(), lower_filename.end(), lower_filename.begin(), ::tolower);
    if (!std::regex_match(sanitized_filename, FILENAME_REGEX) || lower_filename.rfind(".pdf") != lower_filename.length() - 4) {
        std::cerr << "Error: Invalid filename or file type. Only .pdf files are allowed." << std::endl;
        return "";
    }
    
    try {
        if (!fs::exists(UPLOAD_DIRECTORY)) {
            fs::create_directories(UPLOAD_DIRECTORY);
        }

        std::string unique_filename = generate_uuid() + ".pdf";
        fs::path destination_path = UPLOAD_DIRECTORY / unique_filename;
        fs::path canonical_dest = fs::weakly_canonical(destination_path);
        fs::path canonical_base = fs::weakly_canonical(UPLOAD_DIRECTORY);

        // Rule #5: Ensure path resolves within the base directory
        if (canonical_dest.string().rfind(canonical_base.string(), 0) != 0) {
            std::cerr << "Error: Directory traversal attempt detected." << std::endl;
            return "";
        }
        
        // Rule #6: Write to file. Using a direct write here for simplicity.
        // For true atomicity, write to a temp file and rename.
        std::ofstream outfile(destination_path, std::ios::binary | std::ios::out);
        if (!outfile.is_open()) {
             throw std::runtime_error("Could not open file for writing.");
        }
        outfile.write(file_content.data(), file_content.size());
        outfile.close();

        fs::path relative_path = fs::path(UPLOAD_DIR_NAME) / unique_filename;

        // Rule #2: Use prepared statements
        std::unique_ptr<sql::PreparedStatement> pstmt(conn->prepareStatement("INSERT INTO files (filepath, original_filename) VALUES (?, ?)"));
        pstmt->setString(1, relative_path.string());
        pstmt->setString(2, sanitized_filename);
        pstmt->executeUpdate();
        
        std::cout << "Successfully uploaded " << sanitized_filename << " to " << relative_path.string() << std::endl;
        return relative_path.string();
        
    } catch (const fs::filesystem_error& e) {
        std::cerr << "File I/O error: " << e.what() << std::endl;
        return "";
    } catch (const std::exception& e) {
        // This could be from the DB or other runtime errors
        std::cerr << "Error: " << e.what() << std::endl;
        return "";
    }
}


// --- Mock Database and Test Cases ---
class MockPreparedStatement : public sql::PreparedStatement {
public:
    void setString(int, const std::string& value) override {
        std::cout << "DB BIND: " << value << std::endl;
    }
    int executeUpdate() override {
        std::cout << "DB EXECUTE UPDATE" << std::endl;
        return 1;
    }
};

class MockConnection : public sql::Connection {
public:
    std::unique_ptr<sql::PreparedStatement> prepareStatement(const std::string& sql) override {
        std::cout << "DB PREPARE: " << sql << std::endl;
        return std::make_unique<MockPreparedStatement>();
    }
};


int main() {
    std::cout << "Running test cases..." << std::endl;
    MockConnection mock_conn;

    // Test Case 1: Valid PDF upload
    std::cout << "\n--- Test Case 1: Valid PDF ---" << std::endl;
    std::vector<char> valid_content(1024, 'a');
    upload_pdf(valid_content, "report.pdf", &mock_conn);

    // Test Case 2: Invalid file type
    std::cout << "\n--- Test Case 2: Invalid File Type ---" << std::endl;
    upload_pdf(valid_content, "image.png", &mock_conn);

    // Test Case 3: File size too large
    std::cout << "\n--- Test Case 3: File Too Large ---" << std::endl;
    std::vector<char> large_content(MAX_FILE_SIZE + 1, 'b');
    upload_pdf(large_content, "big_document.pdf", &mock_conn);
    
    // Test Case 4: Directory traversal attempt
    std::cout << "\n--- Test Case 4: Directory Traversal ---" << std::endl;
    upload_pdf(valid_content, "../../secret.pdf", &mock_conn);
    
    // Test Case 5: Malicious filename
    std::cout << "\n--- Test Case 5: Malicious Filename ---" << std::endl;
    upload_pdf(valid_content, "file<>&.pdf", &mock_conn);

    // Cleanup
    if (fs::exists(UPLOAD_DIRECTORY)) {
        fs::remove_all(UPLOAD_DIRECTORY);
    }
    
    return 0;
}
