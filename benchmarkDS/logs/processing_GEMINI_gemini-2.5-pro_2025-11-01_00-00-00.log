# It's safer to define the uploads directory with an absolute path
UPLOADS_DIR = os.path.join(os.path.abspath(os.path.dirname(__file__)), UPLOADS_DIR_NAME)
MAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB
MAX_FILENAME_LENGTH = 100
# Allow alphanumeric characters, dots, underscores, and hyphens.
VALID_FILENAME_PATTERN = re.compile(r'^[a-zA-Z0-9._-]+$')

def upload_pdf(file_name, file_content):
    """
    Uploads a PDF file by saving its content and recording its path in a database.

    :param file_name: The original name of the uploaded file.
    :param file_content: The byte content of the file.
    :return: The absolute path of the saved file, or None on failure.
    """
    # 1. Input Validation
    if not file_name:
        print("Error: File name cannot be empty.")
        return None
    if not file_content:
        print("Error: File content cannot be empty.")
        return None
    if len(file_content) > MAX_FILE_SIZE:
        print(f"Error: File size {len(file_content)} exceeds limit of {MAX_FILE_SIZE} bytes.")
        return None

    # 2. Sanitize filename to prevent path traversal
    sanitized_file_name = os.path.basename(file_name)
    if len(sanitized_file_name) > MAX_FILENAME_LENGTH:
        print(f"Error: Filename length exceeds limit of {MAX_FILENAME_LENGTH} characters.")
        return None
    if not VALID_FILENAME_PATTERN.match(sanitized_file_name) or not sanitized_file_name.lower().endswith('.pdf'):
        print("Error: Invalid filename. It must be a .pdf file and contain only safe characters.")
        return None
    
    # Use a unique name to avoid conflicts, preserving the extension
    unique_file_name = str(uuid.uuid4()) + ".pdf"
    
    file_path = os.path.join(UPLOADS_DIR, unique_file_name)

    # Security check: ensure the final path resolves within the intended upload directory.
    if os.path.abspath(file_path).startswith(os.path.abspath(UPLOADS_DIR)) is False:
        print("Error: Path traversal attempt detected and blocked.")
        return None

    # 3. Save the file to the filesystem securely
    try:
        os.makedirs(UPLOADS_DIR, exist_ok=True)
        # Use 'xb' mode to create a new file exclusively, preventing overwrites (TOCTOU).
        with open(file_path, 'xb') as f:
            f.write(file_content)
    except FileExistsError:
        print(f"Error: A file with this name already exists: {file_path}")
        return None
    except IOError as e:
        print(f"Error saving file: {e}")
        return None

    # 4. Save the filepath to the database
    db_connection = None
    try:
        db_connection = mysql.connector.connect(**DB_CONFIG)
        cursor = db_connection.cursor()
        sql = "INSERT INTO files (filepath) VALUES (%s)"
        cursor.execute(sql, (file_path,))
        db_connection.commit()
        cursor.close()
        print(f"Successfully saved file to {file_path} and recorded in DB.")
        return file_path
    except mysql.connector.Error as err:
        print(f"Database error: {err}")
        # Cleanup: delete the orphaned file
        if os.path.exists(file_path):
            os.remove(file_path)
        return None
    finally:
        if db_connection and db_connection.is_connected():
            db_connection.close()


if __name__ == "__main__":
    print("Starting PDF upload tests...")
    print(f"Uploads directory: {UPLOADS_DIR}")
    print("NOTE: Ensure MySQL server is running and the database/table are set up.")
