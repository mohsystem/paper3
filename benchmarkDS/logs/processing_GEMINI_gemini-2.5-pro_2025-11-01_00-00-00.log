            // If DB insertion fails, delete the orphaned file
            try {
                Files.delete(finalPath);
            } catch (IOException ex) {
                System.err.println("Failed to clean up orphaned file: " + finalPath);
            }
            return null;
        }

        return relativePath;
    }

