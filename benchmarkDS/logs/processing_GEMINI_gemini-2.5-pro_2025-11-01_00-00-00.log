    if saved_path_1:
       # Re-creating a file with a known path to test the collision logic
       test_file_path = os.path.join(UPLOADS_DIR, os.path.basename(saved_path_1))
       try:
           # Temporarily create the file again to force a collision
           with open(test_file_path, 'wb') as f:
               f.write(b'dummy')
           
           # This should fail because we are not using unique names in this specific test
