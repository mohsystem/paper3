#include <iostream>
#include <fstream>
#include <string>
#include <vector>
#include <stdexcept>
#include <filesystem>
#include <regex>
#include <chrono>
#include <random>

// MySQL Connector/C++ headers
#include <mysql_driver.h>
#include <mysql_connection.h>
#include <cppconn/prepared_statement.h>
#include <cppconn/exception.h>

// For unique filename generation
#include <sstream>
#include <iomanip>

namespace fs = std::filesystem;

const std::string UPLOADS_DIR = "uploads";
constexpr long long MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB
const std::vector<char> PDF_MAGIC_BYTES = {'%', 'P', 'D', 'F', '-'};

// --- Database Configuration ---
// In production, use a secure method to fetch credentials (e.g., environment variables, config file)
const std::string DB_HOST = std::getenv("DB_HOST") ? std::getenv("DB_HOST") : "tcp://127.0.0.1:3306";
const std::string DB_USER = std::getenv("DB_USER") ? std::getenv("DB_USER") : "dbuser";
const std::string DB_PASSWORD = std::getenv("DB_PASSWORD") ? std::getenv("DB_PASSWORD") : "dbpassword";
const std::string DB_NAME = std::getenv("DB_NAME") ? std::getenv("DB_NAME") : "filedb";

std::string generate_unique_filename() {
    auto now = std::chrono::system_clock::now();
    auto ms = std::chrono::duration_cast<std::chrono::milliseconds>(now.time_since_epoch()) % 1000;

    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> distrib(0, 9999);
    
    std::time_t t = std::chrono::system_clock::to_time_t(now);
    std::tm tm_buf;
    // Use platform-specific safe versions of localtime if available
    #ifdef _WIN32
        localtime_s(&tm_buf, &t);
    #else
        localtime_r(&t, &tm_buf);
    #endif

    std::stringstream ss;
    ss << std::put_time(&tm_buf, "%Y%m%d%H%M%S");
    ss << '-' << std::setw(3) << std::setfill('0') << ms.count();
    ss << '-' << std::setw(4) << std::setfill('0') << distrib(gen);
    ss << ".pdf";
    return ss.str();
}

/**
 * Uploads a PDF file by saving it and recording its path in a database.
 *
 * @param fileContent The byte content of the PDF file.
 * @param originalFileName The original name of the uploaded file.
 * @return The unique path where the file was stored, or an empty string on failure.
 */
std::string upload_pdf(const std::vector<char>& fileContent, const std::string& originalFileName) {
    // 1. Input Validation
    if (fileContent.empty()) {
        std::cerr << "Error: File content is empty." << std::endl;
        return "";
    }
    if (fileContent.size() > MAX_FILE_SIZE) {
        std::cerr << "Error: File size exceeds the " << MAX_FILE_SIZE << " byte limit." << std::endl;
        return "";
    }
    if (fileContent.size() < PDF_MAGIC_BYTES.size() || 
        !std::equal(PDF_MAGIC_BYTES.begin(), PDF_MAGIC_BYTES.end(), fileContent.begin())) {
        std::cerr << "Error: File is not a valid PDF (invalid magic bytes)." << std::endl;
        return "";
    }
    if (originalFileName.empty()) {
        std::cerr << "Error: Original filename is missing." << std::endl;
        return "";
    }

    // Basic filename character check to avoid path traversal characters
    std::regex safe_filename_regex("^[a-zA-Z0-9._-]+$");
    if (originalFileName.find('/') != std::string::npos || originalFileName.find('\\') != std::string::npos || !std::regex_match(originalFileName, safe_filename_regex)) {
        std::cerr << "Warning: Original filename contains potentially unsafe characters." << std::endl;
    }

    // 2. Secure File Saving
    fs::path uploadsPath(UPLOADS_DIR);
    fs::path finalPath;
    fs::path tempPath;

    try {
        if (!fs::exists(uploadsPath)) {
            fs::create_directories(uploadsPath);
        } else if (!fs::is_directory(uploadsPath)) {
            std::cerr << "Error: Upload path exists but is not a directory." << std::endl;
            return "";
        }
        
        std::string uniqueFileName = generate_unique_filename();
        tempPath = uploadsPath / (uniqueFileName + ".tmp");
        
        std::ofstream tempFile(tempPath, std::ios::binary | std::ios::out);
        if (!tempFile.is_open()) {
            throw std::runtime_error("Could not create temporary file.");
        }
        tempFile.write(fileContent.data(), fileContent.size());
        tempFile.close();

        finalPath = (uploadsPath / uniqueFileName).lexically_normal();
        
        fs::path base_dir_abs = fs::absolute(uploadsPath).lexically_normal();
        fs::path final_path_abs = fs::absolute(finalPath).lexically_normal();

        if (final_path_abs.string().find(base_dir_abs.string()) != 0) {
            fs::remove(tempPath);
            std::cerr << "Error: Path resolution resulted in directory traversal attempt." << std::endl;
            return "";
        }

        fs::rename(tempPath, finalPath);

    } catch (const std::exception& e) {
        std::cerr << "Error saving file: " << e.what() << std::endl;
        if (fs::exists(tempPath)) fs::remove(tempPath);
        return "";
    }

    // 3. Database Interaction
    try {
        sql::mysql::MySQL_Driver *driver = sql::mysql::get_mysql_driver_instance();
        std::unique_ptr<sql::Connection> con(driver->connect(DB_HOST, DB_USER, DB_PASSWORD));
        con->setSchema(DB_NAME);

        std::unique_ptr<sql::PreparedStatement> pstmt(con->prepareStatement("INSERT INTO pdf_files (original_name, stored_path) VALUES (?, ?)"));
        
        std::string relativePath = finalPath.string();
        #ifdef _WIN32
            std::replace(relativePath.begin(), relativePath.end(), '\\', '/');
        #endif
        
        pstmt->setString(1, originalFileName);
        pstmt->setString(2, relativePath);
        pstmt->executeUpdate();

        return relativePath;
    } catch (const sql::SQLException &e) {
        std::cerr << "Database error: " << e.what();
        std::cerr << " (MySQL error code: " << e.getErrorCode();
        std::cerr << ", SQLState: " << e.getSQLState() << " )" << std::endl;
        // Clean up orphaned file
        if (fs::exists(finalPath)) fs::remove(finalPath);
        return "";
    }
}

