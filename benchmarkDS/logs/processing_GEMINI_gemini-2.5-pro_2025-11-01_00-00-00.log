import os
import uuid
import re
import tempfile
import io
import sys

# In a real application, this should be outside the web root and configured externally.
UPLOAD_DIRECTORY = "uploads"
MAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB

# A restrictive regex for validating the base name of a file.
# It allows alphanumeric characters, dots, underscores, and hyphens.
SAFE_FILENAME_REGEX = re.compile(r"^[a-zA-Z0-9._-]+$")

def upload_pdf(file_stream, original_filename):
    """
    Saves a PDF file to a secure location and records its path in the database.

    :param file_stream: A file-like object containing the file content.
    :param original_filename: The original name of the file provided by the user.
    :return: The canonical path of the saved file, or None on failure.
    """
    if not file_stream or not original_filename or not original_filename.strip():
        print("Error: File stream or original filename is missing.", file=sys.stderr)
        return None

    # 1. Sanitize and validate the filename
    base_name = os.path.basename(original_filename)
    if not SAFE_FILENAME_REGEX.match(base_name):
        print(f"Error: Filename '{base_name}' contains invalid characters.", file=sys.stderr)
        return None

    if not base_name.lower().endswith(".pdf"):
        print("Error: Invalid file type. Only PDF files are allowed.", file=sys.stderr)
        return None

    upload_dir_path = os.path.abspath(UPLOAD_DIRECTORY)
    
    try:
        # Create the directory if it doesn't exist with secure permissions
        os.makedirs(upload_dir_path, mode=0o750, exist_ok=True)

        # 2. Generate a unique filename
        unique_filename = f"{uuid.uuid4()}.pdf"
        final_path = os.path.join(upload_dir_path, unique_filename)

        # 3. Save the file securely using a temporary file for an atomic operation
        bytes_written = 0
        # Create the temp file in the same directory to ensure atomic move/rename
        with tempfile.NamedTemporaryFile(mode='wb', dir=upload_dir_path, delete=False) as tmp_file:
            temp_path = tmp_file.name
            while True:
                chunk = file_stream.read(4096)
                if not chunk:
                    break
                bytes_written += len(chunk)
                if bytes_written > MAX_FILE_SIZE:
                    tmp_file.close()
                    os.remove(temp_path)
                    print(f"Error: File size exceeds the maximum limit of {MAX_FILE_SIZE} bytes.", file=sys.stderr)
                    return None
                tmp_file.write(chunk)
        
        # Atomically rename the temporary file to its final destination
        os.replace(temp_path, final_path)
        # Set restrictive permissions on the final file
        os.chmod(final_path, 0o640)

        print(f"File saved successfully to: {final_path}")

        # 4. Save the file path to the database
        save_filepath_to_db(final_path)

        return final_path

    except (IOError, OSError) as e:
        print(f"Error during file operation: {e}", file=sys.stderr)
        # Clean up temp file if it exists and an error occurred after creation
        if 'temp_path' in locals() and os.path.exists(temp_path):
            os.remove(temp_path)
        return None

def save_filepath_to_db(filepath):
