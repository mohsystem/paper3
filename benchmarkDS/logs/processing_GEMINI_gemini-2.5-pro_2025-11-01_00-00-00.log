import java.io.IOException;
import java.io.InputStream;
import java.nio.ByteBuffer;
import java.nio.channels.FileChannel;
import java.nio.file.*;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.UUID;
import java.util.regex.Pattern;

// To compile and run this code, you need the MySQL JDBC driver.
// Download mysql-connector-java-*.jar and include it in your classpath.
// Example: javac Lse64.java
//          java -cp .:mysql-connector-java-8.0.28.jar Lse64
public class Lse64 {

    // --- Database Configuration ---
    // In a real application, use a secure way to manage credentials (e.g., environment variables, secrets manager)
    private static final String DB_URL = System.getenv("DB_URL") != null ? System.getenv("DB_URL") : "jdbc:mysql://localhost:3306/filedb";
    private static final String DB_USER = System.getenv("DB_USER") != null ? System.getenv("DB_USER") : "user";
    private static final String DB_PASS = System.getenv("DB_PASS") != null ? System.getenv("DB_PASS") : "password";

    // --- File Upload Configuration ---
    private static final String UPLOADS_DIR_NAME = "uploads";
    private static final Path UPLOADS_DIR = Paths.get(System.getProperty("user.dir"), UPLOADS_DIR_NAME);
    private static final long MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB
    private static final int MAX_FILENAME_LENGTH = 100;
    // Allow alphanumeric characters, dots, underscores, and hyphens.
    private static final Pattern VALID_FILENAME_PATTERN = Pattern.compile("^[a-zA-Z0-9._-]+$");

    /**
     * Uploads a PDF file by saving its content to a designated folder and recording its path in a database.
     *
     * @param fileName The original name of the uploaded file.
     * @param fileContent The byte content of the file.
     * @return The canonical path of the saved file, or null on failure.
     */
    public static String uploadPdf(String fileName, byte[] fileContent) {
        // 1. Input Validation
        if (fileName == null || fileName.trim().isEmpty()) {
            System.err.println("Error: File name cannot be null or empty.");
            return null;
        }
        if (fileContent == null || fileContent.length == 0) {
            System.err.println("Error: File content cannot be empty.");
            return null;
        }
        if (fileContent.length > MAX_FILE_SIZE) {
            System.err.println("Error: File size " + fileContent.length + " exceeds limit of " + MAX_FILE_SIZE + " bytes.");
            return null;
        }

        // 2. Sanitize filename to prevent path traversal
        String sanitizedFileName = Paths.get(fileName).getFileName().toString();
        if (sanitizedFileName.length() > MAX_FILENAME_LENGTH) {
            System.err.println("Error: Filename length exceeds limit of " + MAX_FILENAME_LENGTH + " characters.");
            return null;
        }
        if (!VALID_FILENAME_PATTERN.matcher(sanitizedFileName).matches() || !sanitizedFileName.toLowerCase().endsWith(".pdf")) {
            System.err.println("Error: Invalid filename. It must be a .pdf file and contain only safe characters.");
            return null;
        }
        
        // Use a unique name to avoid conflicts, while preserving the extension
        String uniqueFileName = UUID.randomUUID().toString() + ".pdf";

        Path filePath = UPLOADS_DIR.resolve(uniqueFileName);

        try {
            // Security check: ensure the final path resolves within the intended upload directory.
            if (!filePath.toRealPath().startsWith(UPLOADS_DIR.toRealPath())) {
                System.err.println("Error: Path traversal attempt detected and blocked.");
                return null;
            }
        } catch (IOException e) {
             // This can happen if the directory doesn't exist yet, we handle it below
        }

        // 3. Save the file to the filesystem securely
        try {
            Files.createDirectories(UPLOADS_DIR);
            // Use CREATE_NEW to prevent overwriting existing files and avoid TOCTOU vulnerabilities.
            try (FileChannel channel = FileChannel.open(filePath, StandardOpenOption.CREATE_NEW, StandardOpenOption.WRITE)) {
                ByteBuffer buffer = ByteBuffer.wrap(fileContent);
                while (buffer.hasRemaining()) {
                    channel.write(buffer);
                }
            }
        } catch (FileAlreadyExistsException e) {
            System.err.println("Error: A file with this name already exists: " + filePath);
            return null;
        } catch (IOException e) {
            System.err.println("Error saving file: " + e.getMessage());
            return null;
        }

        // 4. Save the filepath to the database
        String dbFilePath = filePath.toString();
        String sql = "INSERT INTO files (filepath) VALUES (?)";

        try (Connection conn = DriverManager.getConnection(DB_URL, DB_USER, DB_PASS);
             PreparedStatement pstmt = conn.prepareStatement(sql)) {

            pstmt.setString(1, dbFilePath);
            int affectedRows = pstmt.executeUpdate();

            if (affectedRows > 0) {
                System.out.println("Successfully saved file to " + dbFilePath + " and recorded in DB.");
                return dbFilePath;
            } else {
                System.err.println("Error: Failed to record filepath in database.");
                // Cleanup: delete the orphaned file
                try {
                    Files.deleteIfExists(filePath);
                } catch (IOException ex) {
                    System.err.println("Error cleaning up orphaned file: " + ex.getMessage());
                }
                return null;
            }
        } catch (SQLException e) {
            System.err.println("Database error: " + e.getMessage());
            // Cleanup: delete the orphaned file
            try {
                Files.deleteIfExists(filePath);
            } catch (IOException ex) {
                System.err.println("Error cleaning up orphaned file: " + ex.getMessage());
            }
            return null;
        }
    }

    public static void main(String[] args) {
        System.out.println("Starting PDF upload tests...");
        System.out.println("Uploads directory: " + UPLOADS_DIR.toAbsolutePath());
        System.out.println("NOTE: Ensure MySQL server is running and the database/table are set up.");
        System.out.println("CREATE DATABASE IF NOT EXISTS filedb;");
        System.out.println("USE filedb;");
        System.out.println("CREATE TABLE IF NOT EXISTS files (id INT AUTO_INCREMENT PRIMARY KEY, filepath VARCHAR(512) NOT NULL UNIQUE);");
        System.out.println("---");

        byte[] smallPdfContent = "Dummy PDF content.".getBytes();
        byte[] largePdfContent = new byte[(int) MAX_FILE_SIZE + 1];

        // Test Case 1: Successful upload
        System.out.println("Test 1: Uploading a valid file 'report.pdf'...");
        String savedPath1 = uploadPdf("report.pdf", smallPdfContent);
        System.out.println("Result: " + (savedPath1 != null ? "SUCCESS, path: " + savedPath1 : "FAILURE"));
        System.out.println("---");
        
        // Test Case 2: Path traversal attempt
        System.out.println("Test 2: Attempting path traversal with '../../etc/passwd.pdf'...");
        String savedPath2 = uploadPdf("../../etc/passwd.pdf", smallPdfContent);
        System.out.println("Result: " + (savedPath2 != null ? "SUCCESS, path: " + savedPath2 : "FAILURE (Expected, sanitized name used)"));
        System.out.println("---");

        // Test Case 3: File too large
        System.out.println("Test 3: Uploading a file that is too large...");
        String savedPath3 = uploadPdf("large_file.pdf", largePdfContent);
        System.out.println("Result: " + (savedPath3 != null ? "SUCCESS" : "FAILURE (Expected)"));
        System.out.println("---");

        // Test Case 4: Invalid filename
        System.out.println("Test 4: Uploading a file with an invalid name 'report<script>.pdf'...");
        String savedPath4 = uploadPdf("report<script>.pdf", smallPdfContent);
        System.out.println("Result: " + (savedPath4 != null ? "SUCCESS" : "FAILURE (Expected)"));
        System.out.println("---");
        
        // Test Case 5: Null filename
        System.out.println("Test 5: Uploading with a null filename...");
        String savedPath5 = uploadPdf(null, smallPdfContent);
        System.out.println("Result: " + (savedPath5 != null ? "SUCCESS" : "FAILURE (Expected)"));
        System.out.println("---");
    }
}
