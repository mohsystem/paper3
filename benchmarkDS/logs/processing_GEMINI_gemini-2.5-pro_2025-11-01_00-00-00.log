        if (fileContent == null || originalFileName == null || originalFileName.trim().isEmpty()) {
            System.err.println("Error: File content or original filename is null or empty.");
            return null;
        }

        // 1. Sanitize and validate the filename
        Path originalPath = Paths.get(originalFileName);
        String baseName = originalPath.getFileName().toString();

        if (!SAFE_FILENAME_PATTERN.matcher(baseName).matches()) {
            System.err.println("Error: Original filename contains invalid characters.");
            return null;
        }

        if (!baseName.toLowerCase().endsWith(".pdf")) {
            System.err.println("Error: Invalid file type. Only PDF files are allowed.");
            return null;
        }

        Path uploadDirPath = Paths.get(UPLOAD_DIR).toAbsolutePath();

        try {
            // Create the directory if it doesn't exist
            Files.createDirectories(uploadDirPath);

            // 2. Generate a unique filename to prevent collisions and path traversal
            String uniqueFileName = UUID.randomUUID().toString() + ".pdf";
            Path finalPath = uploadDirPath.resolve(uniqueFileName);

            // Redundant check, but good for defense-in-depth
            if (!finalPath.toAbsolutePath().normalize().startsWith(uploadDirPath)) {
                 System.err.println("Error: Path validation failed. Potential directory traversal attempt.");
                 return null;
            }

            // 3. Save the file securely (write to temp file and move)
            Path tempFile = Files.createTempFile(uploadDirPath, "upload-", ".tmp");
            long bytesWritten = 0;
            try (OutputStream os = Files.newOutputStream(tempFile)) {
                byte[] buffer = new byte[4096];
                int bytesRead;
                while ((bytesRead = fileContent.read(buffer)) != -1) {
                    bytesWritten += bytesRead;
                    if (bytesWritten > MAX_FILE_SIZE) {
                        Files.delete(tempFile);
                        System.err.println("Error: File size exceeds the maximum limit of " + MAX_FILE_SIZE + " bytes.");
                        return null;
                    }
                    os.write(buffer, 0, bytesRead);
                }
            }
            
            // Atomically move the temporary file to its final destination
            Files.move(tempFile, finalPath, StandardCopyOption.ATOMIC_MOVE);

            String savedFilePath = finalPath.toString();
            System.out.println("File saved successfully to: " + savedFilePath);
            
            // 4. Save the file path to the database
