#include <mysql-cppconn-8/mysql/jdbc.h>


// --- Configuration ---
// In a real application, these would be in a configuration file or environment variables.
const std::filesystem::path UPLOADS_DIR = std::filesystem::absolute("uploads");
const size_t MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB

// --- Database Configuration ---
// IMPORTANT: Never hardcode credentials in production code.
const std::string DB_HOST = "tcp://127.0.0.1:3306";
const std::string DB_USER = "dbuser";
const std::string DB_PASSWORD = "dbpassword"; // Placeholder
const std::string DB_NAME = "filedb";

// Generates a UUID-like random string for a safe filename
std::string generate_safe_filename() {
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> distrib(0, 255);
    
    std::stringstream ss;
    ss << std::hex;
    for (int i = 0; i < 16; ++i) {
        ss << distrib(gen);
    }
    return ss.str();
}

/**
 * Uploads a PDF file from its content bytes.
 * The file is saved to a configured directory with a unique name,
 * and its path is stored in a MySQL database.
 *
 * @param file_content The byte content of the file as a vector of chars.
 * @param original_filename The original filename provided by the user.
 * @return The path where the file was saved, or an empty string on failure.
 */
std::string upload_pdf(const std::vector<char>& file_content, const std::string& original_filename) {
    if (file_content.empty() || original_filename.empty()) {
        std::cerr << "Error: File content or original filename is empty." << std::endl;
        return "";
    }

    // 1. Validate file size
    if (file_content.size() > MAX_FILE_SIZE) {
        std::cerr << "Error: File size exceeds the " << (MAX_FILE_SIZE / (1024 * 1024)) << " MB limit." << std::endl;
        return "";
    }

    // 2. Validate and Sanitize Filename
    std::filesystem::path original_path(original_filename);
    std::string extension = original_path.extension().string();
    std::transform(extension.begin(), extension.end(), extension.begin(), ::tolower);
    if (extension != ".pdf") {
        std::cerr << "Error: Invalid file type. Only PDF files are allowed." << std::endl;
        return "";
    }
    // Note: For better security, also validate the file's magic number (e.g., starts with %PDF-).

    // Generate a new, secure filename.
    std::string new_filename_str = generate_safe_filename() + ".pdf";
    std::filesystem::path destination_path = UPLOADS_DIR / new_filename_str;
    
    // Security check to prevent path traversal after path combination
    auto canonical_dest = std::filesystem::weakly_canonical(destination_path);
    if (canonical_dest.string().rfind(UPLOADS_DIR.string(), 0) != 0) {
        std::cerr << "Error: Invalid path detected (path traversal attempt)." << std::endl;
        return "";
    }

    try {
        // Ensure the uploads directory exists.
        std::filesystem::create_directories(UPLOADS_DIR);

        // 3. Save the file to the filesystem.
        std::ofstream outfile(destination_path, std::ios::binary);
        if (!outfile.is_open()) {
            throw std::runtime_error("Could not open file for writing: " + destination_path.string());
        }
        outfile.write(file_content.data(), file_content.size());
        outfile.close();

        // 4. Save the filepath to the database.
        // This part will fail if the DB or connector is not configured correctly.
        try {
            sql::Driver *driver = get_driver_instance();
            std::unique_ptr<sql::Connection> con(driver->connect(DB_HOST, DB_USER, DB_PASSWORD));
            con->setSchema(DB_NAME);
            
            std::unique_ptr<sql::PreparedStatement> pstmt(con->prepareStatement("INSERT INTO files (filepath) VALUES (?)"));
            pstmt->setString(1, destination_path.string());
            pstmt->executeUpdate();
            
        } catch (sql::SQLException &e) {
            std::cerr << "Database Error: " << e.what() << " (MySQL error code: " << e.getErrorCode() << ")" << std::endl;
            // If DB operation fails, remove the orphaned file.
            std::filesystem::remove(destination_path);
            return "";
        }

        std::cout << "File uploaded successfully to: " << destination_path << std::endl;
        return destination_path.string();

    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        // Attempt to clean up if file was partially created
        if(std::filesystem::exists(destination_path)){
            std::filesystem::remove(destination_path);
        }
        return "";
    }
}


int main() {
    std::cout << "Running test cases..." << std::endl;
    std::cout << "--- NOTE: Database operations will fail without a configured MySQL server and Connector/C++. ---" << std::endl;

    // Test Case 1: Valid PDF upload
    std::cout << "\n[Test Case 1: Valid PDF upload]" << std::endl;
    std::vector<char> valid_content = {'%', 'P', 'D', 'F', '-', '1', '.', '4'};
    upload_pdf(valid_content, "document.pdf");

    // Test Case 2: File too large
    std::cout << "\n[Test Case 2: File too large]" << std::endl;
    std::vector<char> large_content(MAX_FILE_SIZE + 1, 'a');
    upload_pdf(large_content, "large.pdf");

    // Test Case 3: Invalid file type
    std::cout << "\n[Test Case 3: Invalid file type]" << std::endl;
    std::vector<char> text_content = {'s', 'o', 'm', 'e', ' ', 't', 'e', 'x', 't'};
    upload_pdf(text_content, "document.txt");

    // Test Case 4: Filename with path traversal characters (should be sanitized by `filesystem::path`)
    std::cout << "\n[Test Case 4: Path traversal attempt]" << std::endl;
    upload_pdf(valid_content, "../../etc/passwd.pdf");

    // Test Case 5: Empty input
    std::cout << "\n[Test Case 5: Empty input]" << std::endl;
    upload_pdf({}, "");

    // Clean up created files in the uploads directory
    std::cout << "\nCleaning up test files..." << std::endl;
    if (std::filesystem::exists(UPLOADS_DIR)) {
        for (const auto& entry : std::filesystem::directory_iterator(UPLOADS_DIR)) {
