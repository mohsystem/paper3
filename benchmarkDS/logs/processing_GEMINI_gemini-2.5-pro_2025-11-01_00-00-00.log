            std::cout << "File content: " << content << std::endl;
        } else {
            std::cerr << "Failed to read back file content." << std::endl;
        }
    } else {
        std::cerr << "Failed to write to " << fileName << std::endl;
    }
    std::cout << "---" << std::endl;
}

int main() {
