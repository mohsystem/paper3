    const char* content5 = "%PDF-1.4\ncontent";
    FILE* stream5 = fmemopen((void*)content5, strlen(content5), "r");
    if (stream5) {
        saved_path = upload_pdf(stream5, "file<script>.pdf");
        if (saved_path) free(saved_path);
        fclose(stream5);
    }
    
    return 0;
}
