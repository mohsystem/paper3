#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>
#include <regex.h>
#include <errno.h>

// For filesystem and path operations
#include <sys/stat.h>
#include <sys/types.h>
#include <fcntl.h>
#include <unistd.h>
#include <libgen.h> // For basename()
#include <limits.h> // For PATH_MAX

#define UPLOADS_DIR "uploads"
#define MAX_FILE_SIZE (10 * 1024 * 1024) // 10 MB

/**
 * Mock function to simulate saving the filepath to a MySQL database.
 * Real implementation should use a database library with prepared statements.
 */
void saveFilepathInDB(const char* filepath) {
    printf("DATABASE: Attempting to save filepath '%s'\n", filepath);
    // In a real application with a library like libmysqlclient:
    // MYSQL_STMT* stmt = mysql_stmt_init(conn);
    // mysql_stmt_prepare(stmt, "INSERT INTO files (filepath) VALUES (?)", ...);
    // ... bind parameters and execute ...
    printf("DATABASE: (Mock) Successfully executed: INSERT INTO files (filepath) VALUES ('%s')\n", filepath);
}

/**
 * Validates a filename against a safe character whitelist.
 */
bool isValidFilename(const char* filename) {
    regex_t regex;
    int reti;
    bool result = false;

    // Allows letters, numbers, dot, underscore, hyphen.
    reti = regcomp(&regex, "^[a-zA-Z0-9._-]+$", REG_EXTENDED | REG_NOSUB);
    if (reti) {
        fprintf(stderr, "ERROR: Could not compile regex\n");
        return false;
    }

    reti = regexec(&regex, filename, 0, NULL, 0);
    if (reti == 0) {
        result = true;
    } else if (reti != REG_NOMATCH) {
        char msgbuf[100];
        regerror(reti, &regex, msgbuf, sizeof(msgbuf));
        fprintf(stderr, "ERROR: Regex match failed: %s\n", msgbuf);
    }
    
    regfree(&regex);
    return result;
}


/**
 * Uploads a PDF file, saving it to a designated folder and recording the path.
 *
 * @param originalFilename The filename as provided by the user.
 * @param fileContent      The binary content of the file.
 * @param contentLength    The length of the file content.
 * @return true if the upload was successful, false otherwise.
 */
bool uploadPdf(const char* originalFilename, const char* fileContent, size_t contentLength) {
    if (originalFilename == NULL || fileContent == NULL || contentLength == 0) {
        fprintf(stderr, "ERROR: Filename or content is empty.\n");
        return false;
    }
    
    if (contentLength > MAX_FILE_SIZE) {
        fprintf(stderr, "ERROR: File size exceeds the maximum limit of %d bytes.\n", MAX_FILE_SIZE);
        return false;
    }

    // Use a copy because basename() can modify its argument.
    char* original_path_copy = strdup(originalFilename);
    if (original_path_copy == NULL) {
        fprintf(stderr, "ERROR: Memory allocation failed for path copy.\n");
        return false;
    }
    char* base_name = basename(original_path_copy);
    if (!isValidFilename(base_name)) {
        fprintf(stderr, "ERROR: Filename contains invalid characters: %s\n", base_name);
        free(original_path_copy);
        return false;
    }

    mkdir(UPLOADS_DIR, 0755);

    int dir_fd = open(UPLOADS_DIR, O_RDONLY | O_DIRECTORY);
    if (dir_fd == -1) {
        fprintf(stderr, "ERROR: Could not open directory '%s': %s\n", UPLOADS_DIR, strerror(errno));
        free(original_path_copy);
        return false;
    }

    int fd = openat(dir_fd, base_name, O_WRONLY | O_CREAT | O_EXCL, 0600);
    if (fd == -1) {
        if (errno == EEXIST) {
            fprintf(stderr, "ERROR: File already exists: %s/%s\n", UPLOADS_DIR, base_name);
        } else {
            fprintf(stderr, "ERROR: Could not create file '%s': %s\n", base_name, strerror(errno));
        }
        close(dir_fd);
        free(original_path_copy);
        return false;
    }

    ssize_t bytes_written_total = 0;
    while(bytes_written_total < contentLength) {
        ssize_t bytes_written = write(fd, fileContent + bytes_written_total, contentLength - bytes_written_total);
        if (bytes_written < 0) {
            fprintf(stderr, "ERROR: Failed to write to file: %s\n", strerror(errno));
            close(fd);
            close(dir_fd);
            char final_path[PATH_MAX];
            snprintf(final_path, sizeof(final_path), "%s/%s", UPLOADS_DIR, base_name);
            unlink(final_path);
            free(original_path_copy);
            return false;
        }
        bytes_written_total += bytes_written;
    }
    
    close(fd);
    close(dir_fd);

    char final_path[PATH_MAX];
    int len = snprintf(final_path, sizeof(final_path), "%s/%s", UPLOADS_DIR, base_name);
    if (len >= sizeof(final_path)) {
        fprintf(stderr, "ERROR: Constructed file path is too long.\n");
        free(original_path_copy);
        return false;
    }
    
    printf("SUCCESS: File saved to %s\n", final_path);
    
    saveFilepathInDB(final_path);
    
    free(original_path_copy);
    return true;
}


int main() {
    const char* pdfContent = "%PDF-1.4\n...dummy content...";
    size_t pdfContentLength = strlen(pdfContent);

    printf("--- Running Test Cases ---\n");

    // Test Case 1: Valid filename
    printf("\n[Test 1] Valid file\n");
    uploadPdf("report-2023.pdf", pdfContent, pdfContentLength);

    // Test Case 2: Valid filename, attempt to overwrite
    printf("\n[Test 2] Attempt to overwrite existing file\n");
    uploadPdf("report-2023.pdf", pdfContent, pdfContentLength);

    // Test Case 3: Invalid filename with special characters
    printf("\n[Test 3] Invalid characters in filename\n");
    uploadPdf("file<script>.pdf", pdfContent, pdfContentLength);

    // Test Case 4: Path traversal attempt
    printf("\n[Test 4] Path traversal attempt\n");
    uploadPdf("../../../etc/passwd", pdfContent, pdfContentLength);

    // Test Case 5: Another valid file
    printf("\n[Test 5] Another valid file\n");
    uploadPdf("annual_summary_v2.pdf", pdfContent, pdfContentLength);

    printf("\n--- Test Cases Finished ---\n");
    
    unlink(UPLOADS_DIR "/report-2023.pdf");
    unlink(UPLOADS_DIR "/annual_summary_v2.pdf");

    return 0;
}
