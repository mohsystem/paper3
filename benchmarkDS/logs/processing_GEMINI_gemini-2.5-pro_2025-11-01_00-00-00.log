import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.util.UUID;
import java.util.logging.Level;
import java.util.logging.Logger;

public class Lse64 {

    private static final String UPLOADS_DIR = "uploads";
    private static final long MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB
    private static final String ALLOWED_EXTENSION = ".pdf";

    // Database credentials should be read from a secure source, like environment variables.
    // Fallback to defaults for standalone example.
    private static final String DB_URL = System.getenv("DB_URL") != null ? System.getenv("DB_URL") : "jdbc:mysql://localhost:3306/file_db";
    private static final String DB_USER = System.getenv("DB_USER") != null ? System.getenv("DB_USER") : "user";
    private static final String DB_PASSWORD = System.getenv("DB_PASSWORD") != null ? System.getenv("DB_PASSWORD") : "password";

    private static final Logger LOGGER = Logger.getLogger(Lse64.class.getName());

    /**
     * Uploads a PDF file, saves it to a secure location, and records its path in the database.
     *
     * @param originalFilename The original filename provided by the user.
     * @param fileContent      The byte content of the file.
     * @return true on success, false on failure.
     */
    public static boolean uploadPdf(String originalFilename, byte[] fileContent) {
        if (fileContent == null || fileContent.length == 0 || fileContent.length > MAX_FILE_SIZE) {
            LOGGER.log(Level.WARNING, "File content is invalid or exceeds max size.");
            return false;
        }

        if (originalFilename == null || originalFilename.isEmpty()) {
            LOGGER.log(Level.WARNING, "Original filename is null or empty.");
            return false;
        }

        // Normalize filename to prevent path traversal in the name itself.
        String cleanFilename = Paths.get(originalFilename).getFileName().toString();
        if (!cleanFilename.toLowerCase().endsWith(ALLOWED_EXTENSION)) {
            LOGGER.log(Level.WARNING, "Invalid file extension: {0}", cleanFilename);
            return false;
        }
        
        // Generate a new, secure filename to prevent path traversal and other attacks
        String secureFilename = UUID.randomUUID().toString() + ALLOWED_EXTENSION;
        Path destinationPath = Paths.get(UPLOADS_DIR, secureFilename);


        try {
            // Create the uploads directory if it doesn't exist
            Files.createDirectories(Paths.get(UPLOADS_DIR));
            // Save the file
            Files.write(destinationPath, fileContent);
        } catch (IOException e) {
            LOGGER.log(Level.SEVERE, "Failed to save file.", e);
            return false;
        }

        // Save the filepath to the database
        String sql = "INSERT INTO pdf_files (filepath) VALUES (?)";
        try (Connection conn = DriverManager.getConnection(DB_URL, DB_USER, DB_PASSWORD);
             PreparedStatement pstmt = conn.prepareStatement(sql)) {

            pstmt.setString(1, secureFilename);
            int affectedRows = pstmt.executeUpdate();
            
            if (affectedRows > 0) {
                 System.out.println("Successfully uploaded " + originalFilename + " as " + secureFilename);
                 return true;
            } else {
                 LOGGER.log(Level.SEVERE, "Database insert failed, no rows affected.");
                 // Clean up the saved file if DB insert fails
                 try {
                     Files.deleteIfExists(destinationPath);
                 } catch (IOException e) {
                     LOGGER.log(Level.SEVERE, "Failed to delete orphaned file.", e);
                 }
                 return false;
            }

        } catch (SQLException e) {
            LOGGER.log(Level.SEVERE, "Database error occurred.", e);
            // Clean up the saved file if DB insert fails
            try {
                Files.deleteIfExists(destinationPath);
            } catch (IOException ioException) {
                LOGGER.log(Level.SEVERE, "Failed to delete orphaned file after DB error.", ioException);
            }
            return false;
        }
    }

    public static void main(String[] args) {
        // NOTE: This main method requires a running MySQL server with the specified
        // database and table.
        // CREATE DATABASE IF NOT EXISTS file_db;
        // USE file_db;
        // CREATE TABLE IF NOT EXISTS pdf_files (
